    rdfs:label 'Energy Balance Mj' ;
    rdfs:comment 'Total energy consumption or balance for the simulated scale-up run, expressed in megajoules.' ;
    rdfs:domain ind:ScaleUpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:phaseEquilibriumStatus rdf:type rdf:Property ;
    rdfs:label 'Phase Equilibrium Status' ;
    rdfs:comment 'Result of phase-equilibrium analysis for the scale-up (stable, unstable, or not applicable).' ;
    rdfs:domain ind:ScaleUpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scaleFactor rdf:type rdf:Property ;
    rdfs:label 'Scale Factor' ;
    rdfs:comment 'Multiplier applied to the laboratory batch size to reach the target scale.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scaleUpNumber rdf:type rdf:Property ;
    rdfs:label 'Scale Up Number' ;
    rdfs:comment 'Business-visible identifier assigned to the scale-up event.' ;
    rdfs:domain ind:ScaleUpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scaleUpRecordStatus rdf:type rdf:Property ;
    rdfs:label 'Scale Up Record Status' ;
    rdfs:comment 'Current lifecycle status of the scale-up record.' ;
    rdfs:domain ind:ScaleUpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scaleUpTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scale Up Timestamp' ;
    rdfs:comment 'Date and time when the scale-up transition was executed.' ;
    rdfs:domain ind:ScaleUpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:simulationConversionRatePercent rdf:type rdf:Property ;
    rdfs:label 'Simulation Conversion Rate Percent' ;
    rdfs:comment 'Predicted conversion rate from reactants to product in the simulation.' ;
    rdfs:domain ind:ScaleUpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:simulationYieldPredictionPercent rdf:type rdf:Property ;
    rdfs:label 'Simulation Yield Prediction Percent' ;
    rdfs:comment 'Yield percentage predicted by the simulation model.' ;
    rdfs:domain ind:ScaleUpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceFormulaVersion rdf:type rdf:Property ;
    rdfs:label 'Source Formula Version' ;
    rdfs:comment 'Version label of the original laboratory-scale formula.' ;
    rdfs:domain ind:ScaleUpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetScale rdf:type rdf:Property ;
    rdfs:label 'Target Scale' ;
    rdfs:comment 'Intended production scale for the formulation (lab, pilot, or commercial).' ;
    rdfs:domain ind:ScaleUpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationDate rdf:type rdf:Property ;
    rdfs:label 'Validation Date' ;
    rdfs:comment 'Date on which the simulation was compared to actual production results.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:yieldPercent rdf:type rdf:Property ;
    rdfs:label 'Yield Percent' ;
    rdfs:comment 'Actual product yield achieved at the target scale, expressed as a percent of theoretical maximum.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validationBatchId rdf:type rdf:Property ;
    rdfs:label 'Validation Batch Id' ;
    rdfs:comment 'System-generated unique identifier for the validation batch record.' ;
    rdfs:domain ind:ValidationBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inspectionLotId rdf:type rdf:Property ;
    rdfs:label 'Inspection Lot Id' ;
    rdfs:comment 'Foreign key linking to quality.inspection_lot. Business justification: Validation batches are inspected; linking to the inspection lot enables traceability of validation outcomes.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InspectionLot .

ind:batchType rdf:type rdf:Property ;
    rdfs:label 'Batch Type' ;
    rdfs:comment 'Classification of the batch (e.g., pilot, scale-up, full production, lab).' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataCaptureSystem rdf:type rdf:Property ;
    rdfs:label 'Data Capture System' ;
    rdfs:comment 'System that captured the process data for the batch.' ;
    rdfs:domain ind:ValidationBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataCaptureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Data Capture Timestamp' ;
    rdfs:comment 'Timestamp when the batch data was ingested into the lakehouse.' ;
    rdfs:domain ind:ValidationBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:impurityPpm rdf:type rdf:Property ;
    rdfs:label 'Impurity Ppm' ;
    rdfs:comment 'Measured impurity concentration expressed in parts per million.' ;
    rdfs:domain ind:ValidationBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:materialBatchNumber rdf:type rdf:Property ;
    rdfs:label 'Material Batch Number' ;
    rdfs:comment 'Lot number of the primary raw material batch used in the validation.' ;
    rdfs:domain ind:ValidationBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialSource rdf:type rdf:Property ;
    rdfs:label 'Material Source' ;
    rdfs:comment 'Source identifier of the primary raw material used (e.g., vendor code).' ;
    rdfs:domain ind:ValidationBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phValue rdf:type rdf:Property ;
    rdfs:label 'Ph Value' ;
    rdfs:comment 'Measured pH of the batch.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pressureSetpointBar rdf:type rdf:Property ;
    rdfs:label 'Pressure Setpoint Bar' ;
    rdfs:comment 'Target pressure setpoint for the process in bar.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Process End Timestamp' ;
    rdfs:comment 'Timestamp when the batch processing completed.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:processStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Process Start Timestamp' ;
    rdfs:comment 'Timestamp when the batch processing started.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:qualityIssueDescription rdf:type rdf:Property ;
    rdfs:label 'Quality Issue Description' ;
    rdfs:comment 'Description of any quality issue observed during the batch.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityIssueFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Issue Flag' ;
    rdfs:comment 'Indicates if any quality issue was recorded for the batch.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Review Status' ;
    rdfs:comment 'Current status of the regulatory review for the batch.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyIncidentFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Incident Flag' ;
    rdfs:comment 'Flag indicating whether any safety incident occurred during the batch.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:temperatureSetpointC rdf:type rdf:Property ;
    rdfs:label 'Temperature Setpoint C' ;
    rdfs:comment 'Target temperature setpoint for the process in degrees Celsius.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validationBatchStatus rdf:type rdf:Property ;
    rdfs:label 'Validation Batch Status' ;
    rdfs:comment 'Current lifecycle status of the validation batch.' ;
    rdfs:domain ind:ValidationBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationOutcome rdf:type rdf:Property ;
    rdfs:label 'Validation Outcome' ;
    rdfs:comment 'Result of the validation batch indicating pass, fail, or conditional status.' ;
    rdfs:domain ind:ValidationBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consignmentStockId rdf:type rdf:Property ;
    rdfs:label 'Consignment Stock Id' ;
    rdfs:comment 'Unique surrogate identifier for each consignment stock record in the Chemical Mfg inventory system. Primary key for the consignment_stock data product.' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:agingDays rdf:type rdf:Property ;
    rdfs:label 'Aging Days' ;
    rdfs:comment 'Number of calendar days the consignment stock has been held at the manufacturer\'s premises since receipt date. Used for vendor-managed inventory (VMI) performance monitoring, slow-moving stock identification, and consignment agreement compliance (maximum holding period enforcement).' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:consignmentQuantity rdf:type rdf:Property ;
    rdfs:label 'Consignment Quantity' ;
    rdfs:comment 'Current quantity of vendor-owned consignment stock on hand at the manufacturer\'s premises, expressed in the base unit of measure. Represents the unreceived (not yet financially owned) stock balance.' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consignmentStockStatus rdf:type rdf:Property ;
    rdfs:label 'Consignment Stock Status' ;
    rdfs:comment 'Current lifecycle status of the consignment stock record. \'active\' = vendor-owned stock available for consumption; \'consumed\' = fully consumed and liability transferred; \'partially_consumed\' = partially drawn down; \'returned\' = returned to vendor; \'expired\' = past expiration date; \'quarantine\' = held pending quality disposition.' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consignmentValue rdf:type rdf:Property ;
    rdfs:label 'Consignment Value' ;
    rdfs:comment 'Total financial value of the current consignment stock on hand, calculated as consignment_quantity multiplied by valuation_price. Used for balance sheet disclosure of vendor-owned stock, financial reporting, and off-balance-sheet liability tracking under FASB ASC 330 and SOX.' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consumedQuantity rdf:type rdf:Property ;
    rdfs:label 'Consumed Quantity' ;
    rdfs:comment 'Cumulative quantity of consignment stock that has been consumed (goods-issued to production or other cost centers) and for which financial liability has been transferred to the manufacturer. Used for settlement reconciliation and VMI performance reporting.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consumptionTrigger rdf:type rdf:Property ;
    rdfs:label 'Consumption Trigger' ;
    rdfs:comment 'The agreed business event that triggers financial liability transfer from vendor to manufacturer for consignment stock. Defines when ownership and payable obligation are created. Aligned with SAP MM consignment settlement process.' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsReceiptNumber rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Number' ;
    rdfs:comment 'SAP material document number generated when the consignment stock was physically received at the plant (MIGO goods receipt against consignment PO). Used for traceability and audit trail of stock movements.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastConsumptionDate rdf:type rdf:Property ;
    rdfs:label 'Last Consumption Date' ;
    rdfs:comment 'Date of the most recent goods issue (consumption) from this consignment stock lot. Used for slow-moving stock analysis, VMI replenishment planning, and consignment agreement compliance monitoring.' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:liabilityTransferDate rdf:type rdf:Property ;
    rdfs:label 'Liability Transfer Date' ;
    rdfs:comment 'Date on which financial ownership and payable liability for the consignment stock transferred from the vendor to the manufacturer, triggered by the agreed consumption event. Used for accounts payable accrual and financial period-end reporting under SOX and FASB ASC 330.' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maximumHoldingDays rdf:type rdf:Property ;
    rdfs:label 'Maximum Holding Days' ;
    rdfs:comment 'Maximum number of days the consignment stock may be held at the manufacturer\'s premises per the consignment agreement before automatic return or forced consumption. Breach of this threshold may trigger penalty clauses or mandatory settlement.' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maximumStockLevel rdf:type rdf:Property ;
    rdfs:label 'Maximum Stock Level' ;
    rdfs:comment 'Maximum quantity of consignment stock permitted at the manufacturer\'s premises per the VMI or consignment agreement. Prevents over-stocking of hazardous chemicals and ensures compliance with site storage limits under OSHA PSM and EPA RMP.' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumStockLevel rdf:type rdf:Property ;
    rdfs:label 'Minimum Stock Level' ;
    rdfs:comment 'Minimum quantity of consignment stock that must be maintained at the manufacturer\'s premises per the VMI agreement to ensure uninterrupted production supply. Triggers vendor replenishment when consignment_quantity falls below this threshold.' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plantCode rdf:type rdf:Property ;
    rdfs:label 'Plant Code' ;
    rdfs:comment 'SAP plant code identifying the manufacturing site or facility where the consignment stock is physically located. Used for plant-level inventory reporting and regulatory site compliance.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Number' ;
    rdfs:comment 'SAP purchase order number associated with the consignment stock receipt. For consignment arrangements, this is typically a consignment PO (order type KE or KB in SAP MM) that governs the replenishment and settlement terms.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quarantineFlag rdf:type rdf:Property ;
    rdfs:label 'Quarantine Flag' ;
    rdfs:comment 'Indicates whether the consignment stock lot is currently placed under quality quarantine and restricted from consumption pending laboratory testing or quality disposition. Integrates with LabWare LIMS quality hold status and SAP QM usage decision.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quarantineReason rdf:type rdf:Property ;
    rdfs:label 'Quarantine Reason' ;
    rdfs:comment 'Reason code for placing the consignment stock under quarantine. OOS (Out of Specification), OOT (Out of Trend), vendor deviation, physical damage, contamination suspicion, pending COA (Certificate of Analysis), or regulatory hold. Supports CAPA initiation and quality investigation. [ENUM-REF-CANDIDATE: oos_result|oot_result|vendor_deviation|damaged|contamination_suspect|pending_coa|regulatory_hold — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptDate rdf:type rdf:Property ;
    rdfs:label 'Receipt Date' ;
    rdfs:comment 'Date on which the vendor-owned consignment stock was physically received and placed at the manufacturer\'s premises. Used for aging calculation, FIFO/FEFO rotation, and consignment agreement compliance tracking.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:retestDate rdf:type rdf:Property ;
    rdfs:label 'Retest Date' ;
    rdfs:comment 'Date by which the consignment lot must be retested by the quality laboratory to confirm continued conformance to specification before use. Common for chemical raw materials with defined shelf-life stability windows. Sourced from LabWare LIMS batch records.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:returnedQuantity rdf:type rdf:Property ;
    rdfs:label 'Returned Quantity' ;
    rdfs:comment 'Quantity of consignment stock returned to the vendor without consumption, typically due to quality rejection, expiration, or excess inventory. Recorded as a consignment return movement in SAP MM.' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Settlement Document Number' ;
    rdfs:comment 'SAP document number generated by the consignment settlement run (transaction MRKO) when consumed consignment stock is invoiced and liability is transferred to accounts payable. Used for financial reconciliation and audit.' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageBin rdf:type rdf:Property ;
    rdfs:label 'Storage Bin' ;
    rdfs:comment 'Specific warehouse bin, tank number, or silo identifier within the storage location where the consignment material is physically stored. Supports hazardous material segregation and OSHA PSM compliance.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageTemperatureMaxC rdf:type rdf:Property ;
    rdfs:label 'Storage Temperature Max C' ;
    rdfs:comment 'Maximum permitted storage temperature in degrees Celsius for the consignment material as specified in the SDS or vendor COA. Critical for flammable, reactive, or thermally unstable chemical feedstocks.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageTemperatureMinC rdf:type rdf:Property ;
    rdfs:label 'Storage Temperature Min C' ;
    rdfs:comment 'Minimum required storage temperature in degrees Celsius for the consignment material as specified in the SDS or vendor COA. Ensures compliant storage conditions for temperature-sensitive chemicals and prevents degradation or hazardous reactions.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valuationPrice rdf:type rdf:Property ;
    rdfs:label 'Valuation Price' ;
    rdfs:comment 'Agreed unit price at which the consignment stock will be valued upon consumption and liability transfer. Used for inventory valuation, COGS calculation, and accounts payable settlement. Sourced from SAP MM purchasing info record or consignment agreement.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:classificationSystem rdf:type rdf:Property ;
    rdfs:label 'Classification System' ;
    rdfs:comment 'Primary hazard classification system under which this storage rule is defined (e.g., GHS for global chemical classification, NFPA for US fire codes, UN for transport, IMDG for maritime, CLP for EU). Determines which regulatory framework governs the rule\'s applicability. [ENUM-REF-CANDIDATE: GHS|NFPA|UN|DOT|IMDG|IATA|CLP|WHMIS — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:HazmatStorageRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epaRegulatoryCitation rdf:type rdf:Property ;
    rdfs:label 'Epa Regulatory Citation' ;
    rdfs:comment 'Specific EPA regulatory citation (CFR part and section) that mandates or informs this storage rule (e.g., \'40 CFR Part 112\', \'40 CFR Part 68 RMP\', \'40 CFR Part 264 Subpart I\'). Used in environmental compliance reporting and audit documentation submitted to EPA.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fireSuppressionRequired rdf:type rdf:Property ;
    rdfs:label 'Fire Suppression Required' ;
    rdfs:comment 'Indicates whether an automatic fire suppression system (sprinkler, deluge, foam, or dry chemical) is required at the storage location for chemicals governed by this rule. Drives facility engineering requirements and influences NFPA 400 maximum allowable quantity multipliers.' ;
    rdfs:domain ind:HazmatStorageRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fireZoneType rdf:type rdf:Property ;
    rdfs:label 'Fire Zone Type' ;
    rdfs:comment 'Classification of the fire zone or control area type to which the maximum quantity limit applies. NFPA 400 and IFC allow higher MAQ in sprinklered buildings versus unprotected control areas. Drives differentiated quantity limits in SAP EWM storage type configuration.' ;
    rdfs:domain ind:HazmatStorageRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ghsHazardStatementCodes rdf:type rdf:Property ;
    rdfs:label 'Ghs Hazard Statement Codes' ;
    rdfs:comment 'Comma-separated list of GHS H-statement codes applicable to chemicals governed by this rule (e.g., H225,H302,H314). Drives SDS Section 2 alignment and label generation. Used in REACH and CLP regulatory reporting.' ;
    rdfs:domain ind:HazmatStorageRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groundingBondingRequired rdf:type rdf:Property ;
    rdfs:label 'Grounding Bonding Required' ;
    rdfs:comment 'Indicates whether electrical grounding and bonding equipment is required at the storage location for chemicals governed by this rule. Mandatory for flammable liquids with flash points below 100°F to prevent static discharge ignition per NFPA 77 and OSHA standards.' ;
    rdfs:domain ind:HazmatStorageRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazardSubRisk rdf:type rdf:Property ;
    rdfs:label 'Hazard Sub Risk' ;
    rdfs:comment 'Secondary hazard classification or division providing additional specificity within the primary hazard class (e.g., Division 1.1 for mass explosion risk, Packing Group I/II/III, sub-risk 6.1 on a Class 3 flammable). Captures multi-hazard chemical profiles per GHS and UN regulations.' ;
    rdfs:domain ind:HazmatStorageRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incompatibilityConsequence rdf:type rdf:Property ;
    rdfs:label 'Incompatibility Consequence' ;
    rdfs:comment 'Primary hazardous consequence that would result from co-locating the two incompatible hazard classes defined in this rule. Used in risk assessment, PHA/HAZOP documentation, and emergency response planning. Informs the severity weighting in automated putaway violation alerts.' ;
    rdfs:domain ind:HazmatStorageRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incompatibleHazardClassA rdf:type rdf:Property ;
    rdfs:label 'Incompatible Hazard Class A' ;
    rdfs:comment 'First hazard class in the incompatible pair defined by this segregation rule. Together with incompatible_hazard_class_b, forms the segregation matrix entry that prohibits co-location of chemicals from these two hazard classes in the same storage zone. Aligns with NFPA 400 Table 10.3.2 and UN segregation table.' ;
    rdfs:domain ind:HazmatStorageRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incompatibleHazardClassB rdf:type rdf:Property ;
    rdfs:label 'Incompatible Hazard Class B' ;
    rdfs:comment 'Second hazard class in the incompatible pair defined by this segregation rule. Together with incompatible_hazard_class_a, forms the segregation matrix entry. The automated putaway validation engine in SAP EWM checks both directions of this pair to prevent co-location of incompatible chemicals.' ;
    rdfs:domain ind:HazmatStorageRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReviewedDate rdf:type rdf:Property ;
    rdfs:label 'Last Reviewed Date' ;
    rdfs:comment 'Date on which this storage rule was last reviewed for continued regulatory accuracy and operational relevance. ISO 14001 and ISO 45001 require periodic review of EHS controls. Triggers a review workflow in Intelex EHS Management when overdue.' ;
    rdfs:domain ind:HazmatStorageRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maxQuantityPerFireZoneKg rdf:type rdf:Property ;
    rdfs:label 'Max Quantity Per Fire Zone Kg' ;
    rdfs:comment 'Maximum allowable quantity in kilograms of chemicals governed by this rule that may be stored within a single fire zone or control area. Derived from NFPA 400 maximum allowable quantities (MAQ) tables and local fire code. Enforced by SAP EWM inventory capacity checks.' ;
    rdfs:domain ind:HazmatStorageRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxQuantityPerFireZoneL rdf:type rdf:Property ;
    rdfs:label 'Max Quantity Per Fire Zone L' ;
    rdfs:comment 'Maximum allowable quantity in liters of liquid chemicals governed by this rule that may be stored within a single fire zone or control area. Complements the kilogram-based limit for liquid hazmat categories where volume is the regulatory basis (e.g., NFPA 30 flammable liquids).' ;
    rdfs:domain ind:HazmatStorageRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxStorageTempC rdf:type rdf:Property ;
    rdfs:label 'Max Storage Temp C' ;
    rdfs:comment 'Maximum allowable storage temperature in degrees Celsius for chemicals governed by this rule. Exceeding this threshold may cause decomposition, polymerization, or ignition. Monitored via Aveva PI System historian and triggers automated EHS alerts in Intelex.' ;
    rdfs:domain ind:HazmatStorageRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minStorageTempC rdf:type rdf:Property ;
    rdfs:label 'Min Storage Temp C' ;
    rdfs:comment 'Minimum allowable storage temperature in degrees Celsius for chemicals governed by this rule. Below this threshold, the chemical may solidify, become unstable, or lose efficacy. Monitored via Aveva PI System historian for real-time compliance alerting.' ;
    rdfs:domain ind:HazmatStorageRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nfpaFlammabilityRating rdf:type rdf:Property ;
    rdfs:label 'Nfpa Flammability Rating' ;
    rdfs:comment 'NFPA 704 fire diamond flammability rating (0–4) for chemicals governed by this rule. Rating 4 indicates materials that will rapidly vaporize at normal pressure and temperature. Used in fire zone maximum quantity calculations and emergency response planning.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nfpaHealthRating rdf:type rdf:Property ;
    rdfs:label 'Nfpa Health Rating' ;
    rdfs:comment 'NFPA 704 fire diamond health hazard rating (0–4) for chemicals governed by this rule. Rating 4 indicates materials that can cause death or major residual injury on short exposure. Used in PPE requirements and emergency response planning.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nfpaReactivityRating rdf:type rdf:Property ;
    rdfs:label 'Nfpa Reactivity Rating' ;
    rdfs:comment 'NFPA 704 fire diamond instability/reactivity rating (0–4) for chemicals governed by this rule. Rating 4 indicates materials capable of detonation or explosive decomposition at normal temperatures and pressures.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nfpaSpecialHazardCode rdf:type rdf:Property ;
    rdfs:label 'Nfpa Special Hazard Code' ;
    rdfs:comment 'NFPA 704 special hazard symbol code for chemicals governed by this rule (e.g., W = water-reactive, OX = oxidizer, SA = simple asphyxiant, BIO = biological hazard, CRY = cryogenic). Governs special storage precautions and emergency response procedures. [ENUM-REF-CANDIDATE: W|OX|SA|BIO|COR|POI|RAD|CRY|ACID|ALK — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:HazmatStorageRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oshaRegulatoryCitation rdf:type rdf:Property ;
    rdfs:label 'Osha Regulatory Citation' ;
    rdfs:comment 'Specific OSHA regulatory citation (CFR part and section) that mandates or informs this storage rule (e.g., \'29 CFR 1910.119 PSM\', \'29 CFR 1910.106 Flammable Liquids\', \'29 CFR 1910.1200 HazCom\'). Used in PSM compliance documentation and OSHA inspection readiness.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packingGroup rdf:type rdf:Property ;
    rdfs:label 'Packing Group' ;
    rdfs:comment 'UN packing group designation (I = great danger, II = medium danger, III = minor danger) for the hazardous material governed by this rule. Determines packaging requirements for transport and influences storage quantity limits and segregation requirements.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reachRegulationReference rdf:type rdf:Property ;
    rdfs:label 'Reach Regulation Reference' ;
    rdfs:comment 'REACH regulation article or annex reference applicable to this storage rule (e.g., \'REACH Annex XVII Restriction Entry 3\', \'REACH Article 56 Authorization\'). Required for EU operations and ECHA compliance reporting. Populated for chemicals on the SVHC candidate list.' ;
    rdfs:domain ind:HazmatStorageRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleCode rdf:type rdf:Property ;
    rdfs:label 'Rule Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this storage rule within the enterprise rule catalog (e.g., HSR-001, FLAM-OX-SEG-01). Used as the human-readable business key in SAP EWM putaway strategies and EHS management systems.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleDescription rdf:type rdf:Property ;
    rdfs:label 'Rule Description' ;
    rdfs:comment 'Full narrative description of the storage rule, including the rationale for the segregation or storage condition requirement, the chemical hazard interaction being prevented, and any operational guidance for warehouse personnel.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleName rdf:type rdf:Property ;
    rdfs:label 'Rule Name' ;
    rdfs:comment 'Descriptive short name for the storage rule (e.g., \'Flammable-Oxidizer Segregation\', \'Corrosive-Reactive Incompatibility\'). Used in warehouse management UI labels and EHS compliance reports.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleStatus rdf:type rdf:Property ;
    rdfs:label 'Rule Status' ;
    rdfs:comment 'Current lifecycle status of the storage rule record. \'active\' rules are enforced in automated putaway validation. \'superseded\' rules have been replaced by a newer version. \'under_review\' rules are pending regulatory or internal re-assessment.' ;
    rdfs:domain ind:HazmatStorageRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleVersion rdf:type rdf:Property ;
    rdfs:label 'Rule Version' ;
    rdfs:comment 'Version identifier for this storage rule record (e.g., v1.0, v2.3). Supports rule versioning when regulatory updates require rule revisions. Enables audit trail of rule changes over time and ensures warehouse systems reference the current approved version.' ;
    rdfs:domain ind:HazmatStorageRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdsSectionReferences rdf:type rdf:Property ;
    rdfs:label 'Sds Section References' ;
    rdfs:comment 'Comma-separated list of SDS section numbers that provide the source data for this storage rule (e.g., \'7,8,10,14\'). Section 7 = Handling and Storage, Section 8 = Exposure Controls, Section 10 = Reactivity, Section 14 = Transport. Enables traceability from rule to SDS source documentation per GHS.' ;
    rdfs:domain ind:HazmatStorageRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryContainmentType rdf:type rdf:Property ;
    rdfs:label 'Secondary Containment Type' ;
    rdfs:comment 'Type of secondary containment structure required for storage locations holding chemicals governed by this rule. Prevents spill migration to drains and groundwater. Mandatory for EPA SPCC-regulated quantities and OSHA PSM-covered chemicals. Validated during SAP EWM putaway.' ;
    rdfs:domain ind:HazmatStorageRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segregationDistanceM rdf:type rdf:Property ;
    rdfs:label 'Segregation Distance M' ;
    rdfs:comment 'Minimum physical separation distance in meters required between storage locations holding chemicals from the two incompatible hazard classes defined in this rule. Used by SAP EWM bin assignment logic to enforce spatial separation within the warehouse or tank farm.' ;
    rdfs:domain ind:HazmatStorageRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageLocationType rdf:type rdf:Property ;
    rdfs:label 'Storage Location Type' ;
    rdfs:comment 'Type of physical storage location required for chemicals governed by this rule. Drives SAP EWM storage type determination during putaway. \'tank_farm\' applies to bulk liquid chemicals. \'refrigerated_room\' applies to temperature-sensitive hazmat. Validated against warehouse master data.' ;
    rdfs:domain ind:HazmatStorageRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ventilationClass rdf:type rdf:Property ;
    rdfs:label 'Ventilation Class' ;
    rdfs:comment 'Required ventilation classification for storage areas holding chemicals governed by this rule. \'local_exhaust\' indicates dedicated fume extraction is required. \'explosion_proof\' indicates ATEX/NEC-rated ventilation systems are mandatory. Aligns with OSHA industrial hygiene requirements and NFPA 30.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interplantTransferId rdf:type rdf:Property ;
    rdfs:label 'Interplant Transfer Id' ;
    rdfs:comment 'Primary key for interplant_transfer' ;
    rdfs:domain ind:InterplantTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sendingWarehouseLocationId rdf:type rdf:Property ;
    rdfs:label 'Sending Warehouse Location Id' ;
    rdfs:comment 'Foreign key linking to inventory.warehouse_location. Business justification: Inter-plant transfer originates from a warehouse location; replace string with FK.' ;
    rdfs:domain ind:InterplantTransfer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WarehouseLocation .

ind:actualGoodsIssueDate rdf:type rdf:Property ;
    rdfs:label 'Actual Goods Issue Date' ;
    rdfs:comment 'Actual date on which the goods issue posting was made in SAP MM, confirming physical departure of material from the sending plant. Used for transit time analysis and on-time shipment KPI reporting.' ;
    rdfs:domain ind:InterplantTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualGoodsReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Actual Goods Receipt Date' ;
    rdfs:comment 'Actual date on which the goods receipt posting was made in SAP MM at the receiving plant, confirming physical arrival and acceptance of the transferred material. Used for transit time calculation and inventory reconciliation.' ;
    rdfs:domain ind:InterplantTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billOfLadingNumber rdf:type rdf:Property ;
    rdfs:label 'Bill Of Lading Number' ;
    rdfs:comment 'Official bill of lading document number issued for the shipment. Serves as the legal contract of carriage and is required for hazardous material transport documentation under DOT regulations and customs compliance.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierName rdf:type rdf:Property ;
    rdfs:label 'Carrier Name' ;
    rdfs:comment 'Name of the logistics carrier or transport service provider responsible for moving the material between plants. Used for carrier performance tracking and freight cost allocation.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Carrier Reference Number' ;
    rdfs:comment 'Carrier-assigned reference number (e.g., bill of lading number, waybill number, or pro number) for the shipment. Used to cross-reference with Oracle Transportation Management and carrier tracking systems.' ;
    rdfs:domain ind:InterplantTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Delivery Document Number' ;
    rdfs:comment 'SAP outbound delivery document number created in SAP EWM/SD for the physical shipment execution of this stock transfer order. Links the STO to the warehouse execution and shipping documents.' ;
    rdfs:domain ind:InterplantTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatIndicator rdf:type rdf:Property ;
    rdfs:label 'Hazmat Indicator' ;
    rdfs:comment 'Flag indicating whether the transferred material is classified as a hazardous material requiring special handling, labeling, and transport documentation under DOT, GHS, and IMDG regulations. Triggers mandatory SDS/MSDS documentation and emergency response procedures.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:intransitQuantity rdf:type rdf:Property ;
    rdfs:label 'Intransit Quantity' ;
    rdfs:comment 'Quantity of material currently in transit between the sending and receiving plants — goods issued but not yet goods-receipted. Represents the stock-in-transit position used for real-time inventory visibility and financial valuation of in-transit inventory.' ;
    rdfs:domain ind:InterplantTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:issuedQuantity rdf:type rdf:Property ;
    rdfs:label 'Issued Quantity' ;
    rdfs:comment 'Actual quantity of material physically issued (goods issued) from the sending plant\'s inventory at the time of transfer. May differ from transfer_quantity due to partial shipments or measurement variances.' ;
    rdfs:domain ind:InterplantTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:materialDescription rdf:type rdf:Property ;
    rdfs:label 'Material Description' ;
    rdfs:comment 'Short descriptive name of the material being transferred as maintained in the SAP material master. Provides human-readable identification for operational and compliance reporting.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialNumber rdf:type rdf:Property ;
    rdfs:label 'Material Number' ;
    rdfs:comment 'SAP material master number uniquely identifying the chemical, raw material, intermediate, finished good, or packaging material being transferred. Serves as the primary material reference across SAP MM, PP, and QM modules.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedGoodsIssueDate rdf:type rdf:Property ;
    rdfs:label 'Planned Goods Issue Date' ;
    rdfs:comment 'Planned date on which goods are scheduled to be issued from the sending plant\'s inventory. Derived from the requested delivery date and transit lead time in SAP MM planning.' ;
    rdfs:domain ind:InterplantTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quarantineStatus rdf:type rdf:Property ;
    rdfs:label 'Quarantine Status' ;
    rdfs:comment 'Quality management status of the transferred material lot indicating whether it is available for unrestricted use or held under quarantine/quality hold pending inspection or testing. Integrates with SAP QM and LabWare LIMS quality disposition workflows.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivedQuantity rdf:type rdf:Property ;
    rdfs:label 'Received Quantity' ;
    rdfs:comment 'Actual quantity of material confirmed as received (goods received) at the destination plant. Used to calculate transfer variances, identify transit losses, and trigger inventory reconciliation. Populated upon goods receipt posting in SAP MM.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receivingPlantCode rdf:type rdf:Property ;
    rdfs:label 'Receiving Plant Code' ;
    rdfs:comment 'SAP plant code identifying the destination plant, distribution center, or external warehouse that will receive the transferred material. Corresponds to the receiving plant in SAP MM stock transfer processing.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingPlantName rdf:type rdf:Property ;
    rdfs:label 'Receiving Plant Name' ;
    rdfs:comment 'Descriptive name of the destination plant or facility receiving the stock transfer. Provides human-readable context for reporting and operational dashboards without requiring a join to the plant master.' ;
    rdfs:domain ind:InterplantTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingStorageLocation rdf:type rdf:Property ;
    rdfs:label 'Receiving Storage Location' ;
    rdfs:comment 'SAP storage location code within the receiving plant where the material will be placed upon arrival. Identifies the target warehouse area, tank farm, or storage bin at the destination facility.' ;
    rdfs:domain ind:InterplantTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Requested Delivery Date' ;
    rdfs:comment 'Date by which the transferred material is required to arrive at the receiving plant. Used for production planning, supply chain scheduling, and on-time delivery performance measurement.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sapMovementType rdf:type rdf:Property ;
    rdfs:label 'Sap Movement Type' ;
    rdfs:comment 'SAP MM movement type code governing the inventory and accounting postings for this transfer (e.g., 641 for goods issue for STO, 101 for goods receipt). Determines the financial and inventory impact in SAP S/4HANA.' ;
    rdfs:domain ind:InterplantTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sendingPlantCode rdf:type rdf:Property ;
    rdfs:label 'Sending Plant Code' ;
    rdfs:comment 'SAP plant code identifying the originating plant or manufacturing facility from which the material is being transferred. Corresponds to the issuing plant in SAP MM stock transfer processing.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sendingPlantName rdf:type rdf:Property ;
    rdfs:label 'Sending Plant Name' ;
    rdfs:comment 'Descriptive name of the originating plant or facility issuing the stock transfer. Provides human-readable context for reporting and operational dashboards without requiring a join to the plant master.' ;
    rdfs:domain ind:InterplantTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialStockIndicator rdf:type rdf:Property ;
    rdfs:label 'Special Stock Indicator' ;
    rdfs:comment 'SAP special stock type indicator identifying whether the transferred material is standard unrestricted stock or a special stock category such as consignment, project stock, or sales order stock. Affects inventory valuation and availability checking.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Transfer Order Number' ;
    rdfs:comment 'Externally-known SAP stock transfer order document number assigned by SAP S/4HANA MM module. Used as the primary business reference across ERP, WMS, and logistics systems for tracking the inter-plant movement.' ;
    rdfs:domain ind:InterplantTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferQuantity rdf:type rdf:Property ;
    rdfs:label 'Transfer Quantity' ;
    rdfs:comment 'Ordered quantity of material to be transferred from the sending plant to the receiving plant, expressed in the base unit of measure. Represents the planned transfer amount at order creation.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transferReason rdf:type rdf:Property ;
    rdfs:label 'Transfer Reason' ;
    rdfs:comment 'Business reason or justification for initiating the inter-plant stock transfer (e.g., production replenishment, inventory rebalancing, quality rework, customer order fulfillment). Used for operational analytics and cost allocation.' ;
    rdfs:domain ind:InterplantTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferStatus rdf:type rdf:Property ;
    rdfs:label 'Transfer Status' ;
    rdfs:comment 'Current lifecycle status of the inter-plant stock transfer order. Tracks progression from creation through in-transit movement to receipt confirmation at the destination plant. [ENUM-REF-CANDIDATE: created|in_transit|partially_received|received|confirmed|cancelled — promote to reference product if additional statuses are required]' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferType rdf:type rdf:Property ;
    rdfs:label 'Transfer Type' ;
    rdfs:comment 'Classification of the inter-plant transfer indicating the nature of the movement (e.g., plant-to-plant, plant-to-distribution center, cross-company transfer). Determines the SAP movement type and accounting treatment in FI/CO.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferValue rdf:type rdf:Property ;
    rdfs:label 'Transfer Value' ;
    rdfs:comment 'Monetary value of the transferred material quantity based on the standard or moving average price at the sending plant. Used for inter-company or inter-plant inventory valuation and financial settlement in SAP FI/CO. Expressed in the company currency.' ;
    rdfs:domain ind:InterplantTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inventoryAdjustmentId rdf:type rdf:Property ;
    rdfs:label 'Inventory Adjustment Id' ;
    rdfs:comment 'Unique surrogate identifier for each inventory adjustment record in the Chemical Mfg lakehouse silver layer. Primary key for this entity.' ;
    rdfs:domain ind:InventoryAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalAdjustmentInventoryAdjustmentId rdf:type rdf:Property ;
    rdfs:label 'Original Adjustment Inventory Adjustment Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the original inventory adjustment record that this record reverses. Populated only when reversal_flag is True. Enables full reversal chain traceability for audit and SOX compliance.' ;
    rdfs:domain ind:InventoryAdjustment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventoryAdjustment .

ind:primaryInventoryRequestedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Inventory Requested By Employee Id' ;
    rdfs:comment 'Reference to the employee (warehouse operator, inventory controller, or production planner) who initiated and submitted the inventory adjustment request. Required for SOX dual-authorization controls and audit trail.' ;
    rdfs:domain ind:InventoryAdjustment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:adjustmentStatus rdf:type rdf:Property ;
    rdfs:label 'Adjustment Status' ;
    rdfs:comment 'Current lifecycle state of the inventory adjustment record, tracking progression from initial draft through dual-authorization approval (required for SOX-controlled threshold adjustments) to final posting or reversal in SAP MM.' ;
    rdfs:domain ind:InventoryAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Adjustment Timestamp' ;
    rdfs:comment 'The principal real-world business event timestamp recording when the inventory adjustment was physically executed or the stock correction was applied. Distinct from the record creation audit timestamp. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ehsIncidentReference rdf:type rdf:Property ;
    rdfs:label 'Ehs Incident Reference' ;
    rdfs:comment 'Reference number linking this inventory adjustment to an associated EHS incident record in Intelex EHS Management (e.g., a spill, fire, or contamination event that caused material loss). Null when the adjustment is not related to an EHS incident.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialImpactValue rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Value' ;
    rdfs:comment 'The monetary value impact of the inventory adjustment on the balance sheet, calculated as adjustment quantity multiplied by the standard or moving average price of the material. Positive for write-ups, negative for write-offs. Used for COGS (Cost of Goods Sold) reporting and SOX financial controls.' ;
    rdfs:domain ind:InventoryAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:movementTypeCode rdf:type rdf:Property ;
    rdfs:label 'Movement Type Code' ;
    rdfs:comment 'SAP MM movement type code that classifies the goods movement transaction (e.g., 551 for scrapping, 701 for physical inventory difference posting). Determines the accounting entries and stock update logic in SAP.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:physicalInventoryDocument rdf:type rdf:Property ;
    rdfs:label 'Physical Inventory Document' ;
    rdfs:comment 'SAP MM physical inventory document number associated with this adjustment when the adjustment originates from a physical inventory count (cycle count or annual count). Null for non-count-related adjustments such as damage write-offs.' ;
    rdfs:domain ind:InventoryAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapMaterialDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Material Document Number' ;
    rdfs:comment 'The SAP MM material document number generated when the inventory adjustment is posted in SAP S/4HANA. Serves as the primary cross-reference between the lakehouse silver layer record and the ERP system of record for reconciliation and audit purposes.' ;
    rdfs:domain ind:InventoryAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapMaterialDocumentYear rdf:type rdf:Property ;
    rdfs:label 'Sap Material Document Year' ;
    rdfs:comment 'The fiscal year associated with the SAP MM material document number. Required because SAP material document numbers are unique only within a fiscal year; combined with sap_material_document_number provides a globally unique ERP reference.' ;
    rdfs:domain ind:InventoryAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:soxThresholdExceeded rdf:type rdf:Property ;
    rdfs:label 'Sox Threshold Exceeded' ;
    rdfs:comment 'Boolean flag indicating whether the financial impact value of this adjustment exceeds the SOX dual-authorization threshold, triggering the requirement for a secondary approver. True = dual authorization required and applied; False = single authorization sufficient.' ;
    rdfs:domain ind:InventoryAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:soxThresholdValue rdf:type rdf:Property ;
    rdfs:label 'Sox Threshold Value' ;
    rdfs:comment 'The monetary threshold value above which a second approver is required per SOX internal control policy. Stored on the record for audit traceability as thresholds may be updated over time.' ;
    rdfs:domain ind:InventoryAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageLocationCode rdf:type rdf:Property ;
    rdfs:label 'Storage Location Code' ;
    rdfs:comment 'SAP storage location code (e.g., warehouse zone, tank farm area, quarantine area) within the plant where the adjusted material is stored. Supports hazardous material segregation compliance and EWM warehouse operations.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplyPlanId rdf:type rdf:Property ;
    rdfs:label 'Supply Plan Id' ;
    rdfs:comment 'Unique surrogate identifier for the lot (batch) master record in the Silver Layer lakehouse. Primary key for all downstream joins and traceability chains.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplyPlan .

ind:coaNumber rdf:type rdf:Property ;
    rdfs:label 'Coa Number' ;
    rdfs:comment 'The document reference number of the Certificate of Analysis (COA) issued for this lot, confirming that the material meets all specified quality parameters. Provided to customers with shipments and required for regulatory submissions. Stored in LabWare LIMS and SAP QM.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cocNumber rdf:type rdf:Property ;
    rdfs:label 'Coc Number' ;
    rdfs:comment 'The document reference number of the Certificate of Compliance (COC) issued for this lot, attesting conformance to customer-specified or regulatory requirements beyond standard QC testing (e.g., REACH compliance, RoHS, food-contact suitability). Distinct from COA which covers analytical results.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfOrigin rdf:type rdf:Property ;
    rdfs:label 'Country Of Origin' ;
    rdfs:comment 'The ISO 3166-1 alpha-3 country code of the country where this lot was manufactured or, for natural raw materials, where it was extracted. Required for customs declarations, import/export compliance, trade preference certificates, and REACH/TSCA regulatory reporting.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentQuantity rdf:type rdf:Property ;
    rdfs:label 'Current Quantity' ;
    rdfs:comment 'The remaining unreserved quantity of material currently available in this lot, updated with each inventory movement (goods issue, transfer, adjustment). Supports real-time stock position reporting and FIFO/FEFO allocation.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daysToExpiryThreshold rdf:type rdf:Property ;
    rdfs:label 'Days To Expiry Threshold' ;
    rdfs:comment 'The number of days before expiration at which this lot should trigger an inventory alert for proactive disposition, customer notification, or markdown action. Configured per material type and customer contract requirements. Used by FEFO rotation and expiry management workflows.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dispositionStatus rdf:type rdf:Property ;
    rdfs:label 'Disposition Status' ;
    rdfs:comment 'Current quality disposition of the lot governing whether it may be used, shipped, or must be held. Released: QC-approved for use/sale. Quarantined: held pending QC decision. Rejected: failed QC and must be destroyed or reworked. Expired: past expiration date. Under Review: Out-of-Specification (OOS) or Out-of-Trend (OOT) investigation in progress. Recalled: subject to active recall action. Maps to SAP QM Usage Decision (VRBWG).' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmpStatus rdf:type rdf:Property ;
    rdfs:label 'Gmp Status' ;
    rdfs:comment 'Indicates whether this lot was manufactured under Good Manufacturing Practice (GMP) conditions as required for pharmaceutical-grade, food-contact, or regulated chemical applications. Drives customer-specific COA declarations and regulatory submissions.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Date' ;
    rdfs:comment 'The date this lot was physically received into the warehouse or plant, recorded at goods receipt posting in SAP MM. For internally produced lots, this is the date the finished goods were transferred to the warehouse. Maps to SAP MIGO Goods Receipt Posting Date (BUDAT).' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:grade rdf:type rdf:Property ;
    rdfs:label 'Grade' ;
    rdfs:comment 'Quality grade classification assigned to this lot based on QC test results and intended end-use application. Prime: meets full specification. Off-grade: meets reduced specification for alternative use. Technical/Pharmaceutical/Food/Agricultural grades reflect regulatory and customer-specific quality tiers. Drives pricing and customer allocation.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Flag' ;
    rdfs:comment 'Indicates whether this lot is classified as a hazardous material requiring special storage, handling, labelling, and transport compliance under DOT, OSHA, and GHS regulations. Triggers hazmat storage location validation in SAP EWM.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:initialQuantity rdf:type rdf:Property ;
    rdfs:label 'Initial Quantity' ;
    rdfs:comment 'The total quantity of material in this lot at the time of creation (production completion or goods receipt). Expressed in the base unit of measure of the material. Used as the denominator for yield calculations and lot consumption tracking.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inventoryValuationPrice rdf:type rdf:Property ;
    rdfs:label 'Inventory Valuation Price' ;
    rdfs:comment 'The per-unit valuation price applied to this lot for inventory accounting purposes, expressed in the company\'s functional currency. Used for COGS calculation, inventory write-down assessment, and financial reporting. Maps to SAP Moving Average Price or Standard Price (VERPR/STPRS) in FI/CO.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:manufactureDate rdf:type rdf:Property ;
    rdfs:label 'Manufacture Date' ;
    rdfs:comment 'The date on which production of this lot was completed or, for externally received lots, the date of manufacture as declared by the supplier. Basis for shelf-life and expiration date calculation. Maps to SAP Batch Manufacturing Date (HSDAT).' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:moistureContentPercent rdf:type rdf:Property ;
    rdfs:label 'Moisture Content Percent' ;
    rdfs:comment 'The measured moisture content of this lot expressed as a percentage by weight, as determined by QC testing (e.g., Karl Fischer titration, loss on drying). Critical for solid and powder chemical products where moisture affects stability, reactivity, and product performance.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nfpaFireRating rdf:type rdf:Property ;
    rdfs:label 'Nfpa Fire Rating' ;
    rdfs:comment 'NFPA 704 flammability hazard rating (0-4) for the material in this lot. 0 = will not burn; 4 = will rapidly vaporize at normal conditions. Used for storage location assignment, fire suppression system design, and emergency response planning.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:origin rdf:type rdf:Property ;
    rdfs:label 'Origin' ;
    rdfs:comment 'Indicates whether this lot was created through internal manufacturing, received from an external supplier, produced via rework/reprocessing of a non-conforming lot, or originated from a customer return. Drives traceability and regulatory reporting workflows.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purityPercent rdf:type rdf:Property ;
    rdfs:label 'Purity Percent' ;
    rdfs:comment 'The measured purity of the primary chemical substance in this lot expressed as a percentage by weight or volume, as determined by QC analytical testing. Key quality attribute for pricing, formulation accuracy, and regulatory compliance. Sourced from LabWare LIMS COA.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qcReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Qc Release Date' ;
    rdfs:comment 'The date on which the Quality Assurance function formally released this lot from quarantine to unrestricted use following successful completion of all required QC testing. Populated from LabWare LIMS usage decision timestamp. Critical for lead-time and cycle-time analytics.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recallFlag rdf:type rdf:Property ;
    rdfs:label 'Recall Flag' ;
    rdfs:comment 'Indicates whether this lot is subject to an active product recall or market withdrawal action. When True, triggers immediate inventory blocking in SAP EWM, customer notification workflows, and regulatory reporting to FDA/EPA/ECHA as applicable.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:restrictedSubstanceFlag rdf:type rdf:Property ;
    rdfs:label 'Restricted Substance Flag' ;
    rdfs:comment 'Indicates whether this lot contains substances subject to regulatory restriction or authorization under REACH SVHC (Substances of Very High Concern), TSCA, or RoHS. Triggers compliance review before shipment to regulated markets.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shelfLifeDays rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Days' ;
    rdfs:comment 'The total approved shelf life of this lot expressed in days, as defined by the material specification or stability study. Used to validate expiration date assignment and to support shelf-life remaining calculations for customer order fulfillment. Maps to SAP Material Master Total Shelf Life (MHDRZ).' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supplierLotNumber rdf:type rdf:Property ;
    rdfs:label 'Supplier Lot Number' ;
    rdfs:comment 'The original lot or batch number assigned by the external supplier, as printed on the supplier COA and shipping documents. Maintained alongside the internal lot_number for full traceability back to the supplier\'s manufacturing records. Null for internally produced lots.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vocContentPpm rdf:type rdf:Property ;
    rdfs:label 'Voc Content Ppm' ;
    rdfs:comment 'The measured or declared Volatile Organic Compound (VOC) content of this lot expressed in Parts Per Million (PPM) by weight. Required for EPA air emissions reporting, state VOC regulations, and customer environmental product declarations. Sourced from QC analytical results in LabWare LIMS.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lotGenealogyId rdf:type rdf:Property ;
    rdfs:label 'Lot Genealogy Id' ;
    rdfs:comment 'Unique surrogate identifier for the lot genealogy association record. Primary key for this parent-child lot traceability record in the Silver Layer lakehouse.' ;
    rdfs:domain ind:LotGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:childLotId rdf:type rdf:Property ;
    rdfs:label 'Child Lot Id' ;
    rdfs:comment 'Reference to the downstream (child) lot produced or created from the parent lot. Enables downstream traceability for recall management and regulatory reporting.' ;
    rdfs:domain ind:LotGenealogy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lot .

ind:parentLotId rdf:type rdf:Property ;
    rdfs:label 'Parent Lot Id' ;
    rdfs:comment 'Reference to the upstream (parent) lot from which material was consumed or transformed. Enables upstream traceability for recall management and Certificate of Analysis (COA) lineage.' ;
    rdfs:domain ind:LotGenealogy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lot .

ind:actualYieldPct rdf:type rdf:Property ;
    rdfs:label 'Actual Yield Pct' ;
    rdfs:comment 'Actual yield percentage achieved in this transformation, calculated as (child_quantity_produced / parent_quantity_consumed) * 100. Compared against theoretical yield to identify process deviations requiring CAPA or Root Cause Investigation (RCI).' ;
    rdfs:domain ind:LotGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bomVersion rdf:type rdf:Property ;
    rdfs:label 'Bom Version' ;
    rdfs:comment 'Version identifier of the Bill of Materials (BOM) or recipe used for this transformation. Ensures traceability to the exact formulation specification applied during production, supporting change control and regulatory audit.' ;
    rdfs:domain ind:LotGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:childMaterialNumber rdf:type rdf:Property ;
    rdfs:label 'Child Material Number' ;
    rdfs:comment 'SAP material number of the child lot material produced. Denormalized for direct traceability reporting. Identifies the chemical product, formulation, or intermediate resulting from the transformation.' ;
    rdfs:domain ind:LotGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:childQuantityProduced rdf:type rdf:Property ;
    rdfs:label 'Child Quantity Produced' ;
    rdfs:comment 'Quantity of material produced in the child lot as a result of the transformation operation. Expressed in the base unit of measure of the child material. Used for yield analysis, COA quantity declaration, and inventory receipt posting.' ;
    rdfs:domain ind:LotGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:childQuantityUom rdf:type rdf:Property ;
    rdfs:label 'Child Quantity Uom' ;
    rdfs:comment 'Unit of measure for the child lot quantity produced (e.g., KG, LB, L, GAL, MT). Aligns with SAP base unit of measure for the child material to ensure accurate yield reporting and inventory valuation. [ENUM-REF-CANDIDATE: KG|LB|L|GAL|MT|G|TON|M3 — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LotGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coaIssued rdf:type rdf:Property ;
    rdfs:label 'Coa Issued' ;
    rdfs:comment 'Indicates whether the Certificate of Analysis (COA) for the child lot has been issued by the Quality Assurance (QA) function. Used to track COA fulfillment status for customer shipment readiness.' ;
    rdfs:domain ind:LotGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:genealogyRecordNumber rdf:type rdf:Property ;
    rdfs:label 'Genealogy Record Number' ;
    rdfs:comment 'Externally visible business identifier for this genealogy association record, formatted as LG-{YEAR}-{SEQUENCE}. Used in COA lineage documentation, recall notifications, and regulatory submissions.' ;
    rdfs:domain ind:LotGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isHazardous rdf:type rdf:Property ;
    rdfs:label 'Is Hazardous' ;
    rdfs:comment 'Indicates whether the material involved in this lot transformation is classified as hazardous under GHS, OSHA, or DOT regulations. Triggers additional compliance checks for storage, handling, and transport documentation.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMultiParent rdf:type rdf:Property ;
    rdfs:label 'Is Multi Parent' ;
    rdfs:comment 'Indicates whether the child lot was produced from multiple parent lots (True) or a single parent lot (False). Relevant for blend and merge transformation types where multiple input lots contribute to one output lot.' ;
    rdfs:domain ind:LotGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentMaterialNumber rdf:type rdf:Property ;
    rdfs:label 'Parent Material Number' ;
    rdfs:comment 'SAP material number of the parent lot material. Denormalized for direct traceability reporting without joining to the material master. Identifies the chemical substance or intermediate consumed in the transformation.' ;
    rdfs:domain ind:LotGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentQuantityConsumed rdf:type rdf:Property ;
    rdfs:label 'Parent Quantity Consumed' ;
    rdfs:comment 'Quantity of material consumed from the parent lot during the transformation operation. Expressed in the base unit of measure of the parent material. Critical for mass balance verification, yield calculations, and inventory reconciliation.' ;
    rdfs:domain ind:LotGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentQuantityUom rdf:type rdf:Property ;
    rdfs:label 'Parent Quantity Uom' ;
    rdfs:comment 'Unit of measure for the parent lot quantity consumed (e.g., KG, LB, L, GAL, MT). Aligns with SAP base unit of measure for the parent material to ensure accurate mass balance and inventory valuation. [ENUM-REF-CANDIDATE: KG|LB|L|GAL|MT|G|TON|M3 — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LotGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityInspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Status' ;
    rdfs:comment 'Quality Management (QM) inspection status of the child lot produced in this transformation. Not_inspected: awaiting QC sampling. In_inspection: under laboratory testing in LIMS. Released: passed all QC tests and approved for use/shipment. Rejected: failed QC and quarantined. Restricted: conditionally released pending further review.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemCode rdf:type rdf:Property ;
    rdfs:label 'Source System Code' ;
    rdfs:comment 'Code identifying the operational system of record from which this lot genealogy record originated (e.g., SAP_PP for SAP Production Planning, MES for Manufacturing Execution System, LIMS for LabWare). Supports data lineage and Silver Layer provenance tracking.' ;
    rdfs:domain ind:LotGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemRecordCode rdf:type rdf:Property ;
    rdfs:label 'Source System Record Code' ;
    rdfs:comment 'Native record identifier from the originating operational system (e.g., SAP batch classification document number, MES batch record ID). Enables back-referencing to the source system for reconciliation and audit purposes.' ;
    rdfs:domain ind:LotGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:theoreticalYieldPct rdf:type rdf:Property ;
    rdfs:label 'Theoretical Yield Pct' ;
    rdfs:comment 'Expected yield percentage of child material relative to parent material consumed, as defined in the Bill of Materials (BOM) or recipe. Used as the baseline for actual yield variance analysis and process performance monitoring.' ;
    rdfs:domain ind:LotGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transformationDate rdf:type rdf:Property ;
    rdfs:label 'Transformation Date' ;
    rdfs:comment 'Calendar date on which the lot transformation operation was performed. Used for FIFO/FEFO lot rotation analysis, shelf-life calculations, and regulatory batch record dating.' ;
    rdfs:domain ind:LotGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transformationNotes rdf:type rdf:Property ;
    rdfs:label 'Transformation Notes' ;
    rdfs:comment 'Free-text field for recording operational notes, deviations, or observations associated with the lot transformation. May include process deviations, equipment substitutions, or Management of Change (MOC) references that affected the transformation.' ;
    rdfs:domain ind:LotGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transformationStatus rdf:type rdf:Property ;
    rdfs:label 'Transformation Status' ;
    rdfs:comment 'Current lifecycle status of the lot genealogy transformation record. Pending: transformation initiated but not yet executed. In_progress: transformation underway in MES/DCS. Completed: transformation fully executed and confirmed. Cancelled: transformation voided before completion. Reversed: completed transformation subsequently reversed via correction.' ;
    rdfs:domain ind:LotGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transformationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transformation Timestamp' ;
    rdfs:comment 'Precise date and time at which the lot transformation was recorded in the system of record (SAP PP or MES). Provides sub-day precision for process sequencing, DCS event correlation, and audit trail requirements.' ;
    rdfs:domain ind:LotGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:transformationType rdf:type rdf:Property ;
    rdfs:label 'Transformation Type' ;
    rdfs:comment 'Classification of the material transformation operation that created the parent-child lot relationship. Split: one lot divided into multiple child lots. Merge: multiple parent lots combined into one child lot. Conversion: chemical reaction or synthesis producing a new material. Repack: same material repackaged into new containers. Blend: two or more materials combined to produce a formulated product.' ;
    rdfs:domain ind:LotGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workCenterCode rdf:type rdf:Property ;
    rdfs:label 'Work Center Code' ;
    rdfs:comment 'SAP PP work center or production unit code where the transformation operation was physically performed (e.g., reactor, blending vessel, filling line). Supports equipment-level traceability and OEE analysis.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:physicalInventoryCountId rdf:type rdf:Property ;
    rdfs:label 'Physical Inventory Count Id' ;
    rdfs:comment 'Unique surrogate identifier for each physical inventory count record in the lakehouse silver layer. Maps to SAP MM physical inventory document item.' ;
    rdfs:domain ind:PhysicalInventoryCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approverEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Approver Employee Id' ;
    rdfs:comment 'Employee identifier of the manager or supervisor who approved the variance write-off. Required for SOX segregation of duties — the approver must be different from the counter.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:countSessionId rdf:type rdf:Property ;
    rdfs:label 'Count Session Id' ;
    rdfs:comment 'Identifier grouping multiple count document items that were counted together as part of the same physical inventory session or cycle count run. Enables session-level reporting and reconciliation.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CountSession .

ind:primaryPhysicalCounterEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Physical Counter Employee Id' ;
    rdfs:comment 'Employee identifier of the person who physically performed the count. Required for accountability, SOX segregation of duties, and audit trail. References the workforce/HR system.' ;
    rdfs:domain ind:PhysicalInventoryCount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:stockPositionId rdf:type rdf:Property ;
    rdfs:label 'Stock Position Id' ;
    rdfs:comment 'Foreign key linking to inventory.stock_position. Business justification: Physical inventory count should reference the stock position record that aggregates quantity and location; removes duplicated attributes.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StockPosition .

ind:approvalNotes rdf:type rdf:Property ;
    rdfs:label 'Approval Notes' ;
    rdfs:comment 'Free-text notes entered by the approver explaining the rationale for approving the variance write-off. Supports audit documentation and Root Cause Investigation (RCI) for recurring discrepancies.' ;
    rdfs:domain ind:PhysicalInventoryCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookQuantity rdf:type rdf:Property ;
    rdfs:label 'Book Quantity' ;
    rdfs:comment 'System-recorded (book) quantity of the material at the storage location at the time the count document was created, as per SAP MM inventory records. Represents the expected quantity before physical verification.' ;
    rdfs:domain ind:PhysicalInventoryCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:countDate rdf:type rdf:Property ;
    rdfs:label 'Count Date' ;
    rdfs:comment 'Calendar date on which the physical count was performed. Used for inventory valuation cutoff, regulatory reporting, and SOX period-end reconciliation.' ;
    rdfs:domain ind:PhysicalInventoryCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:countDocumentItem rdf:type rdf:Property ;
    rdfs:label 'Count Document Item' ;
    rdfs:comment 'Line item number within the SAP physical inventory document, distinguishing individual material-storage location combinations within the same count document.' ;
    rdfs:domain ind:PhysicalInventoryCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:countDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Count Document Number' ;
    rdfs:comment 'SAP MM physical inventory document number (MI01/MI04) that uniquely identifies the count event in the source system. Used for reconciliation and audit trail back to SAP.' ;
    rdfs:domain ind:PhysicalInventoryCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countMethod rdf:type rdf:Property ;
    rdfs:label 'Count Method' ;
    rdfs:comment 'Indicates whether the count was performed blind (counter not shown book quantity, reducing bias) or informed (counter shown book quantity). Blind counting is preferred for SOX-compliant inventory reconciliation.' ;
    rdfs:domain ind:PhysicalInventoryCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countStatus rdf:type rdf:Property ;
    rdfs:label 'Count Status' ;
    rdfs:comment 'Current lifecycle status of the count document: open (count not yet performed), counted (count entered, pending posting), recounted (recount completed), posted (variance posted to inventory), cancelled (count voided).' ;
    rdfs:domain ind:PhysicalInventoryCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countTimestamp rdf:type rdf:Property ;
    rdfs:label 'Count Timestamp' ;
    rdfs:comment 'Precise date and time when the physical count was recorded, including timezone offset. Used for intraday reconciliation and audit trail in continuous process manufacturing environments.' ;
    rdfs:domain ind:PhysicalInventoryCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:countType rdf:type rdf:Property ;
    rdfs:label 'Count Type' ;
    rdfs:comment 'Classification of the count event: cycle_count (periodic scheduled count of a subset of materials), annual_wall_to_wall (full facility count), triggered_count (initiated due to discrepancy or event), or recount (second count to resolve variance).' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countedQuantity rdf:type rdf:Property ;
    rdfs:label 'Counted Quantity' ;
    rdfs:comment 'Actual physical quantity of the material counted and recorded by the counter. This is the primary measurement outcome of the count event.' ;
    rdfs:domain ind:PhysicalInventoryCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:counterName rdf:type rdf:Property ;
    rdfs:label 'Counter Name' ;
    rdfs:comment 'Full name of the employee who performed the physical count. Stored for audit readability and SOX compliance reporting without requiring a join to HR systems.' ;
    rdfs:domain ind:PhysicalInventoryCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryValuationAmount rdf:type rdf:Property ;
    rdfs:label 'Inventory Valuation Amount' ;
    rdfs:comment 'Monetary value of the inventory variance calculated as variance_quantity multiplied by the standard or moving average price of the material. Used for financial impact assessment and COGS adjustment. Expressed in local currency.' ;
    rdfs:domain ind:PhysicalInventoryCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:materialDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Material Document Number' ;
    rdfs:comment 'SAP material document number generated when the inventory variance is posted (Transaction MI07). Links this count record to the resulting inventory_adjustment material document for financial reconciliation.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingStatus rdf:type rdf:Property ;
    rdfs:label 'Posting Status' ;
    rdfs:comment 'Status of the variance posting to the SAP general ledger: not_posted (pending), posted (successfully posted), posting_failed (error during posting), reversed (posting reversed for correction).' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recountFlag rdf:type rdf:Property ;
    rdfs:label 'Recount Flag' ;
    rdfs:comment 'Indicates whether a recount has been triggered for this count item, typically due to variance exceeding the tolerance threshold. True = recount required or performed; False = no recount needed.' ;
    rdfs:domain ind:PhysicalInventoryCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recountNumber rdf:type rdf:Property ;
    rdfs:label 'Recount Number' ;
    rdfs:comment 'Sequential number indicating which recount iteration this record represents (1 = first recount, 2 = second recount, etc.). Zero or null indicates the original count. Supports multi-round recount audit trails.' ;
    rdfs:domain ind:PhysicalInventoryCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:variancePercentage rdf:type rdf:Property ;
    rdfs:label 'Variance Percentage' ;
    rdfs:comment 'Variance quantity expressed as a percentage of book quantity. Used to determine whether variance exceeds tolerance thresholds requiring management approval or recount. Key KPI for inventory accuracy reporting.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceQuantity rdf:type rdf:Property ;
    rdfs:label 'Variance Quantity' ;
    rdfs:comment 'Difference between counted quantity and book quantity (counted_quantity minus book_quantity). Positive value indicates surplus; negative value indicates shortage. Drives inventory adjustment postings.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceTolerancePct rdf:type rdf:Property ;
    rdfs:label 'Variance Tolerance Pct' ;
    rdfs:comment 'Allowable variance percentage threshold configured for this material or material group. Variances exceeding this threshold require management approval for write-off. Supports SOX-compliant variance authorization controls.' ;
    rdfs:domain ind:PhysicalInventoryCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warehouseNumber rdf:type rdf:Property ;
    rdfs:label 'Warehouse Number' ;
    rdfs:comment 'SAP EWM warehouse number identifying the logical warehouse complex. Used when the count is managed at the warehouse management level rather than simple storage location level.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withinToleranceFlag rdf:type rdf:Property ;
    rdfs:label 'Within Tolerance Flag' ;
    rdfs:comment 'Indicates whether the variance percentage is within the configured tolerance threshold. True = variance is acceptable and can be auto-posted; False = variance exceeds tolerance and requires manual approval.' ;
    rdfs:domain ind:PhysicalInventoryCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quarantineHoldId rdf:type rdf:Property ;
    rdfs:label 'Quarantine Hold Id' ;
    rdfs:comment 'Unique system-generated identifier for the quarantine or quality hold record. Primary key for this entity.' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryQuarantineInitiatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Quarantine Initiator Employee Id' ;
    rdfs:comment 'Reference to the employee (QA analyst, EHS officer, production supervisor, or regulatory affairs specialist) who formally initiated the quarantine hold. Party reference for this transaction.' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Resolution Date' ;
    rdfs:comment 'Actual date on which the quarantine hold was resolved through release, rejection, or administrative closure. Compared against target resolution date for performance reporting.' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:affectedQuantityRejected rdf:type rdf:Property ;
    rdfs:label 'Affected Quantity Rejected' ;
    rdfs:comment 'Quantity of the originally held material that was condemned, destroyed, or returned to supplier following disposition. Together with affected_quantity_released, accounts for the full hold quantity.' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:affectedQuantityReleased rdf:type rdf:Property ;
    rdfs:label 'Affected Quantity Released' ;
    rdfs:comment 'Quantity of the originally held material that was ultimately released for use or shipment following disposition. May be less than hold_quantity if partial release was approved (e.g., after rework or resampling).' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerComplaintNumber rdf:type rdf:Property ;
    rdfs:label 'Customer Complaint Number' ;
    rdfs:comment 'Reference number of the customer complaint (from Salesforce CRM or SAP QM) that triggered the quarantine hold. Null for non-customer-complaint holds. Enables traceability from complaint to hold to disposition.' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionDecision rdf:type rdf:Property ;
    rdfs:label 'Disposition Decision' ;
    rdfs:comment 'Final disposition outcome for the quarantined material: \'released\' = approved for use or shipment; \'rejected\' = condemned and removed from usable stock; \'rework\' = returned to production for reprocessing; \'retest\' = additional testing required before final decision; \'return_to_supplier\' = returned to vendor; \'destroy\' = material to be destroyed per EHS protocols; \'conditional_release\' = released with documented restrictions. [ENUM-REF-CANDIDATE: released|rejected|rework|retest|return_to_supplier|destroy|conditional_release — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionJustification rdf:type rdf:Property ;
    rdfs:label 'Disposition Justification' ;
    rdfs:comment 'Free-text narrative documenting the technical and business rationale for the disposition decision. Required for GMP compliance and regulatory audit readiness.' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Disposition Timestamp' ;
    rdfs:comment 'Date and time when the disposition decision was formally approved and recorded. Distinct from actual resolution date; captures the precise moment of authorization.' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ghsHazardClass rdf:type rdf:Property ;
    rdfs:label 'Ghs Hazard Class' ;
    rdfs:comment 'GHS hazard classification of the quarantined material (e.g., \'Flammable Liquid Cat 2\', \'Acute Toxicity Cat 3\', \'Corrosive\'). Required for safe storage and handling during quarantine and for EHS compliance reporting.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdDate rdf:type rdf:Property ;
    rdfs:label 'Hold Date' ;
    rdfs:comment 'The date and timestamp when the quarantine hold was formally placed on the material or lot. Represents the principal business event time for this transaction.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdDurationDays rdf:type rdf:Property ;
    rdfs:label 'Hold Duration Days' ;
    rdfs:comment 'Number of calendar days the quarantine hold was active, calculated from hold_date to actual_resolution_date. Used for inventory aging analysis, SLA compliance reporting, and process improvement KPIs.' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:holdNumber rdf:type rdf:Property ;
    rdfs:label 'Hold Number' ;
    rdfs:comment 'Externally-known, human-readable reference number assigned to the quarantine hold at initiation (e.g., QH-2024-000123). Used in cross-functional communications, LIMS, and EHS systems.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdQuantity rdf:type rdf:Property ;
    rdfs:label 'Hold Quantity' ;
    rdfs:comment 'Quantity of material placed under quarantine hold. Represents the principal quantitative fact of this hold record. Must be expressed in the base unit of measure for the material.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holdQuantityUom rdf:type rdf:Property ;
    rdfs:label 'Hold Quantity Uom' ;
    rdfs:comment 'Unit of measure for the hold quantity (e.g., KG for kilograms, L for liters, MT for metric tons, DRUM for drum containers). Aligns with SAP base unit of measure (MEINS). [ENUM-REF-CANDIDATE: KG|LB|L|GAL|MT|TON|EA|BAG|DRUM|IBC — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdReasonCode rdf:type rdf:Property ;
    rdfs:label 'Hold Reason Code' ;
    rdfs:comment 'Standardized code indicating the primary reason for the quarantine hold. OOS = Out of Specification; OOT = Out of Trend; CUSTOMER_COMPLAINT = customer-reported quality issue; REGULATORY_HOLD = regulatory agency directive; DAMAGE = physical damage; CONTAMINATION = cross-contamination or foreign material; LABEL_ERROR = incorrect or missing labeling; PENDING_COA = Certificate of Analysis (COA) not yet received. [ENUM-REF-CANDIDATE: OOS|OOT|CUSTOMER_COMPLAINT|REGULATORY_HOLD|DAMAGE|CONTAMINATION|LABEL_ERROR|PENDING_COA — promote to reference product]' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Hold Reason Description' ;
    rdfs:comment 'Free-text narrative describing the specific reason for placing the material under quarantine hold. Provides context beyond the hold reason code, including test failure details, complaint summary, or regulatory directive reference.' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdStatus rdf:type rdf:Property ;
    rdfs:label 'Hold Status' ;
    rdfs:comment 'Current lifecycle state of the quarantine hold. \'open\' indicates active restriction; \'released\' indicates disposition approved for use/shipment; \'rejected\' indicates material condemned or destroyed; \'pending_review\' awaits disposition decision; \'escalated\' requires senior QA or regulatory review; \'closed\' is administratively finalized.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdType rdf:type rdf:Property ;
    rdfs:label 'Hold Type' ;
    rdfs:comment 'Classification of the quarantine hold by originating function: \'quality\' for QC/QA-initiated holds; \'regulatory\' for holds triggered by EPA, OSHA, or ECHA directives; \'safety\' for EHS-initiated holds; \'customer\' for customer complaint-driven holds; \'environmental\' for environmental compliance holds; \'administrative\' for documentation or system-related holds.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiatingSystem rdf:type rdf:Property ;
    rdfs:label 'Initiating System' ;
    rdfs:comment 'Source system that triggered or originated the quarantine hold (e.g., LIMS = LabWare LIMS for OOS results; EHS = Intelex EHS for safety incidents; SAP_QM = SAP Quality Management for inspection lot failures; MES = Manufacturing Execution System; MANUAL = manually initiated by QA personnel). [ENUM-REF-CANDIDATE: LIMS|EHS|SAP_QM|MES|MANUAL|SCADA|ERP — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiatorName rdf:type rdf:Property ;
    rdfs:label 'Initiator Name' ;
    rdfs:comment 'Full name of the person who initiated the quarantine hold. Retained for audit trail and regulatory reporting purposes where employee ID alone is insufficient.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limsInspectionLotNumber rdf:type rdf:Property ;
    rdfs:label 'Lims Inspection Lot Number' ;
    rdfs:comment 'Inspection lot number from LabWare LIMS that triggered the quarantine hold due to an Out of Specification (OOS) or Out of Trend (OOT) result. Enables direct cross-reference to the laboratory test record.' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryHoldReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Hold Reference' ;
    rdfs:comment 'External regulatory agency reference number or directive identifier when the hold is initiated by a regulatory body (e.g., EPA enforcement action number, OSHA citation reference, FDA warning letter number, ECHA restriction notice). Null for non-regulatory holds.' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdsNumber rdf:type rdf:Property ;
    rdfs:label 'Sds Number' ;
    rdfs:comment 'Reference number of the Safety Data Sheet (SDS) applicable to the quarantined material. Ensures proper handling, storage, and emergency response procedures are accessible during the hold period.' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Target Resolution Date' ;
    rdfs:comment 'Target date by which the quarantine hold disposition must be resolved (released or rejected). Used for SLA tracking, escalation management, and inventory planning.' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:stockMovementId rdf:type rdf:Property ;
    rdfs:label 'Stock Movement Id' ;
    rdfs:comment 'Unique surrogate identifier for each inventory movement event record in the silver layer lakehouse. Primary key for the stock_movement data product.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transferOrderId rdf:type rdf:Property ;
    rdfs:label 'Transfer Order Id' ;
    rdfs:comment 'Foreign key linking to inventory.transfer_order. Business justification: Link stock movement to its originating transfer order for end-to-end tracking; replace free-text field with FK.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TransferOrder .

ind:destinationStorageLocation rdf:type rdf:Property ;
    rdfs:label 'Destination Storage Location' ;
    rdfs:comment 'The SAP storage location code (Lagerort) to which the material is being moved or received. Represents the target warehouse area, tank farm zone, production staging area, or quarantine location. Null for pure outbound goods issues with no destination location within the plant.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fifoFefoValidationResult rdf:type rdf:Property ;
    rdfs:label 'Fifo Fefo Validation Result' ;
    rdfs:comment 'The result of the FIFO (First In First Out) or FEFO (First Expired First Out) lot rotation validation check performed at the time of goods issue. Passed = correct lot selected per rotation policy; Failed = incorrect lot selected, violating rotation rules; Not Applicable = movement type does not require lot rotation validation (e.g., goods receipt); Overridden = FIFO/FEFO rule was manually overridden with documented justification. Critical for chemical product quality, shelf-life management, and GMP compliance.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsReceiptBlocked rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Blocked' ;
    rdfs:comment 'Indicates whether this goods receipt movement was posted to GR blocked stock (Wareneingang gesperrt), meaning the material has been physically received but not yet released for use pending inspection or documentation review. True = posted to blocked GR stock; False = posted directly to unrestricted or inspection stock. Corresponds to SAP movement type 103/105 scenario.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:materialDocumentYear rdf:type rdf:Property ;
    rdfs:label 'Material Document Year' ;
    rdfs:comment 'The fiscal year in which the material document was posted in SAP S/4HANA MM. Combined with material_document_number forms the unique SAP document key (MBLNR + MJAHR).' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:movementAmount rdf:type rdf:Property ;
    rdfs:label 'Movement Amount' ;
    rdfs:comment 'The inventory valuation amount (in local currency) associated with this stock movement, representing the financial impact on inventory accounts. Calculated as quantity multiplied by the moving average price or standard price at time of posting. Used for COGS (Cost of Goods Sold) reporting, inventory valuation, and FI/CO integration. Corresponds to SAP DMBTR field.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:movementCategory rdf:type rdf:Property ;
    rdfs:label 'Movement Category' ;
    rdfs:comment 'High-level business classification of the inventory movement event. Goods Receipt (GR) covers inbound receipts from vendors or production; Goods Issue (GI) covers consumption or outbound shipments; Stock Transfer covers location-to-location moves; Return covers vendor or customer returns; Scrapping covers material write-offs; Sampling covers quality lab withdrawals; Revaluation covers price or valuation adjustments. Subsumes formerly separate goods_receipt and goods_issue records as movement subtypes. [ENUM-REF-CANDIDATE: goods_receipt|goods_issue|stock_transfer|return|scrapping|sampling|revaluation — promote to reference product]' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementDirection rdf:type rdf:Property ;
    rdfs:label 'Movement Direction' ;
    rdfs:comment 'Directional classification of the inventory movement relative to the plant or warehouse: inbound (stock entering the facility, e.g., goods receipt), outbound (stock leaving the facility, e.g., goods issue to customer or production), or internal (stock moving within the facility, e.g., storage location transfer). Used for net stock position calculations and directional reporting.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementReasonCode rdf:type rdf:Property ;
    rdfs:label 'Movement Reason Code' ;
    rdfs:comment 'A coded reason explaining why the inventory movement occurred, beyond what the movement type conveys. Examples include: production consumption, quality rejection, customer return, vendor return, cycle count adjustment, process loss, sampling withdrawal, spillage/waste, regulatory disposal. Corresponds to SAP GRUND field. [ENUM-REF-CANDIDATE: production_consumption|quality_rejection|customer_return|vendor_return|cycle_count_adjustment|process_loss|sampling|spillage|regulatory_disposal — promote to reference product]' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementReasonText rdf:type rdf:Property ;
    rdfs:label 'Movement Reason Text' ;
    rdfs:comment 'Free-text description providing additional context or explanation for the inventory movement reason, supplementing the movement_reason_code. Used for exception documentation, CAPA (Corrective and Preventive Action) linkage, and audit trail narratives. Corresponds to SAP text fields associated with GRUND.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementStatus rdf:type rdf:Property ;
    rdfs:label 'Movement Status' ;
    rdfs:comment 'Current lifecycle status of the stock movement record. Posted = successfully committed to inventory books; Reversed = cancelled by a subsequent reversal posting; Blocked = movement is on hold pending approval or investigation; Pending Approval = movement requires workflow approval before final posting (e.g., high-value scrapping). Supports workflow management and audit compliance.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Order Unit Of Measure' ;
    rdfs:comment 'The unit of measure used in the reference order document (purchase order, sales order, or production order) for this movement. Corresponds to SAP ERFME field. Enables reconciliation between order quantities and inventory quantities when UOM conversion applies.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityInOrderUom rdf:type rdf:Property ;
    rdfs:label 'Quantity In Order Uom' ;
    rdfs:comment 'The movement quantity expressed in the order unit of measure (e.g., purchase order UOM or sales order UOM), which may differ from the base unit of measure. For example, a material ordered in drums (DR) but managed in kilograms (KG). Corresponds to SAP ERFMG field.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:referenceDocumentItem rdf:type rdf:Property ;
    rdfs:label 'Reference Document Item' ;
    rdfs:comment 'The line item number within the reference document (e.g., PO line item, production order component line) associated with this inventory movement. Combined with reference_document_number provides precise traceability to the originating document line. Corresponds to SAP EBELP (PO item) field.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Document Number' ;
    rdfs:comment 'The number of the originating reference document (e.g., Purchase Order number, Production Order number, Sales Order number, Delivery number) that triggered this inventory movement. Provides the complete audit trail linking inventory movements back to procurement, production, or sales transactions. Corresponds to SAP EBELN (PO) or AUFNR (order) depending on context.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceDocumentType rdf:type rdf:Property ;
    rdfs:label 'Reference Document Type' ;
    rdfs:comment 'The type of the originating business document that triggered this inventory movement. Purchase Order (PO) for vendor receipts; Production Order or Process Order for manufacturing consumption/receipt; Sales Order for customer-specific stock; Delivery for outbound shipments; Transfer Order for warehouse transfers; Reservation for planned withdrawals. [ENUM-REF-CANDIDATE: purchase_order|production_order|sales_order|delivery|transfer_order|process_order|reservation — promote to reference product]' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversedDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reversed Document Number' ;
    rdfs:comment 'The material document number of the original movement that this record reverses, when reversal_flag is True. Enables bidirectional audit trail linking between original and reversal postings. Corresponds to SAP STBLG field.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourcePlantCode rdf:type rdf:Property ;
    rdfs:label 'Source Plant Code' ;
    rdfs:comment 'The SAP plant code of the sending plant for inter-plant stock transfer movements (STO - Stock Transfer Orders). Populated only for cross-plant transfers. Corresponds to SAP UMWRK field.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockType rdf:type rdf:Property ;
    rdfs:label 'Stock Type' ;
    rdfs:comment 'The SAP stock type category indicating the usability status of the inventory being moved. Unrestricted stock is available for use; Quality Inspection stock is under QC hold pending COA approval; Blocked stock is restricted from use (e.g., OOS - Out of Specification); Restricted stock has conditional use limitations; Returns stock is customer-returned material awaiting disposition. Corresponds to SAP SOBKZ / INSMK fields.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationType rdf:type rdf:Property ;
    rdfs:label 'Valuation Type' ;
    rdfs:comment 'SAP valuation type (Bewertungsart - BWTAR) used when a material is managed with split valuation — for example, differentiating between domestic-sourced and imported raw materials, or between different quality grades of the same chemical. Enables separate inventory valuation for the same material number.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryTargetId rdf:type rdf:Property ;
    rdfs:label 'Inventory Target Id' ;
    rdfs:comment 'Unique surrogate identifier for each stock position record representing a material at a specific storage location, bin, or tank farm. Primary key for the stock_position data product.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventoryTarget .

ind:primaryStockMaterialMasterId rdf:type rdf:Property ;
    rdfs:label 'Primary Stock Material Master Id' ;
    rdfs:comment 'Reference to the material master record identifying the specific raw material, intermediate, finished good, or packaging material held in this stock position. Sourced from SAP MM material master.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialMaster .

ind:stockMaterialMasterId rdf:type rdf:Property ;
    rdfs:label 'Stock Material Master Id' ;
    rdfs:comment 'FK to rawmaterial.material_master' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialMaster .

ind:availableQuantity rdf:type rdf:Property ;
    rdfs:label 'Available Quantity' ;
    rdfs:comment 'Quantity of the material available for unrestricted use, calculated as on-hand quantity minus reserved, blocked, and quality inspection quantities. Drives ATP (Available-to-Promise) checks in SAP SD and production planning in SAP PP.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:blockedQuantity rdf:type rdf:Property ;
    rdfs:label 'Blocked Quantity' ;
    rdfs:comment 'Quantity of the material placed in blocked stock status due to quality failures, regulatory holds, damage, or quarantine. Blocked stock is not available for production or shipment until released by QA or EHS.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inTransitQuantity rdf:type rdf:Property ;
    rdfs:label 'In Transit Quantity' ;
    rdfs:comment 'Quantity of the material currently in transit between storage locations, plants, or external suppliers. Represents stock that has been shipped but not yet received at the destination, tracked via SAP EWM transfer orders.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastCountDate rdf:type rdf:Property ;
    rdfs:label 'Last Count Date' ;
    rdfs:comment 'The date on which the most recent physical inventory count or cycle count was performed for this stock position. Used to assess inventory accuracy and schedule next count per SOX and ISO 9001 audit requirements.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastMovementDate rdf:type rdf:Property ;
    rdfs:label 'Last Movement Date' ;
    rdfs:comment 'The date of the most recent inventory movement (goods issue, goods receipt, transfer order, or stock transfer) affecting this stock position. Used to identify slow-moving or obsolete inventory for write-off analysis.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lotRotationMethod rdf:type rdf:Property ;
    rdfs:label 'Lot Rotation Method' ;
    rdfs:comment 'The inventory rotation strategy applied to this stock position for picking and consumption sequencing. FIFO (First In First Out) is used for most materials; FEFO (First Expired First Out) is mandatory for materials with expiration dates per GMP requirements.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumStockQuantity rdf:type rdf:Property ;
    rdfs:label 'Maximum Stock Quantity' ;
    rdfs:comment 'The maximum allowable stock quantity for this material at this storage location, constrained by tank capacity, regulatory storage limits, or warehouse space. Enforced by SAP EWM capacity checks and EHS hazmat storage quantity limits under OSHA PSM.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onHandQuantity rdf:type rdf:Property ;
    rdfs:label 'On Hand Quantity' ;
    rdfs:comment 'Total physical quantity of the material currently present at the storage location, including all stock types (unrestricted, quality inspection, blocked). Represents the gross inventory position before any reservations or holds are applied.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityInspectionQuantity rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Quantity' ;
    rdfs:comment 'Quantity of the material currently under quality inspection in the LIMS or SAP QM module. This stock is not available for use until the inspection lot is closed and the material is released to unrestricted stock.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reorderPoint rdf:type rdf:Property ;
    rdfs:label 'Reorder Point' ;
    rdfs:comment 'The minimum stock level at which a replenishment order should be triggered for this material at this storage location. Used by SAP MRP (Material Requirements Planning) to generate purchase requisitions or production orders automatically.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reservedQuantity rdf:type rdf:Property ;
    rdfs:label 'Reserved Quantity' ;
    rdfs:comment 'Quantity of the material reserved against open production orders, sales orders, or transfer orders in SAP. Reserved stock is committed but not yet physically moved, reducing the available quantity for new demand.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyStockQuantity rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Quantity' ;
    rdfs:comment 'The minimum buffer stock quantity maintained to protect against supply disruptions, demand variability, or lead time uncertainty. Defined in SAP MRP parameters and used in available quantity calculations for production planning.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:snapshotTimestamp rdf:type rdf:Property ;
    rdfs:label 'Snapshot Timestamp' ;
    rdfs:comment 'The date and time at which this stock position record was captured or last refreshed from the source system (SAP EWM/S4HANA). Represents the as-of time for the inventory snapshot, critical for real-time inventory reporting and reconciliation.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:stockCategory rdf:type rdf:Property ;
    rdfs:label 'Stock Category' ;
    rdfs:comment 'Classification of the material type held in this stock position. Drives inventory valuation rules, storage compliance requirements, and reporting segmentation across raw materials, intermediates, finished goods, and packaging materials.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockStatus rdf:type rdf:Property ;
    rdfs:label 'Stock Status' ;
    rdfs:comment 'Current lifecycle status of the stock position record. Quarantine status is applied when material is pending investigation or regulatory hold. Expired indicates the material has passed its expiration date. Recalled indicates a product recall event has been triggered.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageType rdf:type rdf:Property ;
    rdfs:label 'Storage Type' ;
    rdfs:comment 'Classification of the physical storage infrastructure type where the material is held. Drives hazardous material storage compliance rules under OSHA PSM, NFPA, and DOT regulations. [ENUM-REF-CANDIDATE: bulk_tank|drum_rack|pallet_rack|cold_storage|hazmat_cage|silo|ibc_bay — promote to reference product]' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationClass rdf:type rdf:Property ;
    rdfs:label 'Valuation Class' ;
    rdfs:comment 'SAP valuation class code that determines the general ledger (GL) accounts to which inventory postings are made for this material. Links inventory movements to the correct COGS and balance sheet accounts per FASB and SOX requirements.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationCurrency rdf:type rdf:Property ;
    rdfs:label 'Valuation Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the valuation_price is expressed (e.g., USD, EUR). Required for multi-currency inventory valuation reporting across global plant locations.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockReservationId rdf:type rdf:Property ;
    rdfs:label 'Stock Reservation Id' ;
    rdfs:comment 'Unique system-generated surrogate identifier for the stock reservation record in the inventory management system.' ;
    rdfs:domain ind:StockReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reservedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Reserved By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Inventory allocation reports need the employee who performed the reservation to track accountability and labor costing.' ;
    rdfs:domain ind:StockReservation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:autoReleaseFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Release Flag' ;
    rdfs:comment 'Indicates whether the reservation should be automatically released back to available stock upon reaching the expiry date without fulfillment. Supports automated inventory management and prevents indefinite stock lock-up.' ;
    rdfs:domain ind:StockReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consumingOrderType rdf:type rdf:Property ;
    rdfs:label 'Consuming Order Type' ;
    rdfs:comment 'Specifies the type of the consuming order document. Distinguishes between production orders, process orders (for batch chemical manufacturing), sales delivery orders, maintenance orders, and project orders to support domain-specific analytics.' ;
    rdfs:domain ind:StockReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfilledQuantity rdf:type rdf:Property ;
    rdfs:label 'Fulfilled Quantity' ;
    rdfs:comment 'Cumulative quantity of the reservation that has already been issued or withdrawn against the consuming order. Used to calculate the remaining open quantity and determine partial fulfillment status.' ;
    rdfs:domain ind:StockReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partialFulfillmentAllowed rdf:type rdf:Property ;
    rdfs:label 'Partial Fulfillment Allowed' ;
    rdfs:comment 'Indicates whether the consuming order can accept a partial goods issue against this reservation, or whether the full reserved quantity must be issued in a single transaction. Relevant for batch chemical processes with minimum charge quantities.' ;
    rdfs:domain ind:StockReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reachCompliant rdf:type rdf:Property ;
    rdfs:label 'Reach Compliant' ;
    rdfs:comment 'Indicates whether the reserved material lot has been verified as compliant with REACH regulation requirements at the time of reservation. Prevents issuance of non-compliant chemical stock to production.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requirementDate rdf:type rdf:Property ;
    rdfs:label 'Requirement Date' ;
    rdfs:comment 'The date on which the reserved material is required for consumption by the planned event (production start date, delivery date, or maintenance execution date). Drives FEFO/FIFO lot selection and warehouse picking scheduling.' ;
    rdfs:domain ind:StockReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reservationDate rdf:type rdf:Property ;
    rdfs:label 'Reservation Date' ;
    rdfs:comment 'The business date on which the stock reservation was created and the stock was earmarked. Represents the principal real-world event time for the reservation transaction.' ;
    rdfs:domain ind:StockReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reservationNumber rdf:type rdf:Property ;
    rdfs:label 'Reservation Number' ;
    rdfs:comment 'Externally-known alphanumeric reservation document number assigned by the ERP or WMS system (e.g., SAP reservation number). Used for cross-system reference and communication with warehouse operations.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reservationReasonCode rdf:type rdf:Property ;
    rdfs:label 'Reservation Reason Code' ;
    rdfs:comment 'Business reason code explaining why the reservation was created (e.g., scheduled production run, emergency maintenance, customer priority order, safety stock replenishment). Supports demand analysis and inventory planning. [ENUM-REF-CANDIDATE: scheduled_production|emergency_maintenance|customer_priority|safety_stock|quality_sample|r_and_d_trial|regulatory_hold — promote to reference product]' ;
    rdfs:domain ind:StockReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reservationStatus rdf:type rdf:Property ;
    rdfs:label 'Reservation Status' ;
    rdfs:comment 'Current lifecycle state of the stock reservation. \'open\' indicates no goods movement has occurred; \'partially_fulfilled\' indicates some quantity has been issued; \'fulfilled\' indicates full quantity has been issued; \'cancelled\' indicates the reservation was voided before consumption.' ;
    rdfs:domain ind:StockReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reservationType rdf:type rdf:Property ;
    rdfs:label 'Reservation Type' ;
    rdfs:comment 'Classification of the demand event driving the reservation. Distinguishes between production order consumption, customer delivery fulfillment, maintenance work order material staging, project-based withdrawal, or manually created reservations.' ;
    rdfs:domain ind:StockReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdsVerified rdf:type rdf:Property ;
    rdfs:label 'Sds Verified' ;
    rdfs:comment 'Indicates whether the current Safety Data Sheet (SDS) for the reserved material has been verified as up-to-date and accessible prior to reservation fulfillment. Required for hazardous chemical handling compliance.' ;
    rdfs:domain ind:StockReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:storageBinId rdf:type rdf:Property ;
    rdfs:label 'Storage Bin Id' ;
    rdfs:comment 'Unique surrogate identifier for the storage bin master record in the SAP Extended Warehouse Management (EWM) system. Serves as the primary key for all bin-level inventory tracking and directed putaway/picking operations.' ;
    rdfs:domain ind:StorageBin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:aisle rdf:type rdf:Property ;
    rdfs:label 'Aisle' ;
    rdfs:comment 'Aisle identifier within the warehouse where the storage bin is physically located. Used for warehouse navigation, slotting optimization, and pick path sequencing.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allowedMaterialTypes rdf:type rdf:Property ;
    rdfs:label 'Allowed Material Types' ;
    rdfs:comment 'Comma-separated list of SAP material type codes (e.g., ROH for raw materials, FERT for finished goods, HALB for semi-finished, VERP for packaging) permitted to be stored in this bin. Enforces material segregation rules for chemical compatibility and regulatory compliance.' ;
    rdfs:domain ind:StorageBin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:binAccessType rdf:type rdf:Property ;
    rdfs:label 'Bin Access Type' ;
    rdfs:comment 'Type of material handling equipment required to access this storage bin. Determines equipment assignment during transfer order creation and supports warehouse resource planning. Critical for safety compliance in chemical warehouses where certain hazmat bins require specialized handling equipment.' ;
    rdfs:domain ind:StorageBin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:binCode rdf:type rdf:Property ;
    rdfs:label 'Bin Code' ;
    rdfs:comment 'Alphanumeric code that uniquely identifies the physical storage bin within a warehouse number and storage type. Corresponds to the SAP EWM Lgpla field. Used in directed putaway, picking, and bin-level inventory queries.' ;
    rdfs:domain ind:StorageBin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:binDescription rdf:type rdf:Property ;
    rdfs:label 'Bin Description' ;
    rdfs:comment 'Free-text description of the storage bin providing additional context about its physical characteristics, special use restrictions, or operational notes. May include information about dedicated chemical families, special handling requirements, or historical usage notes.' ;
    rdfs:domain ind:StorageBin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:binName rdf:type rdf:Property ;
    rdfs:label 'Bin Name' ;
    rdfs:comment 'Human-readable descriptive name or label for the storage bin, used in warehouse operations, signage, and reporting. May include aisle, row, and level descriptors (e.g., \'Aisle-A Row-03 Level-02\') to aid physical navigation.' ;
    rdfs:domain ind:StorageBin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:binStatus rdf:type rdf:Property ;
    rdfs:label 'Bin Status' ;
    rdfs:comment 'Current operational lifecycle status of the storage bin. Active bins are available for putaway and picking. Blocked bins are temporarily unavailable. Quarantine status is applied when contents are under quality hold per QM procedures. Maintenance status indicates the bin is undergoing physical inspection or repair.' ;
    rdfs:domain ind:StorageBin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:binType rdf:type rdf:Property ;
    rdfs:label 'Bin Type' ;
    rdfs:comment 'Classification of the physical bin configuration. Fixed bins are dedicated to specific materials (e.g., hazardous chemicals); random bins accept any compatible material; bulk bins hold large quantities; tank bins represent liquid storage vessels in tank farms; floor bins are ground-level pallet positions; rack bins are elevated rack locations.' ;
    rdfs:domain ind:StorageBin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containmentType rdf:type rdf:Property ;
    rdfs:label 'Containment Type' ;
    rdfs:comment 'Type of secondary containment infrastructure present at this storage bin to prevent chemical spills from reaching drains or the environment. Secondary bund and tank bund are used for bulk liquid chemical storage; spill pallets for drum storage; lined floor for general chemical areas. Required for EPA SPCC compliance and ISO 14001 environmental management.' ;
    rdfs:domain ind:StorageBin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Current Volume M3' ;
    rdfs:comment 'Current total volume in cubic meters occupied by stock in the bin. Compared against max_volume_m3 to determine available capacity for putaway decisions.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentWeightKg rdf:type rdf:Property ;
    rdfs:label 'Current Weight Kg' ;
    rdfs:comment 'Current total gross weight in kilograms of all stock currently stored in the bin. Updated upon each goods movement. Used to monitor bin load against maximum weight capacity and support structural safety compliance.' ;
    rdfs:domain ind:StorageBin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deactivationDate rdf:type rdf:Property ;
    rdfs:label 'Deactivation Date' ;
    rdfs:comment 'Date on which the storage bin was or is scheduled to be deactivated and removed from active warehouse operations. Null for currently active bins. Supports bin lifecycle management and warehouse restructuring projects.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fireProtectionZone rdf:type rdf:Property ;
    rdfs:label 'Fire Protection Zone' ;
    rdfs:comment 'NFPA fire protection zone or compartment designation assigned to the storage bin. Used to enforce fire load limits, sprinkler system coverage mapping, and emergency response planning for flammable and combustible chemical storage areas.' ;
    rdfs:domain ind:StorageBin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isFixedBin rdf:type rdf:Property ;
    rdfs:label 'Is Fixed Bin' ;
    rdfs:comment 'Indicates whether this bin is a fixed bin permanently assigned to a specific material or material group, as opposed to a random bin available for any compatible material. True = fixed bin assignment; False = random bin. Drives SAP EWM putaway strategy determination.' ;
    rdfs:domain ind:StorageBin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHazmatApproved rdf:type rdf:Property ;
    rdfs:label 'Is Hazmat Approved' ;
    rdfs:comment 'Indicates whether this storage bin has been formally approved and certified for the storage of hazardous materials in compliance with OSHA PSM, EPA RMP, and GHS regulations. True = approved for hazmat storage; False = not approved.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isQuarantineBin rdf:type rdf:Property ;
    rdfs:label 'Is Quarantine Bin' ;
    rdfs:comment 'Indicates whether this bin is designated as a quarantine storage location for materials under quality hold, out-of-specification (OOS) status, or pending Certificate of Analysis (COA) release. True = quarantine bin; False = standard bin. Integrates with SAP QM quality inspection workflows.' ;
    rdfs:domain ind:StorageBin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastPhysicalInventoryDate rdf:type rdf:Property ;
    rdfs:label 'Last Physical Inventory Date' ;
    rdfs:comment 'Date on which the most recent physical inventory count or cycle count was performed for this storage bin. Used to track inventory accuracy compliance, schedule future counts, and support SOX financial reporting requirements for inventory valuation.' ;
    rdfs:domain ind:StorageBin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maxQuantity rdf:type rdf:Property ;
    rdfs:label 'Max Quantity' ;
    rdfs:comment 'Maximum number of handling units (pallets, drums, IBCs, or containers) that can be stored in the bin simultaneously. Enforced during directed putaway to prevent overfilling.' ;
    rdfs:domain ind:StorageBin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxStackingHeightM rdf:type rdf:Property ;
    rdfs:label 'Max Stacking Height M' ;
    rdfs:comment 'Maximum allowable stacking height in meters for materials stored in this bin. Enforced to prevent structural overload and comply with OSHA stacking safety regulations. Particularly relevant for drum and IBC storage of liquid chemicals.' ;
    rdfs:domain ind:StorageBin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Max Temperature C' ;
    rdfs:comment 'Maximum allowable storage temperature in degrees Celsius for this bin. Prevents thermal degradation, polymerization, or hazardous decomposition of stored chemicals. Critical for compliance with SDS storage requirements.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Max Volume M3' ;
    rdfs:comment 'Maximum storage volume in cubic meters available within the bin. Used for volumetric capacity planning, putaway feasibility checks, and tank farm liquid volume management.' ;
    rdfs:domain ind:StorageBin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxWeightKg rdf:type rdf:Property ;
    rdfs:label 'Max Weight Kg' ;
    rdfs:comment 'Maximum allowable gross weight in kilograms that the storage bin can safely hold, including packaging and handling units. Critical for structural safety compliance and overload prevention in chemical warehouses storing dense raw materials or bulk liquids.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Min Temperature C' ;
    rdfs:comment 'Minimum allowable storage temperature in degrees Celsius for this bin. Enforced for temperature-sensitive chemical raw materials, intermediates, and finished goods to prevent degradation, crystallization, or phase separation.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextInspectionDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Inspection Due Date' ;
    rdfs:comment 'Scheduled date for the next mandatory safety or structural inspection of the storage bin. Drives preventive maintenance scheduling and ensures continuous compliance with OSHA, NFPA, and ISO 45001 inspection frequency requirements.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:occupancyStatus rdf:type rdf:Property ;
    rdfs:label 'Occupancy Status' ;
    rdfs:comment 'Real-time occupancy state of the storage bin indicating whether the bin is empty, fully occupied, partially occupied, or reserved for an incoming transfer order. Drives directed putaway logic in SAP EWM and supports inventory accuracy reporting.' ;
    rdfs:domain ind:StorageBin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickingPoint rdf:type rdf:Property ;
    rdfs:label 'Picking Point' ;
    rdfs:comment 'SAP EWM picking point bin code associated with this storage bin. For bulk or reserve storage bins, identifies the forward pick face bin from which order picking is executed. Supports two-step picking workflows common in chemical distribution operations.' ;
    rdfs:domain ind:StorageBin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:putawayStrategy rdf:type rdf:Property ;
    rdfs:label 'Putaway Strategy' ;
    rdfs:comment 'SAP EWM putaway strategy assigned to this bin that determines how incoming stock is directed to storage locations. Fixed strategy assigns stock to pre-defined bins; open storage allows any compatible bin; bulk strategy consolidates large quantities; near-picking places fast-movers close to pick areas; addition-to-existing consolidates partial bins.' ;
    rdfs:domain ind:StorageBin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rotationStrategy rdf:type rdf:Property ;
    rdfs:label 'Rotation Strategy' ;
    rdfs:comment 'Inventory lot rotation strategy applied to this bin for picking sequence determination. FIFO (First In First Out) is standard for most chemicals; FEFO (First Expired First Out) is mandatory for materials with expiration dates to prevent use of expired lots; LIFO and LEFO are used in specific bulk storage scenarios. Aligns with GMP and ISO 9001 inventory management requirements.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rowNumber rdf:type rdf:Property ;
    rdfs:label 'Row Number' ;
    rdfs:comment 'Row number within the aisle that identifies the horizontal position of the storage bin. Combined with aisle and level, provides the full physical coordinate of the bin within the warehouse.' ;
    rdfs:domain ind:StorageBin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageBinLevel rdf:type rdf:Property ;
    rdfs:label 'Storage Bin Level' ;
    rdfs:comment 'Vertical level or tier of the storage bin within a rack structure. Level 1 is ground floor; higher numbers indicate elevated rack positions. Used for equipment assignment (e.g., forklift vs. reach truck) and weight distribution planning.' ;
    rdfs:domain ind:StorageBin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageSectionCode rdf:type rdf:Property ;
    rdfs:label 'Storage Section Code' ;
    rdfs:comment 'SAP EWM storage section (Lgber) code that subdivides a storage type into logical groupings, such as fast-moving, slow-moving, or temperature-controlled sections. Used to optimize putaway strategies for chemical raw materials and finished goods.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageTypeCode rdf:type rdf:Property ;
    rdfs:label 'Storage Type Code' ;
    rdfs:comment 'SAP EWM storage type (Lgtyp) code that classifies the physical area of the warehouse where this bin resides, such as high-rack storage, bulk storage, tank farm, or hazardous material area. Drives putaway and picking strategies.' ;
    rdfs:domain ind:StorageBin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureZone rdf:type rdf:Property ;
    rdfs:label 'Temperature Zone' ;
    rdfs:comment 'Temperature-controlled storage zone classification for the bin. Ambient bins operate at room temperature; refrigerated bins maintain 2–8°C for temperature-sensitive chemicals or intermediates; heated bins prevent solidification of high-melting-point materials; controlled bins maintain a specific validated temperature range per product specification.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ventilationRequired rdf:type rdf:Property ;
    rdfs:label 'Ventilation Required' ;
    rdfs:comment 'Indicates whether this storage bin requires dedicated ventilation or is located in a ventilated area to manage volatile organic compound (VOC) emissions or hazardous air pollutant (HAP) concentrations. True = ventilation required; False = no special ventilation needed. Supports EHS compliance with EPA and OSHA air quality standards.' ;
    rdfs:domain ind:StorageBin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tankFarmLevelId rdf:type rdf:Property ;
    rdfs:label 'Tank Farm Level Id' ;
    rdfs:comment 'Unique surrogate identifier for each tank farm level measurement record in the Silver Layer lakehouse. Primary key for this entity.' ;
    rdfs:domain ind:TankFarmLevel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryTankMaterialMasterId rdf:type rdf:Property ;
    rdfs:label 'Primary Tank Material Master Id' ;
    rdfs:comment 'Reference to the material master record identifying the bulk liquid chemical currently stored in the tank at the time of measurement.' ;
    rdfs:domain ind:TankFarmLevel ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialMaster .

ind:tankId rdf:type rdf:Property ;
    rdfs:label 'Tank Id' ;
    rdfs:comment 'Reference to the storage tank asset record that this level measurement belongs to. Links to the tank master data entity in the inventory or asset domain.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Tank .

ind:tankMaterialMasterId rdf:type rdf:Property ;
    rdfs:label 'Tank Material Master Id' ;
    rdfs:comment 'FK to rawmaterial.material_master' ;
    rdfs:domain ind:TankFarmLevel ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialMaster .

ind:belowReorderPointFlag rdf:type rdf:Property ;
    rdfs:label 'Below Reorder Point Flag' ;
    rdfs:comment 'Indicates whether the current tank inventory mass is at or below the defined reorder point threshold (True = replenishment required, False = adequate stock). Enables real-time inventory replenishment alerting and integration with SAP MM MRP processes.' ;
    rdfs:domain ind:TankFarmLevel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataCollectionMethod rdf:type rdf:Property ;
    rdfs:label 'Data Collection Method' ;
    rdfs:comment 'Describes how this measurement record was collected: automatic (real-time instrument feed via PI historian), manual (operator-entered gauge reading), or interpolated (value estimated between two valid readings). Supports data quality governance and audit trail requirements.' ;
    rdfs:domain ind:TankFarmLevel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:densityKgM3 rdf:type rdf:Property ;
    rdfs:label 'Density Kg M3' ;
    rdfs:comment 'The density of the stored liquid at the measurement temperature, expressed in kilograms per cubic meter (kg/m³). Used to convert volume measurements to mass for inventory valuation and material balance. May be measured in-line or derived from temperature-corrected reference data.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ghsHazardCategory rdf:type rdf:Property ;
    rdfs:label 'Ghs Hazard Category' ;
    rdfs:comment 'The GHS hazard category code for the stored chemical (e.g., Flammable Liquid Cat 1, Acute Toxicity Cat 3). Supports SDS compliance, emergency response documentation, and regulatory reporting under REACH, TSCA, and EPA requirements.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatStorageClass rdf:type rdf:Property ;
    rdfs:label 'Hazmat Storage Class' ;
    rdfs:comment 'The hazardous material storage class designation for the chemical stored in the tank, based on GHS/DOT classification (e.g., Class 3 Flammable Liquid, Class 8 Corrosive). Used for EHS compliance, emergency response planning, and segregation requirement enforcement. [ENUM-REF-CANDIDATE: class_1_explosive|class_2_gas|class_3_flammable_liquid|class_4_flammable_solid|class_5_oxidizer|class_6_toxic|class_7_radioactive|class_8_corrosive|class_9_misc — promote to reference product]' ;
    rdfs:domain ind:TankFarmLevel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:highLevelAlarm rdf:type rdf:Property ;
    rdfs:label 'High Level Alarm' ;
    rdfs:comment 'Indicates whether the high-level alarm setpoint was active (True) or inactive (False) at the time of measurement. A high-level alarm signals that the tank level has reached or exceeded the high alarm threshold, requiring immediate operational attention to prevent overfill.' ;
    rdfs:domain ind:TankFarmLevel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:instrumentTag rdf:type rdf:Property ;
    rdfs:label 'Instrument Tag' ;
    rdfs:comment 'The P&ID instrument tag identifier for the level transmitter or gauge device that produced this measurement (e.g., LT-101, LIT-2204). Enables traceability to the physical instrument for calibration records, maintenance history, and instrument reliability analysis.' ;
    rdfs:domain ind:TankFarmLevel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryValueUsd rdf:type rdf:Property ;
    rdfs:label 'Inventory Value Usd' ;
    rdfs:comment 'The estimated financial value of the bulk chemical inventory in the tank at the time of measurement, expressed in US Dollars. Calculated from mass_kg and the current standard or moving average cost from SAP FI/CO. Used for inventory valuation reporting and financial close processes.' ;
    rdfs:domain ind:TankFarmLevel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:levelM rdf:type rdf:Property ;
    rdfs:label 'Level M' ;
    rdfs:comment 'The measured liquid level height in the tank expressed in meters, as reported by the level transmitter instrument and captured in the Aveva PI System historian. This is the primary raw measurement value for continuous inventory tracking.' ;
    rdfs:domain ind:TankFarmLevel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:levelPercent rdf:type rdf:Property ;
    rdfs:label 'Level Percent' ;
    rdfs:comment 'The current tank fill level expressed as a percentage of the tank\'s maximum working capacity (0-100%). Provides an intuitive operational view of tank utilization for dashboards, alerts, and capacity planning without requiring knowledge of tank dimensions.' ;
    rdfs:domain ind:TankFarmLevel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lowLevelAlarm rdf:type rdf:Property ;
    rdfs:label 'Low Level Alarm' ;
    rdfs:comment 'Indicates whether the low-level alarm setpoint was active (True) or inactive (False) at the time of measurement. A low-level alarm signals that the tank level has dropped to or below the low alarm threshold, indicating potential supply shortage or pump cavitation risk.' ;
    rdfs:domain ind:TankFarmLevel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:massKg rdf:type rdf:Property ;
    rdfs:label 'Mass Kg' ;
    rdfs:comment 'The calculated mass of the liquid inventory in the tank expressed in kilograms, derived from volume and density. Used for material balance, production accounting, and regulatory emission calculations (e.g., EPA TRI, VOC reporting).' ;
    rdfs:domain ind:TankFarmLevel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementQuality rdf:type rdf:Property ;
    rdfs:label 'Measurement Quality' ;
    rdfs:comment 'The data quality indicator for this measurement record as reported by the Aveva PI System historian (e.g., Good, Bad, Uncertain, Substituted). Reflects instrument health, communication status, or manual data substitution. Used to filter unreliable readings in analytics and reporting.' ;
    rdfs:domain ind:TankFarmLevel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementSource rdf:type rdf:Property ;
    rdfs:label 'Measurement Source' ;
    rdfs:comment 'Identifies the originating source system or method for this level measurement record. Distinguishes between automated PI historian readings, manual gauge readings entered by operators, DCS/SCADA system feeds, calculated values from strapping tables, or estimated values.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:piTagName rdf:type rdf:Property ;
    rdfs:label 'Pi Tag Name' ;
    rdfs:comment 'The Aveva PI System historian tag identifier (e.g., SITE01.TK-101.LEVEL) that is the source of this measurement record. Enables traceability back to the originating instrument data stream in the process historian.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reorderPointKg rdf:type rdf:Property ;
    rdfs:label 'Reorder Point Kg' ;
    rdfs:comment 'The inventory mass threshold in kilograms at which a replenishment order should be triggered for this tank. When mass_kg falls at or below this value, procurement or supply chain teams are alerted to initiate a purchase order or transfer. Supports continuous inventory management for bulk chemicals.' ;
    rdfs:domain ind:TankFarmLevel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tankCapacityM3 rdf:type rdf:Property ;
    rdfs:label 'Tank Capacity M3' ;
    rdfs:comment 'The nominal or maximum working capacity of the tank in cubic meters as defined in the tank design specification and strapping table. Stored with the measurement record to enable percentage calculations and capacity utilization reporting without requiring a join to the tank master.' ;
    rdfs:domain ind:TankFarmLevel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tankFarmName rdf:type rdf:Property ;
    rdfs:label 'Tank Farm Name' ;
    rdfs:comment 'The name or designation of the tank farm area or storage cluster where the tank is physically located (e.g., North Tank Farm, Solvent Storage Area). Supports area-level inventory aggregation and reporting.' ;
    rdfs:domain ind:TankFarmLevel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tankNumber rdf:type rdf:Property ;
    rdfs:label 'Tank Number' ;
    rdfs:comment 'The human-readable functional identifier of the storage tank as designated in the plant P&ID (Piping and Instrumentation Diagram) and SAP PM equipment master (e.g., TK-101, T-2204). Used for operational reference and reporting.' ;
    rdfs:domain ind:TankFarmLevel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureC rdf:type rdf:Property ;
    rdfs:label 'Temperature C' ;
    rdfs:comment 'The temperature of the liquid in the tank at the time of measurement, expressed in degrees Celsius. Temperature is required for density correction, volume-to-mass conversion, and monitoring of temperature-sensitive chemicals to ensure safe storage conditions.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureDeviationFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Deviation Flag' ;
    rdfs:comment 'Indicates whether the measured temperature at the time of this record was outside the defined safe storage temperature range (True = deviation detected, False = within range). Supports EHS compliance monitoring and automated alerting for temperature-sensitive chemical storage.' ;
    rdfs:domain ind:TankFarmLevel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ullageM rdf:type rdf:Property ;
    rdfs:label 'Ullage M' ;
    rdfs:comment 'The available headspace (ullage) in the tank expressed in meters, calculated as the difference between the maximum allowable working level and the current measured level. Critical for safe filling operations, overfill prevention, and scheduling inbound deliveries.' ;
    rdfs:domain ind:TankFarmLevel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ullageVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Ullage Volume M3' ;
    rdfs:comment 'The available headspace volume in the tank expressed in cubic meters, representing the remaining capacity available for additional material. Used for logistics planning, delivery scheduling, and overfill risk management.' ;
    rdfs:domain ind:TankFarmLevel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeLiters rdf:type rdf:Property ;
    rdfs:label 'Volume Liters' ;
    rdfs:comment 'The calculated volume of liquid in the tank expressed in liters, derived from the level measurement and tank strapping table. Used for inventory quantity reporting and material balance calculations.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:handlingUnitId rdf:type rdf:Property ;
    rdfs:label 'Handling Unit Id' ;
    rdfs:comment 'SAP EWM handling unit identifier (pallet, IBC, drum, container) being physically moved. Links the transfer order to the physical packaging unit for scan-based confirmation and traceability.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HandlingUnit .

ind:warehouseTaskId rdf:type rdf:Property ;
    rdfs:label 'Warehouse Task Id' ;
    rdfs:comment 'SAP EWM warehouse task identifier linked to this transfer order. A transfer order may be decomposed into one or more warehouse tasks for execution by operators or automated systems (e.g., conveyor, AGV).' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WarehouseTask .

ind:cancellationReason rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason' ;
    rdfs:comment 'Free-text or coded reason for cancellation of the transfer order (e.g., material not found at source bin, bin blocked, production order cancelled, duplicate order). Supports root cause analysis and process improvement.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cancellation Timestamp' ;
    rdfs:comment 'Date and time when the transfer order was cancelled in SAP EWM. Populated only when transfer_order_status = \'cancelled\'. Used for exception reporting and warehouse efficiency analysis.' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:confirmationMethod rdf:type rdf:Property ;
    rdfs:label 'Confirmation Method' ;
    rdfs:comment 'Method used by the operator or system to confirm execution of the transfer order. \'rf_scan\' = RF barcode/RFID scanner; \'manual\' = paper-based or keyboard entry; \'automated_conveyor\' = conveyor system auto-confirmation; \'voice_picking\' = voice-directed warehouse system; \'agv\' = automated guided vehicle.' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmedQuantity rdf:type rdf:Property ;
    rdfs:label 'Confirmed Quantity' ;
    rdfs:comment 'Actual quantity confirmed as physically moved by the operator upon transfer order completion. May differ from transfer_quantity due to partial picks, short picks, or discrepancies discovered during execution.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confirmedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Confirmed Timestamp' ;
    rdfs:comment 'Date and time when the transfer order was fully confirmed in SAP EWM, triggering the inventory goods movement posting. Represents the principal business event time for this transaction.' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:destinationBin rdf:type rdf:Property ;
    rdfs:label 'Destination Bin' ;
    rdfs:comment 'Alphanumeric identifier of the specific storage bin, rack location, or tank to which the material is being moved. Represents the physical destination within the warehouse complex.' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationStorageSection rdf:type rdf:Property ;
    rdfs:label 'Destination Storage Section' ;
    rdfs:comment 'SAP EWM storage section within the destination storage type, providing logical grouping of target bins.' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationStorageType rdf:type rdf:Property ;
    rdfs:label 'Destination Storage Type' ;
    rdfs:comment 'SAP EWM storage type code for the target location. Used to validate compatibility with material hazard classification and storage requirements (e.g., flammable, corrosive, oxidizer segregation per OSHA PSM and NFPA codes).' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsMovementDocument rdf:type rdf:Property ;
    rdfs:label 'Goods Movement Document' ;
    rdfs:comment 'SAP MM material document number generated upon posting of the inventory goods movement triggered by transfer order confirmation. Links the physical warehouse movement to the financial inventory posting in SAP FI/CO.' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossWeightKg rdf:type rdf:Property ;
    rdfs:label 'Gross Weight Kg' ;
    rdfs:comment 'Total gross weight in kilograms of the material quantity being transferred, including packaging (drums, IBCs, pallets). Used for load planning, equipment capacity validation, and DOT hazmat transport documentation.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Planned Start Timestamp' ;
    rdfs:comment 'Scheduled date and time when the physical movement is planned to begin. Used for warehouse resource scheduling, shift planning, and SLA monitoring against production order requirements.' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sourceBin rdf:type rdf:Property ;
    rdfs:label 'Source Bin' ;
    rdfs:comment 'Alphanumeric identifier of the specific storage bin, rack location, or tank from which the material is being moved. Represents the physical origin within the warehouse complex.' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceStorageSection rdf:type rdf:Property ;
    rdfs:label 'Source Storage Section' ;
    rdfs:comment 'SAP EWM storage section within the source storage type, providing a logical grouping of bins (e.g., flammable liquids section, ambient section, cold storage section).' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceStorageType rdf:type rdf:Property ;
    rdfs:label 'Source Storage Type' ;
    rdfs:comment 'SAP EWM storage type code for the origin location (e.g., bulk storage, high-rack, tank farm, hazardous material cage, quarantine area). Determines handling rules and equipment requirements.' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageCondition rdf:type rdf:Property ;
    rdfs:label 'Storage Condition' ;
    rdfs:comment 'Required storage condition code for the material (e.g., ambient, refrigerated, frozen, temperature-controlled, humidity-controlled, inert atmosphere). Validates that the destination bin meets material storage requirements. [ENUM-REF-CANDIDATE: ambient|refrigerated|frozen|temperature_controlled|humidity_controlled|inert_atmosphere|flammable_cabinet — promote to reference product]' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toNumber rdf:type rdf:Property ;
    rdfs:label 'To Number' ;
    rdfs:comment 'Externally visible alphanumeric transfer order number assigned by SAP EWM. This is the business-facing identifier used in warehouse operations, printed on pick/put-away documents, and referenced in MES and WMS communications.' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferOrderStatus rdf:type rdf:Property ;
    rdfs:label 'Transfer Order Status' ;
    rdfs:comment 'Current lifecycle state of the transfer order within SAP EWM. \'created\' = issued but not yet started; \'in_progress\' = operator has begun movement; \'partially_confirmed\' = partial quantity confirmed; \'confirmed\' = fully executed and goods movement posted; \'cancelled\' = voided before execution.' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:areaSqm rdf:type rdf:Property ;
    rdfs:label 'Area Sqm' ;
    rdfs:comment 'Physical floor area of this storage location in square meters. Used for capacity planning, fire load calculations, and regulatory reporting of storage area dimensions per EPA and OSHA requirements.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:electricalAreaClassification rdf:type rdf:Property ;
    rdfs:label 'Electrical Area Classification' ;
    rdfs:comment 'NEC/NFPA 70 electrical area classification for this storage location, indicating the presence and likelihood of flammable vapors or combustible dust. Determines requirements for explosion-proof electrical equipment. [ENUM-REF-CANDIDATE: unclassified|class_i_div1|class_i_div2|class_ii_div1|class_ii_div2|zone_0|zone_1|zone_2 — promote to reference product]' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fireZoneCode rdf:type rdf:Property ;
    rdfs:label 'Fire Zone Code' ;
    rdfs:comment 'Identifier for the fire protection zone in which this storage location resides. Fire zones define the boundaries of fire suppression systems (sprinkler zones, deluge systems), fire detection circuits, and emergency evacuation areas. Referenced in PSM and HAZOP documentation.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:floorLoadCapacityKgM2 rdf:type rdf:Property ;
    rdfs:label 'Floor Load Capacity Kg M2' ;
    rdfs:comment 'Maximum allowable floor load in kilograms per square meter for this storage location. Ensures structural integrity of the warehouse floor when storing heavy drums, IBCs, or bulk containers. Referenced in facility engineering and OSHA compliance inspections.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ghsHazardClassCompatibility rdf:type rdf:Property ;
    rdfs:label 'Ghs Hazard Class Compatibility' ;
    rdfs:comment 'Pipe-delimited list of GHS hazard classes that are approved for storage at this location (e.g., \'Flammable Liquid|Oxidizer|Corrosive\'). Governs which chemical materials may be placed here based on GHS classification. Used to enforce chemical segregation rules and prevent incompatible co-storage.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:heightM rdf:type rdf:Property ;
    rdfs:label 'Height M' ;
    rdfs:comment 'Clear storage height in meters for this location. Used to determine maximum pallet stack height, forklift clearance requirements, and sprinkler system design (in-rack vs. ceiling sprinklers per NFPA 13).' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incompatibleHazardClasses rdf:type rdf:Property ;
    rdfs:label 'Incompatible Hazard Classes' ;
    rdfs:comment 'Pipe-delimited list of GHS hazard classes that must NOT be co-stored at this location due to chemical incompatibility or regulatory segregation requirements (e.g., \'Oxidizer|Explosive\'). Enforces NFPA and OSHA chemical segregation rules to prevent dangerous reactions.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isQuarantineZone rdf:type rdf:Property ;
    rdfs:label 'Is Quarantine Zone' ;
    rdfs:comment 'Indicates whether this storage location is designated as a quarantine zone for materials under quality hold, regulatory hold, or investigation. True = quarantine zone; False = standard storage. Materials in quarantine zones are blocked from use in production or shipment per GMP and ISO 9001 requirements.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTemperatureControlled rdf:type rdf:Property ;
    rdfs:label 'Is Temperature Controlled' ;
    rdfs:comment 'Indicates whether this storage location has active temperature control (refrigeration, heating, or climate control). True = temperature controlled; False = ambient storage. Drives material assignment rules for temperature-sensitive chemicals and cold chain compliance.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:locationCode rdf:type rdf:Property ;
    rdfs:label 'Location Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the storage location within the warehouse network. Corresponds to SAP EWM storage bin or storage section code used in warehouse operations, goods movements, and transfer orders.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationName rdf:type rdf:Property ;
    rdfs:label 'Location Name' ;
    rdfs:comment 'Human-readable descriptive name for the storage location (e.g., \'Tank Farm A - Bay 3\', \'Hazmat Drum Storage Zone 2\', \'Cold Storage Room 1\'). Used in operational reports, safety documentation, and warehouse management interfaces.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationStatus rdf:type rdf:Property ;
    rdfs:label 'Location Status' ;
    rdfs:comment 'Current operational lifecycle status of the storage location. \'quarantine\' indicates the location is reserved for materials under quality hold. \'blocked\' indicates the location is temporarily unavailable for putaway or picking. \'under_maintenance\' indicates the location is undergoing inspection or repair.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationType rdf:type rdf:Property ;
    rdfs:label 'Location Type' ;
    rdfs:comment 'Classification of the physical storage location type within the warehouse network. Determines applicable storage rules, capacity constraints, and regulatory requirements. [ENUM-REF-CANDIDATE: bulk_tank|drum_storage|cold_storage|hazmat_zone|quarantine_bay|finished_goods|intermediate_storage|open_yard — promote to reference product]' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxHumidityPct rdf:type rdf:Property ;
    rdfs:label 'Max Humidity Pct' ;
    rdfs:comment 'Maximum allowable relative humidity percentage for this storage location. Prevents moisture-induced degradation, corrosion, or microbial growth in stored materials. Expressed as a percentage (0–100).' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxQuantityKg rdf:type rdf:Property ;
    rdfs:label 'Max Quantity Kg' ;
    rdfs:comment 'Maximum quantity in kilograms of hazardous material permitted in this storage zone per EPA, OSHA PSM, and NFPA regulations. Used to enforce Tier II reporting thresholds, RMP covered quantity limits, and NFPA maximum allowable quantities (MAQ) per control area.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxVolumeLiters rdf:type rdf:Property ;
    rdfs:label 'Max Volume Liters' ;
    rdfs:comment 'Maximum volumetric capacity in liters for this storage location. Particularly relevant for bulk tank farms and liquid chemical storage areas. Used to enforce maximum quantity limits per EPA and OSHA regulations.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minHumidityPct rdf:type rdf:Property ;
    rdfs:label 'Min Humidity Pct' ;
    rdfs:comment 'Minimum allowable relative humidity percentage for this storage location. Relevant for hygroscopic chemicals, moisture-sensitive materials, and packaging integrity. Expressed as a percentage (0–100).' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nfpaFireDiamondFlammability rdf:type rdf:Property ;
    rdfs:label 'Nfpa Fire Diamond Flammability' ;
    rdfs:comment 'NFPA 704 flammability hazard rating (red diamond) for the storage location. Scale: 0 (will not burn) to 4 (extremely flammable). Drives fire suppression system design, electrical classification, and hot work permit requirements.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nfpaFireDiamondHealth rdf:type rdf:Property ;
    rdfs:label 'Nfpa Fire Diamond Health' ;
    rdfs:comment 'NFPA 704 health hazard rating (blue diamond) for the storage location, indicating the degree of health hazard posed by materials stored here. Scale: 0 (no hazard) to 4 (deadly). Posted on location signage for emergency responder awareness.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nfpaFireDiamondReactivity rdf:type rdf:Property ;
    rdfs:label 'Nfpa Fire Diamond Reactivity' ;
    rdfs:comment 'NFPA 704 instability/reactivity hazard rating (yellow diamond) for the storage location. Scale: 0 (stable) to 4 (may detonate). Informs emergency response procedures and incompatible material segregation requirements.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nfpaFireDiamondSpecial rdf:type rdf:Property ;
    rdfs:label 'Nfpa Fire Diamond Special' ;
    rdfs:comment 'NFPA 704 special hazard symbol (white diamond) for the storage location. Common values: \'W\' (water reactive), \'OX\' (oxidizer), \'SA\' (simple asphyxiant). Empty if no special hazard applies. Used in emergency response planning and SDS alignment.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rack rdf:type rdf:Property ;
    rdfs:label 'Rack' ;
    rdfs:comment 'Alphanumeric identifier for the rack or bay within the aisle where this storage location is physically situated. Used in conjunction with aisle and level to precisely identify the bin coordinate.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageConditionCode rdf:type rdf:Property ;
    rdfs:label 'Storage Condition Code' ;
    rdfs:comment 'SAP MM/EWM storage condition code assigned to this location, used to match materials requiring specific storage conditions (e.g., flammable, corrosive, refrigerated, dry). Enforces material-location compatibility during putaway strategy execution.' ;
