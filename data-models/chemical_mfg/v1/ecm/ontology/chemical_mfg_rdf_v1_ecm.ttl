ind:materialCompositionStatus rdf:type rdf:Property ;
    rdfs:label 'Material Composition Status' ;
    rdfs:comment 'Current lifecycle state of the composition record.' ;
    rdfs:domain ind:MaterialComposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reachexemptFlag rdf:type rdf:Property ;
    rdfs:label 'Reachexempt Flag' ;
    rdfs:comment 'True if the component is exempt from REACH registration.' ;
