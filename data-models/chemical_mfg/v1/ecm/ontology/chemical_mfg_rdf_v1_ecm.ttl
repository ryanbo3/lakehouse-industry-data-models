    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankAccountId rdf:type rdf:Property ;
    rdfs:label 'Bank Account Id' ;
    rdfs:comment 'Foreign key linking to finance.bank_account. Business justification: Electronic Funds Transfer (EFT) payments require linking a customer account to its bank account record for payment processing.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BankAccount .

ind:parentAccountId rdf:type rdf:Property ;
    rdfs:label 'Parent Account Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the parent account record for corporate hierarchy management. Enables roll-up of subsidiary accounts to ultimate parent for consolidated reporting, credit exposure, and enterprise-level relationship management.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:preferredCarrierId rdf:type rdf:Property ;
    rdfs:label 'Preferred Carrier Id' ;
    rdfs:comment 'Foreign key linking to logistics.carrier. Business justification: Preferred carrier selection for each account is used in carrier performance and rate negotiation reports; linking enables direct lookup of the carrier entity.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:preferredVendorId rdf:type rdf:Property ;
    rdfs:label 'Preferred Vendor Id' ;
    rdfs:comment 'Foreign key linking to supply.vendor. Business justification: Preferred Vendor Management per account; procurement strategy reports require linking each account to its designated vendor.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:profitCenterId rdf:type rdf:Property ;
    rdfs:label 'Profit Center Id' ;
    rdfs:comment 'Foreign key linking to finance.profit_center. Business justification: Profitability dashboards map revenue per customer to profit centers, so each account needs a profit_center_id FK.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProfitCenter .

ind:revenueGlAccountId rdf:type rdf:Property ;
    rdfs:label 'Revenue Gl Account Id' ;
    rdfs:comment 'Foreign key linking to finance.gl_account. Business justification: Revenue Recognition process uses a default GL account per customer; linking account to gl_account enables automated posting.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:segmentId rdf:type rdf:Property ;
    rdfs:label 'Segment Id' ;
    rdfs:comment 'Foreign key linking to customer.customer_segment. Business justification: Linking account to its segment normalizes segment data and eliminates the redundant segment code stored on account.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:territoryId rdf:type rdf:Property ;
    rdfs:label 'Territory Id' ;
    rdfs:comment 'Foreign key linking to sales.territory. Business justification: Territory-assignment report requires each Account to be linked to its Sales Territory for quota and coverage planning.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Territory .

ind:accountStatus rdf:type rdf:Property ;
    rdfs:label 'Account Status' ;
    rdfs:comment 'Current lifecycle status of the customer account. Active: transacting customer. Inactive: no recent transactions. Prospect: under evaluation. Suspended: temporarily halted due to credit or compliance issues. Blocked: SAP-level block applied (e.g., credit block, delivery block). Closed: account permanently deactivated.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountTier rdf:type rdf:Property ;
    rdfs:label 'Account Tier' ;
    rdfs:comment 'Commercial segmentation tier assigned to the account based on revenue contribution, strategic importance, and growth potential. Strategic: top-tier key accounts with dedicated resources. Preferred: high-value accounts with preferred pricing. Standard: regular commercial accounts. Transactional: low-frequency or spot-buy customers.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountType rdf:type rdf:Property ;
    rdfs:label 'Account Type' ;
    rdfs:comment 'Classifies the primary business relationship type of the customer account. Direct Industrial: buys chemicals for own manufacturing use. Distributor: resells to downstream customers. Toll Processor: processes materials on behalf of Chemical Mfg or third parties. OEM: original equipment manufacturer integrating chemical products. End User: final consumer of the product. [ENUM-REF-CANDIDATE: direct_industrial|distributor|toll_processor|oem|end_user — promote to reference product]' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualRevenueBand rdf:type rdf:Property ;
    rdfs:label 'Annual Revenue Band' ;
    rdfs:comment 'Banded range of the customer organization\'s annual revenue used for segmentation and strategic account planning (e.g., \'<$10M\', \'$10M-$100M\', \'$100M-$1B\', \'>$1B\'). Sourced from Dun & Bradstreet or CRM qualification. [ENUM-REF-CANDIDATE: <$10M|$10M-$100M|$100M-$1B|>$1B — promote to reference product]' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Billing Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 three-letter country code for the customer\'s billing address. Used for international tax compliance, REACH/ECHA regulatory applicability, export control (TSCA), and currency determination.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingStateProvince rdf:type rdf:Property ;
    rdfs:label 'Billing State Province' ;
    rdfs:comment 'State or province of the customer\'s billing address. Used for sales tax determination, regulatory jurisdiction mapping (EPA, OSHA state programs), and regional sales analytics.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blocked rdf:type rdf:Property ;
    rdfs:label 'Blocked' ;
    rdfs:comment 'Indicates whether the customer account has an active block in SAP S/4HANA preventing order processing, delivery, or invoicing. Blocks may be applied for credit risk, compliance violations, or sanctions screening failures.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditLimit rdf:type rdf:Property ;
    rdfs:label 'Credit Limit' ;
    rdfs:comment 'Maximum approved credit exposure in the account\'s billing currency authorized for this customer account. Managed in SAP S/4HANA FI/CO credit management. Drives order release decisions and credit block triggers.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditLimitCurrency rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the credit limit is denominated (e.g., USD, EUR, GBP). Required for multi-currency credit exposure management.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditRating rdf:type rdf:Property ;
    rdfs:label 'Credit Rating' ;
    rdfs:comment 'Internal or external credit risk rating assigned to the customer account (e.g., A, B, C, D or numeric score). Derived from Dun & Bradstreet data or internal credit assessment. Drives credit limit setting and payment term eligibility.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunsNumber rdf:type rdf:Property ;
    rdfs:label 'Duns Number' ;
    rdfs:comment 'The nine-digit Data Universal Numbering System (DUNS) number assigned by Dun & Bradstreet to uniquely identify the customer business entity globally. Used for credit risk assessment, corporate hierarchy linkage, and supplier/customer due diligence.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeCountBand rdf:type rdf:Property ;
    rdfs:label 'Employee Count Band' ;
    rdfs:comment 'Banded range of the customer organization\'s total employee headcount used for account sizing and segmentation (e.g., \'1-50\', \'51-500\', \'501-5000\', \'>5000\'). Sourced from Dun & Bradstreet or CRM qualification. [ENUM-REF-CANDIDATE: 1-50|51-500|501-5000|>5000 — promote to reference product]' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incotermsCode rdf:type rdf:Property ;
    rdfs:label 'Incoterms Code' ;
    rdfs:comment 'The default International Commercial Terms (Incoterms 2020) code governing delivery responsibility and risk transfer for shipments to this customer. Used in SAP S/4HANA SD order processing and Oracle Transportation Management for freight planning. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastOrderDate rdf:type rdf:Property ;
    rdfs:label 'Last Order Date' ;
    rdfs:comment 'The date of the most recent confirmed sales order placed by this customer account. Used for customer activity monitoring, churn risk identification, and account health scoring.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalName rdf:type rdf:Property ;
    rdfs:label 'Legal Name' ;
    rdfs:comment 'The full registered legal name of the customer organization as it appears on official business registration documents, contracts, and invoices. Used for regulatory reporting, SOX compliance, and legal correspondence.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:naicsCode rdf:type rdf:Property ;
    rdfs:label 'Naics Code' ;
    rdfs:comment 'The six-digit North American Industry Classification System (NAICS) code identifying the customer\'s industry sector. Used for market analysis, customer segmentation, and regulatory compliance reporting.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onboardingDate rdf:type rdf:Property ;
    rdfs:label 'Onboarding Date' ;
    rdfs:comment 'The date on which the customer account was formally onboarded and activated in the enterprise systems (SAP S/4HANA and Salesforce CRM). Used for customer tenure analysis, cohort reporting, and relationship lifecycle management.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reachComplianceRequired rdf:type rdf:Property ;
    rdfs:label 'Reach Compliance Required' ;
    rdfs:comment 'Indicates whether this customer requires REACH (Registration, Evaluation, Authorisation and Restriction of Chemicals) compliance documentation for supplied substances. Applicable for EU-based customers or those exporting to EU markets. Drives regulatory document management.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresCoaOnDelivery rdf:type rdf:Property ;
    rdfs:label 'Requires Coa On Delivery' ;
    rdfs:comment 'Indicates whether the customer requires a Certificate of Analysis (COA) to accompany each product lot shipment. COA documents quality test results against specification. Driven by customer quality agreements and GMP requirements.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresSdsOnDelivery rdf:type rdf:Property ;
    rdfs:label 'Requires Sds On Delivery' ;
    rdfs:comment 'Indicates whether the customer requires a Safety Data Sheet (SDS) to accompany every chemical shipment delivery. Mandatory for GHS-compliant chemical distribution. Drives document generation in SAP S/4HANA SD and EHS workflows.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:salesforceAccountCode rdf:type rdf:Property ;
    rdfs:label 'Salesforce Account Code' ;
    rdfs:comment 'The native record identifier assigned by Salesforce CRM for this account. Used to reconcile and synchronize customer master data between the lakehouse and the CRM system of record.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapCustomerNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Customer Number' ;
    rdfs:comment 'The customer master number assigned in SAP S/4HANA SD (Sales and Distribution) module. Used for order-to-cash processing, credit management, and financial postings in the ERP system.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Shipping Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 three-letter country code for the customer\'s primary shipping destination. Used for export compliance, DOT hazardous materials transport classification, REACH applicability, and logistics routing.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingMode rdf:type rdf:Property ;
    rdfs:label 'Shipping Mode' ;
    rdfs:comment 'The customer\'s preferred mode of transportation for product delivery. LTL (Less Than Truckload) and FTL (Full Truckload) are common for bulk chemical shipments. Drives logistics planning and DOT hazmat transport compliance. [ENUM-REF-CANDIDATE: ltl|ftl|parcel|rail|ocean|air|intermodal — promote to reference product]' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sicCode rdf:type rdf:Property ;
    rdfs:label 'Sic Code' ;
    rdfs:comment 'The four-digit Standard Industrial Classification (SIC) code that categorizes the customer\'s primary business activity. Used for market segmentation, regulatory reporting, and industry analytics.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Number' ;
    rdfs:comment 'The government-issued tax identification number (EIN, VAT number, or equivalent) for the customer entity. Required for tax reporting, invoice compliance, and regulatory filings under FASB and SOX.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeName rdf:type rdf:Property ;
    rdfs:label 'Trade Name' ;
    rdfs:comment 'The operating or \'doing business as\' (DBA) trade name of the customer, which may differ from the legal entity name. Used in commercial communications and sales reporting.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tscaComplianceRequired rdf:type rdf:Property ;
    rdfs:label 'Tsca Compliance Required' ;
    rdfs:comment 'Indicates whether this customer requires TSCA (Toxic Substances Control Act) compliance certification for chemical products supplied. Applicable for US-based industrial customers subject to EPA chemical substance regulations.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:accountDocumentId rdf:type rdf:Property ;
    rdfs:label 'Account Document Id' ;
    rdfs:comment 'Unique surrogate identifier for each customer account document record in the silver layer lakehouse. Primary key for this entity.' ;
    rdfs:domain ind:AccountDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supersededByDocumentAccountDocumentId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Document Account Document Id' ;
    rdfs:comment 'Reference to the newer account_document record that replaces this document when it has been superseded by a revised version. Enables document version chain traceability for audit and compliance purposes. Null if this is the current active version.' ;
    rdfs:domain ind:AccountDocument ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccountDocument .

ind:acknowledgedBy rdf:type rdf:Property ;
    rdfs:label 'Acknowledged By' ;
    rdfs:comment 'Name or identifier of the customer representative who acknowledged the document. Captured for audit trail and product liability defense purposes. Particularly important for SDS acknowledgments under OSHA HazCom.' ;
    rdfs:domain ind:AccountDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acknowledgmentDate rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Date' ;
    rdfs:comment 'Date on which the customer formally acknowledged receipt or acceptance of the document. Required for SDS acknowledgment audit trails under OSHA HazCom compliance. Null if acknowledgment has not yet been received.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:acknowledgmentMethod rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Method' ;
    rdfs:comment 'Method by which the customer acknowledged receipt of the document, particularly for SDS/MSDS acknowledgments. Electronic acknowledgment via digital signature, signed physical copy, customer portal confirmation, email confirmation, or fax. Null or not_applicable for documents that do not require acknowledgment.' ;
    rdfs:domain ind:AccountDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coaRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Coa Required Flag' ;
    rdfs:comment 'Indicates whether this document specifies or mandates that a Certificate of Analysis (COA) must accompany product shipments to this customer. Drives order fulfillment and quality documentation workflows.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cocRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Coc Required Flag' ;
    rdfs:comment 'Indicates whether this document specifies or mandates that a Certificate of Compliance (COC) must accompany product shipments to this customer. Supports quality assurance and regulatory compliance for customer deliveries.' ;
    rdfs:domain ind:AccountDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerLabelingRequirement rdf:type rdf:Property ;
    rdfs:label 'Customer Labeling Requirement' ;
    rdfs:comment 'Description of customer-specific labeling requirements captured in this document, such as proprietary label formats, language requirements, GHS pictogram specifications, or private-label branding instructions. Relevant for product packaging and distribution compliance.' ;
    rdfs:domain ind:AccountDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentCategory rdf:type rdf:Property ;
    rdfs:label 'Document Category' ;
    rdfs:comment 'High-level grouping of the document for reporting and analytics. Enables segmentation across regulatory compliance, commercial agreements, quality certifications, safety documentation, trade compliance, and customer-specific requirements.' ;
    rdfs:domain ind:AccountDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentNumber rdf:type rdf:Property ;
    rdfs:label 'Document Number' ;
    rdfs:comment 'Externally-known unique identifier or reference number assigned to the document, such as a certificate number, agreement reference, or license number issued by the issuing authority or internal document management system.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentStatus rdf:type rdf:Property ;
    rdfs:label 'Document Status' ;
    rdfs:comment 'Current lifecycle state of the document. Active documents are valid and in force. Expired documents have passed their expiry date. Pending renewal documents are approaching expiry and renewal is in progress. Superseded documents have been replaced by a newer version. Revoked documents have been invalidated by the issuing authority.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentTitle rdf:type rdf:Property ;
    rdfs:label 'Document Title' ;
    rdfs:comment 'Descriptive title of the document as it appears on the official record, such as \'ISO 9001 Quality Management Certificate\', \'SDS Acknowledgment Agreement\', or \'Customer EHS Audit Report\'.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentType rdf:type rdf:Property ;
    rdfs:label 'Document Type' ;
    rdfs:comment 'Classification of the document by its business purpose. Drives workflow routing, retention rules, and compliance reporting. [ENUM-REF-CANDIDATE: signed_agreement|qualification_certificate|iso_certification|ehs_audit_report|import_export_license|sds_acknowledgment|labeling_requirement|coa_requirement|reach_declaration|other — promote to reference product]' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileFormat rdf:type rdf:Property ;
    rdfs:label 'File Format' ;
    rdfs:comment 'Format of the stored document file. PDF is the standard for regulatory submissions and signed agreements. Used to determine rendering and archival requirements. [ENUM-REF-CANDIDATE: PDF|DOCX|XLSX|JPG|PNG|XML|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileReference rdf:type rdf:Property ;
    rdfs:label 'File Reference' ;
    rdfs:comment 'Storage path, URL, or document management system reference pointing to the actual document file (e.g., SharePoint path, S3 URI, Salesforce ContentDocument ID). Enables retrieval of the source document for audit and inspection purposes.' ;
    rdfs:domain ind:AccountDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ghsRevision rdf:type rdf:Property ;
    rdfs:label 'Ghs Revision' ;
    rdfs:comment 'The revision number of the Globally Harmonized System of Classification and Labelling of Chemicals (GHS) standard under which the associated SDS was prepared (e.g., \'Rev 7\', \'Rev 8\', \'Rev 9\'). Required to confirm SDS currency and compliance with current GHS requirements.' ;
    rdfs:domain ind:AccountDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:importExportLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Import Export License Number' ;
    rdfs:comment 'Official license number assigned by the relevant trade authority for import or export of controlled chemicals. Populated when document_type is import_export_license. Required for trade compliance and customs clearance documentation.' ;
    rdfs:domain ind:AccountDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalNotes rdf:type rdf:Property ;
    rdfs:label 'Internal Notes' ;
    rdfs:comment 'Free-text field for internal comments, context, or instructions related to this document record. Not shared externally. Used by account managers, compliance teams, and customer service representatives to capture relevant context.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isoStandardCode rdf:type rdf:Property ;
    rdfs:label 'Iso Standard Code' ;
    rdfs:comment 'The specific ISO standard number referenced by this document (e.g., \'ISO 9001:2015\', \'ISO 14001:2015\', \'ISO 45001:2018\'). Populated for ISO certification documents. Null for non-ISO documents.' ;
    rdfs:domain ind:AccountDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingAuthority rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority' ;
    rdfs:comment 'Name of the organization, regulatory body, or certification body that issued or authenticated the document (e.g., \'Bureau Veritas\', \'TÜV Rheinland\', \'EPA\', \'ECHA\', \'U.S. Customs and Border Protection\'). Critical for validating document authenticity.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Issuing Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 three-letter country code of the country in which the document was issued. Used for trade compliance, import/export license validation, and regulatory jurisdiction determination.' ;
    rdfs:domain ind:AccountDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseType rdf:type rdf:Property ;
    rdfs:label 'License Type' ;
    rdfs:comment 'Specifies whether the import/export license covers import activities, export activities, or both. Populated when document_type is import_export_license. Null or not_applicable for non-license documents.' ;
    rdfs:domain ind:AccountDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Modified Timestamp' ;
    rdfs:comment 'Date and time at which this document record was last updated in the system. Supports change tracking, audit trail completeness, and incremental data pipeline processing.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reachRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Reach Registration Number' ;
    rdfs:comment 'ECHA-assigned REACH registration number associated with this document when the document relates to REACH compliance declarations or substance registration. Format follows ECHA numbering convention (e.g., \'01-XXXXXXXXXX-XX-XXXX\').' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Regulatory Jurisdiction' ;
    rdfs:comment 'The regulatory jurisdiction or geographic scope under which the document is valid (e.g., \'USA\', \'EU\', \'APAC\', \'Global\'). Determines which regulatory framework governs the document\'s requirements and enforcement.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalReminderDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Reminder Date' ;
    rdfs:comment 'Date on which an automated or manual renewal reminder should be triggered, typically set a defined number of days before the expiry date. Supports proactive compliance management and prevents lapses in required documentation.' ;
    rdfs:domain ind:AccountDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Renewal Required Flag' ;
    rdfs:comment 'Indicates whether this document requires periodic renewal before the expiry date. True for time-limited certifications, licenses, and agreements. Drives automated renewal reminder workflows and compliance monitoring.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewDate rdf:type rdf:Property ;
    rdfs:label 'Review Date' ;
    rdfs:comment 'Date on which the document was last reviewed internally for validity, completeness, and continued compliance. Supports periodic document review cycles required under ISO 9001 and regulatory frameworks.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewedBy rdf:type rdf:Property ;
    rdfs:label 'Reviewed By' ;
    rdfs:comment 'Name or employee identifier of the internal staff member who reviewed and validated this document for completeness and compliance. Part of the document control audit trail.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdsAcknowledgmentFlag rdf:type rdf:Property ;
    rdfs:label 'Sds Acknowledgment Flag' ;
    rdfs:comment 'Indicates whether this document record represents a Safety Data Sheet (SDS) or Material Safety Data Sheet (MSDS) acknowledgment from the customer. True when the document type is an SDS/MSDS receipt acknowledgment required under OSHA HazCom.' ;
    rdfs:domain ind:AccountDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceSystemKey rdf:type rdf:Property ;
    rdfs:label 'Source System Key' ;
    rdfs:comment 'The primary key or unique identifier of this document record in the originating source system (e.g., Salesforce ContentDocument ID, SAP document number). Enables cross-system reconciliation and data lineage tracing.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tscaComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Tsca Compliance Flag' ;
    rdfs:comment 'Indicates whether this document serves as evidence of TSCA compliance for the customer account. True when the document is a TSCA certification, import certification, or compliance declaration under the Toxic Substances Control Act.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:version rdf:type rdf:Property ;
    rdfs:label 'Version' ;
    rdfs:comment 'Version or revision identifier of the document as assigned by the issuing authority or internal document control system (e.g., \'1.0\', \'Rev B\', \'2024-v3\'). Critical for document control and audit trail purposes.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountHierarchyId rdf:type rdf:Property ;
    rdfs:label 'Account Hierarchy Id' ;
    rdfs:comment 'Unique surrogate identifier for each account hierarchy relationship record in the customer domain. Primary key for the account_hierarchy data product.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:childAccountId rdf:type rdf:Property ;
    rdfs:label 'Child Account Id' ;
    rdfs:comment 'Identifier of the child account in the hierarchy relationship. References the subordinate node (e.g., subsidiary, division, or plant-level account) beneath the parent account.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:accountSegment rdf:type rdf:Property ;
    rdfs:label 'Account Segment' ;
    rdfs:comment 'Commercial segmentation tier of the child account within the enterprise account management framework. \'strategic\' = top-tier global accounts; \'key\' = significant regional accounts; \'growth\' = high-potential developing accounts; \'standard\' = transactional accounts; \'distributor\' = channel distribution partners. Used for resource allocation and service level differentiation.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationFlag rdf:type rdf:Property ;
    rdfs:label 'Consolidation Flag' ;
    rdfs:comment 'Indicates whether this hierarchy relationship is used for financial consolidation purposes (e.g., rolling up revenue, credit exposure, or receivables to the parent account). True = included in financial consolidation rollup; False = excluded (e.g., commercial grouping only).' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:countryCode rdf:type rdf:Property ;
    rdfs:label 'Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the country of domicile or registration of the child account in this hierarchy relationship. Used for REACH compliance jurisdiction determination, export control, and geographic revenue reporting.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditRollupFlag rdf:type rdf:Property ;
    rdfs:label 'Credit Rollup Flag' ;
    rdfs:comment 'Indicates whether the child account\'s credit exposure is aggregated to the parent account for enterprise-level credit limit management. True = child credit exposure rolls up to parent; False = child is assessed independently. Critical for managing credit risk across multinational chemical buyers and conglomerates.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerGroupCode rdf:type rdf:Property ;
    rdfs:label 'Customer Group Code' ;
    rdfs:comment 'SAP customer group classification code assigned to the child account, used for pricing, reporting, and statistical analysis. Examples include industrial buyer, distributor, OEM, or end-user segments in the chemical manufacturing context.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:domesticUltimateDuns rdf:type rdf:Property ;
    rdfs:label 'Domestic Ultimate Duns' ;
    rdfs:comment 'Dun & Bradstreet D-U-N-S number of the domestic ultimate parent entity (highest-level entity within the same country). Used for country-level credit aggregation and domestic account consolidation.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:globalUltimateDuns rdf:type rdf:Property ;
    rdfs:label 'Global Ultimate Duns' ;
    rdfs:comment 'Dun & Bradstreet D-U-N-S number of the global ultimate parent entity in the corporate ownership chain. Used to link the hierarchy record to the top-level worldwide parent for enterprise credit exposure and global account management.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyCode rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this hierarchy relationship, as assigned in SAP S/4HANA SD customer hierarchy configuration or Salesforce CRM. Used for cross-system reconciliation and reporting.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyDepth rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Depth' ;
    rdfs:comment 'Numeric depth of the child account node within the full hierarchy tree, where 1 represents a direct child of the root (global ultimate). Enables efficient tree traversal queries and level-based revenue rollup in enterprise account analytics.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Level' ;
    rdfs:comment 'Designates the structural tier of the child account within the corporate hierarchy. \'global_ultimate\' is the top-level worldwide parent; \'domestic_ultimate\' is the highest-level entity within a country; \'subsidiary\' is a legally distinct owned entity; \'division\' is an internal business unit; \'plant\' or \'site\' is a specific manufacturing or distribution location. Aligns with Dun & Bradstreet corporate linkage levels used in B2B credit and sales analytics. [ENUM-REF-CANDIDATE: global_ultimate|domestic_ultimate|subsidiary|division|plant|site — promote to reference product]' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyPath rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Path' ;
    rdfs:comment 'Materialized path string representing the full ancestry chain from the root account to the child account (e.g., \'/10001/10045/10089\'). Enables fast subtree queries and hierarchy visualization without recursive joins. Populated by the ETL/data pipeline from SAP or Salesforce hierarchy data.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyStatus rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Status' ;
    rdfs:comment 'Current lifecycle state of the hierarchy relationship record. \'active\' indicates the relationship is currently in effect; \'inactive\' indicates it has been suspended; \'pending\' indicates it is awaiting approval or activation; \'terminated\' indicates the relationship has been formally ended.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyType rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Type' ;
    rdfs:comment 'Classifies the nature of the parent-child relationship. \'ownership\' reflects legal corporate ownership structure; \'commercial\' reflects sales and account management grouping; \'billing\' reflects consolidated invoicing structure; \'reporting\' reflects management reporting rollup; \'logistics\' reflects shipping and delivery consolidation. [ENUM-REF-CANDIDATE: ownership|commercial|billing|reporting|logistics — promote to reference product if additional types emerge]' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyVersion rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Version' ;
    rdfs:comment 'Incrementing version number for this hierarchy relationship record, supporting optimistic concurrency control and change history tracking. Incremented each time the hierarchy relationship is modified (e.g., reclassification, ownership change).' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:industrySectorCode rdf:type rdf:Property ;
    rdfs:label 'Industry Sector Code' ;
    rdfs:comment 'Industry classification code for the child account\'s primary business sector (e.g., automotive, construction, electronics, consumer goods, agriculture). Aligns with SAP industry sector configuration and NAICS/SIC codes. Used for market segment analytics and product portfolio alignment.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalEntityFlag rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Flag' ;
    rdfs:comment 'Indicates whether the child account in this hierarchy relationship represents a distinct legal entity (e.g., incorporated subsidiary) as opposed to an internal division or operational site. Relevant for REACH registration, TSCA compliance, and financial consolidation under FASB ASC 810.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pricingRollupFlag rdf:type rdf:Property ;
    rdfs:label 'Pricing Rollup Flag' ;
    rdfs:comment 'Indicates whether volume-based pricing and rebate agreements negotiated at the parent account level apply to this child account. True = child account inherits parent pricing terms; False = child account has independent pricing. Relevant for chemical distributor networks and multinational industrial buyers.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryRelationshipOwner rdf:type rdf:Property ;
    rdfs:label 'Primary Relationship Owner' ;
    rdfs:comment 'Name or identifier of the global account manager or key account owner responsible for managing the overall parent-child relationship. Sourced from Salesforce CRM account ownership. Used for global account management and escalation routing.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipRole rdf:type rdf:Property ;
    rdfs:label 'Relationship Role' ;
    rdfs:comment 'Describes the role of the child account in the context of this specific hierarchy relationship. \'parent\' indicates the account acts as a superior node; \'child\' indicates a subordinate node; \'sibling\' indicates a peer relationship under the same parent; \'co_parent\' indicates shared ownership or joint venture structures.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRollupFlag rdf:type rdf:Property ;
    rdfs:label 'Revenue Rollup Flag' ;
    rdfs:comment 'Indicates whether the child account\'s revenue is included in the parent account\'s enterprise revenue rollup for global account management, rebate calculation, and volume pricing agreements. True = revenue rolls up; False = revenue is tracked independently.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:salesOrgCode rdf:type rdf:Property ;
    rdfs:label 'Sales Org Code' ;
    rdfs:comment 'SAP Sales Organization code associated with the child account in this hierarchy relationship. Determines pricing procedures, order management rules, and revenue attribution within the SAP S/4HANA SD module.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactId rdf:type rdf:Property ;
    rdfs:label 'Contact Id' ;
    rdfs:comment 'Reference to the specific customer contact person who submitted or is the primary point of contact for this case.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:batchReference rdf:type rdf:Property ;
    rdfs:label 'Batch Reference' ;
    rdfs:comment 'The internal manufacturing batch reference number associated with the product involved in the case. Distinct from lot_number (which is the customer-facing identifier); batch_reference links to the production batch record in SAP PP and MES systems.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaReference rdf:type rdf:Property ;
    rdfs:label 'Capa Reference' ;
    rdfs:comment 'Reference number of the CAPA (Corrective and Preventive Action) record created in SAP QM in response to a quality complaint case. Links the customer case to the formal quality improvement workflow. Populated only when a CAPA has been initiated.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseDescription rdf:type rdf:Property ;
    rdfs:label 'Case Description' ;
    rdfs:comment 'Full narrative description of the customer issue, request, or complaint as reported by the customer. For quality complaints, includes the customer\'s account of the product defect, observed symptoms, and business impact.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseNumber rdf:type rdf:Property ;
    rdfs:label 'Case Number' ;
    rdfs:comment 'Externally visible, human-readable case reference number used in all customer communications and cross-system references. Sourced from Salesforce CRM Case Number field.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseStatus rdf:type rdf:Property ;
    rdfs:label 'Case Status' ;
    rdfs:comment 'Current workflow state of the case lifecycle. Open: newly created, awaiting assignment. In Progress: actively being worked. Pending Customer: awaiting customer response or information. Resolved: solution provided, awaiting confirmation. Closed: fully completed and confirmed.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseType rdf:type rdf:Property ;
    rdfs:label 'Case Type' ;
    rdfs:comment 'Classification of the customer case by business function. Technical Support covers formulation and application assistance; Order Issue covers shipment discrepancies and billing disputes; SDS (Safety Data Sheet) Request and COA (Certificate of Analysis) Request cover documentation fulfillment; Regulatory Inquiry covers REACH, TSCA, GHS compliance questions; Quality Complaint covers OOS (Out of Specification) product issues.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channel rdf:type rdf:Property ;
    rdfs:label 'Channel' ;
    rdfs:comment 'The communication channel through which the customer submitted or initiated the case. Supports channel analytics and resource allocation for customer service operations.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedDate rdf:type rdf:Property ;
    rdfs:label 'Closed Date' ;
    rdfs:comment 'The date on which the case was fully closed after customer confirmation of resolution. Distinct from resolved_date; a case may be resolved but remain open pending customer acknowledgment.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coaReference rdf:type rdf:Property ;
    rdfs:label 'Coa Reference' ;
    rdfs:comment 'Reference number of the Certificate of Analysis (COA) document associated with the product lot involved in the case. Used for quality complaints to cross-reference the analytical results at time of shipment against the customer\'s reported issue.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditNoteIssued rdf:type rdf:Property ;
    rdfs:label 'Credit Note Issued' ;
    rdfs:comment 'Indicates whether a financial credit note has been issued to the customer as part of the resolution of a quality complaint or order discrepancy case. When True, a corresponding credit memo exists in SAP FI/CO.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditNoteNumber rdf:type rdf:Property ;
    rdfs:label 'Credit Note Number' ;
    rdfs:comment 'The SAP document number of the credit note issued to the customer for a quality complaint or order discrepancy resolution. Populated only when credit_note_issued is True. Enables financial reconciliation between the case and the accounting entry.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmCaseCode rdf:type rdf:Property ;
    rdfs:label 'Crm Case Code' ;
    rdfs:comment 'The native case identifier from Salesforce CRM, the system of record for customer cases. Enables bidirectional traceability between the lakehouse silver layer and the operational CRM system.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSatisfactionOutcome rdf:type rdf:Property ;
    rdfs:label 'Customer Satisfaction Outcome' ;
    rdfs:comment 'Categorical outcome of the customer satisfaction assessment following case closure. Derived from the customer\'s qualitative feedback or survey response. Complements the numeric customer_satisfaction_rating for segmentation and reporting.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSatisfactionRating rdf:type rdf:Property ;
    rdfs:label 'Customer Satisfaction Rating' ;
    rdfs:comment 'Numeric customer satisfaction score collected after case resolution, typically on a 1-5 scale (1=Very Dissatisfied, 5=Very Satisfied). Sourced from post-resolution customer survey. Used as a KPI (Key Performance Indicator) for customer service quality.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eightDReportNumber rdf:type rdf:Property ;
    rdfs:label 'Eight D Report Number' ;
    rdfs:comment 'Reference number of the 8D (Eight Disciplines) problem-solving report generated for a quality complaint case. The 8D methodology is the standard structured problem-solving workflow for quality complaints in chemical manufacturing. Populated when an 8D report has been formally initiated.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalated rdf:type rdf:Property ;
    rdfs:label 'Escalated' ;
    rdfs:comment 'Indicates whether the case has been formally escalated beyond the initially assigned service representative, either due to SLA breach, severity, or customer request. Escalated cases trigger management notification workflows.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalationReason rdf:type rdf:Property ;
    rdfs:label 'Escalation Reason' ;
    rdfs:comment 'The reason the case was escalated. SLA Breach: resolution deadline exceeded. Customer Request: customer demanded escalation. Safety Concern: potential EHS (Environment Health and Safety) implication. Regulatory Risk: potential regulatory non-compliance. Management Directive: escalated by management decision.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limsInvestigationReference rdf:type rdf:Property ;
    rdfs:label 'Lims Investigation Reference' ;
    rdfs:comment 'The investigation record identifier in LabWare LIMS linked to this case for OOS (Out of Specification) product investigations. Populated when an OOS investigation has been initiated in the LIMS system in response to a quality complaint.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotNumber rdf:type rdf:Property ;
    rdfs:label 'Lot Number' ;
    rdfs:comment 'The manufacturing lot or batch lot number of the chemical product involved in a quality complaint or technical inquiry. Enables traceability back to the production batch for root cause investigation. Populated primarily for quality_complaint and technical_support case types.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oosFlag rdf:type rdf:Property ;
    rdfs:label 'Oos Flag' ;
    rdfs:comment 'Indicates whether the quality complaint involves a product that has been confirmed as Out of Specification (OOS) against the product\'s Certificate of Analysis (COA) or specification sheet. When True, triggers mandatory OOS investigation workflow in LabWare LIMS.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:openedDate rdf:type rdf:Property ;
    rdfs:label 'Opened Date' ;
    rdfs:comment 'The calendar date on which the customer case was officially opened and entered into the system. Used for SLA (Service Level Agreement) calculation and aging analysis.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rciStatus rdf:type rdf:Property ;
    rdfs:label 'Rci Status' ;
    rdfs:comment 'Current status of the Root Cause Investigation (RCI) triggered by a quality complaint. Tracks whether the investigation into the product defect or OOS (Out of Specification) condition has been initiated, is ongoing, or has been completed. Applicable only to quality_complaint case type.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryFramework rdf:type rdf:Property ;
    rdfs:label 'Regulatory Framework' ;
    rdfs:comment 'The specific regulatory framework or standard that is the subject of a regulatory inquiry case. Identifies whether the customer\'s inquiry relates to REACH (Registration, Evaluation, Authorisation and Restriction of Chemicals), TSCA (Toxic Substances Control Act), GHS (Globally Harmonized System), or other applicable regulation. Populated for regulatory_inquiry case type.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionDescription rdf:type rdf:Property ;
    rdfs:label 'Resolution Description' ;
    rdfs:comment 'Detailed narrative of the actions taken and solution provided to resolve the customer case. For quality complaints, includes findings from the RCI (Root Cause Investigation) and corrective actions applied.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolvedDate rdf:type rdf:Property ;
    rdfs:label 'Resolved Date' ;
    rdfs:comment 'The date on which the case was marked as resolved, meaning the solution or response was provided to the customer. Used to calculate actual resolution time against SLA targets.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sdsDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Sds Document Number' ;
    rdfs:comment 'The document control number of the Safety Data Sheet (SDS) provided or referenced in response to an SDS request case. Enables traceability of which SDS version was fulfilled. Applicable to sds_request case type.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severity rdf:type rdf:Property ;
    rdfs:label 'Severity' ;
    rdfs:comment 'Severity classification of the issue impact on the customer\'s operations or safety. Distinct from priority (which drives internal response urgency), severity reflects the actual business or safety impact of the reported issue. Critical severity triggers mandatory CAPA (Corrective and Preventive Action) and RCI (Root Cause Investigation) workflows.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaBreached rdf:type rdf:Property ;
    rdfs:label 'Sla Breached' ;
    rdfs:comment 'Indicates whether the case resolution exceeded the SLA due date, constituting an SLA breach. Used for service quality reporting, customer penalty tracking, and continuous improvement initiatives.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaDueDate rdf:type rdf:Property ;
    rdfs:label 'Sla Due Date' ;
    rdfs:comment 'The contractual or policy-defined deadline by which the case must be resolved, based on case type, priority, and applicable customer SLA agreement. Drives escalation workflows when breached.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:subject rdf:type rdf:Property ;
    rdfs:label 'Subject' ;
    rdfs:comment 'Brief, descriptive title summarizing the customer issue or request. Used as the primary display label in case management queues and customer communications.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountSiteId rdf:type rdf:Property ;
    rdfs:label 'Account Site Id' ;
    rdfs:comment 'Reference to the specific customer site or plant location this contact is associated with. A customer account may have multiple plant sites; this links the contact to their operational location for logistics and technical service routing.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Site .

ind:sponsorRdProjectId rdf:type rdf:Property ;
    rdfs:label 'Sponsor Rd Project Id' ;
    rdfs:comment 'Foreign key linking to research.project. Business justification: Needed for Sponsor Contact Management process to associate external customer contacts with the R&D projects they fund, supporting contract compliance and communication.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Project .

ind:coaDeliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Coa Delivery Method' ;
    rdfs:comment 'Preferred delivery method for Certificate of Analysis (COA) and Certificate of Compliance (COC) documents for this contact. Drives automated document distribution workflows in the quality management process.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactRole rdf:type rdf:Property ;
    rdfs:label 'Contact Role' ;
    rdfs:comment 'Functional role classification of the contact in relation to Chemical Mfg business interactions. Drives workflow routing for technical sales, EHS (Environment Health and Safety) compliance, logistics coordination, and quality inquiries. [ENUM-REF-CANDIDATE: technical|commercial|ehs|logistics|quality|procurement|finance|executive — promote to reference product if additional roles are needed]' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactStatus rdf:type rdf:Property ;
    rdfs:label 'Contact Status' ;
    rdfs:comment 'Current lifecycle status of the contact record. \'active\' indicates the contact is reachable and engaged; \'inactive\' indicates the contact is no longer in the role; \'do_not_contact\' enforces communication suppression; \'pending_verification\' indicates the record awaits validation.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactType rdf:type rdf:Property ;
    rdfs:label 'Contact Type' ;
    rdfs:comment 'Classification of the contact by their relationship to Chemical Mfg. \'internal\' denotes Chemical Mfg employees; \'external\' denotes customer personnel; \'distributor\' denotes channel partner contacts; \'end_user\' denotes final consumer contacts; \'consultant\' denotes third-party advisors.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmContactCode rdf:type rdf:Property ;
    rdfs:label 'Crm Contact Code' ;
    rdfs:comment 'Unique identifier for this contact record in Salesforce CRM, the system of record for customer contact management. Used for bi-directional synchronization between the lakehouse and Salesforce.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:department rdf:type rdf:Property ;
    rdfs:label 'Department' ;
    rdfs:comment 'Organizational department or functional area the contact belongs to within the customer organization (e.g., Procurement, Engineering, Quality Assurance, Environment Health and Safety, Logistics, R&D). Supports targeted communication routing.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doNotContactFlag rdf:type rdf:Property ;
    rdfs:label 'Do Not Contact Flag' ;
    rdfs:comment 'Indicates whether this contact has opted out of or been suppressed from all outbound communications. When True, no marketing, sales, or non-essential operational communications should be sent. Enforces GDPR and CCPA consent management requirements.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:doNotContactReason rdf:type rdf:Property ;
    rdfs:label 'Do Not Contact Reason' ;
    rdfs:comment 'Reason code explaining why the do_not_contact_flag is set to True. Supports regulatory audit trails for GDPR right-to-erasure and CCPA opt-out compliance. Null when do_not_contact_flag is False.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ehsContactFlag rdf:type rdf:Property ;
    rdfs:label 'Ehs Contact Flag' ;
    rdfs:comment 'Indicates whether this contact is the designated EHS (Environment Health and Safety) coordinator or responsible person at the customer site. EHS contacts receive hazardous material notifications, incident reports, and regulatory compliance updates.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:email rdf:type rdf:Property ;
    rdfs:label 'Email' ;
    rdfs:comment 'Primary business email address of the contact. Used for order confirmations, technical documentation delivery, Safety Data Sheet (SDS) distribution, Certificate of Analysis (COA) transmission, and regulatory correspondence.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emailSecondary rdf:type rdf:Property ;
    rdfs:label 'Email Secondary' ;
    rdfs:comment 'Alternate or secondary email address for the contact. Used as a fallback communication channel when the primary email is undeliverable, or for routing specific document types (e.g., invoices to a separate accounts payable email).' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstName rdf:type rdf:Property ;
    rdfs:label 'First Name' ;
    rdfs:comment 'Given name of the contact person. Used in personalized communications, technical sales outreach, and customer service workflows.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDecisionMaker rdf:type rdf:Property ;
    rdfs:label 'Is Decision Maker' ;
    rdfs:comment 'Indicates whether this contact holds purchasing or approval authority within their organization. Used by technical sales teams to prioritize engagement and qualify opportunities in the chemical sales cycle.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimaryContact rdf:type rdf:Property ;
    rdfs:label 'Is Primary Contact' ;
    rdfs:comment 'Indicates whether this contact is the designated primary contact for the associated customer account. Only one contact per customer account should be flagged as primary. Used to determine the default recipient for account-level communications.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobTitle rdf:type rdf:Property ;
    rdfs:label 'Job Title' ;
    rdfs:comment 'Official job title or position of the contact within their organization (e.g., Procurement Manager, Plant Engineer, Quality Manager, EHS Coordinator, Technical Buyer). Used for routing communications and identifying decision-makers.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languagePreference rdf:type rdf:Property ;
    rdfs:label 'Language Preference' ;
    rdfs:comment 'Preferred language for communications with this contact, expressed as an IETF BCP 47 language tag (e.g., \'en\', \'de\', \'fr\', \'zh-CN\'). Ensures SDS, COA, and regulatory documents are delivered in the correct language per REACH and GHS requirements.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastInteractionDate rdf:type rdf:Property ;
    rdfs:label 'Last Interaction Date' ;
    rdfs:comment 'Date of the most recent recorded business interaction with this contact (e.g., sales call, technical inquiry, order placement, site visit). Used to measure contact engagement recency and identify dormant contacts for re-engagement campaigns.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastName rdf:type rdf:Property ;
    rdfs:label 'Last Name' ;
    rdfs:comment 'Family name or surname of the contact person. Combined with first_name to form the full display name for business correspondence and CRM records.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkedinProfileUrl rdf:type rdf:Property ;
    rdfs:label 'Linkedin Profile Url' ;
    rdfs:comment 'LinkedIn public profile URL for the contact. Used by technical sales and account management teams for relationship intelligence, pre-call research, and identifying decision-maker networks within B2B industrial customer organizations.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:middleName rdf:type rdf:Property ;
    rdfs:label 'Middle Name' ;
    rdfs:comment 'Middle name or initial of the contact person. Used for disambiguation when multiple contacts share the same first and last name within a customer organization.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phoneDirect rdf:type rdf:Property ;
    rdfs:label 'Phone Direct' ;
    rdfs:comment 'Direct office or desk phone number for the contact in E.164 international format. Used for urgent technical support, order management, and regulatory compliance communications.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phoneFax rdf:type rdf:Property ;
    rdfs:label 'Phone Fax' ;
    rdfs:comment 'Fax number for the contact in E.164 international format. Relevant for regulatory document transmission (e.g., SDS, COA, purchase orders) in industries and regions where fax remains a compliance-accepted channel.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phoneMobile rdf:type rdf:Property ;
    rdfs:label 'Phone Mobile' ;
    rdfs:comment 'Mobile or cell phone number for the contact in E.164 international format. Used for SMS notifications, emergency EHS (Environment Health and Safety) alerts, and field-level technical support.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredCommunicationChannel rdf:type rdf:Property ;
    rdfs:label 'Preferred Communication Channel' ;
    rdfs:comment 'The contact\'s preferred channel for receiving business communications from Chemical Mfg. Drives outbound communication routing in Salesforce CRM and customer service workflows.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseOrderAuthorityLimit rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Authority Limit' ;
    rdfs:comment 'Maximum monetary value in the customer\'s base currency that this contact is authorized to approve on a Purchase Order (PO). Used by the technical sales team to identify the appropriate contact for order approvals and to escalate large orders to higher-authority contacts.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryNotificationFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Flag' ;
    rdfs:comment 'Indicates whether this contact should receive regulatory compliance notifications, including TSCA updates, REACH substance restriction alerts, EPA reporting deadlines, and product reformulation notices. Supports proactive regulatory communication workflows.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:relationshipEndDate rdf:type rdf:Property ;
    rdfs:label 'Relationship End Date' ;
    rdfs:comment 'Date on which this contact\'s association with the customer account was terminated (e.g., due to role change, departure, or account closure). Null for currently active contacts. Used for historical record retention and compliance audit trails.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:relationshipStartDate rdf:type rdf:Property ;
    rdfs:label 'Relationship Start Date' ;
    rdfs:comment 'Date on which this contact was first established as an active contact for the customer account. Used to calculate relationship tenure and for historical analysis of contact network evolution.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:salutation rdf:type rdf:Property ;
    rdfs:label 'Salutation' ;
    rdfs:comment 'Formal salutation or honorific prefix for the contact (e.g., Mr., Ms., Dr., Prof.). Used in formal business correspondence, regulatory submissions, and technical documentation.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdsDistributionConsent rdf:type rdf:Property ;
    rdfs:label 'Sds Distribution Consent' ;
    rdfs:comment 'Indicates whether this contact has consented to receive Safety Data Sheet (SDS) and Material Safety Data Sheet (MSDS) documents electronically. Required for OSHA HazCom 2012 and GHS compliance in chemical product distribution.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:technicalServiceFlag rdf:type rdf:Property ;
    rdfs:label 'Technical Service Flag' ;
    rdfs:comment 'Indicates whether this contact is designated to receive technical service support, including application engineering assistance, formulation guidance, process troubleshooting, and Certificate of Analysis (COA) requests.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditProfileId rdf:type rdf:Property ;
    rdfs:label 'Credit Profile Id' ;
    rdfs:comment 'Unique surrogate identifier for the customer credit profile record in the Databricks Silver Layer. Primary key for this entity.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryCreditAnalystEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Credit Analyst Employee Id' ;
    rdfs:comment 'FK to workforce.employee' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:creditBlockFlag rdf:type rdf:Property ;
    rdfs:label 'Credit Block Flag' ;
    rdfs:comment 'Indicates whether the customer is currently subject to a credit block in SAP SD (KNKK-CTLPC / KNVV-AUFSD). When True, new sales orders for this customer are blocked from delivery and billing until the block is resolved by the credit department. Critical control for order-to-cash risk management.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditBlockReason rdf:type rdf:Property ;
    rdfs:label 'Credit Block Reason' ;
    rdfs:comment 'Reason code explaining why the customer credit block is active. \'overlimit\' indicates exposure exceeds approved limit; \'payment_overdue\' indicates past-due invoices; \'credit_review\' indicates periodic review in progress; \'legal_dispute\' indicates an active dispute; \'sanctions_hold\' indicates a regulatory/compliance hold; \'manual_hold\' indicates a discretionary hold by the credit analyst.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditControlArea rdf:type rdf:Property ;
    rdfs:label 'Credit Control Area' ;
    rdfs:comment 'SAP credit control area code (KKBER) that governs the credit limit and exposure tracking for this customer. Defines the organizational unit responsible for credit management, typically aligned to a company code or regional finance entity.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditExposureAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Exposure Amount' ;
    rdfs:comment 'Current total credit exposure for the customer, representing the sum of open receivables, open sales orders, and open deliveries not yet invoiced. Sourced from SAP S/4HANA credit exposure calculation (KNKK-SKFOR). Used to assess proximity to credit limit and trigger credit blocks.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Credit Hold Flag' ;
    rdfs:comment 'Indicates whether the customer account is on a general credit hold, which may be broader than a specific SAP credit block. A credit hold may prevent new orders, shipments, or both, and is managed by the credit department independently of the automated SAP block logic.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditInsuranceCoverageAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Insurance Coverage Amount' ;
    rdfs:comment 'Maximum insured amount under the trade credit insurance policy for this customer. Represents the portion of the credit exposure that is covered by the insurer in the event of customer default. Used to calculate the net uninsured credit exposure.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditInsurancePolicyRef rdf:type rdf:Property ;
    rdfs:label 'Credit Insurance Policy Ref' ;
    rdfs:comment 'Reference number or identifier for the trade credit insurance policy covering this customer\'s receivables. Credit insurance is commonly used in chemical distribution to mitigate counterparty default risk on large B2B accounts. Enables linkage to the insurer\'s policy documentation for claims processing.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Amount' ;
    rdfs:comment 'Maximum approved credit exposure (in base currency) extended to the customer by the credit department. Stored in SAP S/4HANA as KNKK-KLIMK. Drives order block logic in SAP SD when exposure approaches or exceeds this threshold. Critical for order-to-cash risk management in chemical distribution.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditLimitApprovalLevel rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Approval Level' ;
    rdfs:comment 'Authorization level required to approve or modify the credit limit for this customer, based on the credit limit amount and risk category. Enforces the company\'s credit approval authority matrix and SOX segregation of duties controls.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimitEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Effective Date' ;
    rdfs:comment 'Date from which the current approved credit limit became effective. Supports audit trail requirements and enables historical analysis of credit limit changes over time. Aligns with the MASTER_AGREEMENT EFFECTIVE_FROM category.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditLimitExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Expiry Date' ;
    rdfs:comment 'Date on which the current approved credit limit expires and requires renewal or re-approval. Nullable for open-ended credit arrangements. When populated, triggers automated alerts to the credit analyst for timely renewal. Aligns with the MASTER_AGREEMENT EFFECTIVE_UNTIL category.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditNotesText rdf:type rdf:Property ;
    rdfs:label 'Credit Notes Text' ;
    rdfs:comment 'Free-text field for credit analyst notes, observations, and commentary related to the customer\'s credit profile. May include context on credit decisions, customer communications, or risk factors not captured in structured fields. Restricted to credit department personnel.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditProfileStatus rdf:type rdf:Property ;
    rdfs:label 'Credit Profile Status' ;
    rdfs:comment 'Current lifecycle status of the customer credit profile. \'active\' indicates the profile is in use for order-to-cash processing; \'suspended\' indicates temporary hold; \'under_review\' indicates a scheduled or triggered credit review is in progress; \'pending_approval\' indicates a new or revised limit awaiting authorization.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditReviewDate rdf:type rdf:Property ;
    rdfs:label 'Credit Review Date' ;
    rdfs:comment 'Date on which the most recent formal credit review was conducted for this customer. Used to track compliance with the credit department\'s periodic review schedule and to assess the currency of the credit assessment.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditRiskCategory rdf:type rdf:Property ;
    rdfs:label 'Credit Risk Category' ;
    rdfs:comment 'Categorical risk classification assigned to the customer by the credit department, summarizing the overall credit risk level. Drives credit limit approval thresholds, review frequency, and escalation procedures. \'critical\' indicates customers requiring executive-level approval for any credit extension.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditSegment rdf:type rdf:Property ;
    rdfs:label 'Credit Segment' ;
    rdfs:comment 'Customer segmentation classification from a credit management perspective. \'strategic\' and \'key_account\' customers may receive preferential credit terms; \'distributor\' reflects the B2B distribution channel common in chemical manufacturing; \'new_customer\' triggers enhanced due diligence and conservative initial limits.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditUtilizationPct rdf:type rdf:Property ;
    rdfs:label 'Credit Utilization Pct' ;
    rdfs:comment 'Percentage of the approved credit limit currently utilized, calculated as (credit_exposure_amount / credit_limit_amount) × 100. Provides a normalized risk indicator for credit analysts and automated alerting when utilization exceeds defined thresholds (e.g., 80%, 90%, 100%).' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dsoActualDays rdf:type rdf:Property ;
    rdfs:label 'Dso Actual Days' ;
    rdfs:comment 'Actual current days sales outstanding (DSO) for this customer, representing the average number of days receivables remain outstanding. Compared against dso_target_days to identify payment performance trends and trigger credit review actions.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dsoTargetDays rdf:type rdf:Property ;
    rdfs:label 'Dso Target Days' ;
    rdfs:comment 'Target number of days sales outstanding (DSO) established for this customer by the credit department. Represents the expected average collection period for receivables from this customer. Used as a benchmark for monitoring actual collection performance and identifying deteriorating payment behavior.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dunBradstreetNumber rdf:type rdf:Property ;
    rdfs:label 'Dun Bradstreet Number' ;
    rdfs:comment 'The nine-digit Data Universal Numbering System (DUNS) number assigned by Dun & Bradstreet to uniquely identify the customer\'s business entity. Used to retrieve and link external credit reports and financial risk data for the customer.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunBradstreetRating rdf:type rdf:Property ;
    rdfs:label 'Dun Bradstreet Rating' ;
    rdfs:comment 'External credit rating assigned by Dun & Bradstreet (D&B) for the customer organization. Includes the D&B PAYDEX score or composite credit appraisal code. Used to supplement internal credit assessment with third-party financial risk data for B2B industrial customers and distributors in chemical distribution.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalCreditRating rdf:type rdf:Property ;
    rdfs:label 'Internal Credit Rating' ;
    rdfs:comment 'Internally assigned credit rating for the customer, determined by the credit department based on payment history, financial statements, and risk assessment. Typically expressed as a letter or alphanumeric grade (e.g., A1, B2, C3) aligned to the company\'s internal credit scoring methodology. [ENUM-REF-CANDIDATE: A1|A2|B1|B2|C1|C2|D — promote to reference product]' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Last Approval Date' ;
    rdfs:comment 'Date on which the credit limit or credit terms were last formally approved by an authorized approver. Supports SOX audit trail requirements and enables tracking of the age of the most recent credit authorization.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Last Approved By' ;
    rdfs:comment 'Name or user ID of the individual who last approved the credit limit or credit terms for this customer. Provides an audit trail for credit authorization decisions in compliance with SOX internal control requirements.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Review Date' ;
    rdfs:comment 'Scheduled date for the next formal credit review of this customer. Determined by the credit review cycle (e.g., annual, semi-annual, triggered by risk events). Used by credit analysts to manage their review workload and ensure timely reassessment of credit limits.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:oldestOverdueDays rdf:type rdf:Property ;
    rdfs:label 'Oldest Overdue Days' ;
    rdfs:comment 'Number of days since the oldest overdue invoice for this customer became past due. Used to assess the severity of payment delinquency and to trigger escalation actions such as collections referral or credit block.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overdueAmount rdf:type rdf:Property ;
    rdfs:label 'Overdue Amount' ;
    rdfs:comment 'Total value of invoices that are past their due date for this customer, expressed in the credit limit currency. A key indicator of payment risk and a primary trigger for credit block activation and credit review escalation.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentBehaviorScore rdf:type rdf:Property ;
    rdfs:label 'Payment Behavior Score' ;
    rdfs:comment 'Internally calculated payment behavior score for the customer, derived from historical payment patterns including on-time payment rate, frequency of late payments, and average days late. Expressed as a numeric score (e.g., 1–100). Used as an input to the internal credit rating and credit limit decisions.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:profileCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Profile Created Timestamp' ;
    rdfs:comment 'Timestamp when the credit profile record was first created in the system. Provides the audit trail creation marker for this entity, supporting SOX compliance and data lineage requirements in the Databricks Silver Layer.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:profileUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Profile Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent modification to the credit profile record. Used for change tracking, data freshness assessment, and incremental load processing in the Databricks Silver Layer pipeline.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sanctionsCheckDate rdf:type rdf:Property ;
    rdfs:label 'Sanctions Check Date' ;
    rdfs:comment 'Date on which the most recent sanctions and restricted party screening was performed for this customer. Used to ensure screening is current and to schedule re-screening at required intervals per compliance policy.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sanctionsCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Sanctions Check Status' ;
    rdfs:comment 'Status of the most recent sanctions and restricted party screening check performed for this customer. Chemical manufacturers must screen customers against OFAC, EU, and UN sanctions lists. \'flagged\' triggers immediate credit hold and compliance review.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapCreditAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Credit Account Number' ;
    rdfs:comment 'The externally-known SAP credit management account number (KNKK-KNKLI) assigned to the customer in SAP S/4HANA SD. Used as the business identifier for cross-system reconciliation with the ERP credit management module.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialCreditTerms rdf:type rdf:Property ;
    rdfs:label 'Special Credit Terms' ;
    rdfs:comment 'Free-text description of any special or negotiated credit terms applicable to this customer that deviate from standard payment terms. Examples include extended payment schedules, seasonal credit adjustments, or terms negotiated as part of a strategic account agreement in chemical distribution.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerLeadId rdf:type rdf:Property ;
    rdfs:label 'Customer Lead Id' ;
    rdfs:comment 'Unique surrogate identifier for the customer lead record in the silver layer lakehouse. Primary key for the customer_lead data product. Sourced from Salesforce CRM Lead object.' ;
    rdfs:domain ind:CustomerLead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:campaignId rdf:type rdf:Property ;
    rdfs:label 'Campaign Id' ;
    rdfs:comment 'Identifier of the marketing campaign that generated or influenced this lead. Used for campaign ROI measurement, marketing attribution, and budget allocation decisions. References the Salesforce Campaign object.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Campaign .

ind:convertedAccountId rdf:type rdf:Property ;
    rdfs:label 'Converted Account Id' ;
    rdfs:comment 'Salesforce Account ID of the customer account created upon lead conversion. Populated only when lead_status = \'converted\'. Enables traceability from lead origin to active customer account for pipeline attribution and cohort analysis.' ;
    rdfs:domain ind:CustomerLead ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:convertedOpportunityId rdf:type rdf:Property ;
    rdfs:label 'Converted Opportunity Id' ;
    rdfs:comment 'Salesforce Opportunity ID created upon lead conversion. Populated only when lead_status = \'converted\'. Links the lead origin to the downstream commercial deal for end-to-end pipeline attribution.' ;
    rdfs:domain ind:CustomerLead ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Opportunity .

ind:primaryCustomerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Customer Employee Id' ;
    rdfs:comment 'Salesforce User ID of the sales representative currently responsible for working this lead. Used for workload balancing, performance reporting, and commission attribution.' ;
    rdfs:domain ind:CustomerLead ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:city rdf:type rdf:Property ;
    rdfs:label 'City' ;
    rdfs:comment 'City of the prospective customer\'s primary operating location. Used for geographic clustering analysis and logistics proximity assessment for potential supply chain planning.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyName rdf:type rdf:Property ;
    rdfs:label 'Company Name' ;
    rdfs:comment 'Legal or trading name of the prospective customer organization. Represents the business entity being targeted for chemical product sales. Used for account matching and deduplication prior to conversion.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companySizeCategory rdf:type rdf:Property ;
    rdfs:label 'Company Size Category' ;
    rdfs:comment 'Categorical classification of the prospective customer\'s organization size. \'small\' = <50 employees, \'medium\' = 50–499, \'large\' = 500–4999, \'enterprise\' = 5000+. Used for segmentation, pricing strategy, and sales motion selection (transactional vs. strategic).' ;
    rdfs:domain ind:CustomerLead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactFirstName rdf:type rdf:Property ;
    rdfs:label 'Contact First Name' ;
    rdfs:comment 'First name of the primary contact person at the prospective customer organization. Captured from trade show registrations, web inquiries, referrals, or cold outreach.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactLastName rdf:type rdf:Property ;
    rdfs:label 'Contact Last Name' ;
    rdfs:comment 'Last name of the primary contact person at the prospective customer organization. Combined with contact_first_name to form the full contact identity.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactTitle rdf:type rdf:Property ;
    rdfs:label 'Contact Title' ;
    rdfs:comment 'Professional job title or role of the primary contact at the prospective customer (e.g., Procurement Manager, R&D Director, Plant Engineer). Informs sales approach and technical engagement strategy.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionDate rdf:type rdf:Property ;
    rdfs:label 'Conversion Date' ;
    rdfs:comment 'Date on which the lead was converted into a formal customer account and/or sales opportunity in the CRM. Marks the end of the lead lifecycle and the beginning of the account/opportunity lifecycle. Used to calculate lead-to-conversion cycle time KPI.' ;
    rdfs:domain ind:CustomerLead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:crmLeadCode rdf:type rdf:Property ;
    rdfs:label 'Crm Lead Code' ;
    rdfs:comment 'Native Salesforce CRM Lead record identifier (18-character Salesforce ID). Used for traceability and reconciliation back to the system of record.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disqualificationReason rdf:type rdf:Property ;
    rdfs:label 'Disqualification Reason' ;
    rdfs:comment 'Reason code or description explaining why the lead was disqualified from the pipeline (e.g., \'no budget\', \'competitor locked in\', \'wrong product fit\', \'regulatory barrier\', \'no decision maker access\'). Populated only when lead_status = \'disqualified\'. Used for pipeline quality analysis and process improvement.' ;
    rdfs:domain ind:CustomerLead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedAnnualRevenueUsd rdf:type rdf:Property ;
    rdfs:label 'Estimated Annual Revenue Usd' ;
    rdfs:comment 'Estimated annual revenue potential from this lead expressed in US dollars. Derived from volume estimates and indicative pricing. Used for pipeline valuation, sales target tracking, and territory planning. Distinct from volume as it reflects commercial value.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedAnnualVolumeKg rdf:type rdf:Property ;
    rdfs:label 'Estimated Annual Volume Kg' ;
    rdfs:comment 'Prospective annual purchase volume of chemical products expressed in kilograms. Used to prioritize lead qualification effort, assess strategic value, and forecast pipeline contribution. Captured during initial qualification conversation or estimated from industry benchmarks.' ;
    rdfs:domain ind:CustomerLead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exportControlFlag rdf:type rdf:Property ;
    rdfs:label 'Export Control Flag' ;
    rdfs:comment 'Indicates whether the prospective customer or the chemical products of interest are subject to export control regulations (e.g., EAR, ITAR, or dual-use chemical restrictions). When True, requires screening against denied party lists before conversion and shipment.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:industryVertical rdf:type rdf:Property ;
    rdfs:label 'Industry Vertical' ;
    rdfs:comment 'The end-market industry sector of the prospective customer (e.g., Automotive, Construction, Electronics, Consumer Goods, Agriculture, Pharmaceuticals, Coatings). Used for market segmentation, product-to-market alignment, and territory planning. Aligns with NAICS/SIC classification.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadSource rdf:type rdf:Property ;
    rdfs:label 'Lead Source' ;
    rdfs:comment 'The originating channel or method through which the lead was acquired. Used for marketing attribution, ROI analysis, and sales pipeline source reporting. [ENUM-REF-CANDIDATE: trade_show|referral|web_inquiry|cold_outreach|distributor|conference|digital_campaign|inbound_call — promote to reference product]' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadStatus rdf:type rdf:Property ;
    rdfs:label 'Lead Status' ;
    rdfs:comment 'Current stage of the lead in the sales qualification lifecycle. \'new\' = recently captured, \'working\' = active outreach in progress, \'qualified\' = meets criteria for conversion, \'converted\' = promoted to formal account/opportunity, \'disqualified\' = does not meet criteria, \'recycled\' = re-entered pipeline after prior disqualification. Drives CRM workflow automation.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextFollowUpDate rdf:type rdf:Property ;
    rdfs:label 'Next Follow Up Date' ;
    rdfs:comment 'Scheduled date for the next sales outreach or follow-up action with this lead. Used by sales representatives to manage their activity pipeline and ensure timely engagement. Drives CRM task and reminder generation.' ;
    rdfs:domain ind:CustomerLead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:phone rdf:type rdf:Property ;
    rdfs:label 'Phone' ;
    rdfs:comment 'Primary business phone number of the lead contact. Used for direct sales outreach and qualification calls.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productInterest rdf:type rdf:Property ;
    rdfs:label 'Product Interest' ;
    rdfs:comment 'The chemical product line, product family, or specific chemical compound the lead has expressed interest in (e.g., specialty polymers, performance coatings, agricultural intermediates, solvents). Drives assignment to the appropriate technical sales specialist.' ;
    rdfs:domain ind:CustomerLead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationDate rdf:type rdf:Property ;
    rdfs:label 'Qualification Date' ;
    rdfs:comment 'Date on which the lead was formally assessed and determined to meet the minimum criteria for advancement in the sales pipeline (e.g., confirmed budget, authority, need, and timeline — BANT qualification). Marks transition from \'new\' or \'working\' to \'qualified\' status.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rating rdf:type rdf:Property ;
    rdfs:label 'Rating' ;
    rdfs:comment 'Sales representative\'s qualitative assessment of the lead\'s near-term conversion likelihood. \'hot\' = high urgency and fit, \'warm\' = moderate interest, \'cold\' = low engagement or long-horizon. Used to prioritize outreach cadence.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralSourceName rdf:type rdf:Property ;
    rdfs:label 'Referral Source Name' ;
    rdfs:comment 'Name of the individual, company, or partner who referred this lead. Populated when lead_source = \'referral\'. Used for referral program tracking and partner relationship management.' ;
    rdfs:domain ind:CustomerLead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryConcernFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Concern Flag' ;
    rdfs:comment 'Indicates whether the lead involves products or applications subject to heightened regulatory scrutiny (e.g., REACH-restricted substances, TSCA new chemical notifications, EPA hazardous waste regulations, export-controlled chemicals). When True, triggers compliance review before conversion.' ;
    rdfs:domain ind:CustomerLead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:salesTerritoryCode rdf:type rdf:Property ;
    rdfs:label 'Sales Territory Code' ;
    rdfs:comment 'Code identifying the geographic or market-based sales territory to which this lead is assigned. Used for territory performance reporting, quota allocation, and rep assignment routing.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleRequestedFlag rdf:type rdf:Property ;
    rdfs:label 'Sample Requested Flag' ;
    rdfs:comment 'Indicates whether the lead contact has requested a product sample for laboratory evaluation or formulation testing. Sample requests indicate active technical qualification and are a key pipeline progression signal in chemical B2B sales.' ;
    rdfs:domain ind:CustomerLead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:score rdf:type rdf:Property ;
    rdfs:label 'Score' ;
    rdfs:comment 'Numeric score assigned by the CRM marketing automation engine reflecting the lead\'s engagement level and fit with ideal customer profile. Typically ranges 0–100. Inputs include email opens, web visits, content downloads, and firmographic match. Used to trigger automated nurture workflows.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sdsRequestedFlag rdf:type rdf:Property ;
    rdfs:label 'Sds Requested Flag' ;
    rdfs:comment 'Indicates whether the lead contact has requested a Safety Data Sheet (SDS) for a chemical product of interest. SDS requests are a strong buying signal in chemical sales and indicate technical evaluation stage. Aligns with GHS SDS documentation requirements.' ;
    rdfs:domain ind:CustomerLead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stateProvince rdf:type rdf:Property ;
    rdfs:label 'State Province' ;
    rdfs:comment 'State or province of the prospective customer\'s primary operating location. Used for regional sales analysis, territory assignment, and regulatory jurisdiction mapping (e.g., state-level EPA or OSHA requirements).' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalInquiryFlag rdf:type rdf:Property ;
    rdfs:label 'Technical Inquiry Flag' ;
    rdfs:comment 'Indicates whether the lead has submitted a technical inquiry requiring specialist response (e.g., formulation compatibility, regulatory compliance documentation, application engineering support). Triggers routing to technical sales or application development team.' ;
    rdfs:domain ind:CustomerLead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tradeShowName rdf:type rdf:Property ;
    rdfs:label 'Trade Show Name' ;
    rdfs:comment 'Name of the trade show, industry conference, or event at which the lead was captured (e.g., \'ChemShow 2024\', \'ACHEMA\', \'ACS National Meeting\'). Populated when lead_source = \'trade_show\' or \'conference\'. Used for event ROI analysis.' ;
    rdfs:domain ind:CustomerLead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedDate rdf:type rdf:Property ;
    rdfs:label 'Approved Date' ;
    rdfs:comment 'Date on which the customer segment definition was formally approved by the designated authority. Used for governance tracking and audit compliance under SOX and ISO 9001 document control requirements.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:businessUnit rdf:type rdf:Property ;
    rdfs:label 'Business Unit' ;
    rdfs:comment 'The internal business unit or division of Chemical Mfg responsible for serving this customer segment (e.g., Performance Materials, Agricultural Solutions, Specialty Chemicals, Industrial Chemicals). Maps to SAP FI/CO profit center and Salesforce CRM business unit hierarchy.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coaRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Coa Requirement Flag' ;
    rdfs:comment 'Indicates whether customers in this segment require a Certificate of Analysis (COA) to accompany each shipment, confirming that the product meets specified quality parameters. True = COA mandatory per shipment; False = COA provided on request. Relevant for pharmaceutical excipient, food-grade, and high-purity electronic chemical segments.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crmSegmentCode rdf:type rdf:Property ;
    rdfs:label 'Crm Segment Code' ;
    rdfs:comment 'External identifier for this customer segment as maintained in Salesforce CRM, the system of record for customer segmentation. Used for cross-system reconciliation and data lineage tracing between the Silver Layer lakehouse and Salesforce CRM.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultPaymentTerms rdf:type rdf:Property ;
    rdfs:label 'Default Payment Terms' ;
    rdfs:comment 'Standard payment terms applied to customers in this segment as a default in SAP SD order processing (e.g., NET30, NET60, 2/10NET30 for 2% discount if paid within 10 days). Can be overridden at the individual customer account level.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmpComplianceRequired rdf:type rdf:Property ;
    rdfs:label 'Gmp Compliance Required' ;
    rdfs:comment 'Indicates whether customers in this segment require chemical products to be manufactured under Good Manufacturing Practice (GMP) conditions, as applicable to pharmaceutical excipient, API intermediate, and food-contact chemical segments. True = GMP manufacturing and documentation required; False = standard industrial quality.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:growthPotentialRating rdf:type rdf:Property ;
    rdfs:label 'Growth Potential Rating' ;
    rdfs:comment 'Commercial assessment of the revenue growth potential for this customer segment over a 3-5 year horizon: high (significant expansion opportunity), medium (stable moderate growth), low (mature or declining market), emerging (nascent segment with high uncertainty but upside potential). Used in commercial strategy and capital allocation decisions.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatShippingFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Shipping Flag' ;
    rdfs:comment 'Indicates whether products shipped to customers in this segment are classified as hazardous materials requiring DOT/IATA/IMDG compliant shipping documentation, placarding, and carrier certification. True = hazmat shipping protocols apply; False = non-hazardous standard shipping. Drives logistics configuration in Oracle TMS.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Review Date' ;
    rdfs:comment 'Date of the most recent formal review of this customer segment definition, including assessment of segment criteria, customer assignments, and commercial strategy alignment. Supports periodic governance review cycles.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:minOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Min Order Quantity' ;
    rdfs:comment 'Minimum Order Quantity (MOQ) applicable to customers in this segment, expressed in the standard unit of measure for the segment\'s primary product portfolio (e.g., kg, MT, liters). Enforced in SAP SD order entry to ensure commercial viability of transactions.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minOrderQuantityUom rdf:type rdf:Property ;
    rdfs:label 'Min Order Quantity Uom' ;
    rdfs:comment 'Unit of measure for the minimum order quantity field (e.g., kg = kilograms, MT = metric tonnes, L = liters, gal = gallons, drum = 200L drum, IBC = intermediate bulk container, bag = 25kg bag). Aligns with SAP MM unit of measure configuration. [ENUM-REF-CANDIDATE: kg|MT|L|gal|drum|IBC|bag — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:owner rdf:type rdf:Property ;
    rdfs:label 'Owner' ;
    rdfs:comment 'Name or employee identifier of the commercial leader (e.g., Business Development Manager, Market Segment Manager) accountable for the segment strategy, performance targets, and customer relationships within this segment. Aligns with Salesforce CRM account ownership model.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerEmail rdf:type rdf:Property ;
    rdfs:label 'Owner Email' ;
    rdfs:comment 'Corporate email address of the segment owner for routing commercial inquiries, escalations, and reporting. Used in automated workflow notifications from Salesforce CRM and SAP SD.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredPackagingType rdf:type rdf:Property ;
    rdfs:label 'Preferred Packaging Type' ;
    rdfs:comment 'Standard packaging format preferred by customers in this segment for chemical product delivery (e.g., 200L drums, 1000L IBC totes, bulk tanker, 25kg bags, 1kg laboratory bottles). Influences supply chain planning, warehouse operations in SAP EWM, and logistics configuration in Oracle TMS.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingTierCode rdf:type rdf:Property ;
    rdfs:label 'Pricing Tier Code' ;
    rdfs:comment 'Code identifying the pricing tier applicable to customers in this segment, referencing the SAP SD pricing procedure and condition type configuration. Determines base price lists, discount structures, and rebate eligibility. Classified as confidential due to commercial sensitivity.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryProductPortfolio rdf:type rdf:Property ;
    rdfs:label 'Primary Product Portfolio' ;
    rdfs:comment 'Description of the primary chemical product lines, formulations, or product families applicable to this customer segment (e.g., Epoxy Resins, Polyurethane Intermediates, Crop Protection Actives, Electronic-Grade Solvents). Drives product recommendation logic and technical service scoping.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reachRegistrationRequired rdf:type rdf:Property ;
    rdfs:label 'Reach Registration Required' ;
    rdfs:comment 'Indicates whether customers in this segment are located in the European Economic Area and therefore require REACH registration documentation for all chemical substances supplied above 1 tonne per year. True = REACH compliance documentation required; False = not applicable. Drives regulatory documentation workflows.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryComplianceProfile rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Profile' ;
    rdfs:comment 'Description of the primary regulatory frameworks applicable to customers in this segment that Chemical Mfg must support (e.g., REACH compliance documentation for EU customers, TSCA Section 6 for US industrial customers, GHS SDS requirements, FDA food-contact compliance for food-grade chemical customers). Drives documentation and compliance reporting obligations.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesRegion rdf:type rdf:Property ;
    rdfs:label 'Sales Region' ;
    rdfs:comment 'Geographic sales region primarily associated with this customer segment (e.g., North America, EMEA, APAC, Latin America). Used for territory planning, quota allocation, and regional commercial reporting in SAP SD and Salesforce CRM.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapCustomerGroup rdf:type rdf:Property ;
    rdfs:label 'Sap Customer Group' ;
    rdfs:comment 'SAP SD customer group code (field KDGRP) associated with this segment, used for pricing condition determination, rebate processing, and sales statistics grouping in SAP S/4HANA. Enables direct mapping between the segment definition and SAP SD commercial configuration.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdsRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Sds Requirement Flag' ;
    rdfs:comment 'Indicates whether customers in this segment require Safety Data Sheet (SDS) documentation to be provided with all chemical shipments as a standard commercial requirement. True = SDS mandatory for all orders; False = SDS provided on request only. Aligns with GHS and OSHA Hazard Communication Standard (HCS) requirements.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:segmentCode rdf:type rdf:Property ;
    rdfs:label 'Segment Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the customer segment (e.g., AUTO_OEM, AGRO_DIST, SPEC_COAT, PHARMA_EXC, ELEC_MFG). Used as the business key in Salesforce CRM and SAP SD customer classification. Serves as the BUSINESS_IDENTIFIER for this MASTER_RESOURCE entity.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentDescription rdf:type rdf:Property ;
    rdfs:label 'Segment Description' ;
    rdfs:comment 'Detailed narrative description of the customer segment, including the types of customers included, their primary use cases for chemical products, and the commercial rationale for the segment definition.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentName rdf:type rdf:Property ;
    rdfs:label 'Segment Name' ;
    rdfs:comment 'Human-readable name of the customer segment (e.g., Automotive OEM, Agrochemical Distributor, Specialty Coatings, Pharma Excipient, Electronics). Serves as the IDENTITY_LABEL for this MASTER_RESOURCE entity. Used in commercial strategy, pricing tiers, and technical service allocation.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentStatus rdf:type rdf:Property ;
    rdfs:label 'Segment Status' ;
    rdfs:comment 'Current lifecycle status of the customer segment definition: active (in use for commercial operations), inactive (no longer applied to new customers), under_review (being evaluated for revision), deprecated (replaced by a newer segment structure). Serves as the LIFECYCLE_STATUS for this MASTER_RESOURCE entity.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentTier rdf:type rdf:Property ;
    rdfs:label 'Segment Tier' ;
    rdfs:comment 'Commercial priority tier assigned to the segment, reflecting strategic importance and resource allocation level. Tier 1 represents the highest-priority segments (e.g., strategic global accounts), while Tier 4 represents transactional or low-volume segments. Drives pricing authority, technical service allocation, and account management coverage.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentType rdf:type rdf:Property ;
    rdfs:label 'Segment Type' ;
    rdfs:comment 'Classification of the segment by customer relationship type: end_user (direct consumer of chemicals), distributor (reseller/channel partner), oem (original equipment manufacturer), toll_manufacturer (contract processor), trading_company (commodity trader), government (public sector). Serves as the primary CLASSIFICATION_OR_TYPE for this entity. [ENUM-REF-CANDIDATE: end_user|distributor|oem|toll_manufacturer|trading_company|government|broker|cooperative — promote to reference product if additional types are needed]' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategicAccountFlag rdf:type rdf:Property ;
    rdfs:label 'Strategic Account Flag' ;
    rdfs:comment 'Indicates whether customers in this segment are classified as strategic accounts requiring dedicated key account management, executive sponsorship, and customized commercial terms. True = strategic segment; False = standard commercial segment. Drives resource allocation in Salesforce CRM and SAP SD pricing.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetRevenueUsd rdf:type rdf:Property ;
    rdfs:label 'Target Revenue Usd' ;
    rdfs:comment 'Annual revenue target in US Dollars (USD) set for this customer segment as part of the commercial planning cycle. Used in SAP FI/CO profitability analysis (CO-PA) and Salesforce CRM quota management. Classified as confidential due to commercial sensitivity. This is a planning input, not a calculated aggregate.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:technicalServiceLevel rdf:type rdf:Property ;
    rdfs:label 'Technical Service Level' ;
    rdfs:comment 'Level of technical service and application support allocated to customers in this segment: full_service (dedicated technical account manager, on-site support, custom formulation assistance), standard (remote technical support, standard SDS/COA documentation), self_service (online portal access only), none (no technical service). Drives resource planning for technical sales teams.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:walletShareEstimatePct rdf:type rdf:Property ;
    rdfs:label 'Wallet Share Estimate Pct' ;
    rdfs:comment 'Estimated percentage of the total addressable spend within this segment that Chemical Mfg currently captures (0.00 to 100.00). Represents the MEASUREMENT_OR_VALUE principal quantitative fact for this MASTER_RESOURCE entity. Used in commercial strategy to identify penetration gaps and prioritize growth investments. Classified as confidential due to competitive sensitivity.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interactionId rdf:type rdf:Property ;
    rdfs:label 'Interaction Id' ;
    rdfs:comment 'Unique surrogate identifier for each customer interaction record in the Silver Layer lakehouse. Primary key for the interaction data product.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:customerSiteId rdf:type rdf:Property ;
    rdfs:label 'Customer Site Id' ;
    rdfs:comment 'Reference to the specific customer site or plant location where the interaction occurred or is relevant to. Supports site-level account management and technical service tracking.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Site .

ind:coaRequestFlag rdf:type rdf:Property ;
    rdfs:label 'Coa Request Flag' ;
    rdfs:comment 'Indicates whether the customer requested a Certificate of Analysis (COA) during this interaction. Supports quality document fulfillment tracking and customer quality management.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complaintFlag rdf:type rdf:Property ;
    rdfs:label 'Complaint Flag' ;
    rdfs:comment 'Indicates whether this interaction involves or originated from a customer complaint. Triggers linkage to the complaint/case management workflow and Corrective and Preventive Action (CAPA) process.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crmActivityCode rdf:type rdf:Property ;
    rdfs:label 'Crm Activity Code' ;
    rdfs:comment 'External identifier from Salesforce CRM activity record. Used to trace the interaction back to the system of record for reconciliation and lineage.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerParticipantCount rdf:type rdf:Property ;
    rdfs:label 'Customer Participant Count' ;
    rdfs:comment 'Number of customer-side contacts who participated in the interaction. Indicates the breadth of customer engagement and stakeholder involvement.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:customerParticipants rdf:type rdf:Property ;
    rdfs:label 'Customer Participants' ;
    rdfs:comment 'Comma-separated list of customer contact names or identifiers who participated in the interaction. Confidential business relationship data.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSatisfactionScore rdf:type rdf:Property ;
    rdfs:label 'Customer Satisfaction Score' ;
    rdfs:comment 'Numeric satisfaction rating provided by the customer or assessed by the account manager following the interaction, typically on a 1-5 or 1-10 scale. Supports Key Performance Indicator (KPI) tracking for customer relationship health.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:durationMinutes rdf:type rdf:Property ;
    rdfs:label 'Duration Minutes' ;
    rdfs:comment 'The total elapsed time of the interaction in minutes. Used to assess engagement depth, resource utilization, and account planning efficiency.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpDueDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Due Date' ;
    rdfs:comment 'The target date by which the required follow-up action must be completed. Used for task management and account manager accountability tracking.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:followUpNotes rdf:type rdf:Property ;
    rdfs:label 'Follow Up Notes' ;
    rdfs:comment 'Free-text description of the specific follow-up actions committed to during the interaction. Captures commitments made to the customer for accountability and continuity.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpRequired rdf:type rdf:Property ;
    rdfs:label 'Follow Up Required' ;
    rdfs:comment 'Indicates whether a follow-up action or subsequent interaction is required as a result of this interaction. Drives task creation and account planning workflows.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interactionDate rdf:type rdf:Property ;
    rdfs:label 'Interaction Date' ;
    rdfs:comment 'The calendar date on which the customer interaction occurred. Used for day-level scheduling, account planning, and reporting.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:interactionDescription rdf:type rdf:Property ;
    rdfs:label 'Interaction Description' ;
    rdfs:comment 'Detailed narrative of the interaction content, discussion points, and context. Captures technical topics discussed, products referenced, and any regulatory or compliance matters raised.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionStatus rdf:type rdf:Property ;
    rdfs:label 'Interaction Status' ;
    rdfs:comment 'Current lifecycle status of the interaction record. Indicates whether the interaction was completed as planned, cancelled, or requires rescheduling.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Interaction Timestamp' ;
    rdfs:comment 'The precise date and time at which the customer interaction commenced. Supports time-zone-aware analytics and SLA measurement.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:interactionType rdf:type rdf:Property ;
    rdfs:label 'Interaction Type' ;
    rdfs:comment 'Classification of the nature or purpose of the customer interaction. Distinguishes between sales-driven, technical service, complaint handling, and digital engagement touchpoints. [ENUM-REF-CANDIDATE: sales_call|technical_visit|complaint_call|email_exchange|webinar|trade_show|portal_login|video_conference — promote to reference product]' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalParticipantCount rdf:type rdf:Property ;
    rdfs:label 'Internal Participant Count' ;
    rdfs:comment 'Number of internal Chemical Mfg employees who participated in the interaction. Used for resource utilization and engagement intensity analysis.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:internalParticipants rdf:type rdf:Property ;
    rdfs:label 'Internal Participants' ;
    rdfs:comment 'Comma-separated list of internal employee names or identifiers who participated in the interaction (e.g., account manager, technical service representative, application chemist). Supports multi-participant interaction tracking.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:location rdf:type rdf:Property ;
    rdfs:label 'Location' ;
    rdfs:comment 'Physical or virtual location where the interaction took place (e.g., customer plant site, trade show venue, video conference URL, Chemical Mfg office). Relevant for in-person and on-site technical visits.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextInteractionDate rdf:type rdf:Property ;
    rdfs:label 'Next Interaction Date' ;
    rdfs:comment 'The scheduled date for the next planned customer interaction as agreed during this touchpoint. Supports account planning cadence and proactive customer engagement management.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:outcome rdf:type rdf:Property ;
    rdfs:label 'Outcome' ;
    rdfs:comment 'The result or disposition of the interaction as assessed by the internal participant. Supports win/loss analysis, customer satisfaction tracking, and account health scoring.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productLine rdf:type rdf:Property ;
    rdfs:label 'Product Line' ;
    rdfs:comment 'The Chemical Mfg product line or portfolio segment discussed during the interaction (e.g., performance materials, agricultural solutions, specialty chemicals). Supports product-level engagement analytics.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryTopicFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Topic Flag' ;
    rdfs:comment 'Indicates whether the interaction involved discussion of regulatory or compliance topics such as REACH, TSCA, GHS, SDS requirements, or EPA/OSHA obligations. Supports regulatory engagement tracking and compliance reporting.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sampleRequestFlag rdf:type rdf:Property ;
    rdfs:label 'Sample Request Flag' ;
    rdfs:comment 'Indicates whether the customer requested a product sample during this interaction. Triggers linkage to the sample request fulfillment process in the sales domain.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sdsRequestFlag rdf:type rdf:Property ;
    rdfs:label 'Sds Request Flag' ;
    rdfs:comment 'Indicates whether the customer requested a Safety Data Sheet (SDS) or Material Safety Data Sheet (MSDS) during this interaction. Supports regulatory document fulfillment tracking per GHS and OSHA HazCom requirements.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:technicalTopic rdf:type rdf:Property ;
    rdfs:label 'Technical Topic' ;
    rdfs:comment 'The primary technical subject matter discussed during the interaction (e.g., formulation support, application development, regulatory compliance, Safety Data Sheet (SDS) review, Certificate of Analysis (COA) query). Supports technical service analytics.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationId rdf:type rdf:Property ;
    rdfs:label 'Qualification Id' ;
    rdfs:comment 'Primary key for qualification' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ownerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Qualification owner employee tracks responsibility for product approvals, required for qualification audit and renewal processes.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:aplNumber rdf:type rdf:Property ;
    rdfs:label 'Apl Number' ;
    rdfs:comment 'Externally-known business identifier for the qualification record, typically assigned by the customer or jointly by the supplier and customer. Used in customer correspondence, COA references, and audit trails.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationUseCase rdf:type rdf:Property ;
    rdfs:label 'Application Use Case' ;
    rdfs:comment 'The specific end-use application or process for which the chemical product has been qualified at the customer site (e.g., automotive coating adhesion, semiconductor etch bath, pharmaceutical excipient, agricultural formulation carrier).' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedByCustomerContact rdf:type rdf:Property ;
    rdfs:label 'Approved By Customer Contact' ;
    rdfs:comment 'Name or identifier of the customer representative (e.g., quality engineer, procurement manager) who formally approved the qualification. Business-confidential as it identifies a specific customer decision-maker.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedByInternalUser rdf:type rdf:Property ;
    rdfs:label 'Approved By Internal User' ;
    rdfs:comment 'The name or employee ID of the internal Chemical Mfg representative (e.g., technical sales, quality manager) who managed and approved the qualification from the supplier side.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:casNumber rdf:type rdf:Property ;
    rdfs:label 'Cas Number' ;
    rdfs:comment 'The CAS Registry Number of the primary chemical substance in the qualified product. Used for regulatory cross-referencing under REACH, TSCA, and customer EHS systems.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeNotificationLeadDays rdf:type rdf:Property ;
    rdfs:label 'Change Notification Lead Days' ;
    rdfs:comment 'The minimum number of calendar days advance notice required to be given to the customer before implementing any change to the qualified product. Populated only when change_notification_required_flag is True.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:changeNotificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Change Notification Required Flag' ;
    rdfs:comment 'Indicates whether the customer requires formal notification (e.g., PCN - Product Change Notification) before any change to the qualified product formulation, process, or raw material source. Critical in automotive and electronics supply chains.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coaTemplateCode rdf:type rdf:Property ;
    rdfs:label 'Coa Template Code' ;
    rdfs:comment 'Reference to the COA template configured for this customer-product qualification. Defines which quality parameters and test results are reported on the COA accompanying each shipment.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:crmQualificationCode rdf:type rdf:Property ;
    rdfs:label 'Crm Qualification Code' ;
    rdfs:comment 'The qualification record identifier in Salesforce CRM, the system of record for customer-facing qualification activities. Enables bidirectional traceability between the lakehouse Silver Layer and the operational CRM.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerPartNumber rdf:type rdf:Property ;
    rdfs:label 'Customer Part Number' ;
    rdfs:comment 'The customer\'s own internal part number or material code assigned to this qualified chemical product. Used for cross-referencing in purchase orders, COA requests, and EDI transactions.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSpecNumber rdf:type rdf:Property ;
    rdfs:label 'Customer Spec Number' ;
    rdfs:comment 'The customer\'s internal specification document number that defines the quality requirements for this qualified product. Referenced on COA and COC documents during shipment.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusiveSupplyFlag rdf:type rdf:Property ;
    rdfs:label 'Exclusive Supply Flag' ;
    rdfs:comment 'Indicates whether Chemical Mfg is the sole qualified supplier for this product at this customer site. True = exclusive supply arrangement; False = customer has multiple qualified suppliers.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:industrySegment rdf:type rdf:Property ;
    rdfs:label 'Industry Segment' ;
    rdfs:comment 'The end-market industry segment of the customer for which this qualification applies. Drives regulatory requirements, COA content, and qualification rigor. [ENUM-REF-CANDIDATE: automotive|electronics|pharmaceutical|agriculture|construction|consumer_goods|industrial|aerospace|food_beverage|coatings — promote to reference product]' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Updated Timestamp' ;
    rdfs:comment 'The timestamp when this qualification record was most recently modified. Used for change tracking, audit compliance, and incremental data pipeline processing. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:limsQualificationReference rdf:type rdf:Property ;
    rdfs:label 'Lims Qualification Reference' ;
    rdfs:comment 'The qualification record identifier in LabWare LIMS, used to cross-reference lab trial data, test results, and analytical reports that supported the qualification decision.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxApprovedVolumeKg rdf:type rdf:Property ;
    rdfs:label 'Max Approved Volume Kg' ;
    rdfs:comment 'The maximum annual or periodic supply volume in kilograms approved under this qualification. Volumes exceeding this threshold require customer notification or re-qualification.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minApprovedVolumeKg rdf:type rdf:Property ;
    rdfs:label 'Min Approved Volume Kg' ;
    rdfs:comment 'The minimum annual or periodic supply volume in kilograms approved under this qualification. Volumes below this threshold may require re-qualification or customer notification.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productGrade rdf:type rdf:Property ;
    rdfs:label 'Product Grade' ;
    rdfs:comment 'The specific chemical grade or quality tier of the product that has been qualified (e.g., Technical Grade, Reagent Grade, Electronic Grade, Pharmaceutical Grade, Food Grade). Critical differentiator in chemical supply.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationMethod rdf:type rdf:Property ;
    rdfs:label 'Qualification Method' ;
    rdfs:comment 'The method by which the product was qualified for use at the customer site. \'lab_trial\' = bench-scale testing at customer or supplier lab; \'plant_trial\' = full-scale production trial at customer facility; \'third_party_cert\' = qualification via third-party certification body; \'desk_review\' = documentation-only review; \'customer_audit\' = qualification via customer site audit; \'equivalency_study\' = qualification via equivalency to an already-approved product.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationScope rdf:type rdf:Property ;
    rdfs:label 'Qualification Scope' ;
    rdfs:comment 'Defines the geographic or organizational scope of the qualification. \'site_specific\' = applies only to the named customer site; \'global_account\' = applies across all sites of the customer account; \'regional\' = applies to a defined regional cluster of sites; \'product_family\' = applies to a family of related products.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryComplianceStandard rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Standard' ;
    rdfs:comment 'The primary regulatory or quality standard under which this qualification was conducted (e.g., IATF 16949 for automotive, ICH Q7 for pharmaceutical API, IPC-7711 for electronics, ISO 9001 for general industrial). Drives audit and documentation requirements.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Lead Time Days' ;
    rdfs:comment 'The number of calendar days before the expiry date that the renewal process must be initiated to ensure supply continuity. Used to trigger renewal workflow alerts in the quality management system.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sdsIssueDate rdf:type rdf:Property ;
    rdfs:label 'Sds Issue Date' ;
    rdfs:comment 'The issue date of the Safety Data Sheet version referenced in this qualification. Used to verify that the customer was provided with current GHS-compliant hazard information at time of qualification.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sdsVersion rdf:type rdf:Property ;
    rdfs:label 'Sds Version' ;
    rdfs:comment 'The version number of the Safety Data Sheet (SDS) that was current at the time of qualification. Ensures traceability between the qualification and the hazard communication documentation provided to the customer.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skuCode rdf:type rdf:Property ;
    rdfs:label 'Sku Code' ;
    rdfs:comment 'The Stock Keeping Unit code identifying the specific product variant approved for supply. Aligns with SAP material number and customer-facing product catalogue.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specDeviationDescription rdf:type rdf:Property ;
    rdfs:label 'Spec Deviation Description' ;
    rdfs:comment 'Narrative description of any customer-approved deviations from the standard product specification included in this qualification. Populated only when spec_deviation_flag is True.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specDeviationFlag rdf:type rdf:Property ;
    rdfs:label 'Spec Deviation Flag' ;
    rdfs:comment 'Indicates whether this qualification includes customer-approved deviations from the standard product specification. True = one or more approved deviations exist; False = qualification is to standard specification.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:volumePeriod rdf:type rdf:Property ;
    rdfs:label 'Volume Period' ;
    rdfs:comment 'The time period to which the approved volume range (min/max) applies. Defines whether volume limits are annual, quarterly, monthly, or per-order constraints.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryProfileId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Profile Id' ;
    rdfs:comment 'Unique surrogate identifier for the customer regulatory and compliance profile record in the Silver Layer lakehouse.' ;
    rdfs:domain ind:RegulatoryProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hazmatStorageRuleId rdf:type rdf:Property ;
    rdfs:label 'Hazmat Storage Rule Id' ;
    rdfs:comment 'Foreign key linking to inventory.hazmat_storage_rule. Business justification: Ensures Regulatory Compliance Mapping, linking a customer\'s regulatory profile to the specific hazmat storage rule applied for safe handling and reporting.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HazmatStorageRule .

ind:regulatoryContactEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Contact Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Regulatory contact person is an employee; linking enables tracking of communications and compliance responsibilities.' ;
    rdfs:domain ind:RegulatoryProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:approvedProductCategories rdf:type rdf:Property ;
    rdfs:label 'Approved Product Categories' ;
    rdfs:comment 'Comma-separated list of chemical product categories or families that are approved for sale to this customer under the current regulatory profile (e.g., solvents, adhesives, specialty polymers). Restricts order processing to compliant product types.' ;
    rdfs:domain ind:RegulatoryProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditRightsAgreed rdf:type rdf:Property ;
    rdfs:label 'Audit Rights Agreed' ;
    rdfs:comment 'Indicates whether the customer has agreed to grant the supplier audit rights to verify compliance with regulatory requirements, safe handling practices, and end-use declarations for supplied chemicals.' ;
    rdfs:domain ind:RegulatoryProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:auditRightsAgreementDate rdf:type rdf:Property ;
    rdfs:label 'Audit Rights Agreement Date' ;
    rdfs:comment 'Date on which the customer formally agreed to audit rights provisions. Used to track agreement currency and renewal obligations.' ;
    rdfs:domain ind:RegulatoryProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coaRequired rdf:type rdf:Property ;
    rdfs:label 'Coa Required' ;
    rdfs:comment 'Indicates whether a Certificate of Analysis must accompany each shipment to this customer, confirming that the chemical product meets specified quality and composition standards.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cocRequired rdf:type rdf:Property ;
    rdfs:label 'Coc Required' ;
    rdfs:comment 'Indicates whether a Certificate of Compliance is required with each shipment, attesting that the product conforms to applicable regulatory and customer-specified requirements.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:destinationCountryCode rdf:type rdf:Property ;
    rdfs:label 'Destination Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the primary country of destination for chemical product shipments to this customer. Drives applicable regulatory framework selection (e.g., REACH for EU, TSCA for USA).' ;
    rdfs:domain ind:RegulatoryProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationRegion rdf:type rdf:Property ;
    rdfs:label 'Destination Region' ;
    rdfs:comment 'Geographic region or trade bloc of the customer destination (e.g., European Union, North America, Asia-Pacific) used for regional regulatory framework grouping and reporting.' ;
    rdfs:domain ind:RegulatoryProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downstreamUserNotification rdf:type rdf:Property ;
    rdfs:label 'Downstream User Notification' ;
    rdfs:comment 'Indicates whether this customer qualifies as a REACH downstream user and has been notified of their obligations under REACH, including use conditions, exposure scenarios, and risk management measures.' ;
    rdfs:domain ind:RegulatoryProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ehsCertificationExpiry rdf:type rdf:Property ;
    rdfs:label 'Ehs Certification Expiry' ;
    rdfs:comment 'Expiry date of the customer\'s EHS certification. Triggers re-validation workflow when approaching expiry to ensure continued compliance eligibility.' ;
    rdfs:domain ind:RegulatoryProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ehsCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Ehs Certification Number' ;
    rdfs:comment 'Certificate number or registration identifier for the customer\'s EHS management system certification (e.g., ISO 14001 certificate number), used for audit trail and verification.' ;
    rdfs:domain ind:RegulatoryProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ehsCertificationStatus rdf:type rdf:Property ;
    rdfs:label 'Ehs Certification Status' ;
    rdfs:comment 'Current status of the customer\'s EHS certification relevant to handling and using chemical products (e.g., ISO 14001, ISO 45001, OSHA VPP). Determines eligibility for certain product categories.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endUseDeclaration rdf:type rdf:Property ;
    rdfs:label 'End Use Declaration' ;
    rdfs:comment 'Customer\'s declared intended end-use application for the chemical products purchased (e.g., industrial solvent, agricultural formulation, polymer additive, pharmaceutical intermediate). Required for REACH downstream user obligations and export control compliance.' ;
    rdfs:domain ind:RegulatoryProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endUseSector rdf:type rdf:Property ;
    rdfs:label 'End Use Sector' ;
    rdfs:comment 'Industry sector classification of the customer\'s end-use application for purchased chemicals. [ENUM-REF-CANDIDATE: automotive|construction|electronics|agriculture|pharmaceuticals|consumer_goods|coatings|textiles|food_contact|industrial — promote to reference product]' ;
    rdfs:domain ind:RegulatoryProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exportLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Export License Number' ;
    rdfs:comment 'Export license or authorization number issued by the originating country\'s regulatory authority for controlled chemical substances, required for dual-use or restricted chemicals.' ;
    rdfs:domain ind:RegulatoryProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ghsApplicable rdf:type rdf:Property ;
    rdfs:label 'Ghs Applicable' ;
    rdfs:comment 'Indicates whether the Globally Harmonized System of Classification and Labelling of Chemicals applies to products sold to this customer, requiring GHS-compliant Safety Data Sheets and labels.' ;
    rdfs:domain ind:RegulatoryProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazmatTransportClass rdf:type rdf:Property ;
    rdfs:label 'Hazmat Transport Class' ;
    rdfs:comment 'DOT/IATA/IMDG hazardous materials transport classification applicable to chemical products shipped to this customer (e.g., Class 3 Flammable Liquid, Class 8 Corrosive). Governs packaging, labeling, and shipping documentation requirements.' ;
    rdfs:domain ind:RegulatoryProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:importLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Import License Number' ;
    rdfs:comment 'Customer\'s import license or permit number issued by the destination country\'s regulatory authority, required for controlled or restricted chemical substances. Must be validated before shipment.' ;
    rdfs:domain ind:RegulatoryProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAuditDate rdf:type rdf:Property ;
    rdfs:label 'Last Audit Date' ;
    rdfs:comment 'Date of the most recent regulatory compliance audit conducted at or for this customer. Used to schedule next audit and assess compliance currency.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:msdsRequired rdf:type rdf:Property ;
    rdfs:label 'Msds Required' ;
    rdfs:comment 'Indicates whether the legacy MSDS format (pre-GHS) is required in addition to or instead of the current SDS format, applicable for customers in jurisdictions that have not fully adopted GHS.' ;
    rdfs:domain ind:RegulatoryProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:profileNumber rdf:type rdf:Property ;
    rdfs:label 'Profile Number' ;
    rdfs:comment 'Externally-known business identifier for this regulatory profile, used in correspondence, audits, and regulatory submissions. Format: REGP-YYYYMMDD-CountryCode.' ;
    rdfs:domain ind:RegulatoryProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileStatus rdf:type rdf:Property ;
    rdfs:label 'Profile Status' ;
    rdfs:comment 'Current lifecycle state of the customer regulatory profile. Active indicates all requirements are met and sales may proceed; pending_review indicates documentation is under assessment; suspended indicates a compliance hold; expired indicates the profile requires renewal.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileType rdf:type rdf:Property ;
    rdfs:label 'Profile Type' ;
    rdfs:comment 'Classification of the customer relationship type that determines applicable regulatory obligations and documentation requirements for chemical product sales.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prop65Applicable rdf:type rdf:Property ;
    rdfs:label 'Prop65 Applicable' ;
    rdfs:comment 'Indicates whether California Proposition 65 (Safe Drinking Water and Toxic Enforcement Act) warning requirements apply to products sold to this customer based on end-use state or distribution territory.' ;
    rdfs:domain ind:RegulatoryProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reachApplicable rdf:type rdf:Property ;
    rdfs:label 'Reach Applicable' ;
    rdfs:comment 'Indicates whether the European Chemicals Agency REACH regulation applies to chemical products sold to this customer, based on destination country and product use.' ;
    rdfs:domain ind:RegulatoryProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryContactEmail rdf:type rdf:Property ;
    rdfs:label 'Regulatory Contact Email' ;
    rdfs:comment 'Email address of the designated regulatory affairs or EHS contact at the customer organization for compliance documentation, SDS distribution, and regulatory notifications.' ;
    rdfs:domain ind:RegulatoryProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryContactName rdf:type rdf:Property ;
    rdfs:label 'Regulatory Contact Name' ;
    rdfs:comment 'Full name of the designated regulatory affairs or EHS contact person at the customer organization responsible for managing compliance documentation and regulatory correspondence.' ;
    rdfs:domain ind:RegulatoryProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictedProductCategories rdf:type rdf:Property ;
    rdfs:label 'Restricted Product Categories' ;
    rdfs:comment 'Comma-separated list of chemical product categories that are restricted or prohibited from sale to this customer based on regulatory, end-use, or jurisdictional constraints. Triggers order block in SAP S/4HANA SD.' ;
    rdfs:domain ind:RegulatoryProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictedSubstanceAckDate rdf:type rdf:Property ;
    rdfs:label 'Restricted Substance Ack Date' ;
    rdfs:comment 'Date on which the customer formally acknowledged the supplier\'s Restricted Substance List. Used to track acknowledgment currency and trigger renewal when the RSL is updated.' ;
    rdfs:domain ind:RegulatoryProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:restrictedSubstanceAcknowledgment rdf:type rdf:Property ;
    rdfs:label 'Restricted Substance Acknowledgment' ;
    rdfs:comment 'Indicates whether the customer has formally acknowledged receipt and acceptance of the supplier\'s Restricted Substance List, confirming awareness of substances that are prohibited or restricted in supplied products.' ;
    rdfs:domain ind:RegulatoryProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rohsApplicable rdf:type rdf:Property ;
    rdfs:label 'Rohs Applicable' ;
    rdfs:comment 'Indicates whether EU RoHS (Restriction of Hazardous Substances) directive requirements apply to chemical products or materials sold to this customer, particularly relevant for electronics-sector customers.' ;
    rdfs:domain ind:RegulatoryProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sdsLanguageCode rdf:type rdf:Property ;
    rdfs:label 'Sds Language Code' ;
    rdfs:comment 'ISO 639-1 language code (optionally with ISO 3166-1 country subtag) specifying the required language for Safety Data Sheets provided to this customer (e.g., en, de, fr, zh-CN).' ;
    rdfs:domain ind:RegulatoryProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdsVersionRequired rdf:type rdf:Property ;
    rdfs:label 'Sds Version Required' ;
    rdfs:comment 'The specific version or format standard of the Safety Data Sheet required by this customer or their jurisdiction (e.g., GHS Rev 7, OSHA 2012, EU 2015/830). Ensures correct SDS format is provided with each shipment.' ;
    rdfs:domain ind:RegulatoryProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialLabelingRequirements rdf:type rdf:Property ;
    rdfs:label 'Special Labeling Requirements' ;
    rdfs:comment 'Free-text description of any customer-specific or jurisdiction-specific labeling requirements beyond standard GHS/SDS requirements, such as additional language requirements, customer-specific hazard statements, or country-specific pictogram standards.' ;
    rdfs:domain ind:RegulatoryProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:svhcNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Svhc Notification Required' ;
    rdfs:comment 'Indicates whether the customer requires proactive notification when any supplied product contains Substances of Very High Concern (SVHC) above 0.1% w/w threshold, as mandated under REACH Article 33.' ;
    rdfs:domain ind:RegulatoryProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tscaApplicable rdf:type rdf:Property ;
    rdfs:label 'Tsca Applicable' ;
    rdfs:comment 'Indicates whether the US EPA Toxic Substances Control Act requirements apply to chemical products sold to this customer.' ;
    rdfs:domain ind:RegulatoryProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unNumber rdf:type rdf:Property ;
    rdfs:label 'Un Number' ;
    rdfs:comment 'Primary UN number identifying the hazardous substance or article for transport documentation purposes. Required on shipping papers, labels, and placards for regulated chemical shipments to this customer.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceProfileId rdf:type rdf:Property ;
    rdfs:label 'Service Profile Id' ;
    rdfs:comment 'Primary key for service_profile' ;
    rdfs:domain ind:ServiceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryServiceCustomerAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Service Customer Account Id' ;
    rdfs:comment 'Reference to the customer account for which this technical service profile is established. Links the service profile to the customer master record in Salesforce CRM.' ;
    rdfs:domain ind:ServiceProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:primaryServiceTsrEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Service Tsr Employee Id' ;
    rdfs:comment 'Reference to the internal employee designated as the primary Technical Service Representative (TSR) for this customer account. The TSR is the main point of contact for day-to-day technical support and application assistance.' ;
    rdfs:domain ind:ServiceProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryServiceBackupTsrEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Service Backup Tsr Employee Id' ;
    rdfs:comment 'Reference to the secondary or backup Technical Service Representative (TSR) who covers the account in the primary TSR\'s absence, ensuring continuity of technical support.' ;
    rdfs:domain ind:ServiceProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:approvedApplications rdf:type rdf:Property ;
    rdfs:label 'Approved Applications' ;
    rdfs:comment 'Comma-separated list or free-text description of the specific product applications and end-use segments approved for this customer under this service profile (e.g., automotive coatings, agricultural adjuvants, electronic encapsulants). Drives application-specific technical support scope.' ;
    rdfs:domain ind:ServiceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coaAutoDeliveryFlag rdf:type rdf:Property ;
    rdfs:label 'Coa Auto Delivery Flag' ;
    rdfs:comment 'Indicates whether Certificates of Analysis (COA) are automatically delivered to the customer with each shipment as part of this service profile. When True, COA documents are generated from LabWare LIMS and transmitted electronically upon shipment confirmation.' ;
    rdfs:domain ind:ServiceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complaintResponseSlaDays rdf:type rdf:Property ;
    rdfs:label 'Complaint Response Sla Days' ;
    rdfs:comment 'Contracted number of business days within which Chemical Mfg must provide an initial technical response to a customer complaint or out-of-specification (OOS) claim under this service profile. Drives CAPA process timelines.' ;
    rdfs:domain ind:ServiceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:customerSegment rdf:type rdf:Property ;
    rdfs:label 'Customer Segment' ;
    rdfs:comment 'Business segment classification of the customer receiving technical service. Distinguishes between direct industrial customers, distributors, OEM manufacturers, end-users, and strategic accounts, which determines the nature and depth of technical service provided.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationPath rdf:type rdf:Property ;
    rdfs:label 'Escalation Path' ;
    rdfs:comment 'Defined escalation path for technical complaints and out-of-specification (OOS) issues raised by this customer. Specifies the sequence of escalation contacts from TSR through regional management to executive level, aligned with the customer\'s service tier and criticality.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expirationDate rdf:type rdf:Property ;
    rdfs:label 'Expiration Date' ;
    rdfs:comment 'Date on which this technical service profile expires or is scheduled to end. Null indicates an open-ended service agreement with no fixed termination date.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:formulationAssistanceFlag rdf:type rdf:Property ;
    rdfs:label 'Formulation Assistance Flag' ;
    rdfs:comment 'Indicates whether the customer is entitled to formulation assistance services under this service profile. When True, Chemical Mfg\'s formulation scientists provide direct support in developing or optimizing the customer\'s product formulations using Chemical Mfg materials.' ;
    rdfs:domain ind:ServiceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jdaReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Jda Reference Number' ;
    rdfs:comment 'Reference number for the Joint Development Agreement (JDA) between Chemical Mfg and the customer, if applicable. A JDA formalizes collaborative R&D activities, IP ownership, and co-development milestones. Populated only for strategic-tier customers with active joint development programs.' ;
    rdfs:domain ind:ServiceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labSupportEntitlement rdf:type rdf:Property ;
    rdfs:label 'Lab Support Entitlement' ;
    rdfs:comment 'Level of laboratory support the customer is entitled to under this service profile. \'None\' indicates no lab support; \'Basic\' covers standard analytical testing; \'Advanced\' includes formulation development support; \'Full\' includes dedicated lab time and custom testing via LabWare LIMS.' ;
    rdfs:domain ind:ServiceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Modified Timestamp' ;
    rdfs:comment 'Timestamp indicating when this technical service profile record was most recently updated. Supports change tracking, audit compliance, and data freshness monitoring in the Silver Layer.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:limsCustomerCode rdf:type rdf:Property ;
    rdfs:label 'Lims Customer Code' ;
    rdfs:comment 'Customer identifier in LabWare LIMS used to associate lab test requests, COA generation, and analytical results with this customer\'s service profile. Enables traceability between lab activities and customer service entitlements.' ;
    rdfs:domain ind:ServiceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onsiteVisitFrequency rdf:type rdf:Property ;
    rdfs:label 'Onsite Visit Frequency' ;
    rdfs:comment 'Agreed frequency of on-site technical service visits to the customer\'s facility by the assigned TSR or application engineer. Drives field service scheduling and travel planning.' ;
    rdfs:domain ind:ServiceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pilotPlantAccessFlag rdf:type rdf:Property ;
    rdfs:label 'Pilot Plant Access Flag' ;
    rdfs:comment 'Indicates whether the customer has been granted access to Chemical Mfg\'s pilot plant facilities for scale-up trials, process validation, or application development. Typically reserved for strategic-tier customers with active joint development programs.' ;
    rdfs:domain ind:ServiceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryContactEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Email' ;
    rdfs:comment 'Business email address of the primary technical contact at the customer organization. Used for technical communications, SDS/COA distribution, and complaint correspondence.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactName rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Name' ;
    rdfs:comment 'Full name of the primary technical contact person at the customer\'s organization who interfaces with Chemical Mfg\'s technical service team. This is the customer-side counterpart to the assigned TSR.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Phone' ;
    rdfs:comment 'Direct phone number of the primary technical contact at the customer organization for urgent technical support communications.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileCode rdf:type rdf:Property ;
    rdfs:label 'Profile Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this technical service profile, used in customer-facing communications and cross-system references. Sourced from Salesforce CRM service agreement records.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileName rdf:type rdf:Property ;
    rdfs:label 'Profile Name' ;
    rdfs:comment 'Human-readable name or title for the technical service profile, typically reflecting the customer name and service tier (e.g., \'Acme Corp - Strategic Technical Service Profile\').' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileNotes rdf:type rdf:Property ;
    rdfs:label 'Profile Notes' ;
    rdfs:comment 'Free-text field for capturing additional context, special instructions, or qualifications relevant to this customer\'s technical service profile, such as specific handling requirements, regulatory sensitivities, or strategic account notes.' ;
    rdfs:domain ind:ServiceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorySupportFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Support Flag' ;
    rdfs:comment 'Indicates whether this service profile includes regulatory support services, such as assistance with REACH registration dossiers, TSCA compliance documentation, or GHS classification queries. Relevant for customers in regulated end-use markets.' ;
    rdfs:domain ind:ServiceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalReminderDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Reminder Days' ;
    rdfs:comment 'Number of days before the profile expiration date that an automated renewal reminder should be triggered to the assigned TSR and account manager. Supports proactive service contract renewal management.' ;
    rdfs:domain ind:ServiceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sampleRequestEntitlement rdf:type rdf:Property ;
    rdfs:label 'Sample Request Entitlement' ;
    rdfs:comment 'Maximum number of product sample requests the customer is entitled to per calendar year under this service profile. Supports the technical sales model where samples are provided for application evaluation and qualification.' ;
    rdfs:domain ind:ServiceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sapSoldToParty rdf:type rdf:Property ;
    rdfs:label 'Sap Sold To Party' ;
    rdfs:comment 'SAP S/4HANA SD sold-to party number for the customer associated with this service profile. Used to link technical service entitlements to order management, pricing, and delivery processes in SAP.' ;
    rdfs:domain ind:ServiceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdsDistributionFlag rdf:type rdf:Property ;
    rdfs:label 'Sds Distribution Flag' ;
    rdfs:comment 'Indicates whether Chemical Mfg is responsible for proactively distributing Safety Data Sheets (SDS) to this customer as part of the service profile. When True, updated SDS documents are automatically distributed upon revision.' ;
    rdfs:domain ind:ServiceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceSiteCountry rdf:type rdf:Property ;
    rdfs:label 'Service Site Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the customer site location where technical services are delivered. Determines applicable regulatory frameworks (e.g., REACH for EU, TSCA for USA) and regional TSR assignment.' ;
    rdfs:domain ind:ServiceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceSiteLocation rdf:type rdf:Property ;
    rdfs:label 'Service Site Location' ;
    rdfs:comment 'Name or identifier of the specific customer plant, facility, or site location to which this technical service profile applies. A customer may have multiple sites with different service profiles.' ;
    rdfs:domain ind:ServiceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceTier rdf:type rdf:Property ;
    rdfs:label 'Service Tier' ;
    rdfs:comment 'Classification of the level of technical service and application support contracted or agreed upon with the customer. \'Standard\' provides basic technical support; \'Premium\' includes dedicated resources and faster response; \'Strategic\' includes joint development, pilot plant access, and executive engagement. Drives resource allocation and SLA commitments.' ;
    rdfs:domain ind:ServiceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalTrainingEntitlement rdf:type rdf:Property ;
    rdfs:label 'Technical Training Entitlement' ;
    rdfs:comment 'Number of technical training sessions (webinars, workshops, or on-site training) the customer is entitled to per year under this service profile. Covers product application training, safety handling, and regulatory updates.' ;
    rdfs:domain ind:ServiceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:siteId rdf:type rdf:Property ;
    rdfs:label 'Site Id' ;
    rdfs:comment 'Unique surrogate identifier for the customer site or plant location record in the Silver Layer lakehouse. Primary key for the site entity.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Site .

ind:managerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Site Manager assignment needed for daily operations, safety compliance, and site performance reporting.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:parentSiteId rdf:type rdf:Property ;
    rdfs:label 'Parent Site Id' ;
    rdfs:comment 'Self-referencing identifier for the parent site in a site hierarchy (e.g., a campus or complex with multiple sub-sites). Enables multi-level site hierarchy modeling for large industrial customers.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Site .

ind:warehouseLocationId rdf:type rdf:Property ;
    rdfs:label 'Warehouse Location Id' ;
    rdfs:comment 'Foreign key linking to inventory.warehouse_location. Business justification: Required for Delivery Planning Report that maps each customer site to the warehouse location used for shipments, enabling logistics scheduling and compliance with delivery windows.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WarehouseLocation .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line1' ;
    rdfs:comment 'Primary street address of the customer site. Used for shipment routing, hazardous materials transport documentation (DOT), and regulatory permit filings.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line2' ;
    rdfs:comment 'Secondary address detail for the customer site (suite, building, dock number, gate reference). Supplements address_line1 for precise delivery routing.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bulkReceiptCapable rdf:type rdf:Property ;
    rdfs:label 'Bulk Receipt Capable' ;
    rdfs:comment 'Indicates whether the site has infrastructure (tank farm, unloading arms, pumps) to receive bulk liquid or solid chemical shipments via tanker truck or rail car.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capacityMt rdf:type rdf:Property ;
    rdfs:label 'Capacity Mt' ;
    rdfs:comment 'Maximum chemical storage capacity of the site expressed in metric tons. Used for supply planning, inventory replenishment modeling, and tank farm utilization analytics.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Delivery Window End' ;
    rdfs:comment 'Latest time of day (HH:MM, 24-hour) at which the site accepts chemical deliveries. Used for carrier scheduling, route optimization, and on-time delivery KPI measurement.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryWindowStart rdf:type rdf:Property ;
    rdfs:label 'Delivery Window Start' ;
    rdfs:comment 'Earliest time of day (HH:MM, 24-hour) at which the site accepts chemical deliveries. Used for carrier scheduling, route optimization, and on-time delivery KPI measurement.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dockRestrictions rdf:type rdf:Property ;
    rdfs:label 'Dock Restrictions' ;
    rdfs:comment 'Free-text description of physical dock constraints at the site (e.g., maximum trailer length, dock height limitations, no live unload, appointment required). Used by Oracle TMS and carrier dispatch.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ehsContactName rdf:type rdf:Property ;
    rdfs:label 'Ehs Contact Name' ;
    rdfs:comment 'Name of the designated EHS contact at the customer site. Required for hazardous chemical deliveries, SDS acknowledgment, emergency response coordination, and OSHA PSM compliance.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ehsContactPhone rdf:type rdf:Property ;
    rdfs:label 'Ehs Contact Phone' ;
    rdfs:comment 'Direct phone number for the site EHS contact. Used for emergency chemical incident response, hazmat delivery coordination, and regulatory inspection notifications.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fax rdf:type rdf:Property ;
    rdfs:label 'Fax' ;
    rdfs:comment 'Fax number for the customer site. Used for transmission of SDS, COA, COC, and regulatory documentation where electronic fax is the required delivery channel.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatReceivingCapable rdf:type rdf:Property ;
    rdfs:label 'Hazmat Receiving Capable' ;
    rdfs:comment 'Indicates whether the site is certified and equipped to receive hazardous chemical materials per DOT and OSHA regulations. Governs which chemical products can be shipped to this site.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:latitude rdf:type rdf:Property ;
    rdfs:label 'Latitude' ;
    rdfs:comment 'GPS latitude coordinate of the customer site in decimal degrees (WGS 84). Used for route optimization in Oracle Transportation Management, emergency response planning, and geospatial analytics.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:longitude rdf:type rdf:Property ;
    rdfs:label 'Longitude' ;
    rdfs:comment 'GPS longitude coordinate of the customer site in decimal degrees (WGS 84). Used for route optimization, emergency response planning, and geospatial analytics.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatingHours rdf:type rdf:Property ;
    rdfs:label 'Operating Hours' ;
    rdfs:comment 'Textual description of the site\'s standard operating hours for receiving deliveries (e.g., \'Mon-Fri 06:00-18:00 CST\'). Used by Oracle TMS and SAP EWM for delivery window scheduling.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingPreference rdf:type rdf:Property ;
    rdfs:label 'Packaging Preference' ;
    rdfs:comment 'Customer\'s preferred packaging format for chemical product receipt at this site (e.g., bulk tanker, 55-gallon drum, IBC tote, bag). Drives order fulfillment, SKU selection, and GHS labeling requirements.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Permit Expiry Date' ;
    rdfs:comment 'Expiration date of the site\'s primary regulatory operating or environmental permit. Triggers renewal alerts and may restrict chemical deliveries if permit lapses.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:postalCode rdf:type rdf:Property ;
    rdfs:label 'Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the customer site. Used for freight rate calculation, carrier zone assignment, and geographic analytics.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredCarrier rdf:type rdf:Property ;
    rdfs:label 'Preferred Carrier' ;
    rdfs:comment 'Name or code of the customer\'s preferred freight carrier for deliveries to this site. Used in Oracle TMS carrier selection and rate negotiation.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryPermitNumber rdf:type rdf:Property ;
    rdfs:label 'Regulatory Permit Number' ;
    rdfs:comment 'Primary environmental or operating permit number issued to the customer site by a regulatory authority (EPA, state agency, OSHA). Required for hazardous chemical delivery authorization and compliance documentation.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesforceSiteCode rdf:type rdf:Property ;
    rdfs:label 'Salesforce Site Code' ;
    rdfs:comment 'External system identifier for this site record in Salesforce CRM (system of record). Used for data lineage, cross-system reconciliation, and integration with Salesforce-driven sales and service workflows.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdsRequired rdf:type rdf:Property ;
    rdfs:label 'Sds Required' ;
    rdfs:comment 'Indicates whether the site requires a GHS-compliant Safety Data Sheet (SDS) to accompany every chemical shipment. Mandatory for hazardous chemical deliveries under OSHA HazCom and GHS standards.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:siteCode rdf:type rdf:Property ;
    rdfs:label 'Site Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the site, sourced from SAP S/4HANA customer master or Salesforce CRM. Used in order management, shipping documents, and COA/COC references.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteName rdf:type rdf:Property ;
    rdfs:label 'Site Name' ;
    rdfs:comment 'Human-readable name of the customer site or plant location (e.g., \'Baytown Refinery\', \'Chicago Distribution Center\'). Used on shipping labels, SDS delivery documentation, and customer communications.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteStatus rdf:type rdf:Property ;
    rdfs:label 'Site Status' ;
    rdfs:comment 'Current lifecycle status of the customer site record. Controls whether orders, deliveries, and EHS documentation can be processed against this site.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteType rdf:type rdf:Property ;
    rdfs:label 'Site Type' ;
    rdfs:comment 'Classification of the physical site by its primary operational function. Drives logistics planning, hazmat receiving rules, and EHS compliance requirements. [ENUM-REF-CANDIDATE: manufacturing_plant|distribution_center|rd_lab|warehouse|terminal|blending_facility|storage_depot|other — promote to reference product]' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tankFarmAvailable rdf:type rdf:Property ;
    rdfs:label 'Tank Farm Available' ;
    rdfs:comment 'Indicates whether the customer site has a dedicated tank farm for bulk liquid chemical storage. Determines eligibility for bulk tanker delivery and long-term supply agreements.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:temperatureControlled rdf:type rdf:Property ;
    rdfs:label 'Temperature Controlled' ;
    rdfs:comment 'Indicates whether the site requires temperature-controlled storage or delivery conditions for chemical products (e.g., cryogenic, refrigerated, or heated materials).' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:timeZone rdf:type rdf:Property ;
    rdfs:label 'Time Zone' ;
    rdfs:comment 'IANA time zone identifier for the customer site (e.g., \'America/Chicago\', \'Europe/Berlin\'). Used for delivery window scheduling, order cutoff time calculation, and global reporting normalization.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unLocode rdf:type rdf:Property ;
    rdfs:label 'Un Locode' ;
    rdfs:comment 'UN/LOCODE five-character location code identifying the customer site\'s port, city, or logistics node. Used in international shipping documentation, ASN processing, and TMS routing.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unloadingEquipment rdf:type rdf:Property ;
    rdfs:label 'Unloading Equipment' ;
    rdfs:comment 'Description of unloading equipment available at the site (e.g., forklift, pump, conveyor, crane, vacuum system). Ensures carrier and driver preparedness for chemical product offloading.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusHistoryId rdf:type rdf:Property ;
    rdfs:label 'Status History Id' ;
    rdfs:comment 'Primary key for status_history' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:customerAccountId rdf:type rdf:Property ;
    rdfs:label 'Customer Account Id' ;
    rdfs:comment 'Reference to the customer account whose status changed. Links this history record to the master customer account entity.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:reversedHistoryStatusHistoryId rdf:type rdf:Property ;
    rdfs:label 'Reversed History Status History Id' ;
    rdfs:comment 'Reference to the original account_status_history_id that this record reverses or corrects. Null when is_reversal is False. Enables complete audit chain reconstruction for compliance inquiries.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StatusHistory .

ind:approvalReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Approval Reference Code' ;
    rdfs:comment 'Reference to the approval workflow record or authorization document that sanctioned this status change. Required for credit department audit compliance and segregation of duties verification.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvalReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Approval Reference Number' ;
    rdfs:comment 'External or human-readable reference number of the approval document, workflow ticket, or authorization memo that sanctioned this status change. Complements the approval_reference_id for audit trail documentation and cross-system traceability.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingBlockCode rdf:type rdf:Property ;
    rdfs:label 'Billing Block Code' ;
    rdfs:comment 'The SAP billing block code applied to or removed from the customer account as part of this status change. Null when no billing block change occurred. Supports accounts receivable and revenue recognition impact analysis.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockedOrderCount rdf:type rdf:Property ;
    rdfs:label 'Blocked Order Count' ;
    rdfs:comment 'The number of open sales orders that were blocked or released as a direct result of this status change. Captured as a snapshot at transition time to quantify the operational impact of credit hold and suspension events.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capaReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Capa Reference Number' ;
    rdfs:comment 'Reference to a CAPA record when the status change was triggered by a quality or compliance corrective action outcome. Links customer account standing changes to the quality management system for traceability.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeReasonCode rdf:type rdf:Property ;
    rdfs:label 'Change Reason Code' ;
    rdfs:comment 'Standardized code identifying the business reason for the status transition (e.g., CREDIT_REVIEW, INSOLVENCY, REACTIVATION, REGULATORY_ACTION, MA_ACTIVITY, PAYMENT_DEFAULT, CUSTOMER_REQUEST). [ENUM-REF-CANDIDATE: CREDIT_REVIEW|INSOLVENCY|REACTIVATION|REGULATORY_ACTION|MA_ACTIVITY|PAYMENT_DEFAULT|CUSTOMER_REQUEST|CAPA_OUTCOME — promote to reference product]' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Change Reason Description' ;
    rdfs:comment 'Free-text narrative providing additional context for the status change beyond the standardized reason code. Captures nuanced circumstances such as specific regulatory action details, M&A transaction references, or credit review findings.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Change Timestamp' ;
    rdfs:comment 'The precise date and time when the status change was recorded in the system. Serves as the EVENT_TIMESTAMP for this event log record. Distinct from effective_date which represents the business effective date.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:companyCode rdf:type rdf:Property ;
    rdfs:label 'Company Code' ;
    rdfs:comment 'The SAP company code associated with this status change record. Identifies the legal entity within the chemical manufacturing enterprise for which the customer account status was changed. Supports multi-entity financial reporting.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditExposureAtChange rdf:type rdf:Property ;
    rdfs:label 'Credit Exposure At Change' ;
    rdfs:comment 'The customer\'s total outstanding credit exposure (open orders + open invoices + deliveries) in the base currency at the time of this status change. Provides context for credit hold and suspension decisions.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditLimitAtChange rdf:type rdf:Property ;
    rdfs:label 'Credit Limit At Change' ;
    rdfs:comment 'The customer\'s approved credit limit in the base currency at the time of this status change. Captured as a snapshot to support credit department audit compliance and historical credit exposure analysis.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daysInPreviousStatus rdf:type rdf:Property ;
    rdfs:label 'Days In Previous Status' ;
    rdfs:comment 'The number of calendar days the customer account remained in the previous status before this transition. Captured at the time of transition for customer lifecycle analytics and credit risk reporting. Not a calculated metric — stored as a business fact at transition time.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryBlockCode rdf:type rdf:Property ;
    rdfs:label 'Delivery Block Code' ;
    rdfs:comment 'The SAP delivery block code applied to or removed from the customer account as part of this status change (e.g., 01 for credit block). Null when no delivery block change occurred. Supports supply chain impact analysis.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insolvencyFilingReference rdf:type rdf:Property ;
    rdfs:label 'Insolvency Filing Reference' ;
    rdfs:comment 'Court case number, bankruptcy filing reference, or insolvency proceeding identifier when the status change was triggered by an insolvency filing. Null for non-insolvency transitions. Critical for accounts receivable risk management.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Ma Transaction Reference' ;
    rdfs:comment 'Reference identifier for the merger, acquisition, divestiture, or corporate restructuring event that triggered this status change. Null for non-M&A transitions. Supports customer hierarchy realignment and account consolidation tracking.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newStatus rdf:type rdf:Property ;
    rdfs:label 'New Status' ;
    rdfs:comment 'The customer account status assigned as a result of this transition event. Captures the \'to\' state in the status lifecycle transition pair (e.g., credit_hold in a transition from active→credit_hold).' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationDate rdf:type rdf:Property ;
    rdfs:label 'Notification Date' ;
    rdfs:comment 'The date on which the customer was formally notified of the status change. Null when notification_sent is False. Used to track compliance with contractual notification obligations and credit department procedures.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notificationSent rdf:type rdf:Property ;
    rdfs:label 'Notification Sent' ;
    rdfs:comment 'Indicates whether a formal notification was sent to the customer regarding this status change. Relevant for credit hold and suspension events where customer communication is required per contractual or regulatory obligations.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:previousStatus rdf:type rdf:Property ;
    rdfs:label 'Previous Status' ;
    rdfs:comment 'The customer account status immediately before this transition event. Captures the \'from\' state in the status lifecycle transition pair (e.g., active in a transition from active→credit_hold).' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reachComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Reach Compliance Flag' ;
    rdfs:comment 'Indicates whether this status change was triggered by or is associated with a REACH (Registration, Evaluation, Authorisation and Restriction of Chemicals) compliance issue with the customer. Supports ECHA regulatory reporting and EHS compliance tracking.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryAuthority rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority' ;
    rdfs:comment 'The governing body or regulatory authority whose action triggered this status change. Applicable when triggering_business_event is \'regulatory_action\'. Supports regulatory inquiry responses and EHS compliance reporting. [ENUM-REF-CANDIDATE: EPA|OSHA|ECHA|FDA|DOT|TSCA|ACC|NFPA|OTHER — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reference Number' ;
    rdfs:comment 'External regulatory case number, enforcement action identifier, or compliance filing reference associated with this status change when triggered by a regulatory action (e.g., EPA enforcement, TSCA violation, OSHA citation). Null for non-regulatory transitions.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewDueDate rdf:type rdf:Property ;
    rdfs:label 'Review Due Date' ;
    rdfs:comment 'The scheduled date by which this status should be reviewed for potential change (e.g., credit hold review date, suspension expiry review). Supports proactive credit management and customer lifecycle workflows.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceSystemChangeReference rdf:type rdf:Property ;
    rdfs:label 'Source System Change Reference' ;
    rdfs:comment 'The native change document number or record identifier from the originating source system (e.g., SAP change document number, Salesforce record ID). Enables cross-system traceability and reconciliation.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transitionType rdf:type rdf:Property ;
    rdfs:label 'Transition Type' ;
    rdfs:comment 'Categorical classification of the direction and nature of the status change. Distinguishes upgrades (e.g., prospect→active, credit_hold→active) from downgrades (e.g., active→credit_hold, active→suspended) and closures for lifecycle analytics.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggeringBusinessEvent rdf:type rdf:Property ;
    rdfs:label 'Triggering Business Event' ;
    rdfs:comment 'Classification of the specific business event that triggered this status transition. Distinguishes between credit review outcomes, M&A activity, insolvency filings, regulatory actions, and other lifecycle events for customer analytics and compliance reporting. [ENUM-REF-CANDIDATE: credit_review|ma_activity|insolvency_filing|regulatory_action|payment_default|customer_request|periodic_review|reactivation — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaRecordId rdf:type rdf:Property ;
    rdfs:label 'Capa Record Id' ;
    rdfs:comment 'System-generated unique identifier for the CAPA record.' ;
    rdfs:domain ind:CapaRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capaEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Capa Employee Id' ;
    rdfs:comment 'FK to workforce.employee' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:capaId rdf:type rdf:Property ;
    rdfs:label 'Capa Id' ;
    rdfs:comment 'Foreign key linking to quality.capa. Business justification: Coordinated corrective actions: EHS CAPA records often reference the same quality CAPA record to ensure aligned safety and quality remediation.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Capa .

ind:functionalLocationId rdf:type rdf:Property ;
    rdfs:label 'Functional Location Id' ;
    rdfs:comment 'Reference to the plant, facility, or site where the CAPA originates.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FunctionalLocation .

ind:managementOfChangeId rdf:type rdf:Property ;
    rdfs:label 'Management Of Change Id' ;
    rdfs:comment 'Identifier of the MOC record linked to this CAPA, if applicable.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ManagementOfChange .

ind:primaryCapaEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Capa Employee Id' ;
    rdfs:comment 'Identifier of the internal party (person or team) responsible for executing the CAPA.' ;
    rdfs:domain ind:CapaRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:relatedIncidentSafetyIncidentId rdf:type rdf:Property ;
    rdfs:label 'Related Incident Safety Incident Id' ;
    rdfs:comment 'Identifier of the safety or quality incident that generated this CAPA.' ;
    rdfs:domain ind:CapaRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SafetyIncident .

ind:actionType rdf:type rdf:Property ;
    rdfs:label 'Action Type' ;
    rdfs:comment 'Indicates whether the record documents a corrective action or a preventive action.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attachedDocumentCount rdf:type rdf:Property ;
    rdfs:label 'Attached Document Count' ;
    rdfs:comment 'Number of supporting documents attached to the CAPA record.' ;
    rdfs:domain ind:Ehs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capaRecordStatus rdf:type rdf:Property ;
    rdfs:label 'Capa Record Status' ;
    rdfs:comment 'Current lifecycle state of the CAPA record.' ;
    rdfs:domain ind:CapaRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureReason rdf:type rdf:Property ;
    rdfs:label 'Closure Reason' ;
    rdfs:comment 'Reason why the CAPA was closed (e.g., completed, withdrawn, not applicable).' ;
    rdfs:domain ind:Ehs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionDate rdf:type rdf:Property ;
    rdfs:label 'Completion Date' ;
    rdfs:comment 'Actual date when the CAPA was closed.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Status' ;
    rdfs:comment 'Current compliance status of the CAPA with the referenced regulation.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionDescription rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Description' ;
    rdfs:comment 'Detailed steps to correct the identified non-conformance.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costActual rdf:type rdf:Property ;
    rdfs:label 'Cost Actual' ;
    rdfs:comment 'Actual financial cost incurred for the CAPA.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costEstimate rdf:type rdf:Property ;
    rdfs:label 'Cost Estimate' ;
    rdfs:comment 'Projected financial cost to implement the CAPA.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:effectivenessRating rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Rating' ;
    rdfs:comment 'Result of the effectiveness review after CAPA closure.' ;
    rdfs:domain ind:CapaRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivenessReviewDate rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Review Date' ;
    rdfs:comment 'Date when the effectiveness of the CAPA was evaluated.' ;
    rdfs:domain ind:CapaRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:initiatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Initiated Timestamp' ;
    rdfs:comment 'Date and time when the CAPA was formally initiated.' ;
    rdfs:domain ind:CapaRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isExternal rdf:type rdf:Property ;
    rdfs:label 'Is External' ;
    rdfs:comment 'True if external consultants or contractors are involved in the CAPA.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preventiveActionDescription rdf:type rdf:Property ;
    rdfs:label 'Preventive Action Description' ;
    rdfs:comment 'Detailed steps to prevent recurrence of the issue.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Created Timestamp' ;
    rdfs:comment 'Timestamp when the CAPA record was first created in the system.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent modification to the CAPA record.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:regulatoryReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reference' ;
    rdfs:comment 'Regulatory framework or standard that prompted the CAPA (e.g., OSHA, EPA).' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewComments rdf:type rdf:Property ;
    rdfs:label 'Review Comments' ;
    rdfs:comment 'Comments entered during the effectiveness review.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseDescription rdf:type rdf:Property ;
    rdfs:label 'Root Cause Description' ;
    rdfs:comment 'Narrative description of the underlying cause that triggered the CAPA.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationMethod rdf:type rdf:Property ;
    rdfs:label 'Verification Method' ;
    rdfs:comment 'Method used to verify that the CAPA was effective.' ;
    rdfs:domain ind:ChemicalMfg ;
