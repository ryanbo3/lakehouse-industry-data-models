    rdfs:comment 'Indicates whether a rebate has been settled on this invoice.' ;
    rdfs:domain ind:IntercompanyBilling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receivingCompanyCode rdf:type rdf:Property ;
    rdfs:label 'Receiving Company Code' ;
    rdfs:comment 'Code of the legal entity that is receiving the goods or services.' ;
    rdfs:domain ind:IntercompanyBilling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryTransferPricingDoc rdf:type rdf:Property ;
    rdfs:label 'Regulatory Transfer Pricing Doc' ;
    rdfs:comment 'Reference to the supporting transfer pricing documentation required for regulatory compliance.' ;
    rdfs:domain ind:IntercompanyBilling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sendingCompanyCode rdf:type rdf:Property ;
    rdfs:label 'Sending Company Code' ;
    rdfs:comment 'Code of the legal entity that is sending the goods or services.' ;
    rdfs:domain ind:IntercompanyBilling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionStatus rdf:type rdf:Property ;
    rdfs:label 'Transaction Status' ;
    rdfs:comment 'Current lifecycle status of the intercompany invoice.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferPriceMethodology rdf:type rdf:Property ;
    rdfs:label 'Transfer Price Methodology' ;
    rdfs:comment 'Method used to determine the intercompany transfer price.' ;
    rdfs:domain ind:IntercompanyBilling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emissionSourceId rdf:type rdf:Property ;
    rdfs:label 'Emission Source Id' ;
    rdfs:comment 'Foreign key linking to ehs.emission_source. Business justification: Required: Monitoring services for specific emission sources are billed; the FK connects the invoice to the emission source being serviced.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EmissionSource .

ind:ipRecordId rdf:type rdf:Property ;
    rdfs:label 'Ip Record Id' ;
    rdfs:comment 'Foreign key linking to formulation.ip_record. Business justification: Royalty invoicing depends on the IP record that underlies the sold formulation; linking enables accurate royalty calculation.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IpRecord .

ind:manufacturingOrderId rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Order Id' ;
    rdfs:comment 'Foreign key linking to production.manufacturing_order. Business justification: Invoice generation is based on a specific manufacturing order; required for order-to-cash reporting and traceability of sold product.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ManufacturingOrder .

ind:operatingPermitId rdf:type rdf:Property ;
    rdfs:label 'Operating Permit Id' ;
    rdfs:comment 'Foreign key linking to ehs.operating_permit. Business justification: Required: Permit fees are invoiced; linking an invoice to the operating permit records the fee source and supports compliance reporting.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OperatingPermit .

ind:opportunityId rdf:type rdf:Property ;
    rdfs:label 'Opportunity Id' ;
    rdfs:comment 'Foreign key linking to sales.opportunity. Business justification: Needed for Opportunity-to-Invoice conversion metrics used in pipeline performance dashboards.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Opportunity .

ind:outboundDeliveryId rdf:type rdf:Property ;
    rdfs:label 'Outbound Delivery Id' ;
    rdfs:comment 'Identifier of the delivery/shipment associated with the invoice.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OutboundDelivery .

ind:priceListId rdf:type rdf:Property ;
    rdfs:label 'Price List Id' ;
    rdfs:comment 'Foreign key linking to pricing.price_list. Business justification: INVOICE generation uses the selected price list to calculate line prices; finance reports require linking each invoice to its price list.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceList .

ind:productOrderId rdf:type rdf:Property ;
    rdfs:label 'Product Order Id' ;
    rdfs:comment 'Identifier of the sales order that generated this invoice.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductOrder .

ind:productionPlanId rdf:type rdf:Property ;
    rdfs:label 'Production Plan Id' ;
    rdfs:comment 'Foreign key linking to planning.production_plan. Business justification: Required for linking each invoice to the specific production plan that generated the shipped product, enabling cost allocation, ASC 606 revenue recognition, and plant performance reporting.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductionPlan .

ind:purchaseOrderId rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Id' ;
    rdfs:comment 'Identifier of the purchase order from the customer, if applicable.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseOrder .

ind:quoteId rdf:type rdf:Property ;
    rdfs:label 'Quote Id' ;
    rdfs:comment 'Foreign key linking to sales.quote. Business justification: Required for Quote-to-Invoice conversion tracking report, essential for sales effectiveness and compliance.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Quote .

ind:vendorId rdf:type rdf:Property ;
    rdfs:label 'Vendor Id' ;
