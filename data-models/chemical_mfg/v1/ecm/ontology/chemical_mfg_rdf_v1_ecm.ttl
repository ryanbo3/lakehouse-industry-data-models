    rdfs:range xsd:boolean .

ind:studyNotes rdf:type rdf:Property ;
    rdfs:label 'Study Notes' ;
    rdfs:comment 'Free-form comments or observations captured by the analyst.' ;
    rdfs:domain ind:TransferPriceStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyStatus rdf:type rdf:Property ;
    rdfs:label 'Study Status' ;
    rdfs:comment 'Current lifecycle status of the study.' ;
    rdfs:domain ind:TransferPriceStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxYear rdf:type rdf:Property ;
    rdfs:label 'Tax Year' ;
    rdfs:comment 'Fiscal year to which the transfer pricing analysis applies.' ;
    rdfs:domain ind:TransferPriceStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transferPricingMethod rdf:type rdf:Property ;
    rdfs:label 'Transfer Pricing Method' ;
    rdfs:comment 'Methodology selected for the transfer pricing calculation.' ;
    rdfs:domain ind:TransferPriceStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeDiscountScheduleId rdf:type rdf:Property ;
    rdfs:label 'Volume Discount Schedule Id' ;
    rdfs:comment 'System-generated unique identifier for the volume discount schedule record.' ;
    rdfs:domain ind:VolumeDiscountSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:discountValue rdf:type rdf:Property ;
    rdfs:label 'Discount Value' ;
    rdfs:comment 'Numeric value of the discount as defined by discount_type.' ;
    rdfs:domain ind:VolumeDiscountSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isCumulative rdf:type rdf:Property ;
    rdfs:label 'Is Cumulative' ;
    rdfs:comment 'Indicates if discounts accumulate across multiple orders within the validity period.' ;
    rdfs:domain ind:VolumeDiscountSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduleCode rdf:type rdf:Property ;
    rdfs:label 'Schedule Code' ;
    rdfs:comment 'Business code used to reference the discount schedule in pricing and sales systems.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierQuantityBreak rdf:type rdf:Property ;
    rdfs:label 'Tier Quantity Break' ;
    rdfs:comment 'Minimum quantity required to qualify for this discount tier.' ;
    rdfs:domain ind:VolumeDiscountSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tierQuantityUnit rdf:type rdf:Property ;
    rdfs:label 'Tier Quantity Unit' ;
    rdfs:comment 'Unit of measure for the tier quantity breakpoint.' ;
    rdfs:domain ind:VolumeDiscountSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierSequence rdf:type rdf:Property ;
    rdfs:label 'Tier Sequence' ;
    rdfs:comment 'Ordinal position of the tier within the schedule.' ;
    rdfs:domain ind:VolumeDiscountSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:volumeDiscountScheduleDescription rdf:type rdf:Property ;
    rdfs:label 'Volume Discount Schedule Description' ;
    rdfs:comment 'Free-form text describing the purpose or special conditions of the schedule.' ;
    rdfs:domain ind:VolumeDiscountSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeDiscountScheduleStatus rdf:type rdf:Property ;
    rdfs:label 'Volume Discount Schedule Status' ;
    rdfs:comment 'Current lifecycle status of the discount schedule.' ;
    rdfs:domain ind:VolumeDiscountSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originatingProjectId rdf:type rdf:Property ;
    rdfs:label 'Originating Project Id' ;
    rdfs:comment 'Foreign key linking to research.project. Business justification: Required for Product Launch Traceability report linking each product to the R&D project that created it, enabling cost allocation and regulatory filing.' ;
    rdfs:domain ind:ChemicalProduct ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Project .

ind:primaryCompoundRegistryId rdf:type rdf:Property ;
    rdfs:label 'Primary Compound Registry Id' ;
    rdfs:comment 'Foreign key linking to research.compound_registry. Business justification: Needed for Regulatory Compliance Dashboard to map each product to its primary compound record for hazard classification and REACH reporting.' ;
    rdfs:domain ind:ChemicalProduct ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CompoundRegistry .

ind:productManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Product Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Required for Product Manager assignment; used in product stewardship reports and regulatory compliance tracking.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:standardAnalyticalMethodId rdf:type rdf:Property ;
    rdfs:label 'Standard Analytical Method Id' ;
    rdfs:comment 'Foreign key linking to research.analytical_method. Business justification: Critical for Quality Control Specification to reference the validated analytical method used for product release testing.' ;
    rdfs:domain ind:ChemicalProduct ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AnalyticalMethod .

ind:applicationGuidelines rdf:type rdf:Property ;
    rdfs:label 'Application Guidelines' ;
    rdfs:comment 'Recommended use cases and application instructions for the product. Describes target industries, processes, and best practices for product utilization.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Base Unit Of Measure' ;
    rdfs:comment 'Primary unit of measure for inventory, sales, and production transactions. KG: kilogram, L: liter, MT: metric ton, GAL: gallon, LB: pound, TON: short ton.' ;
    rdfs:domain ind:ChemicalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chemicalName rdf:type rdf:Property ;
    rdfs:label 'Chemical Name' ;
    rdfs:comment 'IUPAC systematic chemical name or common chemical name describing the molecular composition. Used for regulatory reporting and technical documentation.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:densityKgPerL rdf:type rdf:Property ;
    rdfs:label 'Density Kg Per L' ;
    rdfs:comment 'Product density in kilograms per liter at standard temperature and pressure. Used for volume-to-weight conversions in logistics and formulation calculations.' ;
    rdfs:domain ind:ChemicalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discontinuationDate rdf:type rdf:Property ;
    rdfs:label 'Discontinuation Date' ;
    rdfs:comment 'Date the product was or will be withdrawn from active sale. Null for active products. Used for end-of-life planning and inventory liquidation.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fdaApprovalRequired rdf:type rdf:Property ;
    rdfs:label 'Fda Approval Required' ;
    rdfs:comment 'Indicates whether the product requires FDA approval for food-contact, pharmaceutical, or cosmetic applications. True if FDA oversight applies.' ;
    rdfs:domain ind:ChemicalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ghsPictograms rdf:type rdf:Property ;
    rdfs:label 'Ghs Pictograms' ;
    rdfs:comment 'Comma-separated list of GHS pictogram codes required on product labels (e.g., GHS02 Flame, GHS07 Exclamation Mark). Communicates hazards visually per global standards.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hapContentPercent rdf:type rdf:Property ;
    rdfs:label 'Hap Content Percent' ;
    rdfs:comment 'Percentage of EPA-listed hazardous air pollutants by weight. Triggers additional reporting and control requirements under Clean Air Act regulations.' ;
    rdfs:domain ind:ChemicalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:introductionDate rdf:type rdf:Property ;
    rdfs:label 'Introduction Date' ;
    rdfs:comment 'Date the product was first made available for commercial sale. Used for product age analysis, lifecycle planning, and portfolio management.' ;
    rdfs:domain ind:ChemicalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lifecycleState rdf:type rdf:Property ;
    rdfs:label 'Lifecycle State' ;
    rdfs:comment 'Current stage in the product lifecycle. Active: available for sale. Discontinued: no longer manufactured but may have inventory. Developmental: in R&D phase. Phased Out: transitioning to discontinuation. Pending Approval: awaiting regulatory or internal approval. Obsolete: fully retired.' ;
    rdfs:domain ind:ChemicalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:listPriceUsd rdf:type rdf:Property ;
    rdfs:label 'List Price Usd' ;
    rdfs:comment 'Published list price per base unit in USD before discounts or negotiations. Starting point for customer pricing discussions. Confidential business data.' ;
    rdfs:domain ind:ChemicalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packagingConfiguration rdf:type rdf:Property ;
    rdfs:label 'Packaging Configuration' ;
    rdfs:comment 'Standard packaging options available for the product (e.g., 55-gallon drum, 1000L IBC tote, bulk tanker, 25kg bag). Affects pricing, logistics, and customer ordering.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:physicalForm rdf:type rdf:Property ;
    rdfs:label 'Physical Form' ;
    rdfs:comment 'Physical state of the product at standard temperature and pressure. Critical for storage requirements, handling procedures, and transportation classification. [ENUM-REF-CANDIDATE: liquid|solid|powder|granular|gas|paste|emulsion|suspension — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryChemicalSdsId rdf:type rdf:Property ;
    rdfs:label 'Primary Chemical Sds Id' ;
    rdfs:comment 'Unique identifier linking to the current SDS document in the document management system. SDS provides comprehensive safety, handling, and emergency information.' ;
    rdfs:domain ind:ChemicalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productType rdf:type rdf:Property ;
    rdfs:label 'Product Type' ;
    rdfs:comment 'Classification of product by commercial offering model. Bulk: high-volume commodity. Packaged: pre-packaged finished goods. Specialty: high-value low-volume. Custom Blend: customer-specific formulation. Intermediate: used in further manufacturing.' ;
    rdfs:domain ind:ChemicalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reachStatus rdf:type rdf:Property ;
    rdfs:label 'Reach Status' ;
    rdfs:comment 'Current REACH compliance status. Registered: full dossier submitted. Pre-registered: intent declared. Exempt: below tonnage threshold or exempted substance. Not Applicable: not sold in EU. Pending: registration in progress.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardCostUsd rdf:type rdf:Property ;
    rdfs:label 'Standard Cost Usd' ;
    rdfs:comment 'Standard manufacturing cost per base unit in USD. Used for inventory valuation, margin analysis, and financial reporting. Confidential business data.' ;
    rdfs:domain ind:ChemicalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tscaStatus rdf:type rdf:Property ;
    rdfs:label 'Tsca Status' ;
    rdfs:comment 'EPA TSCA inventory status for US market. Active: on inventory and commercially used. Inactive: on inventory but not currently manufactured. Exempt: polymer or other exemption. Not On Inventory: requires PMN before manufacture.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:viscosityCps rdf:type rdf:Property ;
    rdfs:label 'Viscosity Cps' ;
    rdfs:comment 'Dynamic viscosity measured in centipoise at standard temperature. Affects pumping requirements, mixing behavior, and application characteristics.' ;
    rdfs:domain ind:ChemicalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vocContentPercent rdf:type rdf:Property ;
    rdfs:label 'Voc Content Percent' ;
    rdfs:comment 'Percentage of volatile organic compounds by weight. Subject to EPA and state air quality regulations. Critical for environmental compliance and emissions reporting.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exposureScenarioId rdf:type rdf:Property ;
    rdfs:label 'Exposure Scenario Id' ;
    rdfs:comment 'System-generated unique identifier for the exposure scenario record.' ;
    rdfs:domain ind:ExposureScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:amountUsedKg rdf:type rdf:Property ;
    rdfs:label 'Amount Used Kg' ;
    rdfs:comment 'Quantity of the chemical used in the scenario, expressed in kilograms.' ;
    rdfs:domain ind:ExposureScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:articleCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Article Category Code' ;
    rdfs:comment 'Code for the article form (e.g., solid, liquid) of the chemical in the scenario.' ;
    rdfs:domain ind:ExposureScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contributingScenarioName rdf:type rdf:Property ;
    rdfs:label 'Contributing Scenario Name' ;
    rdfs:comment 'Name of any parent or related scenario that contributes to this exposure scenario.' ;
    rdfs:domain ind:ExposureScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dnelUnit rdf:type rdf:Property ;
    rdfs:label 'Dnel Unit' ;
    rdfs:comment 'Unit of measurement for the DNEL (e.g., mg/m³).' ;
    rdfs:domain ind:ExposureScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dnelValue rdf:type rdf:Property ;
    rdfs:label 'Dnel Value' ;
    rdfs:comment 'Quantitative DNEL value derived for the scenario.' ;
    rdfs:domain ind:ExposureScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalReleaseCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Environmental Release Category Code' ;
    rdfs:comment 'Code indicating the type of environmental release considered in the scenario.' ;
    rdfs:domain ind:ExposureScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationalDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Operational Duration Minutes' ;
    rdfs:comment 'Length of time the exposure condition is applied, measured in minutes.' ;
    rdfs:domain ind:ExposureScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operationalFrequencyPerDay rdf:type rdf:Property ;
    rdfs:label 'Operational Frequency Per Day' ;
    rdfs:comment 'Number of times the exposure condition occurs each day.' ;
    rdfs:domain ind:ExposureScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operationalTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Operational Temperature C' ;
    rdfs:comment 'Temperature at which the chemical is used or processed, expressed in degrees Celsius.' ;
    rdfs:domain ind:ExposureScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pnecUnit rdf:type rdf:Property ;
    rdfs:label 'Pnec Unit' ;
    rdfs:comment 'Unit of measurement for the PNEC (e.g., µg/L).' ;
    rdfs:domain ind:ExposureScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pnecValue rdf:type rdf:Property ;
    rdfs:label 'Pnec Value' ;
    rdfs:comment 'PNEC value used for environmental risk assessment.' ;
    rdfs:domain ind:ExposureScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Process Category Code' ;
    rdfs:comment 'Code describing the manufacturing or usage process category for the scenario.' ;
    rdfs:domain ind:ExposureScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rcrValue rdf:type rdf:Property ;
    rdfs:label 'Rcr Value' ;
    rdfs:comment 'Ratio of exposure to the DNEL/PNEC, indicating risk level.' ;
    rdfs:domain ind:ExposureScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:riskManagementMeasureContainment rdf:type rdf:Property ;
    rdfs:label 'Risk Management Measure Containment' ;
    rdfs:comment 'Physical containment measures (e.g., fume hood) needed for the scenario.' ;
    rdfs:domain ind:ExposureScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskManagementMeasurePpe rdf:type rdf:Property ;
    rdfs:label 'Risk Management Measure Ppe' ;
    rdfs:comment 'Description of required PPE for safe handling under this scenario.' ;
    rdfs:domain ind:ExposureScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskManagementMeasureVentilation rdf:type rdf:Property ;
    rdfs:label 'Risk Management Measure Ventilation' ;
    rdfs:comment 'Ventilation controls required to mitigate exposure.' ;
    rdfs:domain ind:ExposureScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scenarioCode rdf:type rdf:Property ;
    rdfs:label 'Scenario Code' ;
    rdfs:comment 'Business code used to reference the scenario in regulatory documents and internal systems.' ;
    rdfs:domain ind:ExposureScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scenarioEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Scenario Effective Date' ;
    rdfs:comment 'Date from which the scenario is considered valid.' ;
    rdfs:domain ind:ExposureScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scenarioExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Scenario Expiry Date' ;
    rdfs:comment 'Date after which the scenario is no longer valid.' ;
    rdfs:domain ind:ExposureScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scenarioStatus rdf:type rdf:Property ;
    rdfs:label 'Scenario Status' ;
    rdfs:comment 'Current lifecycle status of the scenario.' ;
    rdfs:domain ind:ExposureScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sectorOfUseCode rdf:type rdf:Property ;
    rdfs:label 'Sector Of Use Code' ;
    rdfs:comment 'Code representing the industrial sector where the chemical is used (REACH SU classification).' ;
    rdfs:domain ind:ExposureScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productGhsClassificationId rdf:type rdf:Property ;
    rdfs:label 'Product Ghs Classification Id' ;
    rdfs:comment 'Unique identifier for the GHS classification record.' ;
    rdfs:domain ind:ProductGhsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supersededByClassificationProductGhsClassificationId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Classification Product Ghs Classification Id' ;
    rdfs:comment 'Reference to the newer GHS classification record that supersedes this one, enabling classification version history tracking.' ;
    rdfs:domain ind:ProductGhsClassification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductGhsClassification .

ind:classificationAuthority rdf:type rdf:Property ;
    rdfs:label 'Classification Authority' ;
    rdfs:comment 'Entity responsible for the classification: self-classification by manufacturer, ECHA harmonized classification, competent authority, or third-party assessor.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classificationBasis rdf:type rdf:Property ;
    rdfs:label 'Classification Basis' ;
    rdfs:comment 'Methodology or data source used to determine the classification: experimental test data, read-across from analogous substances, QSAR (Quantitative Structure-Activity Relationship) modeling, expert judgment, literature review, or bridging principles.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classificationDate rdf:type rdf:Property ;
    rdfs:label 'Classification Date' ;
    rdfs:comment 'Date when the GHS classification was performed or last updated.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:classificationNotes rdf:type rdf:Property ;
    rdfs:label 'Classification Notes' ;
    rdfs:comment 'Free-text notes providing additional context, rationale, or special considerations for the classification decision.' ;
    rdfs:domain ind:ProductGhsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classificationStatus rdf:type rdf:Property ;
    rdfs:label 'Classification Status' ;
    rdfs:comment 'Current lifecycle status of the GHS classification record.' ;
    rdfs:domain ind:ProductGhsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classificationVersion rdf:type rdf:Property ;
    rdfs:label 'Classification Version' ;
    rdfs:comment 'Version number of the GHS classification (e.g., GHS Rev 7, GHS Rev 8) indicating which revision of the Globally Harmonized System was applied.' ;
    rdfs:domain ind:ProductGhsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classifierName rdf:type rdf:Property ;
    rdfs:label 'Classifier Name' ;
    rdfs:comment 'Name of the individual or team responsible for performing the GHS classification.' ;
    rdfs:domain ind:ProductGhsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clpNotificationNumber rdf:type rdf:Property ;
    rdfs:label 'Clp Notification Number' ;
    rdfs:comment 'Notification number assigned by ECHA for substances notified under the CLP Regulation.' ;
    rdfs:domain ind:ProductGhsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cmrClassification rdf:type rdf:Property ;
    rdfs:label 'Cmr Classification' ;
    rdfs:comment 'Specific CMR classification categories if applicable (e.g., Carc. 1A, Muta. 1B, Repr. 2), indicating carcinogenic, mutagenic, or reproductive toxicity hazards.' ;
    rdfs:domain ind:ProductGhsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ecNumber rdf:type rdf:Property ;
    rdfs:label 'Ec Number' ;
    rdfs:comment 'European Community number (EINECS, ELINCS, or NLP number) identifying the substance in the EU.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveUntilDate rdf:type rdf:Property ;
    rdfs:label 'Effective Until Date' ;
    rdfs:comment 'Date until which this GHS classification remains valid; nullable for current active classifications.' ;
    rdfs:domain ind:ProductGhsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:environmentalHazardCategories rdf:type rdf:Property ;
    rdfs:label 'Environmental Hazard Categories' ;
    rdfs:comment 'Comma-separated list of environmental hazard categories corresponding to the classes (e.g., Acute 1, Chronic 2, Chronic 3).' ;
    rdfs:domain ind:ProductGhsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalHazardClasses rdf:type rdf:Property ;
    rdfs:label 'Environmental Hazard Classes' ;
    rdfs:comment 'Comma-separated list of environmental hazard classes assigned (e.g., Hazardous to the Aquatic Environment, Hazardous to the Ozone Layer).' ;
    rdfs:domain ind:ProductGhsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardStatementCodes rdf:type rdf:Property ;
    rdfs:label 'Hazard Statement Codes' ;
    rdfs:comment 'Comma-separated list of GHS hazard statement codes (e.g., H225, H302, H315, H319, H411) describing the nature and severity of hazards.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:healthHazardCategories rdf:type rdf:Property ;
    rdfs:label 'Health Hazard Categories' ;
    rdfs:comment 'Comma-separated list of health hazard categories corresponding to the classes (e.g., Category 1, Category 2, Category 1A, Category 1B).' ;
    rdfs:domain ind:ProductGhsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:healthHazardClasses rdf:type rdf:Property ;
    rdfs:label 'Health Hazard Classes' ;
    rdfs:comment 'Comma-separated list of health hazard classes assigned (e.g., Acute Toxicity, Skin Corrosion, Carcinogenicity, Reproductive Toxicity, Respiratory Sensitization).' ;
    rdfs:domain ind:ProductGhsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelGenerationRequired rdf:type rdf:Property ;
    rdfs:label 'Label Generation Required' ;
    rdfs:comment 'Boolean flag indicating whether a GHS-compliant label must be generated for this classification.' ;
    rdfs:domain ind:ProductGhsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:physicalHazardCategories rdf:type rdf:Property ;
    rdfs:label 'Physical Hazard Categories' ;
    rdfs:comment 'Comma-separated list of physical hazard categories corresponding to the classes (e.g., Category 2, Category 1A, Category 3).' ;
    rdfs:domain ind:ProductGhsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:physicalHazardClasses rdf:type rdf:Property ;
    rdfs:label 'Physical Hazard Classes' ;
    rdfs:comment 'Comma-separated list of physical hazard classes assigned (e.g., Flammable Liquids, Explosives, Oxidizing Liquids, Corrosive to Metals).' ;
    rdfs:domain ind:ProductGhsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pictogramCodes rdf:type rdf:Property ;
    rdfs:label 'Pictogram Codes' ;
    rdfs:comment 'Comma-separated list of GHS pictogram codes (e.g., GHS01, GHS02, GHS05, GHS07, GHS09) representing the hazard symbols required on labels.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:precautionaryStatementCodes rdf:type rdf:Property ;
    rdfs:label 'Precautionary Statement Codes' ;
    rdfs:comment 'Comma-separated list of GHS precautionary statement codes (e.g., P210, P280, P301+P312, P501) describing recommended measures to minimize or prevent adverse effects.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewerName rdf:type rdf:Property ;
    rdfs:label 'Reviewer Name' ;
    rdfs:comment 'Name of the individual or team who reviewed and approved the GHS classification.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tscaInventoryStatus rdf:type rdf:Property ;
    rdfs:label 'Tsca Inventory Status' ;
    rdfs:comment 'Status of the substance on the TSCA Chemical Substance Inventory: active (commercial use), inactive (no current commercial use), or not listed.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Capacity Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the nominal capacity. Common units include L (liters), GAL (gallons), M3 (cubic meters), KG (kilograms), LB (pounds).' ;
    rdfs:domain ind:PackagingConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureType rdf:type rdf:Property ;
    rdfs:label 'Closure Type' ;
    rdfs:comment 'Type of closure or sealing mechanism used on the packaging container (e.g., screw cap, bung, valve, crimp seal, tamper-evident seal).' ;
    rdfs:domain ind:PackagingConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSpecificFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Specific Flag' ;
    rdfs:comment 'Indicates whether this packaging configuration is designed for a specific customer or customer segment with unique packaging requirements.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fillVolumeLiters rdf:type rdf:Property ;
    rdfs:label 'Fill Volume Liters' ;
    rdfs:comment 'Maximum fill volume of the chemical product in liters that can be loaded into this packaging configuration.' ;
    rdfs:domain ind:PackagingConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fillWeightKg rdf:type rdf:Property ;
    rdfs:label 'Fill Weight Kg' ;
    rdfs:comment 'Maximum fill weight of the chemical product in kilograms that can be loaded into this packaging configuration.' ;
    rdfs:domain ind:PackagingConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:foodGradeCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Food Grade Certified Flag' ;
    rdfs:comment 'Indicates whether this packaging configuration is certified for food-contact chemicals and meets FDA (Food and Drug Administration) food-grade requirements.' ;
    rdfs:domain ind:PackagingConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazmatCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Certified Flag' ;
    rdfs:comment 'Indicates whether this packaging configuration is certified for transporting hazardous materials under DOT, IATA, and IMDG regulations.' ;
    rdfs:domain ind:PackagingConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:heightMm rdf:type rdf:Property ;
    rdfs:label 'Height Mm' ;
    rdfs:comment 'Height of the packaging container in millimeters. Used for warehouse slotting, stacking calculations, and transportation planning.' ;
    rdfs:domain ind:PackagingConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:iataLabelRequired rdf:type rdf:Property ;
    rdfs:label 'Iata Label Required' ;
    rdfs:comment 'Indicates whether IATA dangerous goods air transport labels are required on this packaging configuration.' ;
    rdfs:domain ind:PackagingConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:imdgLabelRequired rdf:type rdf:Property ;
    rdfs:label 'Imdg Label Required' ;
    rdfs:comment 'Indicates whether IMDG Code maritime transport labels are required on this packaging configuration.' ;
    rdfs:domain ind:PackagingConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lengthMm rdf:type rdf:Property ;
    rdfs:label 'Length Mm' ;
    rdfs:comment 'Length of rectangular packaging (IBCs, totes, boxes) in millimeters. Used for warehouse slotting and transportation planning.' ;
    rdfs:domain ind:PackagingConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:materialOfConstruction rdf:type rdf:Property ;
    rdfs:label 'Material Of Construction' ;
    rdfs:comment 'Material used to construct the packaging container. Options include HDPE (High-Density Polyethylene), steel, stainless steel, fiber, aluminum, and lined containers.' ;
    rdfs:domain ind:PackagingConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nominalCapacity rdf:type rdf:Property ;
    rdfs:label 'Nominal Capacity' ;
    rdfs:comment 'Nominal or rated capacity of the packaging container, expressed in the unit specified by capacity_unit_of_measure.' ;
    rdfs:domain ind:PackagingConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outerDiameterMm rdf:type rdf:Property ;
    rdfs:label 'Outer Diameter Mm' ;
    rdfs:comment 'Outer diameter of cylindrical packaging (drums, cylinders, pails) in millimeters. Used for warehouse slotting and space planning.' ;
    rdfs:domain ind:PackagingConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packagingCode rdf:type rdf:Property ;
    rdfs:label 'Packaging Code' ;
    rdfs:comment 'Unique business identifier for the packaging configuration, used in SAP EWM (Extended Warehouse Management) and order fulfillment systems.' ;
    rdfs:domain ind:PackagingConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingConfigStatus rdf:type rdf:Property ;
    rdfs:label 'Packaging Config Status' ;
    rdfs:comment 'Current lifecycle status of the packaging configuration. Active configurations are available for order fulfillment; inactive/obsolete are phased out; pending approval are under review; restricted require special authorization.' ;
    rdfs:domain ind:PackagingConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingGroup rdf:type rdf:Property ;
    rdfs:label 'Packaging Group' ;
    rdfs:comment 'UN Packaging Group classification indicating the degree of danger: I (high danger), II (medium danger), III (low danger). Determines packaging performance requirements.' ;
    rdfs:domain ind:PackagingConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:palletType rdf:type rdf:Property ;
    rdfs:label 'Pallet Type' ;
    rdfs:comment 'Type of pallet used for this packaging configuration (e.g., EUR pallet, standard 48x40, block pallet, chemical-resistant pallet).' ;
    rdfs:domain ind:PackagingConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pharmaceuticalGradeFlag rdf:type rdf:Property ;
    rdfs:label 'Pharmaceutical Grade Flag' ;
    rdfs:comment 'Indicates whether this packaging configuration meets pharmaceutical-grade standards for API (Active Pharmaceutical Ingredient) and pharmaceutical chemical packaging.' ;
    rdfs:domain ind:PackagingConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferredFlag rdf:type rdf:Property ;
    rdfs:label 'Preferred Flag' ;
    rdfs:comment 'Indicates whether this is the preferred or default packaging configuration for the associated product SKU (Stock Keeping Unit).' ;
    rdfs:domain ind:PackagingConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regionRestriction rdf:type rdf:Property ;
    rdfs:label 'Region Restriction' ;
    rdfs:comment 'Geographic regions where this packaging configuration is approved or restricted for use, based on local regulatory requirements (e.g., USA, CAN, MEX, EUR, CHN). Pipe-separated list of ISO 3166-1 alpha-3 country codes.' ;
    rdfs:domain ind:PackagingConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnableFlag rdf:type rdf:Property ;
    rdfs:label 'Returnable Flag' ;
    rdfs:comment 'Indicates whether this packaging configuration is returnable (e.g., returnable drums, IBCs, cylinders) requiring deposit tracking and reverse logistics.' ;
    rdfs:domain ind:PackagingConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stackHeightMax rdf:type rdf:Property ;
    rdfs:label 'Stack Height Max' ;
    rdfs:comment 'Maximum number of pallet layers that can be safely stacked vertically in warehouse storage, considering packaging strength and product stability.' ;
    rdfs:domain ind:PackagingConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unPackagingCode rdf:type rdf:Property ;
    rdfs:label 'Un Packaging Code' ;
    rdfs:comment 'United Nations packaging certification code indicating the packaging meets UN performance standards for hazardous materials transport. Examples: 4G (fiberboard box), 1A1 (steel drum), 1H1 (plastic drum), 31HA1 (IBC composite).' ;
    rdfs:domain ind:PackagingConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitsPerPallet rdf:type rdf:Property ;
    rdfs:label 'Units Per Pallet' ;
    rdfs:comment 'Number of packaging units (drums, IBCs, bags, etc.) that can be loaded on a single pallet for warehouse storage and transportation.' ;
    rdfs:domain ind:PackagingConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:widthMm rdf:type rdf:Property ;
    rdfs:label 'Width Mm' ;
    rdfs:comment 'Width of rectangular packaging (IBCs, totes, boxes) in millimeters. Used for warehouse slotting and transportation planning.' ;
    rdfs:domain ind:PackagingConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificationId rdf:type rdf:Property ;
    rdfs:label 'Certification Id' ;
    rdfs:comment 'Unique identifier for the product certification record.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditDate rdf:type rdf:Property ;
    rdfs:label 'Audit Date' ;
    rdfs:comment 'Date of the most recent audit related to the certification.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificateNumber rdf:type rdf:Property ;
    rdfs:label 'Certificate Number' ;
    rdfs:comment 'Unique number assigned by the certifying body.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationStatus rdf:type rdf:Property ;
    rdfs:label 'Certification Status' ;
    rdfs:comment 'Current status of the certification.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationType rdf:type rdf:Property ;
    rdfs:label 'Certification Type' ;
    rdfs:comment 'Type of certification held by the product.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifyingBody rdf:type rdf:Property ;
    rdfs:label 'Certifying Body' ;
    rdfs:comment 'Organization that issued the certification.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issueDate rdf:type rdf:Property ;
    rdfs:label 'Issue Date' ;
    rdfs:comment 'Date when the certification was issued.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalIntervalMonths rdf:type rdf:Property ;
    rdfs:label 'Renewal Interval Months' ;
    rdfs:comment 'Number of months between required renewals.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewalRequired rdf:type rdf:Property ;
    rdfs:label 'Renewal Required' ;
    rdfs:comment 'Indicates whether the certification requires renewal.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scopeOfCertification rdf:type rdf:Property ;
    rdfs:label 'Scope Of Certification' ;
    rdfs:comment 'Description of the product scope covered by the certification.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compositionId rdf:type rdf:Property ;
    rdfs:label 'Composition Id' ;
    rdfs:comment 'Unique identifier for the product composition record.' ;
    rdfs:domain ind:Composition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:componentApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Component Approval Date' ;
    rdfs:comment 'Date when the component received regulatory approval.' ;
    rdfs:domain ind:Composition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:componentConcentrationRangeFlag rdf:type rdf:Property ;
    rdfs:label 'Component Concentration Range Flag' ;
    rdfs:comment 'Indicates whether the concentration is expressed as a range.' ;
    rdfs:domain ind:Composition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:componentConcentrationUnit rdf:type rdf:Property ;
    rdfs:label 'Component Concentration Unit' ;
    rdfs:comment 'Unit of measurement for the component concentration.' ;
    rdfs:domain ind:Composition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentConcentrationValue rdf:type rdf:Property ;
    rdfs:label 'Component Concentration Value' ;
    rdfs:comment 'Numeric concentration of the component.' ;
    rdfs:domain ind:Composition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:componentEcNumber rdf:type rdf:Property ;
    rdfs:label 'Component Ec Number' ;
    rdfs:comment 'EC number identifying the component within European regulatory lists.' ;
    rdfs:domain ind:Composition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Component Expiration Date' ;
    rdfs:comment 'Date after which the component is considered expired.' ;
    rdfs:domain ind:Composition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:componentFunction rdf:type rdf:Property ;
    rdfs:label 'Component Function' ;
    rdfs:comment 'Role of the component within the product formulation.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentHazardClass rdf:type rdf:Property ;
    rdfs:label 'Component Hazard Class' ;
    rdfs:comment 'Globally Harmonized System hazard class applicable to the component.' ;
    rdfs:domain ind:Composition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentHazardStatement rdf:type rdf:Property ;
    rdfs:label 'Component Hazard Statement' ;
    rdfs:comment 'Standard hazard statement describing the risks of the component.' ;
    rdfs:domain ind:Composition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentIupacName rdf:type rdf:Property ;
    rdfs:label 'Component Iupac Name' ;
    rdfs:comment 'Systematic IUPAC name of the component.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentLotNumber rdf:type rdf:Property ;
    rdfs:label 'Component Lot Number' ;
    rdfs:comment 'Lot or batch number assigned to the component by the supplier.' ;
    rdfs:domain ind:Composition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentPhysicalState rdf:type rdf:Property ;
    rdfs:label 'Component Physical State' ;
    rdfs:comment 'Physical state of the component at room temperature.' ;
    rdfs:domain ind:Composition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentPrecautionaryStatement rdf:type rdf:Property ;
    rdfs:label 'Component Precautionary Statement' ;
    rdfs:comment 'Standard precautionary statement for safe handling of the component.' ;
    rdfs:domain ind:Composition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentPurity rdf:type rdf:Property ;
    rdfs:label 'Component Purity' ;
    rdfs:comment 'Purity of the component expressed as a percentage.' ;
    rdfs:domain ind:Composition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:componentPurityUnit rdf:type rdf:Property ;
    rdfs:label 'Component Purity Unit' ;
    rdfs:comment 'Unit for the component purity value.' ;
    rdfs:domain ind:Composition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentQuantityUnit rdf:type rdf:Property ;
    rdfs:label 'Component Quantity Unit' ;
    rdfs:comment 'Unit of measurement for the component quantity.' ;
    rdfs:domain ind:Composition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentRegulatoryNumber rdf:type rdf:Property ;
    rdfs:label 'Component Regulatory Number' ;
    rdfs:comment 'Regulatory registration or listing number for the component.' ;
    rdfs:domain ind:Composition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentRegulatoryStatus rdf:type rdf:Property ;
    rdfs:label 'Component Regulatory Status' ;
    rdfs:comment 'Regulatory status of the component under applicable chemical regulations.' ;
    rdfs:domain ind:Composition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentTradeName rdf:type rdf:Property ;
    rdfs:label 'Component Trade Name' ;
    rdfs:comment 'Commercial trade name used for the component.' ;
    rdfs:domain ind:Composition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compositionStatus rdf:type rdf:Property ;
    rdfs:label 'Composition Status' ;
    rdfs:comment 'Current lifecycle status of the composition record.' ;
    rdfs:domain ind:Composition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityFlag rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Flag' ;
    rdfs:comment 'Indicates whether the component information is protected as confidential business information.' ;
    rdfs:domain ind:Composition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disclosureThreshold rdf:type rdf:Property ;
    rdfs:label 'Disclosure Threshold' ;
    rdfs:comment 'Regulatory threshold that triggers mandatory disclosure of the component.' ;
    rdfs:domain ind:Composition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossReferenceId rdf:type rdf:Property ;
    rdfs:label 'Cross Reference Id' ;
    rdfs:comment 'System-generated unique identifier for each product cross-reference record.' ;
    rdfs:domain ind:CrossReference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryCrossChemicalProductId rdf:type rdf:Property ;
    rdfs:label 'Primary Cross Chemical Product Id' ;
    rdfs:comment 'Identifier of the primary chemical product for which the cross-reference is defined.' ;
    rdfs:domain ind:CrossReference ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ChemicalProduct .

ind:crossReferenceStatus rdf:type rdf:Property ;
    rdfs:label 'Cross Reference Status' ;
    rdfs:comment 'Current lifecycle status of the cross-reference record.' ;
    rdfs:domain ind:CrossReference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerApprovalRequired rdf:type rdf:Property ;
    rdfs:label 'Customer Approval Required' ;
    rdfs:comment 'True if the customer must approve the substitution before execution.' ;
    rdfs:domain ind:CrossReference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Required' ;
    rdfs:comment 'Indicates whether the customer must be notified when this substitution is applied.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:equivalenceType rdf:type rdf:Property ;
    rdfs:label 'Equivalence Type' ;
    rdfs:comment 'Degree of similarity between the primary product and the referenced product.' ;
    rdfs:domain ind:CrossReference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityHoldSubstitutionAllowed rdf:type rdf:Property ;
    rdfs:label 'Quality Hold Substitution Allowed' ;
    rdfs:comment 'True if substitution is permitted when the primary product is on a quality hold.' ;
    rdfs:domain ind:CrossReference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:referenceOwner rdf:type rdf:Property ;
    rdfs:label 'Reference Owner' ;
    rdfs:comment 'Business unit or team that owns and maintains the cross-reference record.' ;
    rdfs:domain ind:CrossReference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceType rdf:type rdf:Property ;
    rdfs:label 'Reference Type' ;
    rdfs:comment 'Category describing the origin or nature of the reference (e.g., internal, competitor, legacy).' ;
    rdfs:domain ind:CrossReference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockOutSubstitutionAllowed rdf:type rdf:Property ;
    rdfs:label 'Stock Out Substitution Allowed' ;
    rdfs:comment 'True if substitution may be used automatically when primary product is out of stock.' ;
    rdfs:domain ind:CrossReference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:substitutionCondition rdf:type rdf:Property ;
    rdfs:label 'Substitution Condition' ;
    rdfs:comment 'Free-text description of conditions under which the substitution may be applied (e.g., stock-out, quality hold).' ;
    rdfs:domain ind:CrossReference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substitutionDirection rdf:type rdf:Property ;
    rdfs:label 'Substitution Direction' ;
    rdfs:comment 'Indicates whether the substitution relationship works both ways or only from primary to referenced product.' ;
    rdfs:domain ind:CrossReference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substitutionType rdf:type rdf:Property ;
    rdfs:label 'Substitution Type' ;
    rdfs:comment 'Classification of substitution based on business policy (direct, conditional, or emergency).' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gradeId rdf:type rdf:Property ;
    rdfs:label 'Grade Id' ;
    rdfs:comment 'Unique identifier for the product grade record. Primary key.' ;
    rdfs:domain ind:Grade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualityManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quality Manager Employee Id' ;
    rdfs:comment 'FK to workforce.employee' ;
    rdfs:domain ind:Grade ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tdsId rdf:type rdf:Property ;
    rdfs:label 'Tds Id' ;
    rdfs:comment 'Reference identifier linking to the technical data sheet document containing detailed specifications, properties, and application guidelines for this grade.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Tds .

ind:acsReagentFlag rdf:type rdf:Property ;
    rdfs:label 'Acs Reagent Flag' ;
    rdfs:comment 'Indicates whether this grade meets American Chemical Society (ACS) reagent specifications for laboratory and analytical use.' ;
    rdfs:domain ind:Grade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:applicationSector rdf:type rdf:Property ;
    rdfs:label 'Application Sector' ;
    rdfs:comment 'Primary industry sector or application area for which this grade is intended (e.g., pharmaceutical, food and beverage, electronics, agriculture, industrial manufacturing). [ENUM-REF-CANDIDATE: pharmaceutical|food_beverage|electronics|agriculture|industrial|research_laboratory|cosmetics|automotive|construction — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Grade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:basePricePerKg rdf:type rdf:Property ;
    rdfs:label 'Base Price Per Kg' ;
    rdfs:comment 'Standard base price per kilogram for this grade in the default currency, used as a reference for pricing agreements and quotations. Subject to volume discounts and contract terms.' ;
    rdfs:domain ind:Grade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificateOfAnalysisRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Analysis Required Flag' ;
    rdfs:comment 'Indicates whether a Certificate of Analysis (COA) must be issued with each lot or shipment of this grade, typically required for pharmaceutical, food, and high-purity grades.' ;
    rdfs:domain ind:Grade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificateOfComplianceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Compliance Required Flag' ;
    rdfs:comment 'Indicates whether a Certificate of Compliance (COC) must be issued with shipments of this grade, certifying conformance to regulatory and customer specifications.' ;
    rdfs:domain ind:Grade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:epGradeFlag rdf:type rdf:Property ;
    rdfs:label 'Ep Grade Flag' ;
    rdfs:comment 'Indicates whether this grade meets European Pharmacopoeia (EP) monograph standards for pharmaceutical use in European markets.' ;
    rdfs:domain ind:Grade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fccGradeFlag rdf:type rdf:Property ;
    rdfs:label 'Fcc Grade Flag' ;
    rdfs:comment 'Indicates whether this grade meets Food Chemicals Codex (FCC) standards for food-contact and food-additive applications.' ;
    rdfs:domain ind:Grade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gmpCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Gmp Compliant Flag' ;
    rdfs:comment 'Indicates whether this grade is manufactured under Good Manufacturing Practice (GMP) standards, required for pharmaceutical and food-contact applications.' ;
    rdfs:domain ind:Grade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gradeCode rdf:type rdf:Property ;
    rdfs:label 'Grade Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the grade within the product catalog (e.g., TG, RG, FG, PG, EG, AG for Technical, Reagent, Food, Pharmaceutical, Electronic, Agricultural grades).' ;
    rdfs:domain ind:Grade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gradeDescription rdf:type rdf:Property ;
    rdfs:label 'Grade Description' ;
    rdfs:comment 'Detailed description of the grade, including its intended use, distinguishing characteristics, and typical applications.' ;
    rdfs:domain ind:Grade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gradeName rdf:type rdf:Property ;
    rdfs:label 'Grade Name' ;
    rdfs:comment 'Full descriptive name of the grade (e.g., Technical Grade, Reagent Grade, Food Grade, Pharmaceutical Grade, Electronic Grade, Agricultural Grade).' ;
    rdfs:domain ind:Grade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gradeStatus rdf:type rdf:Property ;
    rdfs:label 'Grade Status' ;
    rdfs:comment 'Current lifecycle status of the product grade in the catalog. Determines availability for sales and production.' ;
    rdfs:domain ind:Grade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handlingRequirements rdf:type rdf:Property ;
    rdfs:label 'Handling Requirements' ;
    rdfs:comment 'Special handling, storage, and safety requirements specific to this grade (e.g., temperature control, moisture sensitivity, inert atmosphere, light protection). References Safety Data Sheet (SDS) and Process Safety Management (PSM) protocols.' ;
    rdfs:domain ind:Grade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intendedUseDescription rdf:type rdf:Property ;
    rdfs:label 'Intended Use Description' ;
    rdfs:comment 'Detailed description of the intended applications and use cases for this grade, including typical customer processes and end-product integration.' ;
    rdfs:domain ind:Grade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumImpurityPpm rdf:type rdf:Property ;
    rdfs:label 'Maximum Impurity Ppm' ;
    rdfs:comment 'Maximum allowable impurity concentration in parts per million (PPM) for this grade. Used in quality specifications and Certificate of Analysis (COA).' ;
    rdfs:domain ind:Grade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumOrderQuantityKg rdf:type rdf:Property ;
    rdfs:label 'Minimum Order Quantity Kg' ;
    rdfs:comment 'Minimum Order Quantity (MOQ) in kilograms for this grade, driven by production batch economics and packaging constraints.' ;
    rdfs:domain ind:Grade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumPurityPercentage rdf:type rdf:Property ;
    rdfs:label 'Minimum Purity Percentage' ;
    rdfs:comment 'Minimum chemical purity level required for this grade, expressed as a percentage (e.g., 99.50 for 99.5% purity). Critical for Quality Control (QC) and Certificate of Analysis (COA) compliance.' ;
    rdfs:domain ind:Grade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reachRegisteredFlag rdf:type rdf:Property ;
    rdfs:label 'Reach Registered Flag' ;
    rdfs:comment 'Indicates whether this grade is registered under the European REACH (Registration, Evaluation, Authorization and Restriction of Chemicals) regulation for sale in the EU.' ;
    rdfs:domain ind:Grade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tscaListedFlag rdf:type rdf:Property ;
    rdfs:label 'Tsca Listed Flag' ;
    rdfs:comment 'Indicates whether this grade is listed on the EPA TSCA (Toxic Substances Control Act) inventory for commercial use in the United States.' ;
    rdfs:domain ind:Grade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:uspGradeFlag rdf:type rdf:Property ;
    rdfs:label 'Usp Grade Flag' ;
    rdfs:comment 'Indicates whether this grade meets United States Pharmacopeia (USP) monograph standards for pharmaceutical use.' ;
    rdfs:domain ind:Grade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hierarchyId rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Id' ;
    rdfs:comment 'Unique identifier for the product hierarchy node. Primary key for the product hierarchy entity.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Hierarchy .

ind:parentNodeHierarchyId rdf:type rdf:Property ;
    rdfs:label 'Parent Node Hierarchy Id' ;
    rdfs:comment 'Reference to the parent node in the hierarchy structure. Null for top-level division nodes. Enables recursive hierarchy traversal and roll-up aggregations for EBITDA reporting and sales analytics.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Hierarchy .

ind:applicationCategory rdf:type rdf:Property ;
    rdfs:label 'Application Category' ;
    rdfs:comment 'Primary end-use application or industry segment for products in this node. Examples: Automotive Coatings, Construction Materials, Electronics Manufacturing, Consumer Goods, Agriculture Crop Protection. Supports market segmentation and application-based analytics.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessUnitCode rdf:type rdf:Property ;
    rdfs:label 'Business Unit Code' ;
    rdfs:comment 'Code identifying the business unit responsible for this product hierarchy node. Used for P&L reporting, EBITDA analysis by business unit, and organizational accountability.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:divisionCode rdf:type rdf:Property ;
    rdfs:label 'Division Code' ;
    rdfs:comment 'Code identifying the top-level division. Examples: PERF (Performance Materials), AGRI (Agricultural Solutions), SPEC (Specialty Chemicals). Used for executive-level portfolio reporting.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ebitdaReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Ebitda Reporting Flag' ;
    rdfs:comment 'Indicates whether this hierarchy node is used for EBITDA reporting and financial performance tracking. True for nodes that represent P&L responsibility centers.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:externalHierarchyCode rdf:type rdf:Property ;
    rdfs:label 'External Hierarchy Code' ;
    rdfs:comment 'External system or customer-facing hierarchy code used for EDI transactions, customer portals, or third-party integrations. May differ from internal SAP codes.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isLeafNode rdf:type rdf:Property ;
    rdfs:label 'Is Leaf Node' ;
    rdfs:comment 'Indicates whether this node is a leaf node (has no children) in the hierarchy. True for the lowest level nodes where individual SKUs are assigned. Used for validation and hierarchy integrity checks.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legacyHierarchyCode rdf:type rdf:Property ;
    rdfs:label 'Legacy Hierarchy Code' ;
    rdfs:comment 'Historical product hierarchy code from legacy ERP systems prior to SAP S/4HANA implementation. Retained for data lineage, historical reporting, and migration traceability.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:levelName rdf:type rdf:Property ;
    rdfs:label 'Level Name' ;
    rdfs:comment 'Descriptive name of the hierarchy level. Standard values: division, business_unit, product_family, product_line, product_group, sub_group. Used for reporting labels and user interface display.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeDepth rdf:type rdf:Property ;
    rdfs:label 'Node Depth' ;
    rdfs:comment 'Calculated depth of the node from the root of the hierarchy tree. Root nodes have depth 0. Used for hierarchy traversal algorithms and reporting level filtering.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nodeDescription rdf:type rdf:Property ;
    rdfs:label 'Node Description' ;
    rdfs:comment 'Detailed description of the hierarchy node including scope, product categories included, and business purpose. Provides context for classification decisions and portfolio management.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeName rdf:type rdf:Property ;
    rdfs:label 'Node Name' ;
    rdfs:comment 'Human-readable name of the hierarchy node. Used for display in reports, dashboards, and user interfaces. Examples: Performance Materials, Agricultural Solutions, Specialty Chemicals, Industrial Polymers.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeStatus rdf:type rdf:Property ;
    rdfs:label 'Node Status' ;
    rdfs:comment 'Current lifecycle status of the hierarchy node. Active: in use for classification and reporting. Inactive: temporarily disabled. Pending: awaiting approval. Deprecated: scheduled for retirement. Archived: historical reference only.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:path rdf:type rdf:Property ;
    rdfs:label 'Path' ;
    rdfs:comment 'Full path from root to this node using node codes separated by forward slashes. Example: DIV01/BU05/FAM12/LINE34. Enables fast ancestor/descendant queries and breadcrumb navigation.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productFamilyCode rdf:type rdf:Property ;
    rdfs:label 'Product Family Code' ;
    rdfs:comment 'Code identifying the product family within the business unit. Groups related product lines with similar chemistry, applications, or market segments.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productLineManager rdf:type rdf:Property ;
    rdfs:label 'Product Line Manager' ;
    rdfs:comment 'Name of the product line manager or business owner responsible for this hierarchy node. Used for accountability, approval workflows, and organizational reporting.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapProductHierarchyCode rdf:type rdf:Property ;
    rdfs:label 'Sap Product Hierarchy Code' ;
    rdfs:comment '18-character SAP S/4HANA product hierarchy code (PRODH field). Concatenated representation of the full hierarchy path used in SAP MM and SD modules for material grouping and sales reporting.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productSpecificationId rdf:type rdf:Property ;
    rdfs:label 'Product Specification Id' ;
    rdfs:comment 'Unique identifier for the product specification record. Primary key for the product specification entity.' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supersededSpecificationProductSpecificationId rdf:type rdf:Property ;
    rdfs:label 'Superseded Specification Product Specification Id' ;
    rdfs:comment 'Reference to the previous specification version that this version replaces. Nullable for initial specifications. Supports version history tracking and regulatory audit trail for specification changes.' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductSpecification .

ind:acceptanceCriteria rdf:type rdf:Property ;
    rdfs:label 'Acceptance Criteria' ;
    rdfs:comment 'Textual description of the acceptance rule for this parameter. Used for qualitative assessments or complex criteria that cannot be expressed as simple numeric ranges (e.g., \'clear colorless liquid\', \'no visible particulates\', \'conforms to reference standard\').' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalityLevel rdf:type rdf:Property ;
    rdfs:label 'Criticality Level' ;
    rdfs:comment 'Classification of the parameter\'s importance to product quality and safety. Critical parameters directly impact safety or efficacy and trigger immediate batch rejection if Out of Specification (OOS). Major parameters affect product performance. Minor parameters are informational or aesthetic.' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ghsClassificationRelevance rdf:type rdf:Property ;
    rdfs:label 'Ghs Classification Relevance' ;
    rdfs:comment 'Describes how this specification parameter relates to Globally Harmonized System (GHS) hazard classification and Safety Data Sheet (SDS) content. For example, pH specifications may determine corrosivity classification; VOC content affects environmental hazard labeling.' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isoStandardReference rdf:type rdf:Property ;
    rdfs:label 'Iso Standard Reference' ;
    rdfs:comment 'Reference to the International Organization for Standardization (ISO) standard that governs this specification parameter or test method. Examples include ISO 9001 for quality management, ISO 14001 for environmental parameters, ISO 17025 for testing competence.' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limsTestCode rdf:type rdf:Property ;
    rdfs:label 'Lims Test Code' ;
    rdfs:comment 'Test code or identifier in the Laboratory Information Management System (LIMS) used to execute this specification parameter. Links this specification to LabWare LIMS for test execution, result capture, and Certificate of Analysis (COA) generation.' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumValue rdf:type rdf:Property ;
    rdfs:label 'Maximum Value' ;
    rdfs:comment 'Upper acceptance limit for the quality parameter. Test results above this value indicate Out of Specification (OOS) condition. Nullable for parameters with only lower limits.' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumValue rdf:type rdf:Property ;
    rdfs:label 'Minimum Value' ;
    rdfs:comment 'Lower acceptance limit for the quality parameter. Test results below this value indicate Out of Specification (OOS) condition. Nullable for parameters with only upper limits.' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parameterName rdf:type rdf:Property ;
    rdfs:label 'Parameter Name' ;
    rdfs:comment 'Name of the quality parameter being specified. Examples include assay, pH (Potential of Hydrogen), viscosity, moisture content, color, density, particle size, heavy metals concentration, residual solvents, Volatile Organic Compound (VOC) content, and other chemical or physical properties.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reachRegistrationRelevance rdf:type rdf:Property ;
    rdfs:label 'Reach Registration Relevance' ;
    rdfs:comment 'Describes how this specification parameter supports Registration Evaluation Authorization and Restriction of Chemicals (REACH) registration and compliance. For example, impurity limits may be required to demonstrate substance identity and composition per REACH dossier.' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Requirement Flag' ;
    rdfs:comment 'Indicates whether this parameter is mandated by regulatory authorities such as Environmental Protection Agency (EPA), Occupational Safety and Health Administration (OSHA), Registration Evaluation Authorization and Restriction of Chemicals (REACH), Toxic Substances Control Act (TSCA), or Food and Drug Administration (FDA). True if regulatory-mandated, false if internal quality control only.' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:samplingPlan rdf:type rdf:Property ;
    rdfs:label 'Sampling Plan' ;
    rdfs:comment 'Description of the sampling strategy for this parameter. Defines sample size, sampling frequency, and sampling points (e.g., \'three samples from top, middle, bottom of batch\', \'composite sample from each reactor vessel\'). Links to Good Manufacturing Practice (GMP) requirements.' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdsSectionReference rdf:type rdf:Property ;
    rdfs:label 'Sds Section Reference' ;
    rdfs:comment 'Reference to the section of the Safety Data Sheet (SDS) or Material Safety Data Sheet (MSDS) where this specification parameter is documented. Supports linkage between quality specifications and safety documentation.' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationNumber rdf:type rdf:Property ;
    rdfs:label 'Specification Number' ;
    rdfs:comment 'Business identifier for the specification document. Externally-known unique code used in Certificate of Analysis (COA) and Certificate of Compliance (COC) generation.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationStatus rdf:type rdf:Property ;
    rdfs:label 'Specification Status' ;
    rdfs:comment 'Current lifecycle state of the specification. Active specifications are used for Certificate of Analysis (COA) generation and Quality Control (QC) release decisions. Superseded specifications are retained for audit trail.' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationType rdf:type rdf:Property ;
    rdfs:label 'Specification Type' ;
    rdfs:comment 'Classification of the specification based on its purpose in the quality control lifecycle. Release specifications define final product acceptance criteria; in-process specifications govern intermediate checkpoints; shelf-life and stability specifications define storage and aging limits.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testFrequency rdf:type rdf:Property ;
    rdfs:label 'Test Frequency' ;
    rdfs:comment 'Frequency at which this parameter must be tested. Per-batch and per-lot testing occur for every production run. Periodic testing (daily, weekly, monthly) applies to stability and shelf-life specifications. On-demand testing is triggered by specific events or investigations. [ENUM-REF-CANDIDATE: per-batch|per-lot|daily|weekly|monthly|quarterly|annual|on-demand — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testMethodReference rdf:type rdf:Property ;
    rdfs:label 'Test Method Reference' ;
    rdfs:comment 'Reference to the standardized or internal test method used to measure this parameter. May reference ASTM (American Society for Testing and Materials), ISO (International Organization for Standardization), USP (United States Pharmacopeia), or internal Standard Operating Procedure (SOP) codes.' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tscaComplianceRelevance rdf:type rdf:Property ;
    rdfs:label 'Tsca Compliance Relevance' ;
    rdfs:comment 'Describes how this specification parameter supports Toxic Substances Control Act (TSCA) compliance and reporting. For example, residual monomer content may be required for TSCA inventory listing or Chemical Data Reporting (CDR).' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substitutionId rdf:type rdf:Property ;
    rdfs:label 'Substitution Id' ;
    rdfs:comment 'System-generated unique identifier for the product substitution rule record.' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:substitutionChemicalProductId rdf:type rdf:Property ;
    rdfs:label 'Substitution Chemical Product Id' ;
    rdfs:comment 'Identifier of the product that may be substituted.' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ChemicalProduct .

ind:substitutionSubstituteProductChemicalProductId rdf:type rdf:Property ;
    rdfs:label 'Substitution Substitute Product Chemical Product Id' ;
    rdfs:comment 'Identifier of the product that can replace the original product.' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ChemicalProduct .

ind:conditionCustomerApprovalRequired rdf:type rdf:Property ;
    rdfs:label 'Condition Customer Approval Required' ;
    rdfs:comment 'True when the customer must explicitly approve the substitution.' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conditionQualityHold rdf:type rdf:Property ;
    rdfs:label 'Condition Quality Hold' ;
    rdfs:comment 'True when substitution is permitted only if the original product is under a quality hold.' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conditionStockOut rdf:type rdf:Property ;
    rdfs:label 'Condition Stock Out' ;
    rdfs:comment 'True when substitution is allowed only if the original product is out of stock.' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:direction rdf:type rdf:Property ;
    rdfs:label 'Direction' ;
    rdfs:comment 'Indicates whether substitution can occur both ways or only from original to substitute.' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substitutionStatus rdf:type rdf:Property ;
    rdfs:label 'Substitution Status' ;
    rdfs:comment 'Current lifecycle status of the substitution rule.' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:csrDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Csr Document Reference' ;
    rdfs:comment 'Reference or file identifier for the associated Chemical Safety Report document.' ;
    rdfs:domain ind:ReachDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:csrRequired rdf:type rdf:Property ;
    rdfs:label 'Csr Required' ;
    rdfs:comment 'Indicates whether a full Chemical Safety Report is required for this substance.' ;
    rdfs:domain ind:ReachDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dossierStatus rdf:type rdf:Property ;
    rdfs:label 'Dossier Status' ;
    rdfs:comment 'Current lifecycle state of the REACH dossier.' ;
    rdfs:domain ind:ReachDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dossierUpdateDate rdf:type rdf:Property ;
    rdfs:label 'Dossier Update Date' ;
    rdfs:comment 'Most recent date the dossier information was updated.' ;
    rdfs:domain ind:ReachDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:echaSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Echa Submission Date' ;
    rdfs:comment 'Date the dossier was submitted to the ECHA portal.' ;
    rdfs:domain ind:ReachDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:echaSubmissionReference rdf:type rdf:Property ;
    rdfs:label 'Echa Submission Reference' ;
    rdfs:comment 'Reference code for the submission package in the ECHA REACH-IT portal.' ;
    rdfs:domain ind:ReachDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exposureScenariosCount rdf:type rdf:Property ;
    rdfs:label 'Exposure Scenarios Count' ;
    rdfs:comment 'Total number of exposure scenarios defined within the dossier.' ;
    rdfs:domain ind:ReachDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:registrantRole rdf:type rdf:Property ;
    rdfs:label 'Registrant Role' ;
    rdfs:comment 'Role of the registrant in the REACH dossier (lead registrant, member, or coordinator).' ;
    rdfs:domain ind:ReachDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationDate rdf:type rdf:Property ;
    rdfs:label 'Registration Date' ;
    rdfs:comment 'Date the REACH registration was initially submitted to ECHA.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:siefMembership rdf:type rdf:Property ;
    rdfs:label 'Sief Membership' ;
    rdfs:comment 'Indicates whether the dossier is part of a Substance Information Exchange Forum (SIEF).' ;
    rdfs:domain ind:ReachDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substanceIupacName rdf:type rdf:Property ;
    rdfs:label 'Substance Iupac Name' ;
    rdfs:comment 'Systematic chemical name of the substance as defined by IUPAC.' ;
    rdfs:domain ind:ReachDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tonnageBand rdf:type rdf:Property ;
    rdfs:label 'Tonnage Band' ;
    rdfs:comment 'Annual tonnage range for which the substance is registered.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryStatusId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Status Id' ;
    rdfs:comment 'Unique identifier for the regulatory compliance status record.' ;
    rdfs:domain ind:RegulatoryStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:authorizationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Authorization Expiry Date' ;
    rdfs:comment 'Date when the granted authorization expires and renewal application is required.' ;
    rdfs:domain ind:RegulatoryStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authorizationNumber rdf:type rdf:Property ;
    rdfs:label 'Authorization Number' ;
    rdfs:comment 'Authorization number granted by the regulatory authority for continued use of a restricted or SVHC substance under specific conditions.' ;
    rdfs:domain ind:RegulatoryStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pfasFlag rdf:type rdf:Property ;
    rdfs:label 'Pfas Flag' ;
    rdfs:comment 'Indicates whether this product contains PFAS (per- and polyfluoroalkyl substances), subject to emerging regulatory restrictions.' ;
    rdfs:domain ind:RegulatoryStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pmnNumber rdf:type rdf:Property ;
    rdfs:label 'Pmn Number' ;
    rdfs:comment 'EPA-assigned number for a Pre-Manufacture Notice submitted for a new chemical substance not on the TSCA Inventory.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prop65ListingFlag rdf:type rdf:Property ;
    rdfs:label 'Prop 65 Listing Flag' ;
    rdfs:comment 'Indicates whether this substance is listed under California Proposition 65 as known to cause cancer, birth defects, or reproductive harm.' ;
    rdfs:domain ind:RegulatoryStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reachRegistrationType rdf:type rdf:Property ;
    rdfs:label 'Reach Registration Type' ;
    rdfs:comment 'Type of REACH registration dossier submitted. Full (standard registration), Intermediate (on-site or transported isolated intermediate), Transported Isolated (intermediate transported between sites), Not Applicable (non-REACH regulation).' ;
    rdfs:domain ind:RegulatoryStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Registration Expiry Date' ;
    rdfs:comment 'Date when the current registration expires and renewal or re-notification is required. Nullable for regulations without expiry.' ;
    rdfs:domain ind:RegulatoryStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulationType rdf:type rdf:Property ;
    rdfs:label 'Regulation Type' ;
    rdfs:comment 'Type of regulatory framework applicable to this product. REACH (Registration Evaluation Authorization and Restriction of Chemicals), TSCA (Toxic Substances Control Act), SARA 313 (Superfund Amendments and Reauthorization Act Section 313), Prop 65 (California Proposition 65), RoHS (Restriction of Hazardous Substances), SVHC (Substance of Very High Concern).' ;
    rdfs:domain ind:RegulatoryStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsiblePartyEmail rdf:type rdf:Property ;
    rdfs:label 'Responsible Party Email' ;
    rdfs:comment 'Email address of the responsible party for regulatory compliance inquiries and notifications.' ;
    rdfs:domain ind:RegulatoryStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsiblePartyName rdf:type rdf:Property ;
    rdfs:label 'Responsible Party Name' ;
    rdfs:comment 'Name of the individual or organizational unit responsible for maintaining this regulatory status record and ensuring ongoing compliance.' ;
    rdfs:domain ind:RegulatoryStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictionConditions rdf:type rdf:Property ;
    rdfs:label 'Restriction Conditions' ;
    rdfs:comment 'Detailed description of any restrictions, limitations, or special conditions imposed on the manufacture, import, use, or sale of this product under the applicable regulation.' ;
    rdfs:domain ind:RegulatoryStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rohsCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Rohs Compliant Flag' ;
    rdfs:comment 'Indicates whether this product complies with RoHS Directive restrictions on hazardous substances in electrical and electronic equipment.' ;
    rdfs:domain ind:RegulatoryStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sara313ReportableFlag rdf:type rdf:Property ;
    rdfs:label 'Sara 313 Reportable Flag' ;
    rdfs:comment 'Indicates whether this substance is subject to SARA Section 313 Toxics Release Inventory (TRI) reporting requirements.' ;
    rdfs:domain ind:RegulatoryStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:substanceRole rdf:type rdf:Property ;
    rdfs:label 'Substance Role' ;
    rdfs:comment 'Role of the organization in the supply chain for this substance under the regulatory framework. Manufacturer (produces the substance), Importer (imports into jurisdiction), Only Representative (non-EU manufacturer representative), Downstream User (uses the substance in formulations).' ;
    rdfs:domain ind:RegulatoryStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:svhcCandidateListFlag rdf:type rdf:Property ;
    rdfs:label 'Svhc Candidate List Flag' ;
    rdfs:comment 'Indicates whether this substance is included on the ECHA Candidate List of Substances of Very High Concern for potential authorization under REACH.' ;
    rdfs:domain ind:RegulatoryStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productId rdf:type rdf:Property ;
    rdfs:label 'Product Id' ;
    rdfs:comment 'Reference to the chemical product for which this SDS is issued. Links to the product master catalog.' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ChemicalProduct .

ind:californiaProp65Listed rdf:type rdf:Property ;
    rdfs:label 'California Prop65 Listed' ;
    rdfs:comment 'Indicates whether the chemical is listed under California Proposition 65 as known to cause cancer, birth defects, or reproductive harm.' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disposalConsiderations rdf:type rdf:Property ;
    rdfs:label 'Disposal Considerations' ;
    rdfs:comment 'Recommended methods for safe disposal of the substance and contaminated packaging, including waste treatment methods and applicable regulations, as per GHS Section 13.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dotPackingGroup rdf:type rdf:Property ;
    rdfs:label 'Dot Packing Group' ;
    rdfs:comment 'DOT packing group indicating the degree of danger: I (high danger), II (medium danger), III (low danger).' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dotUnNumber rdf:type rdf:Property ;
    rdfs:label 'Dot Un Number' ;
    rdfs:comment 'Four-digit UN number assigned to the substance for international transport of dangerous goods. Format: UNXXXX.' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ecologicalInformation rdf:type rdf:Property ;
    rdfs:label 'Ecological Information' ;
    rdfs:comment 'Environmental impact data including aquatic toxicity (LC50, EC50), persistence and degradability, bioaccumulative potential, and mobility in soil, as per GHS Section 12.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exposureLimits rdf:type rdf:Property ;
    rdfs:label 'Exposure Limits' ;
    rdfs:comment 'Occupational exposure limits including OSHA PEL (Permissible Exposure Limit), ACGIH TLV (Threshold Limit Value), and other applicable exposure standards, as per GHS Section 8.' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handlingPrecautions rdf:type rdf:Property ;
    rdfs:label 'Handling Precautions' ;
    rdfs:comment 'Safe handling advice including measures to prevent fire, explosion, and exposure, as per GHS Section 7.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iataShippingName rdf:type rdf:Property ;
    rdfs:label 'Iata Shipping Name' ;
    rdfs:comment 'Proper shipping name for air transport as per IATA Dangerous Goods Regulations.' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imdgShippingName rdf:type rdf:Property ;
    rdfs:label 'Imdg Shipping Name' ;
    rdfs:comment 'Proper shipping name for sea transport as per IMDG Code.' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:odor rdf:type rdf:Property ;
    rdfs:label 'Odor' ;
    rdfs:comment 'Characteristic odor of the chemical product (e.g., pungent, sweet, odorless).' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preparedBy rdf:type rdf:Property ;
    rdfs:label 'Prepared By' ;
    rdfs:comment 'Name or identifier of the person or department responsible for preparing or updating this SDS.' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sara313Reportable rdf:type rdf:Property ;
    rdfs:label 'Sara 313 Reportable' ;
    rdfs:comment 'Indicates whether the chemical is subject to SARA Title III Section 313 Toxics Release Inventory (TRI) reporting requirements.' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:solubilityInWater rdf:type rdf:Property ;
    rdfs:label 'Solubility In Water' ;
    rdfs:comment 'Description of the substances solubility in water (e.g., soluble, insoluble, partially soluble, miscible) and quantitative data if available.' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersedesDate rdf:type rdf:Property ;
    rdfs:label 'Supersedes Date' ;
    rdfs:comment 'Date of the previous SDS version that this revision replaces. Used for audit trail and version history.' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:vaporPressureMmhg rdf:type rdf:Property ;
    rdfs:label 'Vapor Pressure Mmhg' ;
    rdfs:comment 'Pressure exerted by the vapor of the substance in equilibrium with its liquid or solid form at a given temperature, measured in millimeters of mercury (mmHg).' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:applicationArea rdf:type rdf:Property ;
    rdfs:label 'Application Area' ;
    rdfs:comment 'Primary industry or application area where this SKU is used (e.g., Automotive, Construction, Electronics, Agriculture, Pharmaceuticals, Water Treatment).' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:barcode rdf:type rdf:Property ;
    rdfs:label 'Barcode' ;
    rdfs:comment 'Machine-readable barcode identifier (UPC, EAN, or GS1-128) printed on product packaging for scanning in warehouse and logistics operations.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gtin rdf:type rdf:Property ;
    rdfs:label 'Gtin' ;
    rdfs:comment 'Global Trade Item Number uniquely identifying this SKU in the global supply chain. Used for EDI transactions and retail distribution.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isControlledSubstance rdf:type rdf:Property ;
    rdfs:label 'Is Controlled Substance' ;
    rdfs:comment 'Flag indicating whether this chemical is a controlled substance requiring special licensing, reporting, and security measures under DEA or EPA regulations.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHazmat rdf:type rdf:Property ;
    rdfs:label 'Is Hazmat' ;
    rdfs:comment 'Flag indicating whether this SKU is classified as a hazardous material requiring special handling, storage, and transportation procedures.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:moqUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Moq Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the minimum order quantity field. [ENUM-REF-CANDIDATE: kg|l|mt|gal|lb|drum|ibc|bag|ea — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packSize rdf:type rdf:Property ;
    rdfs:label 'Pack Size' ;
    rdfs:comment 'Quantity of product contained in one package unit. Used with unit_of_measure to define the orderable quantity.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:skuDescription rdf:type rdf:Property ;
    rdfs:label 'Sku Description' ;
    rdfs:comment 'Human-readable description of the SKU including product name, grade, packaging type, and size. Used on sales orders, shipping documents, and invoices.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skuStatus rdf:type rdf:Property ;
    rdfs:label 'Sku Status' ;
    rdfs:comment 'Current lifecycle status of the SKU. Active SKUs are orderable; inactive and discontinued SKUs cannot be ordered; blocked SKUs are temporarily unavailable.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationSummary rdf:type rdf:Property ;
    rdfs:label 'Application Summary' ;
    rdfs:comment 'Summary of recommended applications and use cases for the chemical product. Guides customers on appropriate usage scenarios.' ;
    rdfs:domain ind:Tds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boilingPointUnit rdf:type rdf:Property ;
    rdfs:label 'Boiling Point Unit' ;
    rdfs:comment 'Temperature unit for boiling point measurement, either Celsius or Fahrenheit.' ;
    rdfs:domain ind:Tds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boilingPointValue rdf:type rdf:Property ;
    rdfs:label 'Boiling Point Value' ;
    rdfs:comment 'Temperature at which the product transitions from liquid to vapor phase at standard atmospheric pressure. Important for process design and safety.' ;
    rdfs:domain ind:Tds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compatibilityNotes rdf:type rdf:Property ;
    rdfs:label 'Compatibility Notes' ;
    rdfs:comment 'Information on material compatibility and incompatibility with other chemicals, substrates, or container materials. Prevents adverse reactions.' ;
    rdfs:domain ind:Tds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentFilePath rdf:type rdf:Property ;
    rdfs:label 'Document File Path' ;
    rdfs:comment 'Internal file system or content management system path to the TDS document. Used for document retrieval and version control.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flashPointUnit rdf:type rdf:Property ;
    rdfs:label 'Flash Point Unit' ;
    rdfs:comment 'Temperature unit for flash point measurement, either Celsius or Fahrenheit.' ;
    rdfs:domain ind:Tds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flashPointValue rdf:type rdf:Property ;
    rdfs:label 'Flash Point Value' ;
    rdfs:comment 'Lowest temperature at which vapors ignite when exposed to an ignition source. Critical safety parameter for flammable materials.' ;
    rdfs:domain ind:Tds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceDataReference rdf:type rdf:Property ;
    rdfs:label 'Performance Data Reference' ;
    rdfs:comment 'Reference to supporting performance test data, technical bulletins, or case studies that demonstrate product efficacy and application results.' ;
    rdfs:domain ind:Tds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendedUseConcentration rdf:type rdf:Property ;
    rdfs:label 'Recommended Use Concentration' ;
    rdfs:comment 'Guidance on typical or recommended concentration ranges for product application. May include dilution ratios or usage rates.' ;
    rdfs:domain ind:Tds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryComplianceNotes rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Notes' ;
    rdfs:comment 'Summary of key regulatory compliance information including REACH registration status, TSCA listing, FDA approvals, and other jurisdiction-specific clearances.' ;
    rdfs:domain ind:Tds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionNotes rdf:type rdf:Property ;
    rdfs:label 'Revision Notes' ;
    rdfs:comment 'Summary of changes made in this TDS version compared to the previous version. Supports change management and customer communication.' ;
    rdfs:domain ind:Tds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:solubilityDescription rdf:type rdf:Property ;
    rdfs:label 'Solubility Description' ;
    rdfs:comment 'Description of product solubility characteristics in various solvents (water, organic solvents). Guides formulation and application decisions.' ;
    rdfs:domain ind:Tds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageConditions rdf:type rdf:Property ;
    rdfs:label 'Storage Conditions' ;
    rdfs:comment 'Recommended storage conditions including temperature range, humidity control, and container requirements to maintain product quality and safety.' ;
    rdfs:domain ind:Tds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tdsStatus rdf:type rdf:Property ;
    rdfs:label 'Tds Status' ;
    rdfs:comment 'Current lifecycle state of the TDS document. Controls visibility and usage in customer-facing channels.' ;
    rdfs:domain ind:Tds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:viscosityUnit rdf:type rdf:Property ;
    rdfs:label 'Viscosity Unit' ;
    rdfs:comment 'Unit of measure for the viscosity value. Common units include centipoise (cP), centistokes (cSt), and Pascal-seconds.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:viscosityValue rdf:type rdf:Property ;
    rdfs:label 'Viscosity Value' ;
    rdfs:comment 'Measured viscosity of the product indicating flow resistance. Critical for processing, pumping, and application equipment selection.' ;
    rdfs:domain ind:Tds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchGenealogyId rdf:type rdf:Property ;
    rdfs:label 'Batch Genealogy Id' ;
    rdfs:comment 'Unique identifier for the batch genealogy record tracking parent-child lineage relationships between chemical batches.' ;
    rdfs:domain ind:BatchGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bomItemNumber rdf:type rdf:Property ;
    rdfs:label 'Bom Item Number' ;
    rdfs:comment 'The BOM item number from the production recipe that defines this parent-child material relationship. Links to SAP PP BOM structure.' ;
    rdfs:domain ind:BatchGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:childBatchNumber rdf:type rdf:Property ;
    rdfs:label 'Child Batch Number' ;
    rdfs:comment 'The batch number of the downstream child batch (intermediate or finished good) produced in this production relationship. Part of the lot genealogy traceability chain.' ;
    rdfs:domain ind:BatchGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coaReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Coa Reference Number' ;
    rdfs:comment 'The COA reference number associated with this batch genealogy relationship, linking to quality test results and compliance documentation.' ;
    rdfs:domain ind:BatchGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consumptionPercentage rdf:type rdf:Property ;
    rdfs:label 'Consumption Percentage' ;
    rdfs:comment 'The percentage of the parent batch consumed to produce the child batch, enabling yield and material balance calculations.' ;
    rdfs:domain ind:BatchGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Customer Order Number' ;
    rdfs:comment 'The customer order number if this batch genealogy relationship was created for a specific customer order, enabling customer-specific traceability.' ;
    rdfs:domain ind:BatchGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dcsBatchReference rdf:type rdf:Property ;
    rdfs:label 'Dcs Batch Reference' ;
    rdfs:comment 'The batch identifier from the DCS (Honeywell Experion or Siemens PCS 7) that recorded this batch relationship in real-time process control.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genealogyStatus rdf:type rdf:Property ;
    rdfs:label 'Genealogy Status' ;
    rdfs:comment 'The current status of this batch genealogy record: active (normal traceability), archived (historical record), quarantined (batch under quality hold), recalled (batch subject to recall action).' ;
    rdfs:domain ind:BatchGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mesTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Mes Transaction Reference' ;
    rdfs:comment 'The MES transaction identifier that recorded this batch genealogy event, providing audit trail linkage to the execution system.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentBatchNumber rdf:type rdf:Property ;
    rdfs:label 'Parent Batch Number' ;
    rdfs:comment 'The batch number of the upstream parent batch (raw material or intermediate) consumed in this production relationship. Part of the lot genealogy traceability chain.' ;
    rdfs:domain ind:BatchGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processStepCode rdf:type rdf:Property ;
    rdfs:label 'Process Step Code' ;
    rdfs:comment 'The specific process step or operation code in the manufacturing route where this batch relationship occurred (e.g., synthesis, blending, filtration, drying). Maps to MES (Manufacturing Execution System) operation codes.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processStepDescription rdf:type rdf:Property ;
    rdfs:label 'Process Step Description' ;
    rdfs:comment 'Human-readable description of the process step where the batch relationship occurred, providing context for the genealogy link.' ;
    rdfs:domain ind:BatchGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Status' ;
    rdfs:comment 'The quality status of the batch relationship at the time of transfer: released (approved for use), blocked (quality hold), restricted (conditional use), inspection (pending QC).' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityTransferred rdf:type rdf:Property ;
    rdfs:label 'Quantity Transferred' ;
    rdfs:comment 'The quantity of material transferred from parent batch to child batch in this genealogy relationship. Measured in the unit of measure specified.' ;
    rdfs:domain ind:BatchGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:relationshipType rdf:type rdf:Property ;
    rdfs:label 'Relationship Type' ;
    rdfs:comment 'The type of genealogy relationship between parent and child batches: consumed (parent used to make child), produced (child created from parent), split (one parent divided into multiple children), merged (multiple parents combined into one child), blended (multiple parents mixed into child), reworked (defective batch reprocessed).' ;
    rdfs:domain ind:BatchGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:traceabilityChainDepth rdf:type rdf:Property ;
    rdfs:label 'Traceability Chain Depth' ;
    rdfs:comment 'The depth level of this batch relationship in the overall genealogy chain, where 1 represents direct parent-child, 2 represents grandparent-grandchild, etc. Enables multi-level traceability queries.' ;
    rdfs:domain ind:BatchGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:traceabilityDirection rdf:type rdf:Property ;
    rdfs:label 'Traceability Direction' ;
    rdfs:comment 'The direction of traceability this record supports: forward (parent to child), backward (child to parent), or bidirectional (both directions).' ;
    rdfs:domain ind:BatchGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferDate rdf:type rdf:Property ;
    rdfs:label 'Transfer Date' ;
    rdfs:comment 'The date when the material transfer from parent to child batch occurred, establishing the temporal sequence in the genealogy chain.' ;
    rdfs:domain ind:BatchGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transferTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transfer Timestamp' ;
    rdfs:comment 'The precise timestamp when the material transfer from parent to child batch was recorded in the MES or DCS system, providing exact traceability timing.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:yieldPercentage rdf:type rdf:Property ;
    rdfs:label 'Yield Percentage' ;
    rdfs:comment 'The yield percentage achieved in this batch transformation from parent to child, calculated as (actual output / theoretical output) * 100.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:destinationSiteId rdf:type rdf:Property ;
    rdfs:label 'Destination Site Id' ;
    rdfs:comment 'Foreign key linking to customer.site. Business justification: Needed for logistics and traceability: batch records must reference the customer site where the product will be delivered, supporting shipping plans, regulatory SDS/COA delivery, and site-level yield ' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Site .

ind:maintenanceNotificationId rdf:type rdf:Property ;
    rdfs:label 'Maintenance Notification Id' ;
    rdfs:comment 'Foreign key linking to maintenance.notification. Business justification: Needed for Batch Execution Log to capture the maintenance notification that caused a batch hold, used in compliance and downtime analysis reports.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Notification .

ind:primaryBatchEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Batch Employee Id' ;
    rdfs:comment 'Reference to the primary operator or production technician responsible for executing this batch. Used for accountability, training tracking, and electronic signature compliance (21 CFR Part 11).' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryBatchApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Batch Approved By Employee Id' ;
    rdfs:comment 'Reference to the authorized person (typically QA manager or production manager) who gave final approval for batch release. Required for GMP batch release authorization.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:supplyGoodsReceiptId rdf:type rdf:Property ;
    rdfs:label 'Supply Goods Receipt Id' ;
    rdfs:comment 'Foreign key linking to supply.goods_receipt. Business justification: REQUIRED: Quality and traceability reports link each batch record to the goods receipt that delivered the raw material lot.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GoodsReceipt .

ind:tertiaryBatchReviewedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Batch Reviewed By Employee Id' ;
    rdfs:comment 'Reference to the quality assurance (QA) or quality control (QC) personnel who reviewed this batch record. Required for GMP compliance and electronic signature audit trail.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualYieldQuantity rdf:type rdf:Property ;
    rdfs:label 'Actual Yield Quantity' ;
    rdfs:comment 'Actual quantity produced by this batch after completion. Used to calculate yield percentage, material efficiency, and production performance (OEE - Overall Equipment Effectiveness).' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualYieldUom rdf:type rdf:Property ;
    rdfs:label 'Actual Yield Uom' ;
    rdfs:comment 'Unit of measure for the actual yield quantity. Should match batch_size_uom for yield percentage calculation.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchSizeQuantity rdf:type rdf:Property ;
    rdfs:label 'Batch Size Quantity' ;
    rdfs:comment 'Planned or target quantity for this batch expressed in the base unit of measure. Used for yield calculation, material consumption planning, and production scheduling.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchSizeUom rdf:type rdf:Property ;
    rdfs:label 'Batch Size Uom' ;
    rdfs:comment 'Unit of measure for the batch size quantity (e.g., KG, L, MT, GAL). Must align with the formula base unit and inventory unit of measure.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchStatus rdf:type rdf:Property ;
    rdfs:label 'Batch Status' ;
    rdfs:comment 'Current lifecycle state of the batch in the manufacturing execution workflow. Governs whether the batch can be released to inventory, requires quality review, or is blocked for regulatory or quality reasons.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coaIssuedFlag rdf:type rdf:Property ;
    rdfs:label 'Coa Issued Flag' ;
    rdfs:comment 'Boolean indicator that a Certificate of Analysis (COA) has been issued for this batch. COA is required for customer shipments and regulatory compliance.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deviationCount rdf:type rdf:Property ;
    rdfs:label 'Deviation Count' ;
    rdfs:comment 'Number of process deviations, exceptions, or Out of Specification (OOS) events recorded during batch execution. Triggers CAPA (Corrective and Preventive Action) and RCI (Root Cause Investigation) workflows.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exceptionFlag rdf:type rdf:Property ;
    rdfs:label 'Exception Flag' ;
    rdfs:comment 'Boolean indicator that one or more exceptions occurred during batch execution. Used to filter batches requiring quality review or management attention.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:formulaVersion rdf:type rdf:Property ;
    rdfs:label 'Formula Version' ;
    rdfs:comment 'Version identifier of the formula or recipe used for this batch. Critical for traceability when formulas are revised due to MOC (Management of Change) or process optimization.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmpComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Gmp Compliance Flag' ;
    rdfs:comment 'Boolean indicator that this batch was produced under GMP-compliant conditions and meets all regulatory requirements for pharmaceutical or food-contact chemical production.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:manufacturingEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Manufacturing End Timestamp' ;
    rdfs:comment 'Date and time when batch production was completed and the batch was ready for quality inspection. Used for cycle time analysis and production scheduling.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:manufacturingStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Start Timestamp' ;
    rdfs:comment 'Date and time when batch production was initiated on the manufacturing floor. Captured from MES (Manufacturing Execution System) or DCS (Distributed Control System) transaction log.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:mesSystemVersion rdf:type rdf:Property ;
    rdfs:label 'Mes System Version' ;
    rdfs:comment 'Version of the MES or DCS system that recorded this batch. Required for 21 CFR Part 11 compliance and system validation audit trail.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processPhAvg rdf:type rdf:Property ;
    rdfs:label 'Process Ph Avg' ;
    rdfs:comment 'Average pH level during the critical reaction phase. Key process parameter for chemical synthesis quality control and product specification compliance.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processPressureAvg rdf:type rdf:Property ;
    rdfs:label 'Process Pressure Avg' ;
    rdfs:comment 'Average process pressure during the critical reaction phase, measured in bar. Key process parameter for quality control and process safety management (PSM).' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processTemperatureAvg rdf:type rdf:Property ;
    rdfs:label 'Process Temperature Avg' ;
    rdfs:comment 'Average process temperature during the critical reaction phase, measured in degrees Celsius. Key process parameter for quality control and SPC (Statistical Process Control) analysis.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reactionTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Reaction Time Minutes' ;
    rdfs:comment 'Total duration of the chemical reaction phase in minutes. Critical process parameter for yield optimization and product quality consistency.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recipePhaseExecuted rdf:type rdf:Property ;
    rdfs:label 'Recipe Phase Executed' ;
    rdfs:comment 'Comma-separated list or summary of recipe phases executed during this batch (e.g., charging, heating, reaction, cooling, discharge). Provides high-level execution summary for batch genealogy.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Hold Flag' ;
    rdfs:comment 'Boolean indicator that this batch is under regulatory hold and cannot be released to inventory or shipped until regulatory clearance is obtained. May be set by EHS (Environment Health and Safety) or quality assurance.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewStatus rdf:type rdf:Property ;
    rdfs:label 'Review Status' ;
    rdfs:comment 'Current status of the batch record review and approval workflow. Governs whether the batch can be released to inventory or requires additional quality or management review.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reviewed Timestamp' ;
    rdfs:comment 'Date and time when the batch record was reviewed and approved or rejected by quality assurance. Part of the electronic signature audit trail (21 CFR Part 11).' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:bomConsumptionId rdf:type rdf:Property ;
    rdfs:label 'Bom Consumption Id' ;
    rdfs:comment 'Unique identifier for the BOM consumption transaction record.' ;
    rdfs:domain ind:BomConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualQuantityConsumed rdf:type rdf:Property ;
    rdfs:label 'Actual Quantity Consumed' ;
    rdfs:comment 'Actual quantity of material consumed and posted against the production order.' ;
    rdfs:domain ind:BomConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:backflushIndicator rdf:type rdf:Property ;
    rdfs:label 'Backflush Indicator' ;
    rdfs:comment 'Flag indicating whether this consumption was posted automatically via backflushing at production confirmation.' ;
    rdfs:domain ind:BomConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bomLineItemNumber rdf:type rdf:Property ;
    rdfs:label 'Bom Line Item Number' ;
    rdfs:comment 'Line item sequence number in the BOM structure indicating which component this consumption relates to.' ;
    rdfs:domain ind:BomConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsRecipient rdf:type rdf:Property ;
    rdfs:label 'Goods Recipient' ;
    rdfs:comment 'Name or identifier of the person or entity receiving the goods for production use.' ;
    rdfs:domain ind:BomConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementType rdf:type rdf:Property ;
    rdfs:label 'Movement Type' ;
    rdfs:comment 'SAP MM movement type code indicating the nature of the goods movement (e.g., 261 for goods issue to production order, 262 for reversal).' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Posting Timestamp' ;
    rdfs:comment 'Exact date and time when the consumption record was created in the system.' ;
    rdfs:domain ind:BomConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:productionOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Production Order Number' ;
    rdfs:comment 'Business identifier of the production order for which materials were consumed.' ;
    rdfs:domain ind:BomConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reservationItemNumber rdf:type rdf:Property ;
    rdfs:label 'Reservation Item Number' ;
    rdfs:comment 'Line item number within the reservation document.' ;
    rdfs:domain ind:BomConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardCostPerUnit rdf:type rdf:Property ;
    rdfs:label 'Standard Cost Per Unit' ;
    rdfs:comment 'Standard cost per unit of measure for the consumed material at the time of posting.' ;
    rdfs:domain ind:BomConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCostAmount rdf:type rdf:Property ;
    rdfs:label 'Total Cost Amount' ;
    rdfs:comment 'Total cost impact of this consumption transaction, calculated as actual_quantity_consumed * standard_cost_per_unit.' ;
    rdfs:domain ind:BomConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unloadingPoint rdf:type rdf:Property ;
    rdfs:label 'Unloading Point' ;
    rdfs:comment 'Physical location or point where the material was delivered for consumption.' ;
    rdfs:domain ind:BomConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Campaign Employee Id' ;
    rdfs:comment 'Reference to the production planner responsible for campaign planning and scheduling.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:campaignSupervisorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Campaign Supervisor Employee Id' ;
    rdfs:comment 'Reference to the production supervisor responsible for campaign execution oversight.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:routingId rdf:type rdf:Property ;
    rdfs:label 'Routing Id' ;
    rdfs:comment 'Reference to the production routing or process flow used for all batches in the campaign. Defines the sequence of operations and work centers.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Routing .

ind:actualBatchCount rdf:type rdf:Property ;
    rdfs:label 'Actual Batch Count' ;
    rdfs:comment 'Number of production batches actually executed within this campaign. Updated as batches are completed.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:campaignNumber rdf:type rdf:Property ;
    rdfs:label 'Campaign Number' ;
    rdfs:comment 'Business identifier for the campaign, externally visible and used in production planning and scheduling systems. Typically follows plant-specific numbering conventions.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignType rdf:type rdf:Property ;
    rdfs:label 'Campaign Type' ;
    rdfs:comment 'Classification of the campaign based on equipment utilization strategy. Dedicated campaigns run a single product exclusively; shared campaigns alternate between products in the same family; multi-product campaigns produce multiple SKUs; trial campaigns are for R&D validation.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeoverTimeHours rdf:type rdf:Property ;
    rdfs:label 'Changeover Time Hours' ;
    rdfs:comment 'Total time in hours required for equipment changeover and setup at the start of the campaign. Includes line clearance, equipment configuration, and pre-production checks.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cipDurationHours rdf:type rdf:Property ;
    rdfs:label 'Cip Duration Hours' ;
    rdfs:comment 'Total time in hours allocated for CIP operations during the campaign. Used for OEE calculations and scheduling.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cipScheduleType rdf:type rdf:Property ;
    rdfs:label 'Cip Schedule Type' ;
    rdfs:comment 'Cleaning schedule strategy for the campaign. Between-batches requires CIP after each batch; end-of-campaign performs CIP only at campaign completion; as-needed is based on contamination risk assessment.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costVariancePercentage rdf:type rdf:Property ;
    rdfs:label 'Cost Variance Percentage' ;
    rdfs:comment 'Percentage variance between estimated and actual cost, calculated as ((actual_cost - cost_estimate) / cost_estimate) * 100. Key financial performance indicator.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:masterRecipeReference rdf:type rdf:Property ;
    rdfs:label 'Master Recipe Reference' ;
    rdfs:comment 'Reference to the master recipe or process specification used for all batches in this campaign. Ensures consistency across campaign execution.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mesCampaignReference rdf:type rdf:Property ;
    rdfs:label 'Mes Campaign Reference' ;
    rdfs:comment 'External identifier from the MES system used for integration and traceability. Links to MES execution logs and real-time process data.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mocReference rdf:type rdf:Property ;
    rdfs:label 'Moc Reference' ;
    rdfs:comment 'Reference to any Management of Change documentation associated with this campaign. Required when process parameters, equipment, or materials differ from standard operations.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oeeActualPercentage rdf:type rdf:Property ;
    rdfs:label 'Oee Actual Percentage' ;
    rdfs:comment 'Actual OEE percentage achieved during the campaign, calculated from availability, performance, and quality metrics. Key KPI for production efficiency.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oeeTargetPercentage rdf:type rdf:Property ;
    rdfs:label 'Oee Target Percentage' ;
    rdfs:comment 'Target OEE percentage for the campaign, representing planned equipment utilization efficiency. Used for performance benchmarking.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedBatchCount rdf:type rdf:Property ;
    rdfs:label 'Planned Batch Count' ;
    rdfs:comment 'Number of production batches planned for this campaign at the time of campaign creation.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualityHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Hold Flag' ;
    rdfs:comment 'Indicates whether the campaign output is under quality hold pending final release by QA. Prevents shipment until cleared.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cipRecordId rdf:type rdf:Property ;
    rdfs:label 'Cip Record Id' ;
    rdfs:comment 'Unique identifier for the CIP execution record. Primary key for the CIP record entity.' ;
    rdfs:domain ind:CipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:previousMaterialMasterId rdf:type rdf:Property ;
    rdfs:label 'Previous Material Master Id' ;
    rdfs:comment 'Foreign key linking to rawmaterial.material_master. Business justification: CIP scheduling needs the previous product\'s raw-material details to validate cleaning effectiveness.' ;
    rdfs:domain ind:CipRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialMaster .

ind:primaryCipEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Cip Employee Id' ;
    rdfs:comment 'Identifier of the operator who executed or supervised the CIP cycle. Links to workforce/employee master data.' ;
    rdfs:domain ind:CipRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:cipCycleNumber rdf:type rdf:Property ;
    rdfs:label 'Cip Cycle Number' ;
    rdfs:comment 'Sequential cycle number for this equipment. Tracks the number of CIP cycles performed on the equipment for maintenance and lifecycle analysis.' ;
    rdfs:domain ind:CipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cipProcedureReference rdf:type rdf:Property ;
    rdfs:label 'Cip Procedure Reference' ;
    rdfs:comment 'Reference code to the Standard Operating Procedure (SOP) or master recipe used for this CIP execution. Defines the cleaning protocol, agent, temperature, duration, and acceptance criteria.' ;
    rdfs:domain ind:CipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cipStatus rdf:type rdf:Property ;
    rdfs:label 'Cip Status' ;
    rdfs:comment 'Current status of the CIP execution: in_progress (cleaning underway), completed (successfully finished), failed (did not meet acceptance criteria), aborted (manually stopped), pending_review (awaiting QA approval).' ;
    rdfs:domain ind:CipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cipType rdf:type rdf:Property ;
    rdfs:label 'Cip Type' ;
    rdfs:comment 'Type of CIP execution: manual (operator-driven), automatic (fully automated via DCS/PLC), or semi-automatic (operator-initiated, system-controlled).' ;
    rdfs:domain ind:CipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cleaningAgentCode rdf:type rdf:Property ;
    rdfs:label 'Cleaning Agent Code' ;
    rdfs:comment 'Material code of the cleaning agent or detergent used in the CIP process (e.g., caustic soda, acid wash, sanitizer). Links to material master.' ;
    rdfs:domain ind:CipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cleaningAgentConcentrationPpm rdf:type rdf:Property ;
    rdfs:label 'Cleaning Agent Concentration Ppm' ;
    rdfs:comment 'Concentration of the cleaning agent in parts per million (PPM) used during the CIP cycle. Critical for ensuring effective cleaning without residue.' ;
    rdfs:domain ind:CipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cleaningAgentName rdf:type rdf:Property ;
    rdfs:label 'Cleaning Agent Name' ;
    rdfs:comment 'Descriptive name of the cleaning agent used (e.g., Sodium Hydroxide Solution, Nitric Acid 10%, Hydrogen Peroxide Sanitizer).' ;
    rdfs:domain ind:CipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cleaningDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Cleaning Duration Minutes' ;
    rdfs:comment 'Total duration of the CIP cleaning cycle in minutes, from start of cleaning agent circulation to completion of final rinse.' ;
    rdfs:domain ind:CipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cleaningTemperatureCelsius rdf:type rdf:Property ;
    rdfs:label 'Cleaning Temperature Celsius' ;
    rdfs:comment 'Temperature in degrees Celsius at which the CIP cleaning cycle was executed. Temperature is critical for cleaning efficacy and must meet SOP specifications.' ;
    rdfs:domain ind:CipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deviationDescription rdf:type rdf:Property ;
    rdfs:label 'Deviation Description' ;
    rdfs:comment 'Detailed description of any deviations from the standard CIP procedure, including root cause and corrective actions taken.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flowRateLitersPerMinute rdf:type rdf:Property ;
    rdfs:label 'Flow Rate Liters Per Minute' ;
    rdfs:comment 'Flow rate of cleaning solution in liters per minute during the CIP cycle. Adequate flow rate ensures complete coverage and effective cleaning.' ;
    rdfs:domain ind:CipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mesIntegrationReference rdf:type rdf:Property ;
    rdfs:label 'Mes Integration Reference' ;
    rdfs:comment 'Integration identifier linking this CIP record to the MES system for production scheduling, lot genealogy, and traceability.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextProductCode rdf:type rdf:Property ;
    rdfs:label 'Next Product Code' ;
    rdfs:comment 'Material code of the chemical product scheduled to be manufactured in the equipment after this CIP cycle. Used to validate cleaning protocol adequacy for product changeover.' ;
    rdfs:domain ind:CipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextProductionClearanceFlag rdf:type rdf:Property ;
    rdfs:label 'Next Production Clearance Flag' ;
    rdfs:comment 'Boolean flag indicating whether the equipment has been cleared for the next production run. True means equipment is approved for use; False means additional cleaning or inspection is required.' ;
    rdfs:domain ind:CipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operatorName rdf:type rdf:Property ;
    rdfs:label 'Operator Name' ;
    rdfs:comment 'Full name of the operator who executed or supervised the CIP cycle. Captured for audit trail and accountability.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passFailResult rdf:type rdf:Property ;
    rdfs:label 'Pass Fail Result' ;
    rdfs:comment 'Final pass/fail result of the CIP execution based on acceptance criteria (rinse water conductivity, temperature profile, duration). Conditional_pass indicates minor deviations requiring management review.' ;
    rdfs:domain ind:CipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qaComments rdf:type rdf:Property ;
    rdfs:label 'Qa Comments' ;
    rdfs:comment 'Free-text comments from the QA reviewer regarding the CIP execution, any deviations observed, or additional actions required.' ;
    rdfs:domain ind:CipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qaReviewTimestamp rdf:type rdf:Property ;
    rdfs:label 'Qa Review Timestamp' ;
    rdfs:comment 'Date and time when the QA reviewer approved or rejected the CIP record. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:CipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rinseWaterConductivityUsCm rdf:type rdf:Property ;
    rdfs:label 'Rinse Water Conductivity Us Cm' ;
    rdfs:comment 'Electrical conductivity of the final rinse water in microsiemens per centimeter (µS/cm). Low conductivity indicates effective removal of cleaning agent residues. Typical acceptance threshold is below 20 µS/cm.' ;
    rdfs:domain ind:CipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scadaIntegrationReference rdf:type rdf:Property ;
    rdfs:label 'Scada Integration Reference' ;
    rdfs:comment 'Integration identifier linking this CIP record to SCADA system logs and real-time process data captured during the cleaning cycle.' ;
    rdfs:domain ind:CipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dcsEventLogId rdf:type rdf:Property ;
    rdfs:label 'Dcs Event Log Id' ;
    rdfs:comment 'Unique identifier for each DCS/SCADA event log entry. Primary key for the event log. Inferred role: EVENT_LOG.' ;
    rdfs:domain ind:DcsEventLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:researchProcessSimulationId rdf:type rdf:Property ;
    rdfs:label 'Research Process Simulation Id' ;
    rdfs:comment 'Foreign key linking to research.research_process_simulation. Business justification: Connects DCS events to the HYSYS simulation model used for process design, enabling validation of control actions against the simulated baseline.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ResearchProcessSimulation .

ind:acknowledgedFlag rdf:type rdf:Property ;
    rdfs:label 'Acknowledged Flag' ;
    rdfs:comment 'Indicates whether the event (typically an alarm or interlock) has been acknowledged by an operator. True if acknowledged, False if unacknowledged. Critical for alarm management and operator response tracking.' ;
    rdfs:domain ind:DcsEventLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:acknowledgedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Acknowledged Timestamp' ;
    rdfs:comment 'Date and time when the event was acknowledged by an operator. Null if not yet acknowledged. Used to calculate alarm response time and operator performance metrics. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:DcsEventLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:alarmLimit rdf:type rdf:Property ;
    rdfs:label 'Alarm Limit' ;
    rdfs:comment 'Configured alarm threshold value that triggered the alarm for alarm-type events. Null for non-alarm events. Used for alarm rationalization and setpoint optimization.' ;
    rdfs:domain ind:DcsEventLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:alarmState rdf:type rdf:Property ;
    rdfs:label 'Alarm State' ;
    rdfs:comment 'Current state of the alarm for alarm-type events. Active: alarm condition present. Cleared: alarm condition resolved. Suppressed: alarm temporarily disabled. Shelved: alarm acknowledged but not yet cleared. Null for non-alarm events.' ;
    rdfs:domain ind:DcsEventLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchesCompleted rdf:type rdf:Property ;
    rdfs:label 'Batches Completed' ;
    rdfs:comment 'Number of production batches completed during the shift for shift summary events. Null for non-shift-summary events. Key performance indicator for shift productivity.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:batchesInProgress rdf:type rdf:Property ;
    rdfs:label 'Batches In Progress' ;
    rdfs:comment 'Number of production batches in progress at shift end for shift summary events. Null for non-shift-summary events. Critical for shift handover continuity.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:controlModeNew rdf:type rdf:Property ;
    rdfs:label 'Control Mode New' ;
    rdfs:comment 'New control mode after a mode_change event. Null for non-mode-change events. Tracks transitions between automatic, manual, cascade, remote, and local control modes.' ;
    rdfs:domain ind:DcsEventLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlModePrevious rdf:type rdf:Property ;
    rdfs:label 'Control Mode Previous' ;
    rdfs:comment 'Previous control mode before a mode_change event. Null for non-mode-change events. Tracks transitions between automatic, manual, cascade, remote, and local control modes.' ;
    rdfs:domain ind:DcsEventLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dcsNodeReference rdf:type rdf:Property ;
    rdfs:label 'Dcs Node Reference' ;
    rdfs:comment 'Identifier of the DCS/SCADA node or controller that generated the event. Maps to specific Honeywell Experion or Siemens PCS 7 controller instances within the distributed control architecture.' ;
    rdfs:domain ind:DcsEventLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationSeconds rdf:type rdf:Property ;
    rdfs:label 'Duration Seconds' ;
    rdfs:comment 'Duration of the event in seconds. For alarms: time from activation to clearance. For interlocks: trip duration. For mode changes: time in transient state. Null for instantaneous events.' ;
    rdfs:domain ind:DcsEventLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:environmentalReadings rdf:type rdf:Property ;
    rdfs:label 'Environmental Readings' ;
    rdfs:comment 'Summary of environmental monitoring readings during the shift (e.g., emissions, VOC levels, wastewater parameters). Null if not recorded. Supports EPA and environmental compliance reporting.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentIssues rdf:type rdf:Property ;
    rdfs:label 'Equipment Issues' ;
    rdfs:comment 'Free-text description of equipment problems, malfunctions, or maintenance needs identified during the shift. Null if no issues. Used for shift handover and maintenance planning.' ;
    rdfs:domain ind:DcsEventLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventDescription rdf:type rdf:Property ;
    rdfs:label 'Event Description' ;
    rdfs:comment 'Detailed narrative description of the event. For alarms: alarm message text. For operator actions: action description. For shift handovers: handover notes and instructions. For shift summaries: comprehensive shift narrative.' ;
    rdfs:domain ind:DcsEventLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handoverInstructions rdf:type rdf:Property ;
    rdfs:label 'Handover Instructions' ;
    rdfs:comment 'Detailed instructions and action items for the incoming shift. Null for non-handover events. Ensures operational continuity and clear communication between shifts.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interlockReference rdf:type rdf:Property ;
    rdfs:label 'Interlock Reference' ;
    rdfs:comment 'Unique identifier of the safety interlock that tripped for interlock_trip events. Null for non-interlock events. Links to interlock logic documentation and safety instrumented systems (SIS).' ;
    rdfs:domain ind:DcsEventLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialShortages rdf:type rdf:Property ;
    rdfs:label 'Material Shortages' ;
    rdfs:comment 'Free-text description of raw material shortages or supply issues encountered during the shift. Null if none. Used for shift handover and supply chain escalation.' ;
    rdfs:domain ind:DcsEventLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatorCount rdf:type rdf:Property ;
    rdfs:label 'Operator Count' ;
    rdfs:comment 'Number of operators on duty during the shift for shift-related events. Null for non-shift events. Used for staffing analysis and workload assessment.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:processValue rdf:type rdf:Property ;
    rdfs:label 'Process Value' ;
    rdfs:comment 'Actual process measurement value at the time of the event (e.g., temperature, pressure, flow rate, pH). Null if not applicable. Used for alarm analysis and process deviation investigation.' ;
    rdfs:domain ind:DcsEventLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processValueUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Process Value Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the process value (e.g., degC, bar, pH, kg/h, L/min, ppm). Null if process_value is null. Critical for engineering analysis.' ;
    rdfs:domain ind:DcsEventLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityHolds rdf:type rdf:Property ;
    rdfs:label 'Quality Holds' ;
    rdfs:comment 'Free-text description of batches or materials placed on quality hold during the shift. Null if none. Critical for QA/QC tracking and batch disposition.' ;
    rdfs:domain ind:DcsEventLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyObservations rdf:type rdf:Property ;
    rdfs:label 'Safety Observations' ;
    rdfs:comment 'Free-text description of safety observations, near-misses, or EHS concerns noted during the shift. Null if none. Critical for Process Safety Management and continuous improvement.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:setpointUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Setpoint Unit Of Measure' ;
    rdfs:comment 'Unit of measure for setpoint values (e.g., degC, bar, pH, kg/h, L/min). Null for non-setpoint-change events. Critical for engineering analysis and process control.' ;
    rdfs:domain ind:DcsEventLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:setpointValueNew rdf:type rdf:Property ;
    rdfs:label 'Setpoint Value New' ;
    rdfs:comment 'New setpoint value after a setpoint_change event. Null for non-setpoint-change events. Used for audit trail and process optimization analysis.' ;
    rdfs:domain ind:DcsEventLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:setpointValuePrevious rdf:type rdf:Property ;
    rdfs:label 'Setpoint Value Previous' ;
    rdfs:comment 'Previous setpoint value before a setpoint_change event. Null for non-setpoint-change events. Used for audit trail and process optimization analysis.' ;
    rdfs:domain ind:DcsEventLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shiftDate rdf:type rdf:Property ;
    rdfs:label 'Shift Date' ;
    rdfs:comment 'Calendar date of the shift for shift-related events (shift_handover, shift_summary, shift_observation). Null for non-shift events. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shiftType rdf:type rdf:Property ;
    rdfs:label 'Shift Type' ;
    rdfs:comment 'Type of shift for shift-related events. Identifies day, afternoon (swing), night, weekend, or holiday shifts. Null for non-shift events. Used for shift handover continuity and staffing analysis.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supervisorName rdf:type rdf:Property ;
    rdfs:label 'Supervisor Name' ;
    rdfs:comment 'Name of the shift supervisor on duty for shift-related events. Null for non-shift events. Provides accountability and escalation contact for shift operations.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tagReference rdf:type rdf:Property ;
    rdfs:label 'Tag Reference' ;
    rdfs:comment 'Unique process tag identifier from the DCS/SCADA system representing the specific instrument, sensor, valve, or control point associated with this event. Used for traceability to P&ID diagrams and process control loops.' ;
    rdfs:domain ind:DcsEventLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentEffectivenessId rdf:type rdf:Property ;
    rdfs:label 'Equipment Effectiveness Id' ;
    rdfs:comment 'Primary key for equipment_effectiveness' ;
    rdfs:domain ind:EquipmentEffectiveness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maintenanceWorkOrderId rdf:type rdf:Property ;
    rdfs:label 'Maintenance Work Order Id' ;
    rdfs:comment 'Reference to the maintenance work order created to address the downtime event. Links to SAP PM work order for repair tracking and cost capture.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrder .

ind:primaryEquipmentEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Equipment Employee Id' ;
    rdfs:comment 'Identifier of the operator who reported or was on duty during the downtime event. Used for training needs analysis and accountability.' ;
    rdfs:domain ind:EquipmentEffectiveness ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:shiftScheduleId rdf:type rdf:Property ;
    rdfs:label 'Shift Schedule Id' ;
    rdfs:comment 'Identifier of the production shift during which the downtime event occurred. Used for shift-level OEE analysis and performance comparison.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ShiftSchedule .

ind:capaRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Capa Required Flag' ;
    rdfs:comment 'Indicates whether this downtime event requires formal CAPA (Corrective and Preventive Action) investigation and documentation per quality management system.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dcsAlarmReference rdf:type rdf:Property ;
    rdfs:label 'Dcs Alarm Reference' ;
    rdfs:comment 'Identifier of the DCS or SCADA alarm that triggered or was associated with the downtime event. Links to process control system alarm history.' ;
    rdfs:domain ind:EquipmentEffectiveness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downtimeCategory rdf:type rdf:Property ;
    rdfs:label 'Downtime Category' ;
    rdfs:comment 'High-level classification of the downtime event type. Used for OEE availability loss categorization and root cause analysis. [ENUM-REF-CANDIDATE: mechanical_failure|electrical_failure|process_upset|material_shortage|changeover|planned_maintenance|utility_failure|operator_shortage|quality_issue|safety_incident — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:EquipmentEffectiveness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downtimeDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Downtime Duration Minutes' ;
    rdfs:comment 'Total duration of the downtime event in minutes. Calculated as the difference between end and start timestamps. Used directly in OEE availability calculation.' ;
    rdfs:domain ind:EquipmentEffectiveness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:downtimeEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Downtime End Timestamp' ;
    rdfs:comment 'Precise date and time when the equipment was restored to operational status and production resumed.' ;
    rdfs:domain ind:EquipmentEffectiveness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:downtimeEventNumber rdf:type rdf:Property ;
    rdfs:label 'Downtime Event Number' ;
    rdfs:comment 'Business-readable unique identifier for the downtime event, typically generated by MES or DCS system.' ;
    rdfs:domain ind:EquipmentEffectiveness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downtimeStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Downtime Start Timestamp' ;
    rdfs:comment 'Precise date and time when the downtime event began. Captured from DCS/SCADA system or manually recorded by operator.' ;
    rdfs:domain ind:EquipmentEffectiveness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:downtimeStatus rdf:type rdf:Property ;
    rdfs:label 'Downtime Status' ;
    rdfs:comment 'Current lifecycle status of the downtime event record. Tracks progression from detection through resolution and closure.' ;
    rdfs:domain ind:EquipmentEffectiveness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downtimeSubcategory rdf:type rdf:Property ;
    rdfs:label 'Downtime Subcategory' ;
    rdfs:comment 'Detailed subcategory or specific failure mode within the downtime category. Provides granular classification for maintenance and continuous improvement analysis.' ;
    rdfs:domain ind:EquipmentEffectiveness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalIncidentFlag rdf:type rdf:Property ;
    rdfs:label 'Environmental Incident Flag' ;
    rdfs:comment 'Indicates whether the downtime event resulted in an environmental release or incident requiring EPA or regulatory reporting.' ;
    rdfs:domain ind:EquipmentEffectiveness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:idealCycleTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Ideal Cycle Time Seconds' ;
    rdfs:comment 'Theoretical minimum time to produce one unit of product under ideal conditions. Used for OEE performance calculation.' ;
    rdfs:domain ind:EquipmentEffectiveness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mtbfInclusionFlag rdf:type rdf:Property ;
    rdfs:label 'Mtbf Inclusion Flag' ;
    rdfs:comment 'Indicates whether this downtime event should be counted as a failure event in MTBF (Mean Time Between Failures) calculation for reliability analysis.' ;
    rdfs:domain ind:EquipmentEffectiveness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mttrInclusionFlag rdf:type rdf:Property ;
    rdfs:label 'Mttr Inclusion Flag' ;
    rdfs:comment 'Indicates whether this downtime event should be included in MTTR (Mean Time To Repair) calculation for maintainability analysis.' ;
    rdfs:domain ind:EquipmentEffectiveness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:oeeAvailabilityImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Oee Availability Impact Flag' ;
    rdfs:comment 'Indicates whether this downtime event should be included in the OEE availability component calculation (True) or excluded (False).' ;
    rdfs:domain ind:EquipmentEffectiveness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:oeePerformanceImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Oee Performance Impact Flag' ;
    rdfs:comment 'Indicates whether this downtime event impacted the OEE performance component (speed losses) in addition to availability.' ;
    rdfs:domain ind:EquipmentEffectiveness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:oeeQualityImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Oee Quality Impact Flag' ;
    rdfs:comment 'Indicates whether this downtime event resulted in quality losses or defects that impact the OEE quality component.' ;
    rdfs:domain ind:EquipmentEffectiveness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plannedDowntimeFlag rdf:type rdf:Property ;
    rdfs:label 'Planned Downtime Flag' ;
    rdfs:comment 'Indicates whether the downtime was scheduled and planned (True) or unplanned/unscheduled (False). Critical for distinguishing availability losses in OEE calculation.' ;
    rdfs:domain ind:EquipmentEffectiveness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plannedProductionTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Planned Production Time Minutes' ;
    rdfs:comment 'Total planned production time for the period in which the downtime occurred. Used as the denominator in OEE availability calculation.' ;
    rdfs:domain ind:EquipmentEffectiveness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productionImpactBatchesDelayed rdf:type rdf:Property ;
    rdfs:label 'Production Impact Batches Delayed' ;
    rdfs:comment 'Number of production batches delayed or rescheduled as a result of this downtime event. Measures schedule adherence impact.' ;
    rdfs:domain ind:EquipmentEffectiveness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productionImpactQuantityLost rdf:type rdf:Property ;
    rdfs:label 'Production Impact Quantity Lost' ;
    rdfs:comment 'Quantity of product that could not be produced due to the downtime event, measured in the product\'s base unit of measure. Used for throughput loss calculation.' ;
    rdfs:domain ind:EquipmentEffectiveness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productionImpactUom rdf:type rdf:Property ;
    rdfs:label 'Production Impact Uom' ;
    rdfs:comment 'Unit of measure for the quantity lost (e.g., kg, liters, tons, units). Aligns with material master UOM.' ;
    rdfs:domain ind:EquipmentEffectiveness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recoveryActionCode rdf:type rdf:Property ;
    rdfs:label 'Recovery Action Code' ;
    rdfs:comment 'Standardized code representing the type of recovery action performed (e.g., repair, replacement, adjustment, restart).' ;
    rdfs:domain ind:EquipmentEffectiveness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recoveryActionDescription rdf:type rdf:Property ;
    rdfs:label 'Recovery Action Description' ;
    rdfs:comment 'Detailed description of the corrective actions taken to restore equipment to operational status and resume production.' ;
    rdfs:domain ind:EquipmentEffectiveness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseCode rdf:type rdf:Property ;
    rdfs:label 'Root Cause Code' ;
    rdfs:comment 'Standardized code representing the root cause category from the plant\'s failure mode taxonomy. Enables systematic analysis and trending.' ;
    rdfs:domain ind:EquipmentEffectiveness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomId rdf:type rdf:Property ;
    rdfs:label 'Bom Id' ;
    rdfs:comment 'Identifier for the Bill of Materials defining the raw materials, intermediates, and components required for this production order.' ;
    rdfs:domain ind:ManufacturingOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillOfMaterials .

ind:controlRecipeId rdf:type rdf:Property ;
    rdfs:label 'Control Recipe Id' ;
    rdfs:comment 'Identifier for the control recipe instance downloaded to the DCS (Honeywell Experion, Siemens PCS 7) for automated execution of process phases and unit procedures.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ControlRecipe .

ind:actualYieldPercentage rdf:type rdf:Property ;
    rdfs:label 'Actual Yield Percentage' ;
    rdfs:comment 'Calculated yield percentage achieved in this production run: (actual output / theoretical output) * 100. Key performance indicator for process efficiency.' ;
    rdfs:domain ind:ManufacturingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costVarianceFlag rdf:type rdf:Property ;
    rdfs:label 'Cost Variance Flag' ;
    rdfs:comment 'Indicator that actual cost exceeded planned cost by a threshold percentage, triggering variance investigation and root cause analysis.' ;
    rdfs:domain ind:ManufacturingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectionLotNumber rdf:type rdf:Property ;
    rdfs:label 'Inspection Lot Number' ;
    rdfs:comment 'Identifier for the quality inspection lot created for this production order output, linking to LIMS test results and Certificate of Analysis.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processOrderType rdf:type rdf:Property ;
    rdfs:label 'Process Order Type' ;
    rdfs:comment 'Specific classification of the order purpose: standard (normal production), rework (reprocessing), trial (R&D pilot), validation (process qualification), cleaning (CIP campaign).' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionVersion rdf:type rdf:Property ;
    rdfs:label 'Production Version' ;
    rdfs:comment 'Four-digit version number linking the specific BOM and routing combination used for this order. Enables traceability of recipe changes over time.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityInspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Required' ;
    rdfs:comment 'Indicator that finished product must undergo quality control inspection and COA issuance before release to inventory or shipment.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:yieldTargetPercentage rdf:type rdf:Property ;
    rdfs:label 'Yield Target Percentage' ;
    rdfs:comment 'Expected yield percentage based on master recipe and historical performance. Used as benchmark for variance analysis and process optimization.' ;
    rdfs:domain ind:ManufacturingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mesExecutionLogId rdf:type rdf:Property ;
    rdfs:label 'Mes Execution Log Id' ;
    rdfs:comment 'Unique identifier for the MES execution log record. Primary key for the execution log entry capturing a single step or phase execution within a production batch or process order.' ;
    rdfs:domain ind:MesExecutionLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryMesEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Mes Employee Id' ;
    rdfs:comment 'Reference to the operator or production worker who executed or confirmed this operation step. Critical for accountability and electronic signature compliance.' ;
    rdfs:domain ind:MesExecutionLog ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:processOrderId rdf:type rdf:Property ;
    rdfs:label 'Process Order Id' ;
    rdfs:comment 'Reference to the parent process order or production order under which this execution step was performed. Links the execution log to the overall manufacturing order.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcessOrder .

ind:dcsTagName rdf:type rdf:Property ;
    rdfs:label 'Dcs Tag Name' ;
    rdfs:comment 'DCS or SCADA tag identifier from which the parameter value was read. Links MES execution data to real-time process control system (Honeywell Experion, Siemens PCS 7).' ;
    rdfs:domain ind:MesExecutionLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:electronicSignature rdf:type rdf:Property ;
    rdfs:label 'Electronic Signature' ;
    rdfs:comment 'Encrypted electronic signature of the operator confirming execution of the step. Required for GMP and 21 CFR Part 11 compliance.' ;
    rdfs:domain ind:MesExecutionLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionDescription rdf:type rdf:Property ;
    rdfs:label 'Exception Description' ;
    rdfs:comment 'Detailed description of the exception or deviation that occurred during execution. Provides context for investigation and root cause analysis.' ;
    rdfs:domain ind:MesExecutionLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Execution End Timestamp' ;
    rdfs:comment 'Date and time when the execution of this recipe phase or operation step was completed or terminated.' ;
    rdfs:domain ind:MesExecutionLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:executionStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Execution Start Timestamp' ;
    rdfs:comment 'Date and time when the execution of this recipe phase or operation step was initiated by the operator or system.' ;
    rdfs:domain ind:MesExecutionLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:executionStatus rdf:type rdf:Property ;
    rdfs:label 'Execution Status' ;
    rdfs:comment 'Current status of the execution step. Tracks the lifecycle state of the operation from initiation through completion or exception. [ENUM-REF-CANDIDATE: started|in_progress|completed|paused|aborted|exception|confirmed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MesExecutionLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instructionText rdf:type rdf:Property ;
    rdfs:label 'Instruction Text' ;
    rdfs:comment 'The full text of the work instruction or Standard Operating Procedure (SOP) step displayed to the operator during execution. Captures what the operator was instructed to do.' ;
    rdfs:domain ind:MesExecutionLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialLotNumber rdf:type rdf:Property ;
    rdfs:label 'Material Lot Number' ;
    rdfs:comment 'Lot number of the raw material or intermediate consumed or produced during this execution step. Enables material traceability and genealogy.' ;
    rdfs:domain ind:MesExecutionLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialQuantity rdf:type rdf:Property ;
    rdfs:label 'Material Quantity' ;
    rdfs:comment 'Quantity of material charged, consumed, or produced during this execution step. Used for Bill of Materials (BOM) reconciliation and yield calculation.' ;
    rdfs:domain ind:MesExecutionLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:materialUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Material Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the material quantity (e.g., kg, L, gal, lbs). Essential for accurate material accounting.' ;
    rdfs:domain ind:MesExecutionLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Operation Sequence Number' ;
    rdfs:comment 'Sequential order number of this operation within the process order or batch. Defines the execution order of steps.' ;
    rdfs:domain ind:MesExecutionLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operatorResponseText rdf:type rdf:Property ;
    rdfs:label 'Operator Response Text' ;
    rdfs:comment 'Free-text response or confirmation entered by the operator in response to the instruction. May include observations, comments, or verification statements.' ;
    rdfs:domain ind:MesExecutionLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parameterUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Parameter Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the parameter value (e.g., Celsius, PSI, pH units, RPM, L/min). Essential for correct interpretation of parameter values.' ;
    rdfs:domain ind:MesExecutionLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parameterValue rdf:type rdf:Property ;
    rdfs:label 'Parameter Value' ;
    rdfs:comment 'Actual numeric value of the process parameter entered or recorded during execution. Represents the measured or set value for the parameter.' ;
    rdfs:domain ind:MesExecutionLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recipePhaseCode rdf:type rdf:Property ;
    rdfs:label 'Recipe Phase Code' ;
    rdfs:comment 'Code identifying the specific recipe phase or operation step executed (e.g., CHARGE, HEAT, REACT, COOL, DISCHARGE). Corresponds to the master recipe definition.' ;
    rdfs:domain ind:MesExecutionLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipePhaseName rdf:type rdf:Property ;
    rdfs:label 'Recipe Phase Name' ;
    rdfs:comment 'Human-readable name of the recipe phase or operation step executed. Provides business context for the phase code.' ;
    rdfs:domain ind:MesExecutionLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordLockedFlag rdf:type rdf:Property ;
    rdfs:label 'Record Locked Flag' ;
    rdfs:comment 'Boolean indicator of whether this execution log record is locked and cannot be modified. True indicates the record is finalized and part of the permanent batch record.' ;
    rdfs:domain ind:MesExecutionLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recordModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Modified Timestamp' ;
    rdfs:comment 'Date and time when this execution log record was last modified. Tracks changes to the electronic batch record for audit purposes.' ;
    rdfs:domain ind:MesExecutionLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:signatureMeaning rdf:type rdf:Property ;
    rdfs:label 'Signature Meaning' ;
    rdfs:comment 'The meaning or intent of the electronic signature (e.g., performed, reviewed, approved, verified). Defines what the signature certifies.' ;
    rdfs:domain ind:MesExecutionLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processChangeRecordId rdf:type rdf:Property ;
    rdfs:label 'Process Change Record Id' ;
    rdfs:comment 'Unique identifier for the Management of Change (MOC) record. Primary key for process change tracking and PSM compliance.' ;
    rdfs:domain ind:ProcessChangeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryProcessInitiatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Process Initiator Employee Id' ;
    rdfs:comment 'Employee identifier of the person who initiated the change request.' ;
    rdfs:domain ind:ProcessChangeRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualImplementationDate rdf:type rdf:Property ;
    rdfs:label 'Actual Implementation Date' ;
    rdfs:comment 'Actual date when the change was implemented in the production environment.' ;
    rdfs:domain ind:ProcessChangeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:affectedEquipmentTag rdf:type rdf:Property ;
    rdfs:label 'Affected Equipment Tag' ;
    rdfs:comment 'Equipment tag number or identifier for the specific equipment affected by the change, referencing P&ID documentation.' ;
    rdfs:domain ind:ProcessChangeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedProcessUnit rdf:type rdf:Property ;
    rdfs:label 'Affected Process Unit' ;
    rdfs:comment 'Identification of the process unit, production line, or manufacturing area impacted by the change.' ;
    rdfs:domain ind:ProcessChangeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedSopNumber rdf:type rdf:Property ;
    rdfs:label 'Affected Sop Number' ;
    rdfs:comment 'Identifier of the SOP document that requires revision as a result of this change.' ;
    rdfs:domain ind:ProcessChangeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalWorkflowStage rdf:type rdf:Property ;
    rdfs:label 'Approval Workflow Stage' ;
    rdfs:comment 'Current stage in the multi-level approval workflow (e.g., supervisor review, engineering review, safety review, management approval).' ;
    rdfs:domain ind:ProcessChangeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeCategory rdf:type rdf:Property ;
    rdfs:label 'Change Category' ;
    rdfs:comment 'Duration classification of the change: temporary (time-limited trial), permanent (long-term modification), or emergency (immediate safety-driven change).' ;
    rdfs:domain ind:ProcessChangeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentReferences rdf:type rdf:Property ;
    rdfs:label 'Document References' ;
    rdfs:comment 'List of supporting documents associated with the MOC, including P&IDs, SOPs, risk assessments, training materials, and approval forms.' ;
    rdfs:domain ind:ProcessChangeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazopReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Hazop Reference Number' ;
    rdfs:comment 'Reference identifier for the HAZOP study conducted to evaluate the change.' ;
    rdfs:domain ind:ProcessChangeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implementationNotes rdf:type rdf:Property ;
    rdfs:label 'Implementation Notes' ;
    rdfs:comment 'Detailed notes documenting the implementation process, any deviations from the plan, and observations during execution.' ;
    rdfs:domain ind:ProcessChangeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phaReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Pha Reference Number' ;
    rdfs:comment 'Reference identifier for the associated PHA or HAZOP study conducted to evaluate the change.' ;
    rdfs:domain ind:ProcessChangeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedImplementationDate rdf:type rdf:Property ;
    rdfs:label 'Planned Implementation Date' ;
    rdfs:comment 'Scheduled date for implementing the approved change in the production environment.' ;
    rdfs:domain ind:ProcessChangeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:postImplementationReviewRequired rdf:type rdf:Property ;
    rdfs:label 'Post Implementation Review Required' ;
    rdfs:comment 'Indicates whether a post-implementation review is required to verify the change achieved its objectives and did not introduce new hazards.' ;
    rdfs:domain ind:ProcessChangeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:processChangeRecordDescription rdf:type rdf:Property ;
    rdfs:label 'Process Change Record Description' ;
    rdfs:comment 'Detailed narrative description of the proposed change, including technical specifications, scope, and rationale for the modification.' ;
    rdfs:domain ind:ProcessChangeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processChangeRecordStatus rdf:type rdf:Property ;
    rdfs:label 'Process Change Record Status' ;
    rdfs:comment 'Current lifecycle status of the MOC record in the approval and implementation workflow. [ENUM-REF-CANDIDATE: draft|submitted|under_review|approved|rejected|implementation|completed|closed — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ProcessChangeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Required' ;
    rdfs:comment 'Indicates whether regulatory agencies (EPA, OSHA, ECHA, FDA) must be notified of this change due to compliance requirements.' ;
    rdfs:domain ind:ProcessChangeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riskAssessmentRequired rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Required' ;
    rdfs:comment 'Indicates whether a formal risk assessment (PHA, HAZOP, or other methodology) is required for this change.' ;
    rdfs:domain ind:ProcessChangeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trainingCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Training Completion Date' ;
    rdfs:comment 'Date when all required training for affected personnel was completed.' ;
    rdfs:domain ind:ProcessChangeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:batchSizeCategory rdf:type rdf:Property ;
    rdfs:label 'Batch Size Category' ;
    rdfs:comment 'Classification of process order scale. Lab for R&D bench-scale (<10kg), pilot for scale-up trials (10-1000kg), commercial for standard production (>1000kg), full_scale for maximum reactor capacity utilization.' ;
    rdfs:domain ind:ProcessOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dcsSystemReference rdf:type rdf:Property ;
    rdfs:label 'Dcs System Reference' ;
    rdfs:comment 'Identifier for the DCS or SCADA system instance managing this process order. Maps to Honeywell Experion, Siemens SIMATIC PCS 7, or Aveva PI System historian for real-time data integration.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalPermitNumber rdf:type rdf:Property ;
    rdfs:label 'Environmental Permit Number' ;
    rdfs:comment 'EPA or state environmental permit number authorizing manufacture of this chemical. Required for VOC (Volatile Organic Compound), HAP (Hazardous Air Pollutant), and TRI reportable substances. Links to air quality monitoring and emissions reporting.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mesIntegrationStatus rdf:type rdf:Property ;
    rdfs:label 'Mes Integration Status' ;
    rdfs:comment 'Status of process order synchronization with MES. Tracks order handoff from SAP PP to shop floor execution system. Failed status triggers manual intervention and CAPA (Corrective and Preventive Action) workflow.' ;
    rdfs:domain ind:ProcessOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedEndTime rdf:type rdf:Property ;
    rdfs:label 'Planned End Time' ;
    rdfs:comment 'Precise timestamp for scheduled process order completion. Includes reaction time, cooling, CIP (Clean In Place), and quality hold time.' ;
    rdfs:domain ind:ProcessOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedStartTime rdf:type rdf:Property ;
    rdfs:label 'Planned Start Time' ;
    rdfs:comment 'Precise timestamp for scheduled process order start. Critical for continuous processes and multi-stage reaction sequences requiring tight timing control.' ;
    rdfs:domain ind:ProcessOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:processOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Process Order Number' ;
    rdfs:comment 'Externally visible business identifier for the process order. Unique alphanumeric code used across SAP PP, MES (Manufacturing Execution System), and DCS (Distributed Control System) integration points.' ;
    rdfs:domain ind:ProcessOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionLine rdf:type rdf:Property ;
    rdfs:label 'Production Line' ;
    rdfs:comment 'Identifier for the specific production line, reactor train, or blending unit where the process order is scheduled. Links to P&ID (Piping and Instrumentation Diagram) and SCADA (Supervisory Control and Data Acquisition) tag hierarchy.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipeNumber rdf:type rdf:Property ;
    rdfs:label 'Recipe Number' ;
    rdfs:comment 'Identifier for the master recipe (PI sheet) that defines the synthesis pathway, reaction sequence, process parameters, and control strategy. Links to BOM (Bill of Materials), routing, and control recipe in DCS.' ;
    rdfs:domain ind:ProcessOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceFlag rdf:type rdf:Property ;
    rdfs:label 'Variance Flag' ;
    rdfs:comment 'Boolean indicator that actual results (yield, cycle time, cost) deviated significantly from plan. True triggers variance analysis workflow and potential RCI (Root Cause Investigation) for process improvement.' ;
    rdfs:domain ind:ProcessOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:processParameterId rdf:type rdf:Property ;
    rdfs:label 'Process Parameter Id' ;
    rdfs:comment 'Unique identifier for the process parameter record. Primary key for this entity.' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryProcessEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Process Employee Id' ;
    rdfs:comment 'Reference to the operator or technician who recorded or validated the parameter measurement, if applicable.' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:alarmPriority rdf:type rdf:Property ;
    rdfs:label 'Alarm Priority' ;
    rdfs:comment 'Priority level of the alarm triggered by this parameter measurement, if applicable.' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alarmTriggeredFlag rdf:type rdf:Property ;
    rdfs:label 'Alarm Triggered Flag' ;
    rdfs:comment 'Boolean flag indicating whether an alarm was triggered by the control system due to this parameter measurement (True if alarm triggered, False otherwise).' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:correctiveActionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether corrective action is required based on this parameter measurement (True if action required, False otherwise).' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deviationValue rdf:type rdf:Property ;
    rdfs:label 'Deviation Value' ;
    rdfs:comment 'Calculated deviation of the measured value from the set point (measured_value minus set_point_value).' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:engineeringUnit rdf:type rdf:Property ;
    rdfs:label 'Engineering Unit' ;
    rdfs:comment 'Unit of measure for the parameter value (e.g., Celsius, Fahrenheit, bar, psi, pH units, liters per minute, RPM, percent, ppm).' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:historianSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Historian Source System' ;
    rdfs:comment 'Name of the process historian system from which this parameter data was sourced (e.g., Aveva PI System, Honeywell PHD, OSIsoft PI).' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lowerSpecificationLimit rdf:type rdf:Property ;
    rdfs:label 'Lower Specification Limit' ;
    rdfs:comment 'Lower specification limit defining the minimum acceptable value for the parameter. Values below this limit may result in out-of-specification (OOS) product.' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parameterTagReference rdf:type rdf:Property ;
    rdfs:label 'Parameter Tag Reference' ;
    rdfs:comment 'Unique tag identifier from the DCS (Distributed Control System), SCADA (Supervisory Control and Data Acquisition), or PLC (Programmable Logic Controller) system that sources this parameter. Used for traceability to Honeywell Experion, Siemens PCS 7, or Aveva PI System.' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phaseName rdf:type rdf:Property ;
    rdfs:label 'Phase Name' ;
    rdfs:comment 'Name of the batch phase or process step during which this parameter was measured (e.g., Charging, Reaction, Distillation, Cooling, Discharge).' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Impact Flag' ;
    rdfs:comment 'Boolean flag indicating whether this parameter measurement has potential impact on product quality (True if quality impact identified, False otherwise).' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewTimestamp rdf:type rdf:Property ;
    rdfs:label 'Review Timestamp' ;
    rdfs:comment 'Date and time when the parameter record was reviewed and approved by quality assurance. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:samplingIntervalSeconds rdf:type rdf:Property ;
    rdfs:label 'Sampling Interval Seconds' ;
    rdfs:comment 'Time interval in seconds between consecutive parameter measurements or samples.' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:setPointValue rdf:type rdf:Property ;
    rdfs:label 'Set Point Value' ;
    rdfs:comment 'Target or desired value for the process parameter as defined by the process recipe or control system.' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spcViolationFlag rdf:type rdf:Property ;
    rdfs:label 'Spc Violation Flag' ;
    rdfs:comment 'Boolean flag indicating whether the measured value violated SPC control limits (True if violation detected, False otherwise).' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specificationViolationFlag rdf:type rdf:Property ;
    rdfs:label 'Specification Violation Flag' ;
    rdfs:comment 'Boolean flag indicating whether the measured value violated specification limits (True if out-of-specification, False otherwise).' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:upperSpecificationLimit rdf:type rdf:Property ;
    rdfs:label 'Upper Specification Limit' ;
    rdfs:comment 'Upper specification limit defining the maximum acceptable value for the parameter. Values exceeding this limit may result in out-of-specification (OOS) product.' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deviationId rdf:type rdf:Property ;
    rdfs:label 'Deviation Id' ;
    rdfs:comment 'FK to quality.deviation.deviation_id — Production deviations must link to formal quality deviation investigations for cGMP compliance. Enables \'find all deviations for batch X\' queries spanning production and quality.' ;
    rdfs:domain ind:ProductionDeviation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QualityDeviation .

ind:primaryProductionReportedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Production Reported By Employee Id' ;
    rdfs:comment 'Reference to the employee who reported the deviation.' ;
    rdfs:domain ind:ProductionDeviation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryProductionApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Production Approved By Employee Id' ;
    rdfs:comment 'Reference to the QA manager or authorized employee who approved the deviation closure.' ;
    rdfs:domain ind:ProductionDeviation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:customerNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Date' ;
    rdfs:comment 'Date when affected customers were notified of the deviation, if applicable.' ;
    rdfs:domain ind:ProductionDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customerNotificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Required Flag' ;
    rdfs:comment 'Boolean indicator whether customers must be notified of this deviation due to potential product quality or safety impact.' ;
    rdfs:domain ind:ProductionDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:detectedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Detected Timestamp' ;
    rdfs:comment 'Date and time when the deviation was first detected or observed during production.' ;
    rdfs:domain ind:ProductionDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:holdInitiatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Hold Initiated Timestamp' ;
    rdfs:comment 'Date and time when a quality or production hold was placed on the affected batch, if applicable.' ;
    rdfs:domain ind:ProductionDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:holdReleasedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Hold Released Timestamp' ;
    rdfs:comment 'Date and time when the hold was released and the batch was cleared for further processing or shipment.' ;
    rdfs:domain ind:ProductionDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:immediateActionTaken rdf:type rdf:Property ;
    rdfs:label 'Immediate Action Taken' ;
    rdfs:comment 'Description of the immediate corrective actions taken at the time of deviation detection to contain the issue.' ;
    rdfs:domain ind:ProductionDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Investigation Completed Timestamp' ;
    rdfs:comment 'Date and time when the root cause investigation was completed and documented.' ;
    rdfs:domain ind:ProductionDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ootFlag rdf:type rdf:Property ;
    rdfs:label 'Oot Flag' ;
    rdfs:comment 'Boolean indicator whether this deviation represents an out-of-trend (OOT) condition in process or quality data.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preventiveAction rdf:type rdf:Property ;
    rdfs:label 'Preventive Action' ;
    rdfs:comment 'Description of the preventive actions taken to eliminate potential causes of similar deviations in the future.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionDeviationDescription rdf:type rdf:Property ;
    rdfs:label 'Production Deviation Description' ;
    rdfs:comment 'Detailed narrative description of the deviation event, including what was observed and the circumstances.' ;
    rdfs:domain ind:ProductionDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionDeviationStatus rdf:type rdf:Property ;
    rdfs:label 'Production Deviation Status' ;
    rdfs:comment 'Current lifecycle status of the deviation: open (newly reported), under_investigation (root cause analysis in progress), pending_approval (awaiting management review), closed (resolved and approved), cancelled (determined not a deviation).' ;
    rdfs:domain ind:ProductionDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Date' ;
    rdfs:comment 'Date when the deviation was reported to the relevant regulatory authority, if applicable.' ;
    rdfs:domain ind:ProductionDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reactionStepId rdf:type rdf:Property ;
    rdfs:label 'Reaction Step Id' ;
    rdfs:comment 'Unique identifier for the reaction step within the chemical synthesis sequence. Primary key for the reaction step entity.' ;
    rdfs:domain ind:ReactionStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:phaseId rdf:type rdf:Property ;
    rdfs:label 'Phase Id' ;
    rdfs:comment 'Control recipe phase identifier from the Manufacturing Execution System (MES). Maps the step to the DCS or PLC phase for automation execution.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Phase .

ind:primaryReactionEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Reaction Employee Id' ;
    rdfs:comment 'Reference to the operator or technician who executed or supervised the reaction step. Required for GMP batch record traceability.' ;
    rdfs:domain ind:ReactionStep ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:synthesisProcedureId rdf:type rdf:Property ;
    rdfs:label 'Synthesis Procedure Id' ;
    rdfs:comment 'Foreign key linking to research.synthesis_procedure. Business justification: Links each production reaction step to the validated R&D synthesis procedure, supporting SOP enforcement and deviation investigations.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SynthesisProcedure .

ind:criticalStepFlag rdf:type rdf:Property ;
    rdfs:label 'Critical Step Flag' ;
    rdfs:comment 'Indicates whether this step is a critical control point requiring enhanced monitoring, verification, or approval. Used for Good Manufacturing Practice (GMP) and Process Safety Management (PSM) compliance.' ;
    rdfs:domain ind:ReactionStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:materialChargeQuantity rdf:type rdf:Property ;
    rdfs:label 'Material Charge Quantity' ;
    rdfs:comment 'Quantity of material charged or added during this reaction step. Applicable for charge-type steps and used for Bill of Materials (BOM) consumption tracking.' ;
    rdfs:domain ind:ReactionStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:materialChargeUom rdf:type rdf:Property ;
    rdfs:label 'Material Charge Uom' ;
    rdfs:comment 'Unit of measure for the material charge quantity (e.g., kg, L, mol). Ensures proper inventory consumption and yield calculation.' ;
    rdfs:domain ind:ReactionStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredEquipmentType rdf:type rdf:Property ;
    rdfs:label 'Required Equipment Type' ;
    rdfs:comment 'Type or class of equipment required to execute this reaction step (e.g., reactor, distillation column, filter press, blender). Used for resource allocation and scheduling.' ;
    rdfs:domain ind:ReactionStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scadaTagReference rdf:type rdf:Property ;
    rdfs:label 'Scada Tag Reference' ;
    rdfs:comment 'Reference to the SCADA or process historian (Aveva PI System) tag that captures real-time process data for this reaction step. Enables linkage to time-series process data.' ;
    rdfs:domain ind:ReactionStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sequenceOrder rdf:type rdf:Property ;
    rdfs:label 'Sequence Order' ;
    rdfs:comment 'Execution order within the overall synthesis sequence. May differ from step_number if parallel or conditional steps exist.' ;
    rdfs:domain ind:ReactionStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sopReference rdf:type rdf:Property ;
    rdfs:label 'Sop Reference' ;
    rdfs:comment 'Reference to the Standard Operating Procedure document governing the execution of this reaction step. Ensures compliance with documented procedures.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stepEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Step End Timestamp' ;
    rdfs:comment 'Date and time when the reaction step execution completed. Used to calculate actual duration and for batch genealogy tracking.' ;
    rdfs:domain ind:ReactionStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:stepName rdf:type rdf:Property ;
    rdfs:label 'Step Name' ;
    rdfs:comment 'Descriptive name of the reaction step (e.g., Charge Reactant A, Heat to Reflux, Cool and Filter). Provides human-readable identification of the process phase.' ;
    rdfs:domain ind:ReactionStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stepNotes rdf:type rdf:Property ;
    rdfs:label 'Step Notes' ;
    rdfs:comment 'Free-text notes or comments recorded by the operator during the execution of this reaction step. Captures observations, adjustments, or contextual information for the batch record.' ;
    rdfs:domain ind:ReactionStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stepStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Step Start Timestamp' ;
    rdfs:comment 'Date and time when the reaction step execution began. Captured from MES or DCS for process traceability and batch record documentation.' ;
    rdfs:domain ind:ReactionStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:stepType rdf:type rdf:Property ;
    rdfs:label 'Step Type' ;
    rdfs:comment 'Classification of the reaction step operation type. Defines the nature of the process activity being performed. [ENUM-REF-CANDIDATE: charge|heat|react|cool|filter|distill|blend|transfer|clean|sample|hold|neutralize|crystallize|dry — 14 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ReactionStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Target Duration Minutes' ;
    rdfs:comment 'Planned or target duration for the reaction step in minutes as defined in the master recipe. Used for scheduling and capacity planning.' ;
    rdfs:domain ind:ReactionStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetPh rdf:type rdf:Property ;
    rdfs:label 'Target Ph' ;
    rdfs:comment 'Target pH level for the reaction step. Critical for acid-base reactions, neutralization, and pH-sensitive synthesis processes.' ;
    rdfs:domain ind:ReactionStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduleId rdf:type rdf:Property ;
    rdfs:label 'Schedule Id' ;
    rdfs:comment 'Primary key for schedule' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billOfMaterialsId rdf:type rdf:Property ;
    rdfs:label 'Bill Of Materials Id' ;
    rdfs:comment 'Reference to the Bill of Materials that defines the raw material components and quantities required for this scheduled production.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillOfMaterials .

ind:qualityPlanId rdf:type rdf:Property ;
    rdfs:label 'Quality Plan Id' ;
    rdfs:comment 'Reference to the quality control plan that defines the inspection points, test methods, and acceptance criteria for this scheduled production.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InspectionPlan .

ind:capacityRequirementHours rdf:type rdf:Property ;
    rdfs:label 'Capacity Requirement Hours' ;
    rdfs:comment 'The total work center capacity required to complete this schedule, expressed in machine hours or labor hours.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:completedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Completed Timestamp' ;
    rdfs:comment 'The date and time when this scheduled production was completed and confirmed in the system.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:expectedYieldPercentage rdf:type rdf:Property ;
    rdfs:label 'Expected Yield Percentage' ;
    rdfs:comment 'The expected production yield as a percentage of theoretical maximum, accounting for normal process losses, waste, and off-spec material.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:frozenFlag rdf:type rdf:Property ;
    rdfs:label 'Frozen Flag' ;
    rdfs:comment 'Indicates whether this schedule is frozen and locked from further changes, typically within the frozen planning horizon where changes require special approval.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorityRank rdf:type rdf:Property ;
    rdfs:label 'Priority Rank' ;
    rdfs:comment 'Numeric priority ranking for scheduling sequence, where lower numbers indicate higher priority. Used for sequencing when multiple schedules compete for the same work center.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:releasedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Released Timestamp' ;
    rdfs:comment 'The date and time when this schedule was released for execution to the Manufacturing Execution System (MES) or shop floor.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:runTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Run Time Minutes' ;
    rdfs:comment 'The estimated production run time in minutes to manufacture the planned quantity, excluding setup and changeover.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:safetyReviewRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Review Required Flag' ;
    rdfs:comment 'Indicates whether this schedule requires a safety review or Process Hazard Analysis (PHA) before execution, typically for new products, process changes, or hazardous materials.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduleStatus rdf:type rdf:Property ;
    rdfs:label 'Schedule Status' ;
    rdfs:comment 'Current lifecycle status of the production schedule: planned (initial draft), firmed (committed but not released), released (authorized for execution), in_progress (actively running), completed (finished), cancelled (voided).' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledEndDatetime rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Datetime' ;
    rdfs:comment 'The planned date and time when production is scheduled to complete for this schedule entry.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledStartDatetime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Datetime' ;
    rdfs:comment 'The planned date and time when production is scheduled to begin for this schedule entry.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:schedulingConstraintNotes rdf:type rdf:Property ;
    rdfs:label 'Scheduling Constraint Notes' ;
    rdfs:comment 'Free-text notes capturing any special scheduling constraints, dependencies, or considerations such as raw material availability, regulatory windows, customer delivery commitments, or equipment maintenance windows.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schedulingMethod rdf:type rdf:Property ;
    rdfs:label 'Scheduling Method' ;
    rdfs:comment 'The scheduling algorithm used to create this schedule: forward (from earliest start), backward (from required delivery), finite (capacity-constrained), or infinite (capacity-unconstrained).' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:setupTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Setup Time Minutes' ;
    rdfs:comment 'The time in minutes required to set up equipment, load raw materials, and prepare the work center before production can begin.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftPattern rdf:type rdf:Property ;
    rdfs:label 'Shift Pattern' ;
    rdfs:comment 'The shift pattern during which this production is scheduled to run (day, night, swing, continuous 24/7, or weekend).' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftLogId rdf:type rdf:Property ;
    rdfs:label 'Shift Log Id' ;
    rdfs:comment 'Unique identifier for the shift log record. Primary key for the shift log entity.' ;
    rdfs:domain ind:ShiftLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dcsSystemStatus rdf:type rdf:Property ;
    rdfs:label 'Dcs System Status' ;
    rdfs:comment 'Operational status of the Distributed Control System during the shift.' ;
    rdfs:domain ind:ShiftLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentDowntimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Equipment Downtime Minutes' ;
    rdfs:comment 'Total minutes of unplanned equipment downtime during the shift.' ;
    rdfs:domain ind:ShiftLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:equipmentIssuesNoted rdf:type rdf:Property ;
    rdfs:label 'Equipment Issues Noted' ;
    rdfs:comment 'Description of any equipment malfunctions, breakdowns, or performance issues observed during the shift.' ;
    rdfs:domain ind:ShiftLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyEventsNarrative rdf:type rdf:Property ;
    rdfs:label 'Key Events Narrative' ;
    rdfs:comment 'Free-text narrative documenting significant events, observations, and activities that occurred during the shift.' ;
    rdfs:domain ind:ShiftLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialShortagesFlagged rdf:type rdf:Property ;
    rdfs:label 'Material Shortages Flagged' ;
    rdfs:comment 'Description of any raw material or component shortages identified during the shift that impacted production.' ;
    rdfs:domain ind:ShiftLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mocActivities rdf:type rdf:Property ;
    rdfs:label 'Moc Activities' ;
    rdfs:comment 'Documentation of any Management of Change activities or temporary process modifications implemented during the shift.' ;
    rdfs:domain ind:ShiftLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processDeviationsNoted rdf:type rdf:Property ;
    rdfs:label 'Process Deviations Noted' ;
    rdfs:comment 'Description of any deviations from standard operating procedures or master recipes observed during the shift.' ;
    rdfs:domain ind:ShiftLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionArea rdf:type rdf:Property ;
    rdfs:label 'Production Area' ;
    rdfs:comment 'Name or designation of the production area or manufacturing zone covered during the shift.' ;
    rdfs:domain ind:ShiftLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionOrdersActive rdf:type rdf:Property ;
    rdfs:label 'Production Orders Active' ;
    rdfs:comment 'Count of production orders that were active or in-progress during the shift.' ;
    rdfs:domain ind:ShiftLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productionOutputQuantity rdf:type rdf:Property ;
    rdfs:label 'Production Output Quantity' ;
    rdfs:comment 'Total quantity of product manufactured during the shift.' ;
    rdfs:domain ind:ShiftLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productionOutputUom rdf:type rdf:Property ;
    rdfs:label 'Production Output Uom' ;
    rdfs:comment 'Unit of measure for the production output quantity (e.g., kg, liters, tons, gallons).' ;
    rdfs:domain ind:ShiftLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityHoldsNoted rdf:type rdf:Property ;
    rdfs:label 'Quality Holds Noted' ;
    rdfs:comment 'Documentation of any quality holds, Out of Specification (OOS) events, or quality concerns raised during the shift.' ;
    rdfs:domain ind:ShiftLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityIssuesCount rdf:type rdf:Property ;
    rdfs:label 'Quality Issues Count' ;
    rdfs:comment 'Number of quality-related issues or deviations identified during the shift.' ;
    rdfs:domain ind:ShiftLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:safetyIncidentsCount rdf:type rdf:Property ;
    rdfs:label 'Safety Incidents Count' ;
    rdfs:comment 'Number of safety incidents or near-miss events recorded during the shift.' ;
    rdfs:domain ind:ShiftLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scadaAlarmsCount rdf:type rdf:Property ;
    rdfs:label 'Scada Alarms Count' ;
    rdfs:comment 'Total number of SCADA system alarms triggered during the shift.' ;
    rdfs:domain ind:ShiftLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shiftEndTime rdf:type rdf:Property ;
    rdfs:label 'Shift End Time' ;
    rdfs:comment 'Timestamp when the shift officially ended.' ;
    rdfs:domain ind:ShiftLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shiftStartTime rdf:type rdf:Property ;
    rdfs:label 'Shift Start Time' ;
    rdfs:comment 'Timestamp when the shift officially began.' ;
    rdfs:domain ind:ShiftLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shiftStatus rdf:type rdf:Property ;
    rdfs:label 'Shift Status' ;
    rdfs:comment 'Current lifecycle status of the shift log record.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingConducted rdf:type rdf:Property ;
    rdfs:label 'Training Conducted' ;
    rdfs:comment 'Description of any operator training, safety briefings, or skill development activities conducted during the shift.' ;
    rdfs:domain ind:ShiftLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utilityConsumptionNotes rdf:type rdf:Property ;
    rdfs:label 'Utility Consumption Notes' ;
    rdfs:comment 'Observations regarding utility consumption (electricity, steam, water, compressed air) during the shift.' ;
    rdfs:domain ind:ShiftLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visitorContractorActivity rdf:type rdf:Property ;
    rdfs:label 'Visitor Contractor Activity' ;
    rdfs:comment 'Documentation of any visitor or contractor activities on-site during the shift.' ;
    rdfs:domain ind:ShiftLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteGenerationNotes rdf:type rdf:Property ;
    rdfs:label 'Waste Generation Notes' ;
    rdfs:comment 'Documentation of waste generation, disposal activities, or environmental compliance observations during the shift.' ;
    rdfs:domain ind:ShiftLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleSupervisorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Responsible Supervisor Employee Id' ;
    rdfs:comment 'Employee identifier for the supervisor responsible for this work center, used for accountability and reporting.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:availableCapacityHoursPerDay rdf:type rdf:Property ;
    rdfs:label 'Available Capacity Hours Per Day' ;
    rdfs:comment 'Standard available operating hours per day for this work center, used in capacity planning and scheduling calculations.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchSizeUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Batch Size Unit Of Measure' ;
    rdfs:comment 'Unit of measure for batch size specifications (minimum and maximum) for this work center.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityCategory rdf:type rdf:Property ;
    rdfs:label 'Capacity Category' ;
    rdfs:comment 'Classification of capacity type used for production planning and scheduling calculations in SAP PP.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityUtilizationRatePercent rdf:type rdf:Property ;
    rdfs:label 'Capacity Utilization Rate Percent' ;
    rdfs:comment 'Current capacity utilization rate expressed as a percentage, indicating how much of available capacity is being used.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cipCleanInPlaceCapableFlag rdf:type rdf:Property ;
    rdfs:label 'Cip Clean In Place Capable Flag' ;
    rdfs:comment 'Indicates whether this work center is equipped with CIP (Clean In Place) automated cleaning systems for sanitation between production runs.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crewSizeStandard rdf:type rdf:Property ;
    rdfs:label 'Crew Size Standard' ;
    rdfs:comment 'Standard number of operators or crew members required to operate this work center during normal production.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dcsSystemType rdf:type rdf:Property ;
    rdfs:label 'Dcs System Type' ;
    rdfs:comment 'Type or vendor of the DCS system controlling this work center for process automation and monitoring.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:efficiencyFactorPercent rdf:type rdf:Property ;
    rdfs:label 'Efficiency Factor Percent' ;
    rdfs:comment 'Standard efficiency factor applied to capacity calculations, representing the expected performance level relative to theoretical maximum.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ehsPermitRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Ehs Permit Required Flag' ;
    rdfs:comment 'Indicates whether EHS (Environment Health and Safety) permits or special authorizations are required to operate this work center.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gmpClassification rdf:type rdf:Property ;
    rdfs:label 'Gmp Classification' ;
    rdfs:comment 'GMP (Good Manufacturing Practice) classification level for this work center, indicating compliance requirements for pharmaceutical or food-contact chemical production.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastMajorOverhaulDate rdf:type rdf:Property ;
    rdfs:label 'Last Major Overhaul Date' ;
    rdfs:comment 'Date of the most recent major overhaul or significant maintenance activity performed on this work center.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maximumBatchSize rdf:type rdf:Property ;
    rdfs:label 'Maximum Batch Size' ;
    rdfs:comment 'Maximum production batch size that can be processed at this work center, expressed in the standard unit of measure.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumBatchSize rdf:type rdf:Property ;
    rdfs:label 'Minimum Batch Size' ;
    rdfs:comment 'Minimum production batch size that can be processed at this work center, expressed in the standard unit of measure.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextPsrDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Psr Due Date' ;
    rdfs:comment 'Scheduled date for the next required Process Safety Review or PHA (Process Hazard Analysis) for this work center.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextScheduledMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Maintenance Date' ;
    rdfs:comment 'Date of the next scheduled preventive maintenance activity for this work center.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:oeeTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Oee Target Percent' ;
    rdfs:comment 'Target OEE (Overall Equipment Effectiveness) percentage for this work center, combining availability, performance, and quality metrics.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operationalStatus rdf:type rdf:Property ;
    rdfs:label 'Operational Status' ;
    rdfs:comment 'Current operational state of the work center indicating availability for production scheduling and execution.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phControlCapabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Ph Control Capability Flag' ;
    rdfs:comment 'Indicates whether this work center has automated pH (Potential of Hydrogen) control capabilities for chemical process management.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:piSystemTagPrefix rdf:type rdf:Property ;
    rdfs:label 'Pi System Tag Prefix' ;
    rdfs:comment 'Aveva PI System tag prefix used for real-time process data historian integration and time-series data collection from this work center.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plcControllerReference rdf:type rdf:Property ;
    rdfs:label 'Plc Controller Reference' ;
    rdfs:comment 'Identifier for the PLC (Programmable Logic Controller) managing discrete control functions for this work center.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pressureControlCapabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Pressure Control Capability Flag' ;
    rdfs:comment 'Indicates whether this work center has automated pressure control capabilities for process management.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:psrProcessSafetyReviewDate rdf:type rdf:Property ;
    rdfs:label 'Psr Process Safety Review Date' ;
    rdfs:comment 'Date of the most recent Process Safety Review or Process Hazard Analysis (PHA) conducted for this work center.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scadaNodeReference rdf:type rdf:Property ;
    rdfs:label 'Scada Node Reference' ;
    rdfs:comment 'SCADA (Supervisory Control and Data Acquisition) system node identifier for real-time monitoring and data collection from this work center.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teardownTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Teardown Time Minutes' ;
    rdfs:comment 'Standard teardown or cleanup time in minutes required after completing a production run at this work center.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureControlCapabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Control Capability Flag' ;
    rdfs:comment 'Indicates whether this work center has automated temperature control capabilities for process management.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workCenterCategory rdf:type rdf:Property ;
    rdfs:label 'Work Center Category' ;
    rdfs:comment 'Operational category indicating the processing mode and operational characteristics of the work center.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workCenterName rdf:type rdf:Property ;
    rdfs:label 'Work Center Name' ;
    rdfs:comment 'Descriptive name of the work center for human identification and reporting purposes.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workCenterType rdf:type rdf:Property ;
    rdfs:label 'Work Center Type' ;
    rdfs:comment 'Classification of the work center based on its primary production function within the chemical manufacturing process.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yieldRecordId rdf:type rdf:Property ;
    rdfs:label 'Yield Record Id' ;
    rdfs:comment 'Unique identifier for the yield record. Primary key for the yield record entity.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryYieldEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Yield Employee Id' ;
    rdfs:comment 'The employee or operator identifier who confirmed the yield and completed the batch record. Used for accountability and training effectiveness tracking.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:byProductCode rdf:type rdf:Property ;
    rdfs:label 'By Product Code' ;
    rdfs:comment 'The material code or SKU for the by-product generated. References the by-product master data in the materials management system.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:byProductQuantity rdf:type rdf:Property ;
    rdfs:label 'By Product Quantity' ;
    rdfs:comment 'The quantity of by-products or co-products generated during the production process. By-products may have commercial value or require disposal.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lossReasonCode rdf:type rdf:Property ;
    rdfs:label 'Loss Reason Code' ;
    rdfs:comment 'Categorical code indicating the primary reason for yield loss. Used for root cause analysis, process improvement, and CAPA (Corrective and Preventive Action) initiatives. [ENUM-REF-CANDIDATE: evaporation|spillage|sampling|reaction_inefficiency|filtration_loss|equipment_holdup|transfer_loss|quality_rejection|other — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedYieldQuantity rdf:type rdf:Property ;
    rdfs:label 'Planned Yield Quantity' ;
    rdfs:comment 'The theoretical or planned yield quantity expected from the production order based on the Bill of Materials (BOM) and process parameters. Represents the target output under ideal conditions.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productionEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Production End Timestamp' ;
    rdfs:comment 'The date and time when the production batch or run was completed and yield was confirmed. Used for cycle time analysis and OEE calculation.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:productionLineCode rdf:type rdf:Property ;
    rdfs:label 'Production Line Code' ;
    rdfs:comment 'Identifier for the production line, reactor, or processing unit where the batch was manufactured. May reference DCS (Distributed Control System) or MES (Manufacturing Execution System) equipment identifiers.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Production Start Timestamp' ;
    rdfs:comment 'The date and time when the production batch or run was started. Captured from MES (Manufacturing Execution System) or DCS (Distributed Control System) logs.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rawMaterialCost rdf:type rdf:Property ;
    rdfs:label 'Raw Material Cost' ;
    rdfs:comment 'The total cost of raw materials consumed in this production run. Used for cost accounting, COGS (Cost of Goods Sold) calculation, and yield-based profitability analysis.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recipeVersion rdf:type rdf:Property ;
    rdfs:label 'Recipe Version' ;
    rdfs:comment 'The version of the production recipe or master formula used for this batch. Critical for traceability and Management of Change (MOC) compliance.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:theoreticalYieldBasis rdf:type rdf:Property ;
    rdfs:label 'Theoretical Yield Basis' ;
    rdfs:comment 'The method or basis used to calculate the planned yield. Indicates whether the theoretical yield was derived from BOM standards, process simulation (e.g., Aspen HYSYS), historical averages, or lab/pilot scale data.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceThresholdPercentage rdf:type rdf:Property ;
    rdfs:label 'Variance Threshold Percentage' ;
    rdfs:comment 'The acceptable variance threshold percentage used to determine if yield_variance_flag should be set. Typically defined in process control plans or SOPs (Standard Operating Procedures).' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wasteClassification rdf:type rdf:Property ;
    rdfs:label 'Waste Classification' ;
    rdfs:comment 'Classification of the waste material for environmental and regulatory purposes. Indicates whether waste is hazardous, contains VOC (Volatile Organic Compounds), HAP (Hazardous Air Pollutants), or is recyclable.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteQuantity rdf:type rdf:Property ;
    rdfs:label 'Waste Quantity' ;
    rdfs:comment 'The quantity of waste material generated during production that requires disposal or treatment. Critical for environmental reporting and TRI (Toxics Release Inventory) compliance.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yieldConfirmationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Yield Confirmation Timestamp' ;
    rdfs:comment 'The date and time when the actual yield quantity was confirmed and recorded in the system. May differ from production_end_timestamp if post-production weighing or measurement is required.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:yieldEfficiencyScore rdf:type rdf:Property ;
    rdfs:label 'Yield Efficiency Score' ;
    rdfs:comment 'A normalized efficiency score (0-100) that factors in yield percentage, quality status, and process losses. Used for benchmarking and continuous improvement initiatives.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yieldLossQuantity rdf:type rdf:Property ;
    rdfs:label 'Yield Loss Quantity' ;
    rdfs:comment 'The total quantity of material lost during the production process due to evaporation, spillage, sampling, filtration loss, reaction inefficiency, or other process losses. Represents unrecoverable material.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yieldVarianceFlag rdf:type rdf:Property ;
    rdfs:label 'Yield Variance Flag' ;
    rdfs:comment 'Boolean flag indicating whether the yield variance exceeds acceptable tolerance limits. True indicates an out-of-specification (OOS) or out-of-trend (OOT) condition requiring investigation.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:yieldVarianceQuantity rdf:type rdf:Property ;
    rdfs:label 'Yield Variance Quantity' ;
    rdfs:comment 'The absolute difference between planned and actual yield (planned_yield_quantity - actual_yield_quantity). Positive values indicate under-production; negative values indicate over-production.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditId rdf:type rdf:Property ;
    rdfs:label 'Audit Id' ;
    rdfs:comment 'Primary key for audit' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Audit .

ind:leadAuditorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Lead Auditor Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Lead auditor is a designated employee; linking enables audit assignment tracking and regulatory reporting.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:auditNumber rdf:type rdf:Property ;
    rdfs:label 'Audit Number' ;
    rdfs:comment 'Business identifier assigned to the audit, used for tracking and reference.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditScope rdf:type rdf:Property ;
    rdfs:label 'Audit Scope' ;
    rdfs:comment 'Scope of the audit, e.g., ISO 9001, GMP, Process Safety, etc.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditStatus rdf:type rdf:Property ;
    rdfs:label 'Audit Status' ;
    rdfs:comment 'Current lifecycle status of the audit record.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditType rdf:type rdf:Property ;
    rdfs:label 'Audit Type' ;
    rdfs:comment 'Classification of the audit based on its origin or purpose.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionOwner rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Owner' ;
    rdfs:comment 'Name of the person or group responsible for implementing corrective actions.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalAuditor rdf:type rdf:Property ;
    rdfs:label 'External Auditor' ;
    rdfs:comment 'Name of the external auditor or audit firm, if applicable.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingsMajor rdf:type rdf:Property ;
    rdfs:label 'Findings Major' ;
    rdfs:comment 'Count of major non-conformance findings.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:findingsMinor rdf:type rdf:Property ;
    rdfs:label 'Findings Minor' ;
    rdfs:comment 'Count of minor non-conformance findings.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:findingsObservation rdf:type rdf:Property ;
    rdfs:label 'Findings Observation' ;
    rdfs:comment 'Count of observation-type findings.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:findingsOfi rdf:type rdf:Property ;
    rdfs:label 'Findings Ofi' ;
    rdfs:comment 'Count of OFI-type findings.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:findingsTotal rdf:type rdf:Property ;
    rdfs:label 'Findings Total' ;
    rdfs:comment 'Total number of findings recorded for the audit.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:leadAuditor rdf:type rdf:Property ;
    rdfs:label 'Lead Auditor' ;
    rdfs:comment 'Name of the primary auditor responsible for the audit.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulationReference rdf:type rdf:Property ;
    rdfs:label 'Regulation Reference' ;
    rdfs:comment 'Specific regulation or clause referenced by the audit.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standard rdf:type rdf:Property ;
    rdfs:label 'Standard' ;
    rdfs:comment 'Standard or regulation against which the audit is performed.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:team rdf:type rdf:Property ;
    rdfs:label 'Team' ;
    rdfs:comment 'Comma-separated list of auditors participating in the audit.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typeDetail rdf:type rdf:Property ;
    rdfs:label 'Type Detail' ;
    rdfs:comment 'Additional detail describing the audit type, e.g., supplier certification, customer compliance.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationStatus rdf:type rdf:Property ;
    rdfs:label 'Verification Status' ;
    rdfs:comment 'Status of verification for the corrective action.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditFindingId rdf:type rdf:Property ;
    rdfs:label 'Audit Finding Id' ;
    rdfs:comment 'System-generated unique identifier for each audit finding.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:evidenceDocumentId rdf:type rdf:Property ;
    rdfs:label 'Evidence Document Id' ;
    rdfs:comment 'Identifier of the document or file that provides evidence for the finding.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EvidenceDocument .

ind:primaryAuditEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Audit Employee Id' ;
    rdfs:comment 'Identifier of the person or team assigned to address the finding.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryAuditUpdatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Audit Updated By User Employee Id' ;
    rdfs:comment 'Identifier of the system user who performed the latest update.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:affectedProcess rdf:type rdf:Property ;
    rdfs:label 'Affected Process' ;
    rdfs:comment 'Name or code of the process, unit, or operation impacted by the finding.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditFindingDescription rdf:type rdf:Property ;
    rdfs:label 'Audit Finding Description' ;
    rdfs:comment 'Detailed narrative of the audit observation or non-conformance.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditFindingSource rdf:type rdf:Property ;
    rdfs:label 'Audit Finding Source' ;
    rdfs:comment 'Indicates whether the finding originated from an internal audit or an external party.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditFindingStatus rdf:type rdf:Property ;
    rdfs:label 'Audit Finding Status' ;
    rdfs:comment 'Current lifecycle status of the audit finding.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clauseReference rdf:type rdf:Property ;
    rdfs:label 'Clause Reference' ;
    rdfs:comment 'Reference to the ISO 9001 or GMP clause that the finding relates to.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryClause rdf:type rdf:Property ;
    rdfs:label 'Regulatory Clause' ;
    rdfs:comment 'Specific regulatory requirement (e.g., EPA, OSHA, REACH) cited by the finding.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseDescription rdf:type rdf:Property ;
    rdfs:label 'Response Description' ;
    rdfs:comment 'Textual description of the corrective or preventive action proposed.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseSubmittedDate rdf:type rdf:Property ;
    rdfs:label 'Response Submitted Date' ;
    rdfs:comment 'Date on which the corrective response was actually submitted.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capaQualityDeviationId rdf:type rdf:Property ;
    rdfs:label 'Capa Quality Deviation Id' ;
    rdfs:comment 'Reference to the Out-of-Specification event that triggered the CAPA, if applicable.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QualityDeviation .

ind:capaRelatedQualityNotificationQualityNotificationQualityDeviationId rdf:type rdf:Property ;
    rdfs:label 'Capa Related Quality Notification Quality Notification Quality Deviation Id' ;
    rdfs:comment 'Reference to a quality notification (e.g., OOS, OOT) linked to this CAPA.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QualityDeviation .

ind:auditTrailNotes rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Notes' ;
    rdfs:comment 'Free-form notes capturing audit trail comments, approvals, or change history.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaDescription rdf:type rdf:Property ;
    rdfs:label 'Capa Description' ;
    rdfs:comment 'Detailed narrative of the issue, its impact, and the rationale for the CAPA.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaStatus rdf:type rdf:Property ;
    rdfs:label 'Capa Status' ;
    rdfs:comment 'Current lifecycle state of the CAPA record.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaType rdf:type rdf:Property ;
    rdfs:label 'Capa Type' ;
    rdfs:comment 'Indicates whether the action addresses an existing issue (corrective) or aims to prevent future occurrence (preventive).' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivenessOutcome rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Outcome' ;
    rdfs:comment 'Result of the effectiveness verification.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivenessVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Verification Date' ;
    rdfs:comment 'Date on which the effectiveness of the CAPA was evaluated.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gmpCompliance rdf:type rdf:Property ;
    rdfs:label 'Gmp Compliance' ;
    rdfs:comment 'Indicates whether the CAPA satisfies Good Manufacturing Practice requirements.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rciMethod rdf:type rdf:Property ;
    rdfs:label 'Rci Method' ;
    rdfs:comment 'Methodology used to determine the root cause.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Target Completion Date' ;
    rdfs:comment 'Planned date by which the corrective or preventive action should be completed.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verificationResult rdf:type rdf:Property ;
    rdfs:label 'Verification Result' ;
    rdfs:comment 'Outcome of the verification activity.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cocRecordId rdf:type rdf:Property ;
    rdfs:label 'Coc Record Id' ;
    rdfs:comment 'System-generated surrogate primary key for the certificate record.' ;
    rdfs:domain ind:CocRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryCocEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Coc Employee Id' ;
    rdfs:comment 'Identifier of the QA employee who approved the certificate.' ;
    rdfs:domain ind:CocRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:archiveTimestamp rdf:type rdf:Property ;
    rdfs:label 'Archive Timestamp' ;
    rdfs:comment 'Timestamp when the certificate was moved to archive.' ;
    rdfs:domain ind:CocRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:batchQuantity rdf:type rdf:Property ;
    rdfs:label 'Batch Quantity' ;
    rdfs:comment 'Quantity of product produced in the batch.' ;
    rdfs:domain ind:CocRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificateType rdf:type rdf:Property ;
    rdfs:label 'Certificate Type' ;
    rdfs:comment 'Indicates whether the document is a Certificate of Analysis (COA) or Certificate of Compliance (COC).' ;
    rdfs:domain ind:CocRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cocRecordStatus rdf:type rdf:Property ;
    rdfs:label 'Coc Record Status' ;
    rdfs:comment 'Current lifecycle status of the certificate.' ;
    rdfs:domain ind:CocRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceStatement rdf:type rdf:Property ;
    rdfs:label 'Compliance Statement' ;
    rdfs:comment 'Textual statement affirming compliance with applicable specifications and regulations.' ;
    rdfs:domain ind:CocRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionList rdf:type rdf:Property ;
    rdfs:label 'Distribution List' ;
    rdfs:comment 'Comma-separated list of internal or external recipients of the certificate.' ;
    rdfs:domain ind:CocRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failedTestCount rdf:type rdf:Property ;
    rdfs:label 'Failed Test Count' ;
    rdfs:comment 'Number of tests that did not meet specification limits.' ;
    rdfs:domain ind:CocRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isArchived rdf:type rdf:Property ;
    rdfs:label 'Is Archived' ;
    rdfs:comment 'Indicates whether the certificate record has been archived.' ;
    rdfs:domain ind:CocRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCustomerSpecific rdf:type rdf:Property ;
    rdfs:label 'Is Customer Specific' ;
    rdfs:comment 'Indicates whether the certificate includes customer-specific requirements or format.' ;
    rdfs:domain ind:CocRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overallResult rdf:type rdf:Property ;
    rdfs:label 'Overall Result' ;
    rdfs:comment 'Overall pass/fail outcome of the certificate based on specifications.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passedTestCount rdf:type rdf:Property ;
    rdfs:label 'Passed Test Count' ;
    rdfs:comment 'Number of tests that met specification limits.' ;
    rdfs:domain ind:CocRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qaSignatoryName rdf:type rdf:Property ;
    rdfs:label 'Qa Signatory Name' ;
    rdfs:comment 'Name of the Quality Assurance person who approved the certificate.' ;
    rdfs:domain ind:CocRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryComplianceCodes rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Codes' ;
    rdfs:comment 'Pipe-separated list of regulatory codes (e.g., REACH, TSCA) applicable to the batch.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationReference rdf:type rdf:Property ;
    rdfs:label 'Specification Reference' ;
    rdfs:comment 'Reference code to the product specification document used for evaluation.' ;
    rdfs:domain ind:CocRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalTestCount rdf:type rdf:Property ;
    rdfs:label 'Total Test Count' ;
    rdfs:comment 'Number of analytical tests performed for this batch.' ;
    rdfs:domain ind:CocRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inspectionCharacteristicId rdf:type rdf:Property ;
    rdfs:label 'Inspection Characteristic Id' ;
    rdfs:comment 'Unique surrogate key for the inspection characteristic record.' ;
    rdfs:domain ind:InspectionCharacteristic ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:testMethodId rdf:type rdf:Property ;
    rdfs:label 'Test Method Id' ;
    rdfs:comment 'Foreign key linking to quality.test_method. Business justification: inspection_characteristic defines which test method is used; linking to test_method eliminates redundant string reference and enforces referential integrity.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TestMethod .

ind:characteristicType rdf:type rdf:Property ;
    rdfs:label 'Characteristic Type' ;
    rdfs:comment 'Indicates whether the characteristic is quantitative, qualitative, or an attribute-type check.' ;
    rdfs:domain ind:InspectionCharacteristic ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decimalPrecision rdf:type rdf:Property ;
    rdfs:label 'Decimal Precision' ;
    rdfs:comment 'Number of decimal places stored for numeric values of this characteristic.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:defaultSamplingSize rdf:type rdf:Property ;
    rdfs:label 'Default Sampling Size' ;
    rdfs:comment 'Standard number of samples to be taken per lot when this characteristic is applied.' ;
    rdfs:domain ind:InspectionCharacteristic ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gmpCriticalFlag rdf:type rdf:Property ;
    rdfs:label 'Gmp Critical Flag' ;
    rdfs:comment 'Indicates whether the characteristic is critical for Good Manufacturing Practice compliance.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectionCharacteristicDescription rdf:type rdf:Property ;
    rdfs:label 'Inspection Characteristic Description' ;
    rdfs:comment 'Detailed description of what the characteristic measures and its relevance.' ;
    rdfs:domain ind:InspectionCharacteristic ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionCharacteristicName rdf:type rdf:Property ;
    rdfs:label 'Inspection Characteristic Name' ;
    rdfs:comment 'Human-readable name of the quality characteristic.' ;
    rdfs:domain ind:InspectionCharacteristic ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionCharacteristicStatus rdf:type rdf:Property ;
    rdfs:label 'Inspection Characteristic Status' ;
    rdfs:comment 'Current lifecycle status of the characteristic.' ;
    rdfs:domain ind:InspectionCharacteristic ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lowerSpecLimit rdf:type rdf:Property ;
    rdfs:label 'Lower Spec Limit' ;
    rdfs:comment 'Minimum acceptable value for the characteristic as defined by specifications.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementCategory rdf:type rdf:Property ;
    rdfs:label 'Measurement Category' ;
    rdfs:comment 'Broad category of the measurement (e.g., physical, chemical).' ;
    rdfs:domain ind:InspectionCharacteristic ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryRequirement rdf:type rdf:Property ;
    rdfs:label 'Regulatory Requirement' ;
    rdfs:comment 'Regulation(s) that drive the definition or limits of this characteristic.' ;
    rdfs:domain ind:InspectionCharacteristic ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relatedDocumentation rdf:type rdf:Property ;
    rdfs:label 'Related Documentation' ;
    rdfs:comment 'Reference (e.g., URL or document ID) to supporting specifications, SOPs, or test method documents.' ;
    rdfs:domain ind:InspectionCharacteristic ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplingProcedure rdf:type rdf:Property ;
    rdfs:label 'Sampling Procedure' ;
    rdfs:comment 'Method used to select samples for this characteristic.' ;
    rdfs:domain ind:InspectionCharacteristic ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationVersion rdf:type rdf:Property ;
    rdfs:label 'Specification Version' ;
    rdfs:comment 'Version identifier of the specification governing this characteristic.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upperSpecLimit rdf:type rdf:Property ;
    rdfs:label 'Upper Spec Limit' ;
    rdfs:comment 'Maximum acceptable value for the characteristic as defined by specifications.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coaDocumentId rdf:type rdf:Property ;
    rdfs:label 'Coa Document Id' ;
    rdfs:comment 'Reference to the generated Certificate of Analysis for this lot.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CoaDocument .

ind:inspectionPlanId rdf:type rdf:Property ;
    rdfs:label 'Inspection Plan Id' ;
    rdfs:comment 'Foreign key linking to quality.inspection_plan. Business justification: inspection_lot is executed according to an inspection_plan; linking to the plan provides the test method and other plan details, removing duplicated method code fields.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InspectionPlan .

ind:inspectorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Inspector Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Inspection execution requires assigning a qualified inspector; the inspector is recorded for each lot to support compliance reports.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryInspectionMaterialMasterId rdf:type rdf:Property ;
    rdfs:label 'Primary Inspection Material Master Id' ;
    rdfs:comment 'Identifier of the material or chemical substance being inspected.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialMaster .

ind:researchProjectId rdf:type rdf:Property ;
    rdfs:label 'Research Project Id' ;
    rdfs:comment 'Foreign key linking to research.project. Business justification: Batch Release Report requires traceability of each inspected lot to the originating R&D project for regulatory genealogy.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Project .

ind:samplingPlanId rdf:type rdf:Property ;
    rdfs:label 'Sampling Plan Id' ;
    rdfs:comment 'Identifier of the sampling plan applied to this lot.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SamplingPlan .

ind:dispositionBy rdf:type rdf:Property ;
    rdfs:label 'Disposition By' ;
    rdfs:comment 'User identifier of the person who authorized the disposition.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionCode rdf:type rdf:Property ;
    rdfs:label 'Disposition Code' ;
    rdfs:comment 'Final decision for the lot after inspection (e.g., accept, rework, scrap).' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionDate rdf:type rdf:Property ;
    rdfs:label 'Disposition Date' ;
    rdfs:comment 'Date on which the disposition decision was recorded.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gmpCompliant rdf:type rdf:Property ;
    rdfs:label 'Gmp Compliant' ;
    rdfs:comment 'Indicates whether the inspection complies with Good Manufacturing Practice requirements.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:holdFlag rdf:type rdf:Property ;
    rdfs:label 'Hold Flag' ;
    rdfs:comment 'Indicates whether the lot is placed on quality hold pending further investigation.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectionEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Inspection End Timestamp' ;
    rdfs:comment 'Date and time when the inspection activity was completed.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:inspectionLotStatus rdf:type rdf:Property ;
    rdfs:label 'Inspection Lot Status' ;
    rdfs:comment 'Current lifecycle status of the inspection lot.' ;
