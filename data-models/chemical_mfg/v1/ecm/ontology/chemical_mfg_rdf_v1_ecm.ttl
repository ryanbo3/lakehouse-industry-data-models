    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:selectivityPercent rdf:type rdf:Property ;
    rdfs:label 'Selectivity Percent' ;
    rdfs:comment 'Selectivity of desired product relative to by-products, expressed as a percentage.' ;
