    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionInstructions rdf:type rdf:Property ;
    rdfs:label 'Disposition Instructions' ;
    rdfs:comment 'Instructions for material disposition based on decision.' ;
