# --- Attribute Properties ---
ind:arOpenItemId rdf:type rdf:Property ;
    rdfs:label 'Ar Open Item Id' ;
    rdfs:comment 'System-generated unique identifier for the open AR item.' ;
    rdfs:domain ind:ArOpenItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:costCenterId rdf:type rdf:Property ;
    rdfs:label 'Cost Center Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_center. Business justification: AR aging reports are often broken out by cost center; linking open items to cost_center enables cost-center level DSO analysis.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:invoiceId rdf:type rdf:Property ;
    rdfs:label 'Invoice Id' ;
    rdfs:comment 'Unique identifier of the source invoice in SAP FI.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:primaryArAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Ar Account Id' ;
    rdfs:comment 'Unique identifier of the customer in the master data system.' ;
    rdfs:domain ind:ArOpenItem ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:agingBucket rdf:type rdf:Property ;
    rdfs:label 'Aging Bucket' ;
    rdfs:comment 'Categorized aging range used for collection reporting.' ;
    rdfs:domain ind:ArOpenItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amountOriginal rdf:type rdf:Property ;
    rdfs:label 'Amount Original' ;
    rdfs:comment 'Total amount originally invoiced before any payments, discounts, or adjustments.' ;
    rdfs:domain ind:ArOpenItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amountOutstanding rdf:type rdf:Property ;
    rdfs:label 'Amount Outstanding' ;
    rdfs:comment 'Remaining amount that has not been settled, including taxes and fees.' ;
