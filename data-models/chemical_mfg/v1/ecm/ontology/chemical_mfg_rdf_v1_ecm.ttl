ind:operatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Operator Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Needed for SOP execution log; ties the operator performing the synthesis to employee for safety training compliance.' ;
    rdfs:domain ind:SynthesisProcedure ;
