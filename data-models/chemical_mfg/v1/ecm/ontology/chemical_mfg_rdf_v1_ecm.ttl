ind:calibrationStandard rdf:type rdf:Property ;
    rdfs:label 'Calibration Standard' ;
    rdfs:comment 'Name or code of the reference standard used for calibration (e.g., NIST SRM).' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
