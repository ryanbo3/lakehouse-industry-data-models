    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteDisposalRecordStatus rdf:type rdf:Property ;
    rdfs:label 'Waste Disposal Record Status' ;
    rdfs:comment 'Current lifecycle status of the waste disposal record.' ;
    rdfs:domain ind:WasteDisposalRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteDisposalType rdf:type rdf:Property ;
    rdfs:label 'Waste Disposal Type' ;
    rdfs:comment 'Indicates whether the disposal was a single shipment, multiple shipments, or type unknown.' ;
    rdfs:domain ind:WasteDisposalRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteGenerationDate rdf:type rdf:Property ;
    rdfs:label 'Waste Generation Date' ;
    rdfs:comment 'Date the waste was generated at the facility.' ;
    rdfs:domain ind:WasteDisposalRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:wasteStorageLocation rdf:type rdf:Property ;
    rdfs:label 'Waste Storage Location' ;
    rdfs:comment 'On-site location where waste was stored prior to disposal.' ;
    rdfs:domain ind:WasteDisposalRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageMonthlyVolume rdf:type rdf:Property ;
    rdfs:label 'Average Monthly Volume' ;
    rdfs:comment 'Average volume of waste generated per month, expressed in unit_of_measure.' ;
