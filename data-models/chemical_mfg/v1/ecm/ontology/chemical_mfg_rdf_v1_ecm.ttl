ind:invoiceLineId rdf:type rdf:Property ;
    rdfs:label 'Invoice Line Id' ;
    rdfs:comment 'Unique surrogate key for each invoice line record.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InvoiceLine .

ind:batchRecordId rdf:type rdf:Property ;
    rdfs:label 'Batch Record Id' ;
    rdfs:comment 'Foreign key linking to production.batch_record. Business justification: Regulatory and quality compliance demand linking each invoiced line to the exact production batch that supplied the material.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BatchRecord .

ind:experimentalFormulationId rdf:type rdf:Property ;
    rdfs:label 'Experimental Formulation Id' ;
    rdfs:comment 'Foreign key linking to research.experimental_formulation. Business justification: Custom formulation sales need traceability; each invoice line for a formulation references the experimental formulation record.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
