    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceStatus rdf:type rdf:Property ;
    rdfs:label 'Invoice Status' ;
    rdfs:comment 'Current lifecycle status of the invoice.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceType rdf:type rdf:Property ;
    rdfs:label 'Invoice Type' ;
    rdfs:comment 'Classification of the invoice document.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isElectronicInvoice rdf:type rdf:Property ;
