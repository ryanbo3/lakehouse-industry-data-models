    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:wasteStreamId rdf:type rdf:Property ;
    rdfs:label 'Waste Stream Id' ;
    rdfs:comment 'Foreign key linking to ehs.waste_stream. Business justification: Required: Customers are charged per waste stream disposal; linking invoices to waste streams enables detailed billing and waste tracking.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WasteStream .

ind:billingAddressLine1 rdf:type rdf:Property ;
