    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendedProcessModifications rdf:type rdf:Property ;
    rdfs:label 'Recommended Process Modifications' ;
    rdfs:comment 'Suggested changes to equipment, operating conditions, or control strategies to improve feasibility.' ;
