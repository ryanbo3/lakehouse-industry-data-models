ind:formulaVersionId rdf:type rdf:Property ;
    rdfs:label 'Formula Version Id' ;
    rdfs:comment 'Foreign key linking to formulation.formula_version. Business justification: Regulatory traceability report requires each sold line item to reference the exact formula version used in production.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
