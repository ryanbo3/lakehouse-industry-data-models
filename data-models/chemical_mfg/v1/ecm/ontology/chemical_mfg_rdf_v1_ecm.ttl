ind:sampleStatus rdf:type rdf:Property ;
    rdfs:label 'Sample Status' ;
    rdfs:comment 'Current lifecycle status of the sample.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceIdentifier rdf:type rdf:Property ;
    rdfs:label 'Source Identifier' ;
    rdfs:comment 'Identifier of the source entity (e.g., supplier batch number, field collection ID).' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:structureActivityRecordId rdf:type rdf:Property ;
    rdfs:label 'Structure Activity Record Id' ;
    rdfs:comment 'Unique identifier for the structure-activity relationship record.' ;
