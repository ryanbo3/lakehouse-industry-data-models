    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rcraHazardous rdf:type rdf:Property ;
    rdfs:label 'Rcra Hazardous' ;
    rdfs:comment 'Indicates whether the waste stream is classified as hazardous under RCRA regulations.' ;
    rdfs:domain ind:WasteStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Date' ;
    rdfs:comment 'Date on which the required regulatory notification was submitted.' ;
