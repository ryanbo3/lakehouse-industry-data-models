    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:technologyTransferId rdf:type rdf:Property ;
    rdfs:label 'Technology Transfer Id' ;
    rdfs:comment 'Unique system-generated identifier for the technology transfer record.' ;
    rdfs:domain ind:TechnologyTransfer ;
