ind:arOpenItemDescription rdf:type rdf:Property ;
    rdfs:label 'Ar Open Item Description' ;
    rdfs:comment 'Free-text description of the goods or services represented by the line.' ;
    rdfs:domain ind:ArOpenItem ;
    rdf:type owl:DatatypeProperty ;
