    rdfs:range xsd:string .

ind:vendorName rdf:type rdf:Property ;
    rdfs:label 'Vendor Name' ;
    rdfs:comment 'Full legal name of the chemical supplier or raw material vendor as registered with governing authorities.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorStatus rdf:type rdf:Property ;
    rdfs:label 'Vendor Status' ;
    rdfs:comment 'Current operational status of the vendor indicating whether they are approved for procurement transactions and order placement.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorTier rdf:type rdf:Property ;
    rdfs:label 'Vendor Tier' ;
    rdfs:comment 'Tiered classification reflecting the vendors strategic importance, performance history, and procurement preference level within the supply chain network.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:websiteUrl rdf:type rdf:Property ;
    rdfs:label 'Website Url' ;
    rdfs:comment 'Primary website URL for the vendor providing access to product catalogs, technical documentation, and company information.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:womanOwned rdf:type rdf:Property ;
    rdfs:label 'Woman Owned' ;
    rdfs:comment 'Indicates whether the vendor is certified as a woman-owned business enterprise for supplier diversity program tracking and reporting.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:activeFromDate rdf:type rdf:Property ;
    rdfs:label 'Active From Date' ;
    rdfs:comment 'Date when the vendor site became active in the supply chain network. Used for supplier relationship tracking and historical analysis.' ;
    rdfs:domain ind:VendorSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:activeToDate rdf:type rdf:Property ;
    rdfs:label 'Active To Date' ;
    rdfs:comment 'Date when the vendor site was deactivated or decommissioned. Null for currently active sites. Used for supplier lifecycle management.' ;
    rdfs:domain ind:VendorSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line 1' ;
    rdfs:comment 'Primary street address line for the vendor site. Used for shipping, logistics planning, and regulatory reporting.' ;
    rdfs:domain ind:VendorSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line 2' ;
    rdfs:comment 'Secondary address line for building, suite, or unit information.' ;
    rdfs:domain ind:VendorSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dockHours rdf:type rdf:Property ;
    rdfs:label 'Dock Hours' ;
    rdfs:comment 'Operating hours for receiving and shipping at the vendor site dock. Used for delivery scheduling and ASN planning.' ;
    rdfs:domain ind:VendorSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incoterm rdf:type rdf:Property ;
    rdfs:label 'Incoterm' ;
    rdfs:comment 'Default Incoterm for shipments from this vendor site. Defines responsibility for freight, insurance, and risk transfer. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iso14001CertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Iso 14001 Certificate Number' ;
    rdfs:comment 'Certificate number for the site\'s ISO 14001 certification. Used for environmental compliance verification.' ;
    rdfs:domain ind:VendorSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iso14001ExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Iso 14001 Expiration Date' ;
    rdfs:comment 'Expiration date of the site\'s ISO 14001 certification. Monitored for environmental compliance and supplier sustainability programs.' ;
    rdfs:domain ind:VendorSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:iso9001CertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Iso 9001 Certificate Number' ;
    rdfs:comment 'Certificate number for the site\'s ISO 9001 certification. Used for audit verification and supplier qualification documentation.' ;
    rdfs:domain ind:VendorSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iso9001ExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Iso 9001 Expiration Date' ;
    rdfs:comment 'Expiration date of the site\'s ISO 9001 certification. Monitored for supplier compliance and re-qualification triggers.' ;
    rdfs:domain ind:VendorSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Lead Time Days' ;
    rdfs:comment 'Standard lead time in days from purchase order placement to shipment readiness at this vendor site. Used for procurement planning and MRP calculations.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Minimum Order Quantity' ;
    rdfs:comment 'Minimum order quantity required by this vendor site for purchase orders. Used for procurement planning and order consolidation.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumOrderQuantityUom rdf:type rdf:Property ;
    rdfs:label 'Minimum Order Quantity Uom' ;
    rdfs:comment 'Unit of measure for the minimum order quantity. Common chemical industry units include kilograms, liters, drums, totes, and railcars. [ENUM-REF-CANDIDATE: KG|LB|MT|L|GAL|M3|EA|DRUM|TOTE|RAILCAR — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:VendorSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationStatus rdf:type rdf:Property ;
    rdfs:label 'Qualification Status' ;
    rdfs:comment 'Current supplier qualification status of the vendor site. Determines whether site can be used for new purchase orders and material sourcing.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryDate rdf:type rdf:Property ;
    rdfs:label 'Delivery Date' ;
    rdfs:comment 'Date by which the ordered materials or services are requested to be delivered to the receiving plant or location.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:freightTerms rdf:type rdf:Property ;
    rdfs:label 'Freight Terms' ;
    rdfs:comment 'Freight payment responsibility: prepaid (seller pays freight), collect (buyer pays freight), or third_party (third party pays freight).' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poNumber rdf:type rdf:Property ;
    rdfs:label 'Po Number' ;
    rdfs:comment 'Externally-known unique purchase order document number issued to the supplier. Typically a 10-digit SAP document number from MM module.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poStatus rdf:type rdf:Property ;
    rdfs:label 'Po Status' ;
    rdfs:comment 'Current lifecycle status of the purchase order: draft (being created), pending_approval (awaiting authorization), approved (authorized but not yet released), released (transmitted to vendor), partially_received (some goods received), fully_received (all goods received), closed (completed and archived), cancelled (voided before fulfillment). [ENUM-REF-CANDIDATE: draft|pending_approval|approved|released|partially_received|fully_received|closed|cancelled — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poType rdf:type rdf:Property ;
    rdfs:label 'Po Type' ;
    rdfs:comment 'Classification of the purchase order type: standard (one-time purchase), blanket (release against framework agreement), contract (long-term agreement), consignment (vendor-owned inventory), subcontracting (material provided to vendor for processing), or service (non-material procurement).' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchasingGroup rdf:type rdf:Property ;
    rdfs:label 'Purchasing Group' ;
    rdfs:comment 'Buyer or purchasing team responsible for this purchase order. Typically a 3-character code identifying the procurement specialist or commodity team (e.g., raw materials, packaging, services).' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchasingOrganization rdf:type rdf:Property ;
    rdfs:label 'Purchasing Organization' ;
    rdfs:comment 'SAP organizational unit responsible for procurement activities. Typically a 4-character alphanumeric code representing the central or regional purchasing group.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseDate rdf:type rdf:Property ;
    rdfs:label 'Release Date' ;
    rdfs:comment 'Date when the purchase order was officially released and transmitted to the vendor for fulfillment.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitionNumber rdf:type rdf:Property ;
    rdfs:label 'Requisition Number' ;
    rdfs:comment 'Reference number of the internal purchase requisition that triggered the creation of this purchase order.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfqNumber rdf:type rdf:Property ;
    rdfs:label 'Rfq Number' ;
    rdfs:comment 'Reference number of the Request for Quotation (RFQ) document that preceded this purchase order, if applicable. Links PO to the sourcing event.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Shipping Address Line1' ;
    rdfs:comment 'First line of the delivery address where the ordered materials should be shipped (street address, building number).' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingCity rdf:type rdf:Property ;
    rdfs:label 'Shipping City' ;
    rdfs:comment 'City name of the delivery address for the purchase order shipment.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingMethod rdf:type rdf:Property ;
    rdfs:label 'Shipping Method' ;
    rdfs:comment 'Primary mode of transportation for delivering the ordered materials: truck (road freight), rail (railway), ocean (sea freight), air (air cargo), pipeline (bulk liquid/gas), or intermodal (combination).' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingPostalCode rdf:type rdf:Property ;
    rdfs:label 'Shipping Postal Code' ;
    rdfs:comment 'Postal code or ZIP code of the delivery address for the purchase order shipment.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingStateProvince rdf:type rdf:Property ;
    rdfs:label 'Shipping State Province' ;
    rdfs:comment 'State or province of the delivery address for the purchase order shipment.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialInstructions rdf:type rdf:Property ;
    rdfs:label 'Special Instructions' ;
    rdfs:comment 'Free-text field for any special handling, packaging, labeling, or delivery instructions communicated to the vendor.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalGrossValue rdf:type rdf:Property ;
    rdfs:label 'Total Gross Value' ;
    rdfs:comment 'Total gross monetary value of the purchase order including net value, taxes, freight, and all other charges.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalNetValue rdf:type rdf:Property ;
    rdfs:label 'Total Net Value' ;
    rdfs:comment 'Total net monetary value of the purchase order before taxes, freight, and other charges. Sum of all line item net values.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Total Tax Amount' ;
    rdfs:comment 'Total tax amount applicable to the purchase order, including sales tax, VAT, or other applicable taxes based on jurisdiction.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validityEndDate rdf:type rdf:Property ;
    rdfs:label 'Validity End Date' ;
    rdfs:comment 'End date of the purchase order validity period. Applicable primarily for blanket or contract purchase orders defining the expiration date.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validityStartDate rdf:type rdf:Property ;
    rdfs:label 'Validity Start Date' ;
    rdfs:comment 'Start date of the purchase order validity period. Applicable primarily for blanket or contract purchase orders defining the effective-from date.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:vendorContactEmail rdf:type rdf:Property ;
    rdfs:label 'Vendor Contact Email' ;
    rdfs:comment 'Email address of the primary vendor contact for order acknowledgment, shipping notifications, and issue resolution.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorContactName rdf:type rdf:Property ;
    rdfs:label 'Vendor Contact Name' ;
    rdfs:comment 'Name of the primary contact person at the vendor organization for this purchase order.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poLineId rdf:type rdf:Property ;
    rdfs:label 'Po Line Id' ;
    rdfs:comment 'Unique identifier for the purchase order line item. Primary key for the po_line data product.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PoLine .

ind:contractPriceId rdf:type rdf:Property ;
    rdfs:label 'Contract Price Id' ;
    rdfs:comment 'Foreign key linking to supply.contract_price. Business justification: PO line pricing in chemical manufacturing is typically derived from negotiated contract price conditions (price scales, condition records). Adding contract_price_id to po_line links each line item to ' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContractPrice .

ind:batchManagedFlag rdf:type rdf:Property ;
    rdfs:label 'Batch Managed Flag' ;
    rdfs:comment 'Indicates whether this material requires batch management and lot tracking for quality control and traceability purposes.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:confirmationControlKey rdf:type rdf:Property ;
    rdfs:label 'Confirmation Control Key' ;
    rdfs:comment 'Code defining the type of order confirmation required from the supplier (e.g., order acknowledgment, shipping notification, delivery confirmation).' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deletionIndicator rdf:type rdf:Property ;
    rdfs:label 'Deletion Indicator' ;
    rdfs:comment 'Flag indicating whether this purchase order line has been marked for deletion and should be excluded from active procurement processing.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:goodsReceiptQuantity rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Quantity' ;
    rdfs:comment 'Cumulative quantity of material that has been received against this purchase order line to date.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:goodsReceiptRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Required Flag' ;
    rdfs:comment 'Indicates whether a formal goods receipt transaction must be posted in the system before invoice processing can occur.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:invoiceReceiptQuantity rdf:type rdf:Property ;
    rdfs:label 'Invoice Receipt Quantity' ;
    rdfs:comment 'Cumulative quantity of material that has been invoiced by the supplier against this purchase order line.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceReceiptRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Invoice Receipt Required Flag' ;
    rdfs:comment 'Indicates whether an invoice must be received and verified before payment can be processed for this line item.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:materialGroup rdf:type rdf:Property ;
    rdfs:label 'Material Group' ;
    rdfs:comment 'Classification code grouping similar materials together for procurement analysis and reporting (e.g., solvents, acids, polymers).' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netOrderValue rdf:type rdf:Property ;
    rdfs:label 'Net Order Value' ;
    rdfs:comment 'Total net value of this purchase order line, calculated as ordered quantity multiplied by net price, before taxes and freight.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netPrice rdf:type rdf:Property ;
    rdfs:label 'Net Price' ;
    rdfs:comment 'The negotiated unit price for the material before taxes and additional charges. Expressed per price unit.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderedQuantity rdf:type rdf:Property ;
    rdfs:label 'Ordered Quantity' ;
    rdfs:comment 'The quantity of material ordered on this purchase order line, expressed in the unit of measure specified.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outstandingQuantity rdf:type rdf:Property ;
    rdfs:label 'Outstanding Quantity' ;
    rdfs:comment 'Remaining quantity of material still to be delivered on this purchase order line, calculated as ordered quantity minus goods receipt quantity.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overDeliveryTolerancePct rdf:type rdf:Property ;
    rdfs:label 'Over Delivery Tolerance Pct' ;
    rdfs:comment 'Acceptable percentage by which the supplier may exceed the ordered quantity without requiring approval.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceUnit rdf:type rdf:Property ;
    rdfs:label 'Price Unit' ;
    rdfs:comment 'The quantity unit to which the net price applies (e.g., price per 1 unit, per 100 units, per 1000 units).' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityInspectionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Required Flag' ;
    rdfs:comment 'Indicates whether incoming material on this line must undergo quality control inspection and Certificate of Analysis (COA) verification before release to production.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supplierMaterialNumber rdf:type rdf:Property ;
    rdfs:label 'Supplier Material Number' ;
    rdfs:comment 'The suppliers own material number or product code for this chemical substance, used for cross-referencing and order confirmation.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCode rdf:type rdf:Property ;
    rdfs:label 'Tax Code' ;
    rdfs:comment 'Tax classification code determining the applicable tax rate and tax jurisdiction for this purchase order line.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:underDeliveryTolerancePct rdf:type rdf:Property ;
    rdfs:label 'Under Delivery Tolerance Pct' ;
    rdfs:comment 'Acceptable percentage by which the supplier may deliver less than the ordered quantity without penalty.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:asnId rdf:type rdf:Property ;
    rdfs:label 'Asn Id' ;
    rdfs:comment 'Foreign key linking to supply.asn. Business justification: Goods receipts in chemical manufacturing are frequently matched against ASNs (Advanced Shipping Notices) received from suppliers prior to physical delivery. The goods_receipt table stores asn_number (' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asn .

ind:carrierId rdf:type rdf:Property ;
    rdfs:label 'Carrier Id' ;
    rdfs:comment 'Foreign key linking to logistics.carrier. Business justification: Carrier traceability on goods receipt is a regulatory requirement in chemical manufacturing: DOT incident reporting and hazmat delivery audits require identifying the specific carrier. carrier_name on' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:inboundDeliveryId rdf:type rdf:Property ;
    rdfs:label 'Inbound Delivery Id' ;
    rdfs:comment 'Foreign key linking to supply.inbound_delivery. Business justification: An inbound delivery record tracks the physical movement of materials to the plant, and the goods receipt records the formal posting of that receipt. These are sequential events in the inbound logistic' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InboundDelivery .

ind:vehicleId rdf:type rdf:Property ;
    rdfs:label 'Vehicle Id' ;
    rdfs:comment 'Foreign key linking to logistics.vehicle. Business justification: Vehicle traceability on inbound hazmat receipts is a DOT and EHS regulatory requirement in chemical manufacturing: temperature control verification, cleaning certification, and incident investigation ' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vehicle .

ind:coaDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Coa Document Number' ;
    rdfs:comment 'The document number or reference identifier of the vendor-supplied Certificate of Analysis for the received batch.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coaReceivedFlag rdf:type rdf:Property ;
    rdfs:label 'Coa Received Flag' ;
    rdfs:comment 'Boolean indicator specifying whether the vendor-supplied Certificate of Analysis has been received and attached to the goods receipt record.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:damageDescription rdf:type rdf:Property ;
    rdfs:label 'Damage Description' ;
    rdfs:comment 'Free-text description of any damage, leakage, or packaging issues observed during receipt inspection. Used for vendor claims and quality investigations.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryNoteNumber rdf:type rdf:Property ;
    rdfs:label 'Delivery Note Number' ;
    rdfs:comment 'The vendor-supplied delivery note or packing slip number accompanying the shipment. Used for cross-referencing with vendor documentation.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grDate rdf:type rdf:Property ;
    rdfs:label 'Gr Date' ;
    rdfs:comment 'The date on which the goods were physically received at the plant gate or warehouse dock. This is the principal business event timestamp for the receipt transaction.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:grDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Gr Document Number' ;
    rdfs:comment 'The unique goods receipt document number generated by the ERP system (SAP material document number). This is the business identifier for the receipt transaction.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grStatus rdf:type rdf:Property ;
    rdfs:label 'Gr Status' ;
    rdfs:comment 'Current lifecycle status of the goods receipt transaction. Indicates whether the receipt is posted, pending approval, reversed, or blocked.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grTimestamp rdf:type rdf:Property ;
    rdfs:label 'Gr Timestamp' ;
    rdfs:comment 'The precise date and time when the goods receipt was recorded in the system, including time zone information.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:movementType rdf:type rdf:Property ;
    rdfs:label 'Movement Type' ;
    rdfs:comment 'SAP movement type code indicating the nature of the goods receipt transaction (e.g., 101 for GR against PO, 102 for GR reversal, 161 for return delivery). [ENUM-REF-CANDIDATE: 101|102|103|105|161|501|511|Z01|Z02 — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingCondition rdf:type rdf:Property ;
    rdfs:label 'Packaging Condition' ;
    rdfs:comment 'Assessment of the physical condition of the packaging upon receipt. Critical for identifying damage, leaks, or contamination of chemical shipments.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiverName rdf:type rdf:Property ;
    rdfs:label 'Receiver Name' ;
    rdfs:comment 'The name of the warehouse or receiving dock employee who physically accepted and inspected the shipment.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sealIntactFlag rdf:type rdf:Property ;
    rdfs:label 'Seal Intact Flag' ;
    rdfs:comment 'Boolean indicator specifying whether the security seal was found intact upon arrival. False value triggers security investigation.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sealNumber rdf:type rdf:Property ;
    rdfs:label 'Seal Number' ;
    rdfs:comment 'The security seal number applied to the shipment container or truck. Verified upon receipt to ensure shipment integrity and prevent tampering.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureOnArrivalC rdf:type rdf:Property ;
    rdfs:label 'Temperature On Arrival C' ;
    rdfs:comment 'The measured temperature of the material shipment upon arrival at the receiving dock, recorded in degrees Celsius. Critical for temperature-sensitive chemicals and compliance with storage specifications.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valuationAmount rdf:type rdf:Property ;
    rdfs:label 'Valuation Amount' ;
    rdfs:comment 'The total monetary value of the goods receipt transaction, calculated based on purchase order price and received quantity. Posted to inventory and financial accounts.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualArrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Arrival Timestamp' ;
    rdfs:comment 'Actual date and time when the shipment physically arrived at the receiving facility.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:asnNumber rdf:type rdf:Property ;
    rdfs:label 'Asn Number' ;
    rdfs:comment 'Externally-known unique ASN document number provided by the supplier.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:asnStatus rdf:type rdf:Property ;
    rdfs:label 'Asn Status' ;
    rdfs:comment 'Current lifecycle status of the ASN in the receiving workflow. [ENUM-REF-CANDIDATE: draft|transmitted|in_transit|arrived|receiving|completed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:asnType rdf:type rdf:Property ;
    rdfs:label 'Asn Type' ;
    rdfs:comment 'Classification of the ASN based on shipment characteristics and handling requirements.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerNumber rdf:type rdf:Property ;
    rdfs:label 'Container Number' ;
    rdfs:comment 'ISO standard container identification number for intermodal shipments.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Expected Delivery Date' ;
    rdfs:comment 'Scheduled date when the shipment is expected to arrive at the receiving facility.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expectedDeliveryTime rdf:type rdf:Property ;
    rdfs:label 'Expected Delivery Time' ;
    rdfs:comment 'Precise timestamp when the shipment is scheduled to arrive at the receiving dock.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:hazmatPlacardCode rdf:type rdf:Property ;
    rdfs:label 'Hazmat Placard Code' ;
    rdfs:comment 'DOT hazard class placard code required for transportation (e.g., 3 for flammable liquids, 8 for corrosives).' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageCount rdf:type rdf:Property ;
    rdfs:label 'Package Count' ;
    rdfs:comment 'Total number of packages, containers, or handling units in the shipment.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:palletCount rdf:type rdf:Property ;
    rdfs:label 'Pallet Count' ;
    rdfs:comment 'Total number of pallets included in the shipment for warehouse planning.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:proNumber rdf:type rdf:Property ;
    rdfs:label 'Pro Number' ;
    rdfs:comment 'Carrier-assigned tracking number for Less Than Truckload (LTL) shipments.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingDockLocation rdf:type rdf:Property ;
    rdfs:label 'Receiving Dock Location' ;
    rdfs:comment 'Specific dock or bay location at the receiving facility designated for unloading this shipment.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredTemperatureMax rdf:type rdf:Property ;
    rdfs:label 'Required Temperature Max' ;
    rdfs:comment 'Maximum temperature threshold allowed during transportation to maintain product integrity.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requiredTemperatureMin rdf:type rdf:Property ;
    rdfs:label 'Required Temperature Min' ;
    rdfs:comment 'Minimum temperature threshold required during transportation to maintain product integrity.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shipmentMode rdf:type rdf:Property ;
    rdfs:label 'Shipment Mode' ;
    rdfs:comment 'Transportation mode used for this shipment (Less Than Truckload, Full Truckload, etc.).' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialHandlingInstructions rdf:type rdf:Property ;
    rdfs:label 'Special Handling Instructions' ;
    rdfs:comment 'Free-text instructions for special handling requirements during transportation and receiving.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureControlledIndicator rdf:type rdf:Property ;
    rdfs:label 'Temperature Controlled Indicator' ;
    rdfs:comment 'Flag indicating whether the shipment requires temperature-controlled transportation.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:temperatureUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Temperature Unit Of Measure' ;
    rdfs:comment 'Unit of measure for temperature values (Celsius, Fahrenheit, Kelvin).' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalGrossWeight rdf:type rdf:Property ;
    rdfs:label 'Total Gross Weight' ;
    rdfs:comment 'Total gross weight of the entire shipment including packaging materials.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalNetWeight rdf:type rdf:Property ;
    rdfs:label 'Total Net Weight' ;
    rdfs:comment 'Total net weight of the chemical materials excluding packaging.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalVolume rdf:type rdf:Property ;
    rdfs:label 'Total Volume' ;
    rdfs:comment 'Total volume of the shipment for capacity planning and storage allocation.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trailerNumber rdf:type rdf:Property ;
    rdfs:label 'Trailer Number' ;
    rdfs:comment 'Identification number of the trailer or truck used for transportation.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transmittedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transmitted Timestamp' ;
    rdfs:comment 'Timestamp when the ASN was transmitted by the vendor to the receiving system.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:volumeUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Volume Unit Of Measure' ;
    rdfs:comment 'Unit of measure for volume values (liters, gallons, cubic meters, cubic feet).' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Weight Unit Of Measure' ;
    rdfs:comment 'Unit of measure for weight values (kilograms, pounds, metric tons, tons).' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractMaterialMasterId rdf:type rdf:Property ;
    rdfs:label 'Contract Material Master Id' ;
    rdfs:comment 'FK to rawmaterial.material_master' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialMaster .

ind:contractMaterialMaterialMasterId rdf:type rdf:Property ;
    rdfs:label 'Contract Material Material Master Id' ;
    rdfs:comment 'FK to rawmaterial.material_master' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialMaster .

ind:primaryContractMaterialMasterId rdf:type rdf:Property ;
    rdfs:label 'Primary Contract Material Master Id' ;
    rdfs:comment 'Reference to the primary chemical raw material or product covered by this contract. For multi-material contracts, this represents the primary or representative material.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialMaster .

ind:approvedByName rdf:type rdf:Property ;
    rdfs:label 'Approved By Name' ;
    rdfs:comment 'Name of the executive or manager who provided final approval for this contract.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Number' ;
    rdfs:comment 'Externally-known unique business identifier for the contract. Used in SAP MM ME31K and across procurement documents.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractStatus rdf:type rdf:Property ;
    rdfs:label 'Contract Status' ;
    rdfs:comment 'Current lifecycle status of the contract: draft (being prepared), pending approval (awaiting authorization), active (in force), suspended (temporarily halted), expired (validity period ended), terminated (ended early), or closed (completed and archived). [ENUM-REF-CANDIDATE: draft|pending_approval|active|suspended|expired|terminated|closed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractType rdf:type rdf:Property ;
    rdfs:label 'Contract Type' ;
    rdfs:comment 'Classification of the contract arrangement: quantity contract (fixed volume), value contract (fixed spend), scheduling agreement (delivery schedule), blanket purchase agreement (BPA), framework agreement, or spot contract.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryFrequency rdf:type rdf:Property ;
    rdfs:label 'Delivery Frequency' ;
    rdfs:comment 'Planned frequency of material deliveries under this contract: daily, weekly, biweekly, monthly, quarterly, on-demand (as needed), or just-in-time (JIT synchronized with production). [ENUM-REF-CANDIDATE: daily|weekly|biweekly|monthly|quarterly|on_demand|just_in_time — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forceMajeureTerms rdf:type rdf:Property ;
    rdfs:label 'Force Majeure Terms' ;
    rdfs:comment 'Contractual provisions defining events beyond parties control (natural disasters, war, pandemics, regulatory changes) that excuse performance obligations without penalty.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Maximum Order Quantity' ;
    rdfs:comment 'Maximum quantity that can be ordered per purchase order or delivery schedule line. Used to manage supplier capacity constraints.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceCurrency rdf:type rdf:Property ;
    rdfs:label 'Price Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the contracted price (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricePerUnit rdf:type rdf:Property ;
    rdfs:label 'Price Per Unit' ;
    rdfs:comment 'Base contracted price per unit of measure. For contracts with price scales or condition-based pricing, this represents the baseline or reference price.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityUnit rdf:type rdf:Property ;
    rdfs:label 'Quantity Unit' ;
    rdfs:comment 'Unit of measure for the target quantity (e.g., KG for kilograms, L for liters, MT for metric tons, GAL for gallons).' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalTermMonths rdf:type rdf:Property ;
    rdfs:label 'Renewal Term Months' ;
    rdfs:comment 'Duration in months for each automatic renewal period if auto-renewal is enabled.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetQuantity rdf:type rdf:Property ;
    rdfs:label 'Target Quantity' ;
    rdfs:comment 'Total volume or quantity of material committed under this contract. Applicable for quantity contracts and scheduling agreements.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:terminationNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Termination Notice Days' ;
    rdfs:comment 'Number of calendar days advance notice required to terminate the contract early. Protects both parties from abrupt contract cancellation.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:valueAmount rdf:type rdf:Property ;
    rdfs:label 'Value Amount' ;
    rdfs:comment 'Total monetary value committed under this contract. For value contracts, this is the maximum spend limit. For quantity contracts, this is the estimated total value based on contracted volumes and prices.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valueCurrency rdf:type rdf:Property ;
    rdfs:label 'Value Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the contract value (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplyContractId rdf:type rdf:Property ;
    rdfs:label 'Supply Contract Id' ;
    rdfs:comment 'FK to supply.contract' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contract .

ind:calculationType rdf:type rdf:Property ;
    rdfs:label 'Calculation Type' ;
    rdfs:comment 'Method for calculating the condition value: percentage (e.g., 5% discount), fixed amount per unit, or absolute amount per order.' ;
    rdfs:domain ind:ContractPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionClass rdf:type rdf:Property ;
    rdfs:label 'Condition Class' ;
    rdfs:comment 'Classification of the pricing condition into business categories: base price, surcharge (e.g., hazmat handling), discount, freight, tax, or other adjustments.' ;
    rdfs:domain ind:ContractPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionRecordNumber rdf:type rdf:Property ;
    rdfs:label 'Condition Record Number' ;
    rdfs:comment 'SAP MM condition record number (KNUMH) that uniquely identifies the pricing condition in the source system. Business identifier for the contract price.' ;
    rdfs:domain ind:ContractPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionType rdf:type rdf:Property ;
    rdfs:label 'Condition Type' ;
    rdfs:comment 'SAP condition type code that classifies the pricing element (e.g., PB00 for gross price, FRA1 for freight, SKTO for cash discount). Determines how the price is applied in purchase order calculation.' ;
    rdfs:domain ind:ContractPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Freight Included Flag' ;
    rdfs:comment 'Indicates whether freight and transportation costs are included in the contract price or billed separately.' ;
    rdfs:domain ind:ContractPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazmatSurchargeFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Surcharge Flag' ;
    rdfs:comment 'Indicates whether this price includes or is subject to a hazardous material handling surcharge due to the chemical nature of the material.' ;
    rdfs:domain ind:ContractPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:infoRecordNumber rdf:type rdf:Property ;
    rdfs:label 'Info Record Number' ;
    rdfs:comment 'SAP purchasing info record number that stores vendor-material pricing and procurement data. Alternative to contract-based pricing.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:negotiationDate rdf:type rdf:Property ;
    rdfs:label 'Negotiation Date' ;
    rdfs:comment 'Date when the contract price was negotiated and agreed upon with the vendor.' ;
    rdfs:domain ind:ContractPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priceAmount rdf:type rdf:Property ;
    rdfs:label 'Price Amount' ;
    rdfs:comment 'The contracted price value or rate for the material. Represents the base price, surcharge, or discount amount depending on condition type.' ;
    rdfs:domain ind:ContractPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceChangeReason rdf:type rdf:Property ;
    rdfs:label 'Price Change Reason' ;
    rdfs:comment 'Business justification or reason code for the price change or new pricing condition (e.g., raw material cost increase, volume commitment, market adjustment).' ;
    rdfs:domain ind:ContractPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceDeterminationRule rdf:type rdf:Property ;
    rdfs:label 'Price Determination Rule' ;
    rdfs:comment 'Rule or logic used to determine the final price when multiple condition records exist (e.g., most specific, lowest price, highest discount). Governs price selection in purchase orders.' ;
    rdfs:domain ind:ContractPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceSource rdf:type rdf:Property ;
    rdfs:label 'Price Source' ;
    rdfs:comment 'Origin of the contract price: contract (formal supply agreement), info record (vendor-material record), quotation (RFQ response), catalog (vendor price list), or manual entry.' ;
    rdfs:domain ind:ContractPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceStatus rdf:type rdf:Property ;
    rdfs:label 'Price Status' ;
    rdfs:comment 'Current lifecycle status of the contract price: active (in use), inactive (disabled), pending (awaiting approval), expired (past validity), or superseded (replaced by newer price).' ;
    rdfs:domain ind:ContractPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingSequence rdf:type rdf:Property ;
    rdfs:label 'Pricing Sequence' ;
    rdfs:comment 'Order of application in the pricing procedure. Lower numbers are applied first. Determines the sequence of price calculations, surcharges, and discounts.' ;
    rdfs:domain ind:ContractPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scaleQuantityFrom rdf:type rdf:Property ;
    rdfs:label 'Scale Quantity From' ;
    rdfs:comment 'Lower bound of the quantity scale break for tiered pricing. Defines the minimum order quantity for this price tier. Null for non-scaled pricing.' ;
    rdfs:domain ind:ContractPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scaleQuantityTo rdf:type rdf:Property ;
    rdfs:label 'Scale Quantity To' ;
    rdfs:comment 'Upper bound of the quantity scale break for tiered pricing. Defines the maximum order quantity for this price tier. Null for open-ended top tier.' ;
    rdfs:domain ind:ContractPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scaleType rdf:type rdf:Property ;
    rdfs:label 'Scale Type' ;
    rdfs:comment 'Type of scale pricing applied: quantity-based (volume discounts), value-based (order value thresholds), or none for flat pricing.' ;
    rdfs:domain ind:ContractPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorQualificationId rdf:type rdf:Property ;
    rdfs:label 'Vendor Qualification Id' ;
    rdfs:comment 'Unique identifier for the vendor qualification record. Primary key for the vendor qualification lifecycle.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VendorQualification .

ind:auditDurationDays rdf:type rdf:Property ;
    rdfs:label 'Audit Duration Days' ;
    rdfs:comment 'Total number of days spent conducting the qualification audit including preparation, on-site/remote assessment, and reporting.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditMethod rdf:type rdf:Property ;
    rdfs:label 'Audit Method' ;
    rdfs:comment 'Method used to conduct the qualification audit: on-site (physical visit to vendor facility), remote (virtual audit), hybrid (combination), or desktop_review (document-only assessment).' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditTeamMembers rdf:type rdf:Property ;
    rdfs:label 'Audit Team Members' ;
    rdfs:comment 'Comma-separated list of employee names or identifiers who participated in the qualification audit team.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaDueDate rdf:type rdf:Property ;
    rdfs:label 'Capa Due Date' ;
    rdfs:comment 'Target date by which the vendor must complete and submit CAPA (Corrective and Preventive Action) responses for audit findings.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capaRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Capa Required Flag' ;
    rdfs:comment 'Indicates whether CAPA (Corrective and Preventive Action) is required from the vendor to address audit findings before or after qualification approval.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryPerformanceScore rdf:type rdf:Property ;
    rdfs:label 'Delivery Performance Score' ;
    rdfs:comment 'Score for logistics and delivery performance including on-time delivery rate, lead time reliability, and order fulfillment accuracy.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:effectiveFromDate rdf:type rdf:Property ;
    rdfs:label 'Effective From Date' ;
    rdfs:comment 'Date from which the vendor qualification becomes effective and the vendor is authorized for procurement activities.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ehsScore rdf:type rdf:Property ;
    rdfs:label 'Ehs Score' ;
    rdfs:comment 'Score for environmental, health, and safety compliance assessment including EHS management systems, incident history, and regulatory compliance.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financialStabilityScore rdf:type rdf:Property ;
    rdfs:label 'Financial Stability Score' ;
    rdfs:comment 'Score for financial health assessment including credit rating, financial statements review, and business continuity risk.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:findingsCriticalCount rdf:type rdf:Property ;
    rdfs:label 'Findings Critical Count' ;
    rdfs:comment 'Number of critical findings identified during the qualification audit that represent major non-conformances or immediate risks requiring resolution before approval.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:findingsMajorCount rdf:type rdf:Property ;
    rdfs:label 'Findings Major Count' ;
    rdfs:comment 'Number of major findings identified during the qualification audit that represent significant non-conformances requiring corrective action.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:findingsMinorCount rdf:type rdf:Property ;
    rdfs:label 'Findings Minor Count' ;
    rdfs:comment 'Number of minor findings or observations identified during the qualification audit that represent opportunities for improvement.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gmpCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Gmp Certified Flag' ;
    rdfs:comment 'Indicates whether the vendor holds valid GMP (Good Manufacturing Practice) certification for pharmaceutical or food-contact chemical manufacturing.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:initiatedDate rdf:type rdf:Property ;
    rdfs:label 'Initiated Date' ;
    rdfs:comment 'Date when the vendor qualification process was formally initiated.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:iso14001CertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Iso 14001 Certified Flag' ;
    rdfs:comment 'Indicates whether the vendor holds valid ISO 14001 Environmental Management System certification.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iso45001CertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Iso 45001 Certified Flag' ;
    rdfs:comment 'Indicates whether the vendor holds valid ISO 45001 Occupational Health and Safety Management System certification.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iso9001CertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Iso 9001 Certified Flag' ;
    rdfs:comment 'Indicates whether the vendor holds valid ISO 9001 Quality Management System certification.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:materialCategory rdf:type rdf:Property ;
    rdfs:label 'Material Category' ;
    rdfs:comment 'Primary chemical material category or product family that this qualification covers (e.g., solvents, polymers, catalysts, intermediates, specialty chemicals).' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationNumber rdf:type rdf:Property ;
    rdfs:label 'Qualification Number' ;
    rdfs:comment 'Business identifier for the vendor qualification record. Format: VQ-YYYYNNNN where YYYY is year and NNNN is sequence.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationScore rdf:type rdf:Property ;
    rdfs:label 'Qualification Score' ;
    rdfs:comment 'Composite numerical score representing the overall qualification assessment result, typically on a 0-100 scale based on weighted criteria.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualificationType rdf:type rdf:Property ;
    rdfs:label 'Qualification Type' ;
    rdfs:comment 'Type of qualification assessment being performed: initial (new vendor), periodic (scheduled review), for-cause (triggered by incident), re-qualification (after suspension), or expedited (fast-track for critical need).' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityScore rdf:type rdf:Property ;
    rdfs:label 'Quality Score' ;
    rdfs:comment 'Score for quality management system assessment including QMS (Quality Management System) certification, process controls, and product quality history.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reachCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Reach Compliant Flag' ;
    rdfs:comment 'Indicates whether the vendor is compliant with REACH (Registration Evaluation Authorization and Restriction of Chemicals) regulation for European chemical substance registration.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryComplianceScore rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Score' ;
    rdfs:comment 'Score for regulatory compliance assessment covering REACH (Registration Evaluation Authorization and Restriction of Chemicals), TSCA (Toxic Substances Control Act), GHS (Globally Harmonized System), and other applicable chemical regulations.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rejectionReason rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason' ;
    rdfs:comment 'Detailed explanation of why the vendor qualification was rejected, including specific deficiencies or non-conformances that led to the rejection decision.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleCareMemberFlag rdf:type rdf:Property ;
    rdfs:label 'Responsible Care Member Flag' ;
    rdfs:comment 'Indicates whether the vendor is a member of the Responsible Care program administered by the American Chemistry Council (ACC) or equivalent regional program.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riskClassification rdf:type rdf:Property ;
    rdfs:label 'Risk Classification' ;
    rdfs:comment 'Overall supply risk classification of the vendor based on criticality of materials, single-source dependency, regulatory complexity, and business impact.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Target Completion Date' ;
    rdfs:comment 'Planned date by which the qualification assessment should be completed and decision rendered.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tscaCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Tsca Compliant Flag' ;
    rdfs:comment 'Indicates whether the vendor is compliant with TSCA (Toxic Substances Control Act) requirements for chemical substances manufactured or imported into the United States.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vendorAuditId rdf:type rdf:Property ;
    rdfs:label 'Vendor Audit Id' ;
    rdfs:comment 'Unique identifier for the vendor audit record. Primary key.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VendorAudit .

ind:auditClosureDate rdf:type rdf:Property ;
    rdfs:label 'Audit Closure Date' ;
    rdfs:comment 'Date the audit was formally closed after all findings were addressed, CAPA verified, and follow-up activities completed.' ;
    rdfs:domain ind:VendorAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditDate rdf:type rdf:Property ;
    rdfs:label 'Audit Date' ;
    rdfs:comment 'The date the on-site or remote audit was conducted or commenced. Principal business event timestamp for the audit.' ;
    rdfs:domain ind:VendorAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditEndDate rdf:type rdf:Property ;
    rdfs:label 'Audit End Date' ;
    rdfs:comment 'The date the audit fieldwork was completed. Nullable for single-day audits.' ;
    rdfs:domain ind:VendorAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Audit Frequency Months' ;
    rdfs:comment 'Frequency in months at which this vendor should be audited, based on risk classification and business criticality (e.g., 12, 24, 36 months).' ;
    rdfs:domain ind:VendorAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditNumber rdf:type rdf:Property ;
    rdfs:label 'Audit Number' ;
    rdfs:comment 'Externally-known unique audit identifier assigned by the auditing organization or system. Typically follows a pattern such as QA-20230145 or EHS-2023-0012.' ;
    rdfs:domain ind:VendorAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditReportIssuedDate rdf:type rdf:Property ;
    rdfs:label 'Audit Report Issued Date' ;
    rdfs:comment 'Date the formal audit report was issued to the vendor and internal stakeholders.' ;
    rdfs:domain ind:VendorAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditScope rdf:type rdf:Property ;
    rdfs:label 'Audit Scope' ;
    rdfs:comment 'Detailed description of the audit scope, including processes, systems, facilities, and standards evaluated during the audit.' ;
    rdfs:domain ind:VendorAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditScore rdf:type rdf:Property ;
    rdfs:label 'Audit Score' ;
    rdfs:comment 'Numerical score assigned to the audit, typically on a scale of 0-100, representing the vendor\'s overall performance against audit criteria.' ;
    rdfs:domain ind:VendorAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditStatus rdf:type rdf:Property ;
    rdfs:label 'Audit Status' ;
    rdfs:comment 'Current lifecycle status of the audit: scheduled (planned but not started), in_progress (audit fieldwork underway), completed (audit finished, report issued), closed (all CAPA completed and verified), cancelled (audit did not proceed).' ;
    rdfs:domain ind:VendorAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditType rdf:type rdf:Property ;
    rdfs:label 'Audit Type' ;
    rdfs:comment 'Classification of the audit scope: quality (QM systems), EHS (Environment Health and Safety), PSM (Process Safety Management), GMP (Good Manufacturing Practice), combined (multiple disciplines), or responsible_care (ACC Responsible Care program).' ;
    rdfs:domain ind:VendorAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Capa Approval Date' ;
    rdfs:comment 'Date the vendor\'s CAPA plan was reviewed and approved by the auditing organization. Nullable if not yet approved.' ;
    rdfs:domain ind:VendorAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capaSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Capa Submission Date' ;
    rdfs:comment 'Actual date the vendor submitted their CAPA plan. Nullable if not yet submitted.' ;
    rdfs:domain ind:VendorAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:comments rdf:type rdf:Property ;
    rdfs:label 'Comments' ;
    rdfs:comment 'Free-text field for additional comments, observations, or context related to the audit that do not fit into structured fields.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingsObservationCount rdf:type rdf:Property ;
    rdfs:label 'Findings Observation Count' ;
    rdfs:comment 'Number of observations or recommendations noted during the audit that are not formal non-conformances but represent best practice suggestions.' ;
    rdfs:domain ind:VendorAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:followUpAuditRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Follow Up Audit Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether a follow-up audit is required to verify implementation of corrective actions. True if follow-up audit is required, False otherwise.' ;
    rdfs:domain ind:VendorAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:followUpCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Completion Date' ;
    rdfs:comment 'Actual date the follow-up verification activities were completed. Nullable if not yet completed.' ;
    rdfs:domain ind:VendorAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leadAuditorName rdf:type rdf:Property ;
    rdfs:label 'Lead Auditor Name' ;
    rdfs:comment 'Full name of the lead auditor responsible for conducting and reporting the audit.' ;
    rdfs:domain ind:VendorAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallAuditRating rdf:type rdf:Property ;
    rdfs:label 'Overall Audit Rating' ;
    rdfs:comment 'Overall assessment rating assigned to the vendor based on audit results. Determines vendor qualification status and future business relationship.' ;
    rdfs:domain ind:VendorAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleCareCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Responsible Care Compliant Flag' ;
    rdfs:comment 'Boolean flag indicating whether the vendor demonstrates compliance with the American Chemistry Council (ACC) Responsible Care program requirements. True if compliant, False otherwise.' ;
    rdfs:domain ind:VendorAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:standardsAuditedAgainst rdf:type rdf:Property ;
    rdfs:label 'Standards Audited Against' ;
    rdfs:comment 'Comma-separated list of standards, regulations, or frameworks against which the vendor was audited (e.g., ISO 9001, ISO 14001, ISO 45001, OSHA PSM, GMP, REACH, Responsible Care).' ;
    rdfs:domain ind:VendorAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorResponseDate rdf:type rdf:Property ;
    rdfs:label 'Vendor Response Date' ;
    rdfs:comment 'Date the vendor submitted their formal response to the audit findings. Nullable if no response received.' ;
    rdfs:domain ind:VendorAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:vendorResponseReceivedFlag rdf:type rdf:Property ;
    rdfs:label 'Vendor Response Received Flag' ;
    rdfs:comment 'Boolean flag indicating whether the vendor has provided a formal response to the audit findings. True if response received, False otherwise.' ;
    rdfs:domain ind:VendorAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:purchaseRequisitionId rdf:type rdf:Property ;
    rdfs:label 'Purchase Requisition Id' ;
    rdfs:comment 'Unique identifier for the purchase requisition record. Primary key.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approverName rdf:type rdf:Property ;
    rdfs:label 'Approver Name' ;
    rdfs:comment 'Name of the manager or authorized person who approved or rejected the requisition.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignProductionFlag rdf:type rdf:Property ;
    rdfs:label 'Campaign Production Flag' ;
    rdfs:comment 'Indicates whether this requisition is aligned with a campaign production schedule for batch manufacturing.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedTotalValue rdf:type rdf:Property ;
    rdfs:label 'Estimated Total Value' ;
    rdfs:comment 'Total estimated value of the requisition calculated as quantity multiplied by estimated unit price.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedUnitPrice rdf:type rdf:Property ;
    rdfs:label 'Estimated Unit Price' ;
    rdfs:comment 'Estimated price per unit of the material or service at the time of requisition creation.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mrpElement rdf:type rdf:Property ;
    rdfs:label 'Mrp Element' ;
    rdfs:comment 'Type of MRP element that generated or is associated with this requisition in the planning run.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannerCode rdf:type rdf:Property ;
    rdfs:label 'Planner Code' ;
    rdfs:comment 'Code identifying the MRP planner or buyer responsible for managing procurement of this material.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningHorizon rdf:type rdf:Property ;
    rdfs:label 'Planning Horizon' ;
    rdfs:comment 'Time bucket granularity for forward-looking procurement planning associated with this requisition.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poConversionStatus rdf:type rdf:Property ;
    rdfs:label 'Po Conversion Status' ;
    rdfs:comment 'Status indicating whether the requisition has been converted to one or more purchase orders.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procurementType rdf:type rdf:Property ;
    rdfs:label 'Procurement Type' ;
    rdfs:comment 'Classification of procurement purpose: stock replenishment, direct consumption, asset acquisition, or project-specific procurement.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requesterPhone rdf:type rdf:Property ;
    rdfs:label 'Requester Phone' ;
    rdfs:comment 'Contact phone number of the requisition requester for clarifications and follow-up.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitionStatus rdf:type rdf:Property ;
    rdfs:label 'Requisition Status' ;
    rdfs:comment 'Current lifecycle status of the requisition in the approval and conversion workflow. [ENUM-REF-CANDIDATE: draft|submitted|approved|rejected|partially_converted|fully_converted|cancelled|closed — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitionType rdf:type rdf:Property ;
    rdfs:label 'Requisition Type' ;
    rdfs:comment 'Classification of the requisition based on procurement scenario: standard purchase, subcontracting, consignment, stock transfer, service procurement, or third-party order.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyStockTrigger rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Trigger' ;
    rdfs:comment 'Indicates whether this requisition was triggered by safety stock replenishment logic in MRP.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceOfSupply rdf:type rdf:Property ;
    rdfs:label 'Source Of Supply' ;
    rdfs:comment 'Planned source type for fulfilling the requisition: external procurement from vendor, internal stock transfer, subcontracting, or consignment.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creationDate rdf:type rdf:Property ;
    rdfs:label 'Creation Date' ;
    rdfs:comment 'Date when the purchase requisition was originally created in the system.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceListId rdf:type rdf:Property ;
    rdfs:label 'Source List Id' ;
    rdfs:comment 'Unique identifier for the source list record. Primary key.' ;
    rdfs:domain ind:SourceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:agreementItem rdf:type rdf:Property ;
    rdfs:label 'Agreement Item' ;
    rdfs:comment 'The line item number within the referenced contract or scheduling agreement that applies to this material-vendor-plant combination.' ;
    rdfs:domain ind:SourceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:avlStatus rdf:type rdf:Property ;
    rdfs:label 'Avl Status' ;
    rdfs:comment 'The current status of this vendor on the Approved Vendor List for the material-plant combination. Enforces procurement compliance and quality standards.' ;
    rdfs:domain ind:SourceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockedFlag rdf:type rdf:Property ;
    rdfs:label 'Blocked Flag' ;
    rdfs:comment 'Indicates whether this source list entry is temporarily blocked from use in procurement. Used to suspend a vendor without deleting the source list record.' ;
    rdfs:domain ind:SourceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fixedSourceFlag rdf:type rdf:Property ;
    rdfs:label 'Fixed Source Flag' ;
    rdfs:comment 'Indicates whether this vendor is the mandatory (fixed) source for the material-plant combination. When true, procurement must use this vendor exclusively during the validity period.' ;
    rdfs:domain ind:SourceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incotermLocation rdf:type rdf:Property ;
    rdfs:label 'Incoterm Location' ;
    rdfs:comment 'The specific location (port, warehouse, plant) associated with the Incoterm for this source list entry. Clarifies the point of delivery or risk transfer.' ;
    rdfs:domain ind:SourceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedBy rdf:type rdf:Property ;
    rdfs:label 'Last Modified By' ;
    rdfs:comment 'The user ID or name of the person who last modified this source list entry. Supports change tracking and accountability.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastPurchaseOrderDate rdf:type rdf:Property ;
    rdfs:label 'Last Purchase Order Date' ;
    rdfs:comment 'The date of the most recent purchase order issued to this vendor for this material-plant combination. Used to track vendor activity and source list currency.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastQualificationDate rdf:type rdf:Property ;
    rdfs:label 'Last Qualification Date' ;
    rdfs:comment 'The date when the vendor was last qualified or re-qualified for supplying this material. Used to track qualification currency and trigger re-qualification cycles.' ;
    rdfs:domain ind:SourceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mrpRelevantFlag rdf:type rdf:Property ;
    rdfs:label 'Mrp Relevant Flag' ;
    rdfs:comment 'Indicates whether this source list entry is considered during MRP runs for automatic source determination and purchase requisition generation.' ;
    rdfs:domain ind:SourceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextQualificationDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Qualification Due Date' ;
    rdfs:comment 'The date by which the vendor must be re-qualified for this material. Supports proactive supplier management and compliance with AVL (Approved Vendor List) policies.' ;
    rdfs:domain ind:SourceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:orderQuantityUom rdf:type rdf:Property ;
    rdfs:label 'Order Quantity Uom' ;
    rdfs:comment 'The unit of measure for the minimum order quantity and standard ordering unit for this material from this vendor.' ;
    rdfs:domain ind:SourceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredVendorFlag rdf:type rdf:Property ;
    rdfs:label 'Preferred Vendor Flag' ;
    rdfs:comment 'Indicates whether this vendor is the preferred source for the material-plant combination when multiple approved sources exist. Used to guide procurement decisions.' ;
    rdfs:domain ind:SourceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:record rdf:type rdf:Property ;
    rdfs:label 'Record' ;
    rdfs:comment 'The sequential record number within the source list for the material-plant combination. Used for ordering and identification within SAP MM.' ;
    rdfs:domain ind:SourceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceListCategory rdf:type rdf:Property ;
    rdfs:label 'Source List Category' ;
    rdfs:comment 'The procurement category or special procurement type that this source list entry supports. Distinguishes between regular purchasing, subcontracting, consignment, and pipeline scenarios.' ;
    rdfs:domain ind:SourceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorPriority rdf:type rdf:Property ;
    rdfs:label 'Vendor Priority' ;
    rdfs:comment 'The priority ranking of this vendor for the material-plant combination when multiple approved sources exist. Lower numbers indicate higher priority for automatic source determination.' ;
    rdfs:domain ind:SourceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billOfLadingId rdf:type rdf:Property ;
    rdfs:label 'Bill Of Lading Id' ;
    rdfs:comment 'Foreign key linking to logistics.bill_of_lading. Business justification: The BOL is the primary legal document for inbound chemical deliveries governing hazmat compliance, title transfer, and carrier liability. Linking inbound_delivery to bill_of_lading enables regulatory ' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillOfLading .

ind:freightOrderId rdf:type rdf:Property ;
    rdfs:label 'Freight Order Id' ;
    rdfs:comment 'Foreign key linking to logistics.freight_order. Business justification: In chemical manufacturing, inbound deliveries are executed under freight orders that govern carrier contracts, hazmat compliance terms, and delivery windows. Linking inbound_delivery to freight_order ' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FreightOrder .

ind:actualArrivalDate rdf:type rdf:Property ;
    rdfs:label 'Actual Arrival Date' ;
    rdfs:comment 'Actual date the delivery arrived at the destination plant gate or receiving dock. Used for on-time delivery performance measurement.' ;
    rdfs:domain ind:InboundDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualArrivalTime rdf:type rdf:Property ;
    rdfs:label 'Actual Arrival Time' ;
    rdfs:comment 'Actual date and time the delivery arrived at the destination plant, including time zone. Captured by gate systems or receiving personnel.' ;
    rdfs:domain ind:InboundDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deliveryNumber rdf:type rdf:Property ;
    rdfs:label 'Delivery Number' ;
    rdfs:comment 'Business identifier for the inbound delivery, typically generated by Oracle Transportation Management or SAP EWM. Externally visible tracking number used across systems and by vendors.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryStatus rdf:type rdf:Property ;
    rdfs:label 'Delivery Status' ;
    rdfs:comment 'Current lifecycle status of the inbound delivery. Tracks progression from scheduling through completion or cancellation. [ENUM-REF-CANDIDATE: scheduled|in_transit|arrived|unloading|completed|cancelled|delayed|rejected — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationPlantCode rdf:type rdf:Property ;
    rdfs:label 'Destination Plant Code' ;
    rdfs:comment 'Code identifying the receiving chemical manufacturing plant or facility. Corresponds to SAP plant master data.' ;
    rdfs:domain ind:InboundDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dotHazmatDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Dot Hazmat Document Number' ;
    rdfs:comment 'DOT-required shipping document number for hazardous materials transport. Must accompany hazmat shipments and be available for inspection.' ;
    rdfs:domain ind:InboundDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightCost rdf:type rdf:Property ;
    rdfs:label 'Freight Cost' ;
    rdfs:comment 'Transportation cost for this delivery in the specified currency. May be vendor-paid or buyer-paid depending on Incoterm.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Freight Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for freight cost (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:InboundDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsReceiptNumber rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Number' ;
    rdfs:comment 'SAP goods receipt document number created when materials are physically received and posted to inventory. Links delivery to inventory transaction.' ;
    rdfs:domain ind:InboundDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionLotNumber rdf:type rdf:Property ;
    rdfs:label 'Inspection Lot Number' ;
    rdfs:comment 'SAP QM inspection lot number created for quality testing of received materials. Links delivery to quality control process.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netWeightKg rdf:type rdf:Property ;
    rdfs:label 'Net Weight Kg' ;
    rdfs:comment 'Weight of the actual chemical materials excluding packaging and container, measured in kilograms. Used for inventory valuation and goods receipt.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requiredTemperatureMaxC rdf:type rdf:Property ;
    rdfs:label 'Required Temperature Max C' ;
    rdfs:comment 'Maximum temperature in Celsius that must not be exceeded during transport to prevent material degradation or safety hazards.' ;
    rdfs:domain ind:InboundDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requiredTemperatureMinC rdf:type rdf:Property ;
    rdfs:label 'Required Temperature Min C' ;
    rdfs:comment 'Minimum temperature in Celsius that must be maintained during transport to preserve material integrity. Applies to temperature-sensitive chemicals.' ;
    rdfs:domain ind:InboundDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduledArrivalDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Arrival Date' ;
    rdfs:comment 'Planned date for the delivery to arrive at the destination plant. Used for production planning and resource allocation.' ;
    rdfs:domain ind:InboundDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledArrivalTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Arrival Time' ;
    rdfs:comment 'Planned date and time for the delivery to arrive at the destination plant, including time zone. Precise timing critical for dock scheduling and unloading crew coordination.' ;
    rdfs:domain ind:InboundDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:temperatureControlledFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Controlled Flag' ;
    rdfs:comment 'Indicates whether the delivery requires temperature-controlled transport to maintain material stability and quality. Critical for temperature-sensitive chemicals.' ;
    rdfs:domain ind:InboundDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transportEquipmentNumber rdf:type rdf:Property ;
    rdfs:label 'Transport Equipment Number' ;
    rdfs:comment 'Identifier of the specific transport equipment used (tanker truck number, rail car number, container number). Used for tracking and safety audits.' ;
    rdfs:domain ind:InboundDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceVerificationId rdf:type rdf:Property ;
    rdfs:label 'Invoice Verification Id' ;
    rdfs:comment 'Unique identifier for the invoice verification record. Primary key for three-way match verification in SAP MM MIRO.' ;
    rdfs:domain ind:InvoiceVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:baselineDate rdf:type rdf:Property ;
    rdfs:label 'Baseline Date' ;
    rdfs:comment 'Baseline date for payment terms calculation in SAP. Typically the invoice date or goods receipt date depending on payment terms configuration.' ;
    rdfs:domain ind:InvoiceVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:blockingReason rdf:type rdf:Property ;
    rdfs:label 'Blocking Reason' ;
    rdfs:comment 'Reason why the invoice verification is blocked from payment. Common blocks include price tolerance exceeded, quantity short, or quality hold pending Certificate of Analysis (COA) review. [ENUM-REF-CANDIDATE: price_tolerance_exceeded|quantity_short|quality_hold_pending_coa|duplicate_invoice|missing_gr|missing_po|tax_code_mismatch|vendor_blocked|manual_review_required|unblocked — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InvoiceVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coaReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Coa Review Status' ;
    rdfs:comment 'Status of the Certificate of Analysis review by Quality Control. Invoices may be blocked pending COA approval for chemical raw materials.' ;
    rdfs:domain ind:InvoiceVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightCharge rdf:type rdf:Property ;
    rdfs:label 'Freight Charge' ;
    rdfs:comment 'Freight or transportation charge included in the vendor invoice. Common surcharge in chemical procurement for bulk material shipments.' ;
    rdfs:domain ind:InvoiceVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazmatHandlingFee rdf:type rdf:Property ;
    rdfs:label 'Hazmat Handling Fee' ;
    rdfs:comment 'Special handling fee for hazardous chemical materials. Charged by vendors for DOT-regulated hazmat transportation and storage compliance.' ;
    rdfs:domain ind:InvoiceVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:indexEscalatorAmount rdf:type rdf:Property ;
    rdfs:label 'Index Escalator Amount' ;
    rdfs:comment 'Price adjustment based on commodity index escalation clauses common in chemical supply contracts. Reflects market-driven price volatility.' ;
    rdfs:domain ind:InvoiceVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoicedAmount rdf:type rdf:Property ;
    rdfs:label 'Invoiced Amount' ;
    rdfs:comment 'Total amount invoiced by the vendor before tax. Base amount for three-way match price variance calculation.' ;
    rdfs:domain ind:InvoiceVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoicedQuantity rdf:type rdf:Property ;
    rdfs:label 'Invoiced Quantity' ;
    rdfs:comment 'Quantity of chemical material invoiced by the vendor. Compared against PO quantity and GR quantity for variance detection.' ;
    rdfs:domain ind:InvoiceVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentBlockIndicator rdf:type rdf:Property ;
    rdfs:label 'Payment Block Indicator' ;
    rdfs:comment 'Flag indicating whether the invoice is blocked for payment. True if blocked, False if released for payment processing.' ;
    rdfs:domain ind:InvoiceVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentDueDate rdf:type rdf:Property ;
    rdfs:label 'Payment Due Date' ;
    rdfs:comment 'Calculated date by which payment is due to the vendor based on invoice date and payment terms. Critical for cash flow management and vendor relationship.' ;
    rdfs:domain ind:InvoiceVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentReleaseBy rdf:type rdf:Property ;
    rdfs:label 'Payment Release By' ;
    rdfs:comment 'User ID or name of the person who released the invoice for payment. Audit trail for payment authorization.' ;
    rdfs:domain ind:InvoiceVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Payment Release Date' ;
    rdfs:comment 'Date on which the invoice was released for payment after successful three-way match verification and block resolution.' ;
    rdfs:domain ind:InvoiceVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priceVariance rdf:type rdf:Property ;
    rdfs:label 'Price Variance' ;
    rdfs:comment 'Difference between invoiced price and PO price. Common in chemical procurement due to index-linked pricing, freight surcharges, and hazmat handling fees.' ;
    rdfs:domain ind:InvoiceVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityVariance rdf:type rdf:Property ;
    rdfs:label 'Quantity Variance' ;
    rdfs:comment 'Difference between invoiced quantity and goods receipt quantity. Typical with bulk liquid chemical deliveries measured by weight at receipt.' ;
    rdfs:domain ind:InvoiceVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalInvoiceAmount rdf:type rdf:Property ;
    rdfs:label 'Total Invoice Amount' ;
    rdfs:comment 'Total invoice amount including tax. Gross amount payable to the vendor upon verification approval.' ;
    rdfs:domain ind:InvoiceVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:verificationDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Verification Document Number' ;
    rdfs:comment 'SAP document number assigned to the invoice verification transaction. Unique business identifier for the three-way match record.' ;
    rdfs:domain ind:InvoiceVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationStatus rdf:type rdf:Property ;
    rdfs:label 'Verification Status' ;
    rdfs:comment 'Overall status of the three-way match verification process. Tracks the invoice through verification workflow from receipt to approval.' ;
    rdfs:domain ind:InvoiceVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifiedBy rdf:type rdf:Property ;
    rdfs:label 'Verified By' ;
    rdfs:comment 'User ID or name of the person who performed the invoice verification. Audit trail for accountability and compliance.' ;
    rdfs:domain ind:InvoiceVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Verified Timestamp' ;
    rdfs:comment 'Date and time when the invoice verification was completed. Tracks verification cycle time for process efficiency analysis.' ;
    rdfs:domain ind:InvoiceVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:materialInfoRecordId rdf:type rdf:Property ;
    rdfs:label 'Material Info Record Id' ;
    rdfs:comment 'Unique identifier for the material info record. Primary key for this purchasing master data entity.' ;
    rdfs:domain ind:MaterialInfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acknowledgementRequired rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Required' ;
    rdfs:comment 'Indicates whether the vendor must send a formal acknowledgement confirming receipt and acceptance of purchase orders. When true, procurement tracks acknowledgement status.' ;
    rdfs:domain ind:MaterialInfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:agreementItemNumber rdf:type rdf:Property ;
    rdfs:label 'Agreement Item Number' ;
    rdfs:comment 'Specific line item within the referenced contract that covers this material. Five-digit numeric identifier linking to the contract line item.' ;
    rdfs:domain ind:MaterialInfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockedSource rdf:type rdf:Property ;
    rdfs:label 'Blocked Source' ;
    rdfs:comment 'Indicates whether this source is temporarily blocked from procurement. When true, no new purchase orders can be created using this material-vendor-plant combination.' ;
    rdfs:domain ind:MaterialInfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificateOfAnalysisRequired rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Analysis Required' ;
    rdfs:comment 'Indicates whether the vendor must provide a Certificate of Analysis with each shipment. Critical for chemical materials to verify composition, purity, and compliance with specifications.' ;
    rdfs:domain ind:MaterialInfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fixedSource rdf:type rdf:Property ;
    rdfs:label 'Fixed Source' ;
    rdfs:comment 'Indicates whether this is the mandatory source for the material. When true, Material Requirements Planning (MRP) and purchase requisitions must use this vendor exclusively.' ;
    rdfs:domain ind:MaterialInfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:goodsReceiptRequired rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Required' ;
    rdfs:comment 'Indicates whether a formal goods receipt transaction must be posted in SAP MM before invoice processing. Standard requirement for physical materials.' ;
    rdfs:domain ind:MaterialInfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:infoRecordCategory rdf:type rdf:Property ;
    rdfs:label 'Info Record Category' ;
    rdfs:comment 'Classification of the purchasing info record type. Defines the procurement model: standard purchase, subcontracting arrangement, consignment stock, or pipeline supply for bulk chemicals.' ;
    rdfs:domain ind:MaterialInfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:infoRecordStatus rdf:type rdf:Property ;
    rdfs:label 'Info Record Status' ;
    rdfs:comment 'Current lifecycle status of the purchasing info record. Determines whether this source can be used for new purchase orders and MRP planning.' ;
    rdfs:domain ind:MaterialInfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceReceiptRequired rdf:type rdf:Property ;
    rdfs:label 'Invoice Receipt Required' ;
    rdfs:comment 'Indicates whether invoice verification is required for purchases from this source. When true, three-way match (PO, goods receipt, invoice) is enforced.' ;
    rdfs:domain ind:MaterialInfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastPurchaseOrderPrice rdf:type rdf:Property ;
    rdfs:label 'Last Purchase Order Price' ;
    rdfs:comment 'Most recent actual price paid for this material from this vendor. Used for price variance analysis and to track pricing trends over time.' ;
    rdfs:domain ind:MaterialInfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:manufacturerPartNumber rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Part Number' ;
    rdfs:comment 'Original manufacturer\'s part number when the vendor is a distributor. Ensures correct material identification and traceability to the chemical producer.' ;
    rdfs:domain ind:MaterialInfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mrpRelevant rdf:type rdf:Property ;
    rdfs:label 'Mrp Relevant' ;
    rdfs:comment 'Indicates whether this source is considered during MRP runs for automatic source determination. When true, MRP will propose this vendor when generating planned orders or purchase requisitions.' ;
    rdfs:domain ind:MaterialInfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netPriceIndicator rdf:type rdf:Property ;
    rdfs:label 'Net Price Indicator' ;
    rdfs:comment 'Indicates whether the standard price is a net price (no further discounts apply) or a gross price (subject to additional discounts or surcharges).' ;
    rdfs:domain ind:MaterialInfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plannedDeliveryTimeDays rdf:type rdf:Property ;
    rdfs:label 'Planned Delivery Time Days' ;
    rdfs:comment 'Expected lead time in calendar days from purchase order placement to goods receipt at the plant. Used by MRP for scheduling and by procurement for delivery date calculation.' ;
    rdfs:domain ind:MaterialInfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priceCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Price Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the standard price. Defines the currency in which pricing is negotiated and invoiced.' ;
    rdfs:domain ind:MaterialInfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityInspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Required' ;
    rdfs:comment 'Indicates whether incoming materials from this vendor must undergo quality control inspection before release to production. When true, goods are placed in quality inspection stock upon receipt.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:safetyDataSheetRequired rdf:type rdf:Property ;
    rdfs:label 'Safety Data Sheet Required' ;
    rdfs:comment 'Indicates whether the vendor must provide a current Safety Data Sheet (SDS) with shipments. Mandatory for hazardous chemicals to ensure safe handling and compliance with OSHA and GHS requirements.' ;
    rdfs:domain ind:MaterialInfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceListRecord rdf:type rdf:Property ;
    rdfs:label 'Source List Record' ;
    rdfs:comment 'Indicates whether this info record is part of the approved vendor list (AVL). When true, this vendor is authorized to supply this material to this plant during the validity period.' ;
    rdfs:domain ind:MaterialInfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:standardOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Standard Order Quantity' ;
    rdfs:comment 'Recommended or typical order quantity for this material-vendor combination. Used as default value in purchase requisitions and for optimizing order economics.' ;
    rdfs:domain ind:MaterialInfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardPrice rdf:type rdf:Property ;
    rdfs:label 'Standard Price' ;
    rdfs:comment 'Default unit price for this material from this vendor. Used as the baseline price for purchase order creation and cost estimation. Expressed in the currency specified in price_currency_code.' ;
    rdfs:domain ind:MaterialInfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unlimitedOverDelivery rdf:type rdf:Property ;
    rdfs:label 'Unlimited Over Delivery' ;
    rdfs:comment 'Indicates whether the vendor is allowed to deliver any quantity above the purchase order amount without restriction. Typically used for bulk chemicals where exact quantities are difficult to control.' ;
    rdfs:domain ind:MaterialInfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billOfMaterialsId rdf:type rdf:Property ;
    rdfs:label 'Bill Of Materials Id' ;
    rdfs:comment 'Identifier for the Bill of Materials defining the raw materials, intermediates, and components required for this production order.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillOfMaterials .

ind:campaignId rdf:type rdf:Property ;
    rdfs:label 'Campaign Id' ;
    rdfs:comment 'Identifier linking this order to a multi-batch production campaign. Used for extended runs of the same product to optimize changeover and yield.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Campaign .

ind:demandForecastId rdf:type rdf:Property ;
    rdfs:label 'Demand Forecast Id' ;
    rdfs:comment 'Foreign key linking to planning.demand_forecast. Business justification: Order release uses the demand forecast that generated the manufacturing order; linking enables the Order Release report.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DemandForecast .

ind:destinationSiteId rdf:type rdf:Property ;
    rdfs:label 'Destination Site Id' ;
    rdfs:comment 'Foreign key linking to customer.site. Business justification: Manufacturing orders for bulk/dedicated production must reference the customer delivery site to align production parameters (packaging, volume, temperature control) with site capabilities (bulk_receip' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Site .

ind:routingId rdf:type rdf:Property ;
    rdfs:label 'Routing Id' ;
    rdfs:comment 'Identifier for the production routing or master recipe defining the sequence of operations, process steps, and control parameters.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Routing .

ind:actualCost rdf:type rdf:Property ;
    rdfs:label 'Actual Cost' ;
    rdfs:comment 'Actual total cost incurred for this production order, settled from material consumption, labor confirmations, and activity allocations.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualQuantity rdf:type rdf:Property ;
    rdfs:label 'Actual Quantity' ;
    rdfs:comment 'Actual quantity of finished product manufactured and confirmed via goods receipt. Used for yield calculation and variance analysis.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualYieldPercentage rdf:type rdf:Property ;
    rdfs:label 'Actual Yield Percentage' ;
    rdfs:comment 'Calculated yield percentage achieved in this production run: (actual output / theoretical output) * 100. Key performance indicator for process efficiency.' ;
    rdfs:domain ind:ManufacturingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costEstimate rdf:type rdf:Property ;
    rdfs:label 'Cost Estimate' ;
    rdfs:comment 'Planned total cost for this production order, including raw materials, labor, utilities, and overhead. Used for cost accounting and variance analysis.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costVarianceFlag rdf:type rdf:Property ;
    rdfs:label 'Cost Variance Flag' ;
    rdfs:comment 'Indicator that actual cost exceeded planned cost by a threshold percentage, triggering variance investigation and root cause analysis.' ;
    rdfs:domain ind:ManufacturingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dcsBatchReference rdf:type rdf:Property ;
    rdfs:label 'Dcs Batch Reference' ;
    rdfs:comment 'Batch identifier assigned by the DCS (Honeywell Experion, Siemens PCS 7) for automated process control and SCADA data historian linkage.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationFlag rdf:type rdf:Property ;
    rdfs:label 'Deviation Flag' ;
    rdfs:comment 'Indicator that one or more process deviations, out-of-specification events, or quality exceptions occurred during production execution.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastModifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User' ;
    rdfs:comment 'User ID or name of the person who last modified the production order, supporting change tracking and accountability.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:masterRecipeReference rdf:type rdf:Property ;
    rdfs:label 'Master Recipe Reference' ;
    rdfs:comment 'Reference to the master recipe or Process Instruction (PI) sheet governing the synthesis, reaction conditions, and quality parameters for this product.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mesIntegrationReference rdf:type rdf:Property ;
    rdfs:label 'Mes Integration Reference' ;
    rdfs:comment 'External identifier used for integration with MES systems. Links ERP production order to MES work order for real-time execution tracking.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mocReference rdf:type rdf:Property ;
    rdfs:label 'Moc Reference' ;
    rdfs:comment 'Reference number for any Management of Change request associated with this production order, documenting process deviations or recipe modifications.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderStatus rdf:type rdf:Property ;
    rdfs:label 'Order Status' ;
    rdfs:comment 'Current lifecycle state of the production order: created (planned but not released), released (authorized for execution), started (production begun), in_progress (active manufacturing), confirmed (goods receipt posted), technically_complete (production finished, pending final settlement), closed (financially settled), cancelled (order voided). [ENUM-REF-CANDIDATE: created|released|started|in_progress|confirmed|technically_complete|closed|cancelled — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderType rdf:type rdf:Property ;
    rdfs:label 'Order Type' ;
    rdfs:comment 'Classification of the manufacturing process mode: batch (discrete lots), continuous (steady-state flow), semi-continuous (hybrid), campaign (extended multi-batch run), rework (reprocessing off-spec material), or trial (R&D pilot run).' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedQuantity rdf:type rdf:Property ;
    rdfs:label 'Planned Quantity' ;
    rdfs:comment 'Target quantity of finished product to be manufactured, as specified in the production order. Expressed in the base unit of measure.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processOrderType rdf:type rdf:Property ;
    rdfs:label 'Process Order Type' ;
    rdfs:comment 'Specific classification of the order purpose: standard (normal production), rework (reprocessing), trial (R&D pilot), validation (process qualification), cleaning (CIP campaign).' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionVersion rdf:type rdf:Property ;
    rdfs:label 'Production Version' ;
    rdfs:comment 'Four-digit version number linking the specific BOM and routing combination used for this order. Enables traceability of recipe changes over time.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledFinishDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Finish Date' ;
    rdfs:comment 'Planned date for production order completion, including all manufacturing operations and goods receipt confirmation.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:settlementRule rdf:type rdf:Property ;
    rdfs:label 'Settlement Rule' ;
    rdfs:comment 'Configuration defining how production order costs are settled to inventory, cost centers, or profitability segments upon order closure.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yieldTargetPercentage rdf:type rdf:Property ;
    rdfs:label 'Yield Target Percentage' ;
    rdfs:comment 'Expected yield percentage based on master recipe and historical performance. Used as benchmark for variance analysis and process optimization.' ;
    rdfs:domain ind:ManufacturingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchStorageBinId rdf:type rdf:Property ;
    rdfs:label 'Batch Storage Bin Id' ;
    rdfs:comment 'Foreign key linking to inventory.storage_bin. Business justification: GMP chemical manufacturing requires tracking the physical storage bin where each produced batch is held pending QC release. Batch-to-bin traceability is mandatory for FIFO/FEFO management and regulato' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageBin .

ind:consumedLotRecordId rdf:type rdf:Property ;
    rdfs:label 'Consumed Lot Record Id' ;
    rdfs:comment 'Foreign key linking to rawmaterial.lot_record. Business justification: The batch record is the master GMP document; QA batch release requires direct reference to the primary raw material lot consumed, including its CoA reference, quality inspection result, and supplier l' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LotRecord .

ind:maintenanceNotificationId rdf:type rdf:Property ;
    rdfs:label 'Maintenance Notification Id' ;
    rdfs:comment 'Foreign key linking to maintenance.notification. Business justification: Needed for Batch Execution Log to capture the maintenance notification that caused a batch hold, used in compliance and downtime analysis reports.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Notification .

ind:scheduleId rdf:type rdf:Property ;
    rdfs:label 'Schedule Id' ;
    rdfs:comment 'Foreign key linking to production.schedule. Business justification: batch_record execution should reference the schedule that planned it. Linking batch_record to schedule enables schedule adherence analysis — comparing planned vs. actual batch execution times, quantit' ;
    rdfs:domain ind:Production ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Schedule .

ind:supplyGoodsReceiptId rdf:type rdf:Property ;
    rdfs:label 'Supply Goods Receipt Id' ;
    rdfs:comment 'Foreign key linking to supply.goods_receipt. Business justification: REQUIRED: Quality and traceability reports link each batch record to the goods receipt that delivered the raw material lot.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GoodsReceipt .

ind:wasteStreamId rdf:type rdf:Property ;
    rdfs:label 'Waste Stream Id' ;
    rdfs:comment 'Foreign key linking to ehs.waste_stream. Business justification: Batch records in chemical manufacturing generate specific waste streams (solvent residues, reaction by-products). RCRA compliance and TRI reporting require linking each batch to its waste stream. GMP ' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WasteStream .

ind:actualYieldQuantity rdf:type rdf:Property ;
    rdfs:label 'Actual Yield Quantity' ;
    rdfs:comment 'Actual quantity produced by this batch after completion. Used to calculate yield percentage, material efficiency, and production performance (OEE - Overall Equipment Effectiveness).' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualYieldUom rdf:type rdf:Property ;
    rdfs:label 'Actual Yield Uom' ;
    rdfs:comment 'Unit of measure for the actual yield quantity. Should match batch_size_uom for yield percentage calculation.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchSizeQuantity rdf:type rdf:Property ;
    rdfs:label 'Batch Size Quantity' ;
    rdfs:comment 'Planned or target quantity for this batch expressed in the base unit of measure. Used for yield calculation, material consumption planning, and production scheduling.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchSizeUom rdf:type rdf:Property ;
    rdfs:label 'Batch Size Uom' ;
    rdfs:comment 'Unit of measure for the batch size quantity (e.g., KG, L, MT, GAL). Must align with the formula base unit and inventory unit of measure.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchStatus rdf:type rdf:Property ;
    rdfs:label 'Batch Status' ;
    rdfs:comment 'Current lifecycle state of the batch in the manufacturing execution workflow. Governs whether the batch can be released to inventory, requires quality review, or is blocked for regulatory or quality reasons.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coaIssuedFlag rdf:type rdf:Property ;
    rdfs:label 'Coa Issued Flag' ;
    rdfs:comment 'Boolean indicator that a Certificate of Analysis (COA) has been issued for this batch. COA is required for customer shipments and regulatory compliance.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coaNumber rdf:type rdf:Property ;
    rdfs:label 'Coa Number' ;
    rdfs:comment 'Unique identifier for the Certificate of Analysis issued for this batch. Links the batch record to the quality test results and customer documentation.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationCount rdf:type rdf:Property ;
    rdfs:label 'Deviation Count' ;
    rdfs:comment 'Number of process deviations, exceptions, or Out of Specification (OOS) events recorded during batch execution. Triggers CAPA (Corrective and Preventive Action) and RCI (Root Cause Investigation) workflows.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exceptionFlag rdf:type rdf:Property ;
    rdfs:label 'Exception Flag' ;
    rdfs:comment 'Boolean indicator that one or more exceptions occurred during batch execution. Used to filter batches requiring quality review or management attention.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:formulaVersion rdf:type rdf:Property ;
    rdfs:label 'Formula Version' ;
    rdfs:comment 'Version identifier of the formula or recipe used for this batch. Critical for traceability when formulas are revised due to MOC (Management of Change) or process optimization.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmpComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Gmp Compliance Flag' ;
    rdfs:comment 'Boolean indicator that this batch was produced under GMP-compliant conditions and meets all regulatory requirements for pharmaceutical or food-contact chemical production.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:manufacturingDate rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Date' ;
    rdfs:comment 'Calendar date of batch production. Used for shelf-life calculation, expiry date determination, and regulatory labeling (GHS - Globally Harmonized System).' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:manufacturingEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Manufacturing End Timestamp' ;
    rdfs:comment 'Date and time when batch production was completed and the batch was ready for quality inspection. Used for cycle time analysis and production scheduling.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:manufacturingStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Start Timestamp' ;
    rdfs:comment 'Date and time when batch production was initiated on the manufacturing floor. Captured from MES (Manufacturing Execution System) or DCS (Distributed Control System) transaction log.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:mesSystemVersion rdf:type rdf:Property ;
    rdfs:label 'Mes System Version' ;
    rdfs:comment 'Version of the MES or DCS system that recorded this batch. Required for 21 CFR Part 11 compliance and system validation audit trail.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mesTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Mes Transaction Reference' ;
    rdfs:comment 'Unique transaction identifier from the MES system that initiated or recorded this batch. Used for audit trail linkage and electronic records compliance (21 CFR Part 11).' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processPhAvg rdf:type rdf:Property ;
    rdfs:label 'Process Ph Avg' ;
    rdfs:comment 'Average pH level during the critical reaction phase. Key process parameter for chemical synthesis quality control and product specification compliance.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processPressureAvg rdf:type rdf:Property ;
    rdfs:label 'Process Pressure Avg' ;
    rdfs:comment 'Average process pressure during the critical reaction phase, measured in bar. Key process parameter for quality control and process safety management (PSM).' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processTemperatureAvg rdf:type rdf:Property ;
    rdfs:label 'Process Temperature Avg' ;
    rdfs:comment 'Average process temperature during the critical reaction phase, measured in degrees Celsius. Key process parameter for quality control and SPC (Statistical Process Control) analysis.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reactionTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Reaction Time Minutes' ;
    rdfs:comment 'Total duration of the chemical reaction phase in minutes. Critical process parameter for yield optimization and product quality consistency.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recipePhaseExecuted rdf:type rdf:Property ;
    rdfs:label 'Recipe Phase Executed' ;
    rdfs:comment 'Comma-separated list or summary of recipe phases executed during this batch (e.g., charging, heating, reaction, cooling, discharge). Provides high-level execution summary for batch genealogy.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Hold Flag' ;
    rdfs:comment 'Boolean indicator that this batch is under regulatory hold and cannot be released to inventory or shipped until regulatory clearance is obtained. May be set by EHS (Environment Health and Safety) or quality assurance.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewStatus rdf:type rdf:Property ;
    rdfs:label 'Review Status' ;
    rdfs:comment 'Current status of the batch record review and approval workflow. Governs whether the batch can be released to inventory or requires additional quality or management review.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reviewed Timestamp' ;
    rdfs:comment 'Date and time when the batch record was reviewed and approved or rejected by quality assurance. Part of the electronic signature audit trail (21 CFR Part 11).' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:yieldPercentage rdf:type rdf:Property ;
    rdfs:label 'Yield Percentage' ;
    rdfs:comment 'Calculated yield efficiency as a percentage of actual yield to planned batch size. Key performance indicator for production efficiency and process optimization (SPC - Statistical Process Control).' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchSizeCategory rdf:type rdf:Property ;
    rdfs:label 'Batch Size Category' ;
    rdfs:comment 'Classification of process order scale. Lab for R&D bench-scale (<10kg), pilot for scale-up trials (10-1000kg), commercial for standard production (>1000kg), full_scale for maximum reactor capacity utilization.' ;
    rdfs:domain ind:ProcessOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dcsSystemReference rdf:type rdf:Property ;
    rdfs:label 'Dcs System Reference' ;
    rdfs:comment 'Identifier for the DCS or SCADA system instance managing this process order. Maps to Honeywell Experion, Siemens SIMATIC PCS 7, or Aveva PI System historian for real-time data integration.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardClassification rdf:type rdf:Property ;
    rdfs:label 'Hazard Classification' ;
    rdfs:comment 'GHS hazard classification for the product being manufactured. Determines PSM (Process Safety Management) requirements, permit-to-work rules, and EHS monitoring. Aligns with SDS Section 2 hazard identification. [ENUM-REF-CANDIDATE: non_hazardous|flammable|corrosive|toxic|oxidizer|explosive|reactive — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mesIntegrationStatus rdf:type rdf:Property ;
    rdfs:label 'Mes Integration Status' ;
    rdfs:comment 'Status of process order synchronization with MES. Tracks order handoff from SAP PP to shop floor execution system. Failed status triggers manual intervention and CAPA (Corrective and Preventive Action) workflow.' ;
    rdfs:domain ind:ProcessOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedEndDate rdf:type rdf:Property ;
    rdfs:label 'Planned End Date' ;
    rdfs:comment 'Scheduled date for process order completion and final product discharge. Used for capacity planning and customer delivery commitments.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedEndTime rdf:type rdf:Property ;
    rdfs:label 'Planned End Time' ;
    rdfs:comment 'Precise timestamp for scheduled process order completion. Includes reaction time, cooling, CIP (Clean In Place), and quality hold time.' ;
    rdfs:domain ind:ProcessOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedStartTime rdf:type rdf:Property ;
    rdfs:label 'Planned Start Time' ;
    rdfs:comment 'Precise timestamp for scheduled process order start. Critical for continuous processes and multi-stage reaction sequences requiring tight timing control.' ;
    rdfs:domain ind:ProcessOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:processOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Process Order Number' ;
    rdfs:comment 'Externally visible business identifier for the process order. Unique alphanumeric code used across SAP PP, MES (Manufacturing Execution System), and DCS (Distributed Control System) integration points.' ;
    rdfs:domain ind:ProcessOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionLine rdf:type rdf:Property ;
    rdfs:label 'Production Line' ;
    rdfs:comment 'Identifier for the specific production line, reactor train, or blending unit where the process order is scheduled. Links to P&ID (Piping and Instrumentation Diagram) and SCADA (Supervisory Control and Data Acquisition) tag hierarchy.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipeNumber rdf:type rdf:Property ;
    rdfs:label 'Recipe Number' ;
    rdfs:comment 'Identifier for the master recipe (PI sheet) that defines the synthesis pathway, reaction sequence, process parameters, and control strategy. Links to BOM (Bill of Materials), routing, and control recipe in DCS.' ;
    rdfs:domain ind:ProcessOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceFlag rdf:type rdf:Property ;
    rdfs:label 'Variance Flag' ;
    rdfs:comment 'Boolean indicator that actual results (yield, cycle time, cost) deviated significantly from plan. True triggers variance analysis workflow and potential RCI (Root Cause Investigation) for process improvement.' ;
    rdfs:domain ind:ProcessOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:batchGenealogyId rdf:type rdf:Property ;
    rdfs:label 'Batch Genealogy Id' ;
    rdfs:comment 'Unique identifier for the batch genealogy record tracking parent-child lineage relationships between chemical batches.' ;
    rdfs:domain ind:BatchGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:childLotId rdf:type rdf:Property ;
    rdfs:label 'Child Lot Id' ;
    rdfs:comment 'Foreign key linking to inventory.lot. Business justification: Batch genealogy tracks parent-child batch relationships for traceability. Linking the child batch to its inventory lot enables recall management and forward/backward traceability reports required by F' ;
    rdfs:domain ind:BatchGenealogy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lot .

ind:lotRecordId rdf:type rdf:Property ;
    rdfs:label 'Lot Record Id' ;
    rdfs:comment 'Foreign key linking to rawmaterial.lot_record. Business justification: Batch genealogy tracks which raw material lots fed into which production batches — the foundational traceability requirement in chemical manufacturing. Linking batch_genealogy to lot_record enables fo' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LotRecord .

ind:processUnitId rdf:type rdf:Property ;
    rdfs:label 'Process Unit Id' ;
    rdfs:comment 'Foreign key linking to production.process_unit. Business justification: batch_genealogy tracks the lineage of chemical batches through multi-stage synthesis. Linking to process_unit identifies which process unit (reactor, vessel, blending unit) was used at each stage of t' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcessUnit .

ind:bomItemNumber rdf:type rdf:Property ;
    rdfs:label 'Bom Item Number' ;
    rdfs:comment 'The BOM item number from the production recipe that defines this parent-child material relationship. Links to SAP PP BOM structure.' ;
    rdfs:domain ind:BatchGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:childBatchNumber rdf:type rdf:Property ;
    rdfs:label 'Child Batch Number' ;
    rdfs:comment 'The batch number of the downstream child batch (intermediate or finished good) produced in this production relationship. Part of the lot genealogy traceability chain.' ;
    rdfs:domain ind:BatchGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coaReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Coa Reference Number' ;
    rdfs:comment 'The COA reference number associated with this batch genealogy relationship, linking to quality test results and compliance documentation.' ;
    rdfs:domain ind:BatchGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consumptionPercentage rdf:type rdf:Property ;
    rdfs:label 'Consumption Percentage' ;
    rdfs:comment 'The percentage of the parent batch consumed to produce the child batch, enabling yield and material balance calculations.' ;
    rdfs:domain ind:BatchGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Customer Order Number' ;
    rdfs:comment 'The customer order number if this batch genealogy relationship was created for a specific customer order, enabling customer-specific traceability.' ;
    rdfs:domain ind:BatchGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genealogyStatus rdf:type rdf:Property ;
    rdfs:label 'Genealogy Status' ;
    rdfs:comment 'The current status of this batch genealogy record: active (normal traceability), archived (historical record), quarantined (batch under quality hold), recalled (batch subject to recall action).' ;
    rdfs:domain ind:BatchGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentBatchNumber rdf:type rdf:Property ;
    rdfs:label 'Parent Batch Number' ;
    rdfs:comment 'The batch number of the upstream parent batch (raw material or intermediate) consumed in this production relationship. Part of the lot genealogy traceability chain.' ;
    rdfs:domain ind:BatchGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processStepCode rdf:type rdf:Property ;
    rdfs:label 'Process Step Code' ;
    rdfs:comment 'The specific process step or operation code in the manufacturing route where this batch relationship occurred (e.g., synthesis, blending, filtration, drying). Maps to MES (Manufacturing Execution System) operation codes.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processStepDescription rdf:type rdf:Property ;
    rdfs:label 'Process Step Description' ;
    rdfs:comment 'Human-readable description of the process step where the batch relationship occurred, providing context for the genealogy link.' ;
    rdfs:domain ind:BatchGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Status' ;
    rdfs:comment 'The quality status of the batch relationship at the time of transfer: released (approved for use), blocked (quality hold), restricted (conditional use), inspection (pending QC).' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityTransferred rdf:type rdf:Property ;
    rdfs:label 'Quantity Transferred' ;
    rdfs:comment 'The quantity of material transferred from parent batch to child batch in this genealogy relationship. Measured in the unit of measure specified.' ;
    rdfs:domain ind:BatchGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Flag' ;
    rdfs:comment 'Boolean flag indicating whether this batch genealogy relationship meets all applicable regulatory traceability requirements (REACH, FDA, TSCA). True if compliant, False if non-compliant or pending verification.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipType rdf:type rdf:Property ;
    rdfs:label 'Relationship Type' ;
    rdfs:comment 'The type of genealogy relationship between parent and child batches: consumed (parent used to make child), produced (child created from parent), split (one parent divided into multiple children), merged (multiple parents combined into one child), blended (multiple parents mixed into child), reworked (defective batch reprocessed).' ;
    rdfs:domain ind:BatchGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:traceabilityChainDepth rdf:type rdf:Property ;
    rdfs:label 'Traceability Chain Depth' ;
    rdfs:comment 'The depth level of this batch relationship in the overall genealogy chain, where 1 represents direct parent-child, 2 represents grandparent-grandchild, etc. Enables multi-level traceability queries.' ;
    rdfs:domain ind:BatchGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:traceabilityDirection rdf:type rdf:Property ;
    rdfs:label 'Traceability Direction' ;
    rdfs:comment 'The direction of traceability this record supports: forward (parent to child), backward (child to parent), or bidirectional (both directions).' ;
    rdfs:domain ind:BatchGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferDate rdf:type rdf:Property ;
    rdfs:label 'Transfer Date' ;
    rdfs:comment 'The date when the material transfer from parent to child batch occurred, establishing the temporal sequence in the genealogy chain.' ;
    rdfs:domain ind:BatchGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transferTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transfer Timestamp' ;
    rdfs:comment 'The precise timestamp when the material transfer from parent to child batch was recorded in the MES or DCS system, providing exact traceability timing.' ;
    rdfs:domain ind:BatchGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:processParameterId rdf:type rdf:Property ;
    rdfs:label 'Process Parameter Id' ;
    rdfs:comment 'Unique identifier for the process parameter record. Primary key for this entity.' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inspectionCharacteristicId rdf:type rdf:Property ;
    rdfs:label 'Inspection Characteristic Id' ;
    rdfs:comment 'Foreign key linking to quality.inspection_characteristic. Business justification: Process parameters (DCS/historian readings) map directly to inspection characteristics for process capability analysis and SPC. In chemical manufacturing PAT frameworks, each monitored parameter corre' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InspectionCharacteristic .

ind:reactionStepId rdf:type rdf:Property ;
    rdfs:label 'Reaction Step Id' ;
    rdfs:comment 'Foreign key linking to production.reaction_step. Business justification: process_parameter records CPPs (Critical Process Parameters) measured during manufacturing. Linking to reaction_step provides the specific step context for each parameter measurement (e.g., temperatur' ;
    rdfs:domain ind:Production ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReactionStep .

ind:spcControlId rdf:type rdf:Property ;
    rdfs:label 'Spc Control Id' ;
    rdfs:comment 'Foreign key linking to quality.spc_control. Business justification: Process parameter measurements are the source data for SPC control charts in chemical manufacturing. Linking process_parameter to spc_control enables real-time SPC violation detection, control chart u' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SpcControl .

ind:alarmPriority rdf:type rdf:Property ;
    rdfs:label 'Alarm Priority' ;
    rdfs:comment 'Priority level of the alarm triggered by this parameter measurement, if applicable.' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alarmTriggeredFlag rdf:type rdf:Property ;
    rdfs:label 'Alarm Triggered Flag' ;
    rdfs:comment 'Boolean flag indicating whether an alarm was triggered by the control system due to this parameter measurement (True if alarm triggered, False otherwise).' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:correctiveActionDescription rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Description' ;
    rdfs:comment 'Description of the corrective action taken or planned in response to parameter deviation or violation.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether corrective action is required based on this parameter measurement (True if action required, False otherwise).' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataQualityFlag rdf:type rdf:Property ;
    rdfs:label 'Data Quality Flag' ;
    rdfs:comment 'Indicator of the quality or reliability of the measured data (e.g., Good, Questionable, Bad, Estimated).' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationValue rdf:type rdf:Property ;
    rdfs:label 'Deviation Value' ;
    rdfs:comment 'Calculated deviation of the measured value from the set point (measured_value minus set_point_value).' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:engineeringUnit rdf:type rdf:Property ;
    rdfs:label 'Engineering Unit' ;
    rdfs:comment 'Unit of measure for the parameter value (e.g., Celsius, Fahrenheit, bar, psi, pH units, liters per minute, RPM, percent, ppm).' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:historianSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Historian Source System' ;
    rdfs:comment 'Name of the process historian system from which this parameter data was sourced (e.g., Aveva PI System, Honeywell PHD, OSIsoft PI).' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lowerControlLimit rdf:type rdf:Property ;
    rdfs:label 'Lower Control Limit' ;
    rdfs:comment 'Lower control limit for Statistical Process Control (SPC). Values below this threshold indicate the process may be out of statistical control.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lowerSpecificationLimit rdf:type rdf:Property ;
    rdfs:label 'Lower Specification Limit' ;
    rdfs:comment 'Lower specification limit defining the minimum acceptable value for the parameter. Values below this limit may result in out-of-specification (OOS) product.' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parameterName rdf:type rdf:Property ;
    rdfs:label 'Parameter Name' ;
    rdfs:comment 'Name of the critical process parameter being measured or controlled (e.g., temperature, pressure, pH, flow rate, agitation speed, dissolved oxygen, viscosity, concentration).' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parameterStatus rdf:type rdf:Property ;
    rdfs:label 'Parameter Status' ;
    rdfs:comment 'Current status of the parameter measurement indicating whether it is within acceptable ranges or requires investigation.' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parameterTagReference rdf:type rdf:Property ;
    rdfs:label 'Parameter Tag Reference' ;
    rdfs:comment 'Unique tag identifier from the DCS (Distributed Control System), SCADA (Supervisory Control and Data Acquisition), or PLC (Programmable Logic Controller) system that sources this parameter. Used for traceability to Honeywell Experion, Siemens PCS 7, or Aveva PI System.' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phaseName rdf:type rdf:Property ;
    rdfs:label 'Phase Name' ;
    rdfs:comment 'Name of the batch phase or process step during which this parameter was measured (e.g., Charging, Reaction, Distillation, Cooling, Discharge).' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Impact Flag' ;
    rdfs:comment 'Boolean flag indicating whether this parameter measurement has potential impact on product quality (True if quality impact identified, False otherwise).' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewTimestamp rdf:type rdf:Property ;
    rdfs:label 'Review Timestamp' ;
    rdfs:comment 'Date and time when the parameter record was reviewed and approved by quality assurance. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:samplingIntervalSeconds rdf:type rdf:Property ;
    rdfs:label 'Sampling Interval Seconds' ;
    rdfs:comment 'Time interval in seconds between consecutive parameter measurements or samples.' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:setPointValue rdf:type rdf:Property ;
    rdfs:label 'Set Point Value' ;
    rdfs:comment 'Target or desired value for the process parameter as defined by the process recipe or control system.' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spcViolationFlag rdf:type rdf:Property ;
    rdfs:label 'Spc Violation Flag' ;
    rdfs:comment 'Boolean flag indicating whether the measured value violated SPC control limits (True if violation detected, False otherwise).' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specificationViolationFlag rdf:type rdf:Property ;
    rdfs:label 'Specification Violation Flag' ;
    rdfs:comment 'Boolean flag indicating whether the measured value violated specification limits (True if out-of-specification, False otherwise).' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:upperControlLimit rdf:type rdf:Property ;
    rdfs:label 'Upper Control Limit' ;
    rdfs:comment 'Upper control limit for Statistical Process Control (SPC). Values above this threshold indicate the process may be out of statistical control.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:upperSpecificationLimit rdf:type rdf:Property ;
    rdfs:label 'Upper Specification Limit' ;
    rdfs:comment 'Upper specification limit defining the maximum acceptable value for the parameter. Values exceeding this limit may result in out-of-specification (OOS) product.' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consumedLotId rdf:type rdf:Property ;
    rdfs:label 'Consumed Lot Id' ;
    rdfs:comment 'Foreign key linking to inventory.lot. Business justification: Step-level lot traceability is required in GMP chemical manufacturing (FDA 21 CFR Part 211, EU GMP Annex 15). Each reaction step consumes a specific raw material lot. Role-prefix \'consumed_\' distingui' ;
    rdfs:domain ind:ReactionStep ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lot .

ind:actualDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Actual Duration Minutes' ;
    rdfs:comment 'Actual elapsed time for the reaction step execution in minutes. Captured from MES or DCS for process performance analysis and Overall Equipment Effectiveness (OEE) calculation.' ;
    rdfs:domain ind:ReactionStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Approval Required Flag' ;
    rdfs:comment 'Indicates whether this step requires supervisory or quality approval before proceeding to the next step. Used for critical process control points.' ;
    rdfs:domain ind:ReactionStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:criticalStepFlag rdf:type rdf:Property ;
    rdfs:label 'Critical Step Flag' ;
    rdfs:comment 'Indicates whether this step is a critical control point requiring enhanced monitoring, verification, or approval. Used for Good Manufacturing Practice (GMP) and Process Safety Management (PSM) compliance.' ;
    rdfs:domain ind:ReactionStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deviationDescription rdf:type rdf:Property ;
    rdfs:label 'Deviation Description' ;
    rdfs:comment 'Detailed description of any process deviation, out-of-specification condition, or abnormal event that occurred during the reaction step execution. Used for Root Cause Investigation (RCI) and CAPA.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialChargeQuantity rdf:type rdf:Property ;
    rdfs:label 'Material Charge Quantity' ;
    rdfs:comment 'Quantity of material charged or added during this reaction step. Applicable for charge-type steps and used for Bill of Materials (BOM) consumption tracking.' ;
    rdfs:domain ind:ReactionStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:materialChargeUom rdf:type rdf:Property ;
    rdfs:label 'Material Charge Uom' ;
    rdfs:comment 'Unit of measure for the material charge quantity (e.g., kg, L, mol). Ensures proper inventory consumption and yield calculation.' ;
    rdfs:domain ind:ReactionStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredEquipmentType rdf:type rdf:Property ;
    rdfs:label 'Required Equipment Type' ;
    rdfs:comment 'Type or class of equipment required to execute this reaction step (e.g., reactor, distillation column, filter press, blender). Used for resource allocation and scheduling.' ;
    rdfs:domain ind:ReactionStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scadaTagReference rdf:type rdf:Property ;
    rdfs:label 'Scada Tag Reference' ;
    rdfs:comment 'Reference to the SCADA or process historian (Aveva PI System) tag that captures real-time process data for this reaction step. Enables linkage to time-series process data.' ;
    rdfs:domain ind:ReactionStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sequenceOrder rdf:type rdf:Property ;
    rdfs:label 'Sequence Order' ;
    rdfs:comment 'Execution order within the overall synthesis sequence. May differ from step_number if parallel or conditional steps exist.' ;
    rdfs:domain ind:ReactionStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sopReference rdf:type rdf:Property ;
    rdfs:label 'Sop Reference' ;
    rdfs:comment 'Reference to the Standard Operating Procedure document governing the execution of this reaction step. Ensures compliance with documented procedures.' ;
    rdfs:domain ind:ReactionStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stepEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Step End Timestamp' ;
    rdfs:comment 'Date and time when the reaction step execution completed. Used to calculate actual duration and for batch genealogy tracking.' ;
    rdfs:domain ind:ReactionStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:stepName rdf:type rdf:Property ;
    rdfs:label 'Step Name' ;
    rdfs:comment 'Descriptive name of the reaction step (e.g., Charge Reactant A, Heat to Reflux, Cool and Filter). Provides human-readable identification of the process phase.' ;
    rdfs:domain ind:ReactionStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stepNotes rdf:type rdf:Property ;
    rdfs:label 'Step Notes' ;
    rdfs:comment 'Free-text notes or comments recorded by the operator during the execution of this reaction step. Captures observations, adjustments, or contextual information for the batch record.' ;
    rdfs:domain ind:ReactionStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stepNumber rdf:type rdf:Property ;
    rdfs:label 'Step Number' ;
    rdfs:comment 'Sequential number of this step within the reaction sequence. Defines the order of execution in the synthesis workflow.' ;
    rdfs:domain ind:ReactionStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stepStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Step Start Timestamp' ;
    rdfs:comment 'Date and time when the reaction step execution began. Captured from MES or DCS for process traceability and batch record documentation.' ;
    rdfs:domain ind:ReactionStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:stepStatus rdf:type rdf:Property ;
    rdfs:label 'Step Status' ;
    rdfs:comment 'Current execution status of the reaction step. Tracks the lifecycle state of the step within the production order. [ENUM-REF-CANDIDATE: not_started|in_progress|completed|paused|aborted|failed|skipped — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ReactionStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stepType rdf:type rdf:Property ;
    rdfs:label 'Step Type' ;
    rdfs:comment 'Classification of the reaction step operation type. Defines the nature of the process activity being performed. [ENUM-REF-CANDIDATE: charge|heat|react|cool|filter|distill|blend|transfer|clean|sample|hold|neutralize|crystallize|dry — 14 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ReactionStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetAgitationRpm rdf:type rdf:Property ;
    rdfs:label 'Target Agitation Rpm' ;
    rdfs:comment 'Target agitation or stirring speed in revolutions per minute (RPM). Controls mixing intensity for homogeneous reaction conditions.' ;
    rdfs:domain ind:ReactionStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Target Duration Minutes' ;
    rdfs:comment 'Planned or target duration for the reaction step in minutes as defined in the master recipe. Used for scheduling and capacity planning.' ;
    rdfs:domain ind:ReactionStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetPh rdf:type rdf:Property ;
    rdfs:label 'Target Ph' ;
    rdfs:comment 'Target pH level for the reaction step. Critical for acid-base reactions, neutralization, and pH-sensitive synthesis processes.' ;
    rdfs:domain ind:ReactionStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetPressureBar rdf:type rdf:Property ;
    rdfs:label 'Target Pressure Bar' ;
    rdfs:comment 'Target or setpoint pressure for the reaction step in bar. Critical process parameter for reactions requiring pressurized conditions.' ;
    rdfs:domain ind:ReactionStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Target Temperature C' ;
    rdfs:comment 'Target or setpoint temperature for the reaction step in degrees Celsius. Critical process parameter for chemical synthesis control.' ;
    rdfs:domain ind:ReactionStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bomConsumptionId rdf:type rdf:Property ;
    rdfs:label 'Bom Consumption Id' ;
    rdfs:comment 'Unique identifier for the BOM consumption transaction record.' ;
    rdfs:domain ind:BomConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supplierMaterialId rdf:type rdf:Property ;
    rdfs:label 'Supplier Material Id' ;
    rdfs:comment 'Foreign key linking to rawmaterial.supplier_material. Business justification: BOM consumption records must reference the specific supplier material used (grade, compliance status, price) for supplier performance tracking, cost accounting by supplier, and compliance verification' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplierMaterial .

ind:actualQuantityConsumed rdf:type rdf:Property ;
    rdfs:label 'Actual Quantity Consumed' ;
    rdfs:comment 'Actual quantity of material consumed and posted against the production order.' ;
    rdfs:domain ind:BomConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:backflushIndicator rdf:type rdf:Property ;
    rdfs:label 'Backflush Indicator' ;
    rdfs:comment 'Flag indicating whether this consumption was posted automatically via backflushing at production confirmation.' ;
    rdfs:domain ind:BomConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bomLineItemNumber rdf:type rdf:Property ;
    rdfs:label 'Bom Line Item Number' ;
    rdfs:comment 'Line item sequence number in the BOM structure indicating which component this consumption relates to.' ;
    rdfs:domain ind:BomConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterCode rdf:type rdf:Property ;
    rdfs:label 'Cost Center Code' ;
    rdfs:comment 'Cost center to which the material consumption cost is allocated.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsRecipient rdf:type rdf:Property ;
    rdfs:label 'Goods Recipient' ;
    rdfs:comment 'Name or identifier of the person or entity receiving the goods for production use.' ;
    rdfs:domain ind:BomConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Posting Timestamp' ;
    rdfs:comment 'Exact date and time when the consumption record was created in the system.' ;
    rdfs:domain ind:BomConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:productionOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Production Order Number' ;
    rdfs:comment 'Business identifier of the production order for which materials were consumed.' ;
    rdfs:domain ind:BomConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reservationItemNumber rdf:type rdf:Property ;
    rdfs:label 'Reservation Item Number' ;
    rdfs:comment 'Line item number within the reservation document.' ;
    rdfs:domain ind:BomConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalIndicator rdf:type rdf:Property ;
    rdfs:label 'Reversal Indicator' ;
    rdfs:comment 'Flag indicating whether this consumption record is a reversal of a previous posting.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:standardCostPerUnit rdf:type rdf:Property ;
    rdfs:label 'Standard Cost Per Unit' ;
    rdfs:comment 'Standard cost per unit of measure for the consumed material at the time of posting.' ;
    rdfs:domain ind:BomConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCostAmount rdf:type rdf:Property ;
    rdfs:label 'Total Cost Amount' ;
    rdfs:comment 'Total cost impact of this consumption transaction, calculated as actual_quantity_consumed * standard_cost_per_unit.' ;
    rdfs:domain ind:BomConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unloadingPoint rdf:type rdf:Property ;
    rdfs:label 'Unloading Point' ;
    rdfs:comment 'Physical location or point where the material was delivered for consumption.' ;
    rdfs:domain ind:BomConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yieldRecordId rdf:type rdf:Property ;
    rdfs:label 'Yield Record Id' ;
    rdfs:comment 'Unique identifier for the yield record. Primary key for the yield record entity.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:byProductCode rdf:type rdf:Property ;
    rdfs:label 'By Product Code' ;
    rdfs:comment 'The material code or SKU for the by-product generated. References the by-product master data in the materials management system.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:byProductQuantity rdf:type rdf:Property ;
    rdfs:label 'By Product Quantity' ;
    rdfs:comment 'The quantity of by-products or co-products generated during the production process. By-products may have commercial value or require disposal.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Data Source System' ;
    rdfs:comment 'The source system from which the yield data was captured. Indicates whether data originated from SAP PP, MES, DCS (Honeywell Experion or Siemens PCS 7), LIMS, or manual entry.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lossReasonCode rdf:type rdf:Property ;
    rdfs:label 'Loss Reason Code' ;
    rdfs:comment 'Categorical code indicating the primary reason for yield loss. Used for root cause analysis, process improvement, and CAPA (Corrective and Preventive Action) initiatives. [ENUM-REF-CANDIDATE: evaporation|spillage|sampling|reaction_inefficiency|filtration_loss|equipment_holdup|transfer_loss|quality_rejection|other — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedYieldQuantity rdf:type rdf:Property ;
    rdfs:label 'Planned Yield Quantity' ;
    rdfs:comment 'The theoretical or planned yield quantity expected from the production order based on the Bill of Materials (BOM) and process parameters. Represents the target output under ideal conditions.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productionEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Production End Timestamp' ;
    rdfs:comment 'The date and time when the production batch or run was completed and yield was confirmed. Used for cycle time analysis and OEE calculation.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:productionLineCode rdf:type rdf:Property ;
    rdfs:label 'Production Line Code' ;
    rdfs:comment 'Identifier for the production line, reactor, or processing unit where the batch was manufactured. May reference DCS (Distributed Control System) or MES (Manufacturing Execution System) equipment identifiers.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Production Start Timestamp' ;
    rdfs:comment 'The date and time when the production batch or run was started. Captured from MES (Manufacturing Execution System) or DCS (Distributed Control System) logs.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rawMaterialCost rdf:type rdf:Property ;
    rdfs:label 'Raw Material Cost' ;
    rdfs:comment 'The total cost of raw materials consumed in this production run. Used for cost accounting, COGS (Cost of Goods Sold) calculation, and yield-based profitability analysis.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recipeVersion rdf:type rdf:Property ;
    rdfs:label 'Recipe Version' ;
    rdfs:comment 'The version of the production recipe or master formula used for this batch. Critical for traceability and Management of Change (MOC) compliance.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:theoreticalYieldBasis rdf:type rdf:Property ;
    rdfs:label 'Theoretical Yield Basis' ;
    rdfs:comment 'The method or basis used to calculate the planned yield. Indicates whether the theoretical yield was derived from BOM standards, process simulation (e.g., Aspen HYSYS), historical averages, or lab/pilot scale data.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceThresholdPercentage rdf:type rdf:Property ;
    rdfs:label 'Variance Threshold Percentage' ;
    rdfs:comment 'The acceptable variance threshold percentage used to determine if yield_variance_flag should be set. Typically defined in process control plans or SOPs (Standard Operating Procedures).' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wasteClassification rdf:type rdf:Property ;
    rdfs:label 'Waste Classification' ;
    rdfs:comment 'Classification of the waste material for environmental and regulatory purposes. Indicates whether waste is hazardous, contains VOC (Volatile Organic Compounds), HAP (Hazardous Air Pollutants), or is recyclable.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteQuantity rdf:type rdf:Property ;
    rdfs:label 'Waste Quantity' ;
    rdfs:comment 'The quantity of waste material generated during production that requires disposal or treatment. Critical for environmental reporting and TRI (Toxics Release Inventory) compliance.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yieldConfirmationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Yield Confirmation Timestamp' ;
    rdfs:comment 'The date and time when the actual yield quantity was confirmed and recorded in the system. May differ from production_end_timestamp if post-production weighing or measurement is required.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:yieldEfficiencyScore rdf:type rdf:Property ;
    rdfs:label 'Yield Efficiency Score' ;
    rdfs:comment 'A normalized efficiency score (0-100) that factors in yield percentage, quality status, and process losses. Used for benchmarking and continuous improvement initiatives.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yieldLossQuantity rdf:type rdf:Property ;
    rdfs:label 'Yield Loss Quantity' ;
    rdfs:comment 'The total quantity of material lost during the production process due to evaporation, spillage, sampling, filtration loss, reaction inefficiency, or other process losses. Represents unrecoverable material.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yieldVarianceFlag rdf:type rdf:Property ;
    rdfs:label 'Yield Variance Flag' ;
    rdfs:comment 'Boolean flag indicating whether the yield variance exceeds acceptable tolerance limits. True indicates an out-of-specification (OOS) or out-of-trend (OOT) condition requiring investigation.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:yieldVarianceQuantity rdf:type rdf:Property ;
    rdfs:label 'Yield Variance Quantity' ;
    rdfs:comment 'The absolute difference between planned and actual yield (planned_yield_quantity - actual_yield_quantity). Positive values indicate under-production; negative values indicate over-production.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchSize rdf:type rdf:Property ;
    rdfs:label 'Batch Size' ;
    rdfs:comment 'The standard batch size for this production schedule. In batch chemical manufacturing, this represents the quantity produced in a single reactor charge or process cycle.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:campaignFlag rdf:type rdf:Property ;
    rdfs:label 'Campaign Flag' ;
    rdfs:comment 'Indicates whether this schedule is part of a multi-batch production campaign where the same product is manufactured continuously across multiple batches to optimize changeover time and yield.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capacityRequirementHours rdf:type rdf:Property ;
    rdfs:label 'Capacity Requirement Hours' ;
    rdfs:comment 'The total work center capacity required to complete this schedule, expressed in machine hours or labor hours.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:changeoverTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Changeover Time Minutes' ;
    rdfs:comment 'The estimated time in minutes required to changeover the work center from the previous product to this scheduled product, including cleaning (CIP), equipment reconfiguration, and line clearance.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:completedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Completed Timestamp' ;
    rdfs:comment 'The date and time when this scheduled production was completed and confirmed in the system.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:environmentalPermitNumber rdf:type rdf:Property ;
    rdfs:label 'Environmental Permit Number' ;
    rdfs:comment 'Reference to the environmental permit or air quality permit required for this production, particularly for processes that emit VOCs (Volatile Organic Compounds) or HAPs (Hazardous Air Pollutants).' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedYieldPercentage rdf:type rdf:Property ;
    rdfs:label 'Expected Yield Percentage' ;
    rdfs:comment 'The expected production yield as a percentage of theoretical maximum, accounting for normal process losses, waste, and off-spec material.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:frozenFlag rdf:type rdf:Property ;
    rdfs:label 'Frozen Flag' ;
    rdfs:comment 'Indicates whether this schedule is frozen and locked from further changes, typically within the frozen planning horizon where changes require special approval.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:numberOfBatches rdf:type rdf:Property ;
    rdfs:label 'Number Of Batches' ;
    rdfs:comment 'The total number of batches required to fulfill the planned quantity for this schedule.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:planningPeriod rdf:type rdf:Property ;
    rdfs:label 'Planning Period' ;
    rdfs:comment 'The planning horizon period for this schedule entry, expressed as year-quarter, year-month, or year-week (e.g., 2024-Q2, 2024-M06, 2024-W23).' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityRank rdf:type rdf:Property ;
    rdfs:label 'Priority Rank' ;
    rdfs:comment 'Numeric priority ranking for scheduling sequence, where lower numbers indicate higher priority. Used for sequencing when multiple schedules compete for the same work center.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:releasedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Released Timestamp' ;
    rdfs:comment 'The date and time when this schedule was released for execution to the Manufacturing Execution System (MES) or shop floor.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:runTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Run Time Minutes' ;
    rdfs:comment 'The estimated production run time in minutes to manufacture the planned quantity, excluding setup and changeover.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:safetyReviewRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Review Required Flag' ;
    rdfs:comment 'Indicates whether this schedule requires a safety review or Process Hazard Analysis (PHA) before execution, typically for new products, process changes, or hazardous materials.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduleNumber rdf:type rdf:Property ;
    rdfs:label 'Schedule Number' ;
    rdfs:comment 'Business identifier for the production schedule, externally visible and used for tracking and communication across planning and execution teams.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleStatus rdf:type rdf:Property ;
    rdfs:label 'Schedule Status' ;
    rdfs:comment 'Current lifecycle status of the production schedule: planned (initial draft), firmed (committed but not released), released (authorized for execution), in_progress (actively running), completed (finished), cancelled (voided).' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledEndDatetime rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Datetime' ;
    rdfs:comment 'The planned date and time when production is scheduled to complete for this schedule entry.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledStartDatetime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Datetime' ;
    rdfs:comment 'The planned date and time when production is scheduled to begin for this schedule entry.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:schedulingConstraintNotes rdf:type rdf:Property ;
    rdfs:label 'Scheduling Constraint Notes' ;
    rdfs:comment 'Free-text notes capturing any special scheduling constraints, dependencies, or considerations such as raw material availability, regulatory windows, customer delivery commitments, or equipment maintenance windows.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schedulingMethod rdf:type rdf:Property ;
    rdfs:label 'Scheduling Method' ;
    rdfs:comment 'The scheduling algorithm used to create this schedule: forward (from earliest start), backward (from required delivery), finite (capacity-constrained), or infinite (capacity-unconstrained).' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:setupTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Setup Time Minutes' ;
    rdfs:comment 'The time in minutes required to set up equipment, load raw materials, and prepare the work center before production can begin.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftPattern rdf:type rdf:Property ;
    rdfs:label 'Shift Pattern' ;
    rdfs:comment 'The shift pattern during which this production is scheduled to run (day, night, swing, continuous 24/7, or weekend).' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resourceId rdf:type rdf:Property ;
    rdfs:label 'Resource Id' ;
    rdfs:comment 'Foreign key linking to production.resource. Business justification: Work center may be associated with a generic resource; adding resource_id creates proper reference.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Resource .

ind:samplingPlanId rdf:type rdf:Property ;
    rdfs:label 'Sampling Plan Id' ;
    rdfs:comment 'Foreign key linking to quality.sampling_plan. Business justification: Work centers have associated sampling plans defining how and how frequently samples are taken at that production location — a GMP in-process control requirement. This link enables work-center-specific' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SamplingPlan .

ind:availableCapacityHoursPerDay rdf:type rdf:Property ;
    rdfs:label 'Available Capacity Hours Per Day' ;
    rdfs:comment 'Standard available operating hours per day for this work center, used in capacity planning and scheduling calculations.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchSizeUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Batch Size Unit Of Measure' ;
    rdfs:comment 'Unit of measure for batch size specifications (minimum and maximum) for this work center.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityCategory rdf:type rdf:Property ;
    rdfs:label 'Capacity Category' ;
    rdfs:comment 'Classification of capacity type used for production planning and scheduling calculations in SAP PP.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityUtilizationRatePercent rdf:type rdf:Property ;
    rdfs:label 'Capacity Utilization Rate Percent' ;
    rdfs:comment 'Current capacity utilization rate expressed as a percentage, indicating how much of available capacity is being used.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cipCleanInPlaceCapableFlag rdf:type rdf:Property ;
    rdfs:label 'Cip Clean In Place Capable Flag' ;
    rdfs:comment 'Indicates whether this work center is equipped with CIP (Clean In Place) automated cleaning systems for sanitation between production runs.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crewSizeStandard rdf:type rdf:Property ;
    rdfs:label 'Crew Size Standard' ;
    rdfs:comment 'Standard number of operators or crew members required to operate this work center during normal production.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dcsSystemType rdf:type rdf:Property ;
    rdfs:label 'Dcs System Type' ;
    rdfs:comment 'Type or vendor of the DCS system controlling this work center for process automation and monitoring.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:efficiencyFactorPercent rdf:type rdf:Property ;
    rdfs:label 'Efficiency Factor Percent' ;
    rdfs:comment 'Standard efficiency factor applied to capacity calculations, representing the expected performance level relative to theoretical maximum.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ehsPermitRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Ehs Permit Required Flag' ;
    rdfs:comment 'Indicates whether EHS (Environment Health and Safety) permits or special authorizations are required to operate this work center.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gmpClassification rdf:type rdf:Property ;
    rdfs:label 'Gmp Classification' ;
    rdfs:comment 'GMP (Good Manufacturing Practice) classification level for this work center, indicating compliance requirements for pharmaceutical or food-contact chemical production.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastMajorOverhaulDate rdf:type rdf:Property ;
    rdfs:label 'Last Major Overhaul Date' ;
    rdfs:comment 'Date of the most recent major overhaul or significant maintenance activity performed on this work center.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maximumBatchSize rdf:type rdf:Property ;
    rdfs:label 'Maximum Batch Size' ;
    rdfs:comment 'Maximum production batch size that can be processed at this work center, expressed in the standard unit of measure.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumBatchSize rdf:type rdf:Property ;
    rdfs:label 'Minimum Batch Size' ;
    rdfs:comment 'Minimum production batch size that can be processed at this work center, expressed in the standard unit of measure.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextPsrDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Psr Due Date' ;
    rdfs:comment 'Scheduled date for the next required Process Safety Review or PHA (Process Hazard Analysis) for this work center.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextScheduledMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Maintenance Date' ;
    rdfs:comment 'Date of the next scheduled preventive maintenance activity for this work center.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:oeeTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Oee Target Percent' ;
    rdfs:comment 'Target OEE (Overall Equipment Effectiveness) percentage for this work center, combining availability, performance, and quality metrics.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operationalStatus rdf:type rdf:Property ;
    rdfs:label 'Operational Status' ;
    rdfs:comment 'Current operational state of the work center indicating availability for production scheduling and execution.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phControlCapabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Ph Control Capability Flag' ;
    rdfs:comment 'Indicates whether this work center has automated pH (Potential of Hydrogen) control capabilities for chemical process management.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:piSystemTagPrefix rdf:type rdf:Property ;
    rdfs:label 'Pi System Tag Prefix' ;
    rdfs:comment 'Aveva PI System tag prefix used for real-time process data historian integration and time-series data collection from this work center.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plcControllerReference rdf:type rdf:Property ;
    rdfs:label 'Plc Controller Reference' ;
    rdfs:comment 'Identifier for the PLC (Programmable Logic Controller) managing discrete control functions for this work center.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pressureControlCapabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Pressure Control Capability Flag' ;
    rdfs:comment 'Indicates whether this work center has automated pressure control capabilities for process management.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:psrProcessSafetyReviewDate rdf:type rdf:Property ;
    rdfs:label 'Psr Process Safety Review Date' ;
    rdfs:comment 'Date of the most recent Process Safety Review or Process Hazard Analysis (PHA) conducted for this work center.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scadaNodeReference rdf:type rdf:Property ;
    rdfs:label 'Scada Node Reference' ;
    rdfs:comment 'SCADA (Supervisory Control and Data Acquisition) system node identifier for real-time monitoring and data collection from this work center.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teardownTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Teardown Time Minutes' ;
    rdfs:comment 'Standard teardown or cleanup time in minutes required after completing a production run at this work center.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureControlCapabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Control Capability Flag' ;
    rdfs:comment 'Indicates whether this work center has automated temperature control capabilities for process management.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workCenterCategory rdf:type rdf:Property ;
    rdfs:label 'Work Center Category' ;
    rdfs:comment 'Operational category indicating the processing mode and operational characteristics of the work center.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workCenterName rdf:type rdf:Property ;
    rdfs:label 'Work Center Name' ;
    rdfs:comment 'Descriptive name of the work center for human identification and reporting purposes.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workCenterType rdf:type rdf:Property ;
    rdfs:label 'Work Center Type' ;
    rdfs:comment 'Classification of the work center based on its primary production function within the chemical manufacturing process.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionDeviationId rdf:type rdf:Property ;
    rdfs:label 'Production Deviation Id' ;
    rdfs:comment 'Unique identifier for the production deviation record. Primary key.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductionDeviation .

ind:correctiveWorkOrderId rdf:type rdf:Property ;
    rdfs:label 'Corrective Work Order Id' ;
    rdfs:comment 'Foreign key linking to maintenance.work_order. Business justification: GMP and quality regulations in chemical manufacturing require production deviations to be linked to corrective maintenance work orders when equipment is the root cause. Role-prefix \'corrective_\' disti' ;
    rdfs:domain ind:ProductionDeviation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrder .

ind:customerNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Date' ;
    rdfs:comment 'Date when affected customers were notified of the deviation, if applicable.' ;
    rdfs:domain ind:ProductionDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customerNotificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Required Flag' ;
    rdfs:comment 'Boolean indicator whether customers must be notified of this deviation due to potential product quality or safety impact.' ;
    rdfs:domain ind:ProductionDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:detectedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Detected Timestamp' ;
    rdfs:comment 'Date and time when the deviation was first detected or observed during production.' ;
    rdfs:domain ind:ProductionDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deviationNumber rdf:type rdf:Property ;
    rdfs:label 'Deviation Number' ;
    rdfs:comment 'Externally visible unique business identifier for the deviation, typically following format DEV-YYYYNNNN.' ;
    rdfs:domain ind:ProductionDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationType rdf:type rdf:Property ;
    rdfs:label 'Deviation Type' ;
    rdfs:comment 'Classification of the deviation by category: process (out-of-spec process parameter), material (raw material issue), equipment (equipment malfunction), documentation (procedure not followed), environmental (EHS event), safety (PSM incident), quality (OOS result), or other. [ENUM-REF-CANDIDATE: process|material|equipment|documentation|environmental|safety|quality|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ProductionDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdInitiatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Hold Initiated Timestamp' ;
    rdfs:comment 'Date and time when a quality or production hold was placed on the affected batch, if applicable.' ;
    rdfs:domain ind:ProductionDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:holdReleasedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Hold Released Timestamp' ;
    rdfs:comment 'Date and time when the hold was released and the batch was cleared for further processing or shipment.' ;
    rdfs:domain ind:ProductionDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:immediateActionTaken rdf:type rdf:Property ;
    rdfs:label 'Immediate Action Taken' ;
    rdfs:comment 'Description of the immediate corrective actions taken at the time of deviation detection to contain the issue.' ;
    rdfs:domain ind:ProductionDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Investigation Completed Timestamp' ;
    rdfs:comment 'Date and time when the root cause investigation was completed and documented.' ;
    rdfs:domain ind:ProductionDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ootFlag rdf:type rdf:Property ;
    rdfs:label 'Oot Flag' ;
    rdfs:comment 'Boolean indicator whether this deviation represents an out-of-trend (OOT) condition in process or quality data.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preventiveAction rdf:type rdf:Property ;
    rdfs:label 'Preventive Action' ;
    rdfs:comment 'Description of the preventive actions taken to eliminate potential causes of similar deviations in the future.' ;
    rdfs:domain ind:ProductionDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionDeviationDescription rdf:type rdf:Property ;
    rdfs:label 'Production Deviation Description' ;
    rdfs:comment 'Detailed narrative description of the deviation event, including what was observed and the circumstances.' ;
    rdfs:domain ind:ProductionDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionDeviationStatus rdf:type rdf:Property ;
    rdfs:label 'Production Deviation Status' ;
    rdfs:comment 'Current lifecycle status of the deviation: open (newly reported), under_investigation (root cause analysis in progress), pending_approval (awaiting management review), closed (resolved and approved), cancelled (determined not a deviation).' ;
    rdfs:domain ind:ProductionDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Date' ;
    rdfs:comment 'Date when the deviation was reported to the relevant regulatory authority, if applicable.' ;
    rdfs:domain ind:ProductionDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryReportableFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reportable Flag' ;
    rdfs:comment 'Boolean indicator whether this deviation must be reported to regulatory authorities (FDA, EPA, OSHA, etc.) based on severity and impact.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rootCauseCategory rdf:type rdf:Property ;
    rdfs:label 'Root Cause Category' ;
    rdfs:comment 'High-level classification of the root cause: human_error, equipment_failure, material_defect, process_design, environmental, procedural, or unknown (if investigation incomplete). [ENUM-REF-CANDIDATE: human_error|equipment_failure|material_defect|process_design|environmental|procedural|unknown — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processChangeRecordId rdf:type rdf:Property ;
    rdfs:label 'Process Change Record Id' ;
    rdfs:comment 'Unique identifier for the Management of Change (MOC) record. Primary key for process change tracking and PSM compliance.' ;
    rdfs:domain ind:ProcessChangeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualImplementationDate rdf:type rdf:Property ;
    rdfs:label 'Actual Implementation Date' ;
    rdfs:comment 'Actual date when the change was implemented in the production environment.' ;
    rdfs:domain ind:ProcessChangeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:affectedProcessUnit rdf:type rdf:Property ;
    rdfs:label 'Affected Process Unit' ;
    rdfs:comment 'Identification of the process unit, production line, or manufacturing area impacted by the change.' ;
    rdfs:domain ind:ProcessChangeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedSopNumber rdf:type rdf:Property ;
    rdfs:label 'Affected Sop Number' ;
    rdfs:comment 'Identifier of the SOP document that requires revision as a result of this change.' ;
    rdfs:domain ind:ProcessChangeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalWorkflowStage rdf:type rdf:Property ;
    rdfs:label 'Approval Workflow Stage' ;
    rdfs:comment 'Current stage in the multi-level approval workflow (e.g., supervisor review, engineering review, safety review, management approval).' ;
    rdfs:domain ind:ProcessChangeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeCategory rdf:type rdf:Property ;
    rdfs:label 'Change Category' ;
    rdfs:comment 'Duration classification of the change: temporary (time-limited trial), permanent (long-term modification), or emergency (immediate safety-driven change).' ;
    rdfs:domain ind:ProcessChangeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeType rdf:type rdf:Property ;
    rdfs:label 'Change Type' ;
    rdfs:comment 'Classification of the type of change being requested: process (reaction parameters, operating conditions), equipment (hardware modifications), material (raw material substitutions), procedure (SOP updates), facility (infrastructure changes), or software (control system updates).' ;
    rdfs:domain ind:ProcessChangeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentReferences rdf:type rdf:Property ;
    rdfs:label 'Document References' ;
    rdfs:comment 'List of supporting documents associated with the MOC, including P&IDs, SOPs, risk assessments, training materials, and approval forms.' ;
    rdfs:domain ind:ProcessChangeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost' ;
    rdfs:comment 'Estimated total cost of implementing the change, including materials, labor, downtime, and training expenses.' ;
    rdfs:domain ind:ProcessChangeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:implementationNotes rdf:type rdf:Property ;
    rdfs:label 'Implementation Notes' ;
    rdfs:comment 'Detailed notes documenting the implementation process, any deviations from the plan, and observations during execution.' ;
    rdfs:domain ind:ProcessChangeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiatorDepartment rdf:type rdf:Property ;
    rdfs:label 'Initiator Department' ;
    rdfs:comment 'Department or functional area of the change initiator (e.g., Production, Engineering, Quality, R&D).' ;
    rdfs:domain ind:ProcessChangeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:justification rdf:type rdf:Property ;
    rdfs:label 'Justification' ;
    rdfs:comment 'Business and technical justification for the change, including expected benefits, cost savings, safety improvements, or regulatory compliance drivers.' ;
    rdfs:domain ind:ProcessChangeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phaReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Pha Reference Number' ;
    rdfs:comment 'Reference identifier for the associated PHA or HAZOP study conducted to evaluate the change.' ;
    rdfs:domain ind:ProcessChangeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedImplementationDate rdf:type rdf:Property ;
    rdfs:label 'Planned Implementation Date' ;
    rdfs:comment 'Scheduled date for implementing the approved change in the production environment.' ;
    rdfs:domain ind:ProcessChangeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:postImplementationReviewDate rdf:type rdf:Property ;
    rdfs:label 'Post Implementation Review Date' ;
    rdfs:comment 'Date when the post-implementation review was conducted to assess the effectiveness and safety of the change.' ;
    rdfs:domain ind:ProcessChangeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:postImplementationReviewFindings rdf:type rdf:Property ;
    rdfs:label 'Post Implementation Review Findings' ;
    rdfs:comment 'Summary of findings from the post-implementation review, including any corrective actions or lessons learned.' ;
    rdfs:domain ind:ProcessChangeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postImplementationReviewRequired rdf:type rdf:Property ;
    rdfs:label 'Post Implementation Review Required' ;
    rdfs:comment 'Indicates whether a post-implementation review is required to verify the change achieved its objectives and did not introduce new hazards.' ;
    rdfs:domain ind:ProcessChangeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:processChangeRecordDescription rdf:type rdf:Property ;
    rdfs:label 'Process Change Record Description' ;
    rdfs:comment 'Detailed narrative description of the proposed change, including technical specifications, scope, and rationale for the modification.' ;
    rdfs:domain ind:ProcessChangeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processChangeRecordStatus rdf:type rdf:Property ;
    rdfs:label 'Process Change Record Status' ;
    rdfs:comment 'Current lifecycle status of the MOC record in the approval and implementation workflow. [ENUM-REF-CANDIDATE: draft|submitted|under_review|approved|rejected|implementation|completed|closed — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ProcessChangeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAgency rdf:type rdf:Property ;
    rdfs:label 'Regulatory Agency' ;
    rdfs:comment 'Name of the regulatory agency that was notified (e.g., EPA, OSHA, ECHA, FDA, state environmental agency).' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Date' ;
    rdfs:comment 'Date when regulatory notification was submitted to the appropriate governing body.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Required' ;
    rdfs:comment 'Indicates whether regulatory agencies (EPA, OSHA, ECHA, FDA) must be notified of this change due to compliance requirements.' ;
    rdfs:domain ind:ProcessChangeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riskAssessmentRequired rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Required' ;
    rdfs:comment 'Indicates whether a formal risk assessment (PHA, HAZOP, or other methodology) is required for this change.' ;
    rdfs:domain ind:ProcessChangeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riskAssessmentSummary rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Summary' ;
    rdfs:comment 'Summary of the risk assessment findings, including identified hazards, risk levels, and mitigation measures.' ;
    rdfs:domain ind:ProcessChangeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskLevel rdf:type rdf:Property ;
    rdfs:label 'Risk Level' ;
    rdfs:comment 'Overall risk classification assigned to the change based on the risk assessment (low, medium, high, critical).' ;
    rdfs:domain ind:ProcessChangeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:title rdf:type rdf:Property ;
    rdfs:label 'Title' ;
    rdfs:comment 'Brief descriptive title summarizing the nature of the change for quick identification and reporting.' ;
    rdfs:domain ind:ProcessChangeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Training Completion Date' ;
    rdfs:comment 'Date when all required training for affected personnel was completed.' ;
    rdfs:domain ind:ProcessChangeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trainingDescription rdf:type rdf:Property ;
    rdfs:label 'Training Description' ;
    rdfs:comment 'Description of the training content and scope provided to personnel affected by the change.' ;
    rdfs:domain ind:ProcessChangeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingRequired rdf:type rdf:Property ;
    rdfs:label 'Training Required' ;
    rdfs:comment 'Indicates whether operator or staff training is required before or after implementing the change.' ;
    rdfs:domain ind:ProcessChangeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:actualBatchCount rdf:type rdf:Property ;
    rdfs:label 'Actual Batch Count' ;
    rdfs:comment 'Number of production batches actually executed within this campaign. Updated as batches are completed.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:campaignName rdf:type rdf:Property ;
    rdfs:label 'Campaign Name' ;
    rdfs:comment 'Descriptive name of the production campaign, typically indicating the product family or synthesis route being manufactured.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignNumber rdf:type rdf:Property ;
    rdfs:label 'Campaign Number' ;
    rdfs:comment 'Business identifier for the campaign, externally visible and used in production planning and scheduling systems. Typically follows plant-specific numbering conventions.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignStatus rdf:type rdf:Property ;
    rdfs:label 'Campaign Status' ;
    rdfs:comment 'Current lifecycle status of the production campaign. Tracks progression from planning through execution to completion or cancellation. [ENUM-REF-CANDIDATE: planned|scheduled|in_progress|on_hold|completed|cancelled|aborted — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignType rdf:type rdf:Property ;
    rdfs:label 'Campaign Type' ;
    rdfs:comment 'Classification of the campaign based on equipment utilization strategy. Dedicated campaigns run a single product exclusively; shared campaigns alternate between products in the same family; multi-product campaigns produce multiple SKUs; trial campaigns are for R&D validation.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeoverTimeHours rdf:type rdf:Property ;
    rdfs:label 'Changeover Time Hours' ;
    rdfs:comment 'Total time in hours required for equipment changeover and setup at the start of the campaign. Includes line clearance, equipment configuration, and pre-production checks.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cipDurationHours rdf:type rdf:Property ;
    rdfs:label 'Cip Duration Hours' ;
    rdfs:comment 'Total time in hours allocated for CIP operations during the campaign. Used for OEE calculations and scheduling.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cipScheduleType rdf:type rdf:Property ;
    rdfs:label 'Cip Schedule Type' ;
    rdfs:comment 'Cleaning schedule strategy for the campaign. Between-batches requires CIP after each batch; end-of-campaign performs CIP only at campaign completion; as-needed is based on contamination risk assessment.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costVariancePercentage rdf:type rdf:Property ;
    rdfs:label 'Cost Variance Percentage' ;
    rdfs:comment 'Percentage variance between estimated and actual cost, calculated as ((actual_cost - cost_estimate) / cost_estimate) * 100. Key financial performance indicator.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mesCampaignReference rdf:type rdf:Property ;
    rdfs:label 'Mes Campaign Reference' ;
    rdfs:comment 'External identifier from the MES system used for integration and traceability. Links to MES execution logs and real-time process data.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oeeActualPercentage rdf:type rdf:Property ;
    rdfs:label 'Oee Actual Percentage' ;
    rdfs:comment 'Actual OEE percentage achieved during the campaign, calculated from availability, performance, and quality metrics. Key KPI for production efficiency.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oeeTargetPercentage rdf:type rdf:Property ;
    rdfs:label 'Oee Target Percentage' ;
    rdfs:comment 'Target OEE percentage for the campaign, representing planned equipment utilization efficiency. Used for performance benchmarking.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedBatchCount rdf:type rdf:Property ;
    rdfs:label 'Planned Batch Count' ;
    rdfs:comment 'Number of production batches planned for this campaign at the time of campaign creation.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priorityLevel rdf:type rdf:Property ;
    rdfs:label 'Priority Level' ;
    rdfs:comment 'Business priority assigned to the campaign for scheduling and resource allocation. Critical campaigns receive preferential treatment in capacity planning.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Hold Flag' ;
    rdfs:comment 'Indicates whether the campaign output is under quality hold pending final release by QA. Prevents shipment until cleared.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cipRecordId rdf:type rdf:Property ;
    rdfs:label 'Cip Record Id' ;
    rdfs:comment 'Unique identifier for the CIP execution record. Primary key for the CIP record entity.' ;
    rdfs:domain ind:CipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cleaningAgentLotId rdf:type rdf:Property ;
    rdfs:label 'Cleaning Agent Lot Id' ;
    rdfs:comment 'Foreign key linking to inventory.lot. Business justification: GMP CIP records must document the specific lot of cleaning agent used for equipment cleaning validation. Required for regulatory audit trails (FDA, EMA). Role-prefix \'cleaning_agent_\' distinguishes th' ;
    rdfs:domain ind:CipRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lot .

ind:nextChemicalProductId rdf:type rdf:Property ;
    rdfs:label 'Next Chemical Product Id' ;
    rdfs:comment 'Foreign key linking to product.chemical_product. Business justification: CIP (Clean-In-Place) records document equipment cleaning between product campaigns. The next product to be manufactured determines cleaning validation requirements and cross-contamination risk assessm' ;
    rdfs:domain ind:CipRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ChemicalProduct .

ind:previousMaterialMasterId rdf:type rdf:Property ;
    rdfs:label 'Previous Material Master Id' ;
    rdfs:comment 'Foreign key linking to rawmaterial.material_master. Business justification: CIP scheduling needs the previous product\'s raw-material details to validate cleaning effectiveness.' ;
    rdfs:domain ind:CipRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialMaster .

ind:cipCycleNumber rdf:type rdf:Property ;
    rdfs:label 'Cip Cycle Number' ;
    rdfs:comment 'Sequential cycle number for this equipment. Tracks the number of CIP cycles performed on the equipment for maintenance and lifecycle analysis.' ;
    rdfs:domain ind:CipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cipProcedureReference rdf:type rdf:Property ;
    rdfs:label 'Cip Procedure Reference' ;
    rdfs:comment 'Reference code to the Standard Operating Procedure (SOP) or master recipe used for this CIP execution. Defines the cleaning protocol, agent, temperature, duration, and acceptance criteria.' ;
    rdfs:domain ind:CipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cipStatus rdf:type rdf:Property ;
    rdfs:label 'Cip Status' ;
    rdfs:comment 'Current status of the CIP execution: in_progress (cleaning underway), completed (successfully finished), failed (did not meet acceptance criteria), aborted (manually stopped), pending_review (awaiting QA approval).' ;
    rdfs:domain ind:CipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cipType rdf:type rdf:Property ;
    rdfs:label 'Cip Type' ;
    rdfs:comment 'Type of CIP execution: manual (operator-driven), automatic (fully automated via DCS/PLC), or semi-automatic (operator-initiated, system-controlled).' ;
    rdfs:domain ind:CipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cleaningAgentCode rdf:type rdf:Property ;
    rdfs:label 'Cleaning Agent Code' ;
    rdfs:comment 'Material code of the cleaning agent or detergent used in the CIP process (e.g., caustic soda, acid wash, sanitizer). Links to material master.' ;
    rdfs:domain ind:CipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cleaningAgentConcentrationPpm rdf:type rdf:Property ;
    rdfs:label 'Cleaning Agent Concentration Ppm' ;
    rdfs:comment 'Concentration of the cleaning agent in parts per million (PPM) used during the CIP cycle. Critical for ensuring effective cleaning without residue.' ;
    rdfs:domain ind:CipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cleaningAgentName rdf:type rdf:Property ;
    rdfs:label 'Cleaning Agent Name' ;
    rdfs:comment 'Descriptive name of the cleaning agent used (e.g., Sodium Hydroxide Solution, Nitric Acid 10%, Hydrogen Peroxide Sanitizer).' ;
    rdfs:domain ind:CipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cleaningDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Cleaning Duration Minutes' ;
    rdfs:comment 'Total duration of the CIP cleaning cycle in minutes, from start of cleaning agent circulation to completion of final rinse.' ;
    rdfs:domain ind:CipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cleaningTemperatureCelsius rdf:type rdf:Property ;
    rdfs:label 'Cleaning Temperature Celsius' ;
    rdfs:comment 'Temperature in degrees Celsius at which the CIP cleaning cycle was executed. Temperature is critical for cleaning efficacy and must meet SOP specifications.' ;
    rdfs:domain ind:CipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:flowRateLitersPerMinute rdf:type rdf:Property ;
    rdfs:label 'Flow Rate Liters Per Minute' ;
    rdfs:comment 'Flow rate of cleaning solution in liters per minute during the CIP cycle. Adequate flow rate ensures complete coverage and effective cleaning.' ;
    rdfs:domain ind:CipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextProductionClearanceFlag rdf:type rdf:Property ;
    rdfs:label 'Next Production Clearance Flag' ;
    rdfs:comment 'Boolean flag indicating whether the equipment has been cleared for the next production run. True means equipment is approved for use; False means additional cleaning or inspection is required.' ;
    rdfs:domain ind:CipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operatorName rdf:type rdf:Property ;
    rdfs:label 'Operator Name' ;
    rdfs:comment 'Full name of the operator who executed or supervised the CIP cycle. Captured for audit trail and accountability.' ;
    rdfs:domain ind:CipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passFailResult rdf:type rdf:Property ;
    rdfs:label 'Pass Fail Result' ;
    rdfs:comment 'Final pass/fail result of the CIP execution based on acceptance criteria (rinse water conductivity, temperature profile, duration). Conditional_pass indicates minor deviations requiring management review.' ;
    rdfs:domain ind:CipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qaComments rdf:type rdf:Property ;
    rdfs:label 'Qa Comments' ;
    rdfs:comment 'Free-text comments from the QA reviewer regarding the CIP execution, any deviations observed, or additional actions required.' ;
    rdfs:domain ind:CipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qaReviewTimestamp rdf:type rdf:Property ;
    rdfs:label 'Qa Review Timestamp' ;
    rdfs:comment 'Date and time when the QA reviewer approved or rejected the CIP record. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:CipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:regulatoryComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Status' ;
    rdfs:comment 'Compliance status of the CIP execution with respect to GMP, FDA, and food-contact regulations. Compliant means all criteria met; non_compliant triggers investigation; pending_review awaits final determination.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rinseWaterConductivityUsCm rdf:type rdf:Property ;
    rdfs:label 'Rinse Water Conductivity Us Cm' ;
    rdfs:comment 'Electrical conductivity of the final rinse water in microsiemens per centimeter (µS/cm). Low conductivity indicates effective removal of cleaning agent residues. Typical acceptance threshold is below 20 µS/cm.' ;
    rdfs:domain ind:CipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scadaIntegrationReference rdf:type rdf:Property ;
    rdfs:label 'Scada Integration Reference' ;
    rdfs:comment 'Integration identifier linking this CIP record to SCADA system logs and real-time process data captured during the cleaning cycle.' ;
    rdfs:domain ind:CipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Timestamp' ;
    rdfs:comment 'Planned date and time when the CIP cycle was scheduled to begin. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:facilityId rdf:type rdf:Property ;
    rdfs:label 'Facility Id' ;
    rdfs:comment 'Foreign key linking to ehs.facility. Business justification: Chemical products are manufactured at specific facilities. Facility-level TRI, RMP, and EPCRA regulatory reporting requires knowing which facility produces each chemical product. A chemical manufactur' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:primaryVendorId rdf:type rdf:Property ;
    rdfs:label 'Primary Vendor Id' ;
    rdfs:comment 'Foreign key linking to supply.vendor. Business justification: Procurement Planning uses a designated primary vendor per chemical product to generate purchase orders, cost analysis, and supplier performance reporting.' ;
    rdfs:domain ind:ChemicalProduct ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:salesTerritoryId rdf:type rdf:Property ;
    rdfs:label 'Sales Territory Id' ;
    rdfs:comment 'Foreign key linking to sales.territory. Business justification: Required for Regional Pricing and Regulatory Reporting linking product to its default sales territory.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Territory .

ind:applicationGuidelines rdf:type rdf:Property ;
    rdfs:label 'Application Guidelines' ;
    rdfs:comment 'Recommended use cases and application instructions for the product. Describes target industries, processes, and best practices for product utilization.' ;
    rdfs:domain ind:ChemicalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Base Unit Of Measure' ;
    rdfs:comment 'Primary unit of measure for inventory, sales, and production transactions. KG: kilogram, L: liter, MT: metric ton, GAL: gallon, LB: pound, TON: short ton.' ;
    rdfs:domain ind:ChemicalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chemicalName rdf:type rdf:Property ;
    rdfs:label 'Chemical Name' ;
    rdfs:comment 'IUPAC systematic chemical name or common chemical name describing the molecular composition. Used for regulatory reporting and technical documentation.' ;
    rdfs:domain ind:ChemicalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:densityKgPerL rdf:type rdf:Property ;
    rdfs:label 'Density Kg Per L' ;
    rdfs:comment 'Product density in kilograms per liter at standard temperature and pressure. Used for volume-to-weight conversions in logistics and formulation calculations.' ;
    rdfs:domain ind:ChemicalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discontinuationDate rdf:type rdf:Property ;
    rdfs:label 'Discontinuation Date' ;
    rdfs:comment 'Date the product was or will be withdrawn from active sale. Null for active products. Used for end-of-life planning and inventory liquidation.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fdaApprovalRequired rdf:type rdf:Property ;
    rdfs:label 'Fda Approval Required' ;
    rdfs:comment 'Indicates whether the product requires FDA approval for food-contact, pharmaceutical, or cosmetic applications. True if FDA oversight applies.' ;
    rdfs:domain ind:ChemicalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:flashPointC rdf:type rdf:Property ;
    rdfs:label 'Flash Point C' ;
    rdfs:comment 'Lowest temperature at which vapors ignite when exposed to an ignition source. Critical for flammability classification, storage requirements, and fire safety planning.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ghsClassification rdf:type rdf:Property ;
    rdfs:label 'Ghs Classification' ;
    rdfs:comment 'GHS hazard classification codes (e.g., H226 Flammable liquid, H302 Harmful if swallowed). Used for SDS authoring, label generation, and workplace safety communication.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ghsPictograms rdf:type rdf:Property ;
    rdfs:label 'Ghs Pictograms' ;
    rdfs:comment 'Comma-separated list of GHS pictogram codes required on product labels (e.g., GHS02 Flame, GHS07 Exclamation Mark). Communicates hazards visually per global standards.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hapContentPercent rdf:type rdf:Property ;
    rdfs:label 'Hap Content Percent' ;
    rdfs:comment 'Percentage of EPA-listed hazardous air pollutants by weight. Triggers additional reporting and control requirements under Clean Air Act regulations.' ;
    rdfs:domain ind:ChemicalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:introductionDate rdf:type rdf:Property ;
    rdfs:label 'Introduction Date' ;
    rdfs:comment 'Date the product was first made available for commercial sale. Used for product age analysis, lifecycle planning, and portfolio management.' ;
    rdfs:domain ind:ChemicalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lifecycleState rdf:type rdf:Property ;
    rdfs:label 'Lifecycle State' ;
    rdfs:comment 'Current stage in the product lifecycle. Active: available for sale. Discontinued: no longer manufactured but may have inventory. Developmental: in R&D phase. Phased Out: transitioning to discontinuation. Pending Approval: awaiting regulatory or internal approval. Obsolete: fully retired.' ;
    rdfs:domain ind:ChemicalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:listPriceUsd rdf:type rdf:Property ;
    rdfs:label 'List Price Usd' ;
    rdfs:comment 'Published list price per base unit in USD before discounts or negotiations. Starting point for customer pricing discussions. Confidential business data.' ;
    rdfs:domain ind:ChemicalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packagingConfiguration rdf:type rdf:Property ;
    rdfs:label 'Packaging Configuration' ;
    rdfs:comment 'Standard packaging options available for the product (e.g., 55-gallon drum, 1000L IBC tote, bulk tanker, 25kg bag). Affects pricing, logistics, and customer ordering.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:physicalForm rdf:type rdf:Property ;
    rdfs:label 'Physical Form' ;
    rdfs:comment 'Physical state of the product at standard temperature and pressure. Critical for storage requirements, handling procedures, and transportation classification. [ENUM-REF-CANDIDATE: liquid|solid|powder|granular|gas|paste|emulsion|suspension — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productName rdf:type rdf:Property ;
    rdfs:label 'Product Name' ;
    rdfs:comment 'Official commercial product name as marketed to customers. Primary human-readable identifier used in sales literature, technical data sheets, and customer communications.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productType rdf:type rdf:Property ;
    rdfs:label 'Product Type' ;
    rdfs:comment 'Classification of product by commercial offering model. Bulk: high-volume commodity. Packaged: pre-packaged finished goods. Specialty: high-value low-volume. Custom Blend: customer-specific formulation. Intermediate: used in further manufacturing.' ;
    rdfs:domain ind:ChemicalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reachStatus rdf:type rdf:Property ;
    rdfs:label 'Reach Status' ;
    rdfs:comment 'Current REACH compliance status. Registered: full dossier submitted. Pre-registered: intent declared. Exempt: below tonnage threshold or exempted substance. Not Applicable: not sold in EU. Pending: registration in progress.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardCostUsd rdf:type rdf:Property ;
    rdfs:label 'Standard Cost Usd' ;
    rdfs:comment 'Standard manufacturing cost per base unit in USD. Used for inventory valuation, margin analysis, and financial reporting. Confidential business data.' ;
    rdfs:domain ind:ChemicalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tscaStatus rdf:type rdf:Property ;
    rdfs:label 'Tsca Status' ;
    rdfs:comment 'EPA TSCA inventory status for US market. Active: on inventory and commercially used. Inactive: on inventory but not currently manufactured. Exempt: polymer or other exemption. Not On Inventory: requires PMN before manufacture.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:viscosityCps rdf:type rdf:Property ;
    rdfs:label 'Viscosity Cps' ;
    rdfs:comment 'Dynamic viscosity measured in centipoise at standard temperature. Affects pumping requirements, mixing behavior, and application characteristics.' ;
    rdfs:domain ind:ChemicalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vocContentPercent rdf:type rdf:Property ;
    rdfs:label 'Voc Content Percent' ;
    rdfs:comment 'Percentage of volatile organic compounds by weight. Subject to EPA and state air quality regulations. Critical for environmental compliance and emissions reporting.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:applicationArea rdf:type rdf:Property ;
    rdfs:label 'Application Area' ;
    rdfs:comment 'Primary industry or application area where this SKU is used (e.g., Automotive, Construction, Electronics, Agriculture, Pharmaceuticals, Water Treatment).' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:barcode rdf:type rdf:Property ;
    rdfs:label 'Barcode' ;
    rdfs:comment 'Machine-readable barcode identifier (UPC, EAN, or GS1-128) printed on product packaging for scanning in warehouse and logistics operations.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gtin rdf:type rdf:Property ;
    rdfs:label 'Gtin' ;
    rdfs:comment 'Global Trade Item Number uniquely identifying this SKU in the global supply chain. Used for EDI transactions and retail distribution.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isControlledSubstance rdf:type rdf:Property ;
    rdfs:label 'Is Controlled Substance' ;
    rdfs:comment 'Flag indicating whether this chemical is a controlled substance requiring special licensing, reporting, and security measures under DEA or EPA regulations.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHazmat rdf:type rdf:Property ;
    rdfs:label 'Is Hazmat' ;
    rdfs:comment 'Flag indicating whether this SKU is classified as a hazardous material requiring special handling, storage, and transportation procedures.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:moqUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Moq Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the minimum order quantity field. [ENUM-REF-CANDIDATE: kg|l|mt|gal|lb|drum|ibc|bag|ea — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packSize rdf:type rdf:Property ;
    rdfs:label 'Pack Size' ;
    rdfs:comment 'Quantity of product contained in one package unit. Used with unit_of_measure to define the orderable quantity.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:skuCode rdf:type rdf:Property ;
    rdfs:label 'Sku Code' ;
    rdfs:comment 'Externally-known unique alphanumeric code identifying this specific SKU configuration. Used in ordering, shipping, and inventory systems.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skuDescription rdf:type rdf:Property ;
    rdfs:label 'Sku Description' ;
    rdfs:comment 'Human-readable description of the SKU including product name, grade, packaging type, and size. Used on sales orders, shipping documents, and invoices.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skuStatus rdf:type rdf:Property ;
    rdfs:label 'Sku Status' ;
    rdfs:comment 'Current lifecycle status of the SKU. Active SKUs are orderable; inactive and discontinued SKUs cannot be ordered; blocked SKUs are temporarily unavailable.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificGravity rdf:type rdf:Property ;
    rdfs:label 'Specific Gravity' ;
    rdfs:comment 'Ratio of the density of the chemical to the density of water at a specified temperature. Used for volume-to-weight conversions and quality control.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acsReagentFlag rdf:type rdf:Property ;
    rdfs:label 'Acs Reagent Flag' ;
    rdfs:comment 'Indicates whether this grade meets American Chemical Society (ACS) reagent specifications for laboratory and analytical use.' ;
    rdfs:domain ind:Grade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:applicationSector rdf:type rdf:Property ;
    rdfs:label 'Application Sector' ;
    rdfs:comment 'Primary industry sector or application area for which this grade is intended (e.g., pharmaceutical, food and beverage, electronics, agriculture, industrial manufacturing). [ENUM-REF-CANDIDATE: pharmaceutical|food_beverage|electronics|agriculture|industrial|research_laboratory|cosmetics|automotive|construction — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Grade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:basePricePerKg rdf:type rdf:Property ;
    rdfs:label 'Base Price Per Kg' ;
    rdfs:comment 'Standard base price per kilogram for this grade in the default currency, used as a reference for pricing agreements and quotations. Subject to volume discounts and contract terms.' ;
    rdfs:domain ind:Grade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificateOfAnalysisRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Analysis Required Flag' ;
    rdfs:comment 'Indicates whether a Certificate of Analysis (COA) must be issued with each lot or shipment of this grade, typically required for pharmaceutical, food, and high-purity grades.' ;
    rdfs:domain ind:Grade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificateOfComplianceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Compliance Required Flag' ;
    rdfs:comment 'Indicates whether a Certificate of Compliance (COC) must be issued with shipments of this grade, certifying conformance to regulatory and customer specifications.' ;
    rdfs:domain ind:Grade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:epGradeFlag rdf:type rdf:Property ;
    rdfs:label 'Ep Grade Flag' ;
    rdfs:comment 'Indicates whether this grade meets European Pharmacopoeia (EP) monograph standards for pharmaceutical use in European markets.' ;
    rdfs:domain ind:Grade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fccGradeFlag rdf:type rdf:Property ;
    rdfs:label 'Fcc Grade Flag' ;
    rdfs:comment 'Indicates whether this grade meets Food Chemicals Codex (FCC) standards for food-contact and food-additive applications.' ;
    rdfs:domain ind:Grade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gmpCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Gmp Compliant Flag' ;
    rdfs:comment 'Indicates whether this grade is manufactured under Good Manufacturing Practice (GMP) standards, required for pharmaceutical and food-contact applications.' ;
    rdfs:domain ind:Grade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gradeCode rdf:type rdf:Property ;
    rdfs:label 'Grade Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the grade within the product catalog (e.g., TG, RG, FG, PG, EG, AG for Technical, Reagent, Food, Pharmaceutical, Electronic, Agricultural grades).' ;
    rdfs:domain ind:Grade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gradeDescription rdf:type rdf:Property ;
    rdfs:label 'Grade Description' ;
    rdfs:comment 'Detailed description of the grade, including its intended use, distinguishing characteristics, and typical applications.' ;
    rdfs:domain ind:Grade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gradeName rdf:type rdf:Property ;
    rdfs:label 'Grade Name' ;
    rdfs:comment 'Full descriptive name of the grade (e.g., Technical Grade, Reagent Grade, Food Grade, Pharmaceutical Grade, Electronic Grade, Agricultural Grade).' ;
    rdfs:domain ind:Grade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gradeStatus rdf:type rdf:Property ;
    rdfs:label 'Grade Status' ;
    rdfs:comment 'Current lifecycle status of the product grade in the catalog. Determines availability for sales and production.' ;
    rdfs:domain ind:Grade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handlingRequirements rdf:type rdf:Property ;
    rdfs:label 'Handling Requirements' ;
    rdfs:comment 'Special handling, storage, and safety requirements specific to this grade (e.g., temperature control, moisture sensitivity, inert atmosphere, light protection). References Safety Data Sheet (SDS) and Process Safety Management (PSM) protocols.' ;
    rdfs:domain ind:Grade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intendedUseDescription rdf:type rdf:Property ;
    rdfs:label 'Intended Use Description' ;
    rdfs:comment 'Detailed description of the intended applications and use cases for this grade, including typical customer processes and end-product integration.' ;
    rdfs:domain ind:Grade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumImpurityPpm rdf:type rdf:Property ;
    rdfs:label 'Maximum Impurity Ppm' ;
    rdfs:comment 'Maximum allowable impurity concentration in parts per million (PPM) for this grade. Used in quality specifications and Certificate of Analysis (COA).' ;
    rdfs:domain ind:Grade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumOrderQuantityKg rdf:type rdf:Property ;
    rdfs:label 'Minimum Order Quantity Kg' ;
    rdfs:comment 'Minimum Order Quantity (MOQ) in kilograms for this grade, driven by production batch economics and packaging constraints.' ;
    rdfs:domain ind:Grade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumPurityPercentage rdf:type rdf:Property ;
    rdfs:label 'Minimum Purity Percentage' ;
    rdfs:comment 'Minimum chemical purity level required for this grade, expressed as a percentage (e.g., 99.50 for 99.5% purity). Critical for Quality Control (QC) and Certificate of Analysis (COA) compliance.' ;
    rdfs:domain ind:Grade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricingTier rdf:type rdf:Property ;
    rdfs:label 'Pricing Tier' ;
    rdfs:comment 'Pricing tier classification for this grade, reflecting the quality level and market positioning. Higher purity and specialty grades typically command premium pricing.' ;
    rdfs:domain ind:Grade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reachRegisteredFlag rdf:type rdf:Property ;
    rdfs:label 'Reach Registered Flag' ;
    rdfs:comment 'Indicates whether this grade is registered under the European REACH (Registration, Evaluation, Authorization and Restriction of Chemicals) regulation for sale in the EU.' ;
    rdfs:domain ind:Grade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryClassification rdf:type rdf:Property ;
    rdfs:label 'Regulatory Classification' ;
    rdfs:comment 'Primary regulatory classification or standard applicable to this grade (e.g., GMP-compliant, USP Grade, EP Grade, FCC Grade, ACS Reagent). May reference multiple standards separated by semicolons.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shelfLifeMonths rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Months' ;
    rdfs:comment 'Expected shelf life of this grade in months under proper storage conditions, used for inventory management (FEFO - First Expired First Out) and lot tracking.' ;
    rdfs:domain ind:Grade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tscaListedFlag rdf:type rdf:Property ;
    rdfs:label 'Tsca Listed Flag' ;
    rdfs:comment 'Indicates whether this grade is listed on the EPA TSCA (Toxic Substances Control Act) inventory for commercial use in the United States.' ;
    rdfs:domain ind:Grade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:uspGradeFlag rdf:type rdf:Property ;
    rdfs:label 'Usp Grade Flag' ;
    rdfs:comment 'Indicates whether this grade meets United States Pharmacopeia (USP) monograph standards for pharmaceutical use.' ;
    rdfs:domain ind:Grade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supersededSpecificationProductSpecificationId rdf:type rdf:Property ;
    rdfs:label 'Superseded Specification Product Specification Id' ;
    rdfs:comment 'Reference to the previous specification version that this version replaces. Nullable for initial specifications. Supports version history tracking and regulatory audit trail for specification changes.' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductSpecification .

ind:acceptanceCriteria rdf:type rdf:Property ;
    rdfs:label 'Acceptance Criteria' ;
    rdfs:comment 'Textual description of the acceptance rule for this parameter. Used for qualitative assessments or complex criteria that cannot be expressed as simple numeric ranges (e.g., \'clear colorless liquid\', \'no visible particulates\', \'conforms to reference standard\').' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalAuthority rdf:type rdf:Property ;
    rdfs:label 'Approval Authority' ;
    rdfs:comment 'Role or individual responsible for approving this specification version. Typically Quality Assurance (QA) manager, regulatory affairs director, or technical director. Required for audit trail and compliance with Good Manufacturing Practice (GMP) and ISO 9001.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalityLevel rdf:type rdf:Property ;
    rdfs:label 'Criticality Level' ;
    rdfs:comment 'Classification of the parameter\'s importance to product quality and safety. Critical parameters directly impact safety or efficacy and trigger immediate batch rejection if Out of Specification (OOS). Major parameters affect product performance. Minor parameters are informational or aesthetic.' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSpecificFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Specific Flag' ;
    rdfs:comment 'Indicates whether this specification is tailored for a specific customer contract or represents the standard product specification. True if customer-specific, false if standard. Customer-specific specifications may have tighter limits or additional parameters.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:documentUrl rdf:type rdf:Property ;
    rdfs:label 'Document Url' ;
    rdfs:comment 'Link to the full specification document stored in the document management system. Provides access to detailed test procedures, sampling instructions, and supporting documentation.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ghsClassificationRelevance rdf:type rdf:Property ;
    rdfs:label 'Ghs Classification Relevance' ;
    rdfs:comment 'Describes how this specification parameter relates to Globally Harmonized System (GHS) hazard classification and Safety Data Sheet (SDS) content. For example, pH specifications may determine corrosivity classification; VOC content affects environmental hazard labeling.' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isoStandardReference rdf:type rdf:Property ;
    rdfs:label 'Iso Standard Reference' ;
    rdfs:comment 'Reference to the International Organization for Standardization (ISO) standard that governs this specification parameter or test method. Examples include ISO 9001 for quality management, ISO 14001 for environmental parameters, ISO 17025 for testing competence.' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limsTestCode rdf:type rdf:Property ;
    rdfs:label 'Lims Test Code' ;
    rdfs:comment 'Test code or identifier in the Laboratory Information Management System (LIMS) used to execute this specification parameter. Links this specification to LabWare LIMS for test execution, result capture, and Certificate of Analysis (COA) generation.' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumValue rdf:type rdf:Property ;
    rdfs:label 'Maximum Value' ;
    rdfs:comment 'Upper acceptance limit for the quality parameter. Test results above this value indicate Out of Specification (OOS) condition. Nullable for parameters with only lower limits.' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumValue rdf:type rdf:Property ;
    rdfs:label 'Minimum Value' ;
    rdfs:comment 'Lower acceptance limit for the quality parameter. Test results below this value indicate Out of Specification (OOS) condition. Nullable for parameters with only upper limits.' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reachRegistrationRelevance rdf:type rdf:Property ;
    rdfs:label 'Reach Registration Relevance' ;
    rdfs:comment 'Describes how this specification parameter supports Registration Evaluation Authorization and Restriction of Chemicals (REACH) registration and compliance. For example, impurity limits may be required to demonstrate substance identity and composition per REACH dossier.' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Requirement Flag' ;
    rdfs:comment 'Indicates whether this parameter is mandated by regulatory authorities such as Environmental Protection Agency (EPA), Occupational Safety and Health Administration (OSHA), Registration Evaluation Authorization and Restriction of Chemicals (REACH), Toxic Substances Control Act (TSCA), or Food and Drug Administration (FDA). True if regulatory-mandated, false if internal quality control only.' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:samplingPlan rdf:type rdf:Property ;
    rdfs:label 'Sampling Plan' ;
    rdfs:comment 'Description of the sampling strategy for this parameter. Defines sample size, sampling frequency, and sampling points (e.g., \'three samples from top, middle, bottom of batch\', \'composite sample from each reactor vessel\'). Links to Good Manufacturing Practice (GMP) requirements.' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdsSectionReference rdf:type rdf:Property ;
    rdfs:label 'Sds Section Reference' ;
    rdfs:comment 'Reference to the section of the Safety Data Sheet (SDS) or Material Safety Data Sheet (MSDS) where this specification parameter is documented. Supports linkage between quality specifications and safety documentation.' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationNumber rdf:type rdf:Property ;
    rdfs:label 'Specification Number' ;
    rdfs:comment 'Business identifier for the specification document. Externally-known unique code used in Certificate of Analysis (COA) and Certificate of Compliance (COC) generation.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationStatus rdf:type rdf:Property ;
    rdfs:label 'Specification Status' ;
    rdfs:comment 'Current lifecycle state of the specification. Active specifications are used for Certificate of Analysis (COA) generation and Quality Control (QC) release decisions. Superseded specifications are retained for audit trail.' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationType rdf:type rdf:Property ;
    rdfs:label 'Specification Type' ;
    rdfs:comment 'Classification of the specification based on its purpose in the quality control lifecycle. Release specifications define final product acceptance criteria; in-process specifications govern intermediate checkpoints; shelf-life and stability specifications define storage and aging limits.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testFrequency rdf:type rdf:Property ;
    rdfs:label 'Test Frequency' ;
    rdfs:comment 'Frequency at which this parameter must be tested. Per-batch and per-lot testing occur for every production run. Periodic testing (daily, weekly, monthly) applies to stability and shelf-life specifications. On-demand testing is triggered by specific events or investigations. [ENUM-REF-CANDIDATE: per-batch|per-lot|daily|weekly|monthly|quarterly|annual|on-demand — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testMethodReference rdf:type rdf:Property ;
    rdfs:label 'Test Method Reference' ;
    rdfs:comment 'Reference to the standardized or internal test method used to measure this parameter. May reference ASTM (American Society for Testing and Materials), ISO (International Organization for Standardization), USP (United States Pharmacopeia), or internal Standard Operating Procedure (SOP) codes.' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tscaComplianceRelevance rdf:type rdf:Property ;
    rdfs:label 'Tsca Compliance Relevance' ;
    rdfs:comment 'Describes how this specification parameter supports Toxic Substances Control Act (TSCA) compliance and reporting. For example, residual monomer content may be required for TSCA inventory listing or Chemical Data Reporting (CDR).' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:version rdf:type rdf:Property ;
    rdfs:label 'Version' ;
    rdfs:comment 'Version number of the specification to support lifecycle changes and regulatory audit trail. Follows major.minor versioning convention.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appearance rdf:type rdf:Property ;
    rdfs:label 'Appearance' ;
    rdfs:comment 'Visual appearance characteristics of the product such as color, clarity, and texture. Aids in quality verification and customer identification.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationSummary rdf:type rdf:Property ;
    rdfs:label 'Application Summary' ;
    rdfs:comment 'Summary of recommended applications and use cases for the chemical product. Guides customers on appropriate usage scenarios.' ;
    rdfs:domain ind:Tds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boilingPointUnit rdf:type rdf:Property ;
    rdfs:label 'Boiling Point Unit' ;
    rdfs:comment 'Temperature unit for boiling point measurement, either Celsius or Fahrenheit.' ;
    rdfs:domain ind:Tds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boilingPointValue rdf:type rdf:Property ;
    rdfs:label 'Boiling Point Value' ;
    rdfs:comment 'Temperature at which the product transitions from liquid to vapor phase at standard atmospheric pressure. Important for process design and safety.' ;
    rdfs:domain ind:Tds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compatibilityNotes rdf:type rdf:Property ;
    rdfs:label 'Compatibility Notes' ;
    rdfs:comment 'Information on material compatibility and incompatibility with other chemicals, substrates, or container materials. Prevents adverse reactions.' ;
    rdfs:domain ind:Tds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentFilePath rdf:type rdf:Property ;
    rdfs:label 'Document File Path' ;
    rdfs:comment 'Internal file system or content management system path to the TDS document. Used for document retrieval and version control.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flashPointUnit rdf:type rdf:Property ;
    rdfs:label 'Flash Point Unit' ;
    rdfs:comment 'Temperature unit for flash point measurement, either Celsius or Fahrenheit.' ;
    rdfs:domain ind:Tds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flashPointValue rdf:type rdf:Property ;
    rdfs:label 'Flash Point Value' ;
    rdfs:comment 'Lowest temperature at which vapors ignite when exposed to an ignition source. Critical safety parameter for flammable materials.' ;
    rdfs:domain ind:Tds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:handlingPrecautions rdf:type rdf:Property ;
    rdfs:label 'Handling Precautions' ;
    rdfs:comment 'Safety precautions and best practices for handling the product including personal protective equipment (PPE) requirements and exposure controls.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageCode rdf:type rdf:Property ;
    rdfs:label 'Language Code' ;
    rdfs:comment 'ISO 639-1 two-letter language code indicating the language in which this TDS is published. Supports multi-language TDS distribution for global markets.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:odor rdf:type rdf:Property ;
    rdfs:label 'Odor' ;
    rdfs:comment 'Characteristic odor or scent of the chemical product. Important for safety identification and customer expectations.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceDataReference rdf:type rdf:Property ;
    rdfs:label 'Performance Data Reference' ;
    rdfs:comment 'Reference to supporting performance test data, technical bulletins, or case studies that demonstrate product efficacy and application results.' ;
    rdfs:domain ind:Tds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendedUseConcentration rdf:type rdf:Property ;
    rdfs:label 'Recommended Use Concentration' ;
    rdfs:comment 'Guidance on typical or recommended concentration ranges for product application. May include dilution ratios or usage rates.' ;
    rdfs:domain ind:Tds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryComplianceNotes rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Notes' ;
    rdfs:comment 'Summary of key regulatory compliance information including REACH registration status, TSCA listing, FDA approvals, and other jurisdiction-specific clearances.' ;
    rdfs:domain ind:Tds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionNotes rdf:type rdf:Property ;
    rdfs:label 'Revision Notes' ;
    rdfs:comment 'Summary of changes made in this TDS version compared to the previous version. Supports change management and customer communication.' ;
    rdfs:domain ind:Tds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:solubilityDescription rdf:type rdf:Property ;
    rdfs:label 'Solubility Description' ;
    rdfs:comment 'Description of product solubility characteristics in various solvents (water, organic solvents). Guides formulation and application decisions.' ;
    rdfs:domain ind:Tds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageConditions rdf:type rdf:Property ;
    rdfs:label 'Storage Conditions' ;
    rdfs:comment 'Recommended storage conditions including temperature range, humidity control, and container requirements to maintain product quality and safety.' ;
    rdfs:domain ind:Tds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tdsStatus rdf:type rdf:Property ;
    rdfs:label 'Tds Status' ;
    rdfs:comment 'Current lifecycle state of the TDS document. Controls visibility and usage in customer-facing channels.' ;
    rdfs:domain ind:Tds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionNumber rdf:type rdf:Property ;
    rdfs:label 'Version Number' ;
    rdfs:comment 'Version identifier for this TDS document. Incremented with each revision to track document evolution and ensure customers reference the correct edition.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:viscosityUnit rdf:type rdf:Property ;
    rdfs:label 'Viscosity Unit' ;
    rdfs:comment 'Unit of measure for the viscosity value. Common units include centipoise (cP), centistokes (cSt), and Pascal-seconds.' ;
    rdfs:domain ind:Tds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:viscosityValue rdf:type rdf:Property ;
    rdfs:label 'Viscosity Value' ;
    rdfs:comment 'Measured viscosity of the product indicating flow resistance. Critical for processing, pumping, and application equipment selection.' ;
    rdfs:domain ind:Tds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceSdsRecordId rdf:type rdf:Property ;
    rdfs:label 'Source Sds Record Id' ;
    rdfs:comment 'Foreign key linking to rawmaterial.sds_record. Business justification: Product SDS authoring in chemical manufacturing requires reference to raw material SDS records for hazard data (toxicology, ecological info, physical-chemical properties). SDS authors explicitly cross' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SdsRecord .

ind:accidentalReleaseMeasures rdf:type rdf:Property ;
    rdfs:label 'Accidental Release Measures' ;
    rdfs:comment 'Personal precautions, protective equipment, emergency procedures, and methods for containment and cleanup of spills or leaks, as per GHS Section 6.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boilingPointC rdf:type rdf:Property ;
    rdfs:label 'Boiling Point C' ;
    rdfs:comment 'Temperature at which the substance transitions from liquid to gas at standard atmospheric pressure, measured in degrees Celsius.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:californiaProp65Listed rdf:type rdf:Property ;
    rdfs:label 'California Prop65 Listed' ;
    rdfs:comment 'Indicates whether the chemical is listed under California Proposition 65 as known to cause cancer, birth defects, or reproductive harm.' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:color rdf:type rdf:Property ;
    rdfs:label 'Color' ;
    rdfs:comment 'Visual color or appearance of the chemical product.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalConsiderations rdf:type rdf:Property ;
    rdfs:label 'Disposal Considerations' ;
    rdfs:comment 'Recommended methods for safe disposal of the substance and contaminated packaging, including waste treatment methods and applicable regulations, as per GHS Section 13.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentStatus rdf:type rdf:Property ;
    rdfs:label 'Document Status' ;
    rdfs:comment 'Current lifecycle status of the SDS document: Draft (under preparation), Active (current official version), Superseded (replaced by newer version), Archived (historical record).' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dotHazardClass rdf:type rdf:Property ;
    rdfs:label 'Dot Hazard Class' ;
    rdfs:comment 'US DOT hazard class for transportation of dangerous goods (e.g., Class 3 Flammable Liquid, Class 8 Corrosive).' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dotPackingGroup rdf:type rdf:Property ;
    rdfs:label 'Dot Packing Group' ;
    rdfs:comment 'DOT packing group indicating the degree of danger: I (high danger), II (medium danger), III (low danger).' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dotUnNumber rdf:type rdf:Property ;
    rdfs:label 'Dot Un Number' ;
    rdfs:comment 'Four-digit UN number assigned to the substance for international transport of dangerous goods. Format: UNXXXX.' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ecNumber rdf:type rdf:Property ;
    rdfs:label 'Ec Number' ;
    rdfs:comment 'EC Number (EINECS, ELINCS, or NLP) assigned by the European Chemicals Agency for substance identification under REACH. Format: XXX-XXX-X.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ecologicalInformation rdf:type rdf:Property ;
    rdfs:label 'Ecological Information' ;
    rdfs:comment 'Environmental impact data including aquatic toxicity (LC50, EC50), persistence and degradability, bioaccumulative potential, and mobility in soil, as per GHS Section 12.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exposureLimits rdf:type rdf:Property ;
    rdfs:label 'Exposure Limits' ;
    rdfs:comment 'Occupational exposure limits including OSHA PEL (Permissible Exposure Limit), ACGIH TLV (Threshold Limit Value), and other applicable exposure standards, as per GHS Section 8.' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firefightingMeasures rdf:type rdf:Property ;
    rdfs:label 'Firefighting Measures' ;
    rdfs:comment 'Suitable extinguishing media, unsuitable extinguishing media, and special hazards arising from the substance or mixture during fire, as per GHS Section 5.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstAidMeasures rdf:type rdf:Property ;
    rdfs:label 'First Aid Measures' ;
    rdfs:comment 'Summary of first aid instructions for exposure routes (inhalation, skin contact, eye contact, ingestion) as per GHS Section 4.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardStatements rdf:type rdf:Property ;
    rdfs:label 'Hazard Statements' ;
    rdfs:comment 'Comma-separated list of GHS hazard statement codes (H-codes) describing the nature of the hazards (e.g., H225, H302, H314, H400).' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iataShippingName rdf:type rdf:Property ;
    rdfs:label 'Iata Shipping Name' ;
    rdfs:comment 'Proper shipping name for air transport as per IATA Dangerous Goods Regulations.' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imdgShippingName rdf:type rdf:Property ;
    rdfs:label 'Imdg Shipping Name' ;
    rdfs:comment 'Proper shipping name for sea transport as per IMDG Code.' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meltingPointC rdf:type rdf:Property ;
    rdfs:label 'Melting Point C' ;
    rdfs:comment 'Temperature at which the substance transitions from solid to liquid at standard atmospheric pressure, measured in degrees Celsius.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:physicalState rdf:type rdf:Property ;
    rdfs:label 'Physical State' ;
    rdfs:comment 'Physical form of the chemical product at ambient conditions (e.g., solid, liquid, gas, powder).' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pictogramCodes rdf:type rdf:Property ;
    rdfs:label 'Pictogram Codes' ;
    rdfs:comment 'Comma-separated list of GHS pictogram codes representing hazard symbols (e.g., GHS02 Flame, GHS05 Corrosion, GHS07 Exclamation Mark, GHS09 Environment).' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:precautionaryStatements rdf:type rdf:Property ;
    rdfs:label 'Precautionary Statements' ;
    rdfs:comment 'Comma-separated list of GHS precautionary statement codes (P-codes) describing recommended measures to minimize or prevent adverse effects (e.g., P210, P280, P305+P351+P338).' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preparedBy rdf:type rdf:Property ;
    rdfs:label 'Prepared By' ;
    rdfs:comment 'Name or identifier of the person or department responsible for preparing or updating this SDS.' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryInformation rdf:type rdf:Property ;
    rdfs:label 'Regulatory Information' ;
    rdfs:comment 'Additional regulatory information including national and regional regulations (TSCA, REACH, DSL, ENCS, IECSC, KECL, PICCS, AICS) and safety, health, and environmental regulations, as per GHS Section 15.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionDate rdf:type rdf:Property ;
    rdfs:label 'Revision Date' ;
    rdfs:comment 'Date when this revision of the SDS was issued or last updated. Critical for regulatory compliance and version control.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revisionNumber rdf:type rdf:Property ;
    rdfs:label 'Revision Number' ;
    rdfs:comment 'Sequential revision number of the SDS document. Increments with each update to the safety data sheet.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sara313Reportable rdf:type rdf:Property ;
    rdfs:label 'Sara 313 Reportable' ;
    rdfs:comment 'Indicates whether the chemical is subject to SARA Title III Section 313 Toxics Release Inventory (TRI) reporting requirements.' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:signalWord rdf:type rdf:Property ;
    rdfs:label 'Signal Word' ;
    rdfs:comment 'GHS signal word indicating the severity level of the hazard: Danger (more severe) or Warning (less severe).' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:solubilityInWater rdf:type rdf:Property ;
    rdfs:label 'Solubility In Water' ;
    rdfs:comment 'Description of the substances solubility in water (e.g., soluble, insoluble, partially soluble, miscible) and quantitative data if available.' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageRequirements rdf:type rdf:Property ;
    rdfs:label 'Storage Requirements' ;
    rdfs:comment 'Conditions for safe storage including incompatibilities, temperature limits, ventilation, and container specifications, as per GHS Section 7.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersedesDate rdf:type rdf:Property ;
    rdfs:label 'Supersedes Date' ;
    rdfs:comment 'Date of the previous SDS version that this revision replaces. Used for audit trail and version history.' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:toxicologicalInformation rdf:type rdf:Property ;
    rdfs:label 'Toxicological Information' ;
    rdfs:comment 'Summary of toxicological data including acute toxicity (LD50, LC50), skin corrosion/irritation, eye damage/irritation, sensitization, mutagenicity, carcinogenicity, reproductive toxicity, and target organ effects, as per GHS Section 11.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vaporPressureMmhg rdf:type rdf:Property ;
    rdfs:label 'Vapor Pressure Mmhg' ;
    rdfs:comment 'Pressure exerted by the vapor of the substance in equilibrium with its liquid or solid form at a given temperature, measured in millimeters of mercury (mmHg).' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productGhsClassificationId rdf:type rdf:Property ;
    rdfs:label 'Product Ghs Classification Id' ;
    rdfs:comment 'Unique identifier for the GHS classification record.' ;
    rdfs:domain ind:ProductGhsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rawmaterialGhsClassificationId rdf:type rdf:Property ;
    rdfs:label 'Rawmaterial Ghs Classification Id' ;
    rdfs:comment 'Foreign key linking to rawmaterial.rawmaterial_ghs_classification. Business justification: GHS/CLP mixture classification rules require product hazard classifications to be derived from and traceable to component raw material GHS classifications. EHS and regulatory teams use this link for S' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RawmaterialGhsClassification .

ind:supersededByClassificationProductGhsClassificationId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Classification Product Ghs Classification Id' ;
    rdfs:comment 'Reference to the newer GHS classification record that supersedes this one, enabling classification version history tracking.' ;
    rdfs:domain ind:ProductGhsClassification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductGhsClassification .

ind:classificationAuthority rdf:type rdf:Property ;
    rdfs:label 'Classification Authority' ;
    rdfs:comment 'Entity responsible for the classification: self-classification by manufacturer, ECHA harmonized classification, competent authority, or third-party assessor.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classificationBasis rdf:type rdf:Property ;
    rdfs:label 'Classification Basis' ;
    rdfs:comment 'Methodology or data source used to determine the classification: experimental test data, read-across from analogous substances, QSAR (Quantitative Structure-Activity Relationship) modeling, expert judgment, literature review, or bridging principles.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classificationDate rdf:type rdf:Property ;
    rdfs:label 'Classification Date' ;
    rdfs:comment 'Date when the GHS classification was performed or last updated.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:classificationNotes rdf:type rdf:Property ;
    rdfs:label 'Classification Notes' ;
    rdfs:comment 'Free-text notes providing additional context, rationale, or special considerations for the classification decision.' ;
    rdfs:domain ind:ProductGhsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classificationStatus rdf:type rdf:Property ;
    rdfs:label 'Classification Status' ;
    rdfs:comment 'Current lifecycle status of the GHS classification record.' ;
    rdfs:domain ind:ProductGhsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classificationVersion rdf:type rdf:Property ;
    rdfs:label 'Classification Version' ;
    rdfs:comment 'Version number of the GHS classification (e.g., GHS Rev 7, GHS Rev 8) indicating which revision of the Globally Harmonized System was applied.' ;
    rdfs:domain ind:ProductGhsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classifierName rdf:type rdf:Property ;
    rdfs:label 'Classifier Name' ;
    rdfs:comment 'Name of the individual or team responsible for performing the GHS classification.' ;
    rdfs:domain ind:ProductGhsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clpNotificationNumber rdf:type rdf:Property ;
    rdfs:label 'Clp Notification Number' ;
    rdfs:comment 'Notification number assigned by ECHA for substances notified under the CLP Regulation.' ;
    rdfs:domain ind:ProductGhsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cmrClassification rdf:type rdf:Property ;
    rdfs:label 'Cmr Classification' ;
    rdfs:comment 'Specific CMR classification categories if applicable (e.g., Carc. 1A, Muta. 1B, Repr. 2), indicating carcinogenic, mutagenic, or reproductive toxicity hazards.' ;
    rdfs:domain ind:ProductGhsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveUntilDate rdf:type rdf:Property ;
    rdfs:label 'Effective Until Date' ;
    rdfs:comment 'Date until which this GHS classification remains valid; nullable for current active classifications.' ;
    rdfs:domain ind:ProductGhsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:environmentalHazardCategories rdf:type rdf:Property ;
    rdfs:label 'Environmental Hazard Categories' ;
    rdfs:comment 'Comma-separated list of environmental hazard categories corresponding to the classes (e.g., Acute 1, Chronic 2, Chronic 3).' ;
    rdfs:domain ind:ProductGhsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalHazardClasses rdf:type rdf:Property ;
    rdfs:label 'Environmental Hazard Classes' ;
    rdfs:comment 'Comma-separated list of environmental hazard classes assigned (e.g., Hazardous to the Aquatic Environment, Hazardous to the Ozone Layer).' ;
    rdfs:domain ind:ProductGhsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardStatementCodes rdf:type rdf:Property ;
    rdfs:label 'Hazard Statement Codes' ;
    rdfs:comment 'Comma-separated list of GHS hazard statement codes (e.g., H225, H302, H315, H319, H411) describing the nature and severity of hazards.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:healthHazardCategories rdf:type rdf:Property ;
    rdfs:label 'Health Hazard Categories' ;
    rdfs:comment 'Comma-separated list of health hazard categories corresponding to the classes (e.g., Category 1, Category 2, Category 1A, Category 1B).' ;
    rdfs:domain ind:ProductGhsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:healthHazardClasses rdf:type rdf:Property ;
    rdfs:label 'Health Hazard Classes' ;
    rdfs:comment 'Comma-separated list of health hazard classes assigned (e.g., Acute Toxicity, Skin Corrosion, Carcinogenicity, Reproductive Toxicity, Respiratory Sensitization).' ;
    rdfs:domain ind:ProductGhsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelGenerationRequired rdf:type rdf:Property ;
    rdfs:label 'Label Generation Required' ;
    rdfs:comment 'Boolean flag indicating whether a GHS-compliant label must be generated for this classification.' ;
    rdfs:domain ind:ProductGhsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:physicalHazardCategories rdf:type rdf:Property ;
    rdfs:label 'Physical Hazard Categories' ;
    rdfs:comment 'Comma-separated list of physical hazard categories corresponding to the classes (e.g., Category 2, Category 1A, Category 3).' ;
    rdfs:domain ind:ProductGhsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:physicalHazardClasses rdf:type rdf:Property ;
    rdfs:label 'Physical Hazard Classes' ;
    rdfs:comment 'Comma-separated list of physical hazard classes assigned (e.g., Flammable Liquids, Explosives, Oxidizing Liquids, Corrosive to Metals).' ;
    rdfs:domain ind:ProductGhsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:precautionaryStatementCodes rdf:type rdf:Property ;
    rdfs:label 'Precautionary Statement Codes' ;
    rdfs:comment 'Comma-separated list of GHS precautionary statement codes (e.g., P210, P280, P301+P312, P501) describing recommended measures to minimize or prevent adverse effects.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryRegion rdf:type rdf:Property ;
    rdfs:label 'Regulatory Region' ;
    rdfs:comment 'Geographic region or jurisdiction for which this classification applies (e.g., EU, USA, Canada, China, Australia), as GHS implementation may vary by region.' ;
    rdfs:domain ind:ProductGhsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewerName rdf:type rdf:Property ;
    rdfs:label 'Reviewer Name' ;
    rdfs:comment 'Name of the individual or team who reviewed and approved the GHS classification.' ;
    rdfs:domain ind:ProductGhsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testDataReference rdf:type rdf:Property ;
    rdfs:label 'Test Data Reference' ;
    rdfs:comment 'Reference to the specific test reports, study numbers, or LIMS records that support the classification (e.g., study IDs, OECD guideline numbers).' ;
    rdfs:domain ind:ProductGhsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tscaInventoryStatus rdf:type rdf:Property ;
    rdfs:label 'Tsca Inventory Status' ;
    rdfs:comment 'Status of the substance on the TSCA Chemical Substance Inventory: active (commercial use), inactive (no current commercial use), or not listed.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryStatusId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Status Id' ;
    rdfs:comment 'Unique identifier for the regulatory compliance status record.' ;
    rdfs:domain ind:RegulatoryStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:materialRegulatoryStatusId rdf:type rdf:Property ;
    rdfs:label 'Material Regulatory Status Id' ;
    rdfs:comment 'Foreign key linking to rawmaterial.material_regulatory_status. Business justification: Product regulatory compliance status (TSCA, REACH, jurisdiction) is directly informed by constituent raw material regulatory status. Regulatory affairs teams link product compliance records to raw mat' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialRegulatoryStatus .

ind:authorizationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Authorization Expiry Date' ;
    rdfs:comment 'Date when the granted authorization expires and renewal application is required.' ;
    rdfs:domain ind:RegulatoryStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authorizationNumber rdf:type rdf:Property ;
    rdfs:label 'Authorization Number' ;
    rdfs:comment 'Authorization number granted by the regulatory authority for continued use of a restricted or SVHC substance under specific conditions.' ;
    rdfs:domain ind:RegulatoryStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Status' ;
    rdfs:comment 'Current compliance state of the product under the specified regulation and jurisdiction. Registered (fully compliant and registered), Notified (notification submitted), Exempt (exemption granted), Restricted (use restrictions apply), Prohibited (banned), Pending (application in progress).' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdiction rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction' ;
    rdfs:comment 'Geographic jurisdiction or regulatory region where this compliance status applies. USA (United States), EUR (European Union), CHN (China), JPN (Japan), KOR (South Korea), CAN (Canada).' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pfasFlag rdf:type rdf:Property ;
    rdfs:label 'Pfas Flag' ;
    rdfs:comment 'Indicates whether this product contains PFAS (per- and polyfluoroalkyl substances), subject to emerging regulatory restrictions.' ;
    rdfs:domain ind:RegulatoryStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pmnNumber rdf:type rdf:Property ;
    rdfs:label 'Pmn Number' ;
    rdfs:comment 'EPA-assigned number for a Pre-Manufacture Notice submitted for a new chemical substance not on the TSCA Inventory.' ;
    rdfs:domain ind:RegulatoryStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prop65ListingFlag rdf:type rdf:Property ;
    rdfs:label 'Prop 65 Listing Flag' ;
    rdfs:comment 'Indicates whether this substance is listed under California Proposition 65 as known to cause cancer, birth defects, or reproductive harm.' ;
    rdfs:domain ind:RegulatoryStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reachRegistrationType rdf:type rdf:Property ;
    rdfs:label 'Reach Registration Type' ;
    rdfs:comment 'Type of REACH registration dossier submitted. Full (standard registration), Intermediate (on-site or transported isolated intermediate), Transported Isolated (intermediate transported between sites), Not Applicable (non-REACH regulation).' ;
    rdfs:domain ind:RegulatoryStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationDate rdf:type rdf:Property ;
    rdfs:label 'Registration Date' ;
    rdfs:comment 'Date when the product was officially registered or notified under the applicable regulatory framework.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:registrationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Registration Expiry Date' ;
    rdfs:comment 'Date when the current registration expires and renewal or re-notification is required. Nullable for regulations without expiry.' ;
    rdfs:domain ind:RegulatoryStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:registrationNumber rdf:type rdf:Property ;
    rdfs:label 'Registration Number' ;
    rdfs:comment 'Official registration or notification number issued by the regulatory authority for this product under the specified regulation.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulationType rdf:type rdf:Property ;
    rdfs:label 'Regulation Type' ;
    rdfs:comment 'Type of regulatory framework applicable to this product. REACH (Registration Evaluation Authorization and Restriction of Chemicals), TSCA (Toxic Substances Control Act), SARA 313 (Superfund Amendments and Reauthorization Act Section 313), Prop 65 (California Proposition 65), RoHS (Restriction of Hazardous Substances), SVHC (Substance of Very High Concern).' ;
    rdfs:domain ind:RegulatoryStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAuthority rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority' ;
    rdfs:comment 'Name of the government agency or regulatory body that issued or oversees this compliance status (e.g., EPA, ECHA, METI, MEE).' ;
    rdfs:domain ind:RegulatoryStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsiblePartyEmail rdf:type rdf:Property ;
    rdfs:label 'Responsible Party Email' ;
    rdfs:comment 'Email address of the responsible party for regulatory compliance inquiries and notifications.' ;
    rdfs:domain ind:RegulatoryStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsiblePartyName rdf:type rdf:Property ;
    rdfs:label 'Responsible Party Name' ;
    rdfs:comment 'Name of the individual or organizational unit responsible for maintaining this regulatory status record and ensuring ongoing compliance.' ;
    rdfs:domain ind:RegulatoryStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictionConditions rdf:type rdf:Property ;
    rdfs:label 'Restriction Conditions' ;
    rdfs:comment 'Detailed description of any restrictions, limitations, or special conditions imposed on the manufacture, import, use, or sale of this product under the applicable regulation.' ;
    rdfs:domain ind:RegulatoryStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rohsCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Rohs Compliant Flag' ;
    rdfs:comment 'Indicates whether this product complies with RoHS Directive restrictions on hazardous substances in electrical and electronic equipment.' ;
    rdfs:domain ind:RegulatoryStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sara313ReportableFlag rdf:type rdf:Property ;
    rdfs:label 'Sara 313 Reportable Flag' ;
    rdfs:comment 'Indicates whether this substance is subject to SARA Section 313 Toxics Release Inventory (TRI) reporting requirements.' ;
    rdfs:domain ind:RegulatoryStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:submissionDate rdf:type rdf:Property ;
    rdfs:label 'Submission Date' ;
    rdfs:comment 'Date when the registration, notification, or compliance dossier was submitted to the regulatory authority.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:substanceRole rdf:type rdf:Property ;
    rdfs:label 'Substance Role' ;
    rdfs:comment 'Role of the organization in the supply chain for this substance under the regulatory framework. Manufacturer (produces the substance), Importer (imports into jurisdiction), Only Representative (non-EU manufacturer representative), Downstream User (uses the substance in formulations).' ;
    rdfs:domain ind:RegulatoryStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:svhcCandidateListFlag rdf:type rdf:Property ;
    rdfs:label 'Svhc Candidate List Flag' ;
    rdfs:comment 'Indicates whether this substance is included on the ECHA Candidate List of Substances of Very High Concern for potential authorization under REACH.' ;
    rdfs:domain ind:RegulatoryStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tonnageBand rdf:type rdf:Property ;
    rdfs:label 'Tonnage Band' ;
    rdfs:comment 'Annual production or import volume band for REACH registration purposes, measured in metric tonnes per year. Categories: 1-10 tonnes, 10-100 tonnes, 100-1000 tonnes, over 1000 tonnes, or not applicable for non-REACH regulations.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentNodeHierarchyId rdf:type rdf:Property ;
    rdfs:label 'Parent Node Hierarchy Id' ;
    rdfs:comment 'Reference to the parent node in the hierarchy structure. Null for top-level division nodes. Enables recursive hierarchy traversal and roll-up aggregations for EBITDA reporting and sales analytics.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Hierarchy .

ind:applicationCategory rdf:type rdf:Property ;
    rdfs:label 'Application Category' ;
    rdfs:comment 'Primary end-use application or industry segment for products in this node. Examples: Automotive Coatings, Construction Materials, Electronics Manufacturing, Consumer Goods, Agriculture Crop Protection. Supports market segmentation and application-based analytics.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessUnitCode rdf:type rdf:Property ;
    rdfs:label 'Business Unit Code' ;
    rdfs:comment 'Code identifying the business unit responsible for this product hierarchy node. Used for P&L reporting, EBITDA analysis by business unit, and organizational accountability.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ebitdaReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Ebitda Reporting Flag' ;
    rdfs:comment 'Indicates whether this hierarchy node is used for EBITDA reporting and financial performance tracking. True for nodes that represent P&L responsibility centers.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:externalHierarchyCode rdf:type rdf:Property ;
    rdfs:label 'External Hierarchy Code' ;
    rdfs:comment 'External system or customer-facing hierarchy code used for EDI transactions, customer portals, or third-party integrations. May differ from internal SAP codes.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isLeafNode rdf:type rdf:Property ;
    rdfs:label 'Is Leaf Node' ;
    rdfs:comment 'Indicates whether this node is a leaf node (has no children) in the hierarchy. True for the lowest level nodes where individual SKUs are assigned. Used for validation and hierarchy integrity checks.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legacyHierarchyCode rdf:type rdf:Property ;
    rdfs:label 'Legacy Hierarchy Code' ;
    rdfs:comment 'Historical product hierarchy code from legacy ERP systems prior to SAP S/4HANA implementation. Retained for data lineage, historical reporting, and migration traceability.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:levelName rdf:type rdf:Property ;
    rdfs:label 'Level Name' ;
    rdfs:comment 'Descriptive name of the hierarchy level. Standard values: division, business_unit, product_family, product_line, product_group, sub_group. Used for reporting labels and user interface display.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeCode rdf:type rdf:Property ;
    rdfs:label 'Node Code' ;
    rdfs:comment 'Business identifier code for the hierarchy node. Used in SAP S/4HANA product hierarchy configuration and external reporting systems. Alphanumeric code uniquely identifying the node within the hierarchy structure.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeDepth rdf:type rdf:Property ;
    rdfs:label 'Node Depth' ;
    rdfs:comment 'Calculated depth of the node from the root of the hierarchy tree. Root nodes have depth 0. Used for hierarchy traversal algorithms and reporting level filtering.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nodeDescription rdf:type rdf:Property ;
    rdfs:label 'Node Description' ;
    rdfs:comment 'Detailed description of the hierarchy node including scope, product categories included, and business purpose. Provides context for classification decisions and portfolio management.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeName rdf:type rdf:Property ;
    rdfs:label 'Node Name' ;
    rdfs:comment 'Human-readable name of the hierarchy node. Used for display in reports, dashboards, and user interfaces. Examples: Performance Materials, Agricultural Solutions, Specialty Chemicals, Industrial Polymers.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeStatus rdf:type rdf:Property ;
    rdfs:label 'Node Status' ;
    rdfs:comment 'Current lifecycle status of the hierarchy node. Active: in use for classification and reporting. Inactive: temporarily disabled. Pending: awaiting approval. Deprecated: scheduled for retirement. Archived: historical reference only.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:path rdf:type rdf:Property ;
    rdfs:label 'Path' ;
    rdfs:comment 'Full path from root to this node using node codes separated by forward slashes. Example: DIV01/BU05/FAM12/LINE34. Enables fast ancestor/descendant queries and breadcrumb navigation.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productFamilyCode rdf:type rdf:Property ;
    rdfs:label 'Product Family Code' ;
    rdfs:comment 'Code identifying the product family within the business unit. Groups related product lines with similar chemistry, applications, or market segments.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productLineManager rdf:type rdf:Property ;
    rdfs:label 'Product Line Manager' ;
    rdfs:comment 'Name of the product line manager or business owner responsible for this hierarchy node. Used for accountability, approval workflows, and organizational reporting.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesOrganization rdf:type rdf:Property ;
    rdfs:label 'Sales Organization' ;
    rdfs:comment 'SAP S/4HANA sales organization code responsible for products in this hierarchy node. Used for sales analytics, commission calculations, and regional performance reporting.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapProductHierarchyCode rdf:type rdf:Property ;
    rdfs:label 'Sap Product Hierarchy Code' ;
    rdfs:comment '18-character SAP S/4HANA product hierarchy code (PRODH field). Concatenated representation of the full hierarchy path used in SAP MM and SD modules for material grouping and sales reporting.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sortSequence rdf:type rdf:Property ;
    rdfs:label 'Sort Sequence' ;
    rdfs:comment 'Numeric value controlling the display order of sibling nodes within the same parent. Lower values appear first. Used for consistent presentation in reports and user interfaces.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fillingEquipmentId rdf:type rdf:Property ;
    rdfs:label 'Filling Equipment Id' ;
    rdfs:comment 'Foreign key linking to maintenance.equipment. Business justification: Packaging configurations (drum fill, IBC, bulk tanker) are tied to specific filling/packaging equipment lines. In chemical manufacturing, equipment constraints determine which packaging configs can ru' ;
    rdfs:domain ind:PackagingConfig ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Equipment .

ind:capacityUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Capacity Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the nominal capacity. Common units include L (liters), GAL (gallons), M3 (cubic meters), KG (kilograms), LB (pounds).' ;
    rdfs:domain ind:PackagingConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureType rdf:type rdf:Property ;
    rdfs:label 'Closure Type' ;
    rdfs:comment 'Type of closure or sealing mechanism used on the packaging container (e.g., screw cap, bung, valve, crimp seal, tamper-evident seal).' ;
    rdfs:domain ind:PackagingConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dotLabelRequired rdf:type rdf:Property ;
    rdfs:label 'Dot Label Required' ;
    rdfs:comment 'Indicates whether DOT hazardous materials transportation labels are required on this packaging configuration.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fillVolumeLiters rdf:type rdf:Property ;
    rdfs:label 'Fill Volume Liters' ;
    rdfs:comment 'Maximum fill volume of the chemical product in liters that can be loaded into this packaging configuration.' ;
    rdfs:domain ind:PackagingConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fillWeightKg rdf:type rdf:Property ;
    rdfs:label 'Fill Weight Kg' ;
    rdfs:comment 'Maximum fill weight of the chemical product in kilograms that can be loaded into this packaging configuration.' ;
    rdfs:domain ind:PackagingConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:foodGradeCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Food Grade Certified Flag' ;
    rdfs:comment 'Indicates whether this packaging configuration is certified for food-contact chemicals and meets FDA (Food and Drug Administration) food-grade requirements.' ;
    rdfs:domain ind:PackagingConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ghsLabelRequired rdf:type rdf:Property ;
    rdfs:label 'Ghs Label Required' ;
    rdfs:comment 'Indicates whether GHS hazard communication labels are required on this packaging configuration.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazmatCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Certified Flag' ;
    rdfs:comment 'Indicates whether this packaging configuration is certified for transporting hazardous materials under DOT, IATA, and IMDG regulations.' ;
    rdfs:domain ind:PackagingConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:heightMm rdf:type rdf:Property ;
    rdfs:label 'Height Mm' ;
    rdfs:comment 'Height of the packaging container in millimeters. Used for warehouse slotting, stacking calculations, and transportation planning.' ;
    rdfs:domain ind:PackagingConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:iataLabelRequired rdf:type rdf:Property ;
    rdfs:label 'Iata Label Required' ;
    rdfs:comment 'Indicates whether IATA dangerous goods air transport labels are required on this packaging configuration.' ;
    rdfs:domain ind:PackagingConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:imdgLabelRequired rdf:type rdf:Property ;
    rdfs:label 'Imdg Label Required' ;
    rdfs:comment 'Indicates whether IMDG Code maritime transport labels are required on this packaging configuration.' ;
    rdfs:domain ind:PackagingConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lengthMm rdf:type rdf:Property ;
    rdfs:label 'Length Mm' ;
    rdfs:comment 'Length of rectangular packaging (IBCs, totes, boxes) in millimeters. Used for warehouse slotting and transportation planning.' ;
    rdfs:domain ind:PackagingConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:materialOfConstruction rdf:type rdf:Property ;
    rdfs:label 'Material Of Construction' ;
    rdfs:comment 'Material used to construct the packaging container. Options include HDPE (High-Density Polyethylene), steel, stainless steel, fiber, aluminum, and lined containers.' ;
    rdfs:domain ind:PackagingConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nominalCapacity rdf:type rdf:Property ;
    rdfs:label 'Nominal Capacity' ;
    rdfs:comment 'Nominal or rated capacity of the packaging container, expressed in the unit specified by capacity_unit_of_measure.' ;
    rdfs:domain ind:PackagingConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outerDiameterMm rdf:type rdf:Property ;
    rdfs:label 'Outer Diameter Mm' ;
    rdfs:comment 'Outer diameter of cylindrical packaging (drums, cylinders, pails) in millimeters. Used for warehouse slotting and space planning.' ;
    rdfs:domain ind:PackagingConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packagingCode rdf:type rdf:Property ;
    rdfs:label 'Packaging Code' ;
    rdfs:comment 'Unique business identifier for the packaging configuration, used in SAP EWM (Extended Warehouse Management) and order fulfillment systems.' ;
    rdfs:domain ind:PackagingConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingConfigStatus rdf:type rdf:Property ;
    rdfs:label 'Packaging Config Status' ;
    rdfs:comment 'Current lifecycle status of the packaging configuration. Active configurations are available for order fulfillment; inactive/obsolete are phased out; pending approval are under review; restricted require special authorization.' ;
    rdfs:domain ind:PackagingConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingGroup rdf:type rdf:Property ;
    rdfs:label 'Packaging Group' ;
    rdfs:comment 'UN Packaging Group classification indicating the degree of danger: I (high danger), II (medium danger), III (low danger). Determines packaging performance requirements.' ;
    rdfs:domain ind:PackagingConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingType rdf:type rdf:Property ;
    rdfs:label 'Packaging Type' ;
    rdfs:comment 'Type of packaging container used for the chemical product. Includes drum, IBC (Intermediate Bulk Container), bulk tanker, bag, cylinder, pail, tote, flexitank, and isotank. [ENUM-REF-CANDIDATE: drum|ibc|bulk_tanker|bag|cylinder|pail|tote|flexitank|isotank — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:palletType rdf:type rdf:Property ;
    rdfs:label 'Pallet Type' ;
    rdfs:comment 'Type of pallet used for this packaging configuration (e.g., EUR pallet, standard 48x40, block pallet, chemical-resistant pallet).' ;
    rdfs:domain ind:PackagingConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pharmaceuticalGradeFlag rdf:type rdf:Property ;
    rdfs:label 'Pharmaceutical Grade Flag' ;
    rdfs:comment 'Indicates whether this packaging configuration meets pharmaceutical-grade standards for API (Active Pharmaceutical Ingredient) and pharmaceutical chemical packaging.' ;
    rdfs:domain ind:PackagingConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferredFlag rdf:type rdf:Property ;
    rdfs:label 'Preferred Flag' ;
    rdfs:comment 'Indicates whether this is the preferred or default packaging configuration for the associated product SKU (Stock Keeping Unit).' ;
    rdfs:domain ind:PackagingConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regionRestriction rdf:type rdf:Property ;
    rdfs:label 'Region Restriction' ;
    rdfs:comment 'Geographic regions where this packaging configuration is approved or restricted for use, based on local regulatory requirements (e.g., USA, CAN, MEX, EUR, CHN). Pipe-separated list of ISO 3166-1 alpha-3 country codes.' ;
    rdfs:domain ind:PackagingConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnableFlag rdf:type rdf:Property ;
    rdfs:label 'Returnable Flag' ;
    rdfs:comment 'Indicates whether this packaging configuration is returnable (e.g., returnable drums, IBCs, cylinders) requiring deposit tracking and reverse logistics.' ;
    rdfs:domain ind:PackagingConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stackHeightMax rdf:type rdf:Property ;
    rdfs:label 'Stack Height Max' ;
    rdfs:comment 'Maximum number of pallet layers that can be safely stacked vertically in warehouse storage, considering packaging strength and product stability.' ;
    rdfs:domain ind:PackagingConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tareWeightKg rdf:type rdf:Property ;
    rdfs:label 'Tare Weight Kg' ;
    rdfs:comment 'Weight of the empty packaging container in kilograms, excluding product. Used for net weight calculations and transportation compliance.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unPackagingCode rdf:type rdf:Property ;
    rdfs:label 'Un Packaging Code' ;
    rdfs:comment 'United Nations packaging certification code indicating the packaging meets UN performance standards for hazardous materials transport. Examples: 4G (fiberboard box), 1A1 (steel drum), 1H1 (plastic drum), 31HA1 (IBC composite).' ;
    rdfs:domain ind:PackagingConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitsPerPallet rdf:type rdf:Property ;
    rdfs:label 'Units Per Pallet' ;
    rdfs:comment 'Number of packaging units (drums, IBCs, bags, etc.) that can be loaded on a single pallet for warehouse storage and transportation.' ;
    rdfs:domain ind:PackagingConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:widthMm rdf:type rdf:Property ;
    rdfs:label 'Width Mm' ;
    rdfs:comment 'Width of rectangular packaging (IBCs, totes, boxes) in millimeters. Used for warehouse slotting and transportation planning.' ;
    rdfs:domain ind:PackagingConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compositionId rdf:type rdf:Property ;
    rdfs:label 'Composition Id' ;
    rdfs:comment 'Unique identifier for the product composition record.' ;
    rdfs:domain ind:Composition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:componentCasRegistryId rdf:type rdf:Property ;
    rdfs:label 'Component Cas Registry Id' ;
    rdfs:comment 'Foreign key linking to rawmaterial.cas_registry. Business justification: Each product composition component must reference the authoritative CAS registry record for REACH/TSCA regulatory reporting, SDS authoring, and hazard classification. component_cas_number is a denorma' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CasRegistry .

ind:componentApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Component Approval Date' ;
    rdfs:comment 'Date when the component received regulatory approval.' ;
    rdfs:domain ind:Composition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:componentConcentrationRangeFlag rdf:type rdf:Property ;
    rdfs:label 'Component Concentration Range Flag' ;
    rdfs:comment 'Indicates whether the concentration is expressed as a range.' ;
    rdfs:domain ind:Composition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:componentConcentrationUnit rdf:type rdf:Property ;
    rdfs:label 'Component Concentration Unit' ;
    rdfs:comment 'Unit of measurement for the component concentration.' ;
    rdfs:domain ind:Composition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentConcentrationValue rdf:type rdf:Property ;
    rdfs:label 'Component Concentration Value' ;
    rdfs:comment 'Numeric concentration of the component.' ;
    rdfs:domain ind:Composition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:componentEcNumber rdf:type rdf:Property ;
    rdfs:label 'Component Ec Number' ;
    rdfs:comment 'EC number identifying the component within European regulatory lists.' ;
    rdfs:domain ind:Composition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Component Expiration Date' ;
    rdfs:comment 'Date after which the component is considered expired.' ;
    rdfs:domain ind:Composition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:componentFunction rdf:type rdf:Property ;
    rdfs:label 'Component Function' ;
    rdfs:comment 'Role of the component within the product formulation.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentHazardClass rdf:type rdf:Property ;
    rdfs:label 'Component Hazard Class' ;
    rdfs:comment 'Globally Harmonized System hazard class applicable to the component.' ;
    rdfs:domain ind:Composition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentHazardStatement rdf:type rdf:Property ;
    rdfs:label 'Component Hazard Statement' ;
    rdfs:comment 'Standard hazard statement describing the risks of the component.' ;
    rdfs:domain ind:Composition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentIupacName rdf:type rdf:Property ;
    rdfs:label 'Component Iupac Name' ;
    rdfs:comment 'Systematic IUPAC name of the component.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentPhysicalState rdf:type rdf:Property ;
    rdfs:label 'Component Physical State' ;
    rdfs:comment 'Physical state of the component at room temperature.' ;
    rdfs:domain ind:Composition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentPrecautionaryStatement rdf:type rdf:Property ;
    rdfs:label 'Component Precautionary Statement' ;
    rdfs:comment 'Standard precautionary statement for safe handling of the component.' ;
    rdfs:domain ind:Composition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentPurity rdf:type rdf:Property ;
    rdfs:label 'Component Purity' ;
    rdfs:comment 'Purity of the component expressed as a percentage.' ;
