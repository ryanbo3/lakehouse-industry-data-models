    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsDeclarationRequired rdf:type rdf:Property ;
    rdfs:label 'Customs Declaration Required' ;
    rdfs:comment 'Flag indicating if a customs declaration is required.' ;
