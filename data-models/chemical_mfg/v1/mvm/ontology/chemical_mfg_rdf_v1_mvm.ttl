    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityInspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Status' ;
    rdfs:comment 'Current status of the quality inspection for the lot.' ;
    rdfs:domain ind:LotRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageHumidityPercent rdf:type rdf:Property ;
    rdfs:label 'Storage Humidity Percent' ;
