ind:concentrationNominal rdf:type rdf:Property ;
    rdfs:label 'Concentration Nominal' ;
    rdfs:comment 'Typical concentration of the component in the composition.' ;
    rdfs:domain ind:MaterialComposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:concentrationUnit rdf:type rdf:Property ;
    rdfs:label 'Concentration Unit' ;
    rdfs:comment 'Unit of measure for the concentration values.' ;
    rdfs:domain ind:MaterialComposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardStatement rdf:type rdf:Property ;
