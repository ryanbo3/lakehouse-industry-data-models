ind:reconciliationDate rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Date' ;
    rdfs:comment 'Date the item was reconciled with a payment.' ;
    rdfs:domain ind:ArOpenItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalPaidAmount rdf:type rdf:Property ;
