    rdfs:comment 'Regulatory classification for export control compliance.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightChargeCurrency rdf:type rdf:Property ;
