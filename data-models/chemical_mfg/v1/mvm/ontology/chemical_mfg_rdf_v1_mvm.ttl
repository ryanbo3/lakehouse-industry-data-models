    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costPerUnit rdf:type rdf:Property ;
    rdfs:label 'Cost Per Unit' ;
    rdfs:comment 'Acquisition cost per unit of the material in the lot.' ;
    rdfs:domain ind:LotRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isRecalled rdf:type rdf:Property ;
    rdfs:label 'Is Recalled' ;
    rdfs:comment 'Indicates whether the lot has been placed under a product recall.' ;
