ind:shipmentLineId rdf:type rdf:Property ;
    rdfs:label 'Shipment Line Id' ;
    rdfs:comment 'Unique identifier for the shipment line record.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ShipmentLine .

ind:deliverySiteId rdf:type rdf:Property ;
    rdfs:label 'Delivery Site Id' ;
    rdfs:comment 'Foreign key linking to customer.site. Business justification: In chemical manufacturing, multi-site customers receive split shipments where individual lines are routed to different customer sites. Line-level site assignment drives site-specific COA generation, S' ;
    rdfs:domain ind:ShipmentLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Site .

ind:carrierCode rdf:type rdf:Property ;
    rdfs:label 'Carrier Code' ;
    rdfs:comment 'Code of the carrier responsible for transporting this line.' ;
