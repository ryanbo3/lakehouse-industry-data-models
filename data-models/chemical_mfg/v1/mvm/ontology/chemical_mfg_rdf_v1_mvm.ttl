ind:eventNumber rdf:type rdf:Property ;
    rdfs:label 'Event Number' ;
    rdfs:comment 'External reference number for the revenue recognition posting event.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event Timestamp' ;
    rdfs:comment 'Date and time when the revenue recognition event was triggered (e.g., delivery, billing, milestone).' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isEstimated rdf:type rdf:Property ;
    rdfs:label 'Is Estimated' ;
    rdfs:comment 'Indicates if the recognized revenue amount is estimated (e.g., for long-term contracts).' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReversal rdf:type rdf:Property ;
    rdfs:label 'Is Reversal' ;
    rdfs:comment 'Indicates if this event is a reversal of a previously posted revenue recognition.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recognitionEndDate rdf:type rdf:Property ;
    rdfs:label 'Recognition End Date' ;
    rdfs:comment 'End date of the revenue recognition period (for over-time recognitions).' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recognitionStartDate rdf:type rdf:Property ;
    rdfs:label 'Recognition Start Date' ;
    rdfs:comment 'Start date of the revenue recognition period (for over-time recognitions).' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recognitionType rdf:type rdf:Property ;
    rdfs:label 'Recognition Type' ;
    rdfs:comment 'Indicates whether revenue is recognized at a single point or over a period.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognizedRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Recognized Revenue Amount' ;
    rdfs:comment 'Amount of revenue recognized in this event.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueAmountLocal rdf:type rdf:Property ;
    rdfs:label 'Revenue Amount Local' ;
    rdfs:comment 'Recognized revenue amount in the local currency of the transaction.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueCategory rdf:type rdf:Property ;
    rdfs:label 'Revenue Category' ;
    rdfs:comment 'Category of revenue (e.g., product sales, service, licensing).' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueLineType rdf:type rdf:Property ;
    rdfs:label 'Revenue Line Type' ;
    rdfs:comment 'Type of revenue line item.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRecognitionEventStatus rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Event Status' ;
    rdfs:comment 'Current processing status of the revenue recognition event.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRecognitionMethod rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Method' ;
    rdfs:comment 'Accounting standard used for revenue recognition.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceEventReference rdf:type rdf:Property ;
    rdfs:label 'Source Event Reference' ;
    rdfs:comment 'Identifier of the source transaction (e.g., delivery note, invoice) that caused this revenue recognition.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceEventType rdf:type rdf:Property ;
    rdfs:label 'Source Event Type' ;
    rdfs:comment 'Source event that triggered the revenue recognition.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicabilityCustomerSegment rdf:type rdf:Property ;
    rdfs:label 'Applicability Customer Segment' ;
    rdfs:comment 'Customer segment code (e.g., INDUSTRIAL, RETAIL) for which this payment term is valid.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicabilityProductGroup rdf:type rdf:Property ;
    rdfs:label 'Applicability Product Group' ;
    rdfs:comment 'Product group identifier (e.g., CHEMICALS, POLYMERS) to which the term applies.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicabilityRegion rdf:type rdf:Property ;
    rdfs:label 'Applicability Region' ;
    rdfs:comment 'Geographic region (ISO 3166-1 alpha-3 country code) where the payment term can be used.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselineDateRule rdf:type rdf:Property ;
    rdfs:label 'Baseline Date Rule' ;
    rdfs:comment 'Rule indicating which document date is used as the starting point for due-date calculation.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cashFlowImpactCategory rdf:type rdf:Property ;
    rdfs:label 'Cash Flow Impact Category' ;
    rdfs:comment 'Categorization of the term\'s impact on cash-flow forecasting.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceRegulation rdf:type rdf:Property ;
    rdfs:label 'Compliance Regulation' ;
    rdfs:comment 'Regulatory framework that governs handling of the payment term.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountType rdf:type rdf:Property ;
    rdfs:label 'Discount Type' ;
    rdfs:comment 'Indicates whether the early-payment discount is a percentage or a fixed monetary amount.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunningIntervalDays rdf:type rdf:Property ;
    rdfs:label 'Dunning Interval Days' ;
    rdfs:comment 'Number of days between successive dunning notices.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dunningLevelStart rdf:type rdf:Property ;
    rdfs:label 'Dunning Level Start' ;
    rdfs:comment 'Initial dunning level triggered after the due date passes.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:earlyPaymentDiscountDays rdf:type rdf:Property ;
    rdfs:label 'Early Payment Discount Days' ;
    rdfs:comment 'Number of days from the baseline date during which the early-payment discount applies.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:earlyPaymentDiscountPercent rdf:type rdf:Property ;
    rdfs:label 'Early Payment Discount Percent' ;
    rdfs:comment 'Percentage discount offered for payment made within the qualifying early-payment window.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:externalReferenceCode rdf:type rdf:Property ;
    rdfs:label 'External Reference Code' ;
    rdfs:comment 'Identifier of the payment term in an external source system (e.g., legacy ERP).' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fixedDiscountAmount rdf:type rdf:Property ;
    rdfs:label 'Fixed Discount Amount' ;
    rdfs:comment 'Fixed monetary amount discount offered for early payment when discount_type is fixed_amount.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isConsolidated rdf:type rdf:Property ;
    rdfs:label 'Is Consolidated' ;
    rdfs:comment 'True if the term applies to intercompany or consolidated billing scenarios.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDefault rdf:type rdf:Property ;
    rdfs:label 'Is Default' ;
    rdfs:comment 'Indicates whether this term is the default for new customers or contracts.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalClauseReference rdf:type rdf:Property ;
    rdfs:label 'Legal Clause Reference' ;
    rdfs:comment 'Reference to the contract clause or statutory provision governing this payment term.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxDiscountAmount rdf:type rdf:Property ;
    rdfs:label 'Max Discount Amount' ;
    rdfs:comment 'Cap on the total discount value that can be applied under this term.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netDueDays rdf:type rdf:Property ;
    rdfs:label 'Net Due Days' ;
    rdfs:comment 'Standard number of days after the baseline date when full payment is due if no discount is taken.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paymentMethodAllowed rdf:type rdf:Property ;
    rdfs:label 'Payment Method Allowed' ;
    rdfs:comment 'Payment methods that may be used when this term is applied.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermDescription rdf:type rdf:Property ;
    rdfs:label 'Payment Term Description' ;
    rdfs:comment 'Full textual description of the payment term and its business purpose.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Term Status' ;
    rdfs:comment 'Current lifecycle status of the payment term.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresApproval rdf:type rdf:Property ;
    rdfs:label 'Requires Approval' ;
    rdfs:comment 'True if usage of this payment term must be approved by a manager or finance officer.' ;
