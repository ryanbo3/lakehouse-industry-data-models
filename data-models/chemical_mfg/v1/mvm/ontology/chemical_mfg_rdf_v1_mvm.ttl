ind:reportingRequirement rdf:type rdf:Property ;
    rdfs:label 'Reporting Requirement' ;
    rdfs:comment 'Regulatory reporting framework applicable (e.g., EPA 40 CFR 302, TRI).' ;
    rdfs:domain ind:EmissionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourcePermitLimit rdf:type rdf:Property ;
    rdfs:label 'Source Permit Limit' ;
    rdfs:comment 'Regulatory emission limit for the source.' ;
