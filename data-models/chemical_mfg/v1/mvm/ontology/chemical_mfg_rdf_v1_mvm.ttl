    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceReference rdf:type rdf:Property ;
    rdfs:label 'Source Reference' ;
    rdfs:comment 'Identifier of the emission source (e.g., stack, vent, tank) that generated the event.' ;
    rdfs:domain ind:EmissionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceType rdf:type rdf:Property ;
    rdfs:label 'Source Type' ;
    rdfs:comment 'Classification of the physical source of the emission.' ;
