ind:receiptNumber rdf:type rdf:Property ;
    rdfs:label 'Receipt Number' ;
    rdfs:comment 'Business identifier assigned to the receipt, used for external reference and audit.' ;
    rdfs:domain ind:PaymentReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationStatus rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Status' ;
    rdfs:comment 'Result of matching the payment to open invoices.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryArAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Ar Account Id' ;
