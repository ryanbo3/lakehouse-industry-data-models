    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emissionLimitUnit rdf:type rdf:Property ;
    rdfs:label 'Emission Limit Unit' ;
    rdfs:comment 'Unit of measure for the emission limit (e.g., kilograms per hour).' ;
    rdfs:domain ind:Ehs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emissionLimitValue rdf:type rdf:Property ;
    rdfs:label 'Emission Limit Value' ;
    rdfs:comment 'Maximum allowable emission quantity for the source per reporting period.' ;
    rdfs:domain ind:Ehs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emissionMedium rdf:type rdf:Property ;
    rdfs:label 'Emission Medium' ;
    rdfs:comment 'Environmental medium to which emissions are released.' ;
    rdfs:domain ind:EmissionSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emissionSourceDescription rdf:type rdf:Property ;
    rdfs:label 'Emission Source Description' ;
    rdfs:comment 'Detailed free-text description of the emission source, its function, and any special characteristics.' ;
    rdfs:domain ind:EmissionSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAreaSource rdf:type rdf:Property ;
    rdfs:label 'Is Area Source' ;
    rdfs:comment 'True if emissions are dispersed over an area rather than a single point.' ;
    rdfs:domain ind:EmissionSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isControlled rdf:type rdf:Property ;
    rdfs:label 'Is Controlled' ;
    rdfs:comment 'Indicates whether the source has an attached emissions control device.' ;
    rdfs:domain ind:EmissionSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFugitive rdf:type rdf:Property ;
    rdfs:label 'Is Fugitive' ;
    rdfs:comment 'True if the source represents fugitive emissions (e.g., leaks, vents).' ;
    rdfs:domain ind:EmissionSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPointSource rdf:type rdf:Property ;
    rdfs:label 'Is Point Source' ;
    rdfs:comment 'True if emissions originate from a discrete point (e.g., stack).' ;
    rdfs:domain ind:EmissionSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastMonitoringDate rdf:type rdf:Property ;
    rdfs:label 'Last Monitoring Date' ;
    rdfs:comment 'Date the most recent monitoring measurement was recorded.' ;
    rdfs:domain ind:EmissionSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:locationDescription rdf:type rdf:Property ;
    rdfs:label 'Location Description' ;
    rdfs:comment 'Free-form description of the source location (e.g., building, floor, area).' ;
    rdfs:domain ind:EmissionSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextMonitoringDue rdf:type rdf:Property ;
    rdfs:label 'Next Monitoring Due' ;
    rdfs:comment 'Scheduled date for the next required monitoring activity.' ;
    rdfs:domain ind:EmissionSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingCategory rdf:type rdf:Property ;
    rdfs:label 'Reporting Category' ;
    rdfs:comment 'Regulatory framework(s) under which the source must be reported.' ;
    rdfs:domain ind:EmissionSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceCapacity rdf:type rdf:Property ;
    rdfs:label 'Source Capacity' ;
    rdfs:comment 'Maximum designed throughput or flow rate of the emission source.' ;
    rdfs:domain ind:EmissionSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceCode rdf:type rdf:Property ;
    rdfs:label 'Source Code' ;
    rdfs:comment 'Business-assigned alphanumeric code uniquely identifying the emission source within the enterprise.' ;
    rdfs:domain ind:EmissionSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceGroup rdf:type rdf:Property ;
    rdfs:label 'Source Group' ;
    rdfs:comment 'Logical grouping or classification of related emission sources (e.g., boiler cluster).' ;
    rdfs:domain ind:EmissionSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceName rdf:type rdf:Property ;
    rdfs:label 'Source Name' ;
    rdfs:comment 'Human-readable name of the emission source as used in reports and dashboards.' ;
    rdfs:domain ind:EmissionSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceOperatingHoursPerYear rdf:type rdf:Property ;
    rdfs:label 'Source Operating Hours Per Year' ;
    rdfs:comment 'Total number of hours the source operates in a calendar year.' ;
    rdfs:domain ind:EmissionSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceOwner rdf:type rdf:Property ;
    rdfs:label 'Source Owner' ;
    rdfs:comment 'Organizational unit or department responsible for the emission source.' ;
    rdfs:domain ind:EmissionSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceStatus rdf:type rdf:Property ;
    rdfs:label 'Source Status' ;
    rdfs:comment 'Current operational status of the emission source.' ;
    rdfs:domain ind:EmissionSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteDisposalRecordId rdf:type rdf:Property ;
    rdfs:label 'Waste Disposal Record Id' ;
    rdfs:comment 'System-generated unique identifier for the waste disposal record.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WasteDisposalRecord .

ind:hazmatDeclarationId rdf:type rdf:Property ;
    rdfs:label 'Hazmat Declaration Id' ;
    rdfs:comment 'Foreign key linking to logistics.hazmat_declaration. Business justification: RCRA hazardous waste transport requires a DOT hazmat declaration alongside the waste manifest. Chemical manufacturing EHS teams reconcile waste disposal records against filed hazmat declarations for E' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HazmatDeclaration .

ind:disposalFacilityName rdf:type rdf:Property ;
    rdfs:label 'Disposal Facility Name' ;
    rdfs:comment 'Name of the licensed external facility where waste was sent.' ;
    rdfs:domain ind:WasteDisposalRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalMethod rdf:type rdf:Property ;
    rdfs:label 'Disposal Method' ;
    rdfs:comment 'Method used to dispose of the waste.' ;
    rdfs:domain ind:Ehs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalNumber rdf:type rdf:Property ;
    rdfs:label 'Disposal Number' ;
    rdfs:comment 'Business identifier assigned to the waste disposal transaction, used for tracking and reporting.' ;
    rdfs:domain ind:WasteDisposalRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Disposal Timestamp' ;
    rdfs:comment 'Date and time when the waste was actually disposed of or shipped for disposal.' ;
    rdfs:domain ind:WasteDisposalRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:epaWasteCode rdf:type rdf:Property ;
    rdfs:label 'Epa Waste Code' ;
    rdfs:comment 'EPA hazardous waste code (e.g., D001, F003) associated with the waste.' ;
    rdfs:domain ind:Ehs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardousWasteClassification rdf:type rdf:Property ;
    rdfs:label 'Hazardous Waste Classification' ;
    rdfs:comment 'Classification of waste for RCRA reporting purposes.' ;
    rdfs:domain ind:WasteDisposalRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionReportNumber rdf:type rdf:Property ;
    rdfs:label 'Inspection Report Number' ;
    rdfs:comment 'Identifier of the post-disposal inspection or audit report.' ;
    rdfs:domain ind:WasteDisposalRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:landDisposalRestrictionsCompliance rdf:type rdf:Property ;
    rdfs:label 'Land Disposal Restrictions Compliance' ;
    rdfs:comment 'Indicates compliance with Land Disposal Restrictions (true) or non-compliance (false).' ;
    rdfs:domain ind:WasteDisposalRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ldrComplianceDetails rdf:type rdf:Property ;
    rdfs:label 'Ldr Compliance Details' ;
    rdfs:comment 'Free-text description of any LDR exemptions, variances, or special conditions.' ;
    rdfs:domain ind:WasteDisposalRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manifestNumber rdf:type rdf:Property ;
    rdfs:label 'Manifest Number' ;
    rdfs:comment 'Unique EPA manifest identifier for the waste shipment.' ;
    rdfs:domain ind:WasteDisposalRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rcraHazardousFlag rdf:type rdf:Property ;
    rdfs:label 'Rcra Hazardous Flag' ;
    rdfs:comment 'True if the waste is classified as hazardous under RCRA regulations.' ;
    rdfs:domain ind:WasteDisposalRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shipmentDate rdf:type rdf:Property ;
    rdfs:label 'Shipment Date' ;
    rdfs:comment 'Date the waste shipment left the generating facility.' ;
    rdfs:domain ind:WasteDisposalRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:wasteBatchLotNumber rdf:type rdf:Property ;
    rdfs:label 'Waste Batch Lot Number' ;
    rdfs:comment 'Lot or batch identifier associated with the waste generation batch.' ;
    rdfs:domain ind:WasteDisposalRecord ;
    rdf:type owl:DatatypeProperty ;
