ind:emissionQuantity rdf:type rdf:Property ;
    rdfs:label 'Emission Quantity' ;
    rdfs:comment 'Measured amount of pollutant released during the event.' ;
    rdfs:domain ind:EmissionEvent ;
    rdf:type owl:DatatypeProperty ;
