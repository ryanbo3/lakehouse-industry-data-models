ind:arOpenItemId rdf:type rdf:Property ;
    rdfs:label 'Ar Open Item Id' ;
    rdfs:comment 'Foreign key linking to billing.ar_open_item. Business justification: A payment_receipt clears one or more ar_open_items. This is the fundamental AR clearing relationship in SAP FI/CO-aligned billing: a payment is applied against an open AR item, reducing the outstandin' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ArOpenItem .

ind:amountDiscount rdf:type rdf:Property ;
    rdfs:label 'Amount Discount' ;
    rdfs:comment 'Discounts or rebates applied to the gross amount.' ;
    rdfs:domain ind:PaymentReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amountGross rdf:type rdf:Property ;
    rdfs:label 'Amount Gross' ;
    rdfs:comment 'Total amount received before any deductions.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
