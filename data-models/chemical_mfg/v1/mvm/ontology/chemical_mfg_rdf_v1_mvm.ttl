    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:particleSizeUm rdf:type rdf:Property ;
    rdfs:label 'Particle Size Um' ;
    rdfs:comment 'Average particle size in micrometers.' ;
