    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportableFlag rdf:type rdf:Property ;
    rdfs:label 'Reportable Flag' ;
    rdfs:comment 'True if the emission event meets regulatory reporting thresholds.' ;
