    rdfs:range xsd:dateTime .

ind:recordAuditUpdated rdf:type rdf:Property ;
    rdfs:label 'Record Audit Updated' ;
    rdfs:comment 'Timestamp of the most recent update to the composition record.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:complianceNotes rdf:type rdf:Property ;
    rdfs:label 'Compliance Notes' ;
    rdfs:comment 'Free-text notes on compliance actions, exemptions, or special conditions.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:csrDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Csr Document Reference' ;
    rdfs:comment 'Reference or file identifier for the associated Chemical Safety Report document.' ;
    rdfs:domain ind:ReachDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:csrRequired rdf:type rdf:Property ;
    rdfs:label 'Csr Required' ;
    rdfs:comment 'Indicates whether a full Chemical Safety Report is required for this substance.' ;
    rdfs:domain ind:ReachDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dossierStatus rdf:type rdf:Property ;
    rdfs:label 'Dossier Status' ;
    rdfs:comment 'Current lifecycle state of the REACH dossier.' ;
    rdfs:domain ind:ReachDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dossierUpdateDate rdf:type rdf:Property ;
    rdfs:label 'Dossier Update Date' ;
    rdfs:comment 'Most recent date the dossier information was updated.' ;
    rdfs:domain ind:ReachDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:echaSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Echa Submission Date' ;
    rdfs:comment 'Date the dossier was submitted to the ECHA portal.' ;
    rdfs:domain ind:ReachDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:echaSubmissionReference rdf:type rdf:Property ;
    rdfs:label 'Echa Submission Reference' ;
    rdfs:comment 'Reference code for the submission package in the ECHA REACH-IT portal.' ;
    rdfs:domain ind:ReachDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exposureScenariosCount rdf:type rdf:Property ;
    rdfs:label 'Exposure Scenarios Count' ;
    rdfs:comment 'Total number of exposure scenarios defined within the dossier.' ;
    rdfs:domain ind:ReachDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:registrantRole rdf:type rdf:Property ;
    rdfs:label 'Registrant Role' ;
    rdfs:comment 'Role of the registrant in the REACH dossier (lead registrant, member, or coordinator).' ;
    rdfs:domain ind:ReachDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Status' ;
    rdfs:comment 'Overall regulatory status of the substance across applicable frameworks.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskAssessmentFlag rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Flag' ;
    rdfs:comment 'Indicates whether a risk assessment has been completed for the dossier.' ;
    rdfs:domain ind:ReachDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:siefMembership rdf:type rdf:Property ;
    rdfs:label 'Sief Membership' ;
    rdfs:comment 'Indicates whether the dossier is part of a Substance Information Exchange Forum (SIEF).' ;
    rdfs:domain ind:ReachDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substanceIupacName rdf:type rdf:Property ;
    rdfs:label 'Substance Iupac Name' ;
    rdfs:comment 'Systematic chemical name of the substance as defined by IUPAC.' ;
    rdfs:domain ind:ReachDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchNumberRequired rdf:type rdf:Property ;
    rdfs:label 'Batch Number Required' ;
    rdfs:comment 'Indicates whether a batch number must be assigned for traceability.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazardClassGhs rdf:type rdf:Property ;
    rdfs:label 'Hazard Class Ghs' ;
    rdfs:comment 'Globally Harmonized System hazard classification (e.g., H220, H315).' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:humidityRequirementPercent rdf:type rdf:Property ;
    rdfs:label 'Humidity Requirement Percent' ;
    rdfs:comment 'Maximum relative humidity allowed for storage.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incompatibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Incompatibility Flag' ;
    rdfs:comment 'True if the material is known to be chemically incompatible with certain other substances.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHazardous rdf:type rdf:Property ;
    rdfs:label 'Is Hazardous' ;
    rdfs:comment 'Indicates whether the material is classified as hazardous under GHS/OSHA.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRestrictedSubstance rdf:type rdf:Property ;
    rdfs:label 'Is Restricted Substance' ;
    rdfs:comment 'True if the material is restricted under REACH, TSCA, or other jurisdictional lists.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lifecycleStatus rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Status' ;
    rdfs:comment 'Current lifecycle stage of the material within the enterprise.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lightSensitivityFlag rdf:type rdf:Property ;
    rdfs:label 'Light Sensitivity Flag' ;
    rdfs:comment 'Indicates whether the material degrades when exposed to light.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:materialClass rdf:type rdf:Property ;
    rdfs:label 'Material Class' ;
    rdfs:comment 'Broad functional classification of the material within manufacturing processes.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialMasterName rdf:type rdf:Property ;
    rdfs:label 'Material Master Name' ;
    rdfs:comment 'Human-readable primary name of the material (e.g., common trade name).' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:molecularFormula rdf:type rdf:Property ;
    rdfs:label 'Molecular Formula' ;
    rdfs:comment 'Symbolic representation of the material\'s elemental composition (e.g., C6H12O6).' ;
    rdfs:domain ind:Rawmaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:molecularWeight rdf:type rdf:Property ;
    rdfs:label 'Molecular Weight' ;
    rdfs:comment 'Molar mass of the material expressed in grams per mole.' ;
    rdfs:domain ind:Rawmaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:procurementLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Procurement Lead Time Days' ;
    rdfs:comment 'Average lead time from purchase order to receipt.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualityControlRequired rdf:type rdf:Property ;
    rdfs:label 'Quality Control Required' ;
    rdfs:comment 'True if the material must undergo QC testing before use.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retestIntervalDays rdf:type rdf:Property ;
    rdfs:label 'Retest Interval Days' ;
    rdfs:comment 'Number of days after which the material must be re-qualified or tested.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sapMaterialNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Material Number' ;
    rdfs:comment 'Material number as defined in SAP S/4HANA Materials Management module.' ;
    rdfs:domain ind:MaterialMaster ;
