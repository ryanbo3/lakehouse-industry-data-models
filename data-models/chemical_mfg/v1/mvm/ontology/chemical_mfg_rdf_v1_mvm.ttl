    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotStatus rdf:type rdf:Property ;
    rdfs:label 'Lot Status' ;
    rdfs:comment 'Current status of the lot for inventory and quality control.' ;
    rdfs:domain ind:LotRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Date' ;
    rdfs:comment 'Date on which the quality inspection was performed.' ;
    rdfs:domain ind:LotRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualityInspectionResult rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Result' ;
    rdfs:comment 'Result of the quality inspection (e.g., pass, fail, conditional).' ;
