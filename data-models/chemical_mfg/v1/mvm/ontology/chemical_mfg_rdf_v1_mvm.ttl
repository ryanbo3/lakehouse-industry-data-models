    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Retention Period Days' ;
    rdfs:comment 'Number of days the template must be retained according to policy.' ;
    rdfs:domain ind:CoaTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:templateCode rdf:type rdf:Property ;
    rdfs:label 'Template Code' ;
    rdfs:comment 'Unique code used to reference the COA template across systems.' ;
    rdfs:domain ind:CoaTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateName rdf:type rdf:Property ;
    rdfs:label 'Template Name' ;
    rdfs:comment 'Human-readable name of the certificate of analysis template.' ;
    rdfs:domain ind:CoaTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateType rdf:type rdf:Property ;
    rdfs:label 'Template Type' ;
    rdfs:comment 'Category of the template indicating what kind of item the COA applies to.' ;
    rdfs:domain ind:CoaTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentOrganizationId rdf:type rdf:Property ;
    rdfs:label 'Parent Organization Id' ;
    rdfs:comment 'Identifier of the immediate parent sales organization in the hierarchy.' ;
    rdfs:domain ind:Organization ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Organization .

ind:parentSalesOrganizationId rdf:type rdf:Property ;
    rdfs:label 'Parent Sales Organization Id' ;
    rdfs:comment 'Self-referencing FK on sales_organization (parent_sales_organization_id)' ;
    rdfs:domain ind:Organization ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Organization .

ind:organizationType rdf:type rdf:Property ;
    rdfs:label 'Organization Type' ;
    rdfs:comment 'Category that defines the scope or channel of the sales organization.' ;
    rdfs:domain ind:Organization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesOrganizationDescription rdf:type rdf:Property ;
    rdfs:label 'Sales Organization Description' ;
    rdfs:comment 'Free-form text describing the purpose, focus, or notes about the sales organization.' ;
    rdfs:domain ind:Organization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesOrganizationName rdf:type rdf:Property ;
    rdfs:label 'Sales Organization Name' ;
    rdfs:comment 'Human-readable name of the sales organization.' ;
    rdfs:domain ind:Organization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesOrganizationStatus rdf:type rdf:Property ;
    rdfs:label 'Sales Organization Status' ;
    rdfs:comment 'Current lifecycle state of the sales organization.' ;
    rdfs:domain ind:Organization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planCharacteristicAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Plan Characteristic Assignment Id' ;
    rdfs:comment 'Unique surrogate key for the plan-characteristic assignment record' ;
    rdfs:domain ind:PlanCharacteristicAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:characteristicWeight rdf:type rdf:Property ;
    rdfs:label 'Characteristic Weight' ;
    rdfs:comment 'Relative importance or weighting of this characteristic within the plan, used for scoring or prioritization' ;
    rdfs:domain ind:PlanCharacteristicAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:controlLimitOverride rdf:type rdf:Property ;
    rdfs:label 'Control Limit Override' ;
    rdfs:comment 'Plan-specific control limit that overrides the standard control limits defined in the characteristic master' ;
    rdfs:domain ind:PlanCharacteristicAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:samplingSizeOverride rdf:type rdf:Property ;
    rdfs:label 'Sampling Size Override' ;
    rdfs:comment 'Plan-specific sample size that overrides the default sampling size defined in the characteristic master' ;
    rdfs:domain ind:PlanCharacteristicAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryLineId rdf:type rdf:Property ;
    rdfs:label 'Delivery Line Id' ;
    rdfs:comment 'System-generated unique identifier for this delivery line record.' ;
    rdfs:domain ind:DeliveryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryLineStatus rdf:type rdf:Property ;
    rdfs:label 'Delivery Line Status' ;
    rdfs:comment 'Lifecycle status of this specific delivery line execution. Tracks the operational state of fulfilling this line item on this delivery, independent of the overall delivery status or order line status.' ;
    rdfs:domain ind:DeliveryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packingType rdf:type rdf:Property ;
    rdfs:label 'Packing Type' ;
    rdfs:comment 'Type of packaging used for this delivery line (drums, IBC totes, bulk tanker, bags). Packing decisions are made at delivery execution time and may vary for the same line item across different deliveries.' ;
    rdfs:domain ind:DeliveryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emissionReportingLineItemId rdf:type rdf:Property ;
    rdfs:label 'Emission Reporting Line Item Id' ;
    rdfs:comment 'Unique system-generated identifier for each emission reporting line item record' ;
    rdfs:domain ind:EmissionReportingLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calculationMethod rdf:type rdf:Property ;
    rdfs:label 'Calculation Method' ;
    rdfs:comment 'Method used to calculate the reported quantity for this line item (e.g., direct measurement, emission factor, mass balance, engineering estimate)' ;
    rdfs:domain ind:EmissionReportingLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataQualityCode rdf:type rdf:Property ;
    rdfs:label 'Data Quality Code' ;
    rdfs:comment 'Quality indicator for the reported data on this line item (e.g., measured, calculated, estimated, default)' ;
    rdfs:domain ind:EmissionReportingLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formSectionReference rdf:type rdf:Property ;
    rdfs:label 'Form Section Reference' ;
    rdfs:comment 'Specific section or line number on the regulatory form where this emission is reported (e.g., TRI Form R Section 5.1, Part II Line 3)' ;
    rdfs:domain ind:EmissionReportingLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryBasis rdf:type rdf:Property ;
    rdfs:label 'Regulatory Basis' ;
    rdfs:comment 'The specific regulatory requirement or citation that mandates reporting this emission in this submission (e.g., EPCRA Section 313, 40 CFR Part 98 Subpart C, Title V permit condition)' ;
    rdfs:domain ind:EmissionReportingLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportedQuantity rdf:type rdf:Property ;
    rdfs:label 'Reported Quantity' ;
    rdfs:comment 'The specific quantity of the emission reported in this submission, which may differ from the actual emission quantity due to regulatory calculation methods, rounding rules, or reporting period allocation' ;
    rdfs:domain ind:EmissionReportingLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportingPeriodAllocation rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Allocation' ;
    rdfs:comment 'Method used to allocate the emission event to the reporting period (e.g., full allocation, prorated, annualized) when the event spans multiple reporting periods or requires adjustment' ;
    rdfs:domain ind:EmissionReportingLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionLineItemStatus rdf:type rdf:Property ;
    rdfs:label 'Submission Line Item Status' ;
    rdfs:comment 'Lifecycle status of this specific line item within the submission (draft, submitted, amended, corrected, withdrawn)' ;
    rdfs:domain ind:EmissionReportingLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .
