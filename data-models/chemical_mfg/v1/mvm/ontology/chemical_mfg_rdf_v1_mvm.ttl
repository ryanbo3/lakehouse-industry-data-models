ind:lineAmount rdf:type rdf:Property ;
    rdfs:label 'Line Amount' ;
    rdfs:comment 'Gross monetary amount for the line (quantity × unit_price).' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:manufacturingSite rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Site' ;
    rdfs:comment 'Plant or site where the product batch was produced.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plant rdf:type rdf:Property ;
    rdfs:label 'Plant' ;
    rdfs:comment 'SAP plant code representing the production location.' ;
