    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chainOfCustodyNotes rdf:type rdf:Property ;
    rdfs:label 'Chain Of Custody Notes' ;
    rdfs:comment 'Free-text notes documenting handling, transfers, or observations for the lot.' ;
