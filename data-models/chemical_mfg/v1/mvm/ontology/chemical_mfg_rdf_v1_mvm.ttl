ind:shipmentNumber rdf:type rdf:Property ;
    rdfs:label 'Shipment Number' ;
    rdfs:comment 'External shipment reference number used in logistics and customer communications.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentStatus rdf:type rdf:Property ;
    rdfs:label 'Shipment Status' ;
    rdfs:comment 'Current lifecycle state of the shipment.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentType rdf:type rdf:Property ;
    rdfs:label 'Shipment Type' ;
    rdfs:comment 'Category of shipment based on mode of transport.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureControlRequired rdf:type rdf:Property ;
