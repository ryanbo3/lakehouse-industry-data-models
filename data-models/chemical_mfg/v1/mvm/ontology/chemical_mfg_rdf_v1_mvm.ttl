ind:intercompanyInvoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Intercompany Invoice Number' ;
    rdfs:comment 'Reference number of the corresponding intercompany invoice.' ;
    rdfs:domain ind:InvoiceLine ;
