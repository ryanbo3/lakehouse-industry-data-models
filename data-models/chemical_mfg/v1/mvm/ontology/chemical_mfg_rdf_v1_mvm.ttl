    rdfs:range xsd:boolean .

ind:disclosureThreshold rdf:type rdf:Property ;
    rdfs:label 'Disclosure Threshold' ;
    rdfs:comment 'Regulatory threshold that triggers mandatory disclosure of the component.' ;
    rdfs:domain ind:Composition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordAuditCreated rdf:type rdf:Property ;
    rdfs:label 'Record Audit Created' ;
    rdfs:comment 'Timestamp when the composition record was first created.' ;
