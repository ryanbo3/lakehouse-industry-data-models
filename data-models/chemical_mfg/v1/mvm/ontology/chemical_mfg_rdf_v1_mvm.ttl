ind:emissionUnit rdf:type rdf:Property ;
    rdfs:label 'Emission Unit' ;
    rdfs:comment 'Unit of measure for the emission quantity.' ;
    rdfs:domain ind:EmissionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventType rdf:type rdf:Property ;
    rdfs:label 'Event Type' ;
    rdfs:comment 'Category of the emission event such as routine monitoring, accidental release, or spill.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementMethod rdf:type rdf:Property ;
    rdfs:label 'Measurement Method' ;
    rdfs:comment 'Method used to determine the emission quantity.' ;
    rdfs:domain ind:Ehs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringFrequency rdf:type rdf:Property ;
    rdfs:label 'Monitoring Frequency' ;
    rdfs:comment 'How often the emission source is monitored.' ;
    rdfs:domain ind:Ehs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseMedia rdf:type rdf:Property ;
    rdfs:label 'Release Media' ;
    rdfs:comment 'Environmental medium into which the pollutant was released.' ;
    rdfs:domain ind:EmissionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportStatus rdf:type rdf:Property ;
    rdfs:label 'Report Status' ;
    rdfs:comment 'Current processing status of the regulatory report.' ;
    rdfs:domain ind:EmissionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Report Submission Date' ;
    rdfs:comment 'Date the emission report was submitted to the regulator.' ;
