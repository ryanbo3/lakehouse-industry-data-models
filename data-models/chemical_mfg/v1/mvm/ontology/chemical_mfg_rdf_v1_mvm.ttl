ind:insuranceProviderName rdf:type rdf:Property ;
    rdfs:label 'Insurance Provider Name' ;
    rdfs:comment 'Name of the insurance carrier providing liability coverage.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceAccuracyRate rdf:type rdf:Property ;
    rdfs:label 'Invoice Accuracy Rate' ;
    rdfs:comment 'Proportion of carrier invoices that match agreed rates and terms.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mcNumber rdf:type rdf:Property ;
    rdfs:label 'Mc Number' ;
    rdfs:comment 'Unique identifier for the carrier\'s operating authority.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Measurement Period End' ;
    rdfs:comment 'Last day of the reporting window for carrier KPIs.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Measurement Period Start' ;
    rdfs:comment 'First day of the reporting window for carrier KPIs.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:oracleTmsCarrierCode rdf:type rdf:Property ;
    rdfs:label 'Oracle Tms Carrier Code' ;
    rdfs:comment 'Carrier identifier used within Oracle Transportation Management.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceOnTimeDeliveryRate rdf:type rdf:Property ;
    rdfs:label 'Performance On Time Delivery Rate' ;
    rdfs:comment 'Percentage of deliveries made on schedule during the measurement period.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceOnTimePickupRate rdf:type rdf:Property ;
    rdfs:label 'Performance On Time Pickup Rate' ;
    rdfs:comment 'Percentage of pickups completed within the agreed time window during the measurement period.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preferredLanes rdf:type rdf:Property ;
    rdfs:label 'Preferred Lanes' ;
    rdfs:comment 'Typical origin-to-destination lane pairs where the carrier is preferred.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyRatingScore rdf:type rdf:Property ;
    rdfs:label 'Safety Rating Score' ;
    rdfs:comment 'Composite safety score (0-5) derived from audit results and incident history.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scacCode rdf:type rdf:Property ;
    rdfs:label 'Scac Code' ;
    rdfs:comment 'Four-character code assigned to the carrier by the National Motor Freight Traffic Association.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tenderAcceptanceRate rdf:type rdf:Property ;
    rdfs:label 'Tender Acceptance Rate' ;
    rdfs:comment 'Percentage of carrier tenders accepted versus offered.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tierRating rdf:type rdf:Property ;
    rdfs:label 'Tier Rating' ;
    rdfs:comment 'Internal tier classification based on performance and strategic importance.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryContactId rdf:type rdf:Property ;
    rdfs:label 'Delivery Contact Id' ;
    rdfs:comment 'Foreign key linking to customer.contact. Business justification: Freight order execution in chemical manufacturing requires a designated customer contact for delivery scheduling, dock access coordination, and hazmat receiving confirmation. The contact\'s ehs_contact' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:freightRateId rdf:type rdf:Property ;
    rdfs:label 'Freight Rate Id' ;
    rdfs:comment 'Foreign key linking to logistics.freight_rate. Business justification: A freight order is executed at a specific contracted or spot freight rate. freight_order currently has freight_rate (DECIMAL) as a denormalized rate value. Adding freight_rate_id FK to the freight_rat' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FreightRate .

ind:originLocationSiteId rdf:type rdf:Property ;
    rdfs:label 'Origin Location Site Id' ;
    rdfs:comment 'Reference to the location where the shipment originates.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Site .

ind:primaryFreightSiteId rdf:type rdf:Property ;
    rdfs:label 'Primary Freight Site Id' ;
    rdfs:comment 'Identifier of the shipper (internal customer) that owns the freight order.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Site .

ind:accessorialCharges rdf:type rdf:Property ;
    rdfs:label 'Accessorial Charges' ;
    rdfs:comment 'Additional charges (e.g., liftgate, detention) applied to the freight order.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carrierAcceptanceStatus rdf:type rdf:Property ;
    rdfs:label 'Carrier Acceptance Status' ;
    rdfs:comment 'Current acceptance response from the carrier.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierMode rdf:type rdf:Property ;
    rdfs:label 'Carrier Mode' ;
    rdfs:comment 'Mode of transport used by the carrier for this freight order.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dotRegulationCode rdf:type rdf:Property ;
    rdfs:label 'Dot Regulation Code' ;
    rdfs:comment 'Code referencing applicable DOT transportation regulations for the shipment.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightOrderStatus rdf:type rdf:Property ;
    rdfs:label 'Freight Order Status' ;
    rdfs:comment 'Current lifecycle state of the freight order.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadType rdf:type rdf:Property ;
    rdfs:label 'Load Type' ;
    rdfs:comment 'Classification of the shipment load based on size, hazard, and temperature requirements.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberOfPallets rdf:type rdf:Property ;
    rdfs:label 'Number Of Pallets' ;
    rdfs:comment 'Count of pallets included in the freight order.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pickupWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Pickup Window End' ;
    rdfs:comment 'Latest time the carrier must complete loading at the origin.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pickupWindowStart rdf:type rdf:Property ;
    rdfs:label 'Pickup Window Start' ;
    rdfs:comment 'Earliest time the carrier may begin loading at the origin.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:temperatureRequirementC rdf:type rdf:Property ;
    rdfs:label 'Temperature Requirement C' ;
    rdfs:comment 'Required temperature control for temperature-sensitive chemicals.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tenderMethod rdf:type rdf:Property ;
    rdfs:label 'Tender Method' ;
    rdfs:comment 'Method used to tender the freight order to carriers.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeCubicM rdf:type rdf:Property ;
    rdfs:label 'Volume Cubic M' ;
    rdfs:comment 'Aggregate volume of the freight order in cubic meters.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryConfirmationId rdf:type rdf:Property ;
    rdfs:label 'Delivery Confirmation Id' ;
    rdfs:comment 'System-generated unique identifier for the delivery confirmation record.' ;
    rdfs:domain ind:DeliveryConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:logisticsPartyId rdf:type rdf:Property ;
    rdfs:label 'Logistics Party Id' ;
    rdfs:comment 'Identifier of the customer or receiving party that accepted the shipment.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LogisticsParty .

ind:receiverContactId rdf:type rdf:Property ;
    rdfs:label 'Receiver Contact Id' ;
    rdfs:comment 'Foreign key linking to customer.contact. Business justification: In chemical manufacturing, hazmat deliveries must be received by an authorized customer contact (EHS-certified, with purchase_order_authority_limit). Linking delivery_confirmation to customer.contact ' ;
    rdfs:domain ind:DeliveryConfirmation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:receiverSiteId rdf:type rdf:Property ;
    rdfs:label 'Receiver Site Id' ;
    rdfs:comment 'Foreign key linking to customer.site. Business justification: Proof-of-delivery reconciliation in chemical manufacturing requires matching the delivery to the specific customer site (dock restrictions, hazmat receiving capability, COA/SDS requirements per site).' ;
    rdfs:domain ind:DeliveryConfirmation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Site .

ind:conditionOnArrival rdf:type rdf:Property ;
    rdfs:label 'Condition On Arrival' ;
    rdfs:comment 'Observed condition of the goods at the time of receipt.' ;
    rdfs:domain ind:DeliveryConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveredQuantity rdf:type rdf:Property ;
    rdfs:label 'Delivered Quantity' ;
    rdfs:comment 'Quantity of product actually delivered to the receiver.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryConfirmationStatus rdf:type rdf:Property ;
    rdfs:label 'Delivery Confirmation Status' ;
    rdfs:comment 'Current processing state of the delivery confirmation.' ;
    rdfs:domain ind:DeliveryConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Delivery Timestamp' ;
    rdfs:comment 'Date and time when the shipment was physically received by the customer.' ;
    rdfs:domain ind:DeliveryConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:discrepancyNotes rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Notes' ;
    rdfs:comment 'Free-text notes describing any shortages, damages, or other issues noted on receipt.' ;
    rdfs:domain ind:DeliveryConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionCode rdf:type rdf:Property ;
    rdfs:label 'Exception Code' ;
    rdfs:comment 'Standardized code indicating the type of exception, if any, associated with the delivery.' ;
    rdfs:domain ind:DeliveryConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:humidityPercent rdf:type rdf:Property ;
    rdfs:label 'Humidity Percent' ;
    rdfs:comment 'Relative humidity percentage measured at the delivery location.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:podDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Pod Document Url' ;
    rdfs:comment 'Link to the stored electronic proof-of-delivery document.' ;
    rdfs:domain ind:DeliveryConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiverSignature rdf:type rdf:Property ;
    rdfs:label 'Receiver Signature' ;
    rdfs:comment 'Electronic representation of the signature captured from the receiver as proof of delivery.' ;
    rdfs:domain ind:DeliveryConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originFacilityId rdf:type rdf:Property ;
    rdfs:label 'Origin Facility Id' ;
    rdfs:comment 'Foreign key linking to ehs.facility. Business justification: SARA Title III and EPA TRI reporting require aggregating hazmat shipment quantities by originating facility annually. Chemical manufacturing EHS teams link hazmat declarations to the EHS facility reco' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:applicableRegulation rdf:type rdf:Property ;
    rdfs:label 'Applicable Regulation' ;
    rdfs:comment 'Regulatory framework governing the shipment (DOT, IATA, or IMDG).' ;
    rdfs:domain ind:HazmatDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Compliance Review Date' ;
    rdfs:comment 'Date when the declaration was last reviewed for compliance.' ;
    rdfs:domain ind:HazmatDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:emergencyResponseGuideNumber rdf:type rdf:Property ;
    rdfs:label 'Emergency Response Guide Number' ;
    rdfs:comment 'Reference number of the applicable Emergency Response Guide.' ;
    rdfs:domain ind:HazmatDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardDivision rdf:type rdf:Property ;
    rdfs:label 'Hazard Division' ;
    rdfs:comment 'Division within the hazard class, if applicable (e.g., 1A, 1B).' ;
    rdfs:domain ind:HazmatDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatDeclarationStatus rdf:type rdf:Property ;
    rdfs:label 'Hazmat Declaration Status' ;
    rdfs:comment 'Current approval status of the hazmat declaration.' ;
    rdfs:domain ind:HazmatDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isExempt rdf:type rdf:Property ;
    rdfs:label 'Is Exempt' ;
    rdfs:comment 'Indicates if the shipment is exempt from certain regulations.' ;
    rdfs:domain ind:HazmatDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:properShippingName rdf:type rdf:Property ;
    rdfs:label 'Proper Shipping Name' ;
    rdfs:comment 'Official shipping name as defined in the UN Model Regulations.' ;
    rdfs:domain ind:HazmatDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulationSection rdf:type rdf:Property ;
    rdfs:label 'Regulation Section' ;
    rdfs:comment 'Specific section of the regulation that applies (e.g., 49 CFR 172.200).' ;
    rdfs:domain ind:HazmatDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segregationRequirements rdf:type rdf:Property ;
    rdfs:label 'Segregation Requirements' ;
    rdfs:comment 'Special segregation or incompatibility requirements for transport.' ;
    rdfs:domain ind:HazmatDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipperCertification rdf:type rdf:Property ;
    rdfs:label 'Shipper Certification' ;
    rdfs:comment 'Indicates whether the shipper is certified for the material.' ;
    rdfs:domain ind:HazmatDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spillResponseInstructions rdf:type rdf:Property ;
    rdfs:label 'Spill Response Instructions' ;
    rdfs:comment 'Procedures to follow in case of a spill during transport.' ;
    rdfs:domain ind:HazmatDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureLimitMax rdf:type rdf:Property ;
    rdfs:label 'Temperature Limit Max' ;
    rdfs:comment 'Maximum allowable temperature for transport.' ;
    rdfs:domain ind:HazmatDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureLimitMin rdf:type rdf:Property ;
    rdfs:label 'Temperature Limit Min' ;
    rdfs:comment 'Minimum allowable temperature for transport.' ;
    rdfs:domain ind:HazmatDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureUom rdf:type rdf:Property ;
    rdfs:label 'Temperature Uom' ;
    rdfs:comment 'Unit of measure for temperature limits (Celsius or Fahrenheit).' ;
    rdfs:domain ind:HazmatDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alternateRouteOptions rdf:type rdf:Property ;
    rdfs:label 'Alternate Route Options' ;
    rdfs:comment 'Text description of alternate routes considered during planning.' ;
    rdfs:domain ind:ShipmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arrivalDate rdf:type rdf:Property ;
    rdfs:label 'Arrival Date' ;
    rdfs:comment 'Scheduled date for shipment arrival.' ;
    rdfs:domain ind:ShipmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bridgeRestrictionFlag rdf:type rdf:Property ;
    rdfs:label 'Bridge Restriction Flag' ;
    rdfs:comment 'True if the route is prohibited for certain hazmat due to bridge weight/height restrictions.' ;
    rdfs:domain ind:ShipmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceVolumeLimitM3 rdf:type rdf:Property ;
    rdfs:label 'Compliance Volume Limit M3' ;
    rdfs:comment 'Maximum allowable volume per DOT regulations for the selected route.' ;
    rdfs:domain ind:ShipmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceWeightLimitKg rdf:type rdf:Property ;
    rdfs:label 'Compliance Weight Limit Kg' ;
    rdfs:comment 'Maximum allowable weight per DOT regulations for the selected route.' ;
    rdfs:domain ind:ShipmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costAdjustments rdf:type rdf:Property ;
    rdfs:label 'Cost Adjustments' ;
    rdfs:comment 'Sum of all cost adjustments (fees, discounts, surcharges) applied to the shipment.' ;
    rdfs:domain ind:ShipmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costGross rdf:type rdf:Property ;
    rdfs:label 'Cost Gross' ;
    rdfs:comment 'Total gross cost of the shipment before any adjustments.' ;
    rdfs:domain ind:ShipmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costNet rdf:type rdf:Property ;
    rdfs:label 'Cost Net' ;
    rdfs:comment 'Final net cost after applying adjustments.' ;
    rdfs:domain ind:ShipmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:departureDate rdf:type rdf:Property ;
    rdfs:label 'Departure Date' ;
    rdfs:comment 'Scheduled date for shipment departure.' ;
    rdfs:domain ind:ShipmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:estimatedTransitTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Estimated Transit Time Minutes' ;
    rdfs:comment 'Projected total transit time for the route, in minutes.' ;
    rdfs:domain ind:ShipmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fuelSurchargeAmount rdf:type rdf:Property ;
    rdfs:label 'Fuel Surcharge Amount' ;
    rdfs:comment 'Monetary amount of the fuel surcharge applied to the shipment.' ;
    rdfs:domain ind:ShipmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelSurchargeBasis rdf:type rdf:Property ;
    rdfs:label 'Fuel Surcharge Basis' ;
    rdfs:comment 'Method used to calculate fuel surcharge.' ;
    rdfs:domain ind:ShipmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatRouteFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Route Flag' ;
    rdfs:comment 'True when the route is designated for hazardous material transport.' ;
    rdfs:domain ind:ShipmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isExpedited rdf:type rdf:Property ;
    rdfs:label 'Is Expedited' ;
    rdfs:comment 'True if the shipment is marked for expedited handling.' ;
    rdfs:domain ind:ShipmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loadVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Load Volume M3' ;
    rdfs:comment 'Actual volume loaded onto the vehicle after consolidation.' ;
    rdfs:domain ind:ShipmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loadWeightKg rdf:type rdf:Property ;
    rdfs:label 'Load Weight Kg' ;
    rdfs:comment 'Actual weight loaded onto the vehicle after consolidation.' ;
    rdfs:domain ind:ShipmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:optimizationObjective rdf:type rdf:Property ;
    rdfs:label 'Optimization Objective' ;
    rdfs:comment 'Primary objective used for route and load optimization.' ;
    rdfs:domain ind:ShipmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planTimestamp rdf:type rdf:Property ;
    rdfs:label 'Plan Timestamp' ;
    rdfs:comment 'Timestamp when the shipment plan was generated.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedArrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Planned Arrival Timestamp' ;
    rdfs:comment 'Exact timestamp when the shipment is expected to reach the destination.' ;
    rdfs:domain ind:ShipmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedDepartureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Planned Departure Timestamp' ;
    rdfs:comment 'Exact timestamp when the shipment is expected to leave the origin.' ;
    rdfs:domain ind:ShipmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:restrictedRouteFlag rdf:type rdf:Property ;
    rdfs:label 'Restricted Route Flag' ;
    rdfs:comment 'Indicates if the route includes any regulatory restrictions (e.g., tunnel/bridge limits).' ;
    rdfs:domain ind:ShipmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:routeDescription rdf:type rdf:Property ;
    rdfs:label 'Route Description' ;
    rdfs:comment 'Human-readable description of the planned route, including waypoints.' ;
    rdfs:domain ind:ShipmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeDistanceKm rdf:type rdf:Property ;
    rdfs:label 'Route Distance Km' ;
    rdfs:comment 'Total distance of the planned route, in kilometers.' ;
    rdfs:domain ind:ShipmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shipmentPlanStatus rdf:type rdf:Property ;
    rdfs:label 'Shipment Plan Status' ;
    rdfs:comment 'Current lifecycle status of the shipment plan.' ;
    rdfs:domain ind:ShipmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tunnelRestrictionFlag rdf:type rdf:Property ;
    rdfs:label 'Tunnel Restriction Flag' ;
    rdfs:comment 'True if the route is prohibited for certain hazmat due to tunnel restrictions.' ;
    rdfs:domain ind:ShipmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vehicleCapacityVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Vehicle Capacity Volume M3' ;
    rdfs:comment 'Maximum volume the vehicle can carry, in cubic meters.' ;
    rdfs:domain ind:ShipmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vehicleCapacityWeightKg rdf:type rdf:Property ;
    rdfs:label 'Vehicle Capacity Weight Kg' ;
    rdfs:comment 'Maximum weight the vehicle can carry, in kilograms.' ;
    rdfs:domain ind:ShipmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commodityClass rdf:type rdf:Property ;
    rdfs:label 'Commodity Class' ;
    rdfs:comment 'Chemical commodity classification (e.g., petrochemical, specialty, bulk) for which the rate is negotiated.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceHazmatFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Hazmat Flag' ;
    rdfs:comment 'Indicates whether the rate complies with hazardous material transport regulations.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:destinationZone rdf:type rdf:Property ;
    rdfs:label 'Destination Zone' ;
    rdfs:comment 'Destination geographic or tariff zone code used in rate calculations.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightRateDescription rdf:type rdf:Property ;
    rdfs:label 'Freight Rate Description' ;
    rdfs:comment 'Free-form text describing special conditions, lane details, or notes.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightRateStatus rdf:type rdf:Property ;
    rdfs:label 'Freight Rate Status' ;
    rdfs:comment 'Current lifecycle status of the rate record.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelSurchargePercent rdf:type rdf:Property ;
    rdfs:label 'Fuel Surcharge Percent' ;
    rdfs:comment 'Fuel surcharge expressed as a percentage of the base rate.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isContractual rdf:type rdf:Property ;
    rdfs:label 'Is Contractual' ;
    rdfs:comment 'True if the rate is part of a contracted agreement; false for spot rates.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laneType rdf:type rdf:Property ;
    rdfs:label 'Lane Type' ;
    rdfs:comment 'Description of the shipment lane configuration.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumCharge rdf:type rdf:Property ;
    rdfs:label 'Minimum Charge' ;
    rdfs:comment 'Minimum charge that applies regardless of distance or weight.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mode rdf:type rdf:Property ;
    rdfs:label 'Mode' ;
    rdfs:comment 'Mode of transport for which the rate applies.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originZone rdf:type rdf:Property ;
    rdfs:label 'Origin Zone' ;
    rdfs:comment 'Origin geographic or tariff zone code used in rate calculations.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCode rdf:type rdf:Property ;
    rdfs:label 'Rate Code' ;
    rdfs:comment 'Business identifier or code used by logistics planners to reference the rate.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Rate Source System' ;
    rdfs:comment 'System of record that originated the rate (e.g., OTM, SAP, custom).' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateType rdf:type rdf:Property ;
    rdfs:label 'Rate Type' ;
    rdfs:comment 'Classification of the rate (e.g., base, accessorial, fuel surcharge).' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateValue rdf:type rdf:Property ;
    rdfs:label 'Rate Value' ;
    rdfs:comment 'Numeric value of the rate expressed in the selected unit of measure.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeLimitCubicMeters rdf:type rdf:Property ;
    rdfs:label 'Volume Limit Cubic Meters' ;
    rdfs:comment 'Maximum volume for which the rate applies; null if unlimited.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightLimitKg rdf:type rdf:Property ;
    rdfs:label 'Weight Limit Kg' ;
    rdfs:comment 'Maximum weight for which the rate applies; null if unlimited.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customsDeclarationId rdf:type rdf:Property ;
    rdfs:label 'Customs Declaration Id' ;
    rdfs:comment 'Unique system-generated identifier for the customs declaration record.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryCustomsAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Customs Account Id' ;
    rdfs:comment 'Identifier of the exporting party (company) responsible for the shipment.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:clearanceDate rdf:type rdf:Property ;
    rdfs:label 'Clearance Date' ;
    rdfs:comment 'Date on which customs clearance was completed or finalized.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clearanceStatus rdf:type rdf:Property ;
    rdfs:label 'Clearance Status' ;
    rdfs:comment 'Current status of the customs clearance process.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsBrokerName rdf:type rdf:Property ;
    rdfs:label 'Customs Broker Name' ;
    rdfs:comment 'Name of the licensed customs broker handling the declaration.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declarationDate rdf:type rdf:Property ;
    rdfs:label 'Declaration Date' ;
    rdfs:comment 'Date the customs declaration was filed with the authority.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:declarationNumber rdf:type rdf:Property ;
    rdfs:label 'Declaration Number' ;
    rdfs:comment 'External reference number assigned to the customs declaration by the logistics or customs system.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declarationStatus rdf:type rdf:Property ;
    rdfs:label 'Declaration Status' ;
    rdfs:comment 'Overall processing status of the customs declaration.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declarationType rdf:type rdf:Property ;
    rdfs:label 'Declaration Type' ;
    rdfs:comment 'Indicates whether the declaration is for an export shipment or an import shipment.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declaredValue rdf:type rdf:Property ;
    rdfs:label 'Declared Value' ;
    rdfs:comment 'Monetary value declared for customs assessment, expressed in the transaction currency.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:destinationCountry rdf:type rdf:Property ;
    rdfs:label 'Destination Country' ;
    rdfs:comment 'Three-letter country code of the final destination for the shipment.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dutyAmount rdf:type rdf:Property ;
    rdfs:label 'Duty Amount' ;
    rdfs:comment 'Monetary amount of customs duty assessed on the shipment.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dutyCurrency rdf:type rdf:Property ;
    rdfs:label 'Duty Currency' ;
    rdfs:comment 'Currency in which the duty amount is expressed.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eccn rdf:type rdf:Property ;
    rdfs:label 'Eccn' ;
    rdfs:comment 'Alphanumeric code used by U.S. export control to classify dual-use items.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightCurrency rdf:type rdf:Property ;
    rdfs:label 'Freight Currency' ;
    rdfs:comment 'Currency of the freight cost (ISO 4217).' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardousClassification rdf:type rdf:Property ;
    rdfs:label 'Hazardous Classification' ;
    rdfs:comment 'UN number or class describing the hazardous nature of the chemical.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hsCode rdf:type rdf:Property ;
    rdfs:label 'Hs Code' ;
    rdfs:comment 'Six- to ten-digit code that classifies the goods for customs duties and statistical purposes.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:importPermitReference rdf:type rdf:Property ;
    rdfs:label 'Import Permit Reference' ;
    rdfs:comment 'Reference number of the import permit required for regulated chemicals.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isLcl rdf:type rdf:Property ;
    rdfs:label 'Is Lcl' ;
    rdfs:comment 'True if the shipment is less than a full container load (LCL).' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reachComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Reach Compliance Flag' ;
    rdfs:comment 'Indicates whether the chemical product complies with EU REACH regulations (true = compliant).' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tariffRatePercent rdf:type rdf:Property ;
    rdfs:label 'Tariff Rate Percent' ;
    rdfs:comment 'Applicable tariff rate expressed as a percentage of the declared value.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annualInspectionDueDate rdf:type rdf:Property ;
    rdfs:label 'Annual Inspection Due Date' ;
    rdfs:comment 'Scheduled date by which the next annual DOT inspection must be completed.' ;
    rdfs:domain ind:Vehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cleaningCertificationDate rdf:type rdf:Property ;
    rdfs:label 'Cleaning Certification Date' ;
    rdfs:comment 'Date when the vehicle received its most recent cleaning certification for cross-contamination prevention.' ;
    rdfs:domain ind:Vehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cleaningCertificationStatus rdf:type rdf:Property ;
    rdfs:label 'Cleaning Certification Status' ;
    rdfs:comment 'Current status of the vehicle\'s cleaning certification.' ;
    rdfs:domain ind:Vehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceDocumentationStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Documentation Status' ;
    rdfs:comment 'Overall status of required regulatory documentation for the vehicle.' ;
    rdfs:domain ind:Vehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossContaminationPrevention rdf:type rdf:Property ;
    rdfs:label 'Cross Contamination Prevention' ;
    rdfs:comment 'Indicates whether cleaning procedures have been completed to prevent cross-contamination before the next load.' ;
    rdfs:domain ind:Vehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dedicated rdf:type rdf:Property ;
    rdfs:label 'Dedicated' ;
    rdfs:comment 'True if the vehicle is dedicated to a single customer or product line; false if shared.' ;
    rdfs:domain ind:Vehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:emissionClass rdf:type rdf:Property ;
    rdfs:label 'Emission Class' ;
    rdfs:comment 'Regulatory emission classification (e.g., Euro6, EPA Tier 4).' ;
    rdfs:domain ind:Vehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelType rdf:type rdf:Property ;
    rdfs:label 'Fuel Type' ;
    rdfs:comment 'Primary fuel used by the vehicle.' ;
    rdfs:domain ind:Vehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gpsEnabled rdf:type rdf:Property ;
    rdfs:label 'Gps Enabled' ;
    rdfs:comment 'True if the vehicle is equipped with active GPS tracking.' ;
    rdfs:domain ind:Vehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gpsLastUpdate rdf:type rdf:Property ;
    rdfs:label 'Gps Last Update' ;
    rdfs:comment 'Timestamp of the most recent GPS location transmission.' ;
    rdfs:domain ind:Vehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:gpsLatitude rdf:type rdf:Property ;
    rdfs:label 'Gps Latitude' ;
    rdfs:comment 'Most recent latitude coordinate reported by the vehicle\'s GPS.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gpsLongitude rdf:type rdf:Property ;
    rdfs:label 'Gps Longitude' ;
    rdfs:comment 'Most recent longitude coordinate reported by the vehicle\'s GPS.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazmatPlacardCapability rdf:type rdf:Property ;
    rdfs:label 'Hazmat Placard Capability' ;
    rdfs:comment 'Indicates whether the vehicle is equipped and approved to display DOT hazmat placards.' ;
    rdfs:domain ind:Vehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insurancePolicyNumber rdf:type rdf:Property ;
    rdfs:label 'Insurance Policy Number' ;
    rdfs:comment 'Identifier of the liability insurance policy covering the vehicle.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastCargoCode rdf:type rdf:Property ;
    rdfs:label 'Last Cargo Code' ;
    rdfs:comment 'CAS or internal product code of the most recent cargo carried, used for contamination tracking.' ;
    rdfs:domain ind:Vehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licensePlate rdf:type rdf:Property ;
    rdfs:label 'License Plate' ;
    rdfs:comment 'State-issued license plate identifier.' ;
    rdfs:domain ind:Vehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceCycleKm rdf:type rdf:Property ;
    rdfs:label 'Maintenance Cycle Km' ;
    rdfs:comment 'Mileage interval after which scheduled maintenance is required.' ;
    rdfs:domain ind:Vehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxPayloadKg rdf:type rdf:Property ;
    rdfs:label 'Max Payload Kg' ;
    rdfs:comment 'Maximum allowable cargo weight for the vehicle.' ;
    rdfs:domain ind:Vehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:model rdf:type rdf:Property ;
    rdfs:label 'Model' ;
    rdfs:comment 'Model designation of the vehicle.' ;
    rdfs:domain ind:Vehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Next Maintenance Date' ;
    rdfs:comment 'Planned date for the next preventive maintenance activity.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:odometerKm rdf:type rdf:Property ;
    rdfs:label 'Odometer Km' ;
    rdfs:comment 'Cumulative distance traveled by the vehicle.' ;
    rdfs:domain ind:Vehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureControlCapability rdf:type rdf:Property ;
    rdfs:label 'Temperature Control Capability' ;
    rdfs:comment 'True if the vehicle can maintain a controlled temperature environment for temperature-sensitive chemicals.' ;
    rdfs:domain ind:Vehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vehicleCode rdf:type rdf:Property ;
    rdfs:label 'Vehicle Code' ;
    rdfs:comment 'Internal alphanumeric code used to reference the vehicle within the enterprise system.' ;
    rdfs:domain ind:Vehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleName rdf:type rdf:Property ;
    rdfs:label 'Vehicle Name' ;
    rdfs:comment 'Human-readable name or designation for the vehicle (e.g., "West Coast Tanker 12").' ;
    rdfs:domain ind:Vehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleStatus rdf:type rdf:Property ;
    rdfs:label 'Vehicle Status' ;
    rdfs:comment 'Current operational state of the vehicle.' ;
    rdfs:domain ind:Vehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleType rdf:type rdf:Property ;
    rdfs:label 'Vehicle Type' ;
    rdfs:comment 'Category of transport equipment, aligned with DOT hazardous-material classifications.' ;
    rdfs:domain ind:Vehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vinNumber rdf:type rdf:Property ;
    rdfs:label 'Vin Number' ;
    rdfs:comment 'Globally unique identifier assigned by the vehicle manufacturer.' ;
    rdfs:domain ind:Vehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yearOfManufacture rdf:type rdf:Property ;
    rdfs:label 'Year Of Manufacture' ;
    rdfs:comment 'Calendar year the vehicle was built.' ;
    rdfs:domain ind:Vehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryInspectionMaterialMasterId rdf:type rdf:Property ;
    rdfs:label 'Primary Inspection Material Master Id' ;
    rdfs:comment 'Identifier of the material or chemical substance being inspected.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialMaster .

ind:dispositionBy rdf:type rdf:Property ;
    rdfs:label 'Disposition By' ;
    rdfs:comment 'User identifier of the person who authorized the disposition.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionCode rdf:type rdf:Property ;
    rdfs:label 'Disposition Code' ;
    rdfs:comment 'Final decision for the lot after inspection (e.g., accept, rework, scrap).' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionDate rdf:type rdf:Property ;
    rdfs:label 'Disposition Date' ;
    rdfs:comment 'Date on which the disposition decision was recorded.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gmpCompliant rdf:type rdf:Property ;
    rdfs:label 'Gmp Compliant' ;
    rdfs:comment 'Indicates whether the inspection complies with Good Manufacturing Practice requirements.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:holdFlag rdf:type rdf:Property ;
    rdfs:label 'Hold Flag' ;
    rdfs:comment 'Indicates whether the lot is placed on quality hold pending further investigation.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectionEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Inspection End Timestamp' ;
    rdfs:comment 'Date and time when the inspection activity was completed.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:inspectionLotStatus rdf:type rdf:Property ;
    rdfs:label 'Inspection Lot Status' ;
    rdfs:comment 'Current lifecycle status of the inspection lot.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionReason rdf:type rdf:Property ;
    rdfs:label 'Inspection Reason' ;
    rdfs:comment 'Reason for initiating the inspection (e.g., incoming goods, in-process, periodic, customer complaint).' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionSource rdf:type rdf:Property ;
    rdfs:label 'Inspection Source' ;
    rdfs:comment 'Origin of the inspection data: performed in-lab, field sampling, or automated sensor.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Inspection Start Timestamp' ;
    rdfs:comment 'Date and time when the inspection activity began.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:inspectionVersion rdf:type rdf:Property ;
    rdfs:label 'Inspection Version' ;
    rdfs:comment 'Version number of the inspection record for concurrency control.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lotType rdf:type rdf:Property ;
    rdfs:label 'Lot Type' ;
    rdfs:comment 'Category indicating why the lot was created: incoming goods receipt, in-process production, scheduled periodic inspection, or customer return.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementUom rdf:type rdf:Property ;
    rdfs:label 'Measurement Uom' ;
    rdfs:comment 'Unit of measure for the primary measurement value. [ENUM-REF-CANDIDATE: kg|lb|L|gal|ppm|%|mol — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementValue rdf:type rdf:Property ;
    rdfs:label 'Measurement Value' ;
    rdfs:comment 'Resulting numeric value from the primary analytical measurement.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:passFailFlag rdf:type rdf:Property ;
    rdfs:label 'Pass Fail Flag' ;
    rdfs:comment 'Indicates whether the lot passed all required specifications (True = Pass).' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quantityInspected rdf:type rdf:Property ;
    rdfs:label 'Quantity Inspected' ;
    rdfs:comment 'Total amount of material inspected, expressed in the unit of measure.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sampleQuantity rdf:type rdf:Property ;
    rdfs:label 'Sample Quantity' ;
    rdfs:comment 'Quantity of material taken as a sample for testing.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sampleUom rdf:type rdf:Property ;
    rdfs:label 'Sample Uom' ;
    rdfs:comment 'Unit of measure for the sample quantity.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcResultId rdf:type rdf:Property ;
    rdfs:label 'Qc Result Id' ;
    rdfs:comment 'Unique surrogate key for each QC test result record.' ;
    rdfs:domain ind:QcResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:labSampleId rdf:type rdf:Property ;
    rdfs:label 'Lab Sample Id' ;
    rdfs:comment 'Identifier of the associated control sample, if applicable.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LabSample .

ind:testMethodId rdf:type rdf:Property ;
    rdfs:label 'Test Method Id' ;
    rdfs:comment 'Foreign key linking to quality.test_method. Business justification: Every QC result is produced using a specific analytical test method. qc_result currently stores test_method_code as a STRING denormalized attribute but has no FK to the test_method master table. Addin' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TestMethod .

ind:comment rdf:type rdf:Property ;
    rdfs:label 'Comment' ;
    rdfs:comment 'Free-text notes or observations entered by the analyst.' ;
    rdfs:domain ind:QcResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceReference rdf:type rdf:Property ;
    rdfs:label 'Compliance Reference' ;
    rdfs:comment 'Reference to the regulatory or standard clause (e.g., ISO 9001) governing this test.' ;
    rdfs:domain ind:QcResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationAmount rdf:type rdf:Property ;
    rdfs:label 'Deviation Amount' ;
    rdfs:comment 'Numeric difference between result value and nearest specification limit.' ;
    rdfs:domain ind:QcResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deviationPercent rdf:type rdf:Property ;
    rdfs:label 'Deviation Percent' ;
