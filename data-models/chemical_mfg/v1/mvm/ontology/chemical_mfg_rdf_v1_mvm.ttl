ind:complianceFlagIfrs15 rdf:type rdf:Property ;
    rdfs:label 'Compliance Flag Ifrs15' ;
    rdfs:comment 'Flag indicating compliance with IFRS 15 revenue recognition criteria.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
