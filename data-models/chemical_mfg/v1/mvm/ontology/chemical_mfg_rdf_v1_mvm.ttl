    rdfs:range xsd:string .

ind:compositionType rdf:type rdf:Property ;
    rdfs:label 'Composition Type' ;
    rdfs:comment 'Category of the material composition based on its physical/chemical nature.' ;
    rdfs:domain ind:MaterialComposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:concentrationMax rdf:type rdf:Property ;
    rdfs:label 'Concentration Max' ;
    rdfs:comment 'Maximum allowable concentration for safety and regulatory limits.' ;
    rdfs:domain ind:MaterialComposition ;
