ind:rebateFlag rdf:type rdf:Property ;
    rdfs:label 'Rebate Flag' ;
    rdfs:comment 'True if a rebate applies to this line.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryComplianceCode rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Code' ;
    rdfs:comment 'Code indicating applicable regulatory requirements (e.g., REACH, GHS) for the product.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRecognitionDate rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Date' ;
    rdfs:comment 'Date on which revenue for this line is recognized per accounting policy.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:settlementDate rdf:type rdf:Property ;
    rdfs:label 'Settlement Date' ;
    rdfs:comment 'Date when the line was settled with the customer.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:taxExemptFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Exempt Flag' ;
    rdfs:comment 'True if the line is exempt from tax.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billingAdjustmentId rdf:type rdf:Property ;
    rdfs:label 'Billing Adjustment Id' ;
    rdfs:comment 'Primary key for adjustment' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillingAdjustment .

ind:disputeId rdf:type rdf:Property ;
    rdfs:label 'Dispute Id' ;
    rdfs:comment 'Foreign key linking to billing.dispute. Business justification: A billing_adjustment (credit or debit memo) is frequently issued as the resolution action for a customer dispute. The billing_adjustment already references the original invoice via reference_invoice_i' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Dispute .

ind:referenceInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Reference Invoice Id' ;
    rdfs:comment 'Identifier of the original invoice that is being adjusted.' ;
    rdfs:domain ind:BillingAdjustment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:accountingPeriod rdf:type rdf:Property ;
    rdfs:label 'Accounting Period' ;
    rdfs:comment 'Fiscal period (e.g., 2023Q4) to which the adjustment is posted.' ;
    rdfs:domain ind:BillingAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentNumber rdf:type rdf:Property ;
    rdfs:label 'Adjustment Number' ;
    rdfs:comment 'Business-visible document number assigned to the adjustment (e.g., CM-202300123).' ;
    rdfs:domain ind:BillingAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amount rdf:type rdf:Property ;
    rdfs:label 'Amount' ;
    rdfs:comment 'Monetary amount of the adjustment before tax calculations.' ;
