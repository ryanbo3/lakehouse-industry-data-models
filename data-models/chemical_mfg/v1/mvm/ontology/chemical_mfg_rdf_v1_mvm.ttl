    rdfs:range ind:Shipment .

ind:primaryBillSiteId rdf:type rdf:Property ;
    rdfs:label 'Primary Bill Site Id' ;
    rdfs:comment 'Reference to the party that is sending the shipment.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Site .

ind:shipmentPlanId rdf:type rdf:Property ;
