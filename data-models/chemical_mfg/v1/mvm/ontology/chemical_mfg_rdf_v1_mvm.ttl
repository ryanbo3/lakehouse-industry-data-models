# RDFS Schema for Business: Chemical Mfg

@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix ind: <http://datamodel.lakehouse.org/business/chemical_mfg#> .

# --- Root Business Class ---
ind:Business rdf:type rdfs:Class ;
    rdfs:label 'Business' ;
    rdfs:comment 'Root class for all business entities' .

# --- Specific Business: Chemical Mfg ---
ind:ChemicalMfg rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Business ;
    rdfs:label 'Chemical Mfg' ;
    rdfs:comment 'Chemical Manufacturing is a foundational industry producing a wide range of chemicals, plastics, performance materials, and agricultural solutions used across automotive, construction, electronics, and consumer goods sectors.' .

# --- Domain Classes ---
ind:Rawmaterial rdf:type rdfs:Class ;
    rdfs:subClassOf ind:ChemicalMfg ;
    rdfs:label 'Rawmaterial' ;
    rdfs:comment 'Single source of truth for all raw material master data, chemical feedstocks, intermediates, and input substances used in chemical synthesis and production. Manages CAS number registry, SDS/MSDS records, supplier-material relationships, incoming material specifications, material hazard classifications under GHS and TSCA, and material qualification. Supports Raw Material Procurement and Sourcing processes within SAP MM and production planning with material availability and quality attributes.' .

ind:Customer rdf:type rdfs:Class ;
    rdfs:subClassOf ind:ChemicalMfg ;
    rdfs:label 'Customer' ;
    rdfs:comment 'Single source of truth for all customer identity, profiles, accounts, and relationships across B2B industrial customers, distributors, and end-user segments. Manages customer master data, contact information, credit terms, shipping preferences, technical service requirements, customer segmentation, corporate accounts, site locations, and customer hierarchies. Integrates with Salesforce CRM as system of record.' .

ind:Production rdf:type rdfs:Class ;
    rdfs:subClassOf ind:ChemicalMfg ;
    rdfs:label 'Production' ;
    rdfs:comment 'Core manufacturing execution domain managing batch and continuous chemical processes, reaction sequences, synthesis operations, and production runs. Includes production orders, batch records, process parameters (temperature, pressure, pH), DCS/PLC integration data (Honeywell Experion, Siemens PCS 7), MES execution logs, yield tracking, lot genealogy, BOM consumption, MOC records, and production scheduling. Captures real-time process data from SCADA systems and maintains production history for traceability and process optimization (SPC, OEE).' .

ind:Product rdf:type rdfs:Class ;
    rdfs:subClassOf ind:ChemicalMfg ;
    rdfs:label 'Product' ;
    rdfs:comment 'Authoritative catalog of finished chemical products, formulations, grades, and SKUs offered to customers. Manages product specifications, technical data sheets, GHS classification, SDS document linkage, regulatory status (REACH, TSCA), application guidelines, packaging configurations, product lifecycle state, product hierarchies, and cross-references. Covers performance materials, plastics, agricultural solutions, and specialty chemicals.' .

ind:Quality rdf:type rdfs:Class ;
    rdfs:subClassOf ind:ChemicalMfg ;
    rdfs:label 'Quality' ;
    rdfs:comment 'Quality control and assurance domain managing laboratory testing, analytical results, COA/COC generation, and quality specifications. Includes QC test methods, sampling plans, inspection lots, quality notifications (OOS, OOT), CAPA workflows, quality hold/release decisions, SPC metrics, and GMP compliance records. Integrates with LabWare LIMS for test data and maintains quality history for regulatory audits and ISO 9001 compliance.' .

ind:Inventory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:ChemicalMfg ;
    rdfs:label 'Inventory' ;
    rdfs:comment 'Manages real-time stock positions for raw materials, intermediates, finished goods, and packaging materials across all warehouse locations and tank farms. Governs FIFO/FEFO lot rotation, hazardous material storage compliance, lot numbers, expiration dates, inventory movements, stock transfers, inventory valuation, and quarantine status. Integrates with SAP EWM and WMS for warehouse operations.' .

ind:Sales rdf:type rdfs:Class ;
    rdfs:subClassOf ind:ChemicalMfg ;
    rdfs:label 'Sales' ;
    rdfs:comment 'Commercial sales domain managing sales opportunities, quotes, contracts, pricing agreements, customer negotiations, sales pipeline, territory management, distributor channel data, and sales performance metrics. Supports technical sales with product application guidance and customer-specific formulations. Integrates with Salesforce CRM and SAP SD to drive revenue growth and customer acquisition.' .

ind:Supply rdf:type rdfs:Class ;
    rdfs:subClassOf ind:ChemicalMfg ;
    rdfs:label 'Supply' ;
    rdfs:comment 'Governs end-to-end supply chain network including supplier master data, purchase orders (PO), ASN tracking, vendor performance scorecards, supply risk management, procurement planning, RFQ processes, contract pricing with chemical suppliers, supplier qualification and audits, and inbound logistics coordination. Integrates with SAP MM and Oracle Transportation Management.' .

ind:Logistics rdf:type rdfs:Class ;
    rdfs:subClassOf ind:ChemicalMfg ;
    rdfs:label 'Logistics' ;
    rdfs:comment 'Manages outbound and inbound freight execution including carrier selection, LTL/FTL shipment planning, hazardous materials transport compliance (DOT 49 CFR), route optimization, delivery confirmation, ASN generation, bill of lading, and transport documentation for regulated chemical shipments. Integrates with Oracle Transportation Management (TMS) for logistics cost optimization.' .

ind:Billing rdf:type rdfs:Class ;
    rdfs:subClassOf ind:ChemicalMfg ;
    rdfs:label 'Billing' ;
    rdfs:comment 'Single source of truth for all revenue and financial transaction data: customer invoices, credit/debit memos, payment receipts, dispute management, revenue recognition, rebate settlements, and intercompany billing. Manages pricing execution, invoice generation from orders, payment reconciliation, and accounts receivable. Integrates with SAP FI/CO and supports SOX-compliant financial reporting.' .

ind:Ehs rdf:type rdfs:Class ;
    rdfs:subClassOf ind:ChemicalMfg ;
    rdfs:label 'Ehs' ;
    rdfs:comment 'Environment, Health, and Safety (EHS) domain managing workplace safety, environmental compliance, incident management, and regulatory reporting. Includes safety incidents, near-misses, PSM/HAZOP records, PHA documentation, VOC/HAP emissions tracking, TRI reporting, OSHA recordkeeping, EPA regulatory submissions, chemical exposure monitoring, waste disposal records, and ISO 14001/ISO 45001 audit trails. Integrates with Intelex EHS Management.' .

ind:Maintenance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:ChemicalMfg ;
    rdfs:label 'Maintenance' ;
    rdfs:comment 'Plant maintenance and asset management domain for production equipment, reactors, vessels, pumps, and instrumentation. Includes maintenance work orders, preventive maintenance schedules, equipment master data, maintenance history, spare parts management, equipment reliability metrics (MTBF, MTTR), P&ID asset registry, equipment calibration, and MOC workflows for process equipment changes. Integrates with SAP PM and supports PSM mechanical integrity requirements.' .

ind:Finance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:ChemicalMfg ;
    rdfs:label 'Finance' ;
    rdfs:comment 'Corporate finance domain managing general ledger, cost centers, cost accounting, CapEx/OpEx tracking, COGS analysis, EBITDA reporting, budgeting, financial planning, financial consolidation, and statutory reporting. Supports management reporting, profitability analysis, plant-level cost accounting, standard costing for formulations, and financial audits. Integrates with SAP FI/CO and supports SOX and FASB compliance.' .

ind:Planning rdf:type rdfs:Class ;
    rdfs:subClassOf ind:ChemicalMfg ;
    rdfs:label 'Planning' ;
    rdfs:comment 'Demand planning, sales and operations planning (S&OP), material requirements planning (MRP), capacity planning, and production scheduling for chemical manufacturing operations. Manages demand forecasts, supply-demand balancing, and capacity allocation.' .

# --- Data Product Classes (Tables) ---
ind:Opportunity rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Opportunity' ;
    rdfs:comment 'Core sales opportunity record tracking prospective deals with industrial chemical customers, distributors, and end-users. Captures opportunity stage progression, estimated deal value, probability of close, target close date, and owning sales representative. Includes opportunity-level product associations (per-product quantity, estimated revenue, competitive status) for pipeline visibility. Records structured win/loss outcome on closure (close reason, competitor displaced/displacing, decision criteria, deal value at close) for competitive intelligence. Sourced from Salesforce CRM. Primary pipeline management and forecasting entity for commercial sales.' .

ind:Quote rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Quote' ;
    rdfs:comment 'Formal price quotation issued to a customer or distributor for chemical products, including header-level terms (validity, incoterms, payment terms) and line-level detail (product/grade, quantity, UOM, per-line pricing, discounts, surcharges, COA/COC requirements). Supports RFQ response workflows and technical sales negotiations. Linked to SAP SD quotation and Salesforce CRM quote object. Enables granular margin analysis at the product-grade level.' .

ind:QuoteLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Quote Line' ;
    rdfs:comment 'Individual line item within a customer quote, representing a specific chemical product, grade, or SKU with its own pricing, quantity, unit of measure (kg, MT, L, drums), and technical specification reference. Captures per-line discount, surcharges (e.g., hazmat handling, small-order), and COA/COC requirements. Enables granular margin analysis at the product-grade level.' .

ind:PriceAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Price Agreement' ;
    rdfs:comment 'Negotiated pricing agreement (contract price, volume rebate, or long-term supply agreement) with a customer or distributor. Includes header terms (validity, currency, escalation clauses, approval status) and per-product/grade pricing conditions (unit price, volume break tiers, UOM, surcharges). Maps to SAP SD condition records and pricing contracts. SSOT for customer-specific contracted pricing within the sales domain.' .

ind:PriceAgreementLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Price Agreement Line' ;
    rdfs:comment 'Individual product-level pricing condition within a price agreement, specifying the agreed unit price, volume break tiers, UOM, validity dates, and applicable surcharges or rebate percentages for a specific chemical product or grade. Enables multi-product pricing agreements with per-SKU terms.' .

ind:Territory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Territory' ;
    rdfs:comment 'Sales territory definition, hierarchy, and representative assignment record. Defines geographic regions, industry verticals, or named-account segments with territory hierarchy (global/regional/local) and assigned product line scope. Includes full sales representative assignment history with role type (primary, backup, overlay), effective dates, and coverage scope. Supports territory planning, sales force alignment, quota attribution, and commission allocation for chemical sales organizations.' .

ind:TerritoryAssignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Territory Assignment' ;
    rdfs:comment 'Association record linking a sales representative or account manager to a specific territory, capturing assignment start/end dates, role type (primary, backup, overlay), and coverage scope. Enables historical tracking of territory ownership changes and supports commission and quota attribution in chemical sales organizations.' .

ind:Target rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Target' ;
    rdfs:comment 'Annual or periodic revenue and volume targets assigned to sales territories, product lines, or individual sales representatives. Captures target value (revenue in USD, volume in MT/kg), product category scope, period granularity (year/quarter/month), attainment tracking (actual vs. target with variance), and stretch/floor thresholds. Supports sales performance management, incentive compensation calculations, and management reporting for chemical sales teams.' .

ind:Distributor rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Distributor' ;
    rdfs:comment 'Master record for authorized chemical distributors and channel partners, including the governing distribution agreement terms. Captures distributor identity, tier classification, geographic coverage, credit limit, and compliance certifications (REACH, TSCA, responsible distribution, SDS distribution obligations). Embeds agreement details: type (exclusive/non-exclusive), authorized product categories, territory scope, MOQ, minimum purchase commitments, rebate structure, compliance obligations, and agreement validity period. SSOT for channel partner identity, commercial relationship, and contractual terms within the sales domain.' .

ind:DistributorAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Distributor Agreement' ;
    rdfs:comment 'Formal distribution agreement governing the commercial relationship between Chemical Mfg and an authorized distributor. Captures agreement type (exclusive, non-exclusive), authorized product categories, territory scope, minimum purchase commitments (MOQ), rebate structure, compliance obligations (SDS distribution, REACH downstream user reporting), and agreement validity period.' .

ind:RebateAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Rebate Agreement' ;
    rdfs:comment 'Volume-based or performance-based rebate agreement with a customer or distributor, defining rebate tiers, calculation basis (revenue or volume), accrual method, settlement frequency, and eligible product scope. Captures rebate type (volume rebate, growth incentive, market development fund), threshold levels, and payout currency. Maps to SAP SD rebate processing (BO01/BO02). Distinct from price_agreement — rebates are retrospective settlements, not upfront pricing.' .

ind:OpportunityProduct rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Opportunity Product' ;
    rdfs:comment 'Association record linking a specific chemical product or grade to a sales opportunity, capturing estimated quantity, unit of measure, estimated revenue, probability-weighted value, and competitive status for that product line within the opportunity. Enables product-level pipeline visibility and supports demand forecasting from the sales pipeline.' .

ind:StockPosition rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Stock Position' ;
    rdfs:comment 'Real-time stock position master record for each material (raw material, intermediate, finished good, packaging) at each storage location, bin, or tank farm. Tracks on-hand quantity, available quantity, reserved quantity, blocked quantity, unit of measure, batch/lot number, stock category, and stock type (unrestricted, quality inspection, blocked, returns). Serves as the primary SSOT for current inventory levels across all SAP EWM-managed warehouses and tank farms. Supports FIFO/FEFO lot rotation logic and hazardous material storage compliance. Valuation carried as reference attribute for inventory reporting; authoritative valuation owned by finance domain.' .

ind:WarehouseLocation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Warehouse Location' ;
    rdfs:comment 'Master record for all physical and logical storage locations within the warehouse network, including bulk tank farms, drum storage areas, cold storage rooms, hazmat segregation zones, quarantine bays, and finished goods warehouses. Captures location code, storage type, capacity (volume/weight), temperature range, humidity range, ventilation class, hazard class compatibility, NFPA fire diamond rating, incompatible hazard class segregation rules, maximum storage quantity per zone, fire zone, EPA/OSHA regulatory citations, and SAP EWM storage section mapping. Governs where specific chemical materials may be stored based on GHS/NFPA compatibility rules and required storage conditions.' .

ind:Lot rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Lot' ;
    rdfs:comment 'Lot (batch) master record representing a discrete quantity of a chemical material produced or received under uniform conditions. Captures lot number, material reference, manufacturing date, expiration date, retest date, days-to-expiry threshold, COA reference, GMP status, quarantine flag, lot origin (internal production vs. external receipt), current disposition (released, quarantined, rejected, expired), shelf-life remaining calculation basis, and country-of-origin for regulatory reporting. Central to FIFO/FEFO rotation, full traceability, recall management, and regulatory compliance (FDA, REACH, TSCA). Integrates with LabWare LIMS for QC release status.' .

ind:StockMovement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Stock Movement' ;
    rdfs:comment 'Transactional record of every inventory movement event including goods receipts (GR), goods issues (GI), stock transfers, returns, scrapping, sampling, and revaluations. Captures movement type code (replacing the former movement_type reference table), material, lot number, quantity, unit of measure, source location, destination location, movement direction (inbound/outbound/internal), movement reason, reference document (PO, production order, sales order, delivery), posting date, posting user, and FIFO/FEFO lot selection validation result. Provides the complete audit trail for all inventory changes. Subsumes formerly separate goods_receipt and goods_issue records as movement subtypes.' .

ind:TransferOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Transfer Order' ;
    rdfs:comment 'Warehouse transfer order issued within SAP EWM to physically move stock from one storage bin or location to another within the same warehouse complex. Captures transfer order number, source bin, destination bin, material, lot, quantity, transfer type (replenishment, putaway, pick, internal transfer), priority, assigned operator, confirmation status, and execution timestamps. Distinct from inter-plant stock transfer orders which are logistics-domain events.' .

ind:QuarantineHold rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Quarantine Hold' ;
    rdfs:comment 'Record of a quarantine or quality hold placed on a specific lot or stock quantity, preventing it from being issued or shipped until disposition is resolved. Captures hold reference number, material, lot, quantity affected, hold reason (OOS result, customer complaint, regulatory hold, damage), hold initiator, hold date, target resolution date, CAPA reference, and release or rejection outcome. Integrates with LabWare LIMS and Intelex EHS for hold initiation triggers.' .

ind:PhysicalInventoryCount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Physical Inventory Count' ;
    rdfs:comment 'Record of a physical inventory count event (cycle count, annual wall-to-wall count, or triggered count) for a specific material at a specific storage location or bin. Captures count document number, count date, counter identity, book quantity at time of count, counted quantity, variance quantity, variance percentage, recount flag, count method (blind vs. informed), posting status, and approval chain for variance write-off. Supports regulatory and SOX-compliant inventory reconciliation and feeds inventory_adjustment records for variance postings. Integrates with SAP MM physical inventory module.' .

ind:HazmatStorageRule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Hazmat Storage Rule' ;
    rdfs:comment 'Reference record defining hazardous material storage compatibility and segregation rules per GHS, NFPA, and UN hazard classification systems. Captures hazard class, sub-risk, NFPA fire diamond rating, incompatible hazard class pairs (segregation matrix), required storage conditions (temperature range, ventilation class, secondary containment type), maximum storage quantity per fire zone, EPA/OSHA regulatory citation, and applicable SDS section references. Governs automated putaway validation ensuring incompatible chemicals are never co-located in the same storage zone.' .

ind:StorageBin rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Storage Bin' ;
    rdfs:comment 'Master record for individual storage bins within a warehouse location, representing the smallest addressable unit of storage in SAP EWM. Captures bin code, warehouse number, storage type, storage section, bin capacity (weight and volume), bin type (fixed, random, bulk, tank), current occupancy status, maximum weight, and allowed material types. Enables precise bin-level inventory tracking and directed putaway/picking strategies.' .

ind:StockReservation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Stock Reservation' ;
    rdfs:comment 'Record of a stock reservation that earmarks a specific quantity of a material and lot for a future planned consumption event such as a production order, customer delivery, or maintenance work order. Captures reservation number, material, lot, reserved quantity, unit of measure, requirement date, consuming order or delivery reference, reservation status (open, partially fulfilled, fulfilled, cancelled), and expiry date. Prevents double-allocation of limited or expiring chemical stock.' .

ind:TankFarmLevel rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Tank Farm Level' ;
    rdfs:comment 'Real-time and historical level measurement records for bulk liquid chemical storage tanks in tank farms. Captures tank identifier, material stored, measurement timestamp, level in meters, volume in liters or cubic meters, mass in kg, temperature at measurement, density, ullage (available headspace), high-level alarm status, low-level alarm status, and data source (Aveva PI System historian tag). Supports continuous inventory tracking for bulk chemicals without discrete lot tracking.' .

ind:InventoryAdjustment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Inventory Adjustment' ;
    rdfs:comment 'Record of inventory adjustments made to correct stock quantities outside of normal goods movement transactions, including write-offs, write-ups, count variance postings, and damage adjustments. Captures adjustment document number, material, lot, location, adjustment quantity (positive or negative), adjustment reason code, approver, approval date, financial impact value, and SAP MM material document reference. Requires dual authorization for adjustments above threshold values per SOX controls.' .

ind:ConsignmentStock rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Consignment Stock' ;
    rdfs:comment 'Record tracking vendor-owned consignment stock held at the chemical manufacturer\'s premises but not yet financially owned. Captures consignment agreement reference, vendor, material, lot, quantity on consignment, storage location, receipt date, agreed consumption trigger, valuation price, liability transfer date, and aging days. Enables accurate financial reporting by distinguishing owned stock from consignment stock in SAP MM special stock management. Supports vendor-managed inventory (VMI) arrangements common in chemical feedstock supply.' .

ind:InterplantTransfer rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Interplant Transfer' ;
    rdfs:comment 'Inter-plant or inter-warehouse stock transfer order record for moving materials between different plant locations, distribution centers, or external warehouses. Captures transfer order number, sending plant, receiving plant, material, lot, transfer quantity, unit of measure, requested delivery date, transport mode, carrier reference, in-transit quantity, and transfer status (created, in-transit, received, confirmed). Distinct from intra-warehouse transfer orders managed in SAP EWM.' .

ind:Account rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Account' ;
    rdfs:comment 'Core B2B customer account master record representing industrial customers, distributors, and end-user organizations. Stores the authoritative identity of each customer entity including legal business name, DUNS number, tax ID, SIC/NAICS industry classification, account tier, account status, primary business type (direct industrial, distributor, toll processor, OEM), annual revenue band, employee count, parent account reference for corporate hierarchy, Salesforce CRM account ID, SAP customer number, credit rating, account manager assignment, onboarding date, and shipping/delivery preferences at the account level. This is the SSOT for all customer identity in the chemical-manufacturing enterprise.' .

ind:Contact rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Contact' ;
    rdfs:comment 'Individual contact persons associated with a customer account, including procurement managers, plant engineers, quality managers, EHS coordinators, and technical buyers. Captures full name, job title, department, direct phone, mobile, email, preferred communication channel, contact role (technical, commercial, EHS, logistics), LinkedIn profile, language preference, do-not-contact flag, and Salesforce CRM contact ID. Supports technical sales and customer service workflows.' .

ind:Site rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Site' ;
    rdfs:comment 'Physical customer site or plant location where chemical products are delivered, consumed, or processed. Captures site name, site type (manufacturing plant, distribution center, R&D lab, warehouse), street address, city, state, country, GPS coordinates, UN/LOCODE, site capacity, operating hours, dock restrictions, hazmat receiving capability, tank farm availability, bulk vs. packaged receipt capability, preferred carrier, shipping mode (LTL, FTL, bulk tanker, rail), packaging preference, delivery window constraints, unloading equipment availability, temperature-controlled requirements, site EHS contact, and site-level regulatory permits. Distinct from the account (corporate entity) — one account may have many sites.' .

ind:AccountHierarchy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Account Hierarchy' ;
    rdfs:comment 'Corporate hierarchy relationships between customer accounts, capturing parent-child relationships for multinational chemical buyers, conglomerates, and distributor networks. Stores parent account, child account, hierarchy level (global ultimate, domestic ultimate, subsidiary, division, plant), effective date, end date, hierarchy type (ownership, commercial, billing), and consolidation flag. Enables enterprise-level revenue rollup, credit exposure aggregation, and global account management for large industrial customers.' .

ind:Segment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Segment' ;
    rdfs:comment 'Market segmentation classification for customer accounts used in commercial strategy, pricing, and technical service allocation. Captures segment code, segment name (e.g., Automotive OEM, Agrochemical Distributor, Specialty Coatings, Pharma Excipient, Electronics), segment tier, industry vertical (NAICS-based), strategic account flag, growth potential rating, wallet share estimate, segment owner, and applicable product portfolio. Drives targeted marketing, pricing tiers, and technical service prioritization.' .

ind:CreditProfile rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Credit Profile' ;
    rdfs:comment 'Customer credit standing and financial risk profile managed by the credit department. Stores credit limit (in base currency), credit exposure, payment terms code (Net 30, Net 60, COD, Prepay), credit rating (internal and external Dun & Bradstreet), credit hold flag, credit hold reason, credit review date, next review date, credit analyst, credit insurance policy reference, days sales outstanding (DSO) target, and credit block status in SAP SD. Critical for order-to-cash risk management in chemical distribution.' .

ind:RegulatoryProfile rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Regulatory Profile' ;
    rdfs:comment 'Customer regulatory and compliance profile capturing jurisdiction-specific requirements that govern how chemical products are sold, labeled, and documented for that customer. Stores applicable regulatory frameworks (REACH, TSCA, GHS, RoHS, PROP65), required documentation (SDS version, COA, COC, MSDS language), country of destination, import/export license numbers, end-use declaration, restricted substance list acknowledgment, customer EHS certification status, and audit rights agreement. Ensures regulatory compliance in chemical sales.' .

ind:Qualification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Qualification' ;
    rdfs:comment 'Customer-approved chemical products and grades that have been qualified for use at a specific customer site or application. Captures customer account, site, approved SKU/product code, grade, application use case, qualification date, qualification method (lab trial, plant trial, third-party cert), approval status, expiry date, approved volume range, and any customer-specific specification deviations. Critical in automotive, pharma, and electronics chemical supply where customer qualification is mandatory before commercial supply.' .

ind:Interaction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Interaction' ;
    rdfs:comment 'Log of all customer-facing interactions and touchpoints including sales calls, technical visits, complaint calls, email exchanges, webinar attendance, trade show meetings, and portal logins. Captures interaction type, channel (phone, email, in-person, video, portal), date and time, duration, participants (internal and customer contacts), subject, outcome, follow-up actions, and linked opportunity or case. Sourced from Salesforce CRM activity records. Supports customer relationship management and account planning.' .

ind:Case rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Case' ;
    rdfs:comment 'Customer service cases and support tickets covering the full spectrum of customer issues: technical assistance requests, order discrepancies, documentation requests (SDS, COA, COC), regulatory inquiries, and quality/OOS product complaints. This is the single source of truth for all customer-initiated issues and complaints. Captures case number, case type (technical support, order issue, SDS request, COA request, regulatory inquiry, quality complaint), priority, severity, status (open, in progress, resolved, closed), assigned service rep, SLA due date, resolution description, customer satisfaction rating. For quality complaints: product involved, lot number, batch reference, COA reference, complaint description, root cause investigation (RCI) status, CAPA reference, severity classification, credit note issued flag, and customer satisfaction outcome. Integrates with LabWare LIMS for OOS investigation, SAP QM for CAPA tracking, and Salesforce CRM Case object as system of record. Supports 8D problem-solving workflow for quality complaints.' .

ind:Equipment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Maintenance ;
    rdfs:label 'Equipment' ;
    rdfs:comment 'Equipment master data registry for all maintainable plant assets including reactors, vessels, pumps, compressors, heat exchangers, instrumentation, and piping systems. SSOT for equipment identity, technical specifications (design pressure/temperature, materials of construction, nameplate data), installation history, criticality classification (A/B/C), PSM mechanical integrity status, and regulatory inspection requirements. Supports equipment taxonomy, BOM structure, P&ID tag cross-reference, and full maintenance history linkage.' .

ind:FunctionalLocation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Maintenance ;
    rdfs:label 'Functional Location' ;
    rdfs:comment 'Hierarchical functional location structure representing the physical and logical plant topology — plant, unit, area, system, and sub-system levels. Provides the spatial context for equipment installation and maintenance activities. Aligns with SAP PM Functional Location (IFLOT) and supports P&ID-based asset hierarchy for chemical process units.' .

ind:WorkOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Maintenance ;
    rdfs:label 'Work Order' ;
    rdfs:comment 'Core maintenance work order record capturing all planned, corrective, preventive, predictive, and externally-contracted maintenance activities. Tracks work order type, priority, functional location, equipment, planner group, work center, scheduled/actual dates, labor hours, material consumption summary, internal/external cost totals, permit-to-work reference, and completion status. Supports both internal craft execution and external service provider work. Primary transactional entity for maintenance execution, cost tracking, and PM compliance.' .

ind:WorkOrderOperation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Maintenance ;
    rdfs:label 'Work Order Operation' ;
    rdfs:comment 'Individual operation (task step) within a maintenance work order, representing discrete work activities assigned to specific work centers and crafts. Captures operation number, description, work center, control key, planned and actual labor hours, setup time, execution factor, and confirmation status. Aligns with SAP PM Order Operation (AFVC) and supports detailed labor planning and execution tracking.' .

ind:Notification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Maintenance ;
    rdfs:label 'Notification' ;
    rdfs:comment 'Maintenance notification record capturing all unplanned maintenance demand including equipment defects, malfunctions, breakdowns, activity requests, and condition-based alerts raised by operators, inspectors, or automated monitoring systems. Tracks notification type (M1 malfunction/breakdown, M2 activity request, M3 inspection finding), breakdown indicator with start/end timestamps and duration, reported damage/cause/activity codes (via catalog_code reference), failure mode classification, production impact and loss quantity, safety implications, time to restore, and notification-to-work-order linkage. Serves as the SSOT for all failure events including full breakdowns — consolidating failure recording into a single entry point. Supports MTBF/MTTR calculation, reliability-centered maintenance (RCM) analysis, RCI/RCA investigations, CAPA workflows, PSM incident reporting, and Pareto analysis of failure modes.' .

ind:PmPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Maintenance ;
    rdfs:label 'Pm Plan' ;
    rdfs:comment 'Preventive maintenance plan master record defining the scheduling strategy, cycle packages, and parameters for time-based, counter-based, or condition-based PM activities on equipment or functional locations. Captures plan type (single cycle, strategy, multiple counter), strategy cycles and packages (e.g., 3M/6M/12M/5Y), scheduling indicator, call horizon, tolerance window, task list references for work content definition, cycle set definitions, and seasonal scheduling adjustments. Governs automated generation of schedule calls and resulting work orders. References task_list for standardized work procedures. Supports PSM mechanical integrity inspection programs, API/ASME code-required inspection intervals (API 510, 570, 653), RBI risk-based inspection optimization, and insurance carrier PM requirements.' .

ind:ScheduleCall rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Maintenance ;
    rdfs:label 'Schedule Call' ;
    rdfs:comment 'Individual scheduled maintenance call item generated from a preventive maintenance plan, representing a specific due date and call object for a PM activity. Tracks call date, planned date, completion date, call status, counter reading at call, and the resulting work order reference. Aligns with SAP PM Maintenance Schedule (MPOS) and enables PM compliance tracking and overdue analysis.' .

ind:MeasurementPoint rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Maintenance ;
    rdfs:label 'Measurement Point' ;
    rdfs:comment 'Measurement point master record defining a specific location on equipment where counter readings or measurement values are recorded (e.g., vibration, temperature, pressure, operating hours). Captures measurement point category, characteristic, unit of measure, target value, upper/lower limits, and counter overflow value. Aligns with SAP PM Measurement Point (MPLA/IMRG) and supports condition-based maintenance and OEE tracking.' .

ind:MeasurementReading rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Maintenance ;
    rdfs:label 'Measurement Reading' ;
    rdfs:comment 'Individual measurement document recording an actual counter or measurement value captured at a measurement point on equipment. Tracks reading date and time, measured value, unit, reading type (actual, estimated), reader identification, and deviation from target. Aligns with SAP PM Measurement Document (IMRG) and supports condition monitoring, predictive maintenance triggers, and Aveva PI System integration.' .

ind:CalibrationRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Maintenance ;
    rdfs:label 'Calibration Record' ;
    rdfs:comment 'Calibration record for instrumentation and measurement devices (transmitters, analyzers, gauges, safety valves) documenting as-found and as-left conditions, calibration procedure, tolerance limits, pass/fail status, calibration interval, and next due date. Supports PSM mechanical integrity requirements, ISO 9001 instrument calibration compliance, and LIMS integration for laboratory instrument calibration.' .

ind:BreakdownEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Maintenance ;
    rdfs:label 'Breakdown Event' ;
    rdfs:comment 'Unplanned equipment breakdown or failure event record capturing the onset of failure, failure mode, failure cause, affected production unit, production loss quantity, safety implications, and time to restore. Tracks breakdown start and end timestamps, breakdown duration, malfunction start indicator, and linkage to corrective work order and PM notification. Supports MTBF/MTTR calculation, RCI investigations, and PSM incident reporting.' .

ind:PermitToWork rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Maintenance ;
    rdfs:label 'Permit To Work' ;
    rdfs:comment 'Permit to Work (PTW) record authorizing maintenance and construction activities in hazardous areas of a chemical plant. Captures permit type (hot work, confined space entry, electrical isolation, line breaking, excavation), issuing authority, work description, hazard identification, isolation requirements, PPE requirements, gas test results, validity period, and closure confirmation. Supports OSHA PSM, EHS compliance, and safe work practices.' .

ind:Vendor rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Vendor' ;
    rdfs:comment 'Master record for all chemical suppliers and raw material vendors including multi-site physical locations. Captures vendor identity, classification, SAP vendor number, DUNS number, tax identifiers, payment terms, currency, preferred incoterms, vendor tier (strategic/preferred/approved/conditional), Responsible Care certification status, REACH compliance flag, and onboarding status. Includes site-level detail: physical plant addresses, site types (manufacturing plant, distribution center, port of export), geographic regions, country of origin, UN/LOCODE, hazmat handling capabilities, ISO 9001/14001 certifications at site level, and site-level contacts. Single source of truth for supplier identity, locations, and site capabilities within the supply domain.' .

ind:VendorSite rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Vendor Site' ;
    rdfs:comment 'Physical plant, warehouse, or shipping location associated with a vendor. Tracks site address, site type (manufacturing plant, distribution center, port of export), geographic region, country of origin, UN/LOCODE, hazmat handling capability, ISO 9001/14001 certification at site level, and site-level contact information. Supports multi-site vendor relationships common in chemical raw material sourcing.' .

ind:PurchaseOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Purchase Order' ;
    rdfs:comment 'Core procurement transaction representing a legally binding PO issued to a chemical supplier for raw materials, intermediates, packaging, or services. Captures PO number, PO type (standard, blanket release, consignment, subcontracting), vendor, plant, purchasing organization, purchasing group, document date, delivery date, incoterms, payment terms, currency, total net value, approval status, and SAP document number. Integrates with SAP MM ME21N/ME22N.' .

ind:PoLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Po Line' ;
    rdfs:comment 'Individual line items within a purchase order, each representing a specific raw material or chemical substance being procured. Captures line number, material number, CAS number, material description, ordered quantity, unit of measure, net price, price unit, delivery date, storage location, batch management flag, hazmat classification, GHS hazard category, and line-level delivery status. Integrates with SAP MM EKPO table.' .

ind:GoodsReceipt rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Goods Receipt' ;
    rdfs:comment 'Records the physical receipt of raw materials and chemicals at the plant gate or warehouse dock against a purchase order. Captures GR document number, GR date, vendor, material, received quantity, unit of measure, storage location, batch number (LOT), movement type, quality inspection flag, COA received flag, temperature on arrival, and SAP material document number. Triggers QC inspection workflow in LIMS. Integrates with SAP MM MIGO/MSEG.' .

ind:Asn rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Asn' ;
    rdfs:comment 'Advanced Shipping Notice received from chemical suppliers prior to physical delivery, with full line-level material detail. Captures ASN number, vendor, PO reference, expected delivery date/time, carrier, bill of lading, container/trailer ID, hazmat placard codes, UN numbers. Line-level detail includes: material, CAS number, shipped quantity, unit of measure, batch/lot number, expiry date, country of origin, REACH registration number, SDS version reference, packaging type (drum, IBC, tanker, bag), and net/gross weight per line. Enables pre-receipt planning and line-level receiving reconciliation against PO lines. Integrates with Oracle TMS and SAP MM inbound delivery.' .

ind:Contract rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Contract' ;
    rdfs:comment 'Long-term supply agreements, blanket purchase agreements, and scheduling agreements with chemical raw material suppliers. Captures contract number, type (quantity contract, value contract, scheduling agreement), vendor, material, validity period, total value, volume commitment, MOQ, delivery frequency, quality specifications, force majeure terms, and contract status. Includes all contracted pricing conditions (price scales, surcharges, discounts, escalation clauses, condition types, price determination sequences), and scheduling agreement delivery schedule lines (planned delivery dates, quantities, cumulative receipts, forecast vs. firm categories). Single source of truth for all long-term vendor commercial arrangements, their pricing, and delivery schedules. Integrates with SAP MM ME31K, condition records (KONP/KONH), and scheduling agreement transactions.' .

ind:ContractPrice rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Contract Price' ;
    rdfs:comment 'Contracted pricing conditions and price scales negotiated with chemical suppliers under supply contracts or info records. Captures condition type, material, vendor, plant, validity period, base price, price unit, currency, quantity scale breaks, surcharges (freight, hazmat handling), discounts, and price determination sequence. Supports accurate PO pricing and cost variance analysis. Integrates with SAP MM condition records (KONP/KONH).' .

ind:VendorQualification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Vendor Qualification' ;
    rdfs:comment 'Comprehensive supplier qualification, audit, and compliance documentation lifecycle for chemical vendors. Covers formal qualification assessments (initial, periodic, for-cause), on-site and remote audit records (quality, EHS, PSM, GMP) with findings by severity and audit ratings, and the full repository of compliance documents (SDS, COA, COC, REACH dossiers, TSCA certifications, ISO/GMP certificates, Responsible Care attestations). Captures qualification status, audit scores, document versions and expiry dates, CAPA requirements from audits, lead auditor assignments, and document validity. Single source of truth for \'is this vendor approved, what audits have been conducted, and what evidence supports that decision.\' Prerequisite for issuing POs to new suppliers.' .

ind:VendorAudit rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Vendor Audit' ;
    rdfs:comment 'On-site and remote audit records conducted at chemical supplier facilities to assess quality systems, EHS compliance, process safety, and regulatory adherence. Captures audit number, vendor, audit type (quality, EHS, PSM, GMP, combined), audit date, lead auditor, audit scope, findings count by severity (critical, major, minor), overall audit rating, CAPA required flag, follow-up due date, and audit closure status. Supports Responsible Care program requirements.' .

ind:PurchaseRequisition rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Purchase Requisition' ;
    rdfs:comment 'Internal procurement request records and forward-looking procurement planning covering the full demand-to-sourcing lifecycle. Captures requisition number, type, requesting plant/cost center, material/CAS number, required quantity, delivery date, preferred vendor, estimated price, approval status, and PO conversion status. Also encompasses MRP-generated planned procurement schedules: planning horizons (weekly/monthly/quarterly), planned quantities and dates, source of supply assignments, procurement types, lead time buffers for hazmat transport, planner assignments, safety stock triggers, and campaign production schedule alignment. Integrates with SAP MM ME51N/ME52N and MRP outputs (MD04/MD07).' .

ind:SourceList rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Source List' ;
    rdfs:comment 'Approved source list defining which vendors are authorized to supply specific raw materials or chemicals to specific plants during defined validity periods. Captures material, plant, vendor, purchasing organization, validity start and end dates, fixed source flag, MRP relevance, agreement reference (contract or scheduling agreement), and source list status. Enforces approved vendor list (AVL) compliance and drives automatic source determination in SAP MM.' .

ind:InboundDelivery rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Inbound Delivery' ;
    rdfs:comment 'Inbound logistics delivery record tracking the physical movement of raw materials and chemicals from vendor to plant, coordinated with Oracle Transportation Management. Captures delivery number, vendor, carrier, origin location, destination plant and storage location, scheduled arrival date/time, actual arrival date/time, transport mode (road tanker, rail, sea container, pipeline), hazmat transport document number (DOT), temperature-controlled flag, seal number, and delivery status. Links ASN to goods receipt.' .

ind:InvoiceVerification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Invoice Verification' ;
    rdfs:comment 'Three-way match verification records reconciling vendor invoices against purchase orders and goods receipts for chemical raw material purchases. Captures verification document number, vendor invoice number and date, PO and GR references, invoiced amount, tax amount, currency, price variance (common with index-linked chemical pricing), quantity variance (typical with bulk liquid deliveries measured by weight), blocking reasons (price tolerance exceeded, quantity short, quality hold pending COA review), payment release status, and posting status. Critical for chemical procurement where pricing often includes freight surcharges, hazmat handling fees, and index-based escalators. Integrates with SAP MM MIRO and FI accounts payable.' .

ind:MaterialInfoRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Material Info Record' ;
    rdfs:comment 'Purchasing master data establishing approved sourcing parameters and default procurement conditions for specific material-vendor-plant combinations. Captures info record number, material, vendor, plant, purchasing organization, standard price, planned delivery time, MOQ/max order quantity, delivery tolerances, last PO price, and source status. Also serves as the approved source list (AVL): defines which vendors are authorized to supply specific materials to specific plants during defined validity periods, with fixed source flags, MRP relevance indicators, and agreement references. Single source of truth for which vendors can supply which materials to which plants under what conditions. Drives automatic source determination and default PO values. Integrates with SAP MM ME11/ME12 and source list functionality.' .

ind:ManufacturingOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Manufacturing Order' ;
    rdfs:comment 'Core execution entity authorizing and tracking the manufacture of a chemical product or intermediate, serving as the single ISA-95 Level 3 production order and ISA-88 batch control entity. Captures order number, order type (batch/continuous/semi-continuous), master recipe reference (PI sheet), process order type, planned and actual quantities, unit of measure, scheduled and actual start/finish dates, order status lifecycle (created, released, started, confirmed, technically complete, closed), priority, plant, work center assignment, BOM reference, routing/recipe reference, production version, MES integration ID, DCS control recipe destination, phase sequence, settlement rule, cost estimate vs actual cost, yield target, and variance analysis flags. The single source of truth for \'what are we making, when, and how much\' — the central entity that batch records, BOM consumption, yield records, deviations, and campaigns all reference.' .

ind:BatchRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Batch Record' ;
    rdfs:comment 'Electronic Batch Record (EBR) and complete MES execution audit trail serving as the authoritative manufacturing history for a single production batch (21 CFR Part 11 compliant). Captures batch number (LOT), batch size, batch status (in-process, released, rejected, quarantine), manufacturing date, expiry/retest dates, manufacturing order reference, formula/recipe version, and the full step-by-step execution log: MES transaction IDs, recipe phases executed, execution start/end timestamps per step, operator IDs, equipment IDs, actual parameter values entered, electronic signatures (21 CFR Part 11), instruction text displayed, operator responses/confirmations, exception flags, deviation count, review/approval signatures, GMP compliance flag, COA linkage, regulatory hold flags, and MES system version. The single authoritative document for batch genealogy tracing, regulatory audits, GMP batch release, electronic records compliance, and production floor execution verification.' .

ind:ProcessOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Process Order' ;
    rdfs:comment 'SAP PP Process Order entity representing a discrete manufacturing execution instruction for a chemical synthesis or blending run. Distinct from production_order in that it is specifically tied to a master recipe (PI sheet) and process industry workflow. Captures process order number, recipe reference, process order type, plant, production version, scheduled quantities, actual confirmed quantities, phase sequence, control recipe destination (DCS/PLC system ID), MES integration status, settlement rule, and variance analysis flags. Used for batch and continuous chemical process manufacturing.' .

ind:BatchGenealogy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Batch Genealogy' ;
    rdfs:comment 'Tracks the parent-child lineage of chemical batches through multi-stage synthesis and blending operations. Records upstream raw material lot numbers, intermediate batch numbers, and downstream finished goods batch numbers involved in a production run. Captures relationship type (consumed, produced, split, merged), quantity transferred, transfer date, process step, and traceability chain depth. Enables full forward and backward lot traceability required by FDA, REACH, and customer COA requests. Links raw material batches through intermediates to finished product batches.' .

ind:ProcessParameter rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Process Parameter' ;
    rdfs:comment 'Time-series record of critical process parameters (CPPs) measured or set during a chemical manufacturing operation. Captures parameter name (temperature, pressure, pH, flow rate, agitation speed, dissolved oxygen, viscosity, concentration), tag ID from DCS/SCADA (Honeywell Experion or Siemens PCS 7), measured value, engineering unit, set point value, upper control limit (UCL), lower control limit (LCL), upper specification limit (USL), lower specification limit (LSL), timestamp, measurement source (DCS, PLC, manual entry), operator ID, and SPC violation flag. Sourced from Aveva PI System historian integration.' .

ind:ReactionStep rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Reaction Step' ;
    rdfs:comment 'Defines individual reaction or process steps within a chemical synthesis sequence or master recipe. Captures step number, step name, step type (charge, heat, react, cool, filter, distill, blend, transfer, clean), target duration, actual duration, sequence order, phase assignment, critical step flag, SOP reference, control recipe phase ID, required equipment type, and step completion status. Supports multi-step synthesis workflows and provides the operational backbone for process order execution and MES phase tracking.' .

ind:BomConsumption rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Bom Consumption' ;
    rdfs:comment 'Transactional record of actual raw material and intermediate component consumption against a production or process order BOM. Captures material number, component description, BOM line item, planned quantity, actual quantity consumed, unit of measure, lot number consumed, storage location, goods movement type (SAP MM 261/262), posting date, backflush flag, variance quantity, variance percentage, and cost impact. Enables yield analysis, material balance reconciliation, and COGS calculation per batch. Sourced from SAP PP goods movement postings.' .

ind:YieldRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Yield Record' ;
    rdfs:comment 'Captures actual production yield data for each batch or production run, comparing theoretical yield to actual output. Records planned yield quantity, actual yield quantity, yield percentage, theoretical yield basis, yield loss quantity, loss reason code (evaporation, sampling, spillage, reaction inefficiency, filtration loss), unit of measure, by-product quantities, waste quantities, and yield variance flag. Supports process optimization, SPC trending, OEE calculation, and raw material efficiency reporting. Critical for cost accounting and process improvement initiatives.' .

ind:Schedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Schedule' ;
    rdfs:comment 'Master production schedule (MPS) record defining planned production runs across work centers and production lines for a planning horizon. Captures schedule ID, planning period, work center, product/material number, planned quantity, scheduled start datetime, scheduled end datetime, schedule status (planned, firmed, released, completed), capacity requirement, priority rank, campaign flag (for multi-batch campaigns), changeover time, and scheduling constraint notes. Integrates with SAP PP capacity planning and MES scheduling modules.' .

ind:WorkCenter rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Work Center' ;
    rdfs:comment 'Master data for production work centers, reactors, vessels, blending units, and processing lines within the chemical plant. Captures work center ID, work center name, work center type (reactor, blender, distillation column, filtration unit, packaging line), plant, cost center reference, capacity category, available capacity (hours/day), efficiency factor, utilization rate, OEE target, DCS system ID (Honeywell Experion or Siemens PCS 7 node), equipment list, and operational status. SSOT for production capacity and equipment assignment within the production domain.' .

ind:ProductionDeviation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Production Deviation' ;
    rdfs:comment 'Records deviations, non-conformances, OOS events, and production holds that occur during manufacturing. Captures deviation type, severity, affected batch, hold status, root cause, and resolution actions.' .

ind:ProcessChangeRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Process Change Record' ;
    rdfs:comment 'Management of Change (MOC) record tracking approved changes to production processes, equipment configurations, raw material substitutions, or operating procedures. Captures MOC number, change type (process, equipment, material, procedure, facility), change description, initiator, affected process/equipment, risk assessment summary, PHA/HAZOP reference, approval workflow status, implementation date, post-implementation review date, training requirements, and regulatory notification flag. Required for PSM compliance (OSHA 29 CFR 1910.119) and process safety management.' .

ind:Campaign rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Campaign' ;
    rdfs:comment 'Manages multi-batch production campaigns where the same product or product family is manufactured in consecutive runs to maximize equipment utilization and minimize changeover. Captures campaign ID, campaign name, product family, campaign type (dedicated, shared), planned batch count, actual batch count, campaign start date, campaign end date, work center assignment, total planned quantity, total actual quantity, campaign yield, CIP (Clean-In-Place) schedule between batches, and campaign status. Supports campaign planning, scheduling optimization, and OEE reporting.' .

ind:CipRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Cip Record' ;
    rdfs:comment 'Clean-In-Place (CIP) execution record documenting the cleaning and sanitization of reactors, vessels, pipelines, and processing equipment between production runs. Captures CIP record ID, equipment ID, CIP procedure reference, cleaning agent used, cleaning agent concentration (PPM), rinse water conductivity, temperature profile, duration, flow rate, operator ID, pass/fail result, next production clearance flag, and regulatory compliance status. Critical for preventing cross-contamination between chemical products and maintaining GMP/food-contact compliance.' .

ind:ChemicalProduct rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Chemical Product' ;
    rdfs:comment 'Core master record for every finished chemical product, performance material, plastic, agricultural solution, or specialty chemical offered to customers. Captures authoritative product identity: product name, trade name, chemical name, CAS number, product family, product line, business unit, product type (bulk, packaged, specialty), physical form (liquid, solid, powder, gas), product lifecycle state (active, discontinued, developmental, phased_out), introduction date, discontinuation date, internal product code, storage temperature range, shelf life, and hazmat transport classification (UN number, hazard class, packing group). This is the SSOT for all product identity in the enterprise — SAP S/4HANA Material Master (MM) is the system of record.' .

ind:Sku rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Sku' ;
    rdfs:comment 'Stock Keeping Unit record representing a specific orderable and shippable configuration of a chemical product. Each SKU maps to a unique combination of product, grade, packaging type, pack size, and unit of measure. Captures SKU code, description, net weight, gross weight, unit of measure (kg, L, MT, drum, IBC, bag), packaging type, hazard class, UN number, shelf life (days), storage temperature range, minimum order quantity (MOQ), and SKU status. Links to the parent chemical_product and to packaging_config. SAP SD material variant is the system of record.' .

ind:Grade rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Grade' ;
    rdfs:comment 'Defines the quality grades and purity tiers available for a chemical product (e.g., Technical Grade, Reagent Grade, Food Grade, Pharmaceutical Grade, Electronic Grade, Agricultural Grade). Captures grade code, grade name, grade description, minimum purity percentage, applicable regulatory standards (GMP, USP, EP, FCC), intended application sector, and grade-specific handling requirements. A single chemical product may have multiple grades, each with distinct specifications and pricing. Owned by the product domain as part of the product catalog.' .

ind:ProductSpecification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Product Specification' ;
    rdfs:comment 'Authoritative technical specification record for a chemical product, grade, or SKU, defining the quality parameters and acceptance criteria used in COA/COC generation and QC release. Captures specification version, effective date, expiry date, specification type (release, in-process, shelf-life, stability), parameter name (assay, pH, viscosity, moisture, color, density, particle size, heavy metals, residual solvents), test method reference (ASTM, ISO, USP, internal), minimum value, maximum value, target value, unit of measure, specification status, and approval authority. Versioned to support lifecycle changes and regulatory audit trail. Links to LabWare LIMS for test execution and to quality domain for COA generation.' .

ind:Tds rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Tds' ;
    rdfs:comment 'Technical Data Sheet (TDS) document record for a chemical product, capturing the authoritative technical and application information published to customers and distributors. Stores TDS document number, version, effective date, language, product applications, physical and chemical properties summary, handling and storage guidance, recommended use concentrations, compatibility notes, performance data references, and document URL/path. Versioned and linked to the parent chemical_product. Supports customer technical sales and regulatory submissions.' .

ind:Sds rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Sds' ;
    rdfs:comment 'Safety Data Sheet (SDS/MSDS) master record for a chemical product, compliant with GHS/OSHA HazCom 2012 and REACH Article 31. Captures SDS document number, revision number, revision date, GHS hazard classification, signal word (Danger/Warning), hazard statements (H-codes), precautionary statements (P-codes), pictogram codes, first aid measures, firefighting measures, accidental release measures, handling and storage requirements, exposure controls/PPE, physical and chemical properties, toxicological information, ecological information, disposal considerations, transport information (DOT, IATA, IMDG), regulatory information (TSCA, REACH, SARA 313), and SDS language/country. System of record: Intelex EHS Management.' .

ind:ProductGhsClassification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Product Ghs Classification' ;
    rdfs:comment 'GHS (Globally Harmonized System) hazard classification record for a chemical product, capturing the official classification outcome per GHS/CLP regulation. Stores classification version, classification date, classifying authority (self-classification, ECHA harmonized), physical hazard classes and categories (flammable liquid Cat 2, explosive, oxidizer), health hazard classes (acute toxicity, skin corrosion, CMR categories), environmental hazard classes (aquatic toxicity), hazard statement codes, precautionary statement codes, signal word, pictogram list, and classification basis (test data, read-across, QSAR). Supports REACH, CLP, and GHS label generation. Linked to Intelex EHS.' .

ind:RegulatoryStatus rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Regulatory Status' ;
    rdfs:comment 'Regulatory compliance status record for a chemical product across applicable regulatory frameworks and jurisdictions. Captures regulation type (REACH, TSCA, SARA 313, California Prop 65, RoHS, SVHC, PFAS), jurisdiction (EU, US, China, Japan, Korea, Canada), registration or notification number, registration date, registration expiry, tonnage band (for REACH), substance role (manufacturer, importer, only representative), compliance status (registered, notified, exempt, restricted, prohibited), restriction conditions, and last review date. Enables regulatory reporting to EPA, ECHA, and ACC Responsible Care. System of record: Intelex EHS Management.' .

ind:Hierarchy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Hierarchy' ;
    rdfs:comment 'Multi-level product classification hierarchy for commercial reporting, portfolio management, and SAP material grouping. Captures hierarchy node code, node name, hierarchy level (division > business unit > product family > product line > product group), parent node reference, hierarchy type (commercial, technical, regulatory), effective date, and node status. Supports EBITDA reporting by product line, sales analytics by business unit, regulatory grouping for TSCA/REACH submissions, and product application categorization. Managed in SAP S/4HANA product hierarchy configuration.' .

ind:PackagingConfig rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Packaging Config' ;
    rdfs:comment 'Packaging configuration master defining all approved packaging formats for chemical product SKUs. Captures packaging type (drum, IBC, bulk tanker, bag, cylinder, pail, tote, flexitank, isotank), material of construction (HDPE, steel, stainless steel, fiber, aluminum, lined), nominal capacity, fill weight, fill volume, tare weight, closure type, UN packaging certification code (4G, 1A1, 1H1, 31HA1), packaging group (I, II, III), label requirements (GHS, DOT, IATA), pallet configuration (units per pallet, pallet type, stack height), and packaging status. Supports DOT/IATA/IMDG hazmat packaging compliance, warehouse slotting in SAP EWM, and customer order fulfillment.' .

ind:Composition rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Composition' ;
    rdfs:comment 'Chemical composition disclosure record for a product, capturing the ingredient-level breakdown required for SDS Section 3 (Composition/Information on Ingredients) and REACH substance identification. Stores component CAS number, IUPAC name, trade name, EC number, concentration (exact or range), concentration unit, function in mixture (active ingredient, solvent, stabilizer, surfactant, filler), classification of component, disclosure threshold (OSHA, REACH, SARA 313), and confidentiality flag (CBI — Confidential Business Information). Supports SDS authoring, REACH mixture notification, and TSCA reporting.' .

ind:ReachDossier rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Reach Dossier' ;
    rdfs:comment 'REACH registration dossier record — the single source of truth (SSOT) for substance registration under EU REACH Regulation (EC) No 1907/2006, including the full Chemical Safety Report (CSR) and all exposure scenarios. Captures REACH registration number, substance identity (IUPAC name, CAS, EC number), registrant role (lead registrant, member), SIEF membership, tonnage band, registration date, dossier update date, ECHA submission reference, CSR requirement flag, and dossier status. Contains all exposure scenarios as child records: scenario title, use descriptor codes (SU, PC, PROC, AC, ERC), contributing scenario name, operational conditions (temperature, duration, frequency, amount used), risk management measures (PPE, ventilation, containment), DNEL values, PNEC values, risk characterization ratios (RCR), and scenario validity dates. Supports extended SDS (eSDS) generation for downstream users. Managed in Intelex EHS and submitted to ECHA REACH-IT. This entity is the sole owner of exposure scenario data — there is no separate exposure scenario entity.' .

ind:MaterialMaster rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Rawmaterial ;
    rdfs:label 'Material Master' ;
    rdfs:comment 'Single source of truth for all raw material master records in the chemical manufacturing enterprise. Captures the full identity of each raw material, chemical feedstock, intermediate, or input substance including CAS number reference, IUPAC name, common trade name, molecular formula, molecular weight, physical state at STP, material class (feedstock, intermediate, solvent, catalyst, additive, excipient), SAP material number, material group, unit of measure, shelf life, storage temperature range, humidity requirements, light sensitivity, retest interval, material lifecycle status (new, active, phase-out, obsolete), material category classification, and incompatibility flags. Serves as the authoritative registry for all raw material identities referenced by procurement, production planning, formulation, quality, and EHS domains. Each material has exactly one material_master record regardless of how many suppliers provide it.' .

ind:CasRegistry rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Rawmaterial ;
    rdfs:label 'Cas Registry' ;
    rdfs:comment 'Authoritative CAS (Chemical Abstracts Service) number registry for all chemical substances managed within the enterprise. Each record links a unique CAS number to its canonical chemical identity including IUPAC name, synonyms, molecular formula, InChI key, SMILES notation, chemical family, substance type (pure substance, mixture, polymer, UVCB), regulatory status under TSCA, REACH, and other jurisdictions, and cross-references to internal material master records. Supports regulatory compliance, SDS authoring, REACH registration, and TSCA inventory reporting.' .

ind:SdsRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Rawmaterial ;
    rdfs:label 'Sds Record' ;
    rdfs:comment 'Safety Data Sheet (SDS/MSDS) master records for each raw material, maintained in compliance with GHS (Globally Harmonized System) and OSHA HazCom standards. Each record captures the 16-section GHS SDS structure including supplier identity, hazard identification, composition/ingredient information, first-aid measures, fire-fighting measures, accidental release measures, handling and storage, exposure controls/PPE, physical and chemical properties, stability and reactivity, toxicological information, ecological information, disposal considerations, transport information, regulatory information, and other information. Tracks SDS version number, effective date, expiry date, issuing supplier, language, and regulatory jurisdiction. Linked to material master and GHS classification records. Supports EHS compliance, worker safety training, and emergency response.' .

ind:RawmaterialGhsClassification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Rawmaterial ;
    rdfs:label 'Rawmaterial Ghs Classification' ;
    rdfs:comment 'GHS (Globally Harmonized System) and CLP (Classification, Labelling and Packaging) hazard classification records for each raw material substance. This product is the exclusive SSOT for GHS-framework hazard data: hazard class (flammable liquid, acute toxicity, skin corrosion, respiratory sensitizer, carcinogen, environmental hazard, etc.), hazard category (Category 1, 2, 3, etc.), signal word (Danger/Warning), hazard statements (H-codes), precautionary statements (P-codes), pictogram codes (GHS01-GHS09), classification basis (test data, read-across, expert judgment, calculation method for mixtures), classification date, regulatory jurisdiction (GHS Rev 9, EU CLP, OSHA HazCom 2012), and classification authority. Non-GHS hazard frameworks (NFPA, DOT, EPA, OSHA PEL) are owned by material_hazard_profile. Supports SDS Section 2 authoring, label generation, transport classification, and REACH/CLP compliance reporting.' .

ind:MaterialSpecification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Rawmaterial ;
    rdfs:label 'Material Specification' ;
    rdfs:comment 'Incoming raw material quality specifications defining the acceptance criteria for each material purchased and received. Each specification record captures the material, specification version, effective date, specification owner, and a full set of quality parameters including assay/purity limits (min/max), moisture content limits, heavy metals limits (PPM), pH range, color (APHA/Gardner), viscosity range, density range, particle size distribution, residual solvent limits, microbiological limits, and any material-specific analytical parameters. Includes specification status (draft, approved, superseded), approval authority, and links to the associated test methods. Serves as the acceptance standard for incoming QC testing and COA review.' .

ind:SupplierMaterial rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Rawmaterial ;
    rdfs:label 'Supplier Material' ;
    rdfs:comment 'Approved Supplier List (ASL) records capturing qualified supplier-to-material relationships for raw material procurement. Each record represents a specific supplier\'s offering of a raw material including supplier trade name, part number, approved manufacturer, country of origin, lead time, MOQ, qualification status (approved, conditional, probationary, disqualified), qualification date, last audit date, preferred supplier flag, and supply risk tier. Manages the source list for each raw material and supports SAP MM source list and info record management. Enables procurement to identify qualified sources and supports supply chain risk management.' .

ind:MaterialQualification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Rawmaterial ;
    rdfs:label 'Material Qualification' ;
    rdfs:comment 'Tracks the formal qualification lifecycle of raw materials and supplier-material combinations through the approved supplier qualification process. Each record captures the qualification request date, qualification type (new material, new supplier, change qualification, requalification), qualification scope, qualification protocol reference, lab-scale evaluation results, pilot-scale trial results, production-scale trial results, technical review outcome, regulatory review outcome, qualification decision (approved, rejected, conditional), qualification effective date, requalification interval, and responsible quality engineer. Supports the MOC (Management of Change) process for raw material changes and ensures only qualified materials enter production.' .

ind:IncomingInspection rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Rawmaterial ;
    rdfs:label 'Incoming Inspection' ;
    rdfs:comment 'Records of incoming quality inspection events performed on received raw material lots at the plant gate, warehouse, or tank farm. Each inspection record captures the inspection lot number (SAP QM), material, supplier, purchase order reference, delivery note number, received quantity, sample plan and sample size, inspection date, inspection type (identity test, full COA review, skip lot, reduced, tightened per ANSI/ASQ Z1.4), individual test results against specification parameters (assay, pH, moisture, appearance, color, viscosity, density, particle size, etc.), overall inspection decision (accept, reject, hold, conditional release), disposition instructions, inspector ID, inspection completion timestamp, and any OOS (Out of Specification) or OOT (Out of Trend) findings. Triggers CAPA workflows on rejection. Serves as the quality gate controlling raw material entry into unrestricted inventory and is the SSOT for the accept/reject decision at the rawmaterial domain boundary — downstream quality investigations and CAPAs are owned by the quality domain.' .

ind:LotRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Rawmaterial ;
    rdfs:label 'Lot Record' ;
    rdfs:comment 'Lot-level traceability records for each received batch or lot of raw material. Each lot record captures the internal lot number, supplier lot/batch number, material, supplier, receipt date, manufacturing date, expiry date, retest date, received quantity, unit of measure, storage location, storage conditions (temperature, humidity), lot status (unrestricted, quality hold, blocked, expired, quarantine), COA reference, SDS version at receipt, country of origin, and chain of custody notes. Supports FIFO/FEFO inventory management, lot traceability for production batch records, and regulatory recall management. Serves as the foundational traceability record linking procurement to production.' .

ind:CoaDocument rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Rawmaterial ;
    rdfs:label 'Coa Document' ;
    rdfs:comment 'Certificate of Analysis (COA) documents received from suppliers for each raw material lot shipment. Each COA record captures the supplier name, supplier lot number, material name, CAS number, manufacturing date, expiry date, test parameters and results as reported by the supplier (assay, purity, moisture, pH, heavy metals, residual solvents, appearance, etc.), analytical methods used, specification limits, pass/fail status per parameter, overall COA conclusion, issuing laboratory, authorized signatory, COA issue date, and document file reference. Supports incoming inspection, lot release decisions, and regulatory traceability. Enables COA-to-specification comparison for incoming QC.' .

ind:ReachRegistration rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Rawmaterial ;
    rdfs:label 'Reach Registration' ;
    rdfs:comment 'REACH (Registration, Evaluation, Authorisation and Restriction of Chemicals) registration dossier and compliance records for chemical substances manufactured or imported into the EU/EEA. Each record captures the substance identity (CAS, EC number), ECHA registration number, registration dossier reference, tonnage band, registration holder (lead/member), co-registrant status, joint submission reference, substance evaluation status (CoRAP), authorisation status (if SVHC/Annex XIV), restriction status (Annex XVII), SVHC (Substance of Very High Concern) candidate list date, dossier update date, downstream use notifications, and compliance deadline dates. This product is the SSOT for EU REACH dossier-specific detail — the consolidated cross-jurisdictional compliance view is owned by material_regulatory_status. Supports ECHA regulatory reporting, supply chain communication obligations (Article 33), and import/export compliance for EU/EEA markets.' .

ind:MaterialComposition rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Rawmaterial ;
    rdfs:label 'Material Composition' ;
    rdfs:comment 'Detailed chemical composition records for raw materials that are mixtures, blends, or multi-component substances. Each record captures the parent material, component substance (CAS number, IUPAC name), component concentration (nominal, minimum, maximum), concentration unit (% w/w, % v/v, PPM), component function (active ingredient, solvent, stabilizer, impurity, contaminant), confidential business information (CBI) flag for trade secret components, and the composition version and effective date. Supports SDS Section 3 (Composition/Information on Ingredients), REACH mixture classification, formulation compatibility assessment, and regulatory disclosure obligations.' .

ind:MaterialRegulatoryStatus rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Rawmaterial ;
    rdfs:label 'Material Regulatory Status' ;
    rdfs:comment 'Consolidated cross-jurisdictional regulatory compliance summary for each raw material, providing a single-pane view of a material\'s global regulatory standing across ALL applicable frameworks (REACH, TSCA, CLP, OSHA, EPA TRI, DOT, China IECSC, Japan CSCL, Korea K-REACH, and others). Each record captures substance identity, regulatory framework, jurisdiction, registration/listing status, compliance status (compliant, non-compliant, pending, exempt), restriction applicability, compliance deadlines, and responsible regulatory affairs manager. This product is the SSOT for the consolidated regulatory compliance decision (\'can we use this material in jurisdiction X?\') — it aggregates status from jurisdiction-specific detail products (reach_registration for EU REACH dossier data, tsca_inventory for US EPA TSCA data) but adds coverage for jurisdictions without dedicated detail products and provides the single authoritative compliance summary used by procurement, import/export, and market access teams.' .

ind:Invoice rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Invoice' ;
    rdfs:comment 'Core billing document representing a customer invoice generated from a sales order or delivery. Captures invoice number, billing date, customer account, total amount, currency, payment terms, tax totals, and lifecycle status (open, partially paid, cleared, disputed). Serves as the primary accounts receivable document and SSOT for all customer-facing billing transactions in the chemical manufacturing order-to-cash cycle. Links to invoice_line for item detail and to payment_receipt for cash application.' .

ind:InvoiceLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Invoice Line' ;
    rdfs:comment 'Line-item detail of a customer invoice representing individual chemical products, formulations, or services billed. Captures material number, product description, quantity, unit of measure, unit price, line amount, tax code, cost center, and profit center. Supports detailed revenue recognition and COGS allocation per product SKU and batch lot in SAP FI/CO.' .

ind:BillingAdjustment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Billing Adjustment' ;
    rdfs:comment 'Financial adjustment document issued to a customer to either reduce (credit) or increase (debit) the amount owed on an existing invoice. Credit scenarios include product returns, quality disputes (OOS/OOT), pricing corrections, or volume rebate settlements. Debit scenarios include underbilling corrections, surcharges, freight adjustments, or hazardous material handling fees. Captures adjustment document number, adjustment type (credit/debit), reference invoice, reason code, adjustment amount, tax impact, and approval workflow status. Serves as the SSOT for all post-invoice billing modifications in the chemical manufacturing order-to-cash cycle. Managed in SAP SD/FI as billing document types.' .

ind:PaymentReceipt rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Payment Receipt' ;
    rdfs:comment 'Record of a customer payment received against an open accounts receivable invoice. Captures payment document number, payment date, payment method (wire, ACH, check), amount received, currency, bank clearing reference, and allocation to specific invoices. Supports payment reconciliation and AR aging in SAP FI.' .

ind:ArOpenItem rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Ar Open Item' ;
    rdfs:comment 'Open accounts receivable item representing an outstanding customer obligation not yet fully cleared. Tracks invoice reference, due date, overdue days, dunning level, disputed amount, and partial payment status. Serves as the operational AR aging ledger for collections management and SOX-compliant financial reporting in SAP FI.' .

ind:Dispute rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Dispute' ;
    rdfs:comment 'Formal record of a customer-raised dispute against an invoice or billing document. Captures dispute case number, disputed invoice reference, dispute reason (pricing error, quantity discrepancy, quality claim, duplicate billing), disputed amount, dispute status, resolution owner, and resolution date. Supports CAPA-driven dispute resolution workflows and customer satisfaction tracking.' .

ind:RevenueRecognitionEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Revenue Recognition Event' ;
    rdfs:comment 'Record of a revenue recognition posting event triggered by delivery, billing, or contractual milestone completion. Captures recognition event type (point-in-time, over-time), recognized revenue amount, deferred revenue amount, performance obligation reference, recognition date, and ASC 606 / IFRS 15 compliance flags. Integrates with SAP FI/CO revenue accounting and reporting (RAR) for SOX-compliant financial close.' .

ind:PaymentTerm rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Payment Term' ;
    rdfs:comment 'Reference master defining standard payment terms offered to customers in chemical manufacturing commercial agreements. Captures payment term code, description, baseline date calculation rule, early payment discount percentage and qualifying days, net due days, and applicability rules by customer segment, region, or product group. Examples include Net 30, Net 60, 2/10 Net 30, letter of credit terms, and consignment settlement terms. Referenced by invoices and sales orders to calculate due dates and drive AR aging, dunning triggers, and cash flow forecasting in SAP FI/SD.' .

ind:BillingSchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Billing Schedule' ;
    rdfs:comment 'Master record defining a periodic or milestone-based billing plan for long-term chemical supply contracts, toll manufacturing agreements, or take-or-pay arrangements. Captures billing plan type (periodic, milestone), billing dates, planned billing amounts, percentage of contract value, and billing status per period. Managed in SAP SD billing plan (FPLA/FPLP) for contract-driven revenue scheduling.' .

ind:CostCenter rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Cost Center' ;
    rdfs:comment 'Master record for organizational cost centers used in management accounting and cost controlling. Represents a plant, department, or functional unit to which operating costs are allocated. Tracks hierarchy position, responsible manager, profit center assignment, currency, validity period, and budget ownership. Serves as the primary cost collection point for OpEx tracking, overhead allocation, and variance-to-budget reporting across chemical manufacturing facilities including production plants, R&D labs, and shared services.' .

ind:ProfitCenter rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Profit Center' ;
    rdfs:comment 'Master record for profit centers representing business segments, product lines, or plant units for which profitability is measured independently. Tracks profit center hierarchy, controlling area, responsible manager, currency, segment classification, and validity dates. Supports EBITDA reporting, segment profitability analysis under FASB ASC 280, and statutory reporting for chemical product lines including specialty chemicals, performance materials, and agricultural solutions.' .

ind:GlAccount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Gl Account' ;
    rdfs:comment 'General ledger account master defining the chart of accounts structure for the chemical manufacturing enterprise. Includes account type (P&L, balance sheet), account group, reconciliation account flag, tax category, currency, controlling integration flag, and account description. Serves as the foundational classification for all financial postings, statutory reporting, trial balance generation, and SOX compliance across all legal entities.' .

ind:JournalEntry rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Journal Entry' ;
    rdfs:comment 'Core general ledger posting document capturing all financial transactions across the chemical manufacturing enterprise. Includes document type, posting date, fiscal period, legal entity, reference number, currency, exchange rate, reversal indicator, and audit trail fields. Represents the authoritative record for all accounting events including accruals, reversals, intercompany eliminations, period-end adjustments, tax postings, and reclassifications. Subject to SOX controls, FASB retention requirements, and statutory audit trail obligations.' .

ind:JournalEntryLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Journal Entry Line' ;
    rdfs:comment 'Individual line item within a general ledger journal entry representing one side of a double-entry posting. Captures GL account, cost center, profit center, project/WBS element, business segment, debit/credit indicator, amount in local and document currency, tax code, assignment field, and line item text. Enables granular cost allocation, plant-level cost accounting, and detailed financial audit trails required for SOX and FASB compliance in chemical manufacturing operations.' .

ind:CostElement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Cost Element' ;
    rdfs:comment 'Cost element master defining the nature of costs and revenues tracked in management accounting. Classifies costs as primary (directly linked to GL accounts for external reporting) or secondary (internal allocations, overhead absorption, activity-based costing). Includes cost element category, unit of measure, quantity-based costing flag, and validity period. Critical for standard costing of chemical formulations, overhead rate application, and COGS analysis across batch and continuous manufacturing processes.' .

ind:InternalOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Internal Order' ;
    rdfs:comment 'Cost collection object for tracking expenditures on specific initiatives including capital projects, plant turnarounds, R&D programs, EHS compliance investments, and maintenance campaigns in chemical manufacturing. Captures order type (CapEx, OpEx, R&D, maintenance), budget, actual costs, commitments, settlement rules, responsible cost center, and lifecycle status. Enables project-level cost monitoring, CapEx/OpEx classification per FASB ASC 360, and settlement to fixed assets upon project completion.' .

ind:StandardCost rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Standard Cost' ;
    rdfs:comment 'Standard cost estimate for chemical finished goods, intermediates, and formulations used for inventory valuation and COGS determination. Captures cost component breakdown (raw materials, direct labor, energy, manufacturing overhead, depreciation), standard price per unit, costing lot size, validity period, and release status. Supports product costing for complex multi-step chemical synthesis, make-vs-buy decisions, transfer pricing, and variance analysis against actual production costs in batch and continuous process environments.' .

ind:BudgetPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Budget Plan' ;
    rdfs:comment 'Annual and multi-year budget plan record for cost centers, profit centers, and internal orders. Captures budget version, fiscal year, planning period, budget type (original, supplement, return), planned amounts by cost element, currency, approval status, and planner identity. Supports financial planning, annual budgeting cycles, variance-to-budget reporting, and management reporting for chemical manufacturing operations including plant-level OpEx budgets and R&D investment planning.' .

ind:FixedAsset rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Fixed Asset' ;
    rdfs:comment 'Master record for capitalized plant property and equipment including chemical reactors, distillation columns, storage tanks, control systems, buildings, and infrastructure. Captures asset class, acquisition date and cost, accumulated depreciation, net book value, useful life, depreciation method, plant/cost center assignment, and retirement status. Supports balance sheet reporting, depreciation scheduling, insurance valuation, and regulatory compliance under FASB ASC 360 for impairment testing.' .

ind:AssetTransaction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Asset Transaction' ;
    rdfs:comment 'Fixed asset transaction record capturing all asset value movements including acquisitions, retirements, transfers, write-ups, write-downs, and periodic depreciation postings. Includes transaction type, posting date, amount, document reference, asset value date, depreciation area, and GL account assignment. Provides the complete financial history of plant assets (reactors, columns, tanks, infrastructure) for FASB ASC 360 compliance, audit trails, and SOX controls.' .

ind:SafetyIncident rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ehs ;
    rdfs:label 'Safety Incident' ;
    rdfs:comment 'Master record for all workplace safety incidents, near-misses, first-aid events, and occupational chemical exposure monitoring at Chemical Mfg facilities. Captures incident type (injury, illness, near-miss, property damage, process safety, chemical exposure), severity classification (OSHA recordable, lost-time, first-aid), incident date/time, location, affected personnel, initial description, root cause category, and regulatory reportability flags. For chemical exposure events: captures substance (CAS number), exposure measurement type (personal air sampling, area monitoring, biological monitoring), measured concentration, OSHA PEL/ACGIH TLV threshold, exceedance flag, and required follow-up. Integrates with Intelex EHS Management. Supports OSHA 300/300A recordkeeping, PSM incident reporting, and OSHA 1910.1000 air contaminants compliance.' .

ind:IncidentInvestigation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ehs ;
    rdfs:label 'Incident Investigation' ;
    rdfs:comment 'Detailed root cause investigation record linked to a safety incident or near-miss. Captures investigation team members, RCI (Root Cause Investigation) methodology used (5-Why, Fault Tree, HAZOP-based), contributing factors, direct and root causes, corrective action recommendations, investigation completion date, and regulatory submission status. Supports PSM incident investigation requirements under OSHA 29 CFR 1910.119 and ISO 45001 audit trails.' .

ind:CapaRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ehs ;
    rdfs:label 'Capa Record' ;
    rdfs:comment 'Corrective and Preventive Action (CAPA) record tracking remediation actions arising from safety incidents, near-misses, audit findings, inspection citations, or regulatory observations at Chemical Mfg facilities. Captures action description, action type (corrective vs. preventive), responsible owner, priority, due date, completion date, verification method, effectiveness review outcome, and linkage to originating incident, inspection finding, or MOC. Supports ISO 45001 continual improvement (Clause 10.2), ISO 14001 nonconformity management, OSHA PSM follow-up, and Responsible Care management system requirements.' .

ind:HazopStudy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ehs ;
    rdfs:label 'Hazop Study' ;
    rdfs:comment 'Process safety master record encompassing Process Safety Information (PSI), Hazard and Operability (HAZOP) studies, Process Hazard Analyses (PHA), and granular study nodes for chemical process units at Chemical Mfg plants. PSI content: chemical identity (CAS number), maximum intended inventory, physical/chemical properties, reactivity hazards, corrosivity data, thermal stability, P&ID references, equipment design specifications, safe operating limits. Study content: study scope, process unit reference, team composition, methodology (HAZOP, What-If, Checklist, LOPA), study/revalidation dates, overall risk ranking. Node-level detail: node identifier, design intent, guide words (No, More, Less, Reverse, Other Than), deviations, causes, consequences, safeguards, risk rankings (likelihood × severity), recommended actions. Required under OSHA PSM 29 CFR 1910.119(d) and (e) and EPA RMP 40 CFR Part 68. Integrates with Intelex EHS Management.' .

ind:EmissionEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ehs ;
    rdfs:label 'Emission Event' ;
    rdfs:comment 'Comprehensive environmental emissions, releases, and source inventory record for Chemical Mfg facilities. Source inventory: all permitted and tracked emission sources (stacks, vents, fugitive equipment components, storage tanks, wastewater treatment units), source type, associated process unit, geographic coordinates, permit reference, applicable emission limits, control device linkage, monitoring frequency. Routine emissions: point-source and fugitive release quantities of VOCs, HAPs, GHGs, pollutant CAS numbers, emission factors, measurement methods (CEMS, stack test, engineering estimate). Accidental releases/spills: release date/time, chemical identity, quantity released, release media (air, soil, water, drain), cause, containment effectiveness, emergency response actions, regulatory reportability (CERCLA RQ, EPCRA 304, state spill reporting), agency notifications, cleanup status. Feeds TRI annual reporting, EPA air permit compliance, NPDES reporting, and spill notification workflows.' .

ind:EmissionSource rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ehs ;
    rdfs:label 'Emission Source' ;
    rdfs:comment 'Master record for all permitted and tracked emission sources at Chemical Mfg facilities, including stacks, vents, fugitive equipment components, storage tanks, and wastewater treatment units. Captures source ID, source type, associated process unit, geographic coordinates, permit reference, applicable emission limits, control device linkage, and monitoring frequency requirements. Serves as the SSOT for emission source inventory used in air permit compliance and TRI reporting.' .

ind:WasteDisposalRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ehs ;
    rdfs:label 'Waste Disposal Record' ;
    rdfs:comment 'Comprehensive waste management record for Chemical Mfg operations covering waste stream master definitions, waste characterization, and individual disposal transactions. Waste stream master data: stream name, physical/chemical description, generating process unit, EPA waste codes, RCRA hazardous waste determination, typical generation rate, approved disposal methods, storage requirements, regulatory notification status. Disposal transaction data: waste characterization, quantity generated, disposal method (landfill, incineration, recycling, treatment), licensed disposal facility, manifest number, shipment date, chain-of-custody documentation, and LDR (Land Disposal Restrictions) compliance. Supports EPA RCRA hazardous waste reporting, biennial reporting, state environmental agency submissions, and ISO 14001 waste management tracking.' .

ind:WasteStream rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ehs ;
    rdfs:label 'Waste Stream' ;
    rdfs:comment 'Master record defining each recurring waste stream generated by Chemical Mfg production processes. Captures waste stream name, physical/chemical description, generating process unit, EPA waste codes, RCRA hazardous waste determination, typical generation rate, approved disposal methods, storage requirements, and regulatory notification status. Provides the classification foundation for all waste disposal records and annual waste reporting.' .

ind:RegulatorySubmission rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ehs ;
    rdfs:label 'Regulatory Submission' ;
    rdfs:comment 'Record of formal regulatory submissions, TRI chemical inventory/release calculations, and supporting documentation for Chemical Mfg environmental and safety agency filings. Submission tracking: submission type (TRI Form R, RMP, Title V permit renewal, TSCA CDR, REACH registration, OSHA PSM audit response), submission date, reporting period, agency recipient, status, acknowledgment receipt, permit/registration number. TRI inventory and reporting: TRI-listed chemical (CAS number), facility, reporting year, maximum amount on-site, annual throughput quantity, release quantities by media (air, water, land, off-site transfer), waste management hierarchy data, source reduction activities, Form R submission linkage. Provides the compliance submission audit trail for SOX, ISO 14001/45001 management reviews, EPCRA Section 313 annual reporting, and all agency filing requirements.' .

ind:OperatingPermit rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ehs ;
    rdfs:label 'Operating Permit' ;
    rdfs:comment 'Environmental and safety operating permit master record for Chemical Mfg facilities. Captures permit type (Title V air, NPDES wastewater, RCRA storage, state air permit, stormwater SWPPP), issuing agency, permit number, facility, effective date, expiration date, renewal status, key permit conditions, emission limits, monitoring requirements, and compliance schedule milestones. Serves as the SSOT for permit-driven compliance obligations across air, water, and waste programs.' .

ind:InspectionAudit rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ehs ;
    rdfs:label 'Inspection Audit' ;
    rdfs:comment 'EHS inspection, audit, and findings record for internal safety audits, regulatory agency inspections, and third-party compliance assessments at Chemical Mfg facilities. Captures inspection type (OSHA compliance audit, EPA facility inspection, ISO 14001/45001 internal audit, Responsible Care verification), inspection date, inspector/auditor identity, scope, and individual findings (citations, observations, nonconformances, severity, regulatory standard referenced, affected area, required corrective action, due date, closure status). Supports ISO 14001 Clause 9.2 internal audit, OSHA PSM compliance audit requirements, and drives CAPA generation from findings.' .

ind:ProcessSafetyInfo rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ehs ;
    rdfs:label 'Process Safety Info' ;
    rdfs:comment 'Process Safety Information (PSI) master record for highly hazardous chemicals and covered processes at Chemical Mfg facilities under OSHA PSM. Captures chemical identity (CAS number), maximum intended inventory, physical/chemical properties, reactivity hazards, corrosivity data, thermal stability data, P&ID reference, equipment design specifications, and safe operating limits. Required documentation under OSHA 29 CFR 1910.119(d) and EPA RMP 40 CFR Part 68.' .

ind:SafetyDataSheet rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ehs ;
    rdfs:label 'Safety Data Sheet' ;
    rdfs:comment 'Safety Data Sheet (SDS/MSDS) master record for all chemical substances handled, produced, or distributed by Chemical Mfg. Captures SDS version, GHS classification (hazard class, category, signal word, pictograms), CAS number, chemical composition, first-aid measures, firefighting measures, exposure controls, PPE requirements, physical/chemical properties, stability/reactivity data, toxicological information, and regulatory status (REACH, TSCA, SARA 313). Integrates with product and raw material domains via CAS number.' .

ind:EmergencyResponsePlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ehs ;
    rdfs:label 'Emergency Response Plan' ;
    rdfs:comment 'Emergency response plan master record for Chemical Mfg facilities covering chemical release, fire, explosion, natural disaster, and environmental emergency scenarios. Captures plan type (OSHA EAP, EPA RMP Emergency Response Program, SPCC Plan, EPCRA LEPC notification), covered hazards, emergency coordinator contacts, evacuation routes, shelter-in-place procedures, community notification thresholds, drill schedule and completion history, performance observations from exercises, last review date, and regulatory submission status. Required under OSHA 29 CFR 1910.38, EPA RMP 40 CFR Part 68, and EPCRA Section 304. Now includes drill/exercise tracking previously in emergency_drill.' .

ind:Order rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Order' ;
    rdfs:comment 'Core master record for a customer sales order capturing the full order header: customer account, order type (standard, rush, blanket, consignment, return), requested delivery date, incoterms, payment terms, total order value, currency, plant assignment, sales organization, distribution channel, and division. Serves as the authoritative SSOT for all customer order commitments in the order-to-cash lifecycle. Links to quotation (source), blanket order (if call-off), and downstream confirmations, deliveries, and status events. Maps to SAP SD transaction VA01/VA02.' .

ind:LineItem rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Line Item' ;
    rdfs:comment 'Individual line item within a customer sales order representing a specific chemical product SKU, grade, or formulation being ordered. Captures line number, material number (SAP), product description, ordered quantity, unit of measure (kg, L, MT, drums), confirmed quantity, net price, pricing conditions, requested delivery date per line, plant, storage location, batch determination flag, COA/COC requirement flag, and special handling instructions (e.g., hazmat class, temperature-controlled). Supports MOQ enforcement and partial delivery rules.' .

ind:OrderConfirmation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Order Confirmation' ;
    rdfs:comment 'Official order acknowledgment document sent to the customer confirming acceptance of a sales order. Captures confirmation number, confirmed order quantities, confirmed delivery dates, confirmed pricing, plant of supply, batch allocation status, COA/COC commitment, special handling confirmations (GHS hazard class, DOT classification), and any deviations from the original customer request. Serves as the contractual commitment record between Chemical Mfg and the customer.' .

ind:OutboundDelivery rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Outbound Delivery' ;
    rdfs:comment 'Outbound delivery document created in SAP EWM/SD to execute the physical shipment of chemical products against a sales order. Captures delivery number, delivery date, ship-to party, shipping point, total weight, total volume, hazardous material indicator, UN number, DOT hazard class, packing instructions, batch numbers assigned, COA/COC attachment status, and goods issue posting date. Integrates with Oracle Transportation Management for carrier assignment and freight execution.' .

ind:StatusEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Status Event' ;
    rdfs:comment 'Immutable event log capturing every status transition and fulfillment milestone in the sales order lifecycle from creation through delivery, invoicing, and closure. Records event timestamp, previous status, new status, milestone type (order created, order confirmed, credit check passed, production scheduled, batch released, quality released, goods issued, picked up, in transit, customs cleared, delivered, POD received, invoiced), planned date, actual date, variance in days, triggering user or system, event source (SAP SD, OTM, MES, WMS, manual), responsible party, and event notes. Supports full order lifecycle traceability, SLA monitoring, on-time delivery (OTD) KPI calculation, proactive customer communication, customer inquiry resolution, and regulatory audit trail for controlled substance shipment tracking.' .

ind:ProductHold rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Product Hold' ;
    rdfs:comment 'Record of a hold placed on a sales order preventing further processing or shipment. Captures hold ID, hold type (credit hold, quality hold, regulatory hold, export compliance hold, customer dispute hold), hold reason code, hold placed by, hold placed timestamp, hold release timestamp, release authorization, and resolution notes. Supports credit management integration with SAP FI/CO and quality hold integration with QM module. Tracks order blockage duration for SLA and customer service reporting.' .

ind:ReturnsOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Returns Order' ;
    rdfs:comment 'Customer return order (RMA) capturing the authorization and processing of product returns from customers. Captures return order number, original sales order reference, return reason code (OOS, damaged, wrong product, excess inventory, quality complaint), return quantity, return condition, plant receiving the return, credit memo eligibility, disposal instructions (restock, destroy, rework), and return logistics details. Maps to SAP SD Returns Order (VA01 with order type RE) and reverse logistics workflow.' .

ind:Shipment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Logistics ;
    rdfs:label 'Shipment' ;
    rdfs:comment 'Core master record for every outbound or inbound freight movement of chemical products. Captures shipment type (LTL/FTL/intermodal), origin and destination facilities, scheduled and actual departure/arrival dates, total weight, volume, hazmat class, UN number, DOT 49 CFR compliance status, carrier assignment, freight terms (prepaid/collect), shipment status, and Oracle TMS shipment reference. Serves as the primary operational entity for all logistics execution activities. Supports DOT 49 CFR §172.200 shipping paper requirements and §177.817 driver document requirements.' .

ind:ShipmentLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Logistics ;
    rdfs:label 'Shipment Line' ;
    rdfs:comment 'Line-level detail for each product, material, or package included in a shipment. Records the finished chemical SKU or raw material, ordered and shipped quantities, unit of measure, lot number, batch number, hazmat indicator, UN hazard class, packing group, net and gross weight, COA reference, package count, package type (drum/IBC/tote/ISO tank), package dimensions, tare weight, GHS/DOT label requirements per 49 CFR §172.400, seal or closure verification, and packing list documentation for customs clearance. Supports multi-product chemical shipments, regulatory manifest line-item traceability, receiving verification, and international customs documentation requirements.' .

ind:BillOfLading rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Logistics ;
    rdfs:label 'Bill Of Lading' ;
    rdfs:comment 'Legal transport document issued for each chemical shipment, serving as the contract of carriage between shipper and carrier. Captures BOL number, shipper and consignee details, carrier SCAC code, freight class, declared value, hazmat emergency contact, special handling instructions, seal numbers, and DOT 49 CFR certification statement. Required for all regulated chemical transport under DOT and IATA rules.' .

ind:Carrier rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Logistics ;
    rdfs:label 'Carrier' ;
    rdfs:comment 'Master record for all approved freight carriers used to transport chemical products, including qualification status, contractual terms, and periodic performance scorecards. Stores carrier name, SCAC code, DOT carrier number, MC number, carrier type (LTL/FTL/rail/intermodal/tanker/ISO tank), hazmat certification status, insurance certificate expiry, approved chemical hazard classes, preferred lanes, carrier tier rating, CTPAT certification status, Oracle TMS carrier ID, and performance KPIs (on-time pickup/delivery rates, damage and claim rates, hazmat compliance incidents, tender acceptance rate, invoice accuracy, measurement period, corrective action flags, benchmark comparison). Supports carrier qualification reviews, contract renewal decisions, tier classification, and compliance vetting per DOT 49 CFR §172.800 security plan requirements for regulated chemical transport.' .

ind:FreightOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Logistics ;
    rdfs:label 'Freight Order' ;
    rdfs:comment 'Operational freight order tendered to a carrier for execution of a shipment or consolidated load. Captures freight order number, tendering method (spot/contract/load board), carrier acceptance status, agreed freight rate, accessorial charges, pickup and delivery windows, load type, temperature requirements for temperature-sensitive chemicals (e.g., epoxy resins, catalysts), and TMS order reference. Represents the contractual execution unit between Chemical Mfg and the carrier per DOT 49 CFR §172.204 shipper certification requirements. Supports multi-stop and pool-point distribution common in chemical distribution networks.' .

ind:DeliveryConfirmation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Logistics ;
    rdfs:label 'Delivery Confirmation' ;
    rdfs:comment 'Record of proof-of-delivery (POD) for completed chemical shipments. Captures actual delivery date and time, receiver name and signature, delivery location, condition of goods on arrival, any noted discrepancies (shortage, damage, contamination), exception codes, and electronic POD document reference. Triggers downstream billing and COA release workflows.' .

ind:HazmatDeclaration rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Logistics ;
    rdfs:label 'Hazmat Declaration' ;
    rdfs:comment 'Consolidated hazardous materials compliance record for each regulated chemical shipment line, combining SDS-derived transport requirements with DOT 49 CFR, IATA DGR, and IMDG Code shipping declarations. Records UN number, proper shipping name, hazard class and division, packing group, quantity and type of packaging, emergency response guide number (ERG), shipper certification, segregation requirements for incompatible chemicals, temperature limits during transport, PPE requirements for drivers, spill response instructions, and applicable transport regulation. Serves as the single source of truth for all hazmat transport compliance data — from SDS-sourced chemical properties through to regulatory declaration filing. Mandatory for all chemical shipments involving hazardous materials per DOT 49 CFR §172.200-204.' .

ind:ShipmentPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Logistics ;
    rdfs:label 'Shipment Plan' ;
    rdfs:comment 'Consolidated shipment planning record combining route optimization and load planning for one or more shipments. Captures planned route legs, waypoints, estimated transit times, distance, fuel surcharge basis, restricted route flags (tunnel/bridge restrictions for hazmat per DOT 49 CFR §397.71), alternate route options, optimization objective (cost/time/compliance), load consolidation details, vehicle type and capacity assignment, actual loaded weight and volume, load sequence, temperature zone assignments for mixed chemical loads, and loading dock assignment. Supports DOT hazmat routing compliance, freight utilization optimization, and DOT weight compliance.' .

ind:FreightRate rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Logistics ;
    rdfs:label 'Freight Rate' ;
    rdfs:comment 'Contracted or spot freight rate records negotiated with carriers for specific lanes, modes, and chemical commodity types. Stores rate type (base/accessorial/fuel surcharge), origin and destination zone, carrier, effective and expiry dates, rate per unit (CWT/mile/flat), minimum charge, hazmat surcharge, and Oracle TMS rate table reference. Drives freight cost calculation and carrier selection optimization.' .

ind:CustomsDeclaration rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Logistics ;
    rdfs:label 'Customs Declaration' ;
    rdfs:comment 'Export or import customs declaration for international chemical shipments. Records declaration type (export/import), HS tariff code, country of origin, declared value, currency, Incoterms, export control classification number (ECCN), REACH compliance flag, import permit reference, customs broker details, and clearance status. Required for cross-border movement of chemicals under TSCA, REACH, and national customs regulations.' .

ind:Vehicle rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Logistics ;
    rdfs:label 'Vehicle' ;
    rdfs:comment 'Master record for vehicles and transport equipment used in chemical product logistics, including owned fleet assets and carrier-provided equipment. Stores vehicle ID, vehicle type (tanker, flatbed, dry van, ISO container, railcar, IBC chassis), license plate or equipment number, DOT registration number, hazmat placard capability per DOT 49 CFR §172.500-§172.560, last inspection date, annual DOT inspection status per 49 CFR §396.17, temperature control capability and range, dedicated/non-dedicated status, last cargo carried (for contamination prevention), cleaning certification date, tare weight, and maximum payload. Supports equipment assignment, DOT compliance tracking, and chemical cross-contamination prevention through last-cargo verification.' .

ind:InspectionLot rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Inspection Lot' ;
    rdfs:comment 'Core inspection lot entity representing a quality inspection event triggered by goods receipt, production completion, periodic inspection, or customer return. Captures lot origin, inspection type, lot quantity, material/batch reference, plant, storage location, inspection start/end dates, lot status (created, sample drawn, results recorded, usage decision made), usage decision reference, and GMP compliance flags. Central transactional hub linking samples, test results, and disposition decisions in the quality workflow.' .

ind:QcResult rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Qc Result' ;
    rdfs:comment 'Individual analytical test result record from LabWare LIMS or SAP QM for a specific characteristic measured during an inspection lot. Captures test method, characteristic name, measured value, unit of measure, lower/upper specification limits, result status (pass, fail, OOS, OOT), analyst ID, instrument ID, test date/time, retest flag, and raw data reference. Supports SPC charting and regulatory audit trails per ISO 9001 and GMP requirements.' .

ind:TestMethod rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Test Method' ;
    rdfs:comment 'Master record defining standardized analytical test methods and associated reference standards/reagents used in quality control and laboratory testing. Includes method code, method name, method type (titration, chromatography, spectroscopy, gravimetric, microbiological), applicable product families, instrument type, reagent requirements, sample preparation steps, applicable standard (ASTM, ISO, USP, internal), version number, effective date, and approval status. Embeds reference standard master data: standard ID, standard name, CAS number, standard type (primary, secondary, working, certified reference material), supplier, lot number, purity/concentration, certificate number, receipt date, expiry date, storage condition, current stock quantity, reorder level, and traceability chain (NIST, ECHA, pharmacopoeia). Single source of truth for analytical methodology and the certified reference materials that support measurement traceability per ISO/IEC 17025 and GMP requirements.' .

ind:InspectionCharacteristic rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Inspection Characteristic' ;
    rdfs:comment 'Master definition of a quality characteristic (parameter) to be measured within an inspection plan. Captures characteristic code, description, characteristic type (quantitative, qualitative, attribute), unit of measure, target value, lower/upper specification limits (LSL/USL), lower/upper control limits (LCL/UCL) for SPC, sampling procedure, test method reference, decimal precision, and GMP-critical flag. Linked to inspection plans and drives qc_result recording.' .

ind:InspectionPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Inspection Plan' ;
    rdfs:comment 'Master quality inspection plan defining the complete template for material/product quality evaluation. Includes plan number, version, material/product reference, plant, usage context (goods receipt, in-process, final release), inspection stage, and the full set of inspection characteristics (parameter definitions with target values, specification limits LSL/USL, control limits LCL/UCL for SPC, characteristic types, test method references, decimal precision, GMP-critical flags). Embeds statistical sampling plan details: sampling scheme type (single, double, sequential), inspection level, AQL (Acceptable Quality Level), lot size range, sample size code letter, acceptance/rejection numbers, dynamic modification rules, and applicable sampling standard (ISO 2859, MIL-STD-1916). Serves as the single authoritative template driving inspection lot creation, sample size determination, and characteristic assignment in SAP QM.' .

ind:SamplingPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Sampling Plan' ;
    rdfs:comment 'Statistical sampling plan defining sample size, sampling frequency, acceptance/rejection criteria, and AQL (Acceptable Quality Level) for a given inspection stage and material class. Captures sampling scheme type (single, double, sequential), inspection level, lot size range, sample size code letter, acceptance number, rejection number, dynamic modification rules, and applicable regulatory standard (ISO 2859, MIL-STD-1916). Referenced by inspection plans to determine how many samples to draw.' .

ind:UsageDecision rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Usage Decision' ;
    rdfs:comment 'Quality usage decision record capturing the final disposition of an inspection lot after all test results are evaluated. Records decision code (accept, reject, conditional release, reprocess, scrap, return to vendor), decision date, decision maker, stock posting instruction (unrestricted, blocked, returns), defect quantity, follow-up action triggered, and digital signature for GMP compliance. Drives downstream inventory stock transfer in SAP QM/EWM.' .

ind:QualityDeviation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Quality Deviation' ;
    rdfs:comment 'Quality deviation and notification record capturing all types of quality events requiring investigation: OOS (Out of Specification), OOT (Out of Trend), non-conformance reports (NCR), customer complaints, internal deviations, and supplier quality issues. Includes notification type (complaint, defect, NCR, deviation, OOS, OOT), notification number, subject, affected material/batch/lot, defect description, severity/defect class, priority, originator, responsible department, detection phase (incoming, in-process, outgoing, customer), complaint source details (customer reference, complaint type), NCR disposition (use-as-is, rework, scrap, return), status lifecycle (open, in-process, completed, closed), root cause category, cost of quality impact, and regulatory reportability flag. Single source of truth for all quality events requiring investigation, triggering CAPA workflow and linking to hold decisions.' .

ind:Capa rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Capa' ;
    rdfs:comment 'Corrective and Preventive Action (CAPA) record managing the full lifecycle of quality improvement actions triggered by OOS events, quality notifications, audit findings, or customer complaints. Captures CAPA number, CAPA type (corrective, preventive), root cause description, RCI method (5-Why, Fishbone, FMEA), proposed actions, responsible owner, target completion date, actual completion date, effectiveness verification date, effectiveness outcome, and GMP compliance status. Central to ISO 9001 and GMP compliance.' .

ind:CocRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Coc Record' ;
    rdfs:comment 'Quality certificate master record (COA or COC) generated for a product batch upon quality release. Supports Certificate of Analysis (COA) listing individual test parameters with specification limits and actual measured values, and Certificate of Compliance (COC) attesting overall conformance to specifications without detailed test data. Captures certificate number, certificate type (COA/COC), batch/lot number, product code/grade, manufacturing and expiry dates, test results summary, applicable specification reference, compliance statement, release status, QA signatory, customer-specific variant flag, issue date, document version, and distribution history. Serves as the single authoritative source for all outbound quality certificates supporting customer order fulfillment, regulatory submissions, and audit requirements.' .

ind:QualityHold rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Quality Hold' ;
    rdfs:comment 'Quality hold record placing a material batch, lot, or inventory quantity under restricted status pending quality investigation or disposition. Captures hold number, hold type (incoming, in-process, finished goods, customer return), affected material, batch/lot, quantity, storage location, hold reason, hold initiator, hold date, expected release date, actual release date, release authority, and hold outcome (released, rejected, reprocessed, scrapped). Integrates with SAP QM blocked stock and EWM.' .

ind:SpcControl rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Spc Control' ;
    rdfs:comment 'Statistical Process Control (SPC) chart configuration, control limits, and violation event management for monitored quality characteristics at specific process steps or production units. Captures chart type (X-bar R, X-bar S, I-MR, p-chart, c-chart, u-chart), characteristic reference, process step, control limits (UCL, LCL, CL), warning limits, subgroup size, sampling frequency, chart status, last recalculation date. Includes all violation event records: rule violations (Western Electric / Nelson rules 1-8), violation type, measured value, control limit breached, detection timestamp, operator notification, investigation required flag, disposition (false alarm, assignable cause identified, process adjusted), and trend analysis. Single source of truth for both SPC chart configuration and all control chart violation events. Drives real-time SPC monitoring via LabWare LIMS and Aveva PI integration, feeding quality deviation creation for out-of-control conditions.' .

ind:QualitySpecification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Quality Specification' ;
    rdfs:comment 'Master quality specification record defining the approved limits, grades, and acceptance criteria for a finished product, intermediate, or raw material. Captures specification number, specification version, material/product code, grade, specification type (internal, customer, regulatory, pharmacopoeia), parameter list with LSL/USL/target values, effective date, expiry date, approval status, approving authority, and applicable regulatory standard (ISO, ASTM, EP, USP). Serves as the authoritative specification against which COA results are evaluated.' .

ind:LabSample rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Lab Sample' ;
    rdfs:comment 'Physical laboratory sample record tracking a sample drawn from a batch, process stream, or incoming material for quality testing. Captures sample number, sample type (composite, grab, retention), sampling point, sampled quantity, sample container type, sampling date/time, sampler ID, chain of custody status, storage condition (temperature, humidity), sample status (received, in-testing, tested, disposed), disposal date, and LabWare LIMS sample ID. Provides full chain of custody for GMP and regulatory audit purposes.' .

ind:BankAccount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Bank Account' ;
    rdfs:comment 'Master record for corporate bank accounts used in treasury operations and cash management for the chemical manufacturing enterprise. Captures bank identifier, account number, account type (operating, payroll, investment, escrow), currency, bank name, country, GL account assignment, signatory authorities, and account status. Supports cash position reporting, payment execution, bank statement reconciliation, and liquidity planning across multiple banking relationships and jurisdictions.' .

ind:TaskList rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Maintenance ;
    rdfs:label 'Task List' ;
    rdfs:comment 'Reusable maintenance task list (job plan/procedure template) defining standardized sequences of operations, required materials, tools, safety precautions, and estimated labor for recurring maintenance activities. Serves as the master template from which work order operations are generated, ensuring consistent execution quality across crews and shifts. Captures task list type (equipment-specific, functional-location-specific, general), group/counter structure, operation steps with detailed descriptions, work center assignments, planned hours per operation, required craft qualifications, material/tool requirements with quantities, and safety/lockout-tagout instructions. Referenced by pm_plan for automated work order generation. Aligns with SAP PM Task List (IA01-IA03/PLKO) and supports PSM mechanical integrity procedure documentation, OSHA-required safe work procedures, craft standardization, and audit-ready maintenance procedure records.' .

ind:DemandForecast rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Planning ;
    rdfs:label 'Demand Forecast' ;
    rdfs:comment 'Master demand forecast record capturing statistical and consensus-based demand projections for chemical products and SKUs across planning horizons (short, mid, long-term). Stores forecast version, method (statistical, ML, consensus), baseline quantity, adjusted quantity, forecast accuracy metrics, planning bucket (weekly/monthly), and lifecycle status. Serves as the authoritative SSOT for demand signals feeding S&OP and MRP processes.' .

ind:ForecastVersion rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Planning ;
    rdfs:label 'Forecast Version' ;
    rdfs:comment 'Version-controlled snapshot of a demand forecast cycle, capturing the forecast run date, planning horizon start/end, version number, approval status, and the planner or system that generated it. Enables comparison of forecast versions across S&OP cycles and supports forecast accuracy tracking over time. Each version contains the full set of demand_forecast line records for that planning cycle.' .

ind:MrpRun rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Planning ;
    rdfs:label 'Mrp Run' ;
    rdfs:comment 'Material Requirements Planning (MRP) run master record capturing each MRP execution event in SAP PP/MRP. Records run ID, run type (regenerative, net change, net change in planning horizon), plant scope, planning date, run status, total planned orders generated, total purchase requisitions generated, and exception message count. Serves as the audit header for all MRP-generated planning elements.' .

ind:PlannedOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Planning ;
    rdfs:label 'Planned Order' ;
    rdfs:comment 'MRP-generated planned order representing a proposed production or procurement action to cover a material requirement. Captures planned order number, material, plant, order type (planned production order, planned purchase order, stock transfer), planned quantity, scheduled start date, scheduled finish date, firming status, and conversion status. Core planning element in SAP PP/MRP that drives production scheduling and procurement planning.' .

ind:CapacityPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Planning ;
    rdfs:label 'Capacity Plan' ;
    rdfs:comment 'Capacity planning master record defining the available and required capacity for a production work center, reactor, or processing line over a planning horizon. Captures work center, planning period, available capacity (hours/kg/tons), required capacity from planned orders, utilization percentage, bottleneck flag, and capacity leveling status. Supports rough-cut capacity planning (RCCP) and detailed capacity requirements planning (CRP) in chemical plant operations.' .

ind:ProductionPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Planning ;
    rdfs:label 'Production Plan' ;
    rdfs:comment 'Master Production Schedule (MPS) and production plan record defining the authorized production quantities for finished chemical products and key intermediates over a planning horizon. Captures product, plant, planning period, planned production quantity, UOM, production method, scheduling priority, freeze horizon flag, and plan status. Bridges the S&OP consensus plan and detailed MRP/scheduling execution in chemical manufacturing.' .

ind:SupplyPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Planning ;
    rdfs:label 'Supply Plan' ;
    rdfs:comment 'Integrated supply plan record representing the constrained supply response plan for a material or product family across the planning horizon. Captures supply plan ID, material, plant, planning period, planned supply quantity (from production, procurement, and transfers), confirmed supply quantity, supply gap quantity, constraint type, and plan approval status. Serves as the supply-side counterpart to the demand forecast in S&OP balancing.' .

ind:InventoryTarget rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Planning ;
    rdfs:label 'Inventory Target' ;
    rdfs:comment 'Inventory target and safety stock policy record defining the planned inventory levels for raw materials, intermediates, and finished chemical products. Captures material, plant, storage location, safety stock quantity, reorder point, maximum stock level, target days-of-supply, replenishment lead time, and review cycle. Drives MRP reorder point planning and inventory optimization for chemical feedstocks and finished goods.' .

ind:ProductionSchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Planning ;
    rdfs:label 'Production Schedule' ;
    rdfs:comment 'Detailed production schedule record defining the sequenced and time-phased production runs for chemical manufacturing work centers and reactors. Captures schedule ID, work center, product, batch size, scheduled start datetime, scheduled end datetime, sequence number, campaign flag, changeover time, scheduling status, and freeze status. Drives shop floor execution and feeds the MES/DCS systems in chemical plants.' .

ind:CampaignPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Planning ;
    rdfs:label 'Campaign Plan' ;
    rdfs:comment 'Production campaign planning record defining a multi-batch campaign for a chemical product or product family on a dedicated reactor or production line. Captures campaign ID, product family, work center, planned campaign start/end dates, total planned quantity, number of batches, minimum campaign length, campaign trigger (inventory level, order backlog), and campaign status. Supports campaign-based scheduling optimization common in specialty chemical and agrochemical manufacturing.' .

ind:AllocationRule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Planning ;
    rdfs:label 'Allocation Rule' ;
    rdfs:comment 'Product allocation rule master record defining how constrained supply of a chemical product is allocated across customers, regions, or sales channels during shortage situations. Captures allocation rule ID, product, allocation basis (historical share, contract priority, strategic customer tier), allocation period, total available quantity, allocation method, and approval status. Governs fair and strategic supply allocation during chemical supply shortages or plant outages.' .

ind:CustomerAllocation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Planning ;
    rdfs:label 'Customer Allocation' ;
    rdfs:comment 'Transactional record assigning a specific allocated quantity of a constrained chemical product to a customer account or distribution channel for a defined period. Captures allocation ID, allocation rule reference, customer account, product, allocated quantity, consumed quantity, remaining quantity, allocation period start/end, and allocation status. Enables order management to enforce supply allocation limits during chemical product shortages.' .

ind:BillingParty rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Billing Party' ;
    rdfs:comment 'Master reference table for party. Referenced by party_id.' .

ind:Settlement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Settlement' ;
    rdfs:comment 'Master reference table for settlement. Referenced by settlement_id.' .

ind:FiscalPeriod rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Fiscal Period' ;
    rdfs:comment 'Master reference table for fiscal_period. Referenced by period_id.' .

ind:Facility rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ehs ;
    rdfs:label 'Facility' ;
    rdfs:comment 'Master reference table for facility. Referenced by facility_id.' .

ind:ProcessUnit rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Process Unit' ;
    rdfs:comment 'Master reference table for process_unit. Referenced by process_unit_id.' .

ind:ProductionPlant rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Production Plant' ;
    rdfs:comment 'Master reference table for plant. Referenced by plant_id.' .

ind:LegalEntity rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Legal Entity' ;
    rdfs:comment 'Master reference table for legal_entity. Referenced by legal_entity_id.' .

ind:BusinessUnit rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Business Unit' ;
    rdfs:comment 'Master reference table for business_unit. Referenced by business_unit_id.' .

ind:Tank rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Tank' ;
    rdfs:comment 'Master reference table for tank. Referenced by tank_id.' .

ind:LogisticsParty rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Logistics ;
    rdfs:label 'Logistics Party' ;
    rdfs:comment 'Master reference table for party. Referenced by receiver_party_id.' .

ind:CalibrationProcedure rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Maintenance ;
    rdfs:label 'Calibration Procedure' ;
    rdfs:comment 'Master reference table for calibration_procedure. Referenced by calibration_procedure_id.' .

ind:MaintenancePlant rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Maintenance ;
    rdfs:label 'Maintenance Plant' ;
    rdfs:comment 'Master reference table for plant. Referenced by plant_id.' .

ind:Resource rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Resource' ;
    rdfs:comment 'Master reference table for resource. Referenced by resource_id.' .

ind:Routing rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Routing' ;
    rdfs:comment 'Master reference table for routing. Referenced by routing_id.' .

ind:BillOfMaterials rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Bill Of Materials' ;
    rdfs:comment 'Master reference table for bill_of_materials. Referenced by bom_id.' .

ind:CoaTemplate rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Coa Template' ;
    rdfs:comment 'Master reference table for coa_template. Referenced by coa_template_id.' .

ind:Organization rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Organization' ;
    rdfs:comment 'Master reference table for sales_organization. Referenced by sales_organization_id.' .

ind:PlanCharacteristicAssignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Plan Characteristic Assignment' ;
    rdfs:comment 'This association product represents the assignment of a quality characteristic to an inspection plan in SAP QM. It captures the operational configuration that determines which characteristics must be inspected when a plan is executed, including sequence, mandatory status, and plan-specific overrides to the characteristic master definition. Each record links one inspection plan to one inspection characteristic with attributes that exist only in the context of this assignment.. Existence Justification: In SAP QM and chemical manufacturing quality systems, inspection plans are reusable templates that define which characteristics must be measured, and characteristics are master definitions reused across multiple plans (e.g., \'Assay by HPLC\' appears in every API product plan). The assignment of a characteristic to a plan is an operational configuration managed by quality engineers, carrying plan-specific data like sequence, mandatory flag, and overrides to the characteristic master definition.' .

ind:DeliveryLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Delivery Line' ;
    rdfs:comment 'This association product represents the physical execution of a sales order line item through an outbound delivery in chemical manufacturing. It captures the many-to-many relationship where a single outbound delivery can ship multiple order line items (consolidated shipment), and a single order line item can be split across multiple deliveries due to hazmat transport limits, tank capacity constraints, batch availability, or partial fulfillment. Each record links one outbound delivery to one line item with attributes that exist only in the context of this specific delivery execution: delivered quantity, batch numbers assigned, COA/COC attachment status per line, and temperature deviation tracking.. Existence Justification: In chemical manufacturing operations, the relationship between outbound deliveries and sales order line items is genuinely many-to-many. A single outbound delivery routinely consolidates multiple order line items from one or more sales orders into a single shipment (many line items to one delivery). Conversely, a single order line item is frequently split across multiple deliveries due to hazmat transport quantity limits, production batch availability, tank truck capacity constraints, or customer-requested partial fulfillment (one line item to many deliveries). This is the standard SAP SD/EWM delivery item concept.' .

ind:EmissionReportingLineItem rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ehs ;
    rdfs:label 'Emission Reporting Line Item' ;
    rdfs:comment 'This association product represents the documented inclusion of a specific emission event in a specific regulatory submission. It captures the regulatory reporting relationship between emission events and formal agency filings. Each record links one regulatory submission to one emission event with attributes that exist only in the context of regulatory reporting (reported quantity, period allocation, regulatory basis, and line item status).. Existence Justification: In chemical manufacturing EHS compliance, regulatory submissions (TRI Form R, Title V, EPCRA reports) aggregate emission events across multiple reporting frameworks and time periods. A single emission event can legitimately appear in multiple submissions (e.g., the same VOC release reported in both TRI annual reporting and Title V semi-annual monitoring reports), and each submission covers many emission events. The business actively manages these reporting line items with submission-specific attributes like reported quantity (which may differ from actual due to regulatory calculation rules), regulatory basis, and form section references.' .

# --- Attribute Properties ---
ind:opportunityId rdf:type rdf:Property ;
    rdfs:label 'Opportunity Id' ;
    rdfs:comment 'Unique surrogate identifier for the sales opportunity record in the lakehouse silver layer. Primary key for this entity.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Opportunity .

ind:accountId rdf:type rdf:Property ;
    rdfs:label 'Account Id' ;
    rdfs:comment 'Reference to the customer account (industrial buyer, distributor, or end-user) associated with this opportunity. Links to the customer/account master data product.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:contactId rdf:type rdf:Property ;
    rdfs:label 'Contact Id' ;
    rdfs:comment 'Reference to the primary customer contact person (e.g., procurement manager, technical buyer) associated with this opportunity. Links to the contact master data product.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:legalEntityId rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Id' ;
    rdfs:comment 'Foreign key linking to finance.legal_entity. Business justification: Opportunities in chemical mfg are pursued by a specific legal entity — required for export control (TSCA/REACH jurisdiction), intercompany deal routing, and statutory revenue recognition reporting.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:profitCenterId rdf:type rdf:Property ;
    rdfs:label 'Profit Center Id' ;
    rdfs:comment 'Foreign key linking to finance.profit_center. Business justification: Opportunities are tracked against profit centers for pipeline-to-revenue forecasting in chemical mfg financial planning. Finance uses this link to project expected revenue by profit center from the sa' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProfitCenter .

ind:qualitySpecificationId rdf:type rdf:Property ;
    rdfs:label 'Quality Specification Id' ;
    rdfs:comment 'Foreign key linking to quality.quality_specification. Business justification: Opportunity qualification requires checking the product\'s quality specification to ensure regulatory compliance and customer requirements.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QualitySpecification .

ind:reachDossierId rdf:type rdf:Property ;
    rdfs:label 'Reach Dossier Id' ;
    rdfs:comment 'Foreign key linking to product.reach_dossier. Business justification: REACH compliance is a legal prerequisite for selling chemicals in the EU market. When reach_compliance_required=true on an opportunity, the sales team must verify a valid REACH dossier exists. FK to r' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReachDossier .

ind:regulatoryProfileId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Profile Id' ;
    rdfs:comment 'Foreign key linking to customer.regulatory_profile. Business justification: Chemical sales opportunities must be validated against the customer\'s regulatory profile (REACH registration, TSCA applicability, export licenses). Linking opportunity to regulatory_profile enables co' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryProfile .

ind:segmentId rdf:type rdf:Property ;
    rdfs:label 'Segment Id' ;
    rdfs:comment 'Foreign key linking to customer.segment. Business justification: Chemical sales pipeline reporting by market segment (automotive, electronics, agriculture) is standard practice. opportunity.application_segment is a denormalized text field; replacing with segment_id' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:siteId rdf:type rdf:Property ;
    rdfs:label 'Site Id' ;
    rdfs:comment 'Foreign key linking to customer.site. Business justification: Opportunity delivery planning uses the Customer Site to calculate logistics, compliance (REACH/SDS) and shipping terms.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Site .

ind:territoryId rdf:type rdf:Property ;
    rdfs:label 'Territory Id' ;
    rdfs:comment 'Reference to the sales territory to which this opportunity is assigned. Supports territory-based pipeline reporting, quota management, and regional performance analytics.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Territory .

ind:actualCloseDate rdf:type rdf:Property ;
    rdfs:label 'Actual Close Date' ;
    rdfs:comment 'The actual date on which the opportunity was closed (won or lost). Populated upon opportunity closure. Used for sales cycle analysis, win/loss reporting, and period attribution. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:closeProbabilityPct rdf:type rdf:Property ;
    rdfs:label 'Close Probability Pct' ;
    rdfs:comment 'Estimated probability (0.00–100.00%) that this opportunity will be won, as assessed by the sales representative or derived from stage-based defaults. Used in weighted pipeline calculations and revenue forecasting models.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:closeReason rdf:type rdf:Property ;
    rdfs:label 'Close Reason' ;
    rdfs:comment 'Structured reason code explaining why the opportunity was won or lost. Captures the primary decision criterion at closure. Used for competitive intelligence, win/loss analysis, and sales strategy refinement. [ENUM-REF-CANDIDATE: Price|Technical Fit|Relationship|Competitor|Timeline|Budget|No Decision|Other — promote to reference product]' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedAmount rdf:type rdf:Property ;
    rdfs:label 'Closed Amount' ;
    rdfs:comment 'Actual deal value at the time of opportunity closure (won or lost). May differ from estimated_amount due to negotiation, scope changes, or competitive pricing adjustments. Used for win/loss revenue analysis and competitive intelligence.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:createdTimestamp rdf:type rdf:Property ;
    rdfs:label 'Created Timestamp' ;
    rdfs:comment 'Timestamp when the opportunity record was first created in the source CRM system (Salesforce). Used for pipeline aging, sales cycle duration measurement, and audit trail. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:crmOpportunityCode rdf:type rdf:Property ;
    rdfs:label 'Crm Opportunity Code' ;
    rdfs:comment 'Native opportunity identifier from Salesforce CRM (e.g., 006XXXXXXXXXXXXXXX). Used for cross-system traceability and reconciliation with the source system of record.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currencyCode rdf:type rdf:Property ;
    rdfs:label 'Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the estimated and closed deal amounts (e.g., USD, EUR, GBP). Supports multi-currency pipeline reporting and FX conversion in SAP FI/CO.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionCriteria rdf:type rdf:Property ;
    rdfs:label 'Decision Criteria' ;
    rdfs:comment 'Free-text or structured description of the customer\'s primary evaluation criteria for this opportunity (e.g., price, technical performance, regulatory compliance, delivery reliability, sustainability). Supports win/loss analysis and sales strategy development.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Amount' ;
    rdfs:comment 'Estimated total deal value (revenue) for this opportunity in the transaction currency. Represents the gross revenue expected if the opportunity is won. Used for pipeline valuation, quota tracking, and revenue forecasting. Aligns with SAP SD pricing and SAP FI/CO revenue planning.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedVolumeKg rdf:type rdf:Property ;
    rdfs:label 'Estimated Volume Kg' ;
    rdfs:comment 'Estimated annual or deal-period volume of chemical product(s) in kilograms associated with this opportunity. Used for supply chain capacity planning, raw material procurement forecasting, and production scheduling alignment with SAP PP.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fiscalQuarter rdf:type rdf:Property ;
    rdfs:label 'Fiscal Quarter' ;
    rdfs:comment 'The fiscal quarter in which the opportunity is expected to close, formatted as Q[1-4]-YYYY (e.g., Q3-2024). Used for period-based pipeline reporting, quota attainment tracking, and financial forecasting aligned with SAP FI/CO fiscal calendar.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastCategory rdf:type rdf:Property ;
    rdfs:label 'Forecast Category' ;
    rdfs:comment 'Sales forecast classification assigned to the opportunity, indicating the confidence level for revenue recognition in the current period. Used in executive revenue forecasting and financial planning aligned with SAP FI/CO reporting.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isKeyAccount rdf:type rdf:Property ;
    rdfs:label 'Is Key Account' ;
    rdfs:comment 'Indicates whether this opportunity is associated with a strategically designated key account (True) requiring executive sponsorship, dedicated account management, and priority resource allocation. Used for key account management reporting.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isWon rdf:type rdf:Property ;
    rdfs:label 'Is Won' ;
    rdfs:comment 'Boolean flag indicating whether the opportunity was closed as won (True) or lost/abandoned (False). Null if the opportunity is still open. Used for win rate calculations and pipeline conversion reporting.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastActivityDate rdf:type rdf:Property ;
    rdfs:label 'Last Activity Date' ;
    rdfs:comment 'Date of the most recent sales activity (call, email, meeting, task) logged against this opportunity in Salesforce CRM. Used for pipeline hygiene monitoring, stale opportunity identification, and sales rep engagement tracking. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Modified Timestamp' ;
    rdfs:comment 'Timestamp when the opportunity record was last updated in the source CRM system (Salesforce). Used for change detection, incremental data loading, and audit trail. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:leadSource rdf:type rdf:Property ;
    rdfs:label 'Lead Source' ;
    rdfs:comment 'Channel or origin through which this opportunity was identified or generated. Used for marketing attribution, channel effectiveness analysis, and sales pipeline sourcing analytics. [ENUM-REF-CANDIDATE: Inbound|Trade Show|Referral|Cold Outreach|Distributor|Web|Other — promote to reference product]' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextStep rdf:type rdf:Property ;
    rdfs:label 'Next Step' ;
    rdfs:comment 'Free-text description of the immediate next action required to advance this opportunity (e.g., \'Schedule technical demo\', \'Submit COA for customer qualification\', \'Negotiate pricing terms\'). Used by sales representatives for pipeline management and CRM activity tracking.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opportunityDescription rdf:type rdf:Property ;
    rdfs:label 'Opportunity Description' ;
    rdfs:comment 'Free-text narrative describing the opportunity context, customer requirements, technical application details, and strategic importance. Supports sales team knowledge sharing and opportunity review meetings.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opportunityName rdf:type rdf:Property ;
    rdfs:label 'Opportunity Name' ;
    rdfs:comment 'Human-readable name or title of the sales opportunity, typically describing the customer, product line, and deal context (e.g., \'Acme Corp - Specialty Solvents Q3 2024\'). Used for pipeline reporting and sales team communication.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opportunityType rdf:type rdf:Property ;
    rdfs:label 'Opportunity Type' ;
    rdfs:comment 'Classification of the opportunity by business development type. Distinguishes new customer acquisition from expansion of existing accounts, contract renewals, win-back of lost customers, and channel type (distributor vs. direct). [ENUM-REF-CANDIDATE: New Business|Existing Business Expansion|Renewal|Win-Back|Distributor|Direct — promote to reference product]' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productLine rdf:type rdf:Property ;
    rdfs:label 'Product Line' ;
    rdfs:comment 'The primary chemical product line or portfolio segment associated with this opportunity (e.g., Specialty Solvents, Performance Polymers, Agricultural Chemicals, Adhesives). Used for product-level pipeline and revenue mix reporting.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reachComplianceRequired rdf:type rdf:Property ;
    rdfs:label 'Reach Compliance Required' ;
    rdfs:comment 'Indicates whether the opportunity involves chemical substances subject to REACH registration, evaluation, or authorization requirements under EU regulation. Triggers regulatory compliance review and ECHA documentation workflow.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresCustomFormulation rdf:type rdf:Property ;
    rdfs:label 'Requires Custom Formulation' ;
    rdfs:comment 'Indicates whether this opportunity requires a customer-specific chemical formulation or product development engagement (True) versus a standard catalogue product (False). Triggers R&D and technical sales involvement when True.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresSds rdf:type rdf:Property ;
    rdfs:label 'Requires Sds' ;
    rdfs:comment 'Indicates whether the customer has requested or requires a Safety Data Sheet (SDS) / Material Safety Data Sheet (MSDS) as part of the sales process. Relevant for GHS compliance and REACH regulatory submissions.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:salesChannel rdf:type rdf:Property ;
    rdfs:label 'Sales Channel' ;
    rdfs:comment 'The commercial channel through which this opportunity is being pursued. Distinguishes direct sales from distributor-mediated, agent-based, e-commerce, or tender/bid processes. Used for channel performance analytics and margin analysis.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystem rdf:type rdf:Property ;
    rdfs:label 'Source System' ;
    rdfs:comment 'Identifies the operational system of record from which this opportunity record was sourced (e.g., Salesforce CRM, SAP SD, Manual entry). Used for data lineage tracking and reconciliation in the Databricks lakehouse silver layer.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stage rdf:type rdf:Property ;
    rdfs:label 'Stage' ;
    rdfs:comment 'Current stage of the opportunity in the sales pipeline lifecycle. Drives pipeline forecasting, stage-gate reviews, and funnel conversion analytics. [ENUM-REF-CANDIDATE: Prospecting|Qualification|Needs Analysis|Proposal|Negotiation|Closed Won|Closed Lost — promote to reference product]' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCloseDate rdf:type rdf:Property ;
    rdfs:label 'Target Close Date' ;
    rdfs:comment 'Expected date by which the opportunity will be won or lost. Drives pipeline aging analysis, period-end forecasting, and sales cycle duration reporting. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tscaComplianceRequired rdf:type rdf:Property ;
    rdfs:label 'Tsca Compliance Required' ;
    rdfs:comment 'Indicates whether the opportunity involves chemical substances subject to TSCA inventory listing, reporting, or restriction requirements under US EPA regulation. Triggers regulatory compliance review.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quoteId rdf:type rdf:Property ;
    rdfs:label 'Quote Id' ;
    rdfs:comment 'Unique surrogate identifier for the price quotation record in the lakehouse silver layer. Primary key for the quote entity.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Quote .

ind:contractId rdf:type rdf:Property ;
    rdfs:label 'Contract Id' ;
    rdfs:comment 'Reference to the master pricing agreement or sales contract under which this quotation is issued, linking spot quotes to long-term contractual frameworks.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contract .

ind:materialMasterId rdf:type rdf:Property ;
    rdfs:label 'Material Master Id' ;
    rdfs:comment 'Foreign key linking to rawmaterial.material_master. Business justification: Quote generation attaches SDS, REACH, TSCA compliance data; linking to material_master provides authoritative source for those attributes.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialMaster .

ind:organizationId rdf:type rdf:Property ;
    rdfs:label 'Organization Id' ;
    rdfs:comment 'Reference to the SAP SD sales organization responsible for issuing this quotation, defining the legal selling entity and pricing hierarchy.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Organization .

ind:priceAgreementId rdf:type rdf:Property ;
    rdfs:label 'Price Agreement Id' ;
    rdfs:comment 'Foreign key linking to sales.price_agreement. Business justification: While quote_line already carries a price_agreement_id at the line level, a quote header may be governed by a single overarching price agreement (e.g., a long-term supply agreement or contract price). ' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceAgreement .

ind:qualificationId rdf:type rdf:Property ;
    rdfs:label 'Qualification Id' ;
    rdfs:comment 'Foreign key linking to customer.qualification. Business justification: Chemical quotes must reference the customer qualification record confirming the product grade/spec is approved for that customer\'s use case. Quoting against an unqualified product-customer combination' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Qualification .

ind:sdsId rdf:type rdf:Property ;
    rdfs:label 'Sds Id' ;
    rdfs:comment 'Foreign key linking to product.sds. Business justification: Every chemical quote must reference the current SDS version for OSHA HazCom and REACH regulatory compliance. The sds_version plain-text field is denormalized; FK to sds ensures the correct SDS documen' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sds .

ind:coaRequired rdf:type rdf:Property ;
    rdfs:label 'Coa Required' ;
    rdfs:comment 'Indicates whether the customer requires a Certificate of Analysis (COA) to accompany the chemical product shipment, confirming that the product meets specified quality parameters. Drives LabWare LIMS documentation workflow.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cocRequired rdf:type rdf:Property ;
    rdfs:label 'Coc Required' ;
    rdfs:comment 'Indicates whether the customer requires a Certificate of Compliance (COC) confirming the product meets regulatory, contractual, or customer-specific specification requirements.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:convertedOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Converted Order Number' ;
    rdfs:comment 'SAP SD sales order document number created when this quotation is accepted and converted to a binding sales order, enabling end-to-end quote-to-cash traceability.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmQuoteNumber rdf:type rdf:Property ;
    rdfs:label 'Crm Quote Number' ;
    rdfs:comment 'The Salesforce CRM quote object identifier, enabling bidirectional traceability between the CRM pipeline and the SAP SD quotation document.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerPoNumber rdf:type rdf:Property ;
    rdfs:label 'Customer Po Number' ;
    rdfs:comment 'Customer\'s own Purchase Order (PO) reference number provided with the RFQ or acceptance, required for invoice matching and customer accounts payable reconciliation.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionChannelCode rdf:type rdf:Property ;
    rdfs:label 'Distribution Channel Code' ;
    rdfs:comment 'SAP SD distribution channel code indicating the route to market for this quotation (e.g., direct, distributor, e-commerce), affecting pricing and availability determination.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:divisionCode rdf:type rdf:Property ;
    rdfs:label 'Division Code' ;
    rdfs:comment 'SAP SD division code representing the product line or business unit (e.g., Performance Materials, Agricultural Solutions, Plastics) responsible for this quotation.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exportControlFlag rdf:type rdf:Property ;
    rdfs:label 'Export Control Flag' ;
    rdfs:comment 'Indicates whether any product in this quotation is subject to export control regulations, triggering mandatory compliance review before order conversion (e.g., EAR, ITAR, dual-use chemical controls).' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:grossAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Amount' ;
    rdfs:comment 'Total gross value of the quotation before application of discounts, surcharges, and taxes, expressed in the quotation currency. Supports margin analysis and revenue forecasting.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazmatFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Flag' ;
    rdfs:comment 'Indicates whether the quoted products are classified as hazardous materials under DOT, IATA, or IMDG regulations, requiring special packaging, labeling, and transport documentation.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incotermsCode rdf:type rdf:Property ;
    rdfs:label 'Incoterms Code' ;
    rdfs:comment 'International Commercial Terms (Incoterms 2020) code defining the delivery obligations, risk transfer point, and cost allocation between seller and buyer for chemical product shipments.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incotermsLocation rdf:type rdf:Property ;
    rdfs:label 'Incoterms Location' ;
    rdfs:comment 'Named place or port associated with the Incoterms code, specifying the exact point of delivery or risk transfer (e.g., \'FOB Houston Port\'). Required for complete Incoterms specification per ICC rules.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Updated Timestamp' ;
    rdfs:comment 'The timestamp of the most recent modification to this quotation record, supporting change tracking and incremental data pipeline processing.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:netAmount rdf:type rdf:Property ;
    rdfs:label 'Net Amount' ;
    rdfs:comment 'Net total value of the quotation after all discounts and surcharges but before tax, representing the agreed commercial value. Core metric for margin analysis at the quote level.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentTermsCode rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Code' ;
    rdfs:comment 'SAP SD payment terms key defining the agreed payment schedule, early payment discount conditions, and due date calculation for the customer invoice (e.g., NT30, 2/10NET30).' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceListType rdf:type rdf:Property ;
    rdfs:label 'Price List Type' ;
    rdfs:comment 'Classification of the pricing basis applied to this quotation, determining which SAP SD condition records and pricing procedures are used for calculation.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingDate rdf:type rdf:Property ;
    rdfs:label 'Pricing Date' ;
    rdfs:comment 'The reference date used to determine applicable price lists, condition records, and raw material index values for pricing calculation. May differ from quote_date for forward-priced contracts.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quoteDate rdf:type rdf:Property ;
    rdfs:label 'Quote Date' ;
    rdfs:comment 'The business date on which the quotation was formally issued to the customer or distributor. Represents the principal real-world event date for this transaction.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quoteStatus rdf:type rdf:Property ;
    rdfs:label 'Quote Status' ;
    rdfs:comment 'Current lifecycle state of the quotation, tracking progression from initial draft through customer acceptance or expiry. [ENUM-REF-CANDIDATE: draft|submitted|under_review|approved|rejected|expired|converted|cancelled — promote to reference product]' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quoteType rdf:type rdf:Property ;
    rdfs:label 'Quote Type' ;
    rdfs:comment 'Classification of the quotation by commercial purpose: standard customer quote, spot market offer, contract pricing, distributor channel, intercompany transfer, or product sample. [ENUM-REF-CANDIDATE: standard|spot|contract|distributor|intercompany|sample — promote to reference product]' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reachCompliant rdf:type rdf:Property ;
    rdfs:label 'Reach Compliant' ;
    rdfs:comment 'Indicates whether all chemical substances in this quotation are registered and compliant under REACH Regulation (EC) No 1907/2006 for the destination market, required for EU export.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rejectionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason Code' ;
    rdfs:comment 'Coded reason for quotation rejection or loss, populated when quote_status transitions to rejected or cancelled. Supports win/loss analysis and competitive intelligence. [ENUM-REF-CANDIDATE: price_too_high|competitor_selected|spec_mismatch|delivery_terms|no_decision|budget_cancelled — promote to reference product]' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Requested Delivery Date' ;
    rdfs:comment 'Customer-requested delivery date for the quoted chemical products, used for production scheduling, ATP (Available-to-Promise) checks, and logistics planning.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:salesDistrictCode rdf:type rdf:Property ;
    rdfs:label 'Sales District Code' ;
    rdfs:comment 'SAP SD sales district code identifying the geographic territory assignment for this quotation, used for territory management, sales performance reporting, and commission calculation.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapQuotationNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Quotation Number' ;
    rdfs:comment 'The externally-known 10-digit SAP SD quotation document number used for cross-system reference and customer-facing communication.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipToCountryCode rdf:type rdf:Property ;
    rdfs:label 'Ship To Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the destination country for chemical product delivery. Drives export control screening, REACH compliance checks, and hazardous material transport regulations.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Amount' ;
    rdfs:comment 'Total tax amount applicable to the quotation, including VAT, GST, or applicable excise duties on chemical products, calculated per the customer\'s tax jurisdiction.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:technicalNotes rdf:type rdf:Property ;
    rdfs:label 'Technical Notes' ;
    rdfs:comment 'Free-text field capturing technical sales notes, application guidance, customer-specific formulation requirements, or special handling instructions relevant to the quoted chemical products.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalDiscountAmount rdf:type rdf:Property ;
    rdfs:label 'Total Discount Amount' ;
    rdfs:comment 'Aggregate monetary discount applied across all line items on the quotation, including volume rebates, customer-specific pricing adjustments, and promotional discounts.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalSurchargeAmount rdf:type rdf:Property ;
    rdfs:label 'Total Surcharge Amount' ;
    rdfs:comment 'Aggregate surcharges applied at the header level, including energy surcharges, raw material index surcharges, hazardous material handling fees, and freight surcharges.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validFromDate rdf:type rdf:Property ;
    rdfs:label 'Valid From Date' ;
    rdfs:comment 'The start date from which the quoted prices, terms, and conditions are binding and may be accepted by the customer.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validToDate rdf:type rdf:Property ;
    rdfs:label 'Valid To Date' ;
    rdfs:comment 'The expiry date after which the quoted prices and terms are no longer binding. Drives automated expiry workflows and renewal alerts.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:winProbabilityPct rdf:type rdf:Property ;
    rdfs:label 'Win Probability Pct' ;
    rdfs:comment 'Sales representative\'s estimated probability (0.00–100.00%) that this quotation will be accepted and converted to a sales order, used for pipeline forecasting and revenue planning.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quoteLineId rdf:type rdf:Property ;
    rdfs:label 'Quote Line Id' ;
    rdfs:comment 'Unique surrogate identifier for each individual line item within a customer quote. Primary key for the quote_line entity in the Databricks Silver Layer.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QuoteLine .

ind:casRegistryId rdf:type rdf:Property ;
    rdfs:label 'Cas Registry Id' ;
    rdfs:comment 'Foreign key linking to rawmaterial.cas_registry. Business justification: quote_line.cas_number is a denormalized reference to cas_registry. Chemical quote lines must reference the regulated substance for export control screening, REACH/TSCA compliance flagging, and hazmat ' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CasRegistry .

ind:chemicalProductId rdf:type rdf:Property ;
    rdfs:label 'Chemical Product Id' ;
    rdfs:comment 'Reference to the chemical product, grade, or Stock Keeping Unit (SKU) being quoted on this line. Links to the product master for full material specifications.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ChemicalProduct .

ind:coaTemplateId rdf:type rdf:Property ;
    rdfs:label 'Coa Template Id' ;
    rdfs:comment 'Foreign key linking to quality.coa_template. Business justification: quote_line has coa_required flag. When CoA is required, the specific template must be designated at line level since different products/grades use different certificate formats. This drives automated ' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CoaTemplate .

ind:equipmentId rdf:type rdf:Property ;
    rdfs:label 'Equipment Id' ;
    rdfs:comment 'Foreign key linking to maintenance.equipment. Business justification: Specialty chemical quote lines (process chemicals, lubricants, catalysts) are written for specific customer equipment (reactors, columns, tanks). This link enables equipment-specific pricing, technica' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Equipment .

ind:functionalLocationId rdf:type rdf:Property ;
    rdfs:label 'Functional Location Id' ;
    rdfs:comment 'Reference to the manufacturing plant or distribution center designated to fulfill this quote line. Determines production scheduling, inventory sourcing, and applicable plant-level pricing.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FunctionalLocation .

ind:glAccountId rdf:type rdf:Property ;
    rdfs:label 'Gl Account Id' ;
    rdfs:comment 'Foreign key linking to finance.gl_account. Business justification: Revenue posting requires each quote line to map to a GL account for accurate financial reporting and downstream invoicing.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:gradeId rdf:type rdf:Property ;
    rdfs:label 'Grade Id' ;
    rdfs:comment 'Foreign key linking to product.grade. Business justification: Chemical grade (USP, ACS, technical) is a primary commercial differentiator on quote lines, driving price tier, regulatory compliance requirements, and COA/COC obligations. The product_grade plain-tex' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Grade .

ind:lotId rdf:type rdf:Property ;
    rdfs:label 'Lot Id' ;
    rdfs:comment 'Foreign key linking to inventory.lot. Business justification: Available-to-promise quoting: in chemical manufacturing, quote lines for spot sales or batch-specific products reference a specific inventory lot to confirm availability, purity, COA/COC details, and ' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lot .

ind:packagingConfigId rdf:type rdf:Property ;
    rdfs:label 'Packaging Config Id' ;
    rdfs:comment 'Foreign key linking to product.packaging_config. Business justification: Packaging configuration drives hazmat surcharges, UN certification requirements, and freight cost on chemical quote lines. The packaging_type plain-text field is denormalized; FK to packaging_config e' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PackagingConfig .

ind:safetyDataSheetId rdf:type rdf:Property ;
    rdfs:label 'Safety Data Sheet Id' ;
    rdfs:comment 'Foreign key linking to ehs.safety_data_sheet. Business justification: OSHA HazCom 2012 / GHS / REACH require the current SDS version be attached to customer quote lines for hazardous chemical products. Sales teams must reference the authoritative EHS SDS record per prod' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SafetyDataSheet .

ind:skuId rdf:type rdf:Property ;
    rdfs:label 'Sku Id' ;
    rdfs:comment 'Foreign key linking to product.sku. Business justification: Quote lines in chemical manufacturing are written at SKU level (specific pack size/configuration). The sku_code plain-text field is a denormalized reference; a proper FK to sku enables automated SDS v' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:batchManaged rdf:type rdf:Property ;
    rdfs:label 'Batch Managed' ;
    rdfs:comment 'Indicates whether the chemical product on this quote line is subject to batch management and lot traceability requirements. Batch-managed products require Certificate of Analysis (COA) per lot and full GMP traceability.' ;
    rdfs:domain ind:QuoteLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:confirmedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Confirmed Delivery Date' ;
    rdfs:comment 'Seller-confirmed delivery date for this quote line after Available-to-Promise (ATP) check and production capacity validation. May differ from the requested delivery date.' ;
    rdfs:domain ind:QuoteLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contributionMargin rdf:type rdf:Property ;
    rdfs:label 'Contribution Margin' ;
    rdfs:comment 'Gross contribution margin for this quote line, calculated as line net amount minus total standard cost. Expressed in the transaction currency. Enables profitability analysis at the product-grade level during the quoting process. Commercially sensitive.' ;
    rdfs:domain ind:QuoteLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Delivery Lead Time Days' ;
    rdfs:comment 'Estimated number of calendar days from order confirmation to delivery at the agreed delivery point for this quote line. Accounts for production scheduling, inventory availability, and logistics transit time.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:discountAmount rdf:type rdf:Property ;
    rdfs:label 'Discount Amount' ;
    rdfs:comment 'Absolute monetary value of the discount applied to this quote line in the transaction currency. Derived from discount_percent applied to line_gross_amount. Stored explicitly for audit and margin reporting.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discountPercent rdf:type rdf:Property ;
    rdfs:label 'Discount Percent' ;
    rdfs:comment 'Percentage discount applied to this quote line, representing negotiated price reductions from the list price. Includes volume discounts, customer-specific pricing agreements, and promotional discounts. Commercially sensitive.' ;
    rdfs:domain ind:QuoteLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazardClass rdf:type rdf:Property ;
    rdfs:label 'Hazard Class' ;
    rdfs:comment 'Globally Harmonized System (GHS) hazard classification for the chemical product on this quote line (e.g., Flammable Liquid Class 3, Corrosive, Toxic). Drives hazmat surcharge applicability, packaging requirements, and transport documentation. [ENUM-REF-CANDIDATE: FLAMMABLE_LIQUID|FLAMMABLE_SOLID|OXIDIZER|TOXIC|CORROSIVE|EXPLOSIVE|COMPRESSED_GAS|ENVIRONMENTAL_HAZARD|NON_HAZARDOUS — promote to reference product]' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatSurcharge rdf:type rdf:Property ;
    rdfs:label 'Hazmat Surcharge' ;
    rdfs:comment 'Additional surcharge applied to this quote line for hazardous chemical handling, packaging, labeling, and transport compliance costs. Applicable for products classified under DOT, IATA, or IMDG dangerous goods regulations.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incotermCode rdf:type rdf:Property ;
    rdfs:label 'Incoterm Code' ;
    rdfs:comment 'International Commercial Terms (Incoterms 2020) code defining the delivery obligations, risk transfer point, and cost responsibilities between seller and buyer for this quote line. Affects freight cost allocation and logistics planning. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:QuoteLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineGrossAmount rdf:type rdf:Property ;
    rdfs:label 'Line Gross Amount' ;
    rdfs:comment 'Gross monetary value of this quote line before any discounts or surcharges, calculated as quantity multiplied by unit price in the transaction currency. Used as the baseline for margin and discount analysis.' ;
    rdfs:domain ind:QuoteLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineNetAmount rdf:type rdf:Property ;
    rdfs:label 'Line Net Amount' ;
    rdfs:comment 'Net monetary value of this quote line after applying all discounts and surcharges (gross amount minus discounts plus surcharges) in the transaction currency. Represents the actual quoted value to the customer for this line.' ;
    rdfs:domain ind:QuoteLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineNumber rdf:type rdf:Property ;
    rdfs:label 'Line Number' ;
    rdfs:comment 'Sequential position of this line item within the parent quote, used for ordering and referencing individual items. Corresponds to SAP SD item number (e.g., 10, 20, 30).' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lineStatus rdf:type rdf:Property ;
    rdfs:label 'Line Status' ;
    rdfs:comment 'Current workflow status of this individual quote line item. Allows partial acceptance or rejection of lines within a multi-line quote. Draft: under preparation; Open: submitted to customer; Revised: updated after customer feedback; Accepted: customer confirmed; Rejected: customer declined; Cancelled: withdrawn by seller.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialNumber rdf:type rdf:Property ;
    rdfs:label 'Material Number' ;
    rdfs:comment 'SAP material number (MATNR) identifying the specific chemical product or grade being quoted. Used for cross-referencing with SAP MM and PP modules for production planning and inventory availability.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceUom rdf:type rdf:Property ;
    rdfs:label 'Price Uom' ;
    rdfs:comment 'Unit of measure basis for the unit price (e.g., price per KG, price per MT). May differ from the sales UOM when pricing is expressed per metric ton but sold in drums. Required for accurate line value calculation. [ENUM-REF-CANDIDATE: KG|MT|L|GAL|LB|DRUM|IBC|BAG|TON|M3 — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productDescription rdf:type rdf:Property ;
    rdfs:label 'Product Description' ;
    rdfs:comment 'Human-readable description of the chemical product or grade being quoted, including trade name, grade designation, and key specification identifiers as presented to the customer.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantity rdf:type rdf:Property ;
    rdfs:label 'Quantity' ;
    rdfs:comment 'The quantity of the chemical product being quoted on this line. Expressed in the unit of measure specified in the uom field. Supports bulk chemical quantities in kg, MT, L, or container counts.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdsRequired rdf:type rdf:Property ;
    rdfs:label 'Sds Required' ;
    rdfs:comment 'Indicates whether a Safety Data Sheet (SDS) must be provided to the customer with this quote line. Mandatory for hazardous chemical substances under GHS/OSHA HazCom 2012 and REACH regulations.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:smallOrderSurcharge rdf:type rdf:Property ;
    rdfs:label 'Small Order Surcharge' ;
    rdfs:comment 'Additional surcharge applied when the quoted quantity falls below the Minimum Order Quantity (MOQ) threshold for this product. Covers incremental handling and packaging costs for sub-MOQ orders.' ;
    rdfs:domain ind:QuoteLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardCost rdf:type rdf:Property ;
    rdfs:label 'Standard Cost' ;
    rdfs:comment 'Internal standard cost per unit of measure for the chemical product on this line, sourced from SAP CO (Controlling). Used to calculate contribution margin and Cost of Goods Sold (COGS) at the quote line level. Commercially sensitive internal data.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageLocation rdf:type rdf:Property ;
    rdfs:label 'Storage Location' ;
    rdfs:comment 'SAP storage location code within the delivering plant from which the chemical product will be sourced for this quote line. Relevant for inventory reservation and warehouse management.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tscaCompliant rdf:type rdf:Property ;
    rdfs:label 'Tsca Compliant' ;
    rdfs:comment 'Indicates whether the chemical substance on this quote line is listed on the TSCA Chemical Substance Inventory and compliant with applicable TSCA requirements for US domestic sales.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unNumber rdf:type rdf:Property ;
    rdfs:label 'Un Number' ;
    rdfs:comment 'United Nations dangerous goods number (e.g., UN1090 for Acetone) assigned to the hazardous chemical on this quote line. Required for transport documentation, hazmat labeling, and emergency response planning under DOT and IMDG regulations.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitPrice rdf:type rdf:Property ;
    rdfs:label 'Unit Price' ;
    rdfs:comment 'Quoted price per unit of measure for the chemical product on this line, expressed in the transaction currency. Represents the base list or negotiated price before surcharges and discounts. Commercially sensitive pricing data.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:uom rdf:type rdf:Property ;
    rdfs:label 'Uom' ;
    rdfs:comment 'Unit of measure for the quoted quantity (e.g., KG - kilograms, MT - metric tons, L - litres, GAL - gallons, LB - pounds, DRUM - 200L drum units, IBC - intermediate bulk containers, BAG - bag units, TON - short tons, M3 - cubic meters). Critical for chemical pricing and logistics planning. [ENUM-REF-CANDIDATE: KG|MT|L|GAL|LB|DRUM|IBC|BAG|TON|M3 — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementName rdf:type rdf:Property ;
    rdfs:label 'Agreement Name' ;
    rdfs:comment 'Descriptive name or title of the pricing agreement as referenced internally and in customer negotiations (e.g., \'FY2025 Polyethylene Supply Agreement - Acme Corp\').' ;
    rdfs:domain ind:PriceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementNumber rdf:type rdf:Property ;
    rdfs:label 'Agreement Number' ;
    rdfs:comment 'Externally-known business identifier for the pricing agreement, typically matching the SAP SD condition contract number or Salesforce CRM contract number. Used in customer-facing communications and purchase orders.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementStatus rdf:type rdf:Property ;
    rdfs:label 'Agreement Status' ;
    rdfs:comment 'Current lifecycle state of the pricing agreement. Draft = under preparation; Pending Approval = submitted for internal authorization; Active = in force and applicable to orders; Suspended = temporarily halted; Expired = past effective end date; Terminated = ended before expiry by mutual or unilateral action; Cancelled = voided before activation. [ENUM-REF-CANDIDATE: draft|pending_approval|active|suspended|expired|terminated|cancelled — promote to reference product]' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementType rdf:type rdf:Property ;
    rdfs:label 'Agreement Type' ;
    rdfs:comment 'Classification of the pricing agreement by commercial structure. Contract Price = fixed negotiated unit price; Volume Rebate = retrospective rebate based on volume thresholds; Long-Term Supply = multi-year supply commitment with pricing; Spot Price = short-term market-based pricing; Distributor Price = channel partner pricing. [ENUM-REF-CANDIDATE: contract_price|volume_rebate|long_term_supply|spot_price|distributor_price|framework — promote to reference product if additional types emerge]' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualVolumeCommitment rdf:type rdf:Property ;
    rdfs:label 'Annual Volume Commitment' ;
    rdfs:comment 'The total annual volume the customer has committed to purchase under this agreement, expressed in the price UOM. Used to validate volume rebate eligibility and supply planning. Corresponds to long-term supply agreement volume commitments.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvalStatus rdf:type rdf:Property ;
    rdfs:label 'Approval Status' ;
    rdfs:comment 'Internal authorization status of the pricing agreement through the commercial approval workflow. Pending = awaiting review; Approved = authorized by required approvers; Rejected = declined; Revision Required = returned for amendment. Distinct from agreement_status which reflects the commercial lifecycle.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedBy rdf:type rdf:Property ;
    rdfs:label 'Approved By' ;
    rdfs:comment 'Name or employee ID of the internal approver (e.g., Sales Director, Commercial Manager) who authorized this pricing agreement. Required for SOX audit trail and pricing governance.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedDate rdf:type rdf:Property ;
    rdfs:label 'Approved Date' ;
    rdfs:comment 'Date on which the pricing agreement received final internal approval and was authorized for commercial use.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:baseUnitPrice rdf:type rdf:Property ;
    rdfs:label 'Base Unit Price' ;
    rdfs:comment 'The negotiated base price per unit of measure for the primary product or grade covered by this agreement, expressed in the agreement currency. For volume-rebate agreements, this represents the list price before rebate calculation.' ;
    rdfs:domain ind:PriceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:distributionChannel rdf:type rdf:Property ;
    rdfs:label 'Distribution Channel' ;
    rdfs:comment 'SAP SD distribution channel through which the product is sold under this agreement. Direct = sold directly to end customer; Distributor = sold through channel partner; Toll Manufacturing = customer-owned feedstock processing; Export = cross-border sales.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveEndDate rdf:type rdf:Property ;
    rdfs:label 'Effective End Date' ;
    rdfs:comment 'The date on which the pricing agreement ceases to be binding. Nullable for open-ended agreements. Corresponds to SAP SD condition validity end date (DATBI).' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Effective Start Date' ;
    rdfs:comment 'The date from which the pricing agreement becomes binding and applicable to customer orders. Corresponds to SAP SD condition validity start date (DATAB).' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:escalationFrequency rdf:type rdf:Property ;
    rdfs:label 'Escalation Frequency' ;
    rdfs:comment 'Frequency at which price escalation reviews and adjustments are performed under the escalation clause. Null if no escalation clause applies.' ;
    rdfs:domain ind:PriceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationIndex rdf:type rdf:Property ;
    rdfs:label 'Escalation Index' ;
    rdfs:comment 'Name or code of the external index used to calculate price escalations under the escalation clause (e.g., \'ICIS Ethylene Index\', \'US CPI\', \'Henry Hub Natural Gas\', \'Platts Benzene\'). Null if no escalation clause applies.' ;
    rdfs:domain ind:PriceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minOrderQty rdf:type rdf:Property ;
    rdfs:label 'Min Order Qty' ;
    rdfs:comment 'Minimum order quantity (MOQ) the customer must place per order to qualify for the contracted price. Expressed in the price UOM. Below this threshold, standard list pricing may apply.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:notes rdf:type rdf:Property ;
    rdfs:label 'Notes' ;
    rdfs:comment 'Free-text field for capturing additional commercial terms, negotiation context, special conditions, or internal commentary related to this pricing agreement that are not captured in structured fields.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noticePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Notice Period Days' ;
    rdfs:comment 'Number of calendar days\' advance notice required by either party to terminate or not renew this pricing agreement. Critical for supply chain continuity planning and customer retention management.' ;
    rdfs:domain ind:PriceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priceEscalationClause rdf:type rdf:Property ;
    rdfs:label 'Price Escalation Clause' ;
    rdfs:comment 'Indicates whether the agreement contains a price escalation clause allowing periodic price adjustments based on raw material indices, energy costs, or inflation benchmarks (e.g., CPI, feedstock index). True = escalation clause present.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricePerQty rdf:type rdf:Property ;
    rdfs:label 'Price Per Qty' ;
    rdfs:comment 'The quantity denominator for the unit price (e.g., price per 100 KG, price per 1000 LB). Corresponds to SAP SD condition pricing quantity (KONP.KPEIN). Enables accurate per-unit price calculation when price is expressed per batch or bulk quantity.' ;
    rdfs:domain ind:PriceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productGrade rdf:type rdf:Property ;
    rdfs:label 'Product Grade' ;
    rdfs:comment 'Specific chemical product grade or specification covered by this pricing agreement (e.g., \'Polyethylene HD-5502\', \'Benzene 99.9% Pure\', \'Sulfuric Acid Technical Grade\'). Aligns with SAP SD material number or product hierarchy.' ;
    rdfs:domain ind:PriceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rebatePct rdf:type rdf:Property ;
    rdfs:label 'Rebate Pct' ;
    rdfs:comment 'Retrospective volume rebate percentage applied to the customer\'s total purchases when volume thresholds are met. Expressed as a percentage of net sales value. Applicable for volume rebate agreement types. Null for contract price agreements.' ;
    rdfs:domain ind:PriceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rebateThresholdQty rdf:type rdf:Property ;
    rdfs:label 'Rebate Threshold Qty' ;
    rdfs:comment 'Minimum cumulative purchase quantity (in volume_commitment_uom) the customer must reach within the agreement period to qualify for the rebate percentage. Used in volume rebate agreement types.' ;
    rdfs:domain ind:PriceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewalType rdf:type rdf:Property ;
    rdfs:label 'Renewal Type' ;
    rdfs:comment 'Defines how the pricing agreement is renewed at expiry. Auto Renew = automatically extends for the same term unless cancelled; Manual Renew = requires explicit renegotiation; No Renewal = single-term agreement with no renewal provision.' ;
    rdfs:domain ind:PriceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapConditionContractNo rdf:type rdf:Property ;
    rdfs:label 'Sap Condition Contract No' ;
    rdfs:comment 'The SAP SD condition contract number (KONA.KNUMA_AG) that is the system-of-record identifier for this pricing agreement in SAP S/4HANA. Enables traceability back to the operational source system.' ;
    rdfs:domain ind:PriceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surchargeAmount rdf:type rdf:Property ;
    rdfs:label 'Surcharge Amount' ;
    rdfs:comment 'Fixed surcharge amount per price UOM added to the base unit price. Expressed in the agreement currency. Null if surcharge_type is \'none\' or if surcharge is percentage-based.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:surchargeType rdf:type rdf:Property ;
    rdfs:label 'Surcharge Type' ;
    rdfs:comment 'Type of surcharge applicable to this agreement in addition to the base unit price. Energy = energy cost surcharge; Freight = logistics/transport surcharge; Raw Material = feedstock cost pass-through; Hazmat = hazardous materials handling surcharge per DOT/IATA; None = no surcharge. [ENUM-REF-CANDIDATE: energy|freight|raw_material|hazmat|regulatory|currency|none — promote to reference product]' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeCommitmentUom rdf:type rdf:Property ;
    rdfs:label 'Volume Commitment Uom' ;
    rdfs:comment 'Unit of measure for the annual volume commitment quantity (e.g., MT = metric ton, KG = kilogram). May differ from price UOM for large-volume chemical supply agreements. [ENUM-REF-CANDIDATE: KG|MT|LB|L|GAL|EA|BAG|DR|IBC — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PriceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceAgreementLineId rdf:type rdf:Property ;
    rdfs:label 'Price Agreement Line Id' ;
    rdfs:comment 'Unique surrogate identifier for each individual product-level pricing line within a price agreement. Primary key for this entity in the Databricks Silver Layer.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceAgreementLine .

ind:agreedUnitPrice rdf:type rdf:Property ;
    rdfs:label 'Agreed Unit Price' ;
    rdfs:comment 'Negotiated price per unit of measure for the chemical product on this pricing line. Represents the base contractual price before surcharges, rebates, or volume discounts are applied.' ;
    rdfs:domain ind:PriceAgreementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conditionTypeCode rdf:type rdf:Property ;
    rdfs:label 'Condition Type Code' ;
    rdfs:comment 'SAP SD pricing condition type code identifying the nature of the pricing condition on this line (e.g., PR00 for base price, ZK01 for customer-specific price, RA01 for rebate). Drives pricing determination in SAP SD.' ;
    rdfs:domain ind:PriceAgreementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveDate rdf:type rdf:Property ;
    rdfs:label 'Effective Date' ;
    rdfs:comment 'Date from which this product-level pricing line becomes valid and applicable for customer orders. Aligns with the SAP SD condition record validity start date.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expiryDate rdf:type rdf:Property ;
    rdfs:label 'Expiry Date' ;
    rdfs:comment 'Date on which this product-level pricing line ceases to be valid. After this date, the agreed price is no longer applicable unless the agreement is renewed. Aligns with SAP SD condition validity end date.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:indexAdjustmentFormula rdf:type rdf:Property ;
    rdfs:label 'Index Adjustment Formula' ;
    rdfs:comment 'Description or formula defining how the price index is applied to adjust the agreed unit price (e.g., \'Base price + 0.85 * (current month ICIS ethylene - reference ethylene price)\'). Captures the contractual price escalation mechanism.' ;
    rdfs:domain ind:PriceAgreementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Min Order Quantity' ;
    rdfs:comment 'Minimum quantity the customer must order per transaction to qualify for the agreed price on this line. Enforces contractual MOQ commitments common in chemical supply agreements.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plantCode rdf:type rdf:Property ;
    rdfs:label 'Plant Code' ;
    rdfs:comment 'SAP plant code identifying the manufacturing or distribution facility from which the chemical product on this pricing line is to be supplied. Determines sourcing, logistics costs, and applicable freight surcharges.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceIndexLinked rdf:type rdf:Property ;
    rdfs:label 'Price Index Linked' ;
    rdfs:comment 'Indicates whether the agreed unit price on this line is linked to a commodity or raw material price index (e.g., ethylene cracker margin, benzene spot price, crude oil index). Common in long-term chemical supply contracts.' ;
    rdfs:domain ind:PriceAgreementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priceIndexName rdf:type rdf:Property ;
    rdfs:label 'Price Index Name' ;
    rdfs:comment 'Name or code of the commodity or raw material price index to which this pricing line is linked (e.g., \'ICIS Ethylene NWE\', \'Platts Benzene FOB Korea\', \'WTI Crude Oil\'). Populated only when price_index_linked is true.' ;
    rdfs:domain ind:PriceAgreementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricePerQuantity rdf:type rdf:Property ;
    rdfs:label 'Price Per Quantity' ;
    rdfs:comment 'The quantity base (denominator) for the agreed unit price, indicating how many units the price applies to (e.g., price per 1 KG, price per 100 KG, price per 1000 L). Corresponds to SAP SD condition pricing unit (KPEIN).' ;
    rdfs:domain ind:PriceAgreementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rebateBasis rdf:type rdf:Property ;
    rdfs:label 'Rebate Basis' ;
    rdfs:comment 'The calculation basis on which the rebate percentage is applied: invoice value, net sales value, volume in kilograms, or volume in metric tons. Determines how rebate accruals are computed in SAP SD.' ;
    rdfs:domain ind:PriceAgreementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rebatePercent rdf:type rdf:Property ;
    rdfs:label 'Rebate Percent' ;
    rdfs:comment 'Percentage rebate to be credited back to the customer on purchases of this product line, typically settled periodically (monthly, quarterly, annually). Supports SAP SD rebate agreement processing.' ;
    rdfs:domain ind:PriceAgreementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:surchargePercent rdf:type rdf:Property ;
    rdfs:label 'Surcharge Percent' ;
    rdfs:comment 'Percentage-based surcharge applied to the agreed unit price for this line. Used when the surcharge is calculated as a proportion of the base price (e.g., 2.5% raw material index surcharge).' ;
    rdfs:domain ind:PriceAgreementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:takeOrPayFlag rdf:type rdf:Property ;
    rdfs:label 'Take Or Pay Flag' ;
    rdfs:comment 'Indicates whether this pricing line is subject to a take-or-pay clause, requiring the customer to purchase the committed volume or pay a penalty for the shortfall. Common in long-term chemical feedstock agreements.' ;
    rdfs:domain ind:PriceAgreementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tier1MinQty rdf:type rdf:Property ;
    rdfs:label 'Tier 1 Min Qty' ;
    rdfs:comment 'Minimum order quantity threshold for the first volume break tier. Orders at or above this quantity qualify for the Tier 1 discounted unit price.' ;
    rdfs:domain ind:PriceAgreementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tier1UnitPrice rdf:type rdf:Property ;
    rdfs:label 'Tier 1 Unit Price' ;
    rdfs:comment 'Agreed unit price applicable when the order quantity meets or exceeds the Tier 1 minimum quantity threshold. Represents the first volume discount price break.' ;
    rdfs:domain ind:PriceAgreementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tier2MinQty rdf:type rdf:Property ;
    rdfs:label 'Tier 2 Min Qty' ;
    rdfs:comment 'Minimum order quantity threshold for the second volume break tier. Orders at or above this quantity qualify for the Tier 2 discounted unit price.' ;
    rdfs:domain ind:PriceAgreementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tier2UnitPrice rdf:type rdf:Property ;
    rdfs:label 'Tier 2 Unit Price' ;
    rdfs:comment 'Agreed unit price applicable when the order quantity meets or exceeds the Tier 2 minimum quantity threshold. Represents the second volume discount price break.' ;
    rdfs:domain ind:PriceAgreementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tier3MinQty rdf:type rdf:Property ;
    rdfs:label 'Tier 3 Min Qty' ;
    rdfs:comment 'Minimum order quantity threshold for the third volume break tier. Orders at or above this quantity qualify for the Tier 3 discounted unit price.' ;
    rdfs:domain ind:PriceAgreementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tier3UnitPrice rdf:type rdf:Property ;
    rdfs:label 'Tier 3 Unit Price' ;
    rdfs:comment 'Agreed unit price applicable when the order quantity meets or exceeds the Tier 3 minimum quantity threshold. Represents the third volume discount price break.' ;
    rdfs:domain ind:PriceAgreementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeTierFlag rdf:type rdf:Property ;
    rdfs:label 'Volume Tier Flag' ;
    rdfs:comment 'Indicates whether this pricing line has volume break tiers defined, where the unit price decreases as order quantity increases. When true, volume tier records are associated with this line.' ;
    rdfs:domain ind:PriceAgreementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:volumeTierType rdf:type rdf:Property ;
    rdfs:label 'Volume Tier Type' ;
    rdfs:comment 'Basis on which volume break tiers are calculated: by order quantity (units/weight), by order value (monetary), or by weight (metric tons). Determines how SAP SD scale pricing is evaluated.' ;
    rdfs:domain ind:PriceAgreementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterId rdf:type rdf:Property ;
    rdfs:label 'Cost Center Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_center. Business justification: Territory expense allocation report tracks costs per cost center, linking territory to its responsible cost center.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:maintenancePlantId rdf:type rdf:Property ;
    rdfs:label 'Maintenance Plant Id' ;
    rdfs:comment 'Foreign key linking to maintenance.plant. Business justification: Sales territories in chemical manufacturing are served by specific manufacturing plants, driving delivery lead time commitments, freight cost estimates, and regional supply planning. Territory-to-plan' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaintenancePlant .

ind:parentTerritoryId rdf:type rdf:Property ;
    rdfs:label 'Parent Territory Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the parent territory in the hierarchy. Enables rollup of sales performance, quota, and commission data from local to regional to global levels. Null for top-level global territories.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Territory .

ind:annualQuotaUsd rdf:type rdf:Property ;
    rdfs:label 'Annual Quota Usd' ;
    rdfs:comment 'Annual revenue quota assigned to this territory in US Dollars. Used for sales performance measurement, commission calculation, and territory planning. Represents the revenue target the territory is expected to achieve within the fiscal year.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:channelType rdf:type rdf:Property ;
    rdfs:label 'Channel Type' ;
    rdfs:comment 'Primary sales channel model for this territory. Direct indicates company-employed sales reps selling directly to end customers; distributor indicates third-party channel partners; agent indicates commissioned agents; e_commerce indicates digital self-service; hybrid combines multiple channels.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionPlanCode rdf:type rdf:Property ;
    rdfs:label 'Commission Plan Code' ;
    rdfs:comment 'Code identifying the commission plan applicable to this territory. Determines how sales revenue generated within the territory is translated into commission payments for assigned representatives. Managed in SAP FI/CO and HR incentive compensation systems.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryCode rdf:type rdf:Property ;
    rdfs:label 'Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 three-letter country code for the primary country covered by this territory (e.g., \'USA\', \'DEU\', \'CHN\'). Used for regulatory compliance reporting (REACH, TSCA, EPA) and international sales analytics.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerCount rdf:type rdf:Property ;
    rdfs:label 'Customer Count' ;
    rdfs:comment 'Number of active customer accounts assigned to this territory at the time of last update. Used for territory sizing, workload balancing, and sales force planning in the chemical sales organization.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fiscalYear rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year' ;
    rdfs:comment 'Fiscal year (four-digit integer, e.g., 2024) for which the territory quota and performance targets are defined. Aligns with the company\'s SAP FI/CO fiscal year configuration.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatHandlingRequired rdf:type rdf:Property ;
    rdfs:label 'Hazmat Handling Required' ;
    rdfs:comment 'Indicates whether sales activities in this territory involve hazardous chemical products requiring special handling, DOT transport compliance, GHS labeling, or OSHA PSM considerations. Drives compliance training requirements for assigned reps.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Level' ;
    rdfs:comment 'Position of this territory within the sales territory hierarchy. Global is the top-level rollup; regional covers multi-country or multi-state zones; area covers sub-regional clusters; local is the lowest-level individual rep territory.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industryVertical rdf:type rdf:Property ;
    rdfs:label 'Industry Vertical' ;
    rdfs:comment 'Target customer industry vertical served by this territory (e.g., \'Automotive\', \'Construction\', \'Electronics\', \'Consumer Goods\', \'Agriculture\', \'Pharmaceuticals\'). Supports industry-specific sales strategy and product application guidance for chemical products. [ENUM-REF-CANDIDATE: automotive|construction|electronics|consumer_goods|agriculture|pharmaceuticals|coatings|food_beverage|oil_gas|textiles — promote to reference product]' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastRealignmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Realignment Date' ;
    rdfs:comment 'Date of the most recent territory realignment or restructuring event. Territory realignments in chemical sales organizations occur during annual planning cycles, mergers, or strategic pivots. Used to track territory stability and assess impact on quota attribution.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:namedAccountFlag rdf:type rdf:Property ;
    rdfs:label 'Named Account Flag' ;
    rdfs:comment 'Indicates whether this territory is defined as a named-account territory (True) rather than a geographic or vertical territory (False). Named account territories in chemical sales are assigned to specific strategic customers regardless of geography.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productLineScope rdf:type rdf:Property ;
    rdfs:label 'Product Line Scope' ;
    rdfs:comment 'Comma-delimited list or description of chemical product lines assigned to this territory (e.g., \'Specialty Resins, Performance Coatings\', \'Agricultural Herbicides\'). Defines which product categories the territory rep is authorized to sell. [ENUM-REF-CANDIDATE: specialty_chemicals|performance_materials|agricultural_solutions|plastics|coatings|adhesives|solvents|catalysts — promote to reference product]' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Quota Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the territory quota (e.g., \'USD\', \'EUR\', \'CNY\'). Supports multi-currency quota management for international chemical sales territories.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reachRegulatedFlag rdf:type rdf:Property ;
    rdfs:label 'Reach Regulated Flag' ;
    rdfs:comment 'Indicates whether this territory operates under European REACH (Registration, Evaluation, Authorisation and Restriction of Chemicals) regulation, requiring compliance documentation for chemical substances sold. Relevant for EU/EEA territories.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regionCode rdf:type rdf:Property ;
    rdfs:label 'Region Code' ;
    rdfs:comment 'Standardized geographic region code for the territory (e.g., \'NOAM\', \'EMEA\', \'APAC\', \'LATAM\'). Used for geographic rollup reporting and multi-regional sales performance analysis.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repAssignmentEndDate rdf:type rdf:Property ;
    rdfs:label 'Rep Assignment End Date' ;
    rdfs:comment 'Date on which the current primary sales representative assignment to this territory ends or ended. Null for currently active assignments. Supports historical assignment tracking and commission dispute resolution.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:repAssignmentStartDate rdf:type rdf:Property ;
    rdfs:label 'Rep Assignment Start Date' ;
    rdfs:comment 'Date on which the current primary sales representative assignment to this territory became effective. Used for commission attribution, quota proration, and sales force alignment history tracking.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:salesOrgCode rdf:type rdf:Property ;
    rdfs:label 'Sales Org Code' ;
    rdfs:comment 'SAP SD Sales Organization code to which this territory belongs. Defines the legal entity and organizational unit responsible for selling chemical products within this territory (e.g., \'1000\' for North America Chemicals).' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesforceTerritoryCode rdf:type rdf:Property ;
    rdfs:label 'Salesforce Territory Code' ;
    rdfs:comment 'Native Salesforce CRM Territory2 object identifier (15 or 18-character Salesforce ID) for this territory. Used for cross-system reconciliation between the Databricks Silver Layer and Salesforce CRM source system.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapSalesDistrictCode rdf:type rdf:Property ;
    rdfs:label 'Sap Sales District Code' ;
    rdfs:comment 'SAP SD Sales District code corresponding to this territory. The sales district is the SAP organizational unit that maps most directly to a geographic sales territory and is used in SAP order management, pricing, and reporting.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateProvinceCode rdf:type rdf:Property ;
    rdfs:label 'State Province Code' ;
    rdfs:comment 'ISO 3166-2 state or province code for sub-national geographic territories (e.g., \'US-TX\', \'DE-BY\'). Applicable for local-level territories; null for regional or global territories.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategicAccountFlag rdf:type rdf:Property ;
    rdfs:label 'Strategic Account Flag' ;
    rdfs:comment 'Indicates whether this territory contains one or more strategic (key) accounts that require dedicated executive-level sales engagement. Strategic territories in chemical manufacturing typically involve large-volume contracts and custom formulation agreements.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:technicalSalesRequired rdf:type rdf:Property ;
    rdfs:label 'Technical Sales Required' ;
    rdfs:comment 'Indicates whether this territory requires dedicated technical sales support (True), such as application engineers or chemists who provide product application guidance, formulation support, or SDS/COA documentation assistance to customers.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:territoryCode rdf:type rdf:Property ;
    rdfs:label 'Territory Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the sales territory, as maintained in SAP SD and Salesforce CRM. Used for cross-system reference and reporting (e.g., \'NA-CHEM-NE-01\', \'EMEA-AG-DE-02\').' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryDescription rdf:type rdf:Property ;
    rdfs:label 'Territory Description' ;
    rdfs:comment 'Free-text narrative description of the territory scope, coverage boundaries, special conditions, or strategic context. May include notes on key customer segments, chemical product focus areas, or competitive landscape relevant to the territory.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryName rdf:type rdf:Property ;
    rdfs:label 'Territory Name' ;
    rdfs:comment 'Human-readable descriptive name of the sales territory (e.g., \'Northeast Specialty Chemicals\', \'Germany Agricultural Solutions\'). Used in reporting, dashboards, and sales force communications.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryStatus rdf:type rdf:Property ;
    rdfs:label 'Territory Status' ;
    rdfs:comment 'Current lifecycle status of the territory record. Active territories are currently assigned and operational; pending territories are being set up; inactive territories have been temporarily suspended; archived territories are closed and retained for historical reporting.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryType rdf:type rdf:Property ;
    rdfs:label 'Territory Type' ;
    rdfs:comment 'Classification of how the territory is defined and segmented. Geographic territories are defined by physical region; industry_vertical by customer industry sector; named_account by specific key accounts; product_line by chemical product category; hybrid combines multiple dimensions.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tscaRegulatedFlag rdf:type rdf:Property ;
    rdfs:label 'Tsca Regulated Flag' ;
    rdfs:comment 'Indicates whether this territory operates under US TSCA (Toxic Substances Control Act) regulation, requiring compliance with EPA chemical substance reporting and restriction requirements for products sold in this territory.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:territoryAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Territory Assignment Id' ;
    rdfs:comment 'Unique surrogate identifier for each territory assignment record in the chemical sales organization. Primary key for this association entity linking a sales representative or account manager to a specific territory.' ;
    rdfs:domain ind:TerritoryAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:predecessorAssignmentTerritoryAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Predecessor Assignment Territory Assignment Id' ;
    rdfs:comment 'Reference to the previous territory assignment record that this assignment supersedes. Enables historical tracking of territory ownership changes, succession planning, and audit trail of coverage transitions in the chemical sales organization.' ;
    rdfs:domain ind:TerritoryAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TerritoryAssignment .

ind:accountCountTarget rdf:type rdf:Property ;
    rdfs:label 'Account Count Target' ;
    rdfs:comment 'The planned number of customer accounts the sales representative is expected to manage within this territory assignment. Used for workload balancing, territory sizing, and sales capacity planning in the chemical sales organization.' ;
    rdfs:domain ind:TerritoryAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvalDate rdf:type rdf:Property ;
    rdfs:label 'Approval Date' ;
    rdfs:comment 'The date on which the territory assignment was formally approved by the designated authority. Required for SOX compliance and internal audit trail of territory ownership changes.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentNumber rdf:type rdf:Property ;
    rdfs:label 'Assignment Number' ;
    rdfs:comment 'Externally-known business identifier for the territory assignment record, used in SAP SD and Salesforce CRM for cross-system reference and audit trail. Format: TA-YYYYMMDD-XXXX.' ;
    rdfs:domain ind:TerritoryAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assignment Status' ;
    rdfs:comment 'Current lifecycle state of the territory assignment. Drives commission eligibility, quota attribution, and CRM routing logic. Active indicates the rep is currently responsible for the territory.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentType rdf:type rdf:Property ;
    rdfs:label 'Assignment Type' ;
    rdfs:comment 'Classifies the basis on which the territory is defined and assigned. Geographic assignments cover a physical region; account-based assignments cover named accounts; product-based assignments cover specific chemical product lines (e.g., specialty polymers, agrochemicals); channel-based assignments cover distributor or direct channels.' ;
    rdfs:domain ind:TerritoryAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionRatePct rdf:type rdf:Property ;
    rdfs:label 'Commission Rate Pct' ;
    rdfs:comment 'The commission rate (expressed as a decimal fraction, e.g., 0.0350 = 3.50%) applicable to the sales representative for sales generated within this territory assignment. Used for incentive compensation calculation and financial accruals.' ;
    rdfs:domain ind:TerritoryAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coverageScope rdf:type rdf:Property ;
    rdfs:label 'Coverage Scope' ;
    rdfs:comment 'Indicates the geographic or organizational breadth of the territory assignment. Supports hierarchical territory reporting and sales performance aggregation across the chemical sales organization.' ;
    rdfs:domain ind:TerritoryAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmAssignmentCode rdf:type rdf:Property ;
    rdfs:label 'Crm Assignment Code' ;
    rdfs:comment 'The Salesforce CRM system identifier for this territory assignment record. Enables cross-system reconciliation between the Salesforce CRM territory model and the SAP SD sales organization structure.' ;
    rdfs:domain ind:TerritoryAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveFiscalQuarter rdf:type rdf:Property ;
    rdfs:label 'Effective Fiscal Quarter' ;
    rdfs:comment 'The fiscal quarter within the effective fiscal year for which this territory assignment and associated quota are applicable. Supports quarterly sales performance reporting and commission accrual calculations.' ;
    rdfs:domain ind:TerritoryAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveFiscalYear rdf:type rdf:Property ;
    rdfs:label 'Effective Fiscal Year' ;
    rdfs:comment 'The fiscal year in which this territory assignment is active and quota-bearing. Aligns territory assignments with annual sales planning cycles, budget periods, and financial reporting requirements under SAP FI/CO.' ;
    rdfs:domain ind:TerritoryAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endDate rdf:type rdf:Property ;
    rdfs:label 'End Date' ;
    rdfs:comment 'The date on which the sales representative\'s responsibility for the territory ends. Null indicates an open-ended assignment with no planned termination. Used for historical tracking and commission cutoff.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:geographicRegion rdf:type rdf:Property ;
    rdfs:label 'Geographic Region' ;
    rdfs:comment 'The geographic region or sub-region covered by this territory assignment (e.g., Northeast US, EMEA, APAC). Supports regional sales reporting, territory planning, and logistics coordination for chemical product distribution.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industrySegmentFocus rdf:type rdf:Property ;
    rdfs:label 'Industry Segment Focus' ;
    rdfs:comment 'The target end-market industry segment (e.g., automotive, construction, electronics, consumer goods, agriculture) that this territory assignment is focused on. Supports vertical market analytics and customer acquisition strategy for chemical product sales.' ;
    rdfs:domain ind:TerritoryAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCommissionEligible rdf:type rdf:Property ;
    rdfs:label 'Is Commission Eligible' ;
    rdfs:comment 'Indicates whether the sales representative is eligible to earn commission on sales generated within this territory assignment. Backup and overlay roles may have different commission eligibility rules in chemical sales organizations.' ;
    rdfs:domain ind:TerritoryAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimaryAssignment rdf:type rdf:Property ;
    rdfs:label 'Is Primary Assignment' ;
    rdfs:comment 'Indicates whether this is the primary territory assignment for the sales representative. A representative may have multiple territory assignments; this flag identifies the principal one for reporting and commission attribution purposes.' ;
    rdfs:domain ind:TerritoryAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isQuotaBearing rdf:type rdf:Property ;
    rdfs:label 'Is Quota Bearing' ;
    rdfs:comment 'Indicates whether a formal sales quota is assigned to this territory assignment. Overlay and backup roles may not carry independent quotas. Drives quota attainment reporting and KPI dashboards.' ;
    rdfs:domain ind:TerritoryAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productLineFocus rdf:type rdf:Property ;
    rdfs:label 'Product Line Focus' ;
    rdfs:comment 'Describes the specific chemical product line or portfolio segment (e.g., specialty polymers, performance coatings, agrochemicals, industrial solvents) that the sales representative is primarily responsible for within this territory. Supports product-line-level sales analytics and technical sales alignment.' ;
    rdfs:domain ind:TerritoryAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaAmount rdf:type rdf:Property ;
    rdfs:label 'Quota Amount' ;
    rdfs:comment 'The revenue quota assigned to the sales representative for this territory during the assignment period, expressed in the functional currency. Used for sales performance measurement, KPI reporting, and incentive compensation calculations.' ;
    rdfs:domain ind:TerritoryAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quotaCurrency rdf:type rdf:Property ;
    rdfs:label 'Quota Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the quota amount assigned to this territory (e.g., USD, EUR, GBP). Supports multi-currency chemical sales organizations operating across global markets.' ;
    rdfs:domain ind:TerritoryAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaPeriodType rdf:type rdf:Property ;
    rdfs:label 'Quota Period Type' ;
    rdfs:comment 'Defines the measurement period for the territory quota. Determines how quota attainment is calculated and reported for commission and incentive compensation purposes in the chemical sales organization.' ;
    rdfs:domain ind:TerritoryAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleType rdf:type rdf:Property ;
    rdfs:label 'Role Type' ;
    rdfs:comment 'Defines the nature of the sales representative\'s responsibility for the territory. Primary indicates full ownership; backup covers absence; overlay provides specialist support (e.g., technical sales for specialty chemicals); interim covers temporary gaps; co-primary indicates shared ownership.' ;
    rdfs:domain ind:TerritoryAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapSdAssignmentNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Sd Assignment Number' ;
    rdfs:comment 'The SAP SD system identifier for the territory assignment record. Supports cross-system data lineage, reconciliation, and integration between Salesforce CRM and SAP SD for territory management in the chemical manufacturing enterprise.' ;
    rdfs:domain ind:TerritoryAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startDate rdf:type rdf:Property ;
    rdfs:label 'Start Date' ;
    rdfs:comment 'The date on which the sales representative\'s responsibility for the territory becomes effective. Used for commission calculation, quota proration, and historical territory ownership tracking.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:terminationReason rdf:type rdf:Property ;
    rdfs:label 'Termination Reason' ;
    rdfs:comment 'Reason code explaining why the territory assignment was ended. Supports workforce analytics, territory planning, and historical audit of sales coverage changes in the chemical manufacturing sales organization. [ENUM-REF-CANDIDATE: resignation|reassignment|restructuring|performance|retirement|transfer|contract_end — promote to reference product if additional values are needed]' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Updated Timestamp' ;
    rdfs:comment 'The timestamp when this territory assignment record was last modified. Tracks changes to assignment status, role type, quota, or coverage scope for audit and data governance purposes.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:targetId rdf:type rdf:Property ;
    rdfs:label 'Target Id' ;
    rdfs:comment 'Primary key for target' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:budgetPlanId rdf:type rdf:Property ;
    rdfs:label 'Budget Plan Id' ;
    rdfs:comment 'Foreign key linking to finance.budget_plan. Business justification: Sales revenue targets are directly derived from and aligned with finance budget plans in chemical mfg. This link enables integrated business planning — comparing sales attainment against the approved ' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BudgetPlan .

ind:fiscalPeriodId rdf:type rdf:Property ;
    rdfs:label 'Fiscal Period Id' ;
    rdfs:comment 'Foreign key linking to finance.fiscal_period. Business justification: Sales targets are period-bound; linking to fiscal_period enables proper period-close attainment reporting. fiscal_period, fiscal_quarter, fiscal_year exist as denormalized plain columns on target that' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FiscalPeriod .

ind:hierarchyId rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Id' ;
    rdfs:comment 'Reference to the chemical product line or product family covered by this target (e.g., Specialty Polymers, Agrochemicals, Performance Coatings). Populated when assignment_level is \'product_line\' or when the target is scoped to a specific product category. Sourced from SAP MM material group hierarchy.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Hierarchy .

ind:actualRevenueUsd rdf:type rdf:Property ;
    rdfs:label 'Actual Revenue Usd' ;
    rdfs:comment 'The actual realized revenue in USD for the target period, sourced from SAP SD billing documents and FI/CO revenue postings. Used to calculate revenue attainment variance against the target. Updated periodically via ERP integration.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualVolumeMt rdf:type rdf:Property ;
    rdfs:label 'Actual Volume Mt' ;
    rdfs:comment 'The actual sales volume in metric tons (MT) realized during the target period, sourced from SAP SD delivery and billing records. Used to calculate volume attainment variance against the volume target.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignmentLevel rdf:type rdf:Property ;
    rdfs:label 'Assignment Level' ;
    rdfs:comment 'The organizational or commercial dimension at which this target is assigned. Sales_rep targets are individual; territory targets cover a geographic sales zone; product_line targets cover a chemical product family; business_unit targets cover a division (e.g., Agrochemicals, Specialty Chemicals); channel targets cover distributor or direct sales channels.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselineYear rdf:type rdf:Property ;
    rdfs:label 'Baseline Year' ;
    rdfs:comment 'The prior fiscal year used as the baseline reference for target-setting calculations (e.g., prior year actuals used to derive growth targets). Supports year-over-year growth analysis and target justification documentation.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fiscalPeriod rdf:type rdf:Property ;
    rdfs:label 'Fiscal Period' ;
    rdfs:comment 'The fiscal posting period number (1–12) to which this target applies. Populated only when period_granularity is \'monthly\'. Aligns with SAP FI/CO posting period numbers for monthly attainment reporting.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:floorRevenueUsd rdf:type rdf:Property ;
    rdfs:label 'Floor Revenue Usd' ;
    rdfs:comment 'The minimum revenue threshold (floor) below which no incentive compensation is earned. Typically 70–80% of the base target. Used in incentive compensation calculations to define the minimum attainment level required for commission eligibility.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:growthRatePct rdf:type rdf:Property ;
    rdfs:label 'Growth Rate Pct' ;
    rdfs:comment 'The planned year-over-year or period-over-period growth rate embedded in this target, expressed as a decimal (e.g., 0.0800 = 8.00% growth). Derived from strategic planning assumptions and used to validate target reasonableness in management reviews.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastRevisedDate rdf:type rdf:Property ;
    rdfs:label 'Last Revised Date' ;
    rdfs:comment 'The date on which this target was most recently revised or adjusted. Mid-year target revisions may occur due to market conditions, M&A activity, or force majeure events. Supports audit trail for target change management.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:marginPct rdf:type rdf:Property ;
    rdfs:label 'Margin Pct' ;
    rdfs:comment 'The planned gross margin percentage target for the period, expressed as a decimal (e.g., 0.3250 = 32.50%). Used for profitability management and incentive compensation plans that include margin-based components. Populated when target_type is \'margin\'.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:periodEndDate rdf:type rdf:Property ;
    rdfs:label 'Period End Date' ;
    rdfs:comment 'The calendar date on which the target measurement period ends. For annual targets this is typically December 31 or the fiscal year end date. Aligns with SAP FI/CO posting period close dates.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodGranularity rdf:type rdf:Property ;
    rdfs:label 'Period Granularity' ;
    rdfs:comment 'The time granularity at which this target is set and tracked. Annual targets cover a full fiscal year; quarterly targets align to SAP posting periods Q1–Q4; monthly targets align to individual SAP posting periods for detailed attainment tracking.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodStartDate rdf:type rdf:Property ;
    rdfs:label 'Period Start Date' ;
    rdfs:comment 'The calendar date on which the target measurement period begins. For annual targets this is typically January 1 or the fiscal year start date. Aligns with SAP FI/CO posting period open dates.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:productCategory rdf:type rdf:Property ;
    rdfs:label 'Product Category' ;
    rdfs:comment 'The chemical product category or market segment covered by this target (e.g., Specialty Chemicals, Agrochemicals, Performance Polymers, Industrial Chemicals, Coatings & Adhesives). Sourced from SAP MM material group classification. [ENUM-REF-CANDIDATE: specialty_chemicals|agrochemicals|performance_polymers|industrial_chemicals|coatings_adhesives|plastics|solvents|catalysts — promote to reference product]' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueAttainmentPct rdf:type rdf:Property ;
    rdfs:label 'Revenue Attainment Pct' ;
    rdfs:comment 'The ratio of actual revenue to target revenue for the period, expressed as a decimal (e.g., 0.9250 = 92.50% attainment). Calculated as actual_revenue_usd / target_revenue_usd. Used for sales performance management, KPI dashboards, and incentive compensation calculations. NOTE: This is a stored attainment snapshot, not a real-time computed metric, to support point-in-time reporting and audit.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueUsd rdf:type rdf:Property ;
    rdfs:label 'Revenue Usd' ;
    rdfs:comment 'The planned revenue target value denominated in US Dollars (USD) for the defined period. Represents the gross revenue goal before deductions. Used for EBITDA planning, COGS analysis, and sales performance management. Populated when target_type is \'revenue\' or \'margin\'.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revisionReason rdf:type rdf:Property ;
    rdfs:label 'Revision Reason' ;
    rdfs:comment 'The business reason for the most recent revision to this target. Market_conditions covers demand shifts; portfolio_change covers product additions/removals; territory_realignment covers sales org restructuring; acquisition covers M&A impacts; force_majeure covers unforeseeable events; correction covers data entry errors.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settingMethod rdf:type rdf:Property ;
    rdfs:label 'Setting Method' ;
    rdfs:comment 'The methodology used to establish this sales target. Top_down targets are allocated from corporate/BU level; bottom_up targets are built from rep-level forecasts; negotiated targets result from manager-rep agreement; statistical targets are derived from historical trend analysis and SPC methods.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stretchRevenueUsd rdf:type rdf:Property ;
    rdfs:label 'Stretch Revenue Usd' ;
    rdfs:comment 'The aspirational upper-bound revenue target (stretch goal) in USD, set above the base target to incentivize overperformance. Typically 110–120% of the base target. Used in incentive compensation plans to calculate accelerated commission rates for above-target performance.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetCode rdf:type rdf:Property ;
    rdfs:label 'Target Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the sales target record, used in management reporting, incentive compensation plans, and cross-system references between SAP SD and Salesforce CRM.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetName rdf:type rdf:Property ;
    rdfs:label 'Target Name' ;
    rdfs:comment 'Human-readable descriptive name for the sales target, such as \'FY2025 Q1 Specialty Chemicals - North America\' or \'Annual Volume Target - Agrochemicals - Rep Smith\'. Used in dashboards and management reports.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetStatus rdf:type rdf:Property ;
    rdfs:label 'Target Status' ;
    rdfs:comment 'Current lifecycle state of the sales target record. Draft targets are under review; active targets are in-period and being tracked; approved targets have passed management sign-off; closed targets have reached period end; cancelled targets were withdrawn before period start.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetType rdf:type rdf:Property ;
    rdfs:label 'Target Type' ;
    rdfs:comment 'Classification of the sales target by the primary metric being tracked. Revenue targets are denominated in USD; volume targets in MT or kg; margin targets as gross margin percentage; new_business for new customer acquisition; account_growth for existing account expansion.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeAttainmentPct rdf:type rdf:Property ;
    rdfs:label 'Volume Attainment Pct' ;
    rdfs:comment 'The ratio of actual volume to target volume for the period, expressed as a decimal (e.g., 1.0500 = 105.00% attainment). Calculated as actual_volume_mt / target_volume_mt. Used for supply chain planning alignment and sales volume KPI reporting.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeMt rdf:type rdf:Property ;
    rdfs:label 'Volume Mt' ;
    rdfs:comment 'The planned sales volume target expressed in metric tons (MT). Used for chemical manufacturing capacity planning, raw material procurement forecasting, and supply chain management. Populated when target_type is \'volume\'. Aligns with SAP SD delivery quantity planning.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeUom rdf:type rdf:Property ;
    rdfs:label 'Volume Uom' ;
    rdfs:comment 'The unit of measure for the volume target. MT (metric tons) is standard for bulk chemicals; KG for specialty/fine chemicals; L (liters) for liquid products; GAL (gallons) for US market; LB (pounds) for certain North American contracts. Aligns with SAP MM base unit of measure.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributorId rdf:type rdf:Property ;
    rdfs:label 'Distributor Id' ;
    rdfs:comment 'Unique surrogate identifier for the authorized chemical distributor or channel partner record. Primary key for the distributor master in the sales domain.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Distributor .

ind:salesforceAccountId rdf:type rdf:Property ;
    rdfs:label 'Salesforce Account Id' ;
    rdfs:comment 'Salesforce CRM Account record identifier for this distributor. Enables cross-system traceability between the lakehouse silver layer distributor master and the Salesforce CRM system of record for opportunity and activity management.' ;
    rdfs:domain ind:Distributor ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:agreementEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Agreement Effective Date' ;
    rdfs:comment 'Calendar date on which the distribution agreement becomes legally binding and commercially effective. Marks the start of authorized distribution rights and contractual obligations.' ;
    rdfs:domain ind:Distributor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:agreementExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Agreement Expiry Date' ;
    rdfs:comment 'Calendar date on which the distribution agreement expires or is scheduled to terminate. Null indicates an open-ended agreement. Used for renewal tracking and compliance monitoring.' ;
    rdfs:domain ind:Distributor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:annualPurchaseCommitment rdf:type rdf:Property ;
    rdfs:label 'Annual Purchase Commitment' ;
    rdfs:comment 'Contractually agreed minimum annual purchase value (in agreement currency) that the distributor commits to purchasing from Chemical Mfg. Used for rebate tier qualification and agreement compliance monitoring.' ;
    rdfs:domain ind:Distributor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:authorizedProductCategories rdf:type rdf:Property ;
    rdfs:label 'Authorized Product Categories' ;
    rdfs:comment 'Comma-separated list of product categories or chemical product lines that the distributor is contractually authorized to sell under the distribution agreement (e.g., \'Specialty Solvents,Performance Coatings,Agricultural Intermediates\'). Enforced during order processing in SAP SD.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoRenewalFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Flag' ;
    rdfs:comment 'Indicates whether the distribution agreement automatically renews upon expiry unless explicitly terminated. True = auto-renews; False = requires affirmative renewal action.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Certification Expiry Date' ;
    rdfs:comment 'Earliest expiry date among the distributor\'s active compliance certifications (e.g., ISO 9001, Responsible Distribution, REACH). Used to trigger recertification workflows and flag distributors with lapsing credentials.' ;
    rdfs:domain ind:Distributor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Credit Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the credit limit and financial terms are denominated (e.g., USD, EUR, GBP). Aligns with the agreement currency for consistent financial reporting.' ;
    rdfs:domain ind:Distributor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimit rdf:type rdf:Property ;
    rdfs:label 'Credit Limit' ;
    rdfs:comment 'Maximum outstanding accounts receivable balance (in agreement currency) extended to the distributor by Chemical Mfg. Enforced in SAP SD credit management to block orders exceeding the limit.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:distributorCode rdf:type rdf:Property ;
    rdfs:label 'Distributor Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier assigned to the distributor in SAP SD / Salesforce CRM. Used on purchase orders, invoices, and channel communications as the canonical reference code.' ;
    rdfs:domain ind:Distributor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributorStatus rdf:type rdf:Property ;
    rdfs:label 'Distributor Status' ;
    rdfs:comment 'Current lifecycle status of the distributor master record. Active = approved and trading; Suspended = temporarily blocked (e.g., compliance hold); Pending Approval = onboarding in progress; Terminated = agreement ended.' ;
    rdfs:domain ind:Distributor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributorTier rdf:type rdf:Property ;
    rdfs:label 'Distributor Tier' ;
    rdfs:comment 'Commercial tier classification of the distributor based on sales volume, strategic importance, and service level. Drives rebate eligibility, pricing tiers, and support resource allocation. Tier 1 = highest volume/strategic; Tier 3 = emerging/low volume.' ;
    rdfs:domain ind:Distributor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributorType rdf:type rdf:Property ;
    rdfs:label 'Distributor Type' ;
    rdfs:comment 'Classification of the distributor relationship type. Exclusive distributors hold sole rights in a territory; master distributors may appoint sub-distributors; agents act on behalf without taking title to goods.' ;
    rdfs:domain ind:Distributor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunsNumber rdf:type rdf:Property ;
    rdfs:label 'Duns Number' ;
    rdfs:comment 'Nine-digit Dun & Bradstreet Data Universal Numbering System (DUNS) number uniquely identifying the distributor\'s legal entity globally. Used for credit risk assessment, supplier qualification, and third-party data enrichment.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ghsClassificationAcknowledged rdf:type rdf:Property ;
    rdfs:label 'Ghs Classification Acknowledged' ;
    rdfs:comment 'Indicates whether the distributor has formally acknowledged receipt and understanding of GHS hazard classification and labelling requirements for all authorized product categories. Required for EHS compliance onboarding.' ;
    rdfs:domain ind:Distributor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iso9001Certified rdf:type rdf:Property ;
    rdfs:label 'Iso 9001 Certified' ;
    rdfs:comment 'Indicates whether the distributor holds a current ISO 9001 Quality Management System certification. Used as a quality assurance criterion in distributor qualification and tier classification.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalName rdf:type rdf:Property ;
    rdfs:label 'Legal Name' ;
    rdfs:comment 'Full registered legal name of the distributor entity as recorded in the distribution agreement and government business registry. Used for contract execution, invoicing, and regulatory filings.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moqKg rdf:type rdf:Property ;
    rdfs:label 'Moq Kg' ;
    rdfs:comment 'Minimum Order Quantity (MOQ) in kilograms that the distributor must place per order under the distribution agreement. Enforced in SAP SD order entry to ensure commercial viability of each transaction.' ;
    rdfs:domain ind:Distributor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onboardingDate rdf:type rdf:Property ;
    rdfs:label 'Onboarding Date' ;
    rdfs:comment 'Calendar date on which the distributor completed the formal onboarding process and was approved as an authorized channel partner. Marks the start of the commercial relationship lifecycle.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:primaryContactEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Email' ;
    rdfs:comment 'Primary business email address for the distributor\'s key account contact. Used for order confirmations, SDS/COA distribution, regulatory notifications, and commercial communications.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactName rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Name' ;
    rdfs:comment 'Full name of the primary business contact person at the distributor organization responsible for managing the commercial relationship with Chemical Mfg.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Phone' ;
    rdfs:comment 'Primary business telephone number for the distributor\'s key account contact. Used for urgent order management, compliance escalations, and technical sales support.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reachRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Reach Registration Number' ;
    rdfs:comment 'European Chemicals Agency (ECHA) REACH registration number confirming the distributor\'s compliance with Registration, Evaluation, Authorisation and Restriction of Chemicals (REACH) Regulation (EC) No 1907/2006. Required for distributors operating in EU/EEA markets.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rebateStructureCode rdf:type rdf:Property ;
    rdfs:label 'Rebate Structure Code' ;
    rdfs:comment 'Reference code identifying the rebate or volume incentive program applicable to this distributor as defined in the SAP SD rebate agreement. Determines the rebate calculation method, thresholds, and payout schedule.' ;
    rdfs:domain ind:Distributor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Notice Days' ;
    rdfs:comment 'Number of calendar days prior to agreement expiry by which either party must provide written notice of non-renewal or termination. Contractually mandated and used to trigger renewal workflow alerts.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responsibleDistributionCertified rdf:type rdf:Property ;
    rdfs:label 'Responsible Distribution Certified' ;
    rdfs:comment 'Indicates whether the distributor holds current certification under the National Association of Chemical Distributors (NACD) Responsible Distribution program, demonstrating commitment to EHS, security, and product stewardship standards.' ;
    rdfs:domain ind:Distributor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sapCustomerNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Customer Number' ;
    rdfs:comment 'SAP S/4HANA SD customer master number assigned to the distributor. Used for order-to-cash processing, credit management, and financial reconciliation between the lakehouse and SAP ERP.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdsDistributionObligation rdf:type rdf:Property ;
    rdfs:label 'Sds Distribution Obligation' ;
    rdfs:comment 'Indicates whether the distributor is contractually and regulatory obligated to distribute Safety Data Sheets (SDS) to downstream customers per GHS/OSHA HazCom 2012 requirements. True = obligated; False = exempt (e.g., agent not taking title).' ;
    rdfs:domain ind:Distributor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxIdentificationNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Identification Number' ;
    rdfs:comment 'Government-issued Tax Identification Number (TIN) or VAT registration number of the distributor legal entity. Required for invoicing, customs documentation, and tax compliance reporting.' ;
    rdfs:domain ind:Distributor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationDate rdf:type rdf:Property ;
    rdfs:label 'Termination Date' ;
    rdfs:comment 'Calendar date on which the distribution agreement was formally terminated or the distributor relationship was ended. Null if the relationship is active or the agreement has not been terminated.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tradeName rdf:type rdf:Property ;
    rdfs:label 'Trade Name' ;
    rdfs:comment 'Operating or \'doing business as\' (DBA) trade name of the distributor, which may differ from the legal entity name. Used in commercial communications and sales reporting.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tscaComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Tsca Compliance Flag' ;
    rdfs:comment 'Indicates whether the distributor has confirmed compliance with the Toxic Substances Control Act (TSCA) requirements for chemical distribution in the United States. True = confirmed compliant; False = non-compliant or unconfirmed.' ;
    rdfs:domain ind:Distributor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:distributorAgreementId rdf:type rdf:Property ;
    rdfs:label 'Distributor Agreement Id' ;
    rdfs:comment 'Unique surrogate identifier for the distributor agreement record in the Chemical Mfg lakehouse silver layer. Primary key for this entity.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributorAgreement .

ind:crmOpportunityId rdf:type rdf:Property ;
    rdfs:label 'Crm Opportunity Id' ;
    rdfs:comment 'Salesforce CRM opportunity or contract record identifier that originated or is linked to this distributor agreement. Enables traceability from sales pipeline to executed agreement.' ;
    rdfs:domain ind:DistributorAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Opportunity .

ind:reachRegistrationId rdf:type rdf:Property ;
    rdfs:label 'Reach Registration Id' ;
    rdfs:comment 'Foreign key linking to rawmaterial.reach_registration. Business justification: distributor_agreement.reach_downstream_reporting_required flag confirms REACH obligations exist. Under EU REACH Articles 31-32, distributors must pass SDS and registration information downstream; the ' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReachRegistration .

ind:agreementVersion rdf:type rdf:Property ;
    rdfs:label 'Agreement Version' ;
    rdfs:comment 'Sequential version number of the distributor agreement, incremented each time the agreement is formally amended (e.g., price renegotiation, territory expansion, MOQ revision). Version 1 is the original executed agreement.' ;
    rdfs:domain ind:DistributorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:amendmentDate rdf:type rdf:Property ;
    rdfs:label 'Amendment Date' ;
    rdfs:comment 'Date of the most recent formal amendment to this distributor agreement. Null if no amendments have been made since original execution. Used with agreement_version for change tracking.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:amendmentDescription rdf:type rdf:Property ;
    rdfs:label 'Amendment Description' ;
    rdfs:comment 'Free-text description of the most recent amendment to this distributor agreement, summarizing the key changes made (e.g., \'Territory expanded to include CAN; MOQ increased to USD 500,000\'). Supports audit trail and Management of Change (MOC) documentation.' ;
    rdfs:domain ind:DistributorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimitUsd rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Usd' ;
    rdfs:comment 'Maximum outstanding accounts receivable credit extended to the distributor under this agreement, denominated in USD. Enforced in SAP SD credit management (FD32) to control financial exposure.' ;
    rdfs:domain ind:DistributorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeResolutionMechanism rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Mechanism' ;
    rdfs:comment 'Contractually agreed mechanism for resolving disputes arising under this distributor agreement: arbitration (binding third-party arbitration), litigation (court proceedings), mediation (non-binding third-party mediation), or negotiation (direct party negotiation).' ;
    rdfs:domain ind:DistributorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ehsTrainingRequired rdf:type rdf:Property ;
    rdfs:label 'Ehs Training Required' ;
    rdfs:comment 'Indicates whether distributor personnel are required to complete Chemical Mfg-mandated EHS (Environment Health and Safety) training on product handling, storage, and emergency response as a condition of this agreement.' ;
    rdfs:domain ind:DistributorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exclusivityScope rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Scope' ;
    rdfs:comment 'Defines the breadth of exclusivity granted to the distributor within the authorized territory: full_portfolio (all Chemical Mfg products), product_category (specific product categories only), single_product (one product or SKU), or none (non-exclusive arrangement).' ;
    rdfs:domain ind:DistributorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingLawCountry rdf:type rdf:Property ;
    rdfs:label 'Governing Law Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the jurisdiction whose laws govern interpretation and enforcement of this distributor agreement (e.g., USA, DEU, GBR). Critical for dispute resolution and regulatory compliance.' ;
    rdfs:domain ind:DistributorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moqAnnualUsd rdf:type rdf:Property ;
    rdfs:label 'Moq Annual Usd' ;
    rdfs:comment 'Minimum annual purchase commitment in US dollars that the distributor must achieve to maintain agreement terms and qualify for contracted pricing and rebates. Failure to meet MOQ may trigger agreement renegotiation or termination. Aligns with SAP SD minimum order value configuration.' ;
    rdfs:domain ind:DistributorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productApplicationSupport rdf:type rdf:Property ;
    rdfs:label 'Product Application Support' ;
    rdfs:comment 'Indicates whether Chemical Mfg provides technical sales and product application guidance support to the distributor under this agreement, including customer-specific formulation assistance and technical documentation.' ;
    rdfs:domain ind:DistributorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reachDownstreamReportingRequired rdf:type rdf:Property ;
    rdfs:label 'Reach Downstream Reporting Required' ;
    rdfs:comment 'Indicates whether the distributor must fulfill REACH downstream user reporting obligations, including use notifications and exposure scenario communication, as required under ECHA REACH Regulation (EC) No 1907/2006 Title V.' ;
    rdfs:domain ind:DistributorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rebateRatePct rdf:type rdf:Property ;
    rdfs:label 'Rebate Rate Pct' ;
    rdfs:comment 'Base rebate percentage (0.00–100.00) applied to eligible purchases under this agreement. For volume_tiered structures, this represents the base tier rate; tier thresholds are managed in the rebate schedule. Stored in SAP SD rebate agreement condition records.' ;
    rdfs:domain ind:DistributorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rebateStructureType rdf:type rdf:Property ;
    rdfs:label 'Rebate Structure Type' ;
    rdfs:comment 'Classification of the rebate mechanism applicable to this distributor agreement: volume_tiered (rebate percentage increases with purchase volume tiers), flat_rate (fixed percentage on all purchases), growth_incentive (rebate tied to year-over-year growth targets), or none (no rebate applicable).' ;
    rdfs:domain ind:DistributorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Date' ;
    rdfs:comment 'Date by which a renewal decision must be made or the agreement auto-renews. Drives CRM (Salesforce) renewal opportunity creation and account manager notifications.' ;
    rdfs:domain ind:DistributorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responsibleCareComplianceRequired rdf:type rdf:Property ;
    rdfs:label 'Responsible Care Compliance Required' ;
    rdfs:comment 'Indicates whether the distributor is contractually required to adhere to the ACC (American Chemistry Council) Responsible Care program standards as a condition of this distribution agreement.' ;
    rdfs:domain ind:DistributorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sapContractNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Contract Number' ;
    rdfs:comment 'SAP S/4HANA SD contract document number (transaction VA41/VA42) corresponding to this distributor agreement. Used for cross-system reconciliation between the CRM pipeline and ERP order management.' ;
    rdfs:domain ind:DistributorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdsDistributionRequired rdf:type rdf:Property ;
    rdfs:label 'Sds Distribution Required' ;
    rdfs:comment 'Indicates whether the distributor is contractually obligated to distribute Safety Data Sheets (SDS) to downstream customers for all chemical products sold under this agreement. Mandatory under GHS, REACH, and OSHA HazCom 2012 (29 CFR 1910.1200).' ;
    rdfs:domain ind:DistributorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:signedDate rdf:type rdf:Property ;
    rdfs:label 'Signed Date' ;
    rdfs:comment 'Date on which both parties executed (signed) the distributor agreement. May differ from effective_date when agreements are backdated or post-dated.' ;
    rdfs:domain ind:DistributorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:territoryCountryCode rdf:type rdf:Property ;
    rdfs:label 'Territory Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 three-letter country code representing the primary country of the authorized distribution territory. Used for REACH downstream user reporting and EPA/TSCA jurisdictional compliance tracking.' ;
    rdfs:domain ind:DistributorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryScope rdf:type rdf:Property ;
    rdfs:label 'Territory Scope' ;
    rdfs:comment 'Geographic scope within which the distributor is authorized to sell Chemical Mfg products under this agreement. May be expressed as country codes (ISO 3166-1 alpha-3), regions, or named sales territories (e.g., \'USA,CAN,MEX\' or \'EMEA-West\'). Supports territory management analytics in Salesforce CRM.' ;
    rdfs:domain ind:DistributorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rebateAgreementId rdf:type rdf:Property ;
    rdfs:label 'Rebate Agreement Id' ;
    rdfs:comment 'Unique surrogate identifier for the sales rebate agreement record in the lakehouse silver layer. Primary key for this entity.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RebateAgreement .

ind:accrualGlAccountId rdf:type rdf:Property ;
    rdfs:label 'Accrual Gl Account Id' ;
    rdfs:comment 'Foreign key linking to finance.gl_account. Business justification: Rebate accruals post to specific GL accounts for period-close journal entries. accrual_account_code is a denormalized plain column that should be a proper FK to gl_account for accurate financial posti' ;
    rdfs:domain ind:RebateAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:salesforceOpportunityId rdf:type rdf:Property ;
    rdfs:label 'Salesforce Opportunity Id' ;
    rdfs:comment 'Identifier of the associated Salesforce CRM opportunity or contract record that originated or tracks this rebate agreement. Enables cross-system traceability between CRM pipeline and SAP SD rebate execution.' ;
    rdfs:domain ind:RebateAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Opportunity .

ind:accrualMethod rdf:type rdf:Property ;
    rdfs:label 'Accrual Method' ;
    rdfs:comment 'Accounting method used to recognize and accrue rebate liability over the agreement period. Accrual-based: rebate liability is recognized as sales occur; Cash basis: recognized only upon settlement payment; Manual: accruals are posted manually by finance. Aligns with SAP FI/CO accrual posting logic.' ;
    rdfs:domain ind:RebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accruedAmount rdf:type rdf:Property ;
    rdfs:label 'Accrued Amount' ;
    rdfs:comment 'Cumulative rebate liability accrued to date under this agreement based on eligible customer purchases. Updated periodically via SAP SD rebate settlement runs. Expressed in payout currency. Represents the current outstanding rebate obligation.' ;
    rdfs:domain ind:RebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:agreementNotes rdf:type rdf:Property ;
    rdfs:label 'Agreement Notes' ;
    rdfs:comment 'Free-text field capturing commercial negotiation context, special conditions, customer-specific terms, or exceptions not captured in structured fields. Used by sales and finance teams for agreement administration.' ;
    rdfs:domain ind:RebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselinePeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Baseline Period End' ;
    rdfs:comment 'End date of the reference period used to establish the baseline purchase volume or revenue for growth incentive rebate measurement. Together with baseline_period_start, defines the comparison window.' ;
    rdfs:domain ind:RebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:baselinePeriodStart rdf:type rdf:Property ;
    rdfs:label 'Baseline Period Start' ;
    rdfs:comment 'Start date of the reference period used to establish the baseline purchase volume or revenue against which growth performance is measured for growth incentive rebate agreements.' ;
    rdfs:domain ind:RebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:calculationBasis rdf:type rdf:Property ;
    rdfs:label 'Calculation Basis' ;
    rdfs:comment 'Defines the metric used to measure customer performance and calculate rebate entitlement. Revenue: net invoiced sales value; Volume: quantity of product units; Quantity: number of orders or transactions; Weight (kg): metric weight of chemical products shipped; Mixed: combination of revenue and volume thresholds.' ;
    rdfs:domain ind:RebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveFrom rdf:type rdf:Property ;
    rdfs:label 'Effective From' ;
    rdfs:comment 'Calendar date on which the rebate agreement becomes binding and eligible purchases begin accruing toward rebate thresholds. Formatted as yyyy-MM-dd.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveUntil rdf:type rdf:Property ;
    rdfs:label 'Effective Until' ;
    rdfs:comment 'Calendar date on which the rebate agreement expires and no further accruals are recognized. Nullable for open-ended agreements. Formatted as yyyy-MM-dd.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eligibleProductScope rdf:type rdf:Property ;
    rdfs:label 'Eligible Product Scope' ;
    rdfs:comment 'Defines the breadth of products eligible for rebate accrual under this agreement. All products: entire customer portfolio; Product group: defined SAP material group; Specific SKUs: enumerated Stock Keeping Units (SKUs); Product line: a named chemical product line; Material type: SAP material type classification (e.g., FERT, HALB).' ;
    rdfs:domain ind:RebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:growthTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Growth Target Percent' ;
    rdfs:comment 'Year-over-year revenue or volume growth percentage target that the customer must achieve to qualify for growth incentive rebate tiers. Applicable only when agreement_type is growth_incentive. Expressed as a decimal percentage (e.g., 10.0000 = 10%).' ;
    rdfs:domain ind:RebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isRetroactive rdf:type rdf:Property ;
    rdfs:label 'Is Retroactive' ;
    rdfs:comment 'Indicates whether the rebate is applied retroactively to all eligible purchases once a higher tier threshold is crossed (retroactive/step rebate), as opposed to applying only to incremental purchases above the threshold (incremental rebate). Critical for SAP SD rebate condition type configuration.' ;
    rdfs:domain ind:RebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTiered rdf:type rdf:Property ;
    rdfs:label 'Is Tiered' ;
    rdfs:comment 'Indicates whether this rebate agreement uses a tiered scale structure where different rebate rates apply at different purchase volume or revenue thresholds. True: multiple tiers defined in the rebate tier child product; False: single flat rate applies.' ;
    rdfs:domain ind:RebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastSettlementDate rdf:type rdf:Property ;
    rdfs:label 'Last Settlement Date' ;
    rdfs:comment 'Date on which the most recent rebate settlement was completed and credit memo or payment was issued to the customer. Used to track settlement history and validate settlement frequency compliance.' ;
    rdfs:domain ind:RebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maxRebateCapAmount rdf:type rdf:Property ;
    rdfs:label 'Max Rebate Cap Amount' ;
    rdfs:comment 'Maximum total rebate payout amount allowed under this agreement regardless of actual purchase performance. Protects Chemical Mfg from uncapped rebate liability exposure. Null if no cap applies. Expressed in payout currency.' ;
    rdfs:domain ind:RebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextSettlementDate rdf:type rdf:Property ;
    rdfs:label 'Next Settlement Date' ;
    rdfs:comment 'Scheduled date for the next rebate settlement run for this agreement. Drives SAP SD settlement processing calendar and finance accrual review cycles.' ;
    rdfs:domain ind:RebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:payoutCurrency rdf:type rdf:Property ;
    rdfs:label 'Payout Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the rebate settlement is denominated and paid to the customer or distributor (e.g., USD, EUR, GBP). Supports multi-currency rebate programs for global chemical distribution.' ;
    rdfs:domain ind:RebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rebateAmountFixed rdf:type rdf:Property ;
    rdfs:label 'Rebate Amount Fixed' ;
    rdfs:comment 'Fixed monetary rebate amount payable upon achievement of agreement conditions, used for flat-fee rebate structures (e.g., market development funds with a fixed payout). Null when the agreement uses a percentage-based rate. Expressed in the payout currency.' ;
    rdfs:domain ind:RebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rebateRatePercent rdf:type rdf:Property ;
    rdfs:label 'Rebate Rate Percent' ;
    rdfs:comment 'Percentage rate applied to the calculation basis to determine the rebate payout amount for a given tier. Expressed as a decimal percentage (e.g., 2.5000 = 2.5%). For tiered agreements, this represents the base or entry-level rate; tier-specific rates are captured in the rebate tier product.' ;
    rdfs:domain ind:RebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sapRebateAgreementNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Rebate Agreement Number' ;
    rdfs:comment 'Source system identifier for this rebate agreement in SAP SD (BO01/BO02 agreement number). Enables traceability and reconciliation between the lakehouse silver layer and the SAP S/4HANA system of record.' ;
    rdfs:domain ind:RebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settledAmount rdf:type rdf:Property ;
    rdfs:label 'Settled Amount' ;
    rdfs:comment 'Total rebate amount that has been paid or credited to the customer through completed settlement runs. The difference between accrued_amount and settled_amount represents the outstanding rebate payable. Expressed in payout currency.' ;
    rdfs:domain ind:RebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementFrequency rdf:type rdf:Property ;
    rdfs:label 'Settlement Frequency' ;
    rdfs:comment 'Frequency at which the accrued rebate is settled and paid to the customer or distributor. Determines the cadence of SAP SD rebate settlement runs and credit memo generation.' ;
    rdfs:domain ind:RebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementMethod rdf:type rdf:Property ;
    rdfs:label 'Settlement Method' ;
    rdfs:comment 'Mechanism by which the rebate is paid to the customer or distributor. Credit memo: applied against future invoices in SAP SD; Check: physical payment instrument; Bank transfer: electronic funds transfer; Product credit: rebate applied as credit toward future product purchases.' ;
    rdfs:domain ind:RebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdBasisAmount rdf:type rdf:Property ;
    rdfs:label 'Threshold Basis Amount' ;
    rdfs:comment 'Minimum cumulative purchase value (in payout currency) or volume that the customer must achieve to qualify for the rebate. Represents the entry-level threshold for single-tier agreements. For multi-tier agreements, this is the lowest tier threshold.' ;
    rdfs:domain ind:RebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:thresholdBasisUnit rdf:type rdf:Property ;
    rdfs:label 'Threshold Basis Unit' ;
    rdfs:comment 'Unit of measure for the rebate threshold basis amount. For revenue-based agreements, this is the ISO 4217 currency code. For volume-based agreements, this is the unit of measure (MT = metric ton, KG = kilogram, L = liter, EA = each) aligned with chemical product measurement standards. [ENUM-REF-CANDIDATE: USD|EUR|GBP|MT|KG|L|EA| — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opportunityProductId rdf:type rdf:Property ;
    rdfs:label 'Opportunity Product Id' ;
    rdfs:comment 'Unique surrogate identifier for the opportunity-product association record in the Silver Layer lakehouse. Primary key for this entity.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OpportunityProduct .

ind:costElementId rdf:type rdf:Property ;
    rdfs:label 'Cost Element Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_element. Business justification: Opportunity products in chemical mfg carry standard cost estimates for margin calculation during the sales stage. Linking to cost_element enables accurate contribution margin forecasting on pipeline o' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostElement .

ind:productSpecificationId rdf:type rdf:Property ;
    rdfs:label 'Product Specification Id' ;
    rdfs:comment 'Foreign key linking to product.product_specification. Business justification: In chemical manufacturing, customer-specific specifications drive the technical review process during opportunity qualification. FK from opportunity_product to product_specification links the commerci' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductSpecification .

ind:tdsId rdf:type rdf:Property ;
    rdfs:label 'Tds Id' ;
    rdfs:comment 'Foreign key linking to product.tds. Business justification: TDS documents are central to technical sales in chemical manufacturing — customers require performance data to qualify a chemical for their process. When technical_review_required=true, the TDS should' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Tds .

ind:annualVolumeEstimate rdf:type rdf:Property ;
    rdfs:label 'Annual Volume Estimate' ;
    rdfs:comment 'Estimated annual purchase volume for this product line, expressed in the quantity UOM. Supports long-term demand forecasting, supply chain planning, and volume-based pricing negotiations.' ;
    rdfs:domain ind:OpportunityProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:applicationEndUse rdf:type rdf:Property ;
    rdfs:label 'Application End Use' ;
    rdfs:comment 'Specific end-use application or industry segment for which the customer intends to use this chemical product (e.g., automotive coatings, agricultural formulation, electronic cleaning). Critical for REACH downstream user notifications and technical sales support.' ;
    rdfs:domain ind:OpportunityProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closeDate rdf:type rdf:Property ;
    rdfs:label 'Close Date' ;
    rdfs:comment 'Expected or actual date on which this product line within the opportunity is anticipated to be won or lost. Used for pipeline aging analysis and sales forecast period alignment.' ;
    rdfs:domain ind:OpportunityProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:competitiveStatus rdf:type rdf:Property ;
    rdfs:label 'Competitive Status' ;
    rdfs:comment 'Describes the competitive landscape for this product line within the opportunity. Indicates whether Chemical Mfg is the sole supplier, competing against others, defending incumbent business, or attempting to displace a competitor.' ;
    rdfs:domain ind:OpportunityProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitorName rdf:type rdf:Property ;
    rdfs:label 'Competitor Name' ;
    rdfs:comment 'Name of the primary competing supplier for this product line in the opportunity. Used for competitive intelligence, win/loss analysis, and strategic positioning.' ;
    rdfs:domain ind:OpportunityProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractEndDate rdf:type rdf:Property ;
    rdfs:label 'Contract End Date' ;
    rdfs:comment 'Proposed end date of the supply contract or pricing agreement for this product line. Defines the duration of the commercial commitment being negotiated.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractStartDate rdf:type rdf:Property ;
    rdfs:label 'Contract Start Date' ;
    rdfs:comment 'Proposed start date of the supply contract or pricing agreement for this product line if the opportunity is won. Feeds into contract management and SAP SD scheduling agreements.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:crmOpportunityProductCode rdf:type rdf:Property ;
    rdfs:label 'Crm Opportunity Product Code' ;
    rdfs:comment 'External identifier for this opportunity-product line as recorded in Salesforce CRM (OpportunityLineItem ID). Used for cross-system reconciliation between CRM and SAP SD.' ;
    rdfs:domain ind:OpportunityProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountPct rdf:type rdf:Property ;
    rdfs:label 'Discount Pct' ;
    rdfs:comment 'Percentage discount offered on the list price for this product line as part of the commercial negotiation. Supports margin analysis and pricing governance.' ;
    rdfs:domain ind:OpportunityProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedQuantity rdf:type rdf:Property ;
    rdfs:label 'Estimated Quantity' ;
    rdfs:comment 'Estimated volume or quantity of the chemical product the customer intends to purchase within the opportunity period. Used for demand forecasting and production planning.' ;
    rdfs:domain ind:OpportunityProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedRevenue rdf:type rdf:Property ;
    rdfs:label 'Estimated Revenue' ;
    rdfs:comment 'Total estimated revenue for this product line within the opportunity, calculated as estimated quantity multiplied by unit price. Represents the gross revenue potential before discounts.' ;
    rdfs:domain ind:OpportunityProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:firstShipmentDate rdf:type rdf:Property ;
    rdfs:label 'First Shipment Date' ;
    rdfs:comment 'Anticipated date of the first product shipment if the opportunity is won. Used for production scheduling, raw material procurement planning, and customer commitment management.' ;
    rdfs:domain ind:OpportunityProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:formulationRequired rdf:type rdf:Property ;
    rdfs:label 'Formulation Required' ;
    rdfs:comment 'Indicates whether this opportunity product line requires a customer-specific formulation or blending service rather than a standard catalog product. Triggers engagement with R&D and formulation teams.' ;
    rdfs:domain ind:OpportunityProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:listPrice rdf:type rdf:Property ;
    rdfs:label 'List Price' ;
    rdfs:comment 'Published or standard list price per unit of measure for this chemical product before any negotiated discounts or customer-specific pricing adjustments.' ;
    rdfs:domain ind:OpportunityProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:moq rdf:type rdf:Property ;
    rdfs:label 'Moq' ;
    rdfs:comment 'Minimum order quantity required for this chemical product, expressed in the quantity UOM. Communicated to the customer during opportunity negotiation to set commercial expectations.' ;
    rdfs:domain ind:OpportunityProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:opportunityProductStatus rdf:type rdf:Property ;
    rdfs:label 'Opportunity Product Status' ;
    rdfs:comment 'Current lifecycle status of this specific product line within the opportunity. Allows individual product lines to be won, lost, or withdrawn independently of the overall opportunity status.' ;
    rdfs:domain ind:OpportunityProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:probabilityWeightedRevenue rdf:type rdf:Property ;
    rdfs:label 'Probability Weighted Revenue' ;
    rdfs:comment 'Estimated revenue for this product line adjusted by the win probability percentage. Used for pipeline valuation, sales forecasting, and revenue planning at the product level.' ;
    rdfs:domain ind:OpportunityProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityUom rdf:type rdf:Property ;
    rdfs:label 'Quantity Uom' ;
    rdfs:comment 'Unit of measure for the estimated quantity field (e.g., KG for kilograms, MT for metric tons, L for liters, DRUM for drum containers). Aligns with SAP base unit of measure for the material. [ENUM-REF-CANDIDATE: KG|MT|LB|L|GAL|DRUM|IBC|BAG|TON — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesStage rdf:type rdf:Property ;
    rdfs:label 'Sales Stage' ;
    rdfs:comment 'Current sales pipeline stage for this product line, which may differ from the parent opportunity stage when individual products are at different negotiation phases. [ENUM-REF-CANDIDATE: prospecting|qualification|needs_analysis|proposal|negotiation|closed_won|closed_lost — promote to reference product]' ;
    rdfs:domain ind:OpportunityProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleRequested rdf:type rdf:Property ;
    rdfs:label 'Sample Requested' ;
    rdfs:comment 'Indicates whether the customer has requested a product sample for evaluation or qualification testing as part of this opportunity. Triggers sample order creation in SAP SD.' ;
    rdfs:domain ind:OpportunityProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sapSdItemNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Sd Item Number' ;
    rdfs:comment 'SAP SD quotation or sales order item number corresponding to this product line, used for traceability from opportunity to formal quote or order in SAP S/4HANA.' ;
    rdfs:domain ind:OpportunityProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalReviewRequired rdf:type rdf:Property ;
    rdfs:label 'Technical Review Required' ;
    rdfs:comment 'Indicates whether this product line requires a technical review by the applications engineering or R&D team before a formal proposal can be submitted to the customer.' ;
    rdfs:domain ind:OpportunityProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inventoryTargetId rdf:type rdf:Property ;
    rdfs:label 'Inventory Target Id' ;
    rdfs:comment 'Unique surrogate identifier for each stock position record representing a material at a specific storage location, bin, or tank farm. Primary key for the stock_position data product.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventoryTarget .

ind:stockPositionId rdf:type rdf:Property ;
    rdfs:label 'Stock Position Id' ;
    rdfs:comment 'Primary key for stock_position' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StockPosition .

ind:mrpRunId rdf:type rdf:Property ;
    rdfs:label 'Mrp Run Id' ;
    rdfs:comment 'Foreign key linking to planning.mrp_run. Business justification: MRP runs consume stock position data (on-hand, reserved, in-transit quantities) as primary inputs to net requirements calculation. Chemical manufacturing planners must trace which MRP run last process' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MrpRun .

ind:primaryStockMaterialMasterId rdf:type rdf:Property ;
    rdfs:label 'Primary Stock Material Master Id' ;
    rdfs:comment 'Reference to the material master record identifying the specific raw material, intermediate, finished good, or packaging material held in this stock position. Sourced from SAP MM material master.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialMaster .

ind:productionPlantId rdf:type rdf:Property ;
    rdfs:label 'Production Plant Id' ;
    rdfs:comment 'Reference to the manufacturing plant or facility where this stock position is held. Aligns with SAP organizational structure for plant-level inventory management.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductionPlant .

ind:purchaseOrderId rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Id' ;
    rdfs:comment 'Foreign key linking to supply.purchase_order. Business justification: Required for traceability of on-hand stock to the originating purchase order for regulatory recall and inventory valuation reports.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseOrder .

ind:sdsRecordId rdf:type rdf:Property ;
    rdfs:label 'Sds Record Id' ;
    rdfs:comment 'Foreign key linking to rawmaterial.sds_record. Business justification: OSHA HazCom and GHS require SDS to be accessible at the point of storage for every hazardous chemical. Linking stock_position directly to sds_record enables warehouse safety compliance checks, storage' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SdsRecord .

ind:standardCostId rdf:type rdf:Property ;
    rdfs:label 'Standard Cost Id' ;
    rdfs:comment 'Foreign key linking to finance.standard_cost. Business justification: Balance sheet inventory valuation: stock_position carries valuation_price and valuation_class used to compute inventory value. Linking to standard_cost enables automated standard cost roll-up, price v' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StandardCost .

ind:storageBinId rdf:type rdf:Property ;
    rdfs:label 'Storage Bin Id' ;
    rdfs:comment 'Foreign key linking to inventory.storage_bin. Business justification: stock_position has a storage_bin STRING column representing the bin code. storage_bin is the master record for individual bins within a warehouse location. Adding storage_bin_id FK normalizes the bin ' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageBin .

ind:warehouseLocationId rdf:type rdf:Property ;
    rdfs:label 'Warehouse Location Id' ;
    rdfs:comment 'Reference to the specific warehouse storage location, bin, or tank farm where the material is physically stored. Managed within SAP EWM warehouse structure.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WarehouseLocation .

ind:availableQuantity rdf:type rdf:Property ;
    rdfs:label 'Available Quantity' ;
    rdfs:comment 'Quantity of the material available for unrestricted use, calculated as on-hand quantity minus reserved, blocked, and quality inspection quantities. Drives ATP (Available-to-Promise) checks in SAP SD and production planning in SAP PP.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:blockedQuantity rdf:type rdf:Property ;
    rdfs:label 'Blocked Quantity' ;
    rdfs:comment 'Quantity of the material placed in blocked stock status due to quality failures, regulatory holds, damage, or quarantine. Blocked stock is not available for production or shipment until released by QA or EHS.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expirationDate rdf:type rdf:Property ;
    rdfs:label 'Expiration Date' ;
    rdfs:comment 'The date on which the material lot expires and is no longer suitable for use. Critical for FEFO (First Expired First Out) lot rotation logic, regulatory compliance, and preventing use of out-of-specification materials. Sourced from SAP batch classification.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:goodsReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Date' ;
    rdfs:comment 'The date on which the material was received into the warehouse via a goods receipt posting in SAP MM. Used as the FIFO reference date for lot rotation when manufacture date is unavailable.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inTransitQuantity rdf:type rdf:Property ;
    rdfs:label 'In Transit Quantity' ;
    rdfs:comment 'Quantity of the material currently in transit between storage locations, plants, or external suppliers. Represents stock that has been shipped but not yet received at the destination, tracked via SAP EWM transfer orders.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastCountDate rdf:type rdf:Property ;
    rdfs:label 'Last Count Date' ;
    rdfs:comment 'The date on which the most recent physical inventory count or cycle count was performed for this stock position. Used to assess inventory accuracy and schedule next count per SOX and ISO 9001 audit requirements.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastMovementDate rdf:type rdf:Property ;
    rdfs:label 'Last Movement Date' ;
    rdfs:comment 'The date of the most recent inventory movement (goods issue, goods receipt, transfer order, or stock transfer) affecting this stock position. Used to identify slow-moving or obsolete inventory for write-off analysis.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lotRotationMethod rdf:type rdf:Property ;
    rdfs:label 'Lot Rotation Method' ;
    rdfs:comment 'The inventory rotation strategy applied to this stock position for picking and consumption sequencing. FIFO (First In First Out) is used for most materials; FEFO (First Expired First Out) is mandatory for materials with expiration dates per GMP requirements.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufactureDate rdf:type rdf:Property ;
    rdfs:label 'Manufacture Date' ;
    rdfs:comment 'The date on which the material lot was manufactured or produced. Used in conjunction with expiration_date to calculate shelf life and support FIFO/FEFO rotation. Sourced from SAP batch master or COA.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maximumStockQuantity rdf:type rdf:Property ;
    rdfs:label 'Maximum Stock Quantity' ;
    rdfs:comment 'The maximum allowable stock quantity for this material at this storage location, constrained by tank capacity, regulatory storage limits, or warehouse space. Enforced by SAP EWM capacity checks and EHS hazmat storage quantity limits under OSHA PSM.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onHandQuantity rdf:type rdf:Property ;
    rdfs:label 'On Hand Quantity' ;
    rdfs:comment 'Total physical quantity of the material currently present at the storage location, including all stock types (unrestricted, quality inspection, blocked). Represents the gross inventory position before any reservations or holds are applied.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityInspectionQuantity rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Quantity' ;
    rdfs:comment 'Quantity of the material currently under quality inspection in the LIMS or SAP QM module. This stock is not available for use until the inspection lot is closed and the material is released to unrestricted stock.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quarantineReason rdf:type rdf:Property ;
    rdfs:label 'Quarantine Reason' ;
    rdfs:comment 'Free-text description of the reason this stock position has been placed in quarantine or blocked status. Examples include failed QC test, regulatory hold, contamination suspicion, or pending CAPA investigation. Populated when stock_status is quarantine or stock_type is blocked.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reorderPoint rdf:type rdf:Property ;
    rdfs:label 'Reorder Point' ;
    rdfs:comment 'The minimum stock level at which a replenishment order should be triggered for this material at this storage location. Used by SAP MRP (Material Requirements Planning) to generate purchase requisitions or production orders automatically.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reservedQuantity rdf:type rdf:Property ;
    rdfs:label 'Reserved Quantity' ;
    rdfs:comment 'Quantity of the material reserved against open production orders, sales orders, or transfer orders in SAP. Reserved stock is committed but not yet physically moved, reducing the available quantity for new demand.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyStockQuantity rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Quantity' ;
    rdfs:comment 'The minimum buffer stock quantity maintained to protect against supply disruptions, demand variability, or lead time uncertainty. Defined in SAP MRP parameters and used in available quantity calculations for production planning.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:snapshotTimestamp rdf:type rdf:Property ;
    rdfs:label 'Snapshot Timestamp' ;
    rdfs:comment 'The date and time at which this stock position record was captured or last refreshed from the source system (SAP EWM/S4HANA). Represents the as-of time for the inventory snapshot, critical for real-time inventory reporting and reconciliation.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:specialStockIndicator rdf:type rdf:Property ;
    rdfs:label 'Special Stock Indicator' ;
    rdfs:comment 'Indicates whether this stock position represents a special stock type such as consignment inventory, project stock, sales-order-specific stock, or vendor-managed inventory (VMI). Drives distinct accounting and ownership rules in SAP MM.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockCategory rdf:type rdf:Property ;
    rdfs:label 'Stock Category' ;
    rdfs:comment 'Classification of the material type held in this stock position. Drives inventory valuation rules, storage compliance requirements, and reporting segmentation across raw materials, intermediates, finished goods, and packaging materials.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockStatus rdf:type rdf:Property ;
    rdfs:label 'Stock Status' ;
    rdfs:comment 'Current lifecycle status of the stock position record. Quarantine status is applied when material is pending investigation or regulatory hold. Expired indicates the material has passed its expiration date. Recalled indicates a product recall event has been triggered.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockType rdf:type rdf:Property ;
    rdfs:label 'Stock Type' ;
    rdfs:comment 'SAP stock type classification indicating the usability state of the inventory. Unrestricted stock is available for use; quality_inspection stock is pending QC release; blocked stock is not available for use; returns stock is from customer returns; in_transit stock is between locations.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageType rdf:type rdf:Property ;
    rdfs:label 'Storage Type' ;
    rdfs:comment 'Classification of the physical storage infrastructure type where the material is held. Drives hazardous material storage compliance rules under OSHA PSM, NFPA, and DOT regulations. [ENUM-REF-CANDIDATE: bulk_tank|drum_rack|pallet_rack|cold_storage|hazmat_cage|silo|ibc_bay — promote to reference product]' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Unit Of Measure' ;
    rdfs:comment 'The base unit of measure in which all quantity fields for this stock position are expressed. Chemical manufacturing uses weight (KG, MT), volume (L, GAL, M3), and count (EA, DRUM, IBC) units depending on material type. Aligns with SAP MM base UOM. [ENUM-REF-CANDIDATE: KG|LB|L|GAL|MT|TON|EA|BAG|DRUM|IBC|M3|FT3 — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationClass rdf:type rdf:Property ;
    rdfs:label 'Valuation Class' ;
    rdfs:comment 'SAP valuation class code that determines the general ledger (GL) accounts to which inventory postings are made for this material. Links inventory movements to the correct COGS and balance sheet accounts per FASB and SOX requirements.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationCurrency rdf:type rdf:Property ;
    rdfs:label 'Valuation Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the valuation_price is expressed (e.g., USD, EUR). Required for multi-currency inventory valuation reporting across global plant locations.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationPrice rdf:type rdf:Property ;
    rdfs:label 'Valuation Price' ;
    rdfs:comment 'Reference unit price used to calculate the inventory valuation of this stock position, expressed in the valuation currency. Carried as a reference attribute for inventory reporting; authoritative valuation is owned by the Finance domain (SAP FI/CO). May reflect standard cost or moving average price per SAP valuation class.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warehouseNumber rdf:type rdf:Property ;
    rdfs:label 'Warehouse Number' ;
    rdfs:comment 'The SAP EWM warehouse number identifying the physical warehouse complex managing this stock position. Used for multi-warehouse inventory segregation and reporting.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatStorageRuleId rdf:type rdf:Property ;
    rdfs:label 'Hazmat Storage Rule Id' ;
    rdfs:comment 'Foreign key linking to inventory.hazmat_storage_rule. Business justification: warehouse_location has hazmat-related attributes (ghs_hazard_class_compatibility, fire_zone_code, ventilation_class, nfpa ratings) that should be governed by a hazmat_storage_rule. Adding hazmat_stora' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HazmatStorageRule .

ind:aisle rdf:type rdf:Property ;
    rdfs:label 'Aisle' ;
    rdfs:comment 'Alphanumeric identifier for the aisle within the warehouse where this storage location is physically situated. Used for warehouse navigation, pick path optimization, and physical inventory counting.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:areaSqm rdf:type rdf:Property ;
    rdfs:label 'Area Sqm' ;
    rdfs:comment 'Physical floor area of this storage location in square meters. Used for capacity planning, fire load calculations, and regulatory reporting of storage area dimensions per EPA and OSHA requirements.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:electricalAreaClassification rdf:type rdf:Property ;
    rdfs:label 'Electrical Area Classification' ;
    rdfs:comment 'NEC/NFPA 70 electrical area classification for this storage location, indicating the presence and likelihood of flammable vapors or combustible dust. Determines requirements for explosion-proof electrical equipment. [ENUM-REF-CANDIDATE: unclassified|class_i_div1|class_i_div2|class_ii_div1|class_ii_div2|zone_0|zone_1|zone_2 — promote to reference product]' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epaRegulatoryCitation rdf:type rdf:Property ;
    rdfs:label 'Epa Regulatory Citation' ;
    rdfs:comment 'Applicable EPA regulatory citation(s) governing storage requirements at this location (e.g., \'40 CFR Part 264 - Hazardous Waste Storage\', \'40 CFR Part 68 - RMP\'). Used for environmental compliance documentation, permit management, and regulatory audit support.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fireZoneCode rdf:type rdf:Property ;
    rdfs:label 'Fire Zone Code' ;
    rdfs:comment 'Identifier for the fire protection zone in which this storage location resides. Fire zones define the boundaries of fire suppression systems (sprinkler zones, deluge systems), fire detection circuits, and emergency evacuation areas. Referenced in PSM and HAZOP documentation.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:floorLoadCapacityKgM2 rdf:type rdf:Property ;
    rdfs:label 'Floor Load Capacity Kg M2' ;
    rdfs:comment 'Maximum allowable floor load in kilograms per square meter for this storage location. Ensures structural integrity of the warehouse floor when storing heavy drums, IBCs, or bulk containers. Referenced in facility engineering and OSHA compliance inspections.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ghsHazardClassCompatibility rdf:type rdf:Property ;
    rdfs:label 'Ghs Hazard Class Compatibility' ;
    rdfs:comment 'Pipe-delimited list of GHS hazard classes that are approved for storage at this location (e.g., \'Flammable Liquid|Oxidizer|Corrosive\'). Governs which chemical materials may be placed here based on GHS classification. Used to enforce chemical segregation rules and prevent incompatible co-storage.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:heightM rdf:type rdf:Property ;
    rdfs:label 'Height M' ;
    rdfs:comment 'Clear storage height in meters for this location. Used to determine maximum pallet stack height, forklift clearance requirements, and sprinkler system design (in-rack vs. ceiling sprinklers per NFPA 13).' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incompatibleHazardClasses rdf:type rdf:Property ;
    rdfs:label 'Incompatible Hazard Classes' ;
    rdfs:comment 'Pipe-delimited list of GHS hazard classes that must NOT be co-stored at this location due to chemical incompatibility or regulatory segregation requirements (e.g., \'Oxidizer|Explosive\'). Enforces NFPA and OSHA chemical segregation rules to prevent dangerous reactions.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isHazmatApproved rdf:type rdf:Property ;
    rdfs:label 'Is Hazmat Approved' ;
    rdfs:comment 'Indicates whether this storage location is approved and certified for the storage of hazardous materials per OSHA, EPA, and DOT regulations. True = approved for hazmat storage; False = not approved. Drives putaway rule enforcement in SAP EWM.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isQuarantineZone rdf:type rdf:Property ;
    rdfs:label 'Is Quarantine Zone' ;
    rdfs:comment 'Indicates whether this storage location is designated as a quarantine zone for materials under quality hold, regulatory hold, or investigation. True = quarantine zone; False = standard storage. Materials in quarantine zones are blocked from use in production or shipment per GMP and ISO 9001 requirements.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTemperatureControlled rdf:type rdf:Property ;
    rdfs:label 'Is Temperature Controlled' ;
    rdfs:comment 'Indicates whether this storage location has active temperature control (refrigeration, heating, or climate control). True = temperature controlled; False = ambient storage. Drives material assignment rules for temperature-sensitive chemicals and cold chain compliance.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Last Inspection Date' ;
    rdfs:comment 'Date of the most recent physical inspection or safety audit conducted at this storage location. Used to track inspection frequency compliance per OSHA PSM, EPA RMP, and internal EHS management requirements. Triggers re-inspection workflows when overdue.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:locationCode rdf:type rdf:Property ;
    rdfs:label 'Location Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the storage location within the warehouse network. Corresponds to SAP EWM storage bin or storage section code used in warehouse operations, goods movements, and transfer orders.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationName rdf:type rdf:Property ;
    rdfs:label 'Location Name' ;
    rdfs:comment 'Human-readable descriptive name for the storage location (e.g., \'Tank Farm A - Bay 3\', \'Hazmat Drum Storage Zone 2\', \'Cold Storage Room 1\'). Used in operational reports, safety documentation, and warehouse management interfaces.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationStatus rdf:type rdf:Property ;
    rdfs:label 'Location Status' ;
    rdfs:comment 'Current operational lifecycle status of the storage location. \'quarantine\' indicates the location is reserved for materials under quality hold. \'blocked\' indicates the location is temporarily unavailable for putaway or picking. \'under_maintenance\' indicates the location is undergoing inspection or repair.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationType rdf:type rdf:Property ;
    rdfs:label 'Location Type' ;
    rdfs:comment 'Classification of the physical storage location type within the warehouse network. Determines applicable storage rules, capacity constraints, and regulatory requirements. [ENUM-REF-CANDIDATE: bulk_tank|drum_storage|cold_storage|hazmat_zone|quarantine_bay|finished_goods|intermediate_storage|open_yard — promote to reference product]' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxHumidityPct rdf:type rdf:Property ;
    rdfs:label 'Max Humidity Pct' ;
    rdfs:comment 'Maximum allowable relative humidity percentage for this storage location. Prevents moisture-induced degradation, corrosion, or microbial growth in stored materials. Expressed as a percentage (0–100).' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxQuantityKg rdf:type rdf:Property ;
    rdfs:label 'Max Quantity Kg' ;
    rdfs:comment 'Maximum quantity in kilograms of hazardous material permitted in this storage zone per EPA, OSHA PSM, and NFPA regulations. Used to enforce Tier II reporting thresholds, RMP covered quantity limits, and NFPA maximum allowable quantities (MAQ) per control area.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Max Temperature C' ;
    rdfs:comment 'Maximum allowable storage temperature in degrees Celsius for this location. Prevents thermal degradation, spontaneous reaction, or ignition of stored chemicals. Enforced against material SDS storage condition requirements.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxVolumeLiters rdf:type rdf:Property ;
    rdfs:label 'Max Volume Liters' ;
    rdfs:comment 'Maximum volumetric capacity in liters for this storage location. Particularly relevant for bulk tank farms and liquid chemical storage areas. Used to enforce maximum quantity limits per EPA and OSHA regulations.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxWeightKg rdf:type rdf:Property ;
    rdfs:label 'Max Weight Kg' ;
    rdfs:comment 'Maximum allowable weight in kilograms that this storage location can safely hold. Enforced during putaway to prevent structural overloading. Critical for rack integrity compliance and OSHA load rating requirements.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minHumidityPct rdf:type rdf:Property ;
    rdfs:label 'Min Humidity Pct' ;
    rdfs:comment 'Minimum allowable relative humidity percentage for this storage location. Relevant for hygroscopic chemicals, moisture-sensitive materials, and packaging integrity. Expressed as a percentage (0–100).' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Min Temperature C' ;
    rdfs:comment 'Minimum allowable storage temperature in degrees Celsius for this location. Enforces cold chain and temperature-sensitive chemical storage requirements. Materials requiring higher minimum temperatures must not be stored here.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextInspectionDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Inspection Due Date' ;
    rdfs:comment 'Scheduled date by which the next physical inspection or safety audit of this storage location must be completed. Drives EHS compliance calendar and corrective action workflows in Intelex EHS Management.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nfpaFireDiamondFlammability rdf:type rdf:Property ;
    rdfs:label 'Nfpa Fire Diamond Flammability' ;
    rdfs:comment 'NFPA 704 flammability hazard rating (red diamond) for the storage location. Scale: 0 (will not burn) to 4 (extremely flammable). Drives fire suppression system design, electrical classification, and hot work permit requirements.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nfpaFireDiamondHealth rdf:type rdf:Property ;
    rdfs:label 'Nfpa Fire Diamond Health' ;
    rdfs:comment 'NFPA 704 health hazard rating (blue diamond) for the storage location, indicating the degree of health hazard posed by materials stored here. Scale: 0 (no hazard) to 4 (deadly). Posted on location signage for emergency responder awareness.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nfpaFireDiamondReactivity rdf:type rdf:Property ;
    rdfs:label 'Nfpa Fire Diamond Reactivity' ;
    rdfs:comment 'NFPA 704 instability/reactivity hazard rating (yellow diamond) for the storage location. Scale: 0 (stable) to 4 (may detonate). Informs emergency response procedures and incompatible material segregation requirements.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nfpaFireDiamondSpecial rdf:type rdf:Property ;
    rdfs:label 'Nfpa Fire Diamond Special' ;
    rdfs:comment 'NFPA 704 special hazard symbol (white diamond) for the storage location. Common values: \'W\' (water reactive), \'OX\' (oxidizer), \'SA\' (simple asphyxiant). Empty if no special hazard applies. Used in emergency response planning and SDS alignment.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oshaRegulatoryCitation rdf:type rdf:Property ;
    rdfs:label 'Osha Regulatory Citation' ;
    rdfs:comment 'Applicable OSHA regulatory citation(s) governing safety requirements at this storage location (e.g., \'29 CFR 1910.106 - Flammable Liquids\', \'29 CFR 1910.119 - PSM\'). Used for workplace safety compliance documentation and OSHA inspection readiness.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rack rdf:type rdf:Property ;
    rdfs:label 'Rack' ;
    rdfs:comment 'Alphanumeric identifier for the rack or bay within the aisle where this storage location is physically situated. Used in conjunction with aisle and level to precisely identify the bin coordinate.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rotationStrategy rdf:type rdf:Property ;
    rdfs:label 'Rotation Strategy' ;
    rdfs:comment 'Inventory lot rotation strategy enforced at this storage location. FIFO (First In First Out) is standard for most materials; FEFO (First Expired First Out) is required for materials with expiration dates to prevent use of expired stock. Drives SAP EWM picking strategy configuration.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageConditionCode rdf:type rdf:Property ;
    rdfs:label 'Storage Condition Code' ;
    rdfs:comment 'SAP MM/EWM storage condition code assigned to this location, used to match materials requiring specific storage conditions (e.g., flammable, corrosive, refrigerated, dry). Enforces material-location compatibility during putaway strategy execution.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageSectionCode rdf:type rdf:Property ;
    rdfs:label 'Storage Section Code' ;
    rdfs:comment 'SAP EWM storage section code grouping this location within the warehouse. Storage sections define areas with similar storage conditions (e.g., flammable liquids section, refrigerated section) and drive putaway and picking strategies.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ventilationClass rdf:type rdf:Property ;
    rdfs:label 'Ventilation Class' ;
    rdfs:comment 'Classification of the ventilation system installed at this storage location. Determines suitability for storing volatile organic compounds (VOCs), flammable vapors, and hazardous air pollutants (HAPs). Explosion-proof ventilation is required for Class I flammable liquid storage per NFPA 30.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warehouseLocationLevel rdf:type rdf:Property ;
    rdfs:label 'Warehouse Location Level' ;
    rdfs:comment 'Vertical level or tier identifier within the rack or shelving structure (e.g., \'01\' for ground level, \'02\' for second tier). Used for ergonomic storage assignment and weight-bearing capacity management.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplyPlanId rdf:type rdf:Property ;
    rdfs:label 'Supply Plan Id' ;
    rdfs:comment 'Unique surrogate identifier for the lot (batch) master record in the Silver Layer lakehouse. Primary key for all downstream joins and traceability chains.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplyPlan .

ind:campaignPlanId rdf:type rdf:Property ;
    rdfs:label 'Campaign Plan Id' ;
    rdfs:comment 'Foreign key linking to planning.campaign_plan. Business justification: Chemical manufacturing uses campaign production where multiple lots are produced in a single campaign run. Lots must reference the campaign plan for campaign yield analysis, regulatory batch records, ' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CampaignPlan .

ind:manufacturingOrderId rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Order Id' ;
    rdfs:comment 'Reference to the production order or process order under which this lot was manufactured. Null for externally procured lots. Maps to SAP Production Order (AUFNR) in PP.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ManufacturingOrder .

ind:materialSpecificationId rdf:type rdf:Property ;
    rdfs:label 'Material Specification Id' ;
    rdfs:comment 'Foreign key linking to rawmaterial.material_specification. Business justification: QC lot release in chemical manufacturing requires comparing lot test results against the active material specification version at time of receipt. This direct FK enables lot disposition reporting, CoA' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialSpecification .

ind:processOrderId rdf:type rdf:Property ;
    rdfs:label 'Process Order Id' ;
    rdfs:comment 'Foreign key linking to production.process_order. Business justification: In chemical manufacturing, a process order directly generates a production lot. Lot already links to manufacturing_order, but process_order is the execution-level entity that creates the lot. Required' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcessOrder .

ind:vendorId rdf:type rdf:Property ;
    rdfs:label 'Vendor Id' ;
    rdfs:comment 'Reference to the external supplier or vendor from whom this lot was received, applicable when lot origin is external procurement. Null for internally produced lots. Maps to SAP Vendor (LIFNR).' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:vendorSiteId rdf:type rdf:Property ;
    rdfs:label 'Vendor Site Id' ;
    rdfs:comment 'Foreign key linking to supply.vendor_site. Business justification: GMP compliance and recall management in chemical manufacturing require tracing lots to the specific vendor manufacturing site, not just the vendor. Lot-to-vendor_site enables site-specific quality aud' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VendorSite .

ind:cocNumber rdf:type rdf:Property ;
    rdfs:label 'Coc Number' ;
    rdfs:comment 'The document reference number of the Certificate of Compliance (COC) issued for this lot, attesting conformance to customer-specified or regulatory requirements beyond standard QC testing (e.g., REACH compliance, RoHS, food-contact suitability). Distinct from COA which covers analytical results.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfOrigin rdf:type rdf:Property ;
    rdfs:label 'Country Of Origin' ;
    rdfs:comment 'The ISO 3166-1 alpha-3 country code of the country where this lot was manufactured or, for natural raw materials, where it was extracted. Required for customs declarations, import/export compliance, trade preference certificates, and REACH/TSCA regulatory reporting.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentQuantity rdf:type rdf:Property ;
    rdfs:label 'Current Quantity' ;
    rdfs:comment 'The remaining unreserved quantity of material currently available in this lot, updated with each inventory movement (goods issue, transfer, adjustment). Supports real-time stock position reporting and FIFO/FEFO allocation.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daysToExpiryThreshold rdf:type rdf:Property ;
    rdfs:label 'Days To Expiry Threshold' ;
    rdfs:comment 'The number of days before expiration at which this lot should trigger an inventory alert for proactive disposition, customer notification, or markdown action. Configured per material type and customer contract requirements. Used by FEFO rotation and expiry management workflows.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dispositionStatus rdf:type rdf:Property ;
    rdfs:label 'Disposition Status' ;
    rdfs:comment 'Current quality disposition of the lot governing whether it may be used, shipped, or must be held. Released: QC-approved for use/sale. Quarantined: held pending QC decision. Rejected: failed QC and must be destroyed or reworked. Expired: past expiration date. Under Review: Out-of-Specification (OOS) or Out-of-Trend (OOT) investigation in progress. Recalled: subject to active recall action. Maps to SAP QM Usage Decision (VRBWG).' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmpStatus rdf:type rdf:Property ;
    rdfs:label 'Gmp Status' ;
    rdfs:comment 'Indicates whether this lot was manufactured under Good Manufacturing Practice (GMP) conditions as required for pharmaceutical-grade, food-contact, or regulated chemical applications. Drives customer-specific COA declarations and regulatory submissions.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grade rdf:type rdf:Property ;
    rdfs:label 'Grade' ;
    rdfs:comment 'Quality grade classification assigned to this lot based on QC test results and intended end-use application. Prime: meets full specification. Off-grade: meets reduced specification for alternative use. Technical/Pharmaceutical/Food/Agricultural grades reflect regulatory and customer-specific quality tiers. Drives pricing and customer allocation.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initialQuantity rdf:type rdf:Property ;
    rdfs:label 'Initial Quantity' ;
    rdfs:comment 'The total quantity of material in this lot at the time of creation (production completion or goods receipt). Expressed in the base unit of measure of the material. Used as the denominator for yield calculations and lot consumption tracking.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inventoryValuationPrice rdf:type rdf:Property ;
    rdfs:label 'Inventory Valuation Price' ;
    rdfs:comment 'The per-unit valuation price applied to this lot for inventory accounting purposes, expressed in the company\'s functional currency. Used for COGS calculation, inventory write-down assessment, and financial reporting. Maps to SAP Moving Average Price or Standard Price (VERPR/STPRS) in FI/CO.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lotNumber rdf:type rdf:Property ;
    rdfs:label 'Lot Number' ;
    rdfs:comment 'Externally-known alphanumeric batch/lot identifier assigned at production or goods receipt. Used on Certificate of Analysis (COA), Certificate of Compliance (COC), shipping documents, and regulatory submissions. Maps to SAP Batch Number (CHARG) in MM/QM.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moistureContentPercent rdf:type rdf:Property ;
    rdfs:label 'Moisture Content Percent' ;
    rdfs:comment 'The measured moisture content of this lot expressed as a percentage by weight, as determined by QC testing (e.g., Karl Fischer titration, loss on drying). Critical for solid and powder chemical products where moisture affects stability, reactivity, and product performance.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nfpaFireRating rdf:type rdf:Property ;
    rdfs:label 'Nfpa Fire Rating' ;
    rdfs:comment 'NFPA 704 flammability hazard rating (0-4) for the material in this lot. 0 = will not burn; 4 = will rapidly vaporize at normal conditions. Used for storage location assignment, fire suppression system design, and emergency response planning.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:origin rdf:type rdf:Property ;
    rdfs:label 'Origin' ;
    rdfs:comment 'Indicates whether this lot was created through internal manufacturing, received from an external supplier, produced via rework/reprocessing of a non-conforming lot, or originated from a customer return. Drives traceability and regulatory reporting workflows.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phValue rdf:type rdf:Property ;
    rdfs:label 'Ph Value' ;
    rdfs:comment 'The measured pH (Potential of Hydrogen) of this lot as determined by QC laboratory testing. Critical quality parameter for chemical products; drives corrosivity classification, storage material compatibility, and regulatory classification under GHS/DOT. Sourced from LabWare LIMS COA results.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:purityPercent rdf:type rdf:Property ;
    rdfs:label 'Purity Percent' ;
    rdfs:comment 'The measured purity of the primary chemical substance in this lot expressed as a percentage by weight or volume, as determined by QC analytical testing. Key quality attribute for pricing, formulation accuracy, and regulatory compliance. Sourced from LabWare LIMS COA.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qcReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Qc Release Date' ;
    rdfs:comment 'The date on which the Quality Assurance function formally released this lot from quarantine to unrestricted use following successful completion of all required QC testing. Populated from LabWare LIMS usage decision timestamp. Critical for lead-time and cycle-time analytics.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quarantineFlag rdf:type rdf:Property ;
    rdfs:label 'Quarantine Flag' ;
    rdfs:comment 'Boolean indicator that this lot is currently under quarantine and must not be issued, shipped, or consumed until released by Quality Assurance. Complements disposition_status for rapid system-level blocking in SAP EWM and WMS pick operations.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recallFlag rdf:type rdf:Property ;
    rdfs:label 'Recall Flag' ;
    rdfs:comment 'Indicates whether this lot is subject to an active product recall or market withdrawal action. When True, triggers immediate inventory blocking in SAP EWM, customer notification workflows, and regulatory reporting to FDA/EPA/ECHA as applicable.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:restrictedSubstanceFlag rdf:type rdf:Property ;
    rdfs:label 'Restricted Substance Flag' ;
    rdfs:comment 'Indicates whether this lot contains substances subject to regulatory restriction or authorization under REACH SVHC (Substances of Very High Concern), TSCA, or RoHS. Triggers compliance review before shipment to regulated markets.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retestDate rdf:type rdf:Property ;
    rdfs:label 'Retest Date' ;
    rdfs:comment 'The date by which this lot must be retested by the QC laboratory to confirm continued conformance to specification before further use or shipment. Applicable to raw materials and intermediates with defined retest intervals. Maps to SAP Batch Next Inspection Date (PRÜFDATUM).' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shelfLifeDays rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Days' ;
    rdfs:comment 'The total approved shelf life of this lot expressed in days, as defined by the material specification or stability study. Used to validate expiration date assignment and to support shelf-life remaining calculations for customer order fulfillment. Maps to SAP Material Master Total Shelf Life (MHDRZ).' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supplierLotNumber rdf:type rdf:Property ;
    rdfs:label 'Supplier Lot Number' ;
    rdfs:comment 'The original lot or batch number assigned by the external supplier, as printed on the supplier COA and shipping documents. Maintained alongside the internal lot_number for full traceability back to the supplier\'s manufacturing records. Null for internally produced lots.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vocContentPpm rdf:type rdf:Property ;
    rdfs:label 'Voc Content Ppm' ;
    rdfs:comment 'The measured or declared Volatile Organic Compound (VOC) content of this lot expressed in Parts Per Million (PPM) by weight. Required for EPA air emissions reporting, state VOC regulations, and customer environmental product declarations. Sourced from QC analytical results in LabWare LIMS.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stockMovementId rdf:type rdf:Property ;
    rdfs:label 'Stock Movement Id' ;
    rdfs:comment 'Unique surrogate identifier for each inventory movement event record in the silver layer lakehouse. Primary key for the stock_movement data product.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:batchRecordId rdf:type rdf:Property ;
    rdfs:label 'Batch Record Id' ;
    rdfs:comment 'Foreign key linking to production.batch_record. Business justification: Stock movements in chemical manufacturing are directly triggered by batch confirmations (goods receipt from production, goods issue to production). Direct FK enables movement-to-batch traceability for' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BatchRecord .

ind:goodsReceiptId rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Id' ;
    rdfs:comment 'Foreign key linking to supply.goods_receipt. Business justification: Goods receipt movements (movement type 101) in chemical manufacturing generate stock movements. Linking stock_movement to goods_receipt provides a complete audit trail from supplier delivery to invent' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GoodsReceipt .

ind:journalEntryId rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Id' ;
    rdfs:comment 'Foreign key linking to finance.journal_entry. Business justification: Goods movement to financial posting reconciliation: in SAP-based chemical manufacturing, every stock movement generates a corresponding FI journal entry. Linking enables period-end reconciliation betw' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntry .

ind:outboundDeliveryId rdf:type rdf:Property ;
    rdfs:label 'Outbound Delivery Id' ;
    rdfs:comment 'Foreign key linking to order.outbound_delivery. Business justification: Required for the Delivery Execution report to trace which stock movements belong to each outbound delivery for compliance and audit.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OutboundDelivery .

ind:plannedOrderId rdf:type rdf:Property ;
    rdfs:label 'Planned Order Id' ;
    rdfs:comment 'Foreign key linking to planning.planned_order. Business justification: Goods receipts and goods issues in inventory are triggered by planned orders converted to execution documents. Linking stock movements to originating planned orders enables MRP reconciliation, supply ' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlannedOrder .

ind:transferOrderId rdf:type rdf:Property ;
    rdfs:label 'Transfer Order Id' ;
    rdfs:comment 'Foreign key linking to inventory.transfer_order. Business justification: Link stock movement to its originating transfer order for end-to-end tracking; replace free-text field with FK.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TransferOrder .

ind:usageDecisionId rdf:type rdf:Property ;
    rdfs:label 'Usage Decision Id' ;
    rdfs:comment 'Foreign key linking to quality.usage_decision. Business justification: Usage decisions in QM directly post stock movements (unrestricted/blocked/scrap). This is the core SAP QM-MM integration in chemical manufacturing. Every quality-driven stock posting must reference th' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UsageDecision .

ind:workOrderId rdf:type rdf:Property ;
    rdfs:label 'Work Order Id' ;
    rdfs:comment 'Foreign key linking to maintenance.work_order. Business justification: Core SAP MM/PM integration: chemicals and materials issued from inventory to maintenance work orders (goods issue movement type 261) must reference the consuming work order. This supports maintenance ' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrder .

ind:destinationStorageLocation rdf:type rdf:Property ;
    rdfs:label 'Destination Storage Location' ;
    rdfs:comment 'The SAP storage location code (Lagerort) to which the material is being moved or received. Represents the target warehouse area, tank farm zone, production staging area, or quarantine location. Null for pure outbound goods issues with no destination location within the plant.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentDate rdf:type rdf:Property ;
    rdfs:label 'Document Date' ;
    rdfs:comment 'The date on the physical or external source document (e.g., vendor delivery note, production order confirmation) that triggered the inventory movement. May differ from posting_date when documents are processed with a lag. Corresponds to SAP BLDAT field.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fifoFefoValidationResult rdf:type rdf:Property ;
    rdfs:label 'Fifo Fefo Validation Result' ;
    rdfs:comment 'The result of the FIFO (First In First Out) or FEFO (First Expired First Out) lot rotation validation check performed at the time of goods issue. Passed = correct lot selected per rotation policy; Failed = incorrect lot selected, violating rotation rules; Not Applicable = movement type does not require lot rotation validation (e.g., goods receipt); Overridden = FIFO/FEFO rule was manually overridden with documented justification. Critical for chemical product quality, shelf-life management, and GMP compliance.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsReceiptBlocked rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Blocked' ;
    rdfs:comment 'Indicates whether this goods receipt movement was posted to GR blocked stock (Wareneingang gesperrt), meaning the material has been physically received but not yet released for use pending inspection or documentation review. True = posted to blocked GR stock; False = posted directly to unrestricted or inspection stock. Corresponds to SAP movement type 103/105 scenario.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:materialDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Material Document Number' ;
    rdfs:comment 'The externally-known SAP material document number (Materialbelegs-nummer) assigned by SAP S/4HANA MM upon posting the inventory movement. Serves as the primary business identifier linking back to the source system transaction. Equivalent to MBLNR in SAP.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialDocumentYear rdf:type rdf:Property ;
    rdfs:label 'Material Document Year' ;
    rdfs:comment 'The fiscal year in which the material document was posted in SAP S/4HANA MM. Combined with material_document_number forms the unique SAP document key (MBLNR + MJAHR).' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:movementAmount rdf:type rdf:Property ;
    rdfs:label 'Movement Amount' ;
    rdfs:comment 'The inventory valuation amount (in local currency) associated with this stock movement, representing the financial impact on inventory accounts. Calculated as quantity multiplied by the moving average price or standard price at time of posting. Used for COGS (Cost of Goods Sold) reporting, inventory valuation, and FI/CO integration. Corresponds to SAP DMBTR field.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:movementCategory rdf:type rdf:Property ;
    rdfs:label 'Movement Category' ;
    rdfs:comment 'High-level business classification of the inventory movement event. Goods Receipt (GR) covers inbound receipts from vendors or production; Goods Issue (GI) covers consumption or outbound shipments; Stock Transfer covers location-to-location moves; Return covers vendor or customer returns; Scrapping covers material write-offs; Sampling covers quality lab withdrawals; Revaluation covers price or valuation adjustments. Subsumes formerly separate goods_receipt and goods_issue records as movement subtypes. [ENUM-REF-CANDIDATE: goods_receipt|goods_issue|stock_transfer|return|scrapping|sampling|revaluation — promote to reference product]' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementDirection rdf:type rdf:Property ;
    rdfs:label 'Movement Direction' ;
    rdfs:comment 'Directional classification of the inventory movement relative to the plant or warehouse: inbound (stock entering the facility, e.g., goods receipt), outbound (stock leaving the facility, e.g., goods issue to customer or production), or internal (stock moving within the facility, e.g., storage location transfer). Used for net stock position calculations and directional reporting.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementReasonCode rdf:type rdf:Property ;
    rdfs:label 'Movement Reason Code' ;
    rdfs:comment 'A coded reason explaining why the inventory movement occurred, beyond what the movement type conveys. Examples include: production consumption, quality rejection, customer return, vendor return, cycle count adjustment, process loss, sampling withdrawal, spillage/waste, regulatory disposal. Corresponds to SAP GRUND field. [ENUM-REF-CANDIDATE: production_consumption|quality_rejection|customer_return|vendor_return|cycle_count_adjustment|process_loss|sampling|spillage|regulatory_disposal — promote to reference product]' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementReasonText rdf:type rdf:Property ;
    rdfs:label 'Movement Reason Text' ;
    rdfs:comment 'Free-text description providing additional context or explanation for the inventory movement reason, supplementing the movement_reason_code. Used for exception documentation, CAPA (Corrective and Preventive Action) linkage, and audit trail narratives. Corresponds to SAP text fields associated with GRUND.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementStatus rdf:type rdf:Property ;
    rdfs:label 'Movement Status' ;
    rdfs:comment 'Current lifecycle status of the stock movement record. Posted = successfully committed to inventory books; Reversed = cancelled by a subsequent reversal posting; Blocked = movement is on hold pending approval or investigation; Pending Approval = movement requires workflow approval before final posting (e.g., high-value scrapping). Supports workflow management and audit compliance.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementTypeCode rdf:type rdf:Property ;
    rdfs:label 'Movement Type Code' ;
    rdfs:comment 'SAP movement type code (Bewegungsart) that classifies the inventory transaction. Standard codes include 101 (Goods Receipt for PO), 122 (Return to Vendor), 201 (Goods Issue to Cost Center), 261 (Goods Issue for Production Order), 301 (Transfer Posting), 551 (Scrapping), 601 (Goods Issue for Delivery), 701 (Inventory Difference). Replaces the former movement_type reference table as an embedded code per product design. [ENUM-REF-CANDIDATE: 101|122|201|261|301|551|601|701|... — promote to reference product]' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Order Unit Of Measure' ;
    rdfs:comment 'The unit of measure used in the reference order document (purchase order, sales order, or production order) for this movement. Corresponds to SAP ERFME field. Enables reconciliation between order quantities and inventory quantities when UOM conversion applies.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingDate rdf:type rdf:Property ;
    rdfs:label 'Posting Date' ;
    rdfs:comment 'The principal business event date on which the inventory movement was officially posted to the books in SAP S/4HANA MM (Buchungsdatum - BUDAT). This is the date used for inventory valuation, financial period assignment, and regulatory reporting. Distinct from the document creation timestamp.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quantityInOrderUom rdf:type rdf:Property ;
    rdfs:label 'Quantity In Order Uom' ;
    rdfs:comment 'The movement quantity expressed in the order unit of measure (e.g., purchase order UOM or sales order UOM), which may differ from the base unit of measure. For example, a material ordered in drums (DR) but managed in kilograms (KG). Corresponds to SAP ERFMG field.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:referenceDocumentItem rdf:type rdf:Property ;
    rdfs:label 'Reference Document Item' ;
    rdfs:comment 'The line item number within the reference document (e.g., PO line item, production order component line) associated with this inventory movement. Combined with reference_document_number provides precise traceability to the originating document line. Corresponds to SAP EBELP (PO item) field.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Document Number' ;
    rdfs:comment 'The number of the originating reference document (e.g., Purchase Order number, Production Order number, Sales Order number, Delivery number) that triggered this inventory movement. Provides the complete audit trail linking inventory movements back to procurement, production, or sales transactions. Corresponds to SAP EBELN (PO) or AUFNR (order) depending on context.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceDocumentType rdf:type rdf:Property ;
    rdfs:label 'Reference Document Type' ;
    rdfs:comment 'The type of the originating business document that triggered this inventory movement. Purchase Order (PO) for vendor receipts; Production Order or Process Order for manufacturing consumption/receipt; Sales Order for customer-specific stock; Delivery for outbound shipments; Transfer Order for warehouse transfers; Reservation for planned withdrawals. [ENUM-REF-CANDIDATE: purchase_order|production_order|sales_order|delivery|transfer_order|process_order|reservation — promote to reference product]' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalFlag rdf:type rdf:Property ;
    rdfs:label 'Reversal Flag' ;
    rdfs:comment 'Indicates whether this stock movement record is a reversal (cancellation) of a previously posted movement. True = this document is a reversal posting that negates a prior movement; False = original movement. Essential for net inventory position calculations and audit trail integrity.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reversedDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reversed Document Number' ;
    rdfs:comment 'The material document number of the original movement that this record reverses, when reversal_flag is True. Enables bidirectional audit trail linking between original and reversal postings. Corresponds to SAP STBLG field.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourcePlantCode rdf:type rdf:Property ;
    rdfs:label 'Source Plant Code' ;
    rdfs:comment 'The SAP plant code of the sending plant for inter-plant stock transfer movements (STO - Stock Transfer Orders). Populated only for cross-plant transfers. Corresponds to SAP UMWRK field.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationType rdf:type rdf:Property ;
    rdfs:label 'Valuation Type' ;
    rdfs:comment 'SAP valuation type (Bewertungsart - BWTAR) used when a material is managed with split valuation — for example, differentiating between domestic-sourced and imported raw materials, or between different quality grades of the same chemical. Enables separate inventory valuation for the same material number.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineItemId rdf:type rdf:Property ;
    rdfs:label 'Line Item Id' ;
    rdfs:comment 'Foreign key linking to order.line_item. Business justification: Inter-plant transfer orders are often created to fulfill a particular sales order line; linking enables the Transfer Fulfillment tracking report.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LineItem .

ind:productionScheduleId rdf:type rdf:Property ;
    rdfs:label 'Production Schedule Id' ;
    rdfs:comment 'Foreign key linking to planning.production_schedule. Business justification: Transfer orders in chemical plants are generated to stage raw materials and intermediates to production areas per the production schedule. This link enables schedule-driven warehouse execution reporti' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductionSchedule .

ind:sourceStorageBinId rdf:type rdf:Property ;
    rdfs:label 'Source Storage Bin Id' ;
    rdfs:comment 'Foreign key linking to inventory.storage_bin. Business justification: transfer_order has source_bin (STRING) representing the origin bin. Adding source_storage_bin_id FK to inventory.storage_bin normalizes the source bin reference, enabling bin-level capacity tracking a' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageBin .

ind:actualStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Start Timestamp' ;
    rdfs:comment 'Date and time when the operator physically began executing the transfer order (e.g., first scan of source bin or handling unit). Enables measurement of queue wait time and operator response time.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cancellationReason rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason' ;
    rdfs:comment 'Free-text or coded reason for cancellation of the transfer order (e.g., material not found at source bin, bin blocked, production order cancelled, duplicate order). Supports root cause analysis and process improvement.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cancellation Timestamp' ;
    rdfs:comment 'Date and time when the transfer order was cancelled in SAP EWM. Populated only when transfer_order_status = \'cancelled\'. Used for exception reporting and warehouse efficiency analysis.' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:confirmationMethod rdf:type rdf:Property ;
    rdfs:label 'Confirmation Method' ;
    rdfs:comment 'Method used by the operator or system to confirm execution of the transfer order. \'rf_scan\' = RF barcode/RFID scanner; \'manual\' = paper-based or keyboard entry; \'automated_conveyor\' = conveyor system auto-confirmation; \'voice_picking\' = voice-directed warehouse system; \'agv\' = automated guided vehicle.' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmedQuantity rdf:type rdf:Property ;
    rdfs:label 'Confirmed Quantity' ;
    rdfs:comment 'Actual quantity confirmed as physically moved by the operator upon transfer order completion. May differ from transfer_quantity due to partial picks, short picks, or discrepancies discovered during execution.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confirmedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Confirmed Timestamp' ;
    rdfs:comment 'Date and time when the transfer order was fully confirmed in SAP EWM, triggering the inventory goods movement posting. Represents the principal business event time for this transaction.' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:destinationBin rdf:type rdf:Property ;
    rdfs:label 'Destination Bin' ;
    rdfs:comment 'Alphanumeric identifier of the specific storage bin, rack location, or tank to which the material is being moved. Represents the physical destination within the warehouse complex.' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationStorageSection rdf:type rdf:Property ;
    rdfs:label 'Destination Storage Section' ;
    rdfs:comment 'SAP EWM storage section within the destination storage type, providing logical grouping of target bins.' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationStorageType rdf:type rdf:Property ;
    rdfs:label 'Destination Storage Type' ;
    rdfs:comment 'SAP EWM storage type code for the target location. Used to validate compatibility with material hazard classification and storage requirements (e.g., flammable, corrosive, oxidizer segregation per OSHA PSM and NFPA codes).' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsMovementDocument rdf:type rdf:Property ;
    rdfs:label 'Goods Movement Document' ;
    rdfs:comment 'SAP MM material document number generated upon posting of the inventory goods movement triggered by transfer order confirmation. Links the physical warehouse movement to the financial inventory posting in SAP FI/CO.' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossWeightKg rdf:type rdf:Property ;
    rdfs:label 'Gross Weight Kg' ;
    rdfs:comment 'Total gross weight in kilograms of the material quantity being transferred, including packaging (drums, IBCs, pallets). Used for load planning, equipment capacity validation, and DOT hazmat transport documentation.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Planned Start Timestamp' ;
    rdfs:comment 'Scheduled date and time when the physical movement is planned to begin. Used for warehouse resource scheduling, shift planning, and SLA monitoring against production order requirements.' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:priority rdf:type rdf:Property ;
    rdfs:label 'Priority' ;
    rdfs:comment 'Numeric priority level assigned to the transfer order for warehouse queue management. Lower values indicate higher urgency (e.g., 1 = urgent production replenishment, 10 = routine reorganization). Used by SAP EWM task interleaving and resource optimization.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceStorageSection rdf:type rdf:Property ;
    rdfs:label 'Source Storage Section' ;
    rdfs:comment 'SAP EWM storage section within the source storage type, providing a logical grouping of bins (e.g., flammable liquids section, ambient section, cold storage section).' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceStorageType rdf:type rdf:Property ;
    rdfs:label 'Source Storage Type' ;
    rdfs:comment 'SAP EWM storage type code for the origin location (e.g., bulk storage, high-rack, tank farm, hazardous material cage, quarantine area). Determines handling rules and equipment requirements.' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageCondition rdf:type rdf:Property ;
    rdfs:label 'Storage Condition' ;
    rdfs:comment 'Required storage condition code for the material (e.g., ambient, refrigerated, frozen, temperature-controlled, humidity-controlled, inert atmosphere). Validates that the destination bin meets material storage requirements. [ENUM-REF-CANDIDATE: ambient|refrigerated|frozen|temperature_controlled|humidity_controlled|inert_atmosphere|flammable_cabinet — promote to reference product]' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toNumber rdf:type rdf:Property ;
    rdfs:label 'To Number' ;
    rdfs:comment 'Externally visible alphanumeric transfer order number assigned by SAP EWM. This is the business-facing identifier used in warehouse operations, printed on pick/put-away documents, and referenced in MES and WMS communications.' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferOrderStatus rdf:type rdf:Property ;
    rdfs:label 'Transfer Order Status' ;
    rdfs:comment 'Current lifecycle state of the transfer order within SAP EWM. \'created\' = issued but not yet started; \'in_progress\' = operator has begun movement; \'partially_confirmed\' = partial quantity confirmed; \'confirmed\' = fully executed and goods movement posted; \'cancelled\' = voided before execution.' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferQuantity rdf:type rdf:Property ;
    rdfs:label 'Transfer Quantity' ;
    rdfs:comment 'Planned quantity of material to be moved as specified on the transfer order at creation time. Expressed in the base unit of measure of the material (e.g., KG, L, EA, MT).' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transferType rdf:type rdf:Property ;
    rdfs:label 'Transfer Type' ;
    rdfs:comment 'Classification of the warehouse movement purpose. \'replenishment\' = restocking a pick face from reserve storage; \'putaway\' = placing newly received goods into a bin; \'pick\' = retrieving goods for outbound delivery; \'internal_transfer\' = bin-to-bin move for reorganization or hazmat segregation; \'return_to_stock\' = returning goods from staging or production back to storage.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quarantineHoldId rdf:type rdf:Property ;
    rdfs:label 'Quarantine Hold Id' ;
    rdfs:comment 'Unique system-generated identifier for the quarantine or quality hold record. Primary key for this entity.' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capaId rdf:type rdf:Property ;
    rdfs:label 'Capa Id' ;
    rdfs:comment 'Foreign key linking to quality.capa. Business justification: Quarantine holds in chemical manufacturing are resolved through CAPAs. capa_reference_number is a denormalized text field. A proper FK enables CAPA effectiveness tracking against inventory disposition' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Capa .

ind:caseId rdf:type rdf:Property ;
    rdfs:label 'Case Id' ;
    rdfs:comment 'Foreign key linking to customer.case. Business justification: In chemical mfg, customer complaints (cases) directly trigger quarantine holds on implicated inventory lots. The quarantine_hold table already stores customer_complaint_number as a plain text denormal' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Case .

ind:incomingInspectionId rdf:type rdf:Property ;
    rdfs:label 'Incoming Inspection Id' ;
    rdfs:comment 'Foreign key linking to rawmaterial.incoming_inspection. Business justification: Quarantine holds in chemical manufacturing are frequently triggered by failed incoming inspections. Linking quarantine_hold to the triggering incoming_inspection record is essential for CAPA root caus' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IncomingInspection .

ind:inspectionLotId rdf:type rdf:Property ;
    rdfs:label 'Inspection Lot Id' ;
    rdfs:comment 'Foreign key linking to quality.inspection_lot. Business justification: In chemical manufacturing, quarantine holds are directly triggered by QM inspection lots (goods receipt, in-process). The lims_inspection_lot_number plain-text field is a denormalized reference to ins' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InspectionLot .

ind:returnsOrderId rdf:type rdf:Property ;
    rdfs:label 'Returns Order Id' ;
    rdfs:comment 'Foreign key linking to product.returns_order. Business justification: In chemical manufacturing, customer returns trigger quarantine holds on returned material pending QC inspection and disposition (GMP requirement). Linking quarantine_hold to returns_order enables end-' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReturnsOrder .

ind:safetyIncidentId rdf:type rdf:Property ;
    rdfs:label 'Safety Incident Id' ;
    rdfs:comment 'Foreign key linking to ehs.safety_incident. Business justification: Quarantine holds in chemical manufacturing are frequently initiated as a direct consequence of safety incidents (contamination events, spills, chemical exposure). Linking quarantine_hold to the trigge' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SafetyIncident .

ind:actualResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Resolution Date' ;
    rdfs:comment 'Actual date on which the quarantine hold was resolved through release, rejection, or administrative closure. Compared against target resolution date for performance reporting.' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:affectedQuantityRejected rdf:type rdf:Property ;
    rdfs:label 'Affected Quantity Rejected' ;
    rdfs:comment 'Quantity of the originally held material that was condemned, destroyed, or returned to supplier following disposition. Together with affected_quantity_released, accounts for the full hold quantity.' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:affectedQuantityReleased rdf:type rdf:Property ;
    rdfs:label 'Affected Quantity Released' ;
    rdfs:comment 'Quantity of the originally held material that was ultimately released for use or shipment following disposition. May be less than hold_quantity if partial release was approved (e.g., after rework or resampling).' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchNumber rdf:type rdf:Property ;
    rdfs:label 'Batch Number' ;
    rdfs:comment 'Production batch number associated with the quarantined material, as recorded in the Manufacturing Execution System (MES) or SAP PP. May differ from lot number when multiple batches are consolidated into a single lot.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionDecision rdf:type rdf:Property ;
    rdfs:label 'Disposition Decision' ;
    rdfs:comment 'Final disposition outcome for the quarantined material: \'released\' = approved for use or shipment; \'rejected\' = condemned and removed from usable stock; \'rework\' = returned to production for reprocessing; \'retest\' = additional testing required before final decision; \'return_to_supplier\' = returned to vendor; \'destroy\' = material to be destroyed per EHS protocols; \'conditional_release\' = released with documented restrictions. [ENUM-REF-CANDIDATE: released|rejected|rework|retest|return_to_supplier|destroy|conditional_release — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionJustification rdf:type rdf:Property ;
    rdfs:label 'Disposition Justification' ;
    rdfs:comment 'Free-text narrative documenting the technical and business rationale for the disposition decision. Required for GMP compliance and regulatory audit readiness.' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Disposition Timestamp' ;
    rdfs:comment 'Date and time when the disposition decision was formally approved and recorded. Distinct from actual resolution date; captures the precise moment of authorization.' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:escalationDate rdf:type rdf:Property ;
    rdfs:label 'Escalation Date' ;
    rdfs:comment 'Date on which the quarantine hold was escalated to senior management or regulatory affairs. Null if escalation_flag is false.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:escalationFlag rdf:type rdf:Property ;
    rdfs:label 'Escalation Flag' ;
    rdfs:comment 'Indicates whether the quarantine hold has been escalated to senior QA management, regulatory affairs, or executive leadership due to severity, regulatory implications, or breach of target resolution date.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ghsHazardClass rdf:type rdf:Property ;
    rdfs:label 'Ghs Hazard Class' ;
    rdfs:comment 'GHS hazard classification of the quarantined material (e.g., \'Flammable Liquid Cat 2\', \'Acute Toxicity Cat 3\', \'Corrosive\'). Required for safe storage and handling during quarantine and for EHS compliance reporting.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardousMaterialFlag rdf:type rdf:Property ;
    rdfs:label 'Hazardous Material Flag' ;
    rdfs:comment 'Indicates whether the quarantined material is classified as hazardous under GHS, DOT, or OSHA standards. Drives special handling, storage segregation, and disposal requirements during the hold period.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:holdDate rdf:type rdf:Property ;
    rdfs:label 'Hold Date' ;
    rdfs:comment 'The date and timestamp when the quarantine hold was formally placed on the material or lot. Represents the principal business event time for this transaction.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdDurationDays rdf:type rdf:Property ;
    rdfs:label 'Hold Duration Days' ;
    rdfs:comment 'Number of calendar days the quarantine hold was active, calculated from hold_date to actual_resolution_date. Used for inventory aging analysis, SLA compliance reporting, and process improvement KPIs.' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:holdNumber rdf:type rdf:Property ;
    rdfs:label 'Hold Number' ;
    rdfs:comment 'Externally-known, human-readable reference number assigned to the quarantine hold at initiation (e.g., QH-2024-000123). Used in cross-functional communications, LIMS, and EHS systems.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdQuantity rdf:type rdf:Property ;
    rdfs:label 'Hold Quantity' ;
    rdfs:comment 'Quantity of material placed under quarantine hold. Represents the principal quantitative fact of this hold record. Must be expressed in the base unit of measure for the material.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holdQuantityUom rdf:type rdf:Property ;
    rdfs:label 'Hold Quantity Uom' ;
    rdfs:comment 'Unit of measure for the hold quantity (e.g., KG for kilograms, L for liters, MT for metric tons, DRUM for drum containers). Aligns with SAP base unit of measure (MEINS). [ENUM-REF-CANDIDATE: KG|LB|L|GAL|MT|TON|EA|BAG|DRUM|IBC — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdReasonCode rdf:type rdf:Property ;
    rdfs:label 'Hold Reason Code' ;
    rdfs:comment 'Standardized code indicating the primary reason for the quarantine hold. OOS = Out of Specification; OOT = Out of Trend; CUSTOMER_COMPLAINT = customer-reported quality issue; REGULATORY_HOLD = regulatory agency directive; DAMAGE = physical damage; CONTAMINATION = cross-contamination or foreign material; LABEL_ERROR = incorrect or missing labeling; PENDING_COA = Certificate of Analysis (COA) not yet received. [ENUM-REF-CANDIDATE: OOS|OOT|CUSTOMER_COMPLAINT|REGULATORY_HOLD|DAMAGE|CONTAMINATION|LABEL_ERROR|PENDING_COA — promote to reference product]' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Hold Reason Description' ;
    rdfs:comment 'Free-text narrative describing the specific reason for placing the material under quarantine hold. Provides context beyond the hold reason code, including test failure details, complaint summary, or regulatory directive reference.' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdStatus rdf:type rdf:Property ;
    rdfs:label 'Hold Status' ;
    rdfs:comment 'Current lifecycle state of the quarantine hold. \'open\' indicates active restriction; \'released\' indicates disposition approved for use/shipment; \'rejected\' indicates material condemned or destroyed; \'pending_review\' awaits disposition decision; \'escalated\' requires senior QA or regulatory review; \'closed\' is administratively finalized.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdType rdf:type rdf:Property ;
    rdfs:label 'Hold Type' ;
    rdfs:comment 'Classification of the quarantine hold by originating function: \'quality\' for QC/QA-initiated holds; \'regulatory\' for holds triggered by EPA, OSHA, or ECHA directives; \'safety\' for EHS-initiated holds; \'customer\' for customer complaint-driven holds; \'environmental\' for environmental compliance holds; \'administrative\' for documentation or system-related holds.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiatingSystem rdf:type rdf:Property ;
    rdfs:label 'Initiating System' ;
    rdfs:comment 'Source system that triggered or originated the quarantine hold (e.g., LIMS = LabWare LIMS for OOS results; EHS = Intelex EHS for safety incidents; SAP_QM = SAP Quality Management for inspection lot failures; MES = Manufacturing Execution System; MANUAL = manually initiated by QA personnel). [ENUM-REF-CANDIDATE: LIMS|EHS|SAP_QM|MES|MANUAL|SCADA|ERP — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiatorName rdf:type rdf:Property ;
    rdfs:label 'Initiator Name' ;
    rdfs:comment 'Full name of the person who initiated the quarantine hold. Retained for audit trail and regulatory reporting purposes where employee ID alone is insufficient.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Number' ;
    rdfs:comment 'Purchase Order (PO) number associated with the quarantined material if it was received from an external supplier. Used for supplier quality management, return-to-supplier disposition, and debit memo processing.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryHoldReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Hold Reference' ;
    rdfs:comment 'External regulatory agency reference number or directive identifier when the hold is initiated by a regulatory body (e.g., EPA enforcement action number, OSHA citation reference, FDA warning letter number, ECHA restriction notice). Null for non-regulatory holds.' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Target Resolution Date' ;
    rdfs:comment 'Target date by which the quarantine hold disposition must be resolved (released or rejected). Used for SLA tracking, escalation management, and inventory planning.' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:physicalInventoryCountId rdf:type rdf:Property ;
    rdfs:label 'Physical Inventory Count Id' ;
    rdfs:comment 'Unique surrogate identifier for each physical inventory count record in the lakehouse silver layer. Maps to SAP MM physical inventory document item.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PhysicalInventoryCount .

ind:approvalNotes rdf:type rdf:Property ;
    rdfs:label 'Approval Notes' ;
    rdfs:comment 'Free-text notes entered by the approver explaining the rationale for approving the variance write-off. Supports audit documentation and Root Cause Investigation (RCI) for recurring discrepancies.' ;
    rdfs:domain ind:PhysicalInventoryCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approval Timestamp' ;
    rdfs:comment 'Date and time when the variance write-off was approved by the authorized approver. Part of the SOX-compliant approval chain audit trail for inventory reconciliation.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:bookQuantity rdf:type rdf:Property ;
    rdfs:label 'Book Quantity' ;
    rdfs:comment 'System-recorded (book) quantity of the material at the storage location at the time the count document was created, as per SAP MM inventory records. Represents the expected quantity before physical verification.' ;
    rdfs:domain ind:PhysicalInventoryCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:countDate rdf:type rdf:Property ;
    rdfs:label 'Count Date' ;
    rdfs:comment 'Calendar date on which the physical count was performed. Used for inventory valuation cutoff, regulatory reporting, and SOX period-end reconciliation.' ;
    rdfs:domain ind:PhysicalInventoryCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:countDocumentItem rdf:type rdf:Property ;
    rdfs:label 'Count Document Item' ;
    rdfs:comment 'Line item number within the SAP physical inventory document, distinguishing individual material-storage location combinations within the same count document.' ;
    rdfs:domain ind:PhysicalInventoryCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:countDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Count Document Number' ;
    rdfs:comment 'SAP MM physical inventory document number (MI01/MI04) that uniquely identifies the count event in the source system. Used for reconciliation and audit trail back to SAP.' ;
    rdfs:domain ind:PhysicalInventoryCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countMethod rdf:type rdf:Property ;
    rdfs:label 'Count Method' ;
    rdfs:comment 'Indicates whether the count was performed blind (counter not shown book quantity, reducing bias) or informed (counter shown book quantity). Blind counting is preferred for SOX-compliant inventory reconciliation.' ;
    rdfs:domain ind:PhysicalInventoryCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countStatus rdf:type rdf:Property ;
    rdfs:label 'Count Status' ;
    rdfs:comment 'Current lifecycle status of the count document: open (count not yet performed), counted (count entered, pending posting), recounted (recount completed), posted (variance posted to inventory), cancelled (count voided).' ;
    rdfs:domain ind:PhysicalInventoryCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countTimestamp rdf:type rdf:Property ;
    rdfs:label 'Count Timestamp' ;
    rdfs:comment 'Precise date and time when the physical count was recorded, including timezone offset. Used for intraday reconciliation and audit trail in continuous process manufacturing environments.' ;
    rdfs:domain ind:PhysicalInventoryCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:countType rdf:type rdf:Property ;
    rdfs:label 'Count Type' ;
    rdfs:comment 'Classification of the count event: cycle_count (periodic scheduled count of a subset of materials), annual_wall_to_wall (full facility count), triggered_count (initiated due to discrepancy or event), or recount (second count to resolve variance).' ;
    rdfs:domain ind:PhysicalInventoryCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countedQuantity rdf:type rdf:Property ;
    rdfs:label 'Counted Quantity' ;
    rdfs:comment 'Actual physical quantity of the material counted and recorded by the counter. This is the primary measurement outcome of the count event.' ;
    rdfs:domain ind:PhysicalInventoryCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:counterName rdf:type rdf:Property ;
    rdfs:label 'Counter Name' ;
    rdfs:comment 'Full name of the employee who performed the physical count. Stored for audit readability and SOX compliance reporting without requiring a join to HR systems.' ;
    rdfs:domain ind:PhysicalInventoryCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryValuationAmount rdf:type rdf:Property ;
    rdfs:label 'Inventory Valuation Amount' ;
    rdfs:comment 'Monetary value of the inventory variance calculated as variance_quantity multiplied by the standard or moving average price of the material. Used for financial impact assessment and COGS adjustment. Expressed in local currency.' ;
    rdfs:domain ind:PhysicalInventoryCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:materialDescription rdf:type rdf:Property ;
    rdfs:label 'Material Description' ;
    rdfs:comment 'Short description of the material being counted as maintained in the SAP material master. Provides human-readable context for reporting without requiring a join to the material master.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingStatus rdf:type rdf:Property ;
    rdfs:label 'Posting Status' ;
    rdfs:comment 'Status of the variance posting to the SAP general ledger: not_posted (pending), posted (successfully posted), posting_failed (error during posting), reversed (posting reversed for correction).' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quarantineStatus rdf:type rdf:Property ;
    rdfs:label 'Quarantine Status' ;
    rdfs:comment 'Stock status of the material at time of count: unrestricted (available for use), quarantine (held pending investigation), blocked (restricted from use), quality_inspection (held for QC testing). Aligns with SAP MM stock categories.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recountFlag rdf:type rdf:Property ;
    rdfs:label 'Recount Flag' ;
    rdfs:comment 'Indicates whether a recount has been triggered for this count item, typically due to variance exceeding the tolerance threshold. True = recount required or performed; False = no recount needed.' ;
    rdfs:domain ind:PhysicalInventoryCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recountNumber rdf:type rdf:Property ;
    rdfs:label 'Recount Number' ;
    rdfs:comment 'Sequential number indicating which recount iteration this record represents (1 = first recount, 2 = second recount, etc.). Zero or null indicates the original count. Supports multi-round recount audit trails.' ;
    rdfs:domain ind:PhysicalInventoryCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:variancePercentage rdf:type rdf:Property ;
    rdfs:label 'Variance Percentage' ;
    rdfs:comment 'Variance quantity expressed as a percentage of book quantity. Used to determine whether variance exceeds tolerance thresholds requiring management approval or recount. Key KPI for inventory accuracy reporting.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceQuantity rdf:type rdf:Property ;
    rdfs:label 'Variance Quantity' ;
    rdfs:comment 'Difference between counted quantity and book quantity (counted_quantity minus book_quantity). Positive value indicates surplus; negative value indicates shortage. Drives inventory adjustment postings.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceTolerancePct rdf:type rdf:Property ;
    rdfs:label 'Variance Tolerance Pct' ;
    rdfs:comment 'Allowable variance percentage threshold configured for this material or material group. Variances exceeding this threshold require management approval for write-off. Supports SOX-compliant variance authorization controls.' ;
    rdfs:domain ind:PhysicalInventoryCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:withinToleranceFlag rdf:type rdf:Property ;
    rdfs:label 'Within Tolerance Flag' ;
    rdfs:comment 'Indicates whether the variance percentage is within the configured tolerance threshold. True = variance is acceptable and can be auto-posted; False = variance exceeds tolerance and requires manual approval.' ;
    rdfs:domain ind:PhysicalInventoryCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:classificationSystem rdf:type rdf:Property ;
    rdfs:label 'Classification System' ;
    rdfs:comment 'Primary hazard classification system under which this storage rule is defined (e.g., GHS for global chemical classification, NFPA for US fire codes, UN for transport, IMDG for maritime, CLP for EU). Determines which regulatory framework governs the rule\'s applicability. [ENUM-REF-CANDIDATE: GHS|NFPA|UN|DOT|IMDG|IATA|CLP|WHMIS — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:HazmatStorageRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fireSuppressionRequired rdf:type rdf:Property ;
    rdfs:label 'Fire Suppression Required' ;
    rdfs:comment 'Indicates whether an automatic fire suppression system (sprinkler, deluge, foam, or dry chemical) is required at the storage location for chemicals governed by this rule. Drives facility engineering requirements and influences NFPA 400 maximum allowable quantity multipliers.' ;
    rdfs:domain ind:HazmatStorageRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fireZoneType rdf:type rdf:Property ;
    rdfs:label 'Fire Zone Type' ;
    rdfs:comment 'Classification of the fire zone or control area type to which the maximum quantity limit applies. NFPA 400 and IFC allow higher MAQ in sprinklered buildings versus unprotected control areas. Drives differentiated quantity limits in SAP EWM storage type configuration.' ;
    rdfs:domain ind:HazmatStorageRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ghsHazardStatementCodes rdf:type rdf:Property ;
    rdfs:label 'Ghs Hazard Statement Codes' ;
    rdfs:comment 'Comma-separated list of GHS H-statement codes applicable to chemicals governed by this rule (e.g., H225,H302,H314). Drives SDS Section 2 alignment and label generation. Used in REACH and CLP regulatory reporting.' ;
    rdfs:domain ind:HazmatStorageRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groundingBondingRequired rdf:type rdf:Property ;
    rdfs:label 'Grounding Bonding Required' ;
    rdfs:comment 'Indicates whether electrical grounding and bonding equipment is required at the storage location for chemicals governed by this rule. Mandatory for flammable liquids with flash points below 100°F to prevent static discharge ignition per NFPA 77 and OSHA standards.' ;
    rdfs:domain ind:HazmatStorageRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazardSubRisk rdf:type rdf:Property ;
    rdfs:label 'Hazard Sub Risk' ;
    rdfs:comment 'Secondary hazard classification or division providing additional specificity within the primary hazard class (e.g., Division 1.1 for mass explosion risk, Packing Group I/II/III, sub-risk 6.1 on a Class 3 flammable). Captures multi-hazard chemical profiles per GHS and UN regulations.' ;
    rdfs:domain ind:HazmatStorageRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incompatibilityConsequence rdf:type rdf:Property ;
    rdfs:label 'Incompatibility Consequence' ;
    rdfs:comment 'Primary hazardous consequence that would result from co-locating the two incompatible hazard classes defined in this rule. Used in risk assessment, PHA/HAZOP documentation, and emergency response planning. Informs the severity weighting in automated putaway violation alerts.' ;
    rdfs:domain ind:HazmatStorageRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incompatibleHazardClassA rdf:type rdf:Property ;
    rdfs:label 'Incompatible Hazard Class A' ;
    rdfs:comment 'First hazard class in the incompatible pair defined by this segregation rule. Together with incompatible_hazard_class_b, forms the segregation matrix entry that prohibits co-location of chemicals from these two hazard classes in the same storage zone. Aligns with NFPA 400 Table 10.3.2 and UN segregation table.' ;
    rdfs:domain ind:HazmatStorageRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incompatibleHazardClassB rdf:type rdf:Property ;
    rdfs:label 'Incompatible Hazard Class B' ;
    rdfs:comment 'Second hazard class in the incompatible pair defined by this segregation rule. Together with incompatible_hazard_class_a, forms the segregation matrix entry. The automated putaway validation engine in SAP EWM checks both directions of this pair to prevent co-location of incompatible chemicals.' ;
    rdfs:domain ind:HazmatStorageRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReviewedDate rdf:type rdf:Property ;
    rdfs:label 'Last Reviewed Date' ;
    rdfs:comment 'Date on which this storage rule was last reviewed for continued regulatory accuracy and operational relevance. ISO 14001 and ISO 45001 require periodic review of EHS controls. Triggers a review workflow in Intelex EHS Management when overdue.' ;
    rdfs:domain ind:HazmatStorageRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maxQuantityPerFireZoneKg rdf:type rdf:Property ;
    rdfs:label 'Max Quantity Per Fire Zone Kg' ;
    rdfs:comment 'Maximum allowable quantity in kilograms of chemicals governed by this rule that may be stored within a single fire zone or control area. Derived from NFPA 400 maximum allowable quantities (MAQ) tables and local fire code. Enforced by SAP EWM inventory capacity checks.' ;
    rdfs:domain ind:HazmatStorageRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxQuantityPerFireZoneL rdf:type rdf:Property ;
    rdfs:label 'Max Quantity Per Fire Zone L' ;
    rdfs:comment 'Maximum allowable quantity in liters of liquid chemicals governed by this rule that may be stored within a single fire zone or control area. Complements the kilogram-based limit for liquid hazmat categories where volume is the regulatory basis (e.g., NFPA 30 flammable liquids).' ;
    rdfs:domain ind:HazmatStorageRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxStorageTempC rdf:type rdf:Property ;
    rdfs:label 'Max Storage Temp C' ;
    rdfs:comment 'Maximum allowable storage temperature in degrees Celsius for chemicals governed by this rule. Exceeding this threshold may cause decomposition, polymerization, or ignition. Monitored via Aveva PI System historian and triggers automated EHS alerts in Intelex.' ;
    rdfs:domain ind:HazmatStorageRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minStorageTempC rdf:type rdf:Property ;
    rdfs:label 'Min Storage Temp C' ;
    rdfs:comment 'Minimum allowable storage temperature in degrees Celsius for chemicals governed by this rule. Below this threshold, the chemical may solidify, become unstable, or lose efficacy. Monitored via Aveva PI System historian for real-time compliance alerting.' ;
    rdfs:domain ind:HazmatStorageRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Review Date' ;
    rdfs:comment 'Date by which this storage rule must next be reviewed for regulatory currency and operational accuracy. Calculated based on review frequency policy (typically annual for high-hazard rules). Drives compliance calendar in Intelex EHS Management.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nfpaFlammabilityRating rdf:type rdf:Property ;
    rdfs:label 'Nfpa Flammability Rating' ;
    rdfs:comment 'NFPA 704 fire diamond flammability rating (0–4) for chemicals governed by this rule. Rating 4 indicates materials that will rapidly vaporize at normal pressure and temperature. Used in fire zone maximum quantity calculations and emergency response planning.' ;
    rdfs:domain ind:HazmatStorageRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nfpaHealthRating rdf:type rdf:Property ;
    rdfs:label 'Nfpa Health Rating' ;
    rdfs:comment 'NFPA 704 fire diamond health hazard rating (0–4) for chemicals governed by this rule. Rating 4 indicates materials that can cause death or major residual injury on short exposure. Used in PPE requirements and emergency response planning.' ;
    rdfs:domain ind:HazmatStorageRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nfpaReactivityRating rdf:type rdf:Property ;
    rdfs:label 'Nfpa Reactivity Rating' ;
    rdfs:comment 'NFPA 704 fire diamond instability/reactivity rating (0–4) for chemicals governed by this rule. Rating 4 indicates materials capable of detonation or explosive decomposition at normal temperatures and pressures.' ;
    rdfs:domain ind:HazmatStorageRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nfpaSpecialHazardCode rdf:type rdf:Property ;
    rdfs:label 'Nfpa Special Hazard Code' ;
    rdfs:comment 'NFPA 704 special hazard symbol code for chemicals governed by this rule (e.g., W = water-reactive, OX = oxidizer, SA = simple asphyxiant, BIO = biological hazard, CRY = cryogenic). Governs special storage precautions and emergency response procedures. [ENUM-REF-CANDIDATE: W|OX|SA|BIO|COR|POI|RAD|CRY|ACID|ALK — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:HazmatStorageRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packingGroup rdf:type rdf:Property ;
    rdfs:label 'Packing Group' ;
    rdfs:comment 'UN packing group designation (I = great danger, II = medium danger, III = minor danger) for the hazardous material governed by this rule. Determines packaging requirements for transport and influences storage quantity limits and segregation requirements.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reachRegulationReference rdf:type rdf:Property ;
    rdfs:label 'Reach Regulation Reference' ;
    rdfs:comment 'REACH regulation article or annex reference applicable to this storage rule (e.g., \'REACH Annex XVII Restriction Entry 3\', \'REACH Article 56 Authorization\'). Required for EU operations and ECHA compliance reporting. Populated for chemicals on the SVHC candidate list.' ;
    rdfs:domain ind:HazmatStorageRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleCode rdf:type rdf:Property ;
    rdfs:label 'Rule Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this storage rule within the enterprise rule catalog (e.g., HSR-001, FLAM-OX-SEG-01). Used as the human-readable business key in SAP EWM putaway strategies and EHS management systems.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleDescription rdf:type rdf:Property ;
    rdfs:label 'Rule Description' ;
    rdfs:comment 'Full narrative description of the storage rule, including the rationale for the segregation or storage condition requirement, the chemical hazard interaction being prevented, and any operational guidance for warehouse personnel.' ;
    rdfs:domain ind:HazmatStorageRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleName rdf:type rdf:Property ;
    rdfs:label 'Rule Name' ;
    rdfs:comment 'Descriptive short name for the storage rule (e.g., \'Flammable-Oxidizer Segregation\', \'Corrosive-Reactive Incompatibility\'). Used in warehouse management UI labels and EHS compliance reports.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleStatus rdf:type rdf:Property ;
    rdfs:label 'Rule Status' ;
    rdfs:comment 'Current lifecycle status of the storage rule record. \'active\' rules are enforced in automated putaway validation. \'superseded\' rules have been replaced by a newer version. \'under_review\' rules are pending regulatory or internal re-assessment.' ;
    rdfs:domain ind:HazmatStorageRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleVersion rdf:type rdf:Property ;
    rdfs:label 'Rule Version' ;
    rdfs:comment 'Version identifier for this storage rule record (e.g., v1.0, v2.3). Supports rule versioning when regulatory updates require rule revisions. Enables audit trail of rule changes over time and ensures warehouse systems reference the current approved version.' ;
    rdfs:domain ind:HazmatStorageRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdsSectionReferences rdf:type rdf:Property ;
    rdfs:label 'Sds Section References' ;
    rdfs:comment 'Comma-separated list of SDS section numbers that provide the source data for this storage rule (e.g., \'7,8,10,14\'). Section 7 = Handling and Storage, Section 8 = Exposure Controls, Section 10 = Reactivity, Section 14 = Transport. Enables traceability from rule to SDS source documentation per GHS.' ;
    rdfs:domain ind:HazmatStorageRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segregationDistanceM rdf:type rdf:Property ;
    rdfs:label 'Segregation Distance M' ;
    rdfs:comment 'Minimum physical separation distance in meters required between storage locations holding chemicals from the two incompatible hazard classes defined in this rule. Used by SAP EWM bin assignment logic to enforce spatial separation within the warehouse or tank farm.' ;
    rdfs:domain ind:HazmatStorageRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageLocationType rdf:type rdf:Property ;
    rdfs:label 'Storage Location Type' ;
    rdfs:comment 'Type of physical storage location required for chemicals governed by this rule. Drives SAP EWM storage type determination during putaway. \'tank_farm\' applies to bulk liquid chemicals. \'refrigerated_room\' applies to temperature-sensitive hazmat. Validated against warehouse master data.' ;
    rdfs:domain ind:HazmatStorageRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allowedMaterialTypes rdf:type rdf:Property ;
    rdfs:label 'Allowed Material Types' ;
    rdfs:comment 'Comma-separated list of SAP material type codes (e.g., ROH for raw materials, FERT for finished goods, HALB for semi-finished, VERP for packaging) permitted to be stored in this bin. Enforces material segregation rules for chemical compatibility and regulatory compliance.' ;
    rdfs:domain ind:StorageBin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:binAccessType rdf:type rdf:Property ;
    rdfs:label 'Bin Access Type' ;
    rdfs:comment 'Type of material handling equipment required to access this storage bin. Determines equipment assignment during transfer order creation and supports warehouse resource planning. Critical for safety compliance in chemical warehouses where certain hazmat bins require specialized handling equipment.' ;
    rdfs:domain ind:StorageBin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:binCode rdf:type rdf:Property ;
    rdfs:label 'Bin Code' ;
    rdfs:comment 'Alphanumeric code that uniquely identifies the physical storage bin within a warehouse number and storage type. Corresponds to the SAP EWM Lgpla field. Used in directed putaway, picking, and bin-level inventory queries.' ;
    rdfs:domain ind:StorageBin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:binDescription rdf:type rdf:Property ;
    rdfs:label 'Bin Description' ;
    rdfs:comment 'Free-text description of the storage bin providing additional context about its physical characteristics, special use restrictions, or operational notes. May include information about dedicated chemical families, special handling requirements, or historical usage notes.' ;
    rdfs:domain ind:StorageBin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:binName rdf:type rdf:Property ;
    rdfs:label 'Bin Name' ;
    rdfs:comment 'Human-readable descriptive name or label for the storage bin, used in warehouse operations, signage, and reporting. May include aisle, row, and level descriptors (e.g., \'Aisle-A Row-03 Level-02\') to aid physical navigation.' ;
    rdfs:domain ind:StorageBin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:binStatus rdf:type rdf:Property ;
    rdfs:label 'Bin Status' ;
    rdfs:comment 'Current operational lifecycle status of the storage bin. Active bins are available for putaway and picking. Blocked bins are temporarily unavailable. Quarantine status is applied when contents are under quality hold per QM procedures. Maintenance status indicates the bin is undergoing physical inspection or repair.' ;
    rdfs:domain ind:StorageBin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:binType rdf:type rdf:Property ;
    rdfs:label 'Bin Type' ;
    rdfs:comment 'Classification of the physical bin configuration. Fixed bins are dedicated to specific materials (e.g., hazardous chemicals); random bins accept any compatible material; bulk bins hold large quantities; tank bins represent liquid storage vessels in tank farms; floor bins are ground-level pallet positions; rack bins are elevated rack locations.' ;
    rdfs:domain ind:StorageBin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containmentType rdf:type rdf:Property ;
    rdfs:label 'Containment Type' ;
    rdfs:comment 'Type of secondary containment infrastructure present at this storage bin to prevent chemical spills from reaching drains or the environment. Secondary bund and tank bund are used for bulk liquid chemical storage; spill pallets for drum storage; lined floor for general chemical areas. Required for EPA SPCC compliance and ISO 14001 environmental management.' ;
    rdfs:domain ind:StorageBin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Current Volume M3' ;
    rdfs:comment 'Current total volume in cubic meters occupied by stock in the bin. Compared against max_volume_m3 to determine available capacity for putaway decisions.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentWeightKg rdf:type rdf:Property ;
    rdfs:label 'Current Weight Kg' ;
    rdfs:comment 'Current total gross weight in kilograms of all stock currently stored in the bin. Updated upon each goods movement. Used to monitor bin load against maximum weight capacity and support structural safety compliance.' ;
    rdfs:domain ind:StorageBin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deactivationDate rdf:type rdf:Property ;
    rdfs:label 'Deactivation Date' ;
    rdfs:comment 'Date on which the storage bin was or is scheduled to be deactivated and removed from active warehouse operations. Null for currently active bins. Supports bin lifecycle management and warehouse restructuring projects.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fireProtectionZone rdf:type rdf:Property ;
    rdfs:label 'Fire Protection Zone' ;
    rdfs:comment 'NFPA fire protection zone or compartment designation assigned to the storage bin. Used to enforce fire load limits, sprinkler system coverage mapping, and emergency response planning for flammable and combustible chemical storage areas.' ;
    rdfs:domain ind:StorageBin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isFixedBin rdf:type rdf:Property ;
    rdfs:label 'Is Fixed Bin' ;
    rdfs:comment 'Indicates whether this bin is a fixed bin permanently assigned to a specific material or material group, as opposed to a random bin available for any compatible material. True = fixed bin assignment; False = random bin. Drives SAP EWM putaway strategy determination.' ;
    rdfs:domain ind:StorageBin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isQuarantineBin rdf:type rdf:Property ;
    rdfs:label 'Is Quarantine Bin' ;
    rdfs:comment 'Indicates whether this bin is designated as a quarantine storage location for materials under quality hold, out-of-specification (OOS) status, or pending Certificate of Analysis (COA) release. True = quarantine bin; False = standard bin. Integrates with SAP QM quality inspection workflows.' ;
    rdfs:domain ind:StorageBin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastPhysicalInventoryDate rdf:type rdf:Property ;
    rdfs:label 'Last Physical Inventory Date' ;
    rdfs:comment 'Date on which the most recent physical inventory count or cycle count was performed for this storage bin. Used to track inventory accuracy compliance, schedule future counts, and support SOX financial reporting requirements for inventory valuation.' ;
    rdfs:domain ind:StorageBin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maxQuantity rdf:type rdf:Property ;
    rdfs:label 'Max Quantity' ;
    rdfs:comment 'Maximum number of handling units (pallets, drums, IBCs, or containers) that can be stored in the bin simultaneously. Enforced during directed putaway to prevent overfilling.' ;
    rdfs:domain ind:StorageBin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxStackingHeightM rdf:type rdf:Property ;
    rdfs:label 'Max Stacking Height M' ;
    rdfs:comment 'Maximum allowable stacking height in meters for materials stored in this bin. Enforced to prevent structural overload and comply with OSHA stacking safety regulations. Particularly relevant for drum and IBC storage of liquid chemicals.' ;
    rdfs:domain ind:StorageBin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Max Volume M3' ;
    rdfs:comment 'Maximum storage volume in cubic meters available within the bin. Used for volumetric capacity planning, putaway feasibility checks, and tank farm liquid volume management.' ;
    rdfs:domain ind:StorageBin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:occupancyStatus rdf:type rdf:Property ;
    rdfs:label 'Occupancy Status' ;
    rdfs:comment 'Real-time occupancy state of the storage bin indicating whether the bin is empty, fully occupied, partially occupied, or reserved for an incoming transfer order. Drives directed putaway logic in SAP EWM and supports inventory accuracy reporting.' ;
    rdfs:domain ind:StorageBin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickingPoint rdf:type rdf:Property ;
    rdfs:label 'Picking Point' ;
    rdfs:comment 'SAP EWM picking point bin code associated with this storage bin. For bulk or reserve storage bins, identifies the forward pick face bin from which order picking is executed. Supports two-step picking workflows common in chemical distribution operations.' ;
    rdfs:domain ind:StorageBin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:putawayStrategy rdf:type rdf:Property ;
    rdfs:label 'Putaway Strategy' ;
    rdfs:comment 'SAP EWM putaway strategy assigned to this bin that determines how incoming stock is directed to storage locations. Fixed strategy assigns stock to pre-defined bins; open storage allows any compatible bin; bulk strategy consolidates large quantities; near-picking places fast-movers close to pick areas; addition-to-existing consolidates partial bins.' ;
    rdfs:domain ind:StorageBin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rowNumber rdf:type rdf:Property ;
    rdfs:label 'Row Number' ;
    rdfs:comment 'Row number within the aisle that identifies the horizontal position of the storage bin. Combined with aisle and level, provides the full physical coordinate of the bin within the warehouse.' ;
    rdfs:domain ind:StorageBin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageBinLevel rdf:type rdf:Property ;
    rdfs:label 'Storage Bin Level' ;
    rdfs:comment 'Vertical level or tier of the storage bin within a rack structure. Level 1 is ground floor; higher numbers indicate elevated rack positions. Used for equipment assignment (e.g., forklift vs. reach truck) and weight distribution planning.' ;
    rdfs:domain ind:StorageBin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageTypeCode rdf:type rdf:Property ;
    rdfs:label 'Storage Type Code' ;
    rdfs:comment 'SAP EWM storage type (Lgtyp) code that classifies the physical area of the warehouse where this bin resides, such as high-rack storage, bulk storage, tank farm, or hazardous material area. Drives putaway and picking strategies.' ;
    rdfs:domain ind:StorageBin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureZone rdf:type rdf:Property ;
    rdfs:label 'Temperature Zone' ;
    rdfs:comment 'Temperature-controlled storage zone classification for the bin. Ambient bins operate at room temperature; refrigerated bins maintain 2–8°C for temperature-sensitive chemicals or intermediates; heated bins prevent solidification of high-melting-point materials; controlled bins maintain a specific validated temperature range per product specification.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ventilationRequired rdf:type rdf:Property ;
    rdfs:label 'Ventilation Required' ;
    rdfs:comment 'Indicates whether this storage bin requires dedicated ventilation or is located in a ventilated area to manage volatile organic compound (VOC) emissions or hazardous air pollutant (HAP) concentrations. True = ventilation required; False = no special ventilation needed. Supports EHS compliance with EPA and OSHA air quality standards.' ;
    rdfs:domain ind:StorageBin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stockReservationId rdf:type rdf:Property ;
    rdfs:label 'Stock Reservation Id' ;
    rdfs:comment 'Unique system-generated surrogate identifier for the stock reservation record in the inventory management system.' ;
    rdfs:domain ind:StockReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:customerAllocationId rdf:type rdf:Property ;
    rdfs:label 'Customer Allocation Id' ;
    rdfs:comment 'Foreign key linking to planning.customer_allocation. Business justification: In chemical manufacturing supply constraints, customer allocations authorize specific reservation quantities per customer. Stock reservations must reference the customer allocation that authorized the' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerAllocation .

ind:internalOrderId rdf:type rdf:Property ;
    rdfs:label 'Internal Order Id' ;
    rdfs:comment 'Foreign key linking to finance.internal_order. Business justification: Project budget consumption monitoring: stock reservations for maintenance shutdowns, R&D, or capital projects are created against internal orders. Linking enables real-time budget consumption tracking' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InternalOrder .

ind:orderId rdf:type rdf:Property ;
    rdfs:label 'Order Id' ;
    rdfs:comment 'Reference to the production order, customer delivery order, or maintenance work order that will consume the reserved stock. Establishes the demand source driving the reservation.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:autoReleaseFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Release Flag' ;
    rdfs:comment 'Indicates whether the reservation should be automatically released back to available stock upon reaching the expiry date without fulfillment. Supports automated inventory management and prevents indefinite stock lock-up.' ;
    rdfs:domain ind:StockReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consumingOrderType rdf:type rdf:Property ;
    rdfs:label 'Consuming Order Type' ;
    rdfs:comment 'Specifies the type of the consuming order document. Distinguishes between production orders, process orders (for batch chemical manufacturing), sales delivery orders, maintenance orders, and project orders to support domain-specific analytics.' ;
    rdfs:domain ind:StockReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfilledQuantity rdf:type rdf:Property ;
    rdfs:label 'Fulfilled Quantity' ;
    rdfs:comment 'Cumulative quantity of the reservation that has already been issued or withdrawn against the consuming order. Used to calculate the remaining open quantity and determine partial fulfillment status.' ;
    rdfs:domain ind:StockReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oosFlag rdf:type rdf:Property ;
    rdfs:label 'Oos Flag' ;
    rdfs:comment 'Indicates whether the reserved lot has been flagged as Out of Specification (OOS) by the quality management system. An OOS reservation is blocked from fulfillment pending CAPA resolution.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:partialFulfillmentAllowed rdf:type rdf:Property ;
    rdfs:label 'Partial Fulfillment Allowed' ;
    rdfs:comment 'Indicates whether the consuming order can accept a partial goods issue against this reservation, or whether the full reserved quantity must be issued in a single transaction. Relevant for batch chemical processes with minimum charge quantities.' ;
    rdfs:domain ind:StockReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requirementDate rdf:type rdf:Property ;
    rdfs:label 'Requirement Date' ;
    rdfs:comment 'The date on which the reserved material is required for consumption by the planned event (production start date, delivery date, or maintenance execution date). Drives FEFO/FIFO lot selection and warehouse picking scheduling.' ;
    rdfs:domain ind:StockReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reservationDate rdf:type rdf:Property ;
    rdfs:label 'Reservation Date' ;
    rdfs:comment 'The business date on which the stock reservation was created and the stock was earmarked. Represents the principal real-world event time for the reservation transaction.' ;
    rdfs:domain ind:StockReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reservationNumber rdf:type rdf:Property ;
    rdfs:label 'Reservation Number' ;
    rdfs:comment 'Externally-known alphanumeric reservation document number assigned by the ERP or WMS system (e.g., SAP reservation number). Used for cross-system reference and communication with warehouse operations.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reservationReasonCode rdf:type rdf:Property ;
    rdfs:label 'Reservation Reason Code' ;
    rdfs:comment 'Business reason code explaining why the reservation was created (e.g., scheduled production run, emergency maintenance, customer priority order, safety stock replenishment). Supports demand analysis and inventory planning. [ENUM-REF-CANDIDATE: scheduled_production|emergency_maintenance|customer_priority|safety_stock|quality_sample|r_and_d_trial|regulatory_hold — promote to reference product]' ;
    rdfs:domain ind:StockReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reservationStatus rdf:type rdf:Property ;
    rdfs:label 'Reservation Status' ;
    rdfs:comment 'Current lifecycle state of the stock reservation. \'open\' indicates no goods movement has occurred; \'partially_fulfilled\' indicates some quantity has been issued; \'fulfilled\' indicates full quantity has been issued; \'cancelled\' indicates the reservation was voided before consumption.' ;
    rdfs:domain ind:StockReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reservationType rdf:type rdf:Property ;
    rdfs:label 'Reservation Type' ;
    rdfs:comment 'Classification of the demand event driving the reservation. Distinguishes between production order consumption, customer delivery fulfillment, maintenance work order material staging, project-based withdrawal, or manually created reservations.' ;
    rdfs:domain ind:StockReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdsVerified rdf:type rdf:Property ;
    rdfs:label 'Sds Verified' ;
    rdfs:comment 'Indicates whether the current Safety Data Sheet (SDS) for the reserved material has been verified as up-to-date and accessible prior to reservation fulfillment. Required for hazardous chemical handling compliance.' ;
    rdfs:domain ind:StockReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:storageLocationCode rdf:type rdf:Property ;
    rdfs:label 'Storage Location Code' ;
    rdfs:comment 'SAP storage location code within the plant identifying the specific physical area (e.g., raw material warehouse, tank farm, hazmat storage, quarantine area) where the reserved stock is held.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tankFarmLevelId rdf:type rdf:Property ;
    rdfs:label 'Tank Farm Level Id' ;
    rdfs:comment 'Unique surrogate identifier for each tank farm level measurement record in the Silver Layer lakehouse. Primary key for this entity.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TankFarmLevel .

ind:notificationId rdf:type rdf:Property ;
    rdfs:label 'Notification Id' ;
    rdfs:comment 'Foreign key linking to maintenance.notification. Business justification: Tank level alarm breaches (high/low level alarms) in chemical plants automatically generate maintenance notifications in the CMMS via DCS/historian integration. Linking tank_farm_level readings to the' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Notification .

ind:primaryTankMaterialMasterId rdf:type rdf:Property ;
    rdfs:label 'Primary Tank Material Master Id' ;
    rdfs:comment 'Reference to the material master record identifying the bulk liquid chemical currently stored in the tank at the time of measurement.' ;
    rdfs:domain ind:TankFarmLevel ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialMaster .

ind:tankId rdf:type rdf:Property ;
    rdfs:label 'Tank Id' ;
    rdfs:comment 'Reference to the storage tank asset record that this level measurement belongs to. Links to the tank master data entity in the inventory or asset domain.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Tank .

ind:belowReorderPointFlag rdf:type rdf:Property ;
    rdfs:label 'Below Reorder Point Flag' ;
    rdfs:comment 'Indicates whether the current tank inventory mass is at or below the defined reorder point threshold (True = replenishment required, False = adequate stock). Enables real-time inventory replenishment alerting and integration with SAP MM MRP processes.' ;
    rdfs:domain ind:TankFarmLevel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:casNumber rdf:type rdf:Property ;
    rdfs:label 'Cas Number' ;
    rdfs:comment 'The Chemical Abstracts Service (CAS) registry number uniquely identifying the chemical substance stored in the tank. Critical for regulatory reporting (TSCA, REACH, TRI), SDS linkage, and hazardous material compliance tracking.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataCollectionMethod rdf:type rdf:Property ;
    rdfs:label 'Data Collection Method' ;
    rdfs:comment 'Describes how this measurement record was collected: automatic (real-time instrument feed via PI historian), manual (operator-entered gauge reading), or interpolated (value estimated between two valid readings). Supports data quality governance and audit trail requirements.' ;
    rdfs:domain ind:TankFarmLevel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:densityKgM3 rdf:type rdf:Property ;
    rdfs:label 'Density Kg M3' ;
    rdfs:comment 'The density of the stored liquid at the measurement temperature, expressed in kilograms per cubic meter (kg/m³). Used to convert volume measurements to mass for inventory valuation and material balance. May be measured in-line or derived from temperature-corrected reference data.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ghsHazardCategory rdf:type rdf:Property ;
    rdfs:label 'Ghs Hazard Category' ;
    rdfs:comment 'The GHS hazard category code for the stored chemical (e.g., Flammable Liquid Cat 1, Acute Toxicity Cat 3). Supports SDS compliance, emergency response documentation, and regulatory reporting under REACH, TSCA, and EPA requirements.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatStorageClass rdf:type rdf:Property ;
    rdfs:label 'Hazmat Storage Class' ;
    rdfs:comment 'The hazardous material storage class designation for the chemical stored in the tank, based on GHS/DOT classification (e.g., Class 3 Flammable Liquid, Class 8 Corrosive). Used for EHS compliance, emergency response planning, and segregation requirement enforcement. [ENUM-REF-CANDIDATE: class_1_explosive|class_2_gas|class_3_flammable_liquid|class_4_flammable_solid|class_5_oxidizer|class_6_toxic|class_7_radioactive|class_8_corrosive|class_9_misc — promote to reference product]' ;
    rdfs:domain ind:TankFarmLevel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:highLevelAlarm rdf:type rdf:Property ;
    rdfs:label 'High Level Alarm' ;
    rdfs:comment 'Indicates whether the high-level alarm setpoint was active (True) or inactive (False) at the time of measurement. A high-level alarm signals that the tank level has reached or exceeded the high alarm threshold, requiring immediate operational attention to prevent overfill.' ;
    rdfs:domain ind:TankFarmLevel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:instrumentTag rdf:type rdf:Property ;
    rdfs:label 'Instrument Tag' ;
    rdfs:comment 'The P&ID instrument tag identifier for the level transmitter or gauge device that produced this measurement (e.g., LT-101, LIT-2204). Enables traceability to the physical instrument for calibration records, maintenance history, and instrument reliability analysis.' ;
    rdfs:domain ind:TankFarmLevel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryValueUsd rdf:type rdf:Property ;
    rdfs:label 'Inventory Value Usd' ;
    rdfs:comment 'The estimated financial value of the bulk chemical inventory in the tank at the time of measurement, expressed in US Dollars. Calculated from mass_kg and the current standard or moving average cost from SAP FI/CO. Used for inventory valuation reporting and financial close processes.' ;
    rdfs:domain ind:TankFarmLevel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:levelM rdf:type rdf:Property ;
    rdfs:label 'Level M' ;
    rdfs:comment 'The measured liquid level height in the tank expressed in meters, as reported by the level transmitter instrument and captured in the Aveva PI System historian. This is the primary raw measurement value for continuous inventory tracking.' ;
    rdfs:domain ind:TankFarmLevel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:levelPercent rdf:type rdf:Property ;
    rdfs:label 'Level Percent' ;
    rdfs:comment 'The current tank fill level expressed as a percentage of the tank\'s maximum working capacity (0-100%). Provides an intuitive operational view of tank utilization for dashboards, alerts, and capacity planning without requiring knowledge of tank dimensions.' ;
    rdfs:domain ind:TankFarmLevel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lowLevelAlarm rdf:type rdf:Property ;
    rdfs:label 'Low Level Alarm' ;
    rdfs:comment 'Indicates whether the low-level alarm setpoint was active (True) or inactive (False) at the time of measurement. A low-level alarm signals that the tank level has dropped to or below the low alarm threshold, indicating potential supply shortage or pump cavitation risk.' ;
    rdfs:domain ind:TankFarmLevel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:massKg rdf:type rdf:Property ;
    rdfs:label 'Mass Kg' ;
    rdfs:comment 'The calculated mass of the liquid inventory in the tank expressed in kilograms, derived from volume and density. Used for material balance, production accounting, and regulatory emission calculations (e.g., EPA TRI, VOC reporting).' ;
    rdfs:domain ind:TankFarmLevel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementQuality rdf:type rdf:Property ;
    rdfs:label 'Measurement Quality' ;
    rdfs:comment 'The data quality indicator for this measurement record as reported by the Aveva PI System historian (e.g., Good, Bad, Uncertain, Substituted). Reflects instrument health, communication status, or manual data substitution. Used to filter unreliable readings in analytics and reporting.' ;
    rdfs:domain ind:TankFarmLevel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementSource rdf:type rdf:Property ;
    rdfs:label 'Measurement Source' ;
    rdfs:comment 'Identifies the originating source system or method for this level measurement record. Distinguishes between automated PI historian readings, manual gauge readings entered by operators, DCS/SCADA system feeds, calculated values from strapping tables, or estimated values.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Measurement Timestamp' ;
    rdfs:comment 'The precise date and time at which the tank level measurement was recorded by the process historian or instrumentation system. This is the principal real-world event time for this observation record.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:piTagName rdf:type rdf:Property ;
    rdfs:label 'Pi Tag Name' ;
    rdfs:comment 'The Aveva PI System historian tag identifier (e.g., SITE01.TK-101.LEVEL) that is the source of this measurement record. Enables traceability back to the originating instrument data stream in the process historian.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Created Timestamp' ;
    rdfs:comment 'The date and time when this tank farm level record was first created or ingested into the Silver Layer data lakehouse. Distinct from measurement_timestamp (the real-world event time). Used for data pipeline auditing, latency monitoring, and record lineage tracking.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Updated Timestamp' ;
    rdfs:comment 'The date and time when this tank farm level record was last modified in the Silver Layer, for example due to a data quality correction, manual override, or reprocessing event. Supports change tracking and data lineage auditing.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reorderPointKg rdf:type rdf:Property ;
    rdfs:label 'Reorder Point Kg' ;
    rdfs:comment 'The inventory mass threshold in kilograms at which a replenishment order should be triggered for this tank. When mass_kg falls at or below this value, procurement or supply chain teams are alerted to initiate a purchase order or transfer. Supports continuous inventory management for bulk chemicals.' ;
    rdfs:domain ind:TankFarmLevel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageTemperatureMaxC rdf:type rdf:Property ;
    rdfs:label 'Storage Temperature Max C' ;
    rdfs:comment 'The maximum allowable storage temperature for the chemical in this tank, expressed in degrees Celsius, as specified in the material SDS (Safety Data Sheet). Exceeding this threshold may indicate a safety hazard, product degradation risk, or regulatory non-compliance.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageTemperatureMinC rdf:type rdf:Property ;
    rdfs:label 'Storage Temperature Min C' ;
    rdfs:comment 'The minimum allowable storage temperature for the chemical in this tank, expressed in degrees Celsius, as specified in the material SDS (Safety Data Sheet). Used to trigger temperature deviation alerts and ensure regulatory compliance with safe storage requirements.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tankCapacityM3 rdf:type rdf:Property ;
    rdfs:label 'Tank Capacity M3' ;
    rdfs:comment 'The nominal or maximum working capacity of the tank in cubic meters as defined in the tank design specification and strapping table. Stored with the measurement record to enable percentage calculations and capacity utilization reporting without requiring a join to the tank master.' ;
    rdfs:domain ind:TankFarmLevel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tankFarmName rdf:type rdf:Property ;
    rdfs:label 'Tank Farm Name' ;
    rdfs:comment 'The name or designation of the tank farm area or storage cluster where the tank is physically located (e.g., North Tank Farm, Solvent Storage Area). Supports area-level inventory aggregation and reporting.' ;
    rdfs:domain ind:TankFarmLevel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureC rdf:type rdf:Property ;
    rdfs:label 'Temperature C' ;
    rdfs:comment 'The temperature of the liquid in the tank at the time of measurement, expressed in degrees Celsius. Temperature is required for density correction, volume-to-mass conversion, and monitoring of temperature-sensitive chemicals to ensure safe storage conditions.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureDeviationFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Deviation Flag' ;
    rdfs:comment 'Indicates whether the measured temperature at the time of this record was outside the defined safe storage temperature range (True = deviation detected, False = within range). Supports EHS compliance monitoring and automated alerting for temperature-sensitive chemical storage.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ullageM rdf:type rdf:Property ;
    rdfs:label 'Ullage M' ;
    rdfs:comment 'The available headspace (ullage) in the tank expressed in meters, calculated as the difference between the maximum allowable working level and the current measured level. Critical for safe filling operations, overfill prevention, and scheduling inbound deliveries.' ;
    rdfs:domain ind:TankFarmLevel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ullageVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Ullage Volume M3' ;
    rdfs:comment 'The available headspace volume in the tank expressed in cubic meters, representing the remaining capacity available for additional material. Used for logistics planning, delivery scheduling, and overfill risk management.' ;
    rdfs:domain ind:TankFarmLevel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeLiters rdf:type rdf:Property ;
    rdfs:label 'Volume Liters' ;
    rdfs:comment 'The calculated volume of liquid in the tank expressed in liters, derived from the level measurement and tank strapping table. Used for inventory quantity reporting and material balance calculations.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeM3 rdf:type rdf:Property ;
    rdfs:label 'Volume M3' ;
    rdfs:comment 'The calculated volume of liquid in the tank expressed in cubic meters (m³). Provides SI unit representation for regulatory reporting, engineering calculations, and international trade documentation.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inventoryAdjustmentId rdf:type rdf:Property ;
    rdfs:label 'Inventory Adjustment Id' ;
    rdfs:comment 'Unique surrogate identifier for each inventory adjustment record in the Chemical Mfg lakehouse silver layer. Primary key for this entity.' ;
    rdfs:domain ind:InventoryAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalAdjustmentInventoryAdjustmentId rdf:type rdf:Property ;
    rdfs:label 'Original Adjustment Inventory Adjustment Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the original inventory adjustment record that this record reverses. Populated only when reversal_flag is True. Enables full reversal chain traceability for audit and SOX compliance.' ;
    rdfs:domain ind:InventoryAdjustment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventoryAdjustment .

ind:qualityDeviationId rdf:type rdf:Property ;
    rdfs:label 'Quality Deviation Id' ;
    rdfs:comment 'Foreign key linking to quality.quality_deviation. Business justification: Inventory adjustments for quality-related scrap, rework, or write-offs must reference the triggering quality deviation. This FK enables cost-of-quality reporting, regulatory traceability for material ' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QualityDeviation .

ind:adjustmentStatus rdf:type rdf:Property ;
    rdfs:label 'Adjustment Status' ;
    rdfs:comment 'Current lifecycle state of the inventory adjustment record, tracking progression from initial draft through dual-authorization approval (required for SOX-controlled threshold adjustments) to final posting or reversal in SAP MM.' ;
    rdfs:domain ind:InventoryAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Adjustment Timestamp' ;
    rdfs:comment 'The principal real-world business event timestamp recording when the inventory adjustment was physically executed or the stock correction was applied. Distinct from the record creation audit timestamp. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:InventoryAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:adjustmentType rdf:type rdf:Property ;
    rdfs:label 'Adjustment Type' ;
    rdfs:comment 'Classification of the inventory adjustment indicating the business reason category: write-off (stock reduction for loss/destruction), write-up (stock increase for found goods), count_variance (physical inventory count discrepancy posting), damage (goods damaged in storage or handling), obsolescence (expired or out-of-spec material), or revaluation (value correction). [ENUM-REF-CANDIDATE: write_off|write_up|count_variance|damage|obsolescence|revaluation|transfer_correction|system_correction — promote to reference product]' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaReference rdf:type rdf:Property ;
    rdfs:label 'Capa Reference' ;
    rdfs:comment 'Reference number linking this inventory adjustment to an associated CAPA (Corrective and Preventive Action) record when the adjustment triggers or is part of a quality or process improvement action. Supports ISO 9001 quality management traceability.' ;
    rdfs:domain ind:InventoryAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentNumber rdf:type rdf:Property ;
    rdfs:label 'Document Number' ;
    rdfs:comment 'Externally-known business identifier for the inventory adjustment document, typically matching the SAP MM material document number generated at the time of posting. Used for cross-referencing with ERP and audit trails.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialImpactValue rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Value' ;
    rdfs:comment 'The monetary value impact of the inventory adjustment on the balance sheet, calculated as adjustment quantity multiplied by the standard or moving average price of the material. Positive for write-ups, negative for write-offs. Used for COGS (Cost of Goods Sold) reporting and SOX financial controls.' ;
    rdfs:domain ind:InventoryAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:physicalInventoryDocument rdf:type rdf:Property ;
    rdfs:label 'Physical Inventory Document' ;
    rdfs:comment 'SAP MM physical inventory document number associated with this adjustment when the adjustment originates from a physical inventory count (cycle count or annual count). Null for non-count-related adjustments such as damage write-offs.' ;
    rdfs:domain ind:InventoryAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonCode rdf:type rdf:Property ;
    rdfs:label 'Reason Code' ;
    rdfs:comment 'Standardized reason code classifying the root cause or business justification for the inventory adjustment (e.g., PHYS_INV_DIFF for physical inventory difference, DAMAGE_STORAGE for storage damage, EXPIRY for expired material). Drives financial posting rules and regulatory reporting.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonDescription rdf:type rdf:Property ;
    rdfs:label 'Reason Description' ;
    rdfs:comment 'Free-text narrative description providing additional context for the inventory adjustment beyond the standardized reason code. Captures specific circumstances such as spill details, damage cause, or discrepancy explanation for audit and CAPA purposes.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapMaterialDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Material Document Number' ;
    rdfs:comment 'The SAP MM material document number generated when the inventory adjustment is posted in SAP S/4HANA. Serves as the primary cross-reference between the lakehouse silver layer record and the ERP system of record for reconciliation and audit purposes.' ;
    rdfs:domain ind:InventoryAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapMaterialDocumentYear rdf:type rdf:Property ;
    rdfs:label 'Sap Material Document Year' ;
    rdfs:comment 'The fiscal year associated with the SAP MM material document number. Required because SAP material document numbers are unique only within a fiscal year; combined with sap_material_document_number provides a globally unique ERP reference.' ;
    rdfs:domain ind:InventoryAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:soxThresholdExceeded rdf:type rdf:Property ;
    rdfs:label 'Sox Threshold Exceeded' ;
    rdfs:comment 'Boolean flag indicating whether the financial impact value of this adjustment exceeds the SOX dual-authorization threshold, triggering the requirement for a secondary approver. True = dual authorization required and applied; False = single authorization sufficient.' ;
    rdfs:domain ind:InventoryAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:soxThresholdValue rdf:type rdf:Property ;
    rdfs:label 'Sox Threshold Value' ;
    rdfs:comment 'The monetary threshold value above which a second approver is required per SOX internal control policy. Stored on the record for audit traceability as thresholds may be updated over time.' ;
    rdfs:domain ind:InventoryAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consignmentStockId rdf:type rdf:Property ;
    rdfs:label 'Consignment Stock Id' ;
    rdfs:comment 'Unique surrogate identifier for each consignment stock record in the Chemical Mfg inventory system. Primary key for the consignment_stock data product.' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billingScheduleId rdf:type rdf:Property ;
    rdfs:label 'Billing Schedule Id' ;
    rdfs:comment 'Foreign key linking to billing.billing_schedule. Business justification: Consignment stock arrangements in chemical manufacturing are governed by billing schedules defining when consumption triggers invoicing. Linking consignment_stock to billing_schedule enables automated' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillingSchedule .

ind:invoiceId rdf:type rdf:Property ;
    rdfs:label 'Invoice Id' ;
    rdfs:comment 'Foreign key linking to billing.invoice. Business justification: Consignment stock consumption in chemical manufacturing generates settlement invoices. consignment_stock.settlement_document_number is a denormalized invoice reference. Replacing it with a proper invo' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:agingDays rdf:type rdf:Property ;
    rdfs:label 'Aging Days' ;
    rdfs:comment 'Number of calendar days the consignment stock has been held at the manufacturer\'s premises since receipt date. Used for vendor-managed inventory (VMI) performance monitoring, slow-moving stock identification, and consignment agreement compliance (maximum holding period enforcement).' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:coaReference rdf:type rdf:Property ;
    rdfs:label 'Coa Reference' ;
    rdfs:comment 'Reference number of the vendor-provided Certificate of Analysis (COA) accompanying the consignment lot. Confirms the material meets agreed quality specifications. Linked to LabWare LIMS for incoming quality verification.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consignmentQuantity rdf:type rdf:Property ;
    rdfs:label 'Consignment Quantity' ;
    rdfs:comment 'Current quantity of vendor-owned consignment stock on hand at the manufacturer\'s premises, expressed in the base unit of measure. Represents the unreceived (not yet financially owned) stock balance.' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consignmentStockStatus rdf:type rdf:Property ;
    rdfs:label 'Consignment Stock Status' ;
    rdfs:comment 'Current lifecycle status of the consignment stock record. \'active\' = vendor-owned stock available for consumption; \'consumed\' = fully consumed and liability transferred; \'partially_consumed\' = partially drawn down; \'returned\' = returned to vendor; \'expired\' = past expiration date; \'quarantine\' = held pending quality disposition.' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consignmentValue rdf:type rdf:Property ;
    rdfs:label 'Consignment Value' ;
    rdfs:comment 'Total financial value of the current consignment stock on hand, calculated as consignment_quantity multiplied by valuation_price. Used for balance sheet disclosure of vendor-owned stock, financial reporting, and off-balance-sheet liability tracking under FASB ASC 330 and SOX.' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consumedQuantity rdf:type rdf:Property ;
    rdfs:label 'Consumed Quantity' ;
    rdfs:comment 'Cumulative quantity of consignment stock that has been consumed (goods-issued to production or other cost centers) and for which financial liability has been transferred to the manufacturer. Used for settlement reconciliation and VMI performance reporting.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consumptionTrigger rdf:type rdf:Property ;
    rdfs:label 'Consumption Trigger' ;
    rdfs:comment 'The agreed business event that triggers financial liability transfer from vendor to manufacturer for consignment stock. Defines when ownership and payable obligation are created. Aligned with SAP MM consignment settlement process.' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastConsumptionDate rdf:type rdf:Property ;
    rdfs:label 'Last Consumption Date' ;
    rdfs:comment 'Date of the most recent goods issue (consumption) from this consignment stock lot. Used for slow-moving stock analysis, VMI replenishment planning, and consignment agreement compliance monitoring.' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:liabilityTransferDate rdf:type rdf:Property ;
    rdfs:label 'Liability Transfer Date' ;
    rdfs:comment 'Date on which financial ownership and payable liability for the consignment stock transferred from the vendor to the manufacturer, triggered by the agreed consumption event. Used for accounts payable accrual and financial period-end reporting under SOX and FASB ASC 330.' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maximumHoldingDays rdf:type rdf:Property ;
    rdfs:label 'Maximum Holding Days' ;
    rdfs:comment 'Maximum number of days the consignment stock may be held at the manufacturer\'s premises per the consignment agreement before automatic return or forced consumption. Breach of this threshold may trigger penalty clauses or mandatory settlement.' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maximumStockLevel rdf:type rdf:Property ;
    rdfs:label 'Maximum Stock Level' ;
    rdfs:comment 'Maximum quantity of consignment stock permitted at the manufacturer\'s premises per the VMI or consignment agreement. Prevents over-stocking of hazardous chemicals and ensures compliance with site storage limits under OSHA PSM and EPA RMP.' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumStockLevel rdf:type rdf:Property ;
    rdfs:label 'Minimum Stock Level' ;
    rdfs:comment 'Minimum quantity of consignment stock that must be maintained at the manufacturer\'s premises per the VMI agreement to ensure uninterrupted production supply. Triggers vendor replenishment when consignment_quantity falls below this threshold.' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receiptDate rdf:type rdf:Property ;
    rdfs:label 'Receipt Date' ;
    rdfs:comment 'Date on which the vendor-owned consignment stock was physically received and placed at the manufacturer\'s premises. Used for aging calculation, FIFO/FEFO rotation, and consignment agreement compliance tracking.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:returnedQuantity rdf:type rdf:Property ;
    rdfs:label 'Returned Quantity' ;
    rdfs:comment 'Quantity of consignment stock returned to the vendor without consumption, typically due to quality rejection, expiration, or excess inventory. Recorded as a consignment return movement in SAP MM.' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interplantTransferId rdf:type rdf:Property ;
    rdfs:label 'Interplant Transfer Id' ;
    rdfs:comment 'Primary key for interplant_transfer' ;
    rdfs:domain ind:InterplantTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sendingWarehouseLocationId rdf:type rdf:Property ;
    rdfs:label 'Sending Warehouse Location Id' ;
    rdfs:comment 'Foreign key linking to inventory.warehouse_location. Business justification: Inter-plant transfer originates from a warehouse location; replace string with FK.' ;
    rdfs:domain ind:InterplantTransfer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WarehouseLocation .

ind:actualGoodsIssueDate rdf:type rdf:Property ;
    rdfs:label 'Actual Goods Issue Date' ;
    rdfs:comment 'Actual date on which the goods issue posting was made in SAP MM, confirming physical departure of material from the sending plant. Used for transit time analysis and on-time shipment KPI reporting.' ;
    rdfs:domain ind:InterplantTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualGoodsReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Actual Goods Receipt Date' ;
    rdfs:comment 'Actual date on which the goods receipt posting was made in SAP MM at the receiving plant, confirming physical arrival and acceptance of the transferred material. Used for transit time calculation and inventory reconciliation.' ;
    rdfs:domain ind:InterplantTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billOfLadingNumber rdf:type rdf:Property ;
    rdfs:label 'Bill Of Lading Number' ;
    rdfs:comment 'Official bill of lading document number issued for the shipment. Serves as the legal contract of carriage and is required for hazardous material transport documentation under DOT regulations and customs compliance.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierName rdf:type rdf:Property ;
    rdfs:label 'Carrier Name' ;
    rdfs:comment 'Name of the logistics carrier or transport service provider responsible for moving the material between plants. Used for carrier performance tracking and freight cost allocation.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Carrier Reference Number' ;
    rdfs:comment 'Carrier-assigned reference number (e.g., bill of lading number, waybill number, or pro number) for the shipment. Used to cross-reference with Oracle Transportation Management and carrier tracking systems.' ;
    rdfs:domain ind:InterplantTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdByUser rdf:type rdf:Property ;
    rdfs:label 'Created By User' ;
    rdfs:comment 'SAP user ID of the person who created the stock transfer order in SAP S/4HANA. Required for audit trail, authorization control, and SOX compliance documentation.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Delivery Document Number' ;
    rdfs:comment 'SAP outbound delivery document number created in SAP EWM/SD for the physical shipment execution of this stock transfer order. Links the STO to the warehouse execution and shipping documents.' ;
    rdfs:domain ind:InterplantTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatIndicator rdf:type rdf:Property ;
    rdfs:label 'Hazmat Indicator' ;
    rdfs:comment 'Flag indicating whether the transferred material is classified as a hazardous material requiring special handling, labeling, and transport documentation under DOT, GHS, and IMDG regulations. Triggers mandatory SDS/MSDS documentation and emergency response procedures.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:intransitQuantity rdf:type rdf:Property ;
    rdfs:label 'Intransit Quantity' ;
    rdfs:comment 'Quantity of material currently in transit between the sending and receiving plants — goods issued but not yet goods-receipted. Represents the stock-in-transit position used for real-time inventory visibility and financial valuation of in-transit inventory.' ;
    rdfs:domain ind:InterplantTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:issuedQuantity rdf:type rdf:Property ;
    rdfs:label 'Issued Quantity' ;
    rdfs:comment 'Actual quantity of material physically issued (goods issued) from the sending plant\'s inventory at the time of transfer. May differ from transfer_quantity due to partial shipments or measurement variances.' ;
    rdfs:domain ind:InterplantTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedGoodsIssueDate rdf:type rdf:Property ;
    rdfs:label 'Planned Goods Issue Date' ;
    rdfs:comment 'Planned date on which goods are scheduled to be issued from the sending plant\'s inventory. Derived from the requested delivery date and transit lead time in SAP MM planning.' ;
    rdfs:domain ind:InterplantTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:receivedQuantity rdf:type rdf:Property ;
    rdfs:label 'Received Quantity' ;
    rdfs:comment 'Actual quantity of material confirmed as received (goods received) at the destination plant. Used to calculate transfer variances, identify transit losses, and trigger inventory reconciliation. Populated upon goods receipt posting in SAP MM.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receivingPlantCode rdf:type rdf:Property ;
    rdfs:label 'Receiving Plant Code' ;
    rdfs:comment 'SAP plant code identifying the destination plant, distribution center, or external warehouse that will receive the transferred material. Corresponds to the receiving plant in SAP MM stock transfer processing.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingPlantName rdf:type rdf:Property ;
    rdfs:label 'Receiving Plant Name' ;
    rdfs:comment 'Descriptive name of the destination plant or facility receiving the stock transfer. Provides human-readable context for reporting and operational dashboards without requiring a join to the plant master.' ;
    rdfs:domain ind:InterplantTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingStorageLocation rdf:type rdf:Property ;
    rdfs:label 'Receiving Storage Location' ;
    rdfs:comment 'SAP storage location code within the receiving plant where the material will be placed upon arrival. Identifies the target warehouse area, tank farm, or storage bin at the destination facility.' ;
    rdfs:domain ind:InterplantTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapMovementType rdf:type rdf:Property ;
    rdfs:label 'Sap Movement Type' ;
    rdfs:comment 'SAP MM movement type code governing the inventory and accounting postings for this transfer (e.g., 641 for goods issue for STO, 101 for goods receipt). Determines the financial and inventory impact in SAP S/4HANA.' ;
    rdfs:domain ind:InterplantTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sendingPlantCode rdf:type rdf:Property ;
    rdfs:label 'Sending Plant Code' ;
    rdfs:comment 'SAP plant code identifying the originating plant or manufacturing facility from which the material is being transferred. Corresponds to the issuing plant in SAP MM stock transfer processing.' ;
    rdfs:domain ind:InterplantTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sendingPlantName rdf:type rdf:Property ;
    rdfs:label 'Sending Plant Name' ;
    rdfs:comment 'Descriptive name of the originating plant or facility issuing the stock transfer. Provides human-readable context for reporting and operational dashboards without requiring a join to the plant master.' ;
    rdfs:domain ind:InterplantTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferReason rdf:type rdf:Property ;
    rdfs:label 'Transfer Reason' ;
    rdfs:comment 'Business reason or justification for initiating the inter-plant stock transfer (e.g., production replenishment, inventory rebalancing, quality rework, customer order fulfillment). Used for operational analytics and cost allocation.' ;
    rdfs:domain ind:InterplantTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferStatus rdf:type rdf:Property ;
    rdfs:label 'Transfer Status' ;
    rdfs:comment 'Current lifecycle status of the inter-plant stock transfer order. Tracks progression from creation through in-transit movement to receipt confirmation at the destination plant. [ENUM-REF-CANDIDATE: created|in_transit|partially_received|received|confirmed|cancelled — promote to reference product if additional statuses are required]' ;
    rdfs:domain ind:InterplantTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferValue rdf:type rdf:Property ;
    rdfs:label 'Transfer Value' ;
    rdfs:comment 'Monetary value of the transferred material quantity based on the standard or moving average price at the sending plant. Used for inter-company or inter-plant inventory valuation and financial settlement in SAP FI/CO. Expressed in the company currency.' ;
    rdfs:domain ind:InterplantTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transportMode rdf:type rdf:Property ;
    rdfs:label 'Transport Mode' ;
    rdfs:comment 'Mode of transportation used to move the material between plants (e.g., road tanker, rail car, pipeline, barge). Relevant for hazardous material transport compliance under DOT 49 CFR and IATA/IMDG regulations for chemical shipments.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankAccountId rdf:type rdf:Property ;
    rdfs:label 'Bank Account Id' ;
    rdfs:comment 'Foreign key linking to finance.bank_account. Business justification: Electronic Funds Transfer (EFT) payments require linking a customer account to its bank account record for payment processing.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BankAccount .

ind:businessUnitId rdf:type rdf:Property ;
    rdfs:label 'Business Unit Id' ;
    rdfs:comment 'Foreign key linking to finance.business_unit. Business justification: Accounts in chemical manufacturing are assigned to business units (e.g., Agricultural Solutions, Performance Materials) for BU-level P&L reporting, sales planning, and customer profitability analysis.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BusinessUnit .

ind:parentAccountId rdf:type rdf:Property ;
    rdfs:label 'Parent Account Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the parent account record for corporate hierarchy management. Enables roll-up of subsidiary accounts to ultimate parent for consolidated reporting, credit exposure, and enterprise-level relationship management.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:preferredCarrierId rdf:type rdf:Property ;
    rdfs:label 'Preferred Carrier Id' ;
    rdfs:comment 'Foreign key linking to logistics.carrier. Business justification: Preferred carrier selection for each account is used in carrier performance and rate negotiation reports; linking enables direct lookup of the carrier entity.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:preferredVendorId rdf:type rdf:Property ;
    rdfs:label 'Preferred Vendor Id' ;
    rdfs:comment 'Foreign key linking to supply.vendor. Business justification: Preferred Vendor Management per account; procurement strategy reports require linking each account to its designated vendor.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:revenueGlAccountId rdf:type rdf:Property ;
    rdfs:label 'Revenue Gl Account Id' ;
    rdfs:comment 'Foreign key linking to finance.gl_account. Business justification: Revenue Recognition process uses a default GL account per customer; linking account to gl_account enables automated posting.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:accountStatus rdf:type rdf:Property ;
    rdfs:label 'Account Status' ;
    rdfs:comment 'Current lifecycle status of the customer account. Active: transacting customer. Inactive: no recent transactions. Prospect: under evaluation. Suspended: temporarily halted due to credit or compliance issues. Blocked: SAP-level block applied (e.g., credit block, delivery block). Closed: account permanently deactivated.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountTier rdf:type rdf:Property ;
    rdfs:label 'Account Tier' ;
    rdfs:comment 'Commercial segmentation tier assigned to the account based on revenue contribution, strategic importance, and growth potential. Strategic: top-tier key accounts with dedicated resources. Preferred: high-value accounts with preferred pricing. Standard: regular commercial accounts. Transactional: low-frequency or spot-buy customers.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountType rdf:type rdf:Property ;
    rdfs:label 'Account Type' ;
    rdfs:comment 'Classifies the primary business relationship type of the customer account. Direct Industrial: buys chemicals for own manufacturing use. Distributor: resells to downstream customers. Toll Processor: processes materials on behalf of Chemical Mfg or third parties. OEM: original equipment manufacturer integrating chemical products. End User: final consumer of the product. [ENUM-REF-CANDIDATE: direct_industrial|distributor|toll_processor|oem|end_user — promote to reference product]' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualRevenueBand rdf:type rdf:Property ;
    rdfs:label 'Annual Revenue Band' ;
    rdfs:comment 'Banded range of the customer organization\'s annual revenue used for segmentation and strategic account planning (e.g., \'<$10M\', \'$10M-$100M\', \'$100M-$1B\', \'>$1B\'). Sourced from Dun & Bradstreet or CRM qualification. [ENUM-REF-CANDIDATE: <$10M|$10M-$100M|$100M-$1B|>$1B — promote to reference product]' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Billing Address Line1' ;
    rdfs:comment 'Primary street address line for the customer\'s billing location. Used for invoice generation, tax jurisdiction determination, and financial reporting under FASB and SOX.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCity rdf:type rdf:Property ;
    rdfs:label 'Billing City' ;
    rdfs:comment 'City of the customer\'s billing address. Used for tax jurisdiction assignment, invoice compliance, and geographic sales reporting.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Billing Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 three-letter country code for the customer\'s billing address. Used for international tax compliance, REACH/ECHA regulatory applicability, export control (TSCA), and currency determination.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingPostalCode rdf:type rdf:Property ;
    rdfs:label 'Billing Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the customer\'s billing address. Used for tax rate lookup, geographic segmentation, and logistics zone assignment.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingStateProvince rdf:type rdf:Property ;
    rdfs:label 'Billing State Province' ;
    rdfs:comment 'State or province of the customer\'s billing address. Used for sales tax determination, regulatory jurisdiction mapping (EPA, OSHA state programs), and regional sales analytics.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blocked rdf:type rdf:Property ;
    rdfs:label 'Blocked' ;
    rdfs:comment 'Indicates whether the customer account has an active block in SAP S/4HANA preventing order processing, delivery, or invoicing. Blocks may be applied for credit risk, compliance violations, or sanctions screening failures.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditLimitCurrency rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the credit limit is denominated (e.g., USD, EUR, GBP). Required for multi-currency credit exposure management.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditRating rdf:type rdf:Property ;
    rdfs:label 'Credit Rating' ;
    rdfs:comment 'Internal or external credit risk rating assigned to the customer account (e.g., A, B, C, D or numeric score). Derived from Dun & Bradstreet data or internal credit assessment. Drives credit limit setting and payment term eligibility.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeCountBand rdf:type rdf:Property ;
    rdfs:label 'Employee Count Band' ;
    rdfs:comment 'Banded range of the customer organization\'s total employee headcount used for account sizing and segmentation (e.g., \'1-50\', \'51-500\', \'501-5000\', \'>5000\'). Sourced from Dun & Bradstreet or CRM qualification. [ENUM-REF-CANDIDATE: 1-50|51-500|501-5000|>5000 — promote to reference product]' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastOrderDate rdf:type rdf:Property ;
    rdfs:label 'Last Order Date' ;
    rdfs:comment 'The date of the most recent confirmed sales order placed by this customer account. Used for customer activity monitoring, churn risk identification, and account health scoring.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:naicsCode rdf:type rdf:Property ;
    rdfs:label 'Naics Code' ;
    rdfs:comment 'The six-digit North American Industry Classification System (NAICS) code identifying the customer\'s industry sector. Used for market analysis, customer segmentation, and regulatory compliance reporting.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresCoaOnDelivery rdf:type rdf:Property ;
    rdfs:label 'Requires Coa On Delivery' ;
    rdfs:comment 'Indicates whether the customer requires a Certificate of Analysis (COA) to accompany each product lot shipment. COA documents quality test results against specification. Driven by customer quality agreements and GMP requirements.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresSdsOnDelivery rdf:type rdf:Property ;
    rdfs:label 'Requires Sds On Delivery' ;
    rdfs:comment 'Indicates whether the customer requires a Safety Data Sheet (SDS) to accompany every chemical shipment delivery. Mandatory for GHS-compliant chemical distribution. Drives document generation in SAP S/4HANA SD and EHS workflows.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:salesforceAccountCode rdf:type rdf:Property ;
    rdfs:label 'Salesforce Account Code' ;
    rdfs:comment 'The native record identifier assigned by Salesforce CRM for this account. Used to reconcile and synchronize customer master data between the lakehouse and the CRM system of record.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Shipping Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 three-letter country code for the customer\'s primary shipping destination. Used for export compliance, DOT hazardous materials transport classification, REACH applicability, and logistics routing.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingMode rdf:type rdf:Property ;
    rdfs:label 'Shipping Mode' ;
    rdfs:comment 'The customer\'s preferred mode of transportation for product delivery. LTL (Less Than Truckload) and FTL (Full Truckload) are common for bulk chemical shipments. Drives logistics planning and DOT hazmat transport compliance. [ENUM-REF-CANDIDATE: ltl|ftl|parcel|rail|ocean|air|intermodal — promote to reference product]' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sicCode rdf:type rdf:Property ;
    rdfs:label 'Sic Code' ;
    rdfs:comment 'The four-digit Standard Industrial Classification (SIC) code that categorizes the customer\'s primary business activity. Used for market segmentation, regulatory reporting, and industry analytics.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Number' ;
    rdfs:comment 'The government-issued tax identification number (EIN, VAT number, or equivalent) for the customer entity. Required for tax reporting, invoice compliance, and regulatory filings under FASB and SOX.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountSiteId rdf:type rdf:Property ;
    rdfs:label 'Account Site Id' ;
    rdfs:comment 'Reference to the specific customer site or plant location this contact is associated with. A customer account may have multiple plant sites; this links the contact to their operational location for logistics and technical service routing.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Site .

ind:coaDeliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Coa Delivery Method' ;
    rdfs:comment 'Preferred delivery method for Certificate of Analysis (COA) and Certificate of Compliance (COC) documents for this contact. Drives automated document distribution workflows in the quality management process.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactRole rdf:type rdf:Property ;
    rdfs:label 'Contact Role' ;
    rdfs:comment 'Functional role classification of the contact in relation to Chemical Mfg business interactions. Drives workflow routing for technical sales, EHS (Environment Health and Safety) compliance, logistics coordination, and quality inquiries. [ENUM-REF-CANDIDATE: technical|commercial|ehs|logistics|quality|procurement|finance|executive — promote to reference product if additional roles are needed]' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactStatus rdf:type rdf:Property ;
    rdfs:label 'Contact Status' ;
    rdfs:comment 'Current lifecycle status of the contact record. \'active\' indicates the contact is reachable and engaged; \'inactive\' indicates the contact is no longer in the role; \'do_not_contact\' enforces communication suppression; \'pending_verification\' indicates the record awaits validation.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactType rdf:type rdf:Property ;
    rdfs:label 'Contact Type' ;
    rdfs:comment 'Classification of the contact by their relationship to Chemical Mfg. \'internal\' denotes Chemical Mfg employees; \'external\' denotes customer personnel; \'distributor\' denotes channel partner contacts; \'end_user\' denotes final consumer contacts; \'consultant\' denotes third-party advisors.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmContactCode rdf:type rdf:Property ;
    rdfs:label 'Crm Contact Code' ;
    rdfs:comment 'Unique identifier for this contact record in Salesforce CRM, the system of record for customer contact management. Used for bi-directional synchronization between the lakehouse and Salesforce.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:department rdf:type rdf:Property ;
    rdfs:label 'Department' ;
    rdfs:comment 'Organizational department or functional area the contact belongs to within the customer organization (e.g., Procurement, Engineering, Quality Assurance, Environment Health and Safety, Logistics, R&D). Supports targeted communication routing.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doNotContactFlag rdf:type rdf:Property ;
    rdfs:label 'Do Not Contact Flag' ;
    rdfs:comment 'Indicates whether this contact has opted out of or been suppressed from all outbound communications. When True, no marketing, sales, or non-essential operational communications should be sent. Enforces GDPR and CCPA consent management requirements.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:doNotContactReason rdf:type rdf:Property ;
    rdfs:label 'Do Not Contact Reason' ;
    rdfs:comment 'Reason code explaining why the do_not_contact_flag is set to True. Supports regulatory audit trails for GDPR right-to-erasure and CCPA opt-out compliance. Null when do_not_contact_flag is False.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ehsContactFlag rdf:type rdf:Property ;
    rdfs:label 'Ehs Contact Flag' ;
    rdfs:comment 'Indicates whether this contact is the designated EHS (Environment Health and Safety) coordinator or responsible person at the customer site. EHS contacts receive hazardous material notifications, incident reports, and regulatory compliance updates.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:email rdf:type rdf:Property ;
    rdfs:label 'Email' ;
    rdfs:comment 'Primary business email address of the contact. Used for order confirmations, technical documentation delivery, Safety Data Sheet (SDS) distribution, Certificate of Analysis (COA) transmission, and regulatory correspondence.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emailSecondary rdf:type rdf:Property ;
    rdfs:label 'Email Secondary' ;
    rdfs:comment 'Alternate or secondary email address for the contact. Used as a fallback communication channel when the primary email is undeliverable, or for routing specific document types (e.g., invoices to a separate accounts payable email).' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstName rdf:type rdf:Property ;
    rdfs:label 'First Name' ;
    rdfs:comment 'Given name of the contact person. Used in personalized communications, technical sales outreach, and customer service workflows.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDecisionMaker rdf:type rdf:Property ;
    rdfs:label 'Is Decision Maker' ;
    rdfs:comment 'Indicates whether this contact holds purchasing or approval authority within their organization. Used by technical sales teams to prioritize engagement and qualify opportunities in the chemical sales cycle.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimaryContact rdf:type rdf:Property ;
    rdfs:label 'Is Primary Contact' ;
    rdfs:comment 'Indicates whether this contact is the designated primary contact for the associated customer account. Only one contact per customer account should be flagged as primary. Used to determine the default recipient for account-level communications.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobTitle rdf:type rdf:Property ;
    rdfs:label 'Job Title' ;
    rdfs:comment 'Official job title or position of the contact within their organization (e.g., Procurement Manager, Plant Engineer, Quality Manager, EHS Coordinator, Technical Buyer). Used for routing communications and identifying decision-makers.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languagePreference rdf:type rdf:Property ;
    rdfs:label 'Language Preference' ;
    rdfs:comment 'Preferred language for communications with this contact, expressed as an IETF BCP 47 language tag (e.g., \'en\', \'de\', \'fr\', \'zh-CN\'). Ensures SDS, COA, and regulatory documents are delivered in the correct language per REACH and GHS requirements.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastInteractionDate rdf:type rdf:Property ;
    rdfs:label 'Last Interaction Date' ;
    rdfs:comment 'Date of the most recent recorded business interaction with this contact (e.g., sales call, technical inquiry, order placement, site visit). Used to measure contact engagement recency and identify dormant contacts for re-engagement campaigns.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastName rdf:type rdf:Property ;
    rdfs:label 'Last Name' ;
    rdfs:comment 'Family name or surname of the contact person. Combined with first_name to form the full display name for business correspondence and CRM records.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkedinProfileUrl rdf:type rdf:Property ;
    rdfs:label 'Linkedin Profile Url' ;
    rdfs:comment 'LinkedIn public profile URL for the contact. Used by technical sales and account management teams for relationship intelligence, pre-call research, and identifying decision-maker networks within B2B industrial customer organizations.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:middleName rdf:type rdf:Property ;
    rdfs:label 'Middle Name' ;
    rdfs:comment 'Middle name or initial of the contact person. Used for disambiguation when multiple contacts share the same first and last name within a customer organization.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phoneDirect rdf:type rdf:Property ;
    rdfs:label 'Phone Direct' ;
    rdfs:comment 'Direct office or desk phone number for the contact in E.164 international format. Used for urgent technical support, order management, and regulatory compliance communications.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phoneFax rdf:type rdf:Property ;
    rdfs:label 'Phone Fax' ;
    rdfs:comment 'Fax number for the contact in E.164 international format. Relevant for regulatory document transmission (e.g., SDS, COA, purchase orders) in industries and regions where fax remains a compliance-accepted channel.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phoneMobile rdf:type rdf:Property ;
    rdfs:label 'Phone Mobile' ;
    rdfs:comment 'Mobile or cell phone number for the contact in E.164 international format. Used for SMS notifications, emergency EHS (Environment Health and Safety) alerts, and field-level technical support.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredCommunicationChannel rdf:type rdf:Property ;
    rdfs:label 'Preferred Communication Channel' ;
    rdfs:comment 'The contact\'s preferred channel for receiving business communications from Chemical Mfg. Drives outbound communication routing in Salesforce CRM and customer service workflows.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseOrderAuthorityLimit rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Authority Limit' ;
    rdfs:comment 'Maximum monetary value in the customer\'s base currency that this contact is authorized to approve on a Purchase Order (PO). Used by the technical sales team to identify the appropriate contact for order approvals and to escalate large orders to higher-authority contacts.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryNotificationFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Flag' ;
    rdfs:comment 'Indicates whether this contact should receive regulatory compliance notifications, including TSCA updates, REACH substance restriction alerts, EPA reporting deadlines, and product reformulation notices. Supports proactive regulatory communication workflows.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:relationshipEndDate rdf:type rdf:Property ;
    rdfs:label 'Relationship End Date' ;
    rdfs:comment 'Date on which this contact\'s association with the customer account was terminated (e.g., due to role change, departure, or account closure). Null for currently active contacts. Used for historical record retention and compliance audit trails.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:relationshipStartDate rdf:type rdf:Property ;
    rdfs:label 'Relationship Start Date' ;
    rdfs:comment 'Date on which this contact was first established as an active contact for the customer account. Used to calculate relationship tenure and for historical analysis of contact network evolution.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:salutation rdf:type rdf:Property ;
    rdfs:label 'Salutation' ;
    rdfs:comment 'Formal salutation or honorific prefix for the contact (e.g., Mr., Ms., Dr., Prof.). Used in formal business correspondence, regulatory submissions, and technical documentation.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdsDistributionConsent rdf:type rdf:Property ;
    rdfs:label 'Sds Distribution Consent' ;
    rdfs:comment 'Indicates whether this contact has consented to receive Safety Data Sheet (SDS) and Material Safety Data Sheet (MSDS) documents electronically. Required for OSHA HazCom 2012 and GHS compliance in chemical product distribution.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:technicalServiceFlag rdf:type rdf:Property ;
    rdfs:label 'Technical Service Flag' ;
    rdfs:comment 'Indicates whether this contact is designated to receive technical service support, including application engineering assistance, formulation guidance, process troubleshooting, and Certificate of Analysis (COA) requests.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentSiteId rdf:type rdf:Property ;
    rdfs:label 'Parent Site Id' ;
    rdfs:comment 'Self-referencing identifier for the parent site in a site hierarchy (e.g., a campus or complex with multiple sub-sites). Enables multi-level site hierarchy modeling for large industrial customers.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Site .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line1' ;
    rdfs:comment 'Primary street address of the customer site. Used for shipment routing, hazardous materials transport documentation (DOT), and regulatory permit filings.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line2' ;
    rdfs:comment 'Secondary address detail for the customer site (suite, building, dock number, gate reference). Supplements address_line1 for precise delivery routing.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bulkReceiptCapable rdf:type rdf:Property ;
    rdfs:label 'Bulk Receipt Capable' ;
    rdfs:comment 'Indicates whether the site has infrastructure (tank farm, unloading arms, pumps) to receive bulk liquid or solid chemical shipments via tanker truck or rail car.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capacityMt rdf:type rdf:Property ;
    rdfs:label 'Capacity Mt' ;
    rdfs:comment 'Maximum chemical storage capacity of the site expressed in metric tons. Used for supply planning, inventory replenishment modeling, and tank farm utilization analytics.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:city rdf:type rdf:Property ;
    rdfs:label 'City' ;
    rdfs:comment 'City in which the customer site is located. Used for freight zone determination, tax jurisdiction, and regulatory reporting (EPA TRI, OSHA PSM).' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Delivery Window End' ;
    rdfs:comment 'Latest time of day (HH:MM, 24-hour) at which the site accepts chemical deliveries. Used for carrier scheduling, route optimization, and on-time delivery KPI measurement.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryWindowStart rdf:type rdf:Property ;
    rdfs:label 'Delivery Window Start' ;
    rdfs:comment 'Earliest time of day (HH:MM, 24-hour) at which the site accepts chemical deliveries. Used for carrier scheduling, route optimization, and on-time delivery KPI measurement.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dockRestrictions rdf:type rdf:Property ;
    rdfs:label 'Dock Restrictions' ;
    rdfs:comment 'Free-text description of physical dock constraints at the site (e.g., maximum trailer length, dock height limitations, no live unload, appointment required). Used by Oracle TMS and carrier dispatch.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ehsContactName rdf:type rdf:Property ;
    rdfs:label 'Ehs Contact Name' ;
    rdfs:comment 'Name of the designated EHS contact at the customer site. Required for hazardous chemical deliveries, SDS acknowledgment, emergency response coordination, and OSHA PSM compliance.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ehsContactPhone rdf:type rdf:Property ;
    rdfs:label 'Ehs Contact Phone' ;
    rdfs:comment 'Direct phone number for the site EHS contact. Used for emergency chemical incident response, hazmat delivery coordination, and regulatory inspection notifications.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fax rdf:type rdf:Property ;
    rdfs:label 'Fax' ;
    rdfs:comment 'Fax number for the customer site. Used for transmission of SDS, COA, COC, and regulatory documentation where electronic fax is the required delivery channel.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatReceivingCapable rdf:type rdf:Property ;
    rdfs:label 'Hazmat Receiving Capable' ;
    rdfs:comment 'Indicates whether the site is certified and equipped to receive hazardous chemical materials per DOT and OSHA regulations. Governs which chemical products can be shipped to this site.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:latitude rdf:type rdf:Property ;
    rdfs:label 'Latitude' ;
    rdfs:comment 'GPS latitude coordinate of the customer site in decimal degrees (WGS 84). Used for route optimization in Oracle Transportation Management, emergency response planning, and geospatial analytics.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:longitude rdf:type rdf:Property ;
    rdfs:label 'Longitude' ;
    rdfs:comment 'GPS longitude coordinate of the customer site in decimal degrees (WGS 84). Used for route optimization, emergency response planning, and geospatial analytics.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatingHours rdf:type rdf:Property ;
    rdfs:label 'Operating Hours' ;
    rdfs:comment 'Textual description of the site\'s standard operating hours for receiving deliveries (e.g., \'Mon-Fri 06:00-18:00 CST\'). Used by Oracle TMS and SAP EWM for delivery window scheduling.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingPreference rdf:type rdf:Property ;
    rdfs:label 'Packaging Preference' ;
    rdfs:comment 'Customer\'s preferred packaging format for chemical product receipt at this site (e.g., bulk tanker, 55-gallon drum, IBC tote, bag). Drives order fulfillment, SKU selection, and GHS labeling requirements.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Permit Expiry Date' ;
    rdfs:comment 'Expiration date of the site\'s primary regulatory operating or environmental permit. Triggers renewal alerts and may restrict chemical deliveries if permit lapses.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:phone rdf:type rdf:Property ;
    rdfs:label 'Phone' ;
    rdfs:comment 'Primary telephone number for the customer site. Used for delivery coordination, emergency contact, and carrier communication.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postalCode rdf:type rdf:Property ;
    rdfs:label 'Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the customer site. Used for freight rate calculation, carrier zone assignment, and geographic analytics.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredCarrier rdf:type rdf:Property ;
    rdfs:label 'Preferred Carrier' ;
    rdfs:comment 'Name or code of the customer\'s preferred freight carrier for deliveries to this site. Used in Oracle TMS carrier selection and rate negotiation.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryPermitNumber rdf:type rdf:Property ;
    rdfs:label 'Regulatory Permit Number' ;
    rdfs:comment 'Primary environmental or operating permit number issued to the customer site by a regulatory authority (EPA, state agency, OSHA). Required for hazardous chemical delivery authorization and compliance documentation.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesforceSiteCode rdf:type rdf:Property ;
    rdfs:label 'Salesforce Site Code' ;
    rdfs:comment 'External system identifier for this site record in Salesforce CRM (system of record). Used for data lineage, cross-system reconciliation, and integration with Salesforce-driven sales and service workflows.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteCode rdf:type rdf:Property ;
    rdfs:label 'Site Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the site, sourced from SAP S/4HANA customer master or Salesforce CRM. Used in order management, shipping documents, and COA/COC references.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteName rdf:type rdf:Property ;
    rdfs:label 'Site Name' ;
    rdfs:comment 'Human-readable name of the customer site or plant location (e.g., \'Baytown Refinery\', \'Chicago Distribution Center\'). Used on shipping labels, SDS delivery documentation, and customer communications.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteStatus rdf:type rdf:Property ;
    rdfs:label 'Site Status' ;
    rdfs:comment 'Current lifecycle status of the customer site record. Controls whether orders, deliveries, and EHS documentation can be processed against this site.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteType rdf:type rdf:Property ;
    rdfs:label 'Site Type' ;
    rdfs:comment 'Classification of the physical site by its primary operational function. Drives logistics planning, hazmat receiving rules, and EHS compliance requirements. [ENUM-REF-CANDIDATE: manufacturing_plant|distribution_center|rd_lab|warehouse|terminal|blending_facility|storage_depot|other — promote to reference product]' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateProvince rdf:type rdf:Property ;
    rdfs:label 'State Province' ;
    rdfs:comment 'State or province of the customer site. Used for tax jurisdiction, DOT hazmat routing restrictions, and state-level environmental permit compliance.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tankFarmAvailable rdf:type rdf:Property ;
    rdfs:label 'Tank Farm Available' ;
    rdfs:comment 'Indicates whether the customer site has a dedicated tank farm for bulk liquid chemical storage. Determines eligibility for bulk tanker delivery and long-term supply agreements.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:temperatureControlled rdf:type rdf:Property ;
    rdfs:label 'Temperature Controlled' ;
    rdfs:comment 'Indicates whether the site requires temperature-controlled storage or delivery conditions for chemical products (e.g., cryogenic, refrigerated, or heated materials).' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:timeZone rdf:type rdf:Property ;
    rdfs:label 'Time Zone' ;
    rdfs:comment 'IANA time zone identifier for the customer site (e.g., \'America/Chicago\', \'Europe/Berlin\'). Used for delivery window scheduling, order cutoff time calculation, and global reporting normalization.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unLocode rdf:type rdf:Property ;
    rdfs:label 'Un Locode' ;
    rdfs:comment 'UN/LOCODE five-character location code identifying the customer site\'s port, city, or logistics node. Used in international shipping documentation, ASN processing, and TMS routing.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unloadingEquipment rdf:type rdf:Property ;
    rdfs:label 'Unloading Equipment' ;
    rdfs:comment 'Description of unloading equipment available at the site (e.g., forklift, pump, conveyor, crane, vacuum system). Ensures carrier and driver preparedness for chemical product offloading.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountHierarchyId rdf:type rdf:Property ;
    rdfs:label 'Account Hierarchy Id' ;
    rdfs:comment 'Unique surrogate identifier for each account hierarchy relationship record in the customer domain. Primary key for the account_hierarchy data product.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:childAccountId rdf:type rdf:Property ;
    rdfs:label 'Child Account Id' ;
    rdfs:comment 'Identifier of the child account in the hierarchy relationship. References the subordinate node (e.g., subsidiary, division, or plant-level account) beneath the parent account.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:approvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approved Timestamp' ;
    rdfs:comment 'Date and time when this hierarchy relationship record was formally approved by the designated business approver. Supports SOX-compliant audit trail for master data governance.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:changeReason rdf:type rdf:Property ;
    rdfs:label 'Change Reason' ;
    rdfs:comment 'Business reason code explaining why this hierarchy relationship was created or last modified. \'acquisition\' = parent acquired child; \'divestiture\' = child was divested; \'restructuring\' = internal reorganization; \'correction\' = data correction; \'initial_setup\' = first-time configuration; \'merger\' = entities merged. Supports audit trail and MOC (Management of Change) compliance.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationFlag rdf:type rdf:Property ;
    rdfs:label 'Consolidation Flag' ;
    rdfs:comment 'Indicates whether this hierarchy relationship is used for financial consolidation purposes (e.g., rolling up revenue, credit exposure, or receivables to the parent account). True = included in financial consolidation rollup; False = excluded (e.g., commercial grouping only).' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditRollupFlag rdf:type rdf:Property ;
    rdfs:label 'Credit Rollup Flag' ;
    rdfs:comment 'Indicates whether the child account\'s credit exposure is aggregated to the parent account for enterprise-level credit limit management. True = child credit exposure rolls up to parent; False = child is assessed independently. Critical for managing credit risk across multinational chemical buyers and conglomerates.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerGroupCode rdf:type rdf:Property ;
    rdfs:label 'Customer Group Code' ;
    rdfs:comment 'SAP customer group classification code assigned to the child account, used for pricing, reporting, and statistical analysis. Examples include industrial buyer, distributor, OEM, or end-user segments in the chemical manufacturing context.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:domesticUltimateDuns rdf:type rdf:Property ;
    rdfs:label 'Domestic Ultimate Duns' ;
    rdfs:comment 'Dun & Bradstreet D-U-N-S number of the domestic ultimate parent entity (highest-level entity within the same country). Used for country-level credit aggregation and domestic account consolidation.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:globalUltimateDuns rdf:type rdf:Property ;
    rdfs:label 'Global Ultimate Duns' ;
    rdfs:comment 'Dun & Bradstreet D-U-N-S number of the global ultimate parent entity in the corporate ownership chain. Used to link the hierarchy record to the top-level worldwide parent for enterprise credit exposure and global account management.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyCode rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this hierarchy relationship, as assigned in SAP S/4HANA SD customer hierarchy configuration or Salesforce CRM. Used for cross-system reconciliation and reporting.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyDepth rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Depth' ;
    rdfs:comment 'Numeric depth of the child account node within the full hierarchy tree, where 1 represents a direct child of the root (global ultimate). Enables efficient tree traversal queries and level-based revenue rollup in enterprise account analytics.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hierarchyPath rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Path' ;
    rdfs:comment 'Materialized path string representing the full ancestry chain from the root account to the child account (e.g., \'/10001/10045/10089\'). Enables fast subtree queries and hierarchy visualization without recursive joins. Populated by the ETL/data pipeline from SAP or Salesforce hierarchy data.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyStatus rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Status' ;
    rdfs:comment 'Current lifecycle state of the hierarchy relationship record. \'active\' indicates the relationship is currently in effect; \'inactive\' indicates it has been suspended; \'pending\' indicates it is awaiting approval or activation; \'terminated\' indicates the relationship has been formally ended.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyType rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Type' ;
    rdfs:comment 'Classifies the nature of the parent-child relationship. \'ownership\' reflects legal corporate ownership structure; \'commercial\' reflects sales and account management grouping; \'billing\' reflects consolidated invoicing structure; \'reporting\' reflects management reporting rollup; \'logistics\' reflects shipping and delivery consolidation. [ENUM-REF-CANDIDATE: ownership|commercial|billing|reporting|logistics — promote to reference product if additional types emerge]' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyVersion rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Version' ;
    rdfs:comment 'Incrementing version number for this hierarchy relationship record, supporting optimistic concurrency control and change history tracking. Incremented each time the hierarchy relationship is modified (e.g., reclassification, ownership change).' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:industrySectorCode rdf:type rdf:Property ;
    rdfs:label 'Industry Sector Code' ;
    rdfs:comment 'Industry classification code for the child account\'s primary business sector (e.g., automotive, construction, electronics, consumer goods, agriculture). Aligns with SAP industry sector configuration and NAICS/SIC codes. Used for market segment analytics and product portfolio alignment.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalEntityFlag rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Flag' ;
    rdfs:comment 'Indicates whether the child account in this hierarchy relationship represents a distinct legal entity (e.g., incorporated subsidiary) as opposed to an internal division or operational site. Relevant for REACH registration, TSCA compliance, and financial consolidation under FASB ASC 810.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pricingRollupFlag rdf:type rdf:Property ;
    rdfs:label 'Pricing Rollup Flag' ;
    rdfs:comment 'Indicates whether volume-based pricing and rebate agreements negotiated at the parent account level apply to this child account. True = child account inherits parent pricing terms; False = child account has independent pricing. Relevant for chemical distributor networks and multinational industrial buyers.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryRelationshipOwner rdf:type rdf:Property ;
    rdfs:label 'Primary Relationship Owner' ;
    rdfs:comment 'Name or identifier of the global account manager or key account owner responsible for managing the overall parent-child relationship. Sourced from Salesforce CRM account ownership. Used for global account management and escalation routing.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipRole rdf:type rdf:Property ;
    rdfs:label 'Relationship Role' ;
    rdfs:comment 'Describes the role of the child account in the context of this specific hierarchy relationship. \'parent\' indicates the account acts as a superior node; \'child\' indicates a subordinate node; \'sibling\' indicates a peer relationship under the same parent; \'co_parent\' indicates shared ownership or joint venture structures.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRollupFlag rdf:type rdf:Property ;
    rdfs:label 'Revenue Rollup Flag' ;
    rdfs:comment 'Indicates whether the child account\'s revenue is included in the parent account\'s enterprise revenue rollup for global account management, rebate calculation, and volume pricing agreements. True = revenue rolls up; False = revenue is tracked independently.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceSystemKey rdf:type rdf:Property ;
    rdfs:label 'Source System Key' ;
    rdfs:comment 'The natural key or record identifier for this hierarchy relationship in the originating source system (e.g., SAP customer hierarchy node ID or Salesforce Account relationship ID). Used for cross-system traceability and delta load reconciliation.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermId rdf:type rdf:Property ;
    rdfs:label 'Payment Term Id' ;
    rdfs:comment 'Foreign key linking to billing.payment_term. Business justification: Customer segments in chemical mfg define default payment terms applied to all accounts in the segment (e.g., strategic accounts get net 60, standard accounts net 30). The existing default_payment_term' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentTerm .

ind:businessUnit rdf:type rdf:Property ;
    rdfs:label 'Business Unit' ;
    rdfs:comment 'The internal business unit or division of Chemical Mfg responsible for serving this customer segment (e.g., Performance Materials, Agricultural Solutions, Specialty Chemicals, Industrial Chemicals). Maps to SAP FI/CO profit center and Salesforce CRM business unit hierarchy.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coaRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Coa Requirement Flag' ;
    rdfs:comment 'Indicates whether customers in this segment require a Certificate of Analysis (COA) to accompany each shipment, confirming that the product meets specified quality parameters. True = COA mandatory per shipment; False = COA provided on request. Relevant for pharmaceutical excipient, food-grade, and high-purity electronic chemical segments.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditRiskCategory rdf:type rdf:Property ;
    rdfs:label 'Credit Risk Category' ;
    rdfs:comment 'Aggregate credit risk classification for the customer segment based on historical payment behavior, financial health of segment participants, and industry credit risk benchmarks. Informs credit limit setting and payment term defaults in SAP FI/CO. Classified as confidential.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmSegmentCode rdf:type rdf:Property ;
    rdfs:label 'Crm Segment Code' ;
    rdfs:comment 'External identifier for this customer segment as maintained in Salesforce CRM, the system of record for customer segmentation. Used for cross-system reconciliation and data lineage tracing between the Silver Layer lakehouse and Salesforce CRM.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmpComplianceRequired rdf:type rdf:Property ;
    rdfs:label 'Gmp Compliance Required' ;
    rdfs:comment 'Indicates whether customers in this segment require chemical products to be manufactured under Good Manufacturing Practice (GMP) conditions, as applicable to pharmaceutical excipient, API intermediate, and food-contact chemical segments. True = GMP manufacturing and documentation required; False = standard industrial quality.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:growthPotentialRating rdf:type rdf:Property ;
    rdfs:label 'Growth Potential Rating' ;
    rdfs:comment 'Commercial assessment of the revenue growth potential for this customer segment over a 3-5 year horizon: high (significant expansion opportunity), medium (stable moderate growth), low (mature or declining market), emerging (nascent segment with high uncertainty but upside potential). Used in commercial strategy and capital allocation decisions.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatShippingFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Shipping Flag' ;
    rdfs:comment 'Indicates whether products shipped to customers in this segment are classified as hazardous materials requiring DOT/IATA/IMDG compliant shipping documentation, placarding, and carrier certification. True = hazmat shipping protocols apply; False = non-hazardous standard shipping. Drives logistics configuration in Oracle TMS.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Review Date' ;
    rdfs:comment 'Date of the most recent formal review of this customer segment definition, including assessment of segment criteria, customer assignments, and commercial strategy alignment. Supports periodic governance review cycles.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:minOrderQuantityUom rdf:type rdf:Property ;
    rdfs:label 'Min Order Quantity Uom' ;
    rdfs:comment 'Unit of measure for the minimum order quantity field (e.g., kg = kilograms, MT = metric tonnes, L = liters, gal = gallons, drum = 200L drum, IBC = intermediate bulk container, bag = 25kg bag). Aligns with SAP MM unit of measure configuration. [ENUM-REF-CANDIDATE: kg|MT|L|gal|drum|IBC|bag — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:owner rdf:type rdf:Property ;
    rdfs:label 'Owner' ;
    rdfs:comment 'Name or employee identifier of the commercial leader (e.g., Business Development Manager, Market Segment Manager) accountable for the segment strategy, performance targets, and customer relationships within this segment. Aligns with Salesforce CRM account ownership model.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerEmail rdf:type rdf:Property ;
    rdfs:label 'Owner Email' ;
    rdfs:comment 'Corporate email address of the segment owner for routing commercial inquiries, escalations, and reporting. Used in automated workflow notifications from Salesforce CRM and SAP SD.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredPackagingType rdf:type rdf:Property ;
    rdfs:label 'Preferred Packaging Type' ;
    rdfs:comment 'Standard packaging format preferred by customers in this segment for chemical product delivery (e.g., 200L drums, 1000L IBC totes, bulk tanker, 25kg bags, 1kg laboratory bottles). Influences supply chain planning, warehouse operations in SAP EWM, and logistics configuration in Oracle TMS.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingTierCode rdf:type rdf:Property ;
    rdfs:label 'Pricing Tier Code' ;
    rdfs:comment 'Code identifying the pricing tier applicable to customers in this segment, referencing the SAP SD pricing procedure and condition type configuration. Determines base price lists, discount structures, and rebate eligibility. Classified as confidential due to commercial sensitivity.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryProductPortfolio rdf:type rdf:Property ;
    rdfs:label 'Primary Product Portfolio' ;
    rdfs:comment 'Description of the primary chemical product lines, formulations, or product families applicable to this customer segment (e.g., Epoxy Resins, Polyurethane Intermediates, Crop Protection Actives, Electronic-Grade Solvents). Drives product recommendation logic and technical service scoping.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reachRegistrationRequired rdf:type rdf:Property ;
    rdfs:label 'Reach Registration Required' ;
    rdfs:comment 'Indicates whether customers in this segment are located in the European Economic Area and therefore require REACH registration documentation for all chemical substances supplied above 1 tonne per year. True = REACH compliance documentation required; False = not applicable. Drives regulatory documentation workflows.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryComplianceProfile rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Profile' ;
    rdfs:comment 'Description of the primary regulatory frameworks applicable to customers in this segment that Chemical Mfg must support (e.g., REACH compliance documentation for EU customers, TSCA Section 6 for US industrial customers, GHS SDS requirements, FDA food-contact compliance for food-grade chemical customers). Drives documentation and compliance reporting obligations.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesRegion rdf:type rdf:Property ;
    rdfs:label 'Sales Region' ;
    rdfs:comment 'Geographic sales region primarily associated with this customer segment (e.g., North America, EMEA, APAC, Latin America). Used for territory planning, quota allocation, and regional commercial reporting in SAP SD and Salesforce CRM.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapCustomerGroup rdf:type rdf:Property ;
    rdfs:label 'Sap Customer Group' ;
    rdfs:comment 'SAP SD customer group code (field KDGRP) associated with this segment, used for pricing condition determination, rebate processing, and sales statistics grouping in SAP S/4HANA. Enables direct mapping between the segment definition and SAP SD commercial configuration.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdsRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Sds Requirement Flag' ;
    rdfs:comment 'Indicates whether customers in this segment require Safety Data Sheet (SDS) documentation to be provided with all chemical shipments as a standard commercial requirement. True = SDS mandatory for all orders; False = SDS provided on request only. Aligns with GHS and OSHA Hazard Communication Standard (HCS) requirements.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:segmentCode rdf:type rdf:Property ;
    rdfs:label 'Segment Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the customer segment (e.g., AUTO_OEM, AGRO_DIST, SPEC_COAT, PHARMA_EXC, ELEC_MFG). Used as the business key in Salesforce CRM and SAP SD customer classification. Serves as the BUSINESS_IDENTIFIER for this MASTER_RESOURCE entity.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentDescription rdf:type rdf:Property ;
    rdfs:label 'Segment Description' ;
    rdfs:comment 'Detailed narrative description of the customer segment, including the types of customers included, their primary use cases for chemical products, and the commercial rationale for the segment definition.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentName rdf:type rdf:Property ;
    rdfs:label 'Segment Name' ;
    rdfs:comment 'Human-readable name of the customer segment (e.g., Automotive OEM, Agrochemical Distributor, Specialty Coatings, Pharma Excipient, Electronics). Serves as the IDENTITY_LABEL for this MASTER_RESOURCE entity. Used in commercial strategy, pricing tiers, and technical service allocation.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentStatus rdf:type rdf:Property ;
    rdfs:label 'Segment Status' ;
    rdfs:comment 'Current lifecycle status of the customer segment definition: active (in use for commercial operations), inactive (no longer applied to new customers), under_review (being evaluated for revision), deprecated (replaced by a newer segment structure). Serves as the LIFECYCLE_STATUS for this MASTER_RESOURCE entity.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentTier rdf:type rdf:Property ;
    rdfs:label 'Segment Tier' ;
    rdfs:comment 'Commercial priority tier assigned to the segment, reflecting strategic importance and resource allocation level. Tier 1 represents the highest-priority segments (e.g., strategic global accounts), while Tier 4 represents transactional or low-volume segments. Drives pricing authority, technical service allocation, and account management coverage.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentType rdf:type rdf:Property ;
    rdfs:label 'Segment Type' ;
    rdfs:comment 'Classification of the segment by customer relationship type: end_user (direct consumer of chemicals), distributor (reseller/channel partner), oem (original equipment manufacturer), toll_manufacturer (contract processor), trading_company (commodity trader), government (public sector). Serves as the primary CLASSIFICATION_OR_TYPE for this entity. [ENUM-REF-CANDIDATE: end_user|distributor|oem|toll_manufacturer|trading_company|government|broker|cooperative — promote to reference product if additional types are needed]' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetRevenueUsd rdf:type rdf:Property ;
    rdfs:label 'Target Revenue Usd' ;
    rdfs:comment 'Annual revenue target in US Dollars (USD) set for this customer segment as part of the commercial planning cycle. Used in SAP FI/CO profitability analysis (CO-PA) and Salesforce CRM quota management. Classified as confidential due to commercial sensitivity. This is a planning input, not a calculated aggregate.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:technicalServiceLevel rdf:type rdf:Property ;
    rdfs:label 'Technical Service Level' ;
    rdfs:comment 'Level of technical service and application support allocated to customers in this segment: full_service (dedicated technical account manager, on-site support, custom formulation assistance), standard (remote technical support, standard SDS/COA documentation), self_service (online portal access only), none (no technical service). Drives resource planning for technical sales teams.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:walletShareEstimatePct rdf:type rdf:Property ;
    rdfs:label 'Wallet Share Estimate Pct' ;
    rdfs:comment 'Estimated percentage of the total addressable spend within this segment that Chemical Mfg currently captures (0.00 to 100.00). Represents the MEASUREMENT_OR_VALUE principal quantitative fact for this MASTER_RESOURCE entity. Used in commercial strategy to identify penetration gaps and prioritize growth investments. Classified as confidential due to competitive sensitivity.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditProfileId rdf:type rdf:Property ;
    rdfs:label 'Credit Profile Id' ;
    rdfs:comment 'Unique surrogate identifier for the customer credit profile record in the Databricks Silver Layer. Primary key for this entity.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:badDebtGlAccountId rdf:type rdf:Property ;
    rdfs:label 'Bad Debt Gl Account Id' ;
    rdfs:comment 'Foreign key linking to finance.gl_account. Business justification: Bad debt provisioning in chemical manufacturing requires posting credit loss reserves to specific GL accounts (allowance for doubtful accounts). Credit teams reference the GL account for bad debt rese' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:creditBlockFlag rdf:type rdf:Property ;
    rdfs:label 'Credit Block Flag' ;
    rdfs:comment 'Indicates whether the customer is currently subject to a credit block in SAP SD (KNKK-CTLPC / KNVV-AUFSD). When True, new sales orders for this customer are blocked from delivery and billing until the block is resolved by the credit department. Critical control for order-to-cash risk management.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditBlockReason rdf:type rdf:Property ;
    rdfs:label 'Credit Block Reason' ;
    rdfs:comment 'Reason code explaining why the customer credit block is active. \'overlimit\' indicates exposure exceeds approved limit; \'payment_overdue\' indicates past-due invoices; \'credit_review\' indicates periodic review in progress; \'legal_dispute\' indicates an active dispute; \'sanctions_hold\' indicates a regulatory/compliance hold; \'manual_hold\' indicates a discretionary hold by the credit analyst.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditControlArea rdf:type rdf:Property ;
    rdfs:label 'Credit Control Area' ;
    rdfs:comment 'SAP credit control area code (KKBER) that governs the credit limit and exposure tracking for this customer. Defines the organizational unit responsible for credit management, typically aligned to a company code or regional finance entity.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditExposureAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Exposure Amount' ;
    rdfs:comment 'Current total credit exposure for the customer, representing the sum of open receivables, open sales orders, and open deliveries not yet invoiced. Sourced from SAP S/4HANA credit exposure calculation (KNKK-SKFOR). Used to assess proximity to credit limit and trigger credit blocks.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Credit Hold Flag' ;
    rdfs:comment 'Indicates whether the customer account is on a general credit hold, which may be broader than a specific SAP credit block. A credit hold may prevent new orders, shipments, or both, and is managed by the credit department independently of the automated SAP block logic.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditInsuranceCoverageAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Insurance Coverage Amount' ;
    rdfs:comment 'Maximum insured amount under the trade credit insurance policy for this customer. Represents the portion of the credit exposure that is covered by the insurer in the event of customer default. Used to calculate the net uninsured credit exposure.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditInsurancePolicyRef rdf:type rdf:Property ;
    rdfs:label 'Credit Insurance Policy Ref' ;
    rdfs:comment 'Reference number or identifier for the trade credit insurance policy covering this customer\'s receivables. Credit insurance is commonly used in chemical distribution to mitigate counterparty default risk on large B2B accounts. Enables linkage to the insurer\'s policy documentation for claims processing.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Amount' ;
    rdfs:comment 'Maximum approved credit exposure (in base currency) extended to the customer by the credit department. Stored in SAP S/4HANA as KNKK-KLIMK. Drives order block logic in SAP SD when exposure approaches or exceeds this threshold. Critical for order-to-cash risk management in chemical distribution.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditLimitApprovalLevel rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Approval Level' ;
    rdfs:comment 'Authorization level required to approve or modify the credit limit for this customer, based on the credit limit amount and risk category. Enforces the company\'s credit approval authority matrix and SOX segregation of duties controls.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimitEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Effective Date' ;
    rdfs:comment 'Date from which the current approved credit limit became effective. Supports audit trail requirements and enables historical analysis of credit limit changes over time. Aligns with the MASTER_AGREEMENT EFFECTIVE_FROM category.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditLimitExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Expiry Date' ;
    rdfs:comment 'Date on which the current approved credit limit expires and requires renewal or re-approval. Nullable for open-ended credit arrangements. When populated, triggers automated alerts to the credit analyst for timely renewal. Aligns with the MASTER_AGREEMENT EFFECTIVE_UNTIL category.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditNotesText rdf:type rdf:Property ;
    rdfs:label 'Credit Notes Text' ;
    rdfs:comment 'Free-text field for credit analyst notes, observations, and commentary related to the customer\'s credit profile. May include context on credit decisions, customer communications, or risk factors not captured in structured fields. Restricted to credit department personnel.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditProfileStatus rdf:type rdf:Property ;
    rdfs:label 'Credit Profile Status' ;
    rdfs:comment 'Current lifecycle status of the customer credit profile. \'active\' indicates the profile is in use for order-to-cash processing; \'suspended\' indicates temporary hold; \'under_review\' indicates a scheduled or triggered credit review is in progress; \'pending_approval\' indicates a new or revised limit awaiting authorization.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditReviewDate rdf:type rdf:Property ;
    rdfs:label 'Credit Review Date' ;
    rdfs:comment 'Date on which the most recent formal credit review was conducted for this customer. Used to track compliance with the credit department\'s periodic review schedule and to assess the currency of the credit assessment.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditSegment rdf:type rdf:Property ;
    rdfs:label 'Credit Segment' ;
    rdfs:comment 'Customer segmentation classification from a credit management perspective. \'strategic\' and \'key_account\' customers may receive preferential credit terms; \'distributor\' reflects the B2B distribution channel common in chemical manufacturing; \'new_customer\' triggers enhanced due diligence and conservative initial limits.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditUtilizationPct rdf:type rdf:Property ;
    rdfs:label 'Credit Utilization Pct' ;
    rdfs:comment 'Percentage of the approved credit limit currently utilized, calculated as (credit_exposure_amount / credit_limit_amount) × 100. Provides a normalized risk indicator for credit analysts and automated alerting when utilization exceeds defined thresholds (e.g., 80%, 90%, 100%).' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dsoActualDays rdf:type rdf:Property ;
    rdfs:label 'Dso Actual Days' ;
    rdfs:comment 'Actual current days sales outstanding (DSO) for this customer, representing the average number of days receivables remain outstanding. Compared against dso_target_days to identify payment performance trends and trigger credit review actions.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dsoTargetDays rdf:type rdf:Property ;
    rdfs:label 'Dso Target Days' ;
    rdfs:comment 'Target number of days sales outstanding (DSO) established for this customer by the credit department. Represents the expected average collection period for receivables from this customer. Used as a benchmark for monitoring actual collection performance and identifying deteriorating payment behavior.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dunBradstreetNumber rdf:type rdf:Property ;
    rdfs:label 'Dun Bradstreet Number' ;
    rdfs:comment 'The nine-digit Data Universal Numbering System (DUNS) number assigned by Dun & Bradstreet to uniquely identify the customer\'s business entity. Used to retrieve and link external credit reports and financial risk data for the customer.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunBradstreetRating rdf:type rdf:Property ;
    rdfs:label 'Dun Bradstreet Rating' ;
    rdfs:comment 'External credit rating assigned by Dun & Bradstreet (D&B) for the customer organization. Includes the D&B PAYDEX score or composite credit appraisal code. Used to supplement internal credit assessment with third-party financial risk data for B2B industrial customers and distributors in chemical distribution.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalCreditRating rdf:type rdf:Property ;
    rdfs:label 'Internal Credit Rating' ;
    rdfs:comment 'Internally assigned credit rating for the customer, determined by the credit department based on payment history, financial statements, and risk assessment. Typically expressed as a letter or alphanumeric grade (e.g., A1, B2, C3) aligned to the company\'s internal credit scoring methodology. [ENUM-REF-CANDIDATE: A1|A2|B1|B2|C1|C2|D — promote to reference product]' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Last Approval Date' ;
    rdfs:comment 'Date on which the credit limit or credit terms were last formally approved by an authorized approver. Supports SOX audit trail requirements and enables tracking of the age of the most recent credit authorization.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Last Approved By' ;
    rdfs:comment 'Name or user ID of the individual who last approved the credit limit or credit terms for this customer. Provides an audit trail for credit authorization decisions in compliance with SOX internal control requirements.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oldestOverdueDays rdf:type rdf:Property ;
    rdfs:label 'Oldest Overdue Days' ;
    rdfs:comment 'Number of days since the oldest overdue invoice for this customer became past due. Used to assess the severity of payment delinquency and to trigger escalation actions such as collections referral or credit block.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overdueAmount rdf:type rdf:Property ;
    rdfs:label 'Overdue Amount' ;
    rdfs:comment 'Total value of invoices that are past their due date for this customer, expressed in the credit limit currency. A key indicator of payment risk and a primary trigger for credit block activation and credit review escalation.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentBehaviorScore rdf:type rdf:Property ;
    rdfs:label 'Payment Behavior Score' ;
    rdfs:comment 'Internally calculated payment behavior score for the customer, derived from historical payment patterns including on-time payment rate, frequency of late payments, and average days late. Expressed as a numeric score (e.g., 1–100). Used as an input to the internal credit rating and credit limit decisions.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:profileCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Profile Created Timestamp' ;
    rdfs:comment 'Timestamp when the credit profile record was first created in the system. Provides the audit trail creation marker for this entity, supporting SOX compliance and data lineage requirements in the Databricks Silver Layer.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:profileUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Profile Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent modification to the credit profile record. Used for change tracking, data freshness assessment, and incremental load processing in the Databricks Silver Layer pipeline.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sanctionsCheckDate rdf:type rdf:Property ;
    rdfs:label 'Sanctions Check Date' ;
    rdfs:comment 'Date on which the most recent sanctions and restricted party screening was performed for this customer. Used to ensure screening is current and to schedule re-screening at required intervals per compliance policy.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sanctionsCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Sanctions Check Status' ;
    rdfs:comment 'Status of the most recent sanctions and restricted party screening check performed for this customer. Chemical manufacturers must screen customers against OFAC, EU, and UN sanctions lists. \'flagged\' triggers immediate credit hold and compliance review.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapCreditAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Credit Account Number' ;
    rdfs:comment 'The externally-known SAP credit management account number (KNKK-KNKLI) assigned to the customer in SAP S/4HANA SD. Used as the business identifier for cross-system reconciliation with the ERP credit management module.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialCreditTerms rdf:type rdf:Property ;
    rdfs:label 'Special Credit Terms' ;
    rdfs:comment 'Free-text description of any special or negotiated credit terms applicable to this customer that deviate from standard payment terms. Examples include extended payment schedules, seasonal credit adjustments, or terms negotiated as part of a strategic account agreement in chemical distribution.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingPermitId rdf:type rdf:Property ;
    rdfs:label 'Operating Permit Id' ;
    rdfs:comment 'Foreign key linking to ehs.operating_permit. Business justification: Customer regulatory compliance review process: before shipping regulated chemicals, sales and regulatory teams verify the customer\'s site operating permit is valid and covers the chemical class. This ' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OperatingPermit .

ind:requiredSafetyDataSheetId rdf:type rdf:Property ;
    rdfs:label 'Required Safety Data Sheet Id' ;
    rdfs:comment 'Foreign key linking to ehs.safety_data_sheet. Business justification: SDS distribution compliance process: a customer\'s regulatory profile mandates a specific SDS version and language (OSHA HazCom, REACH Article 31). Linking to the actual SDS record replaces the denorma' ;
    rdfs:domain ind:RegulatoryProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SafetyDataSheet .

ind:approvedProductCategories rdf:type rdf:Property ;
    rdfs:label 'Approved Product Categories' ;
    rdfs:comment 'Comma-separated list of chemical product categories or families that are approved for sale to this customer under the current regulatory profile (e.g., solvents, adhesives, specialty polymers). Restricts order processing to compliant product types.' ;
    rdfs:domain ind:RegulatoryProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditRightsAgreed rdf:type rdf:Property ;
    rdfs:label 'Audit Rights Agreed' ;
    rdfs:comment 'Indicates whether the customer has agreed to grant the supplier audit rights to verify compliance with regulatory requirements, safe handling practices, and end-use declarations for supplied chemicals.' ;
    rdfs:domain ind:RegulatoryProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:auditRightsAgreementDate rdf:type rdf:Property ;
    rdfs:label 'Audit Rights Agreement Date' ;
    rdfs:comment 'Date on which the customer formally agreed to audit rights provisions. Used to track agreement currency and renewal obligations.' ;
    rdfs:domain ind:RegulatoryProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:destinationCountryCode rdf:type rdf:Property ;
    rdfs:label 'Destination Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the primary country of destination for chemical product shipments to this customer. Drives applicable regulatory framework selection (e.g., REACH for EU, TSCA for USA).' ;
    rdfs:domain ind:RegulatoryProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationRegion rdf:type rdf:Property ;
    rdfs:label 'Destination Region' ;
    rdfs:comment 'Geographic region or trade bloc of the customer destination (e.g., European Union, North America, Asia-Pacific) used for regional regulatory framework grouping and reporting.' ;
    rdfs:domain ind:RegulatoryProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downstreamUserNotification rdf:type rdf:Property ;
    rdfs:label 'Downstream User Notification' ;
    rdfs:comment 'Indicates whether this customer qualifies as a REACH downstream user and has been notified of their obligations under REACH, including use conditions, exposure scenarios, and risk management measures.' ;
    rdfs:domain ind:RegulatoryProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ehsCertificationExpiry rdf:type rdf:Property ;
    rdfs:label 'Ehs Certification Expiry' ;
    rdfs:comment 'Expiry date of the customer\'s EHS certification. Triggers re-validation workflow when approaching expiry to ensure continued compliance eligibility.' ;
    rdfs:domain ind:RegulatoryProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ehsCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Ehs Certification Number' ;
    rdfs:comment 'Certificate number or registration identifier for the customer\'s EHS management system certification (e.g., ISO 14001 certificate number), used for audit trail and verification.' ;
    rdfs:domain ind:RegulatoryProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ehsCertificationStatus rdf:type rdf:Property ;
    rdfs:label 'Ehs Certification Status' ;
    rdfs:comment 'Current status of the customer\'s EHS certification relevant to handling and using chemical products (e.g., ISO 14001, ISO 45001, OSHA VPP). Determines eligibility for certain product categories.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endUseDeclaration rdf:type rdf:Property ;
    rdfs:label 'End Use Declaration' ;
    rdfs:comment 'Customer\'s declared intended end-use application for the chemical products purchased (e.g., industrial solvent, agricultural formulation, polymer additive, pharmaceutical intermediate). Required for REACH downstream user obligations and export control compliance.' ;
    rdfs:domain ind:RegulatoryProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endUseSector rdf:type rdf:Property ;
    rdfs:label 'End Use Sector' ;
    rdfs:comment 'Industry sector classification of the customer\'s end-use application for purchased chemicals. [ENUM-REF-CANDIDATE: automotive|construction|electronics|agriculture|pharmaceuticals|consumer_goods|coatings|textiles|food_contact|industrial — promote to reference product]' ;
    rdfs:domain ind:RegulatoryProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exportLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Export License Number' ;
    rdfs:comment 'Export license or authorization number issued by the originating country\'s regulatory authority for controlled chemical substances, required for dual-use or restricted chemicals.' ;
    rdfs:domain ind:RegulatoryProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ghsApplicable rdf:type rdf:Property ;
    rdfs:label 'Ghs Applicable' ;
    rdfs:comment 'Indicates whether the Globally Harmonized System of Classification and Labelling of Chemicals applies to products sold to this customer, requiring GHS-compliant Safety Data Sheets and labels.' ;
    rdfs:domain ind:RegulatoryProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazmatTransportClass rdf:type rdf:Property ;
    rdfs:label 'Hazmat Transport Class' ;
    rdfs:comment 'DOT/IATA/IMDG hazardous materials transport classification applicable to chemical products shipped to this customer (e.g., Class 3 Flammable Liquid, Class 8 Corrosive). Governs packaging, labeling, and shipping documentation requirements.' ;
    rdfs:domain ind:RegulatoryProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:importLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Import License Number' ;
    rdfs:comment 'Customer\'s import license or permit number issued by the destination country\'s regulatory authority, required for controlled or restricted chemical substances. Must be validated before shipment.' ;
    rdfs:domain ind:RegulatoryProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAuditDate rdf:type rdf:Property ;
    rdfs:label 'Last Audit Date' ;
    rdfs:comment 'Date of the most recent regulatory compliance audit conducted at or for this customer. Used to schedule next audit and assess compliance currency.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:msdsRequired rdf:type rdf:Property ;
    rdfs:label 'Msds Required' ;
    rdfs:comment 'Indicates whether the legacy MSDS format (pre-GHS) is required in addition to or instead of the current SDS format, applicable for customers in jurisdictions that have not fully adopted GHS.' ;
    rdfs:domain ind:RegulatoryProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:profileNumber rdf:type rdf:Property ;
    rdfs:label 'Profile Number' ;
    rdfs:comment 'Externally-known business identifier for this regulatory profile, used in correspondence, audits, and regulatory submissions. Format: REGP-YYYYMMDD-CountryCode.' ;
    rdfs:domain ind:RegulatoryProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileStatus rdf:type rdf:Property ;
    rdfs:label 'Profile Status' ;
    rdfs:comment 'Current lifecycle state of the customer regulatory profile. Active indicates all requirements are met and sales may proceed; pending_review indicates documentation is under assessment; suspended indicates a compliance hold; expired indicates the profile requires renewal.' ;
    rdfs:domain ind:RegulatoryProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileType rdf:type rdf:Property ;
    rdfs:label 'Profile Type' ;
    rdfs:comment 'Classification of the customer relationship type that determines applicable regulatory obligations and documentation requirements for chemical product sales.' ;
    rdfs:domain ind:RegulatoryProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prop65Applicable rdf:type rdf:Property ;
    rdfs:label 'Prop65 Applicable' ;
    rdfs:comment 'Indicates whether California Proposition 65 (Safe Drinking Water and Toxic Enforcement Act) warning requirements apply to products sold to this customer based on end-use state or distribution territory.' ;
    rdfs:domain ind:RegulatoryProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reachApplicable rdf:type rdf:Property ;
    rdfs:label 'Reach Applicable' ;
    rdfs:comment 'Indicates whether the European Chemicals Agency REACH regulation applies to chemical products sold to this customer, based on destination country and product use.' ;
    rdfs:domain ind:RegulatoryProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryContactEmail rdf:type rdf:Property ;
    rdfs:label 'Regulatory Contact Email' ;
    rdfs:comment 'Email address of the designated regulatory affairs or EHS contact at the customer organization for compliance documentation, SDS distribution, and regulatory notifications.' ;
    rdfs:domain ind:RegulatoryProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryContactName rdf:type rdf:Property ;
    rdfs:label 'Regulatory Contact Name' ;
    rdfs:comment 'Full name of the designated regulatory affairs or EHS contact person at the customer organization responsible for managing compliance documentation and regulatory correspondence.' ;
    rdfs:domain ind:RegulatoryProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictedProductCategories rdf:type rdf:Property ;
    rdfs:label 'Restricted Product Categories' ;
    rdfs:comment 'Comma-separated list of chemical product categories that are restricted or prohibited from sale to this customer based on regulatory, end-use, or jurisdictional constraints. Triggers order block in SAP S/4HANA SD.' ;
    rdfs:domain ind:RegulatoryProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictedSubstanceAckDate rdf:type rdf:Property ;
    rdfs:label 'Restricted Substance Ack Date' ;
    rdfs:comment 'Date on which the customer formally acknowledged the supplier\'s Restricted Substance List. Used to track acknowledgment currency and trigger renewal when the RSL is updated.' ;
    rdfs:domain ind:RegulatoryProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:restrictedSubstanceAcknowledgment rdf:type rdf:Property ;
    rdfs:label 'Restricted Substance Acknowledgment' ;
    rdfs:comment 'Indicates whether the customer has formally acknowledged receipt and acceptance of the supplier\'s Restricted Substance List, confirming awareness of substances that are prohibited or restricted in supplied products.' ;
    rdfs:domain ind:RegulatoryProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rohsApplicable rdf:type rdf:Property ;
    rdfs:label 'Rohs Applicable' ;
    rdfs:comment 'Indicates whether EU RoHS (Restriction of Hazardous Substances) directive requirements apply to chemical products or materials sold to this customer, particularly relevant for electronics-sector customers.' ;
    rdfs:domain ind:RegulatoryProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sdsLanguageCode rdf:type rdf:Property ;
    rdfs:label 'Sds Language Code' ;
    rdfs:comment 'ISO 639-1 language code (optionally with ISO 3166-1 country subtag) specifying the required language for Safety Data Sheets provided to this customer (e.g., en, de, fr, zh-CN).' ;
    rdfs:domain ind:RegulatoryProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialLabelingRequirements rdf:type rdf:Property ;
    rdfs:label 'Special Labeling Requirements' ;
    rdfs:comment 'Free-text description of any customer-specific or jurisdiction-specific labeling requirements beyond standard GHS/SDS requirements, such as additional language requirements, customer-specific hazard statements, or country-specific pictogram standards.' ;
    rdfs:domain ind:RegulatoryProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:svhcNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Svhc Notification Required' ;
    rdfs:comment 'Indicates whether the customer requires proactive notification when any supplied product contains Substances of Very High Concern (SVHC) above 0.1% w/w threshold, as mandated under REACH Article 33.' ;
    rdfs:domain ind:RegulatoryProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tscaApplicable rdf:type rdf:Property ;
    rdfs:label 'Tsca Applicable' ;
    rdfs:comment 'Indicates whether the US EPA Toxic Substances Control Act requirements apply to chemical products sold to this customer.' ;
    rdfs:domain ind:RegulatoryProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvingContactId rdf:type rdf:Property ;
    rdfs:label 'Approving Contact Id' ;
    rdfs:comment 'Foreign key linking to customer.contact. Business justification: A product qualification at a customer site is formally approved by a specific customer contact (e.g., procurement manager, plant engineer). The existing `approved_by_customer_contact` field is a denor' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:customerSiteId rdf:type rdf:Property ;
    rdfs:label 'Customer Site Id' ;
    rdfs:comment 'Reference to the specific customer plant, facility, or site location where the qualified product is approved for use. Qualifications are site-specific in chemical supply to automotive, pharma, and electronics sectors.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Site .

ind:inspectionPlanId rdf:type rdf:Property ;
    rdfs:label 'Inspection Plan Id' ;
    rdfs:comment 'Foreign key linking to quality.inspection_plan. Business justification: In chemical manufacturing, certain customers (pharma, food-grade) require a customer-specific or stricter inspection plan as a condition of their product qualification. This link enables the productio' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InspectionPlan .

ind:aplNumber rdf:type rdf:Property ;
    rdfs:label 'Apl Number' ;
    rdfs:comment 'Externally-known business identifier for the qualification record, typically assigned by the customer or jointly by the supplier and customer. Used in customer correspondence, COA references, and audit trails.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationUseCase rdf:type rdf:Property ;
    rdfs:label 'Application Use Case' ;
    rdfs:comment 'The specific end-use application or process for which the chemical product has been qualified at the customer site (e.g., automotive coating adhesion, semiconductor etch bath, pharmaceutical excipient, agricultural formulation carrier).' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedByInternalUser rdf:type rdf:Property ;
    rdfs:label 'Approved By Internal User' ;
    rdfs:comment 'The name or employee ID of the internal Chemical Mfg representative (e.g., technical sales, quality manager) who managed and approved the qualification from the supplier side.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeNotificationLeadDays rdf:type rdf:Property ;
    rdfs:label 'Change Notification Lead Days' ;
    rdfs:comment 'The minimum number of calendar days advance notice required to be given to the customer before implementing any change to the qualified product. Populated only when change_notification_required_flag is True.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:changeNotificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Change Notification Required Flag' ;
    rdfs:comment 'Indicates whether the customer requires formal notification (e.g., PCN - Product Change Notification) before any change to the qualified product formulation, process, or raw material source. Critical in automotive and electronics supply chains.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crmQualificationCode rdf:type rdf:Property ;
    rdfs:label 'Crm Qualification Code' ;
    rdfs:comment 'The qualification record identifier in Salesforce CRM, the system of record for customer-facing qualification activities. Enables bidirectional traceability between the lakehouse Silver Layer and the operational CRM.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerPartNumber rdf:type rdf:Property ;
    rdfs:label 'Customer Part Number' ;
    rdfs:comment 'The customer\'s own internal part number or material code assigned to this qualified chemical product. Used for cross-referencing in purchase orders, COA requests, and EDI transactions.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSpecNumber rdf:type rdf:Property ;
    rdfs:label 'Customer Spec Number' ;
    rdfs:comment 'The customer\'s internal specification document number that defines the quality requirements for this qualified product. Referenced on COA and COC documents during shipment.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusiveSupplyFlag rdf:type rdf:Property ;
    rdfs:label 'Exclusive Supply Flag' ;
    rdfs:comment 'Indicates whether Chemical Mfg is the sole qualified supplier for this product at this customer site. True = exclusive supply arrangement; False = customer has multiple qualified suppliers.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:industrySegment rdf:type rdf:Property ;
    rdfs:label 'Industry Segment' ;
    rdfs:comment 'The end-market industry segment of the customer for which this qualification applies. Drives regulatory requirements, COA content, and qualification rigor. [ENUM-REF-CANDIDATE: automotive|electronics|pharmaceutical|agriculture|construction|consumer_goods|industrial|aerospace|food_beverage|coatings — promote to reference product]' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limsQualificationReference rdf:type rdf:Property ;
    rdfs:label 'Lims Qualification Reference' ;
    rdfs:comment 'The qualification record identifier in LabWare LIMS, used to cross-reference lab trial data, test results, and analytical reports that supported the qualification decision.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxApprovedVolumeKg rdf:type rdf:Property ;
    rdfs:label 'Max Approved Volume Kg' ;
    rdfs:comment 'The maximum annual or periodic supply volume in kilograms approved under this qualification. Volumes exceeding this threshold require customer notification or re-qualification.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minApprovedVolumeKg rdf:type rdf:Property ;
    rdfs:label 'Min Approved Volume Kg' ;
    rdfs:comment 'The minimum annual or periodic supply volume in kilograms approved under this qualification. Volumes below this threshold may require re-qualification or customer notification.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualificationDate rdf:type rdf:Property ;
    rdfs:label 'Qualification Date' ;
    rdfs:comment 'The date on which the product qualification was formally approved and granted by the customer. This is the effective start date for commercial supply under this qualification.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualificationMethod rdf:type rdf:Property ;
    rdfs:label 'Qualification Method' ;
    rdfs:comment 'The method by which the product was qualified for use at the customer site. \'lab_trial\' = bench-scale testing at customer or supplier lab; \'plant_trial\' = full-scale production trial at customer facility; \'third_party_cert\' = qualification via third-party certification body; \'desk_review\' = documentation-only review; \'customer_audit\' = qualification via customer site audit; \'equivalency_study\' = qualification via equivalency to an already-approved product.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationScope rdf:type rdf:Property ;
    rdfs:label 'Qualification Scope' ;
    rdfs:comment 'Defines the geographic or organizational scope of the qualification. \'site_specific\' = applies only to the named customer site; \'global_account\' = applies across all sites of the customer account; \'regional\' = applies to a defined regional cluster of sites; \'product_family\' = applies to a family of related products.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryComplianceStandard rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Standard' ;
    rdfs:comment 'The primary regulatory or quality standard under which this qualification was conducted (e.g., IATF 16949 for automotive, ICH Q7 for pharmaceutical API, IPC-7711 for electronics, ISO 9001 for general industrial). Drives audit and documentation requirements.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Lead Time Days' ;
    rdfs:comment 'The number of calendar days before the expiry date that the renewal process must be initiated to ensure supply continuity. Used to trigger renewal workflow alerts in the quality management system.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Renewal Required Flag' ;
    rdfs:comment 'Indicates whether this qualification requires periodic renewal before the expiry date. True = renewal process must be initiated; False = qualification is perpetual or renewal is not contractually required.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specDeviationDescription rdf:type rdf:Property ;
    rdfs:label 'Spec Deviation Description' ;
    rdfs:comment 'Narrative description of any customer-approved deviations from the standard product specification included in this qualification. Populated only when spec_deviation_flag is True.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specDeviationFlag rdf:type rdf:Property ;
    rdfs:label 'Spec Deviation Flag' ;
    rdfs:comment 'Indicates whether this qualification includes customer-approved deviations from the standard product specification. True = one or more approved deviations exist; False = qualification is to standard specification.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:volumePeriod rdf:type rdf:Property ;
    rdfs:label 'Volume Period' ;
    rdfs:comment 'The time period to which the approved volume range (min/max) applies. Defines whether volume limits are annual, quarterly, monthly, or per-order constraints.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionId rdf:type rdf:Property ;
    rdfs:label 'Interaction Id' ;
    rdfs:comment 'Unique surrogate identifier for each customer interaction record in the Silver Layer lakehouse. Primary key for the interaction data product.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:channel rdf:type rdf:Property ;
    rdfs:label 'Channel' ;
    rdfs:comment 'The communication channel through which the interaction was conducted. Supports omnichannel analytics and customer engagement reporting.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coaRequestFlag rdf:type rdf:Property ;
    rdfs:label 'Coa Request Flag' ;
    rdfs:comment 'Indicates whether the customer requested a Certificate of Analysis (COA) during this interaction. Supports quality document fulfillment tracking and customer quality management.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complaintFlag rdf:type rdf:Property ;
    rdfs:label 'Complaint Flag' ;
    rdfs:comment 'Indicates whether this interaction involves or originated from a customer complaint. Triggers linkage to the complaint/case management workflow and Corrective and Preventive Action (CAPA) process.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crmActivityCode rdf:type rdf:Property ;
    rdfs:label 'Crm Activity Code' ;
    rdfs:comment 'External identifier from Salesforce CRM activity record. Used to trace the interaction back to the system of record for reconciliation and lineage.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerParticipantCount rdf:type rdf:Property ;
    rdfs:label 'Customer Participant Count' ;
    rdfs:comment 'Number of customer-side contacts who participated in the interaction. Indicates the breadth of customer engagement and stakeholder involvement.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:customerParticipants rdf:type rdf:Property ;
    rdfs:label 'Customer Participants' ;
    rdfs:comment 'Comma-separated list of customer contact names or identifiers who participated in the interaction. Confidential business relationship data.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSatisfactionScore rdf:type rdf:Property ;
    rdfs:label 'Customer Satisfaction Score' ;
    rdfs:comment 'Numeric satisfaction rating provided by the customer or assessed by the account manager following the interaction, typically on a 1-5 or 1-10 scale. Supports Key Performance Indicator (KPI) tracking for customer relationship health.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:durationMinutes rdf:type rdf:Property ;
    rdfs:label 'Duration Minutes' ;
    rdfs:comment 'The total elapsed time of the interaction in minutes. Used to assess engagement depth, resource utilization, and account planning efficiency.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:followUpDueDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Due Date' ;
    rdfs:comment 'The target date by which the required follow-up action must be completed. Used for task management and account manager accountability tracking.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:followUpNotes rdf:type rdf:Property ;
    rdfs:label 'Follow Up Notes' ;
    rdfs:comment 'Free-text description of the specific follow-up actions committed to during the interaction. Captures commitments made to the customer for accountability and continuity.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpRequired rdf:type rdf:Property ;
    rdfs:label 'Follow Up Required' ;
    rdfs:comment 'Indicates whether a follow-up action or subsequent interaction is required as a result of this interaction. Drives task creation and account planning workflows.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interactionDate rdf:type rdf:Property ;
    rdfs:label 'Interaction Date' ;
    rdfs:comment 'The calendar date on which the customer interaction occurred. Used for day-level scheduling, account planning, and reporting.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:interactionDescription rdf:type rdf:Property ;
    rdfs:label 'Interaction Description' ;
    rdfs:comment 'Detailed narrative of the interaction content, discussion points, and context. Captures technical topics discussed, products referenced, and any regulatory or compliance matters raised.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionStatus rdf:type rdf:Property ;
    rdfs:label 'Interaction Status' ;
    rdfs:comment 'Current lifecycle status of the interaction record. Indicates whether the interaction was completed as planned, cancelled, or requires rescheduling.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Interaction Timestamp' ;
    rdfs:comment 'The precise date and time at which the customer interaction commenced. Supports time-zone-aware analytics and SLA measurement.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:interactionType rdf:type rdf:Property ;
    rdfs:label 'Interaction Type' ;
    rdfs:comment 'Classification of the nature or purpose of the customer interaction. Distinguishes between sales-driven, technical service, complaint handling, and digital engagement touchpoints. [ENUM-REF-CANDIDATE: sales_call|technical_visit|complaint_call|email_exchange|webinar|trade_show|portal_login|video_conference — promote to reference product]' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalParticipantCount rdf:type rdf:Property ;
    rdfs:label 'Internal Participant Count' ;
    rdfs:comment 'Number of internal Chemical Mfg employees who participated in the interaction. Used for resource utilization and engagement intensity analysis.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:internalParticipants rdf:type rdf:Property ;
    rdfs:label 'Internal Participants' ;
    rdfs:comment 'Comma-separated list of internal employee names or identifiers who participated in the interaction (e.g., account manager, technical service representative, application chemist). Supports multi-participant interaction tracking.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:location rdf:type rdf:Property ;
    rdfs:label 'Location' ;
    rdfs:comment 'Physical or virtual location where the interaction took place (e.g., customer plant site, trade show venue, video conference URL, Chemical Mfg office). Relevant for in-person and on-site technical visits.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Modified Timestamp' ;
    rdfs:comment 'The date and time when this interaction record was last updated in the system. Supports change tracking, data quality monitoring, and audit compliance.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:nextInteractionDate rdf:type rdf:Property ;
    rdfs:label 'Next Interaction Date' ;
    rdfs:comment 'The scheduled date for the next planned customer interaction as agreed during this touchpoint. Supports account planning cadence and proactive customer engagement management.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:outcome rdf:type rdf:Property ;
    rdfs:label 'Outcome' ;
    rdfs:comment 'The result or disposition of the interaction as assessed by the internal participant. Supports win/loss analysis, customer satisfaction tracking, and account health scoring.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryTopicFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Topic Flag' ;
    rdfs:comment 'Indicates whether the interaction involved discussion of regulatory or compliance topics such as REACH, TSCA, GHS, SDS requirements, or EPA/OSHA obligations. Supports regulatory engagement tracking and compliance reporting.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:salesTerritoryCode rdf:type rdf:Property ;
    rdfs:label 'Sales Territory Code' ;
    rdfs:comment 'The sales territory code associated with this interaction, derived from the account owner\'s territory assignment. Supports territory-level performance reporting and account planning.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleRequestFlag rdf:type rdf:Property ;
    rdfs:label 'Sample Request Flag' ;
    rdfs:comment 'Indicates whether the customer requested a product sample during this interaction. Triggers linkage to the sample request fulfillment process in the sales domain.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sdsRequestFlag rdf:type rdf:Property ;
    rdfs:label 'Sds Request Flag' ;
    rdfs:comment 'Indicates whether the customer requested a Safety Data Sheet (SDS) or Material Safety Data Sheet (MSDS) during this interaction. Supports regulatory document fulfillment tracking per GHS and OSHA HazCom requirements.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:subject rdf:type rdf:Property ;
    rdfs:label 'Subject' ;
    rdfs:comment 'Brief title or subject line summarizing the topic of the interaction. Mirrors the Salesforce CRM activity subject field and supports keyword search and categorization.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalTopic rdf:type rdf:Property ;
    rdfs:label 'Technical Topic' ;
    rdfs:comment 'The primary technical subject matter discussed during the interaction (e.g., formulation support, application development, regulatory compliance, Safety Data Sheet (SDS) review, Certificate of Analysis (COA) query). Supports technical service analytics.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseDescription rdf:type rdf:Property ;
    rdfs:label 'Case Description' ;
    rdfs:comment 'Full narrative description of the customer issue, request, or complaint as reported by the customer. For quality complaints, includes the customer\'s account of the product defect, observed symptoms, and business impact.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseNumber rdf:type rdf:Property ;
    rdfs:label 'Case Number' ;
    rdfs:comment 'Externally visible, human-readable case reference number used in all customer communications and cross-system references. Sourced from Salesforce CRM Case Number field.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseStatus rdf:type rdf:Property ;
    rdfs:label 'Case Status' ;
    rdfs:comment 'Current workflow state of the case lifecycle. Open: newly created, awaiting assignment. In Progress: actively being worked. Pending Customer: awaiting customer response or information. Resolved: solution provided, awaiting confirmation. Closed: fully completed and confirmed.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseType rdf:type rdf:Property ;
    rdfs:label 'Case Type' ;
    rdfs:comment 'Classification of the customer case by business function. Technical Support covers formulation and application assistance; Order Issue covers shipment discrepancies and billing disputes; SDS (Safety Data Sheet) Request and COA (Certificate of Analysis) Request cover documentation fulfillment; Regulatory Inquiry covers REACH, TSCA, GHS compliance questions; Quality Complaint covers OOS (Out of Specification) product issues.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedDate rdf:type rdf:Property ;
    rdfs:label 'Closed Date' ;
    rdfs:comment 'The date on which the case was fully closed after customer confirmation of resolution. Distinct from resolved_date; a case may be resolved but remain open pending customer acknowledgment.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditNoteIssued rdf:type rdf:Property ;
    rdfs:label 'Credit Note Issued' ;
    rdfs:comment 'Indicates whether a financial credit note has been issued to the customer as part of the resolution of a quality complaint or order discrepancy case. When True, a corresponding credit memo exists in SAP FI/CO.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditNoteNumber rdf:type rdf:Property ;
    rdfs:label 'Credit Note Number' ;
    rdfs:comment 'The SAP document number of the credit note issued to the customer for a quality complaint or order discrepancy resolution. Populated only when credit_note_issued is True. Enables financial reconciliation between the case and the accounting entry.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmCaseCode rdf:type rdf:Property ;
    rdfs:label 'Crm Case Code' ;
    rdfs:comment 'The native case identifier from Salesforce CRM, the system of record for customer cases. Enables bidirectional traceability between the lakehouse silver layer and the operational CRM system.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSatisfactionOutcome rdf:type rdf:Property ;
    rdfs:label 'Customer Satisfaction Outcome' ;
    rdfs:comment 'Categorical outcome of the customer satisfaction assessment following case closure. Derived from the customer\'s qualitative feedback or survey response. Complements the numeric customer_satisfaction_rating for segmentation and reporting.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSatisfactionRating rdf:type rdf:Property ;
    rdfs:label 'Customer Satisfaction Rating' ;
    rdfs:comment 'Numeric customer satisfaction score collected after case resolution, typically on a 1-5 scale (1=Very Dissatisfied, 5=Very Satisfied). Sourced from post-resolution customer survey. Used as a KPI (Key Performance Indicator) for customer service quality.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eightDReportNumber rdf:type rdf:Property ;
    rdfs:label 'Eight D Report Number' ;
    rdfs:comment 'Reference number of the 8D (Eight Disciplines) problem-solving report generated for a quality complaint case. The 8D methodology is the standard structured problem-solving workflow for quality complaints in chemical manufacturing. Populated when an 8D report has been formally initiated.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalated rdf:type rdf:Property ;
    rdfs:label 'Escalated' ;
    rdfs:comment 'Indicates whether the case has been formally escalated beyond the initially assigned service representative, either due to SLA breach, severity, or customer request. Escalated cases trigger management notification workflows.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalationReason rdf:type rdf:Property ;
    rdfs:label 'Escalation Reason' ;
    rdfs:comment 'The reason the case was escalated. SLA Breach: resolution deadline exceeded. Customer Request: customer demanded escalation. Safety Concern: potential EHS (Environment Health and Safety) implication. Regulatory Risk: potential regulatory non-compliance. Management Directive: escalated by management decision.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limsInvestigationReference rdf:type rdf:Property ;
    rdfs:label 'Lims Investigation Reference' ;
    rdfs:comment 'The investigation record identifier in LabWare LIMS linked to this case for OOS (Out of Specification) product investigations. Populated when an OOS investigation has been initiated in the LIMS system in response to a quality complaint.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openedDate rdf:type rdf:Property ;
    rdfs:label 'Opened Date' ;
    rdfs:comment 'The calendar date on which the customer case was officially opened and entered into the system. Used for SLA (Service Level Agreement) calculation and aging analysis.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rciStatus rdf:type rdf:Property ;
    rdfs:label 'Rci Status' ;
    rdfs:comment 'Current status of the Root Cause Investigation (RCI) triggered by a quality complaint. Tracks whether the investigation into the product defect or OOS (Out of Specification) condition has been initiated, is ongoing, or has been completed. Applicable only to quality_complaint case type.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryFramework rdf:type rdf:Property ;
    rdfs:label 'Regulatory Framework' ;
    rdfs:comment 'The specific regulatory framework or standard that is the subject of a regulatory inquiry case. Identifies whether the customer\'s inquiry relates to REACH (Registration, Evaluation, Authorisation and Restriction of Chemicals), TSCA (Toxic Substances Control Act), GHS (Globally Harmonized System), or other applicable regulation. Populated for regulatory_inquiry case type.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionDescription rdf:type rdf:Property ;
    rdfs:label 'Resolution Description' ;
    rdfs:comment 'Detailed narrative of the actions taken and solution provided to resolve the customer case. For quality complaints, includes findings from the RCI (Root Cause Investigation) and corrective actions applied.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolvedDate rdf:type rdf:Property ;
    rdfs:label 'Resolved Date' ;
    rdfs:comment 'The date on which the case was marked as resolved, meaning the solution or response was provided to the customer. Used to calculate actual resolution time against SLA targets.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sdsDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Sds Document Number' ;
    rdfs:comment 'The document control number of the Safety Data Sheet (SDS) provided or referenced in response to an SDS request case. Enables traceability of which SDS version was fulfilled. Applicable to sds_request case type.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severity rdf:type rdf:Property ;
    rdfs:label 'Severity' ;
    rdfs:comment 'Severity classification of the issue impact on the customer\'s operations or safety. Distinct from priority (which drives internal response urgency), severity reflects the actual business or safety impact of the reported issue. Critical severity triggers mandatory CAPA (Corrective and Preventive Action) and RCI (Root Cause Investigation) workflows.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaBreached rdf:type rdf:Property ;
    rdfs:label 'Sla Breached' ;
    rdfs:comment 'Indicates whether the case resolution exceeded the SLA due date, constituting an SLA breach. Used for service quality reporting, customer penalty tracking, and continuous improvement initiatives.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaDueDate rdf:type rdf:Property ;
    rdfs:label 'Sla Due Date' ;
    rdfs:comment 'The contractual or policy-defined deadline by which the case must be resolved, based on case type, priority, and applicable customer SLA agreement. Drives escalation workflows when breached.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fixedAssetId rdf:type rdf:Property ;
    rdfs:label 'Fixed Asset Id' ;
    rdfs:comment 'Foreign key linking to finance.fixed_asset. Business justification: Chemical plant equipment (reactors, compressors, heat exchangers) are capitalized fixed assets. Linking equipment to its fixed_asset record enables depreciation tracking, net book value reporting, ass' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FixedAsset .

ind:processSafetyInfoId rdf:type rdf:Property ;
    rdfs:label 'Process Safety Info Id' ;
    rdfs:comment 'Foreign key linking to ehs.process_safety_info. Business justification: OSHA PSM standard mandates that process safety information (PSI) be accessible for covered equipment. Maintenance technicians performing work on PSM-covered equipment must reference the PSI document f' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcessSafetyInfo .

ind:assetNumber rdf:type rdf:Property ;
    rdfs:label 'Asset Number' ;
    rdfs:comment 'SAP FI-AA fixed asset number linked to this equipment for financial accounting, depreciation calculation, and CapEx tracking. Bridges the maintenance and finance domains.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetTagNumber rdf:type rdf:Property ;
    rdfs:label 'Asset Tag Number' ;
    rdfs:comment 'Physical asset tag or nameplate number affixed to the equipment in the field. Used for physical identification during inspections, maintenance activities, and fixed asset accounting reconciliation.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationRequired rdf:type rdf:Property ;
    rdfs:label 'Calibration Required' ;
    rdfs:comment 'Indicates whether this equipment (typically instrumentation) requires periodic calibration to maintain measurement accuracy and regulatory compliance. True=calibration program applies; False=not applicable.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capacityUnit rdf:type rdf:Property ;
    rdfs:label 'Capacity Unit' ;
    rdfs:comment 'Unit of measure for the equipment capacity value (e.g., m3, m3/hr, kW, kg/hr, bar). Follows SI unit conventions for chemical process engineering.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityValue rdf:type rdf:Property ;
    rdfs:label 'Capacity Value' ;
    rdfs:comment 'Principal rated capacity or throughput of the equipment (e.g., volumetric capacity for vessels in m³, flow rate for pumps in m³/hr, heat duty for heat exchangers in kW). The unit is specified in capacity_unit.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commissioningDate rdf:type rdf:Property ;
    rdfs:label 'Commissioning Date' ;
    rdfs:comment 'Date the equipment was formally commissioned and accepted into operational service following installation, pre-commissioning checks, and startup testing. Distinct from installation date.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:constructionYear rdf:type rdf:Property ;
    rdfs:label 'Construction Year' ;
    rdfs:comment 'Year in which the equipment was manufactured or constructed. Used for age-based risk assessment, remaining useful life estimation, and regulatory inspection scheduling.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:corrosionAllowanceMm rdf:type rdf:Property ;
    rdfs:label 'Corrosion Allowance Mm' ;
    rdfs:comment 'Designed corrosion allowance in millimeters added to the minimum required wall thickness to account for expected corrosion over the equipment\'s design life. Used in fitness-for-service assessments and remaining life calculations.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costCenter rdf:type rdf:Property ;
    rdfs:label 'Cost Center' ;
    rdfs:comment 'SAP CO cost center to which maintenance costs for this equipment are charged. Used for maintenance cost allocation, OpEx reporting, and budget variance analysis.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalityClass rdf:type rdf:Property ;
    rdfs:label 'Criticality Class' ;
    rdfs:comment 'Equipment criticality ranking used to prioritize maintenance resources and inspection frequency. A=Safety-critical/production-critical (highest priority, PSM-covered); B=Important but has redundancy or workaround; C=Non-critical/low impact on safety or production.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decommissionDate rdf:type rdf:Property ;
    rdfs:label 'Decommission Date' ;
    rdfs:comment 'Date the equipment was permanently removed from service and decommissioned. Null for active equipment. Required for fixed asset retirement accounting and regulatory closure documentation.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:designPressureKpa rdf:type rdf:Property ;
    rdfs:label 'Design Pressure Kpa' ;
    rdfs:comment 'Maximum allowable working pressure (MAWP) for which the equipment was designed, expressed in kilopascals (kPa). Critical nameplate data for pressure vessel inspection, relief valve sizing, and PSM mechanical integrity documentation.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Design Temperature C' ;
    rdfs:comment 'Maximum allowable design temperature for which the equipment was designed, expressed in degrees Celsius. Used for material of construction verification, thermal stress analysis, and PSM mechanical integrity records.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:equipmentCategory rdf:type rdf:Property ;
    rdfs:label 'Equipment Category' ;
    rdfs:comment 'SAP PM equipment category code classifying the asset type: M=Mechanical, E=Electrical, I=Instrumentation, P=Piping, V=Vessel/Reactor. Drives maintenance planning strategy and inspection requirements. [ENUM-REF-CANDIDATE: M|E|I|P|V|C|R — promote to reference product]' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentClass rdf:type rdf:Property ;
    rdfs:label 'Equipment Class' ;
    rdfs:comment 'Detailed equipment classification within the category (e.g., Centrifugal Pump, Reciprocating Compressor, Shell-and-Tube Heat Exchanger, Pressure Vessel, Control Valve, Thermocouple). Aligns with ISO 14224 equipment taxonomy for reliability data collection.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentName rdf:type rdf:Property ;
    rdfs:label 'Equipment Name' ;
    rdfs:comment 'Human-readable descriptive name or short description of the equipment asset (e.g., \'Reactor Feed Pump\', \'Distillation Column Overhead Condenser\'). Corresponds to SAP PM equipment description field.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentNumber rdf:type rdf:Property ;
    rdfs:label 'Equipment Number' ;
    rdfs:comment 'Externally-known alphanumeric equipment number assigned in SAP PM (EQUNR). Serves as the primary business identifier used across maintenance work orders, inspection records, and P&ID cross-references.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentStatus rdf:type rdf:Property ;
    rdfs:label 'Equipment Status' ;
    rdfs:comment 'Current operational lifecycle status of the equipment asset. Active=in normal service; Inactive=installed but not in service; Decommissioned=permanently removed from service; Standby=available as backup; Under_Maintenance=currently undergoing planned or corrective maintenance.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardousAreaClassification rdf:type rdf:Property ;
    rdfs:label 'Hazardous Area Classification' ;
    rdfs:comment 'Electrical area classification of the location where this equipment is installed, per NEC/IEC standards. Determines requirements for explosion-proof or intrinsically safe electrical equipment. Zone 0/1/2 per IEC 60079; Division 1/2 per NEC Article 500.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionIntervalMonths rdf:type rdf:Property ;
    rdfs:label 'Inspection Interval Months' ;
    rdfs:comment 'Required inspection frequency in months as determined by regulatory requirements, risk-based inspection (RBI) analysis, or manufacturer recommendations. Used to auto-calculate next_inspection_date.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:installationDate rdf:type rdf:Property ;
    rdfs:label 'Installation Date' ;
    rdfs:comment 'Date the equipment was physically installed at its current functional location. Marks the start of the equipment\'s operational lifecycle at this site for maintenance history and warranty tracking.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:insulationType rdf:type rdf:Property ;
    rdfs:label 'Insulation Type' ;
    rdfs:comment 'Type of thermal or acoustic insulation applied to the equipment (e.g., mineral wool, calcium silicate, cellular glass, none). Relevant for corrosion under insulation (CUI) inspection programs and energy efficiency assessments.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenancePlannerGroup rdf:type rdf:Property ;
    rdfs:label 'Maintenance Planner Group' ;
    rdfs:comment 'SAP PM planner group code responsible for planning and scheduling maintenance activities for this equipment. Determines which maintenance team owns the equipment\'s work order planning.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceStrategy rdf:type rdf:Property ;
    rdfs:label 'Maintenance Strategy' ;
    rdfs:comment 'Assigned maintenance strategy for this equipment asset: Time_Based=fixed interval preventive maintenance; Condition_Based=maintenance triggered by condition monitoring thresholds; Predictive=data-driven prediction of failure; Run_To_Failure=no planned maintenance; Reliability_Centered=RCM-derived strategy.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturerName rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Name' ;
    rdfs:comment 'Name of the original equipment manufacturer (OEM). Used for spare parts sourcing, warranty claims, and technical support escalation.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mocStatus rdf:type rdf:Property ;
    rdfs:label 'Moc Status' ;
    rdfs:comment 'Current Management of Change (MOC) workflow status for any pending or recent modification to this equipment. Not_Required=no active MOC; Pending=MOC initiated and under review; Approved=MOC approved, change authorized; Closed=MOC completed and documented.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelNumber rdf:type rdf:Property ;
    rdfs:label 'Model Number' ;
    rdfs:comment 'Manufacturer\'s model or part number for this equipment type. Used for spare parts procurement, technical documentation retrieval, and like-for-like replacement identification.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextCalibrationDate rdf:type rdf:Property ;
    rdfs:label 'Next Calibration Date' ;
    rdfs:comment 'Date by which the next calibration of this instrument or measurement device must be completed to maintain traceability and compliance. Null if calibration_required is False.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Next Inspection Date' ;
    rdfs:comment 'Date of the next mandatory regulatory or internal inspection due for this equipment. Drives inspection scheduling for PSM mechanical integrity, API 510/570/653 inspections, and insurance surveys.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operatingPressureKpa rdf:type rdf:Property ;
    rdfs:label 'Operating Pressure Kpa' ;
    rdfs:comment 'Normal operating pressure of the equipment under standard process conditions, expressed in kilopascals (kPa). Used for process monitoring, deviation detection, and SPC control limit setting.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatingTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Operating Temperature C' ;
    rdfs:comment 'Normal operating temperature of the equipment under standard process conditions, expressed in degrees Celsius. Used for process monitoring, heat balance calculations, and corrosion rate estimation.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:piTagReference rdf:type rdf:Property ;
    rdfs:label 'Pi Tag Reference' ;
    rdfs:comment 'Aveva PI System historian tag name or tag pattern associated with this equipment for real-time process data retrieval (e.g., temperature, pressure, flow readings). Enables linkage between equipment master data and real-time operational data.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pidTag rdf:type rdf:Property ;
    rdfs:label 'Pid Tag' ;
    rdfs:comment 'The P&ID tag number identifying this equipment on process engineering drawings (e.g., P-101A, E-201, V-301). Used for cross-referencing with Piping and Instrumentation Diagrams, HAZOP studies, and PSM documentation.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:psmCovered rdf:type rdf:Property ;
    rdfs:label 'Psm Covered' ;
    rdfs:comment 'Indicates whether this equipment is subject to OSHA Process Safety Management (PSM) mechanical integrity requirements under 29 CFR 1910.119. True=PSM-covered; requires documented inspection, testing, and quality assurance program.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serialNumber rdf:type rdf:Property ;
    rdfs:label 'Serial Number' ;
    rdfs:comment 'Manufacturer-assigned serial number for the equipment unit. Required for warranty tracking, OEM service records, and regulatory inspection documentation.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightKg rdf:type rdf:Property ;
    rdfs:label 'Weight Kg' ;
    rdfs:comment 'Dry operating weight of the equipment in kilograms. Used for structural load calculations, rigging and lifting plans, and transportation logistics for equipment removal or replacement.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workCenter rdf:type rdf:Property ;
    rdfs:label 'Work Center' ;
    rdfs:comment 'SAP PM work center responsible for executing maintenance activities on this equipment (e.g., MECH-01, ELEC-02, INST-03). Drives labor scheduling, capacity planning, and cost center assignment.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:abcIndicator rdf:type rdf:Property ;
    rdfs:label 'Abc Indicator' ;
    rdfs:comment 'Criticality classification of the functional location using the SAP PM ABC indicator. \'A\' = critical (production-critical, safety-critical), \'B\' = important (significant impact), \'C\' = non-critical (minimal impact). Drives maintenance prioritization, spare parts stocking, and OEE improvement focus. Corresponds to SAP PM IFLOT-ABCKZ.' ;
    rdfs:domain ind:FunctionalLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buildingOrAreaCode rdf:type rdf:Property ;
    rdfs:label 'Building Or Area Code' ;
    rdfs:comment 'Physical building, bay, or plant area code where the functional location is situated. Used for maintenance crew routing, emergency response, and facility management. Complements the hierarchical floc_code with a physical location reference.' ;
    rdfs:domain ind:FunctionalLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:catalogProfileCode rdf:type rdf:Property ;
    rdfs:label 'Catalog Profile Code' ;
    rdfs:comment 'SAP PM catalog profile assigned to this functional location, defining the damage codes, cause codes, and activity codes available for maintenance notifications and work orders. Ensures standardized failure coding for reliability analysis and CAPA workflows. Corresponds to SAP PM IFLOT-RBNR.' ;
    rdfs:domain ind:FunctionalLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyCode rdf:type rdf:Property ;
    rdfs:label 'Company Code' ;
    rdfs:comment 'SAP company code (Buchungskreis) representing the legal entity that owns this functional location. Required for financial reporting, asset accounting, and SOX compliance. Corresponds to SAP PM IFLOT-BUKRS.' ;
    rdfs:domain ind:FunctionalLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constructionMaterial rdf:type rdf:Property ;
    rdfs:label 'Construction Material' ;
    rdfs:comment 'Primary material of construction for the functional location (e.g., \'Carbon Steel A516-70\', \'316L Stainless Steel\', \'Hastelloy C-276\', \'FRP\'). Critical for corrosion management, inspection planning, and chemical compatibility assessment under REACH and PSM requirements.' ;
    rdfs:domain ind:FunctionalLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flocCode rdf:type rdf:Property ;
    rdfs:label 'Floc Code' ;
    rdfs:comment 'The externally-known alphanumeric code uniquely identifying the functional location within the plant hierarchy, as maintained in SAP PM (IFLOT-TPLNR). Follows the plant-unit-area-system-subsystem naming convention (e.g., CH01-RX-001-P-001). This is the business identifier used on work orders, P&IDs, and maintenance records.' ;
    rdfs:domain ind:FunctionalLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:floorOrElevation rdf:type rdf:Property ;
    rdfs:label 'Floor Or Elevation' ;
    rdfs:comment 'Floor level or elevation reference (e.g., \'Grade Level\', \'EL +12.5m\', \'Mezzanine Level 2\') for the functional location within a building or structure. Supports maintenance crew navigation and emergency response planning.' ;
    rdfs:domain ind:FunctionalLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalLocationCategory rdf:type rdf:Property ;
    rdfs:label 'Functional Location Category' ;
    rdfs:comment 'Broad equipment category grouping for the functional location. Used for maintenance strategy segmentation, PSM mechanical integrity scope definition, and EHS compliance reporting. Aligns with ISO 14224 taxonomy. [ENUM-REF-CANDIDATE: process_equipment|utility_equipment|instrumentation|electrical|civil_structural|safety_system|environmental_control — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FunctionalLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalLocationDescription rdf:type rdf:Property ;
    rdfs:label 'Functional Location Description' ;
    rdfs:comment 'Human-readable description of the functional location, describing its physical or logical purpose within the plant (e.g., \'Reactor Feed Pump — Unit 3 Ethylene Plant\'). Corresponds to SAP PM IFLOT-PLTXT.' ;
    rdfs:domain ind:FunctionalLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geoLatitude rdf:type rdf:Property ;
    rdfs:label 'Geo Latitude' ;
    rdfs:comment 'GPS latitude coordinate of the functional location in decimal degrees (WGS84). Enables spatial analytics, emergency response planning, and integration with plant GIS systems for asset location visualization.' ;
    rdfs:domain ind:FunctionalLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geoLongitude rdf:type rdf:Property ;
    rdfs:label 'Geo Longitude' ;
    rdfs:comment 'GPS longitude coordinate of the functional location in decimal degrees (WGS84). Enables spatial analytics, emergency response planning, and integration with plant GIS systems for asset location visualization.' ;
    rdfs:domain ind:FunctionalLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inspectionClass rdf:type rdf:Property ;
    rdfs:label 'Inspection Class' ;
    rdfs:comment 'Inspection methodology classification for this functional location. \'RBI\' (Risk-Based Inspection) applies to pressure equipment per API 580/581; \'fixed_interval\' for time-based statutory inspections; \'condition_based\' for CBM programs; \'run_to_failure\' for non-critical assets. Drives inspection planning and regulatory compliance.' ;
    rdfs:domain ind:FunctionalLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastChangedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Changed Timestamp' ;
    rdfs:comment 'Timestamp of the most recent modification to this functional location record in the source system (SAP PM). Supports change tracking, data lineage, and master data governance audit requirements.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:linearAssetFlag rdf:type rdf:Property ;
    rdfs:label 'Linear Asset Flag' ;
    rdfs:comment 'Indicates whether this functional location represents a linear asset (e.g., pipeline, cable tray, conveyor) as opposed to a point asset. Linear assets require linear reference measurement for inspection and maintenance location identification.' ;
    rdfs:domain ind:FunctionalLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maintenanceStrategyCode rdf:type rdf:Property ;
    rdfs:label 'Maintenance Strategy Code' ;
    rdfs:comment 'SAP PM maintenance strategy assigned to this functional location, defining the preventive maintenance cycle (e.g., time-based, condition-based, predictive). Drives automatic generation of maintenance orders and inspection plans. Corresponds to SAP PM IFLOT-MSTRAT.' ;
    rdfs:domain ind:FunctionalLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mocRequired rdf:type rdf:Property ;
    rdfs:label 'Moc Required' ;
    rdfs:comment 'Indicates whether any modification to this functional location requires a formal Management of Change (MOC) workflow per OSHA PSM requirements. Typically true for PSM-covered locations and safety-critical systems. Drives MOC initiation in the change management process.' ;
    rdfs:domain ind:FunctionalLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:objectType rdf:type rdf:Property ;
    rdfs:label 'Object Type' ;
    rdfs:comment 'SAP PM object type code classifying the functional location by equipment category (e.g., reactor, pump, heat exchanger, vessel, compressor, instrumentation). Drives maintenance strategy assignment and spare parts planning. Corresponds to SAP PM IFLOT-EQART. [ENUM-REF-CANDIDATE: reactor|pump|heat_exchanger|vessel|compressor|instrumentation|piping|column|tank|filter — promote to reference product]' ;
    rdfs:domain ind:FunctionalLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pidReference rdf:type rdf:Property ;
    rdfs:label 'Pid Reference' ;
    rdfs:comment 'Reference number or drawing identifier of the P&ID document on which this functional location appears. Critical for PSM mechanical integrity, MOC workflows, and HAZOP studies. Enables traceability between the physical asset hierarchy and engineering drawings.' ;
    rdfs:domain ind:FunctionalLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannerGroupCode rdf:type rdf:Property ;
    rdfs:label 'Planner Group Code' ;
    rdfs:comment 'SAP PM planner group responsible for planning and scheduling maintenance activities at this functional location. Used for workload distribution, capacity planning, and maintenance KPI reporting. Corresponds to SAP PM IFLOT-INGRP.' ;
    rdfs:domain ind:FunctionalLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pressureRatingBar rdf:type rdf:Property ;
    rdfs:label 'Pressure Rating Bar' ;
    rdfs:comment 'Maximum allowable working pressure (MAWP) for the functional location in bar units. Used for mechanical integrity assessments, inspection planning, and PSM compliance. Applies primarily to pressure vessels, reactors, and piping systems.' ;
    rdfs:domain ind:FunctionalLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processUnitName rdf:type rdf:Property ;
    rdfs:label 'Process Unit Name' ;
    rdfs:comment 'Name of the chemical process unit or production unit to which this functional location belongs (e.g., \'Ethylene Cracker Unit 1\', \'Sulfuric Acid Plant\', \'Polymerization Train B\'). Provides operational context for maintenance planning and P&ID alignment.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sortField rdf:type rdf:Property ;
    rdfs:label 'Sort Field' ;
    rdfs:comment 'Alphanumeric sort field used for grouping and filtering functional locations in maintenance reports and work order lists. Typically encodes plant area, equipment class, or operational unit for reporting convenience. Corresponds to SAP PM IFLOT-EQFNR.' ;
    rdfs:domain ind:FunctionalLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureRatingC rdf:type rdf:Property ;
    rdfs:label 'Temperature Rating C' ;
    rdfs:comment 'Maximum allowable design temperature for the functional location in degrees Celsius. Used for material selection validation, mechanical integrity assessments, and process safety compliance.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workCenterCode rdf:type rdf:Property ;
    rdfs:label 'Work Center Code' ;
    rdfs:comment 'SAP work center responsible for performing maintenance activities at this functional location. Used for capacity planning, scheduling, and cost allocation. Corresponds to SAP PM IFLOT-GEWRK.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionAuditId rdf:type rdf:Property ;
    rdfs:label 'Inspection Audit Id' ;
    rdfs:comment 'Foreign key linking to ehs.inspection_audit. Business justification: Corrective work orders are generated directly from EHS inspection/audit findings in chemical plants. Compliance tracking requires demonstrating that all audit findings resulted in completed work order' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InspectionAudit .

ind:pmPlanId rdf:type rdf:Property ;
    rdfs:label 'Pm Plan Id' ;
    rdfs:comment 'Reference to the preventive maintenance plan that generated this work order, if applicable. Null for corrective or breakdown work orders not originating from a scheduled maintenance plan.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PmPlan .

ind:productionPlanId rdf:type rdf:Property ;
    rdfs:label 'Production Plan Id' ;
    rdfs:comment 'Foreign key linking to planning.production_plan. Business justification: Turnaround and shutdown maintenance work orders are explicitly tied to production plans in chemical manufacturing. A work order for pre-campaign equipment preparation references the production plan it' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductionPlan .

ind:actualDurationHours rdf:type rdf:Property ;
    rdfs:label 'Actual Duration Hours' ;
    rdfs:comment 'Actual total duration of the maintenance work in hours, calculated from start to completion timestamps. Used for performance analysis and future work estimation.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual End Timestamp' ;
    rdfs:comment 'Actual date and time when maintenance work execution was completed, recorded when all work activities are finished and equipment is ready for return to service.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualLaborCost rdf:type rdf:Property ;
    rdfs:label 'Actual Labor Cost' ;
    rdfs:comment 'Actual total cost of internal labor based on confirmed hours and standard or actual labor rates. Used for maintenance cost accounting and variance analysis.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualLaborHours rdf:type rdf:Property ;
    rdfs:label 'Actual Labor Hours' ;
    rdfs:comment 'Actual total labor hours consumed across all crafts and operations, confirmed through time confirmations. Used for cost accounting and productivity analysis.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualMaterialCost rdf:type rdf:Property ;
    rdfs:label 'Actual Material Cost' ;
    rdfs:comment 'Actual total cost of spare parts, materials, and consumables consumed during work order execution, based on goods issue transactions and purchase order receipts.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:completionNotes rdf:type rdf:Property ;
    rdfs:label 'Completion Notes' ;
    rdfs:comment 'Detailed notes recorded by the maintenance crew upon work completion, documenting work performed, parts replaced, test results, and any deviations from planned scope.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveAction rdf:type rdf:Property ;
    rdfs:label 'Corrective Action' ;
    rdfs:comment 'Description of the corrective action taken to address the root cause and prevent recurrence. Part of the Corrective and Preventive Action (CAPA) process.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downtimeDurationHours rdf:type rdf:Property ;
    rdfs:label 'Downtime Duration Hours' ;
    rdfs:comment 'Actual duration in hours that the equipment or process unit was offline due to this maintenance work. Used for Overall Equipment Effectiveness (OEE) calculation and production loss analysis.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:downtimeRequired rdf:type rdf:Property ;
    rdfs:label 'Downtime Required' ;
    rdfs:comment 'Indicates whether this maintenance work requires taking the equipment or process unit offline. True for intrusive maintenance; false for online maintenance activities.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedDurationHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Duration Hours' ;
    rdfs:comment 'Planned total duration of the maintenance work in hours, used for scheduling and resource allocation. Includes all craft labor time across all operations.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedLaborCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Labor Cost' ;
    rdfs:comment 'Planned total cost of internal labor based on estimated hours and standard labor rates by craft. Used for maintenance budget planning.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedLaborHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Labor Hours' ;
    rdfs:comment 'Planned total labor hours across all crafts and operations for this work order. Used for workforce planning and cost estimation.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedMaterialCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Material Cost' ;
    rdfs:comment 'Planned total cost of spare parts, materials, and consumables required for this work order. Used for budget planning and work order approval.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:externalServiceCost rdf:type rdf:Property ;
    rdfs:label 'External Service Cost' ;
    rdfs:comment 'Total cost of external contractor services, third-party vendors, or specialized service providers engaged for this work order. Includes service labor, equipment rental, and contractor-supplied materials.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:failureMode rdf:type rdf:Property ;
    rdfs:label 'Failure Mode' ;
    rdfs:comment 'Description of the equipment failure mode or degradation mechanism that necessitated this corrective maintenance work. Used for reliability analysis and Root Cause Investigation (RCI).' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lockoutTagoutRequired rdf:type rdf:Property ;
    rdfs:label 'Lockout Tagout Required' ;
    rdfs:comment 'Indicates whether lockout/tagout procedures are required for this work order to control hazardous energy sources. True for work on equipment with electrical, mechanical, hydraulic, or chemical energy hazards.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:longText rdf:type rdf:Property ;
    rdfs:label 'Long Text' ;
    rdfs:comment 'Detailed instructions, technical notes, safety precautions, and procedural guidance for executing the maintenance work. May include references to Standard Operating Procedures (SOP), Process and Instrumentation Diagrams (P&ID), or special tools required.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mocReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Moc Reference Number' ;
    rdfs:comment 'Reference number of the Management of Change (MOC) authorization if this work order involves modifications to process equipment, instrumentation, or control systems that require formal change management per PSM requirements.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedBy rdf:type rdf:Property ;
    rdfs:label 'Modified By' ;
    rdfs:comment 'User ID or name of the person who last modified this work order record. Used for audit trail and change tracking.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitToWorkNumber rdf:type rdf:Property ;
    rdfs:label 'Permit To Work Number' ;
    rdfs:comment 'Reference number of the safety permit authorizing this maintenance work, required for work in hazardous areas, confined spaces, hot work, or energized equipment per Process Safety Management (PSM) requirements.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCause rdf:type rdf:Property ;
    rdfs:label 'Root Cause' ;
    rdfs:comment 'Identified root cause of the equipment failure or maintenance need, determined through Root Cause Investigation (RCI). Used to drive Corrective and Preventive Action (CAPA) programs.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledEndDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Date' ;
    rdfs:comment 'Planned date when maintenance work is scheduled to be completed. Used for outage planning and production restart coordination.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledStartDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Date' ;
    rdfs:comment 'Planned date when maintenance work is scheduled to begin. Used for capacity planning and coordination with production schedules.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalCost rdf:type rdf:Property ;
    rdfs:label 'Total Cost' ;
    rdfs:comment 'Total actual cost of the work order including internal labor, materials, and external services. Used for maintenance cost reporting and asset lifecycle cost analysis.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workOrderDescription rdf:type rdf:Property ;
    rdfs:label 'Work Order Description' ;
    rdfs:comment 'Short text description of the maintenance work to be performed, summarizing the scope and nature of the activity for quick identification and communication.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Work Order Number' ;
    rdfs:comment 'Externally visible business identifier for the work order, typically system-generated and used for tracking and communication across maintenance teams and external service providers.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workOrderStatus rdf:type rdf:Property ;
    rdfs:label 'Work Order Status' ;
    rdfs:comment 'Current lifecycle status of the work order tracking progression from creation through execution to closure. Released status indicates work is approved and ready for execution; completed indicates work is finished but administrative closure pending. [ENUM-REF-CANDIDATE: created|released|in_progress|on_hold|completed|closed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workOrderType rdf:type rdf:Property ;
    rdfs:label 'Work Order Type' ;
    rdfs:comment 'Classification of the maintenance work order indicating the nature of the maintenance activity: planned maintenance, corrective repair, preventive maintenance schedule, predictive maintenance based on condition monitoring, emergency breakdown response, or capital project work.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workOrderOperationId rdf:type rdf:Property ;
    rdfs:label 'Work Order Operation Id' ;
    rdfs:comment 'Unique identifier for the work order operation. Primary key for this entity.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrderOperation .

ind:taskListId rdf:type rdf:Property ;
    rdfs:label 'Task List Id' ;
    rdfs:comment 'Foreign key linking to maintenance.task_list. Business justification: Work order operations in SAP PM are frequently generated from task list operations (standard_text_key and operation_number attributes on work_order_operation reflect this). Adding task_list_id to work' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TaskList .

ind:workCenterId rdf:type rdf:Property ;
    rdfs:label 'Work Center Id' ;
    rdfs:comment 'Reference to the work center (maintenance crew, shop, or organizational unit) responsible for executing this operation.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkCenter .

ind:activityType rdf:type rdf:Property ;
    rdfs:label 'Activity Type' ;
    rdfs:comment 'Classification of the maintenance activity being performed (e.g., mechanical repair, electrical work, instrumentation calibration, inspection). Used for cost allocation and capacity planning.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualFinishTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Finish Timestamp' ;
    rdfs:comment 'Date and time when work on the operation was completed, as recorded in the final time confirmation.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualWorkDuration rdf:type rdf:Property ;
    rdfs:label 'Actual Work Duration' ;
    rdfs:comment 'Actual labor hours spent on the operation as recorded through time confirmations. Used for performance analysis and variance reporting.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualWorkUnit rdf:type rdf:Property ;
    rdfs:label 'Actual Work Unit' ;
    rdfs:comment 'Unit of measure for actual work duration. H=hours, MIN=minutes, D=days.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculationKey rdf:type rdf:Property ;
    rdfs:label 'Calculation Key' ;
    rdfs:comment 'Key that determines how operation duration is calculated based on work quantity and standard values. Used for automatic time calculation in preventive maintenance.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Confirmation Required Flag' ;
    rdfs:comment 'Indicates whether time confirmation is required for this operation. True if the operation must be confirmed with actual hours and completion status.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:controlKey rdf:type rdf:Property ;
    rdfs:label 'Control Key' ;
    rdfs:comment 'Control key that determines the operation type and scheduling parameters (e.g., PM01 for internal processing, PM02 for external service, PM03 for inspection). Defines whether the operation requires confirmation, external processing, or automatic goods issue.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:earliestFinishDate rdf:type rdf:Property ;
    rdfs:label 'Earliest Finish Date' ;
    rdfs:comment 'Earliest date the operation can be completed based on earliest start date and planned duration.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:earliestStartDate rdf:type rdf:Property ;
    rdfs:label 'Earliest Start Date' ;
    rdfs:comment 'Earliest date the operation can begin based on scheduling constraints, predecessor operations, and resource availability.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:externalOperationFlag rdf:type rdf:Property ;
    rdfs:label 'External Operation Flag' ;
    rdfs:comment 'Indicates whether this operation is performed by an external service provider rather than internal maintenance staff. True for subcontracted work.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:finalConfirmationFlag rdf:type rdf:Property ;
    rdfs:label 'Final Confirmation Flag' ;
    rdfs:comment 'Indicates whether the operation has received its final confirmation and no further time bookings are expected. True when operation is complete.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:latestFinishDate rdf:type rdf:Property ;
    rdfs:label 'Latest Finish Date' ;
    rdfs:comment 'Latest date the operation must be completed to meet the work order required end date.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:latestStartDate rdf:type rdf:Property ;
    rdfs:label 'Latest Start Date' ;
    rdfs:comment 'Latest date the operation must start to meet the work order required end date without delaying subsequent operations.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:numberOfCapacities rdf:type rdf:Property ;
    rdfs:label 'Number Of Capacities' ;
    rdfs:comment 'Number of people or capacity units required to perform the operation simultaneously. Used for resource leveling and scheduling.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operationLongText rdf:type rdf:Property ;
    rdfs:label 'Operation Long Text' ;
    rdfs:comment 'Detailed description of the operation including step-by-step instructions, safety precautions, and technical specifications required to complete the task.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationNumber rdf:type rdf:Property ;
    rdfs:label 'Operation Number' ;
    rdfs:comment 'Sequential operation number within the work order, typically a 4-digit numeric code (e.g., 0010, 0020, 0030) that defines the execution sequence.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationShortText rdf:type rdf:Property ;
    rdfs:label 'Operation Short Text' ;
    rdfs:comment 'Brief description of the operation task, summarizing the work to be performed (e.g., \'Replace pump seal\', \'Calibrate pressure transmitter\').' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedWorkDuration rdf:type rdf:Property ;
    rdfs:label 'Planned Work Duration' ;
    rdfs:comment 'Planned labor hours required to complete the operation, excluding setup time. Used for capacity planning and scheduling.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedWorkUnit rdf:type rdf:Property ;
    rdfs:label 'Planned Work Unit' ;
    rdfs:comment 'Unit of measure for planned work duration. H=hours, MIN=minutes, D=days.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityCode rdf:type rdf:Property ;
    rdfs:label 'Priority Code' ;
    rdfs:comment 'Urgency level for the operation. 1=Very High (immediate), 2=High (same day), 3=Medium (this week), 4=Low (this month), 5=Very Low (planned). Inherited from work order but can be overridden at operation level.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:setupTime rdf:type rdf:Property ;
    rdfs:label 'Setup Time' ;
    rdfs:comment 'Time required to prepare tools, equipment, and work area before the actual maintenance work can begin. Measured in the same unit as work duration.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardTextKey rdf:type rdf:Property ;
    rdfs:label 'Standard Text Key' ;
    rdfs:comment 'Reference to standard text templates containing predefined operation instructions, safety procedures, or technical specifications that apply to this operation.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:systemStatus rdf:type rdf:Property ;
    rdfs:label 'System Status' ;
    rdfs:comment 'Current system-controlled status of the operation in its lifecycle. System status is automatically set by SAP PM based on business transactions and controls which actions are allowed.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teardownTime rdf:type rdf:Property ;
    rdfs:label 'Teardown Time' ;
    rdfs:comment 'Time required to clean up, restore the work area, and return tools after operation completion. Measured in the same unit as work duration.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:userStatus rdf:type rdf:Property ;
    rdfs:label 'User Status' ;
    rdfs:comment 'User-defined status that provides additional business-specific status information beyond system status. Configurable per business requirements.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workQuantity rdf:type rdf:Property ;
    rdfs:label 'Work Quantity' ;
    rdfs:comment 'Quantity of work to be performed, expressed in operation-specific units (e.g., number of valves to inspect, meters of pipe to replace, number of calibrations).' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workQuantityUnit rdf:type rdf:Property ;
    rdfs:label 'Work Quantity Unit' ;
    rdfs:comment 'Unit of measure for work quantity (e.g., EA=each, M=meter, KG=kilogram). ISO unit codes.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breakdownDurationHours rdf:type rdf:Property ;
    rdfs:label 'Breakdown Duration Hours' ;
    rdfs:comment 'Total duration of the breakdown or malfunction in hours, calculated from breakdown start to end timestamps. Key metric for Overall Equipment Effectiveness (OEE) and reliability reporting.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:breakdownEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Breakdown End Timestamp' ;
    rdfs:comment 'Date and time when the equipment was restored to operational status. Used to calculate Mean Time To Repair (MTTR) and total downtime.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:breakdownIndicator rdf:type rdf:Property ;
    rdfs:label 'Breakdown Indicator' ;
    rdfs:comment 'Flag indicating whether this notification represents a complete equipment breakdown (true) or a partial malfunction/defect (false). Critical for MTBF and reliability analysis.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:breakdownStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Breakdown Start Timestamp' ;
    rdfs:comment 'Date and time when the equipment breakdown or malfunction began. Used to calculate downtime duration and Mean Time Between Failures (MTBF).' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:capaNumber rdf:type rdf:Property ;
    rdfs:label 'Capa Number' ;
    rdfs:comment 'Cross-reference to the CAPA workflow document if a formal corrective action plan was created.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaRequiredIndicator rdf:type rdf:Property ;
    rdfs:label 'Capa Required Indicator' ;
    rdfs:comment 'Flag indicating whether the notification requires a formal Corrective and Preventive Action (CAPA) workflow to prevent recurrence.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:completionDate rdf:type rdf:Property ;
    rdfs:label 'Completion Date' ;
    rdfs:comment 'Date when the notification was closed and the issue was resolved. Used for cycle time analysis and notification aging reports.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:completionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Completion Timestamp' ;
    rdfs:comment 'Precise date and time when the notification was completed. Supports time-to-resolve KPI calculation.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ehsIncidentNumber rdf:type rdf:Property ;
    rdfs:label 'Ehs Incident Number' ;
    rdfs:comment 'Cross-reference to an EHS incident report if the notification is related to a safety event, environmental release, or occupational health issue.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:longDescription rdf:type rdf:Property ;
    rdfs:label 'Long Description' ;
    rdfs:comment 'Detailed narrative description of the defect, malfunction, or activity request, including symptoms, observations, and any immediate actions taken by the reporter.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:malfunctionStartDate rdf:type rdf:Property ;
    rdfs:label 'Malfunction Start Date' ;
    rdfs:comment 'Date when the defect or malfunction was first observed, which may differ from the reported date if discovered retrospectively.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:malfunctionStartTime rdf:type rdf:Property ;
    rdfs:label 'Malfunction Start Time' ;
    rdfs:comment 'Time of day when the malfunction started, in HH:MM format. Used in conjunction with malfunction_start_date for precise event timing.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:mocNumber rdf:type rdf:Property ;
    rdfs:label 'Moc Number' ;
    rdfs:comment 'Cross-reference to the MOC workflow document if a formal change review was triggered by this notification.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mocRequiredIndicator rdf:type rdf:Property ;
    rdfs:label 'Moc Required Indicator' ;
    rdfs:comment 'Flag indicating whether the corrective action requires a formal Management of Change (MOC) review due to process equipment modification or operating parameter change. Critical for PSM compliance.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationNumber rdf:type rdf:Property ;
    rdfs:label 'Notification Number' ;
    rdfs:comment 'Externally visible business identifier for the maintenance notification, typically a 10-12 digit system-generated number used for tracking and communication.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationStatus rdf:type rdf:Property ;
    rdfs:label 'Notification Status' ;
    rdfs:comment 'Current lifecycle status of the notification: outstanding (newly created), in_progress (under investigation or work order created), completed (resolved), cancelled (no action required).' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationType rdf:type rdf:Property ;
    rdfs:label 'Notification Type' ;
    rdfs:comment 'Classification of the notification: M1 (Malfunction/Breakdown), M2 (Activity Request), M3 (Inspection Finding), M4 (Other). Determines workflow and priority handling.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionImpactIndicator rdf:type rdf:Property ;
    rdfs:label 'Production Impact Indicator' ;
    rdfs:comment 'Flag indicating whether the malfunction or breakdown caused a production stoppage or throughput reduction (true) or had no production impact (false).' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productionLossQuantity rdf:type rdf:Property ;
    rdfs:label 'Production Loss Quantity' ;
    rdfs:comment 'Estimated quantity of product not produced due to the equipment breakdown, measured in the primary unit of measure for the affected production line (e.g., metric tons, liters, kilograms).' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productionLossUom rdf:type rdf:Property ;
    rdfs:label 'Production Loss Uom' ;
    rdfs:comment 'Unit of measure for the production loss quantity: MT (metric tons), KG (kilograms), L (liters), GAL (gallons), LB (pounds).' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rciNumber rdf:type rdf:Property ;
    rdfs:label 'Rci Number' ;
    rdfs:comment 'Cross-reference to the RCI or RCA investigation document if a formal root cause analysis was initiated.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rciRequiredIndicator rdf:type rdf:Property ;
    rdfs:label 'Rci Required Indicator' ;
    rdfs:comment 'Flag indicating whether the failure severity or recurrence pattern requires a formal Root Cause Investigation (RCI) or Root Cause Analysis (RCA).' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportedDate rdf:type rdf:Property ;
    rdfs:label 'Reported Date' ;
    rdfs:comment 'Date when the notification was created in the system. Used for response time analysis and notification aging reports.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reported Timestamp' ;
    rdfs:comment 'Precise date and time when the notification was created. Supports time-to-respond KPI calculation and audit trail.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requiredEndDate rdf:type rdf:Property ;
    rdfs:label 'Required End Date' ;
    rdfs:comment 'Target date by which the issue must be resolved to avoid production impact or regulatory non-compliance.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requiredStartDate rdf:type rdf:Property ;
    rdfs:label 'Required Start Date' ;
    rdfs:comment 'Target date by which corrective action or work order execution should begin, based on priority and production schedule impact.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:safetyIndicator rdf:type rdf:Property ;
    rdfs:label 'Safety Indicator' ;
    rdfs:comment 'Flag indicating whether the notification involves a safety hazard, near-miss, or condition that could lead to injury or environmental release. Triggers Process Safety Management (PSM) review.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shortDescription rdf:type rdf:Property ;
    rdfs:label 'Short Description' ;
    rdfs:comment 'Brief summary of the notification issue, typically 40-80 characters, used for list views and quick identification.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workOrderCreatedDate rdf:type rdf:Property ;
    rdfs:label 'Work Order Created Date' ;
    rdfs:comment 'Date when the work order was created in response to this notification. Used to calculate notification-to-work-order response time.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:autoGenerateWorkOrderFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Generate Work Order Flag' ;
    rdfs:comment 'Indicates whether the system automatically generates work orders when maintenance calls are created, or whether manual planner review and approval is required before work order creation.' ;
    rdfs:domain ind:PmPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:callHorizonDays rdf:type rdf:Property ;
    rdfs:label 'Call Horizon Days' ;
    rdfs:comment 'Number of days in advance that the system generates maintenance call objects (schedule lines) before the planned date. Enables proactive work order creation and resource planning.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:counterReadingAtLastMaintenance rdf:type rdf:Property ;
    rdfs:label 'Counter Reading At Last Maintenance' ;
    rdfs:comment 'Performance counter value (operating hours, production cycles, runtime hours) recorded at the time of last maintenance completion. Used for counter-based scheduling.' ;
    rdfs:domain ind:PmPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:counterThresholdForNextMaintenance rdf:type rdf:Property ;
    rdfs:label 'Counter Threshold For Next Maintenance' ;
    rdfs:comment 'Performance counter value that triggers the next maintenance call for counter-based plans (e.g., next PM at 10,000 operating hours).' ;
    rdfs:domain ind:PmPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cycleLength rdf:type rdf:Property ;
    rdfs:label 'Cycle Length' ;
    rdfs:comment 'Numeric value defining the interval between maintenance activities in the specified cycle_unit (e.g., 90 days, 500 operating hours, 1000 production cycles).' ;
    rdfs:domain ind:PmPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cycleUnit rdf:type rdf:Property ;
    rdfs:label 'Cycle Unit' ;
    rdfs:comment 'Unit of measure for the maintenance cycle interval: day, week, month, year (time-based), operating_hour, runtime_hour (performance-based), production_cycle, batch_count (counter-based). [ENUM-REF-CANDIDATE: day|week|month|year|operating_hour|production_cycle|batch_count|runtime_hour — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PmPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionCode rdf:type rdf:Property ;
    rdfs:label 'Inspection Code' ;
    rdfs:comment 'Code identifying the regulatory inspection requirement driving this PM plan (API 510 pressure vessel inspection, API 570 piping inspection, API 653 tank inspection, ASME boiler inspection, PSM mechanical integrity inspection). Links to compliance frameworks.' ;
    rdfs:domain ind:PmPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Insurance Requirement Flag' ;
    rdfs:comment 'Indicates whether this PM plan is mandated by insurance carrier requirements for boilers, pressure vessels, or other insured equipment. Compliance affects insurance coverage.' ;
    rdfs:domain ind:PmPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Last Maintenance Date' ;
    rdfs:comment 'Date when the last preventive maintenance activity was completed under this plan. Used to calculate the next scheduled maintenance date based on cycle length.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mocRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Moc Required Flag' ;
    rdfs:comment 'Indicates whether changes to this PM plan require formal MOC approval per PSM regulations. True for safety-critical equipment and process safety-related maintenance.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextScheduledDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Date' ;
    rdfs:comment 'Calculated date for the next preventive maintenance activity based on cycle length, last maintenance date, and scheduling parameters. Drives work order generation.' ;
    rdfs:domain ind:PmPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planNumber rdf:type rdf:Property ;
    rdfs:label 'Plan Number' ;
    rdfs:comment 'Business identifier for the PM plan, externally visible and used in work order generation and scheduling communications.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planStatus rdf:type rdf:Property ;
    rdfs:label 'Plan Status' ;
    rdfs:comment 'Current lifecycle status of the PM plan: active (generating calls), inactive (not generating calls), suspended (temporarily paused), completed (end date reached), cancelled (permanently terminated).' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planType rdf:type rdf:Property ;
    rdfs:label 'Plan Type' ;
    rdfs:comment 'Classification of the PM plan structure: single_cycle (one maintenance cycle), strategy_plan (multiple cycles with different intervals), multiple_counter (based on operating hours or production volume), time_based (calendar-driven), performance_based (triggered by performance degradation), condition_based (triggered by sensor readings or inspection results).' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pmPlanDescription rdf:type rdf:Property ;
    rdfs:label 'Pm Plan Description' ;
    rdfs:comment 'Detailed textual description of the PM plan purpose, scope, and maintenance objectives. Includes equipment context, maintenance rationale, and special instructions.' ;
    rdfs:domain ind:PmPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schedulingIndicator rdf:type rdf:Property ;
    rdfs:label 'Scheduling Indicator' ;
    rdfs:comment 'Defines how the PM plan generates maintenance calls: time_based (calendar intervals), performance_based (operating hours, cycles, production volume), condition_based (sensor thresholds, inspection findings), fixed_date (specific calendar dates), annual (yearly recurrence), seasonal (tied to production seasons or weather).' ;
    rdfs:domain ind:PmPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schedulingToleranceAfterDays rdf:type rdf:Property ;
    rdfs:label 'Scheduling Tolerance After Days' ;
    rdfs:comment 'Number of days after the planned date that maintenance can be performed without resetting the cycle counter. Provides flexibility for delayed execution.' ;
    rdfs:domain ind:PmPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:schedulingToleranceBeforeDays rdf:type rdf:Property ;
    rdfs:label 'Scheduling Tolerance Before Days' ;
    rdfs:comment 'Number of days before the planned date that maintenance can be performed without resetting the cycle counter. Provides flexibility for early execution.' ;
    rdfs:domain ind:PmPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seasonalAdjustmentFlag rdf:type rdf:Property ;
    rdfs:label 'Seasonal Adjustment Flag' ;
    rdfs:comment 'Indicates whether the PM plan schedule is adjusted for seasonal production patterns (e.g., agricultural chemical production peaks, winter shutdown periods, summer turnaround windows).' ;
    rdfs:domain ind:PmPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seasonalAdjustmentMonths rdf:type rdf:Property ;
    rdfs:label 'Seasonal Adjustment Months' ;
    rdfs:comment 'Comma-separated list of month numbers (1-12) when seasonal adjustments apply to the PM schedule. Used in conjunction with seasonal_adjustment_flag.' ;
    rdfs:domain ind:PmPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdBy rdf:type rdf:Property ;
    rdfs:label 'Created By' ;
    rdfs:comment 'User ID of the maintenance planner or engineer who created the PM plan master record.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleCallId rdf:type rdf:Property ;
    rdfs:label 'Schedule Call Id' ;
    rdfs:comment 'Primary key for schedule_call' ;
    rdfs:domain ind:ScheduleCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Date' ;
    rdfs:comment 'The actual date when the maintenance work was completed. Null if not yet completed.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:callGenerationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Call Generation Timestamp' ;
    rdfs:comment 'Timestamp when this schedule call item was automatically generated by the maintenance planning system.' ;
    rdfs:domain ind:ScheduleCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:callNumber rdf:type rdf:Property ;
    rdfs:label 'Call Number' ;
    rdfs:comment 'Business identifier for the scheduled maintenance call, typically a sequential number within the maintenance plan.' ;
    rdfs:domain ind:ScheduleCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callObjectType rdf:type rdf:Property ;
    rdfs:label 'Call Object Type' ;
    rdfs:comment 'Type of technical object that this maintenance call is scheduled for.' ;
    rdfs:domain ind:ScheduleCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callStatus rdf:type rdf:Property ;
    rdfs:label 'Call Status' ;
    rdfs:comment 'Current lifecycle status of the scheduled maintenance call item.' ;
    rdfs:domain ind:ScheduleCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceRequirement rdf:type rdf:Property ;
    rdfs:label 'Compliance Requirement' ;
    rdfs:comment 'Regulatory or internal compliance requirement that mandates this maintenance activity (PSM, EPA, OSHA, ISO certification, etc.).' ;
    rdfs:domain ind:ScheduleCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterReadingAtCall rdf:type rdf:Property ;
    rdfs:label 'Counter Reading At Call' ;
    rdfs:comment 'The equipment counter reading (operating hours, cycles, production volume) at the time this maintenance call was generated, for performance-based maintenance scheduling.' ;
    rdfs:domain ind:ScheduleCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:counterUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Counter Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the counter reading (hours, cycles, kilometers, batches, etc.).' ;
    rdfs:domain ind:ScheduleCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleNumber rdf:type rdf:Property ;
    rdfs:label 'Cycle Number' ;
    rdfs:comment 'Sequential cycle number within the maintenance plan, indicating which iteration of the recurring maintenance this call represents.' ;
    rdfs:domain ind:ScheduleCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daysOverdue rdf:type rdf:Property ;
    rdfs:label 'Days Overdue' ;
    rdfs:comment 'Number of days this maintenance call is overdue beyond the tolerance window. Null or zero if not overdue.' ;
    rdfs:domain ind:ScheduleCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isOverdue rdf:type rdf:Property ;
    rdfs:label 'Is Overdue' ;
    rdfs:comment 'Boolean flag indicating whether this scheduled maintenance call is past its due date and tolerance window.' ;
    rdfs:domain ind:ScheduleCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maintenanceActivityType rdf:type rdf:Property ;
    rdfs:label 'Maintenance Activity Type' ;
    rdfs:comment 'Classification of the maintenance activity to be performed (inspection, lubrication, calibration, overhaul, cleaning, etc.).' ;
    rdfs:domain ind:ScheduleCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Planned Completion Date' ;
    rdfs:comment 'The planned date by which the maintenance work should be completed.' ;
    rdfs:domain ind:ScheduleCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedStartDate rdf:type rdf:Property ;
    rdfs:label 'Planned Start Date' ;
    rdfs:comment 'The planned start date for executing the maintenance work, may differ from scheduled date due to planning adjustments.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:psmCriticalFlag rdf:type rdf:Property ;
    rdfs:label 'Psm Critical Flag' ;
    rdfs:comment 'Boolean flag indicating whether this maintenance call is for PSM-critical equipment requiring mechanical integrity compliance per OSHA PSM regulations.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Date' ;
    rdfs:comment 'The date when this preventive maintenance call is scheduled to be performed, calculated from the maintenance plan cycle.' ;
    rdfs:domain ind:ScheduleCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shutdownRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Shutdown Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether equipment or process shutdown is required to perform this maintenance activity.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:toleranceDaysEarly rdf:type rdf:Property ;
    rdfs:label 'Tolerance Days Early' ;
    rdfs:comment 'Number of days before the scheduled date that the maintenance can be performed and still be considered on-time.' ;
    rdfs:domain ind:ScheduleCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:toleranceDaysLate rdf:type rdf:Property ;
    rdfs:label 'Tolerance Days Late' ;
    rdfs:comment 'Number of days after the scheduled date that the maintenance can be performed before being considered overdue.' ;
    rdfs:domain ind:ScheduleCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:measurementPointId rdf:type rdf:Property ;
    rdfs:label 'Measurement Point Id' ;
    rdfs:comment 'Unique identifier for the measurement point record. Primary key.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MeasurementPoint .

ind:emissionSourceId rdf:type rdf:Property ;
    rdfs:label 'Emission Source Id' ;
    rdfs:comment 'Foreign key linking to ehs.emission_source. Business justification: Continuous emission monitoring systems (CEMS) and stack monitors are measurement points that directly correspond to permitted emission sources. Linking measurement_point to emission_source enables aut' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EmissionSource .

ind:activationDate rdf:type rdf:Property ;
    rdfs:label 'Activation Date' ;
    rdfs:comment 'Date when the measurement point was activated and monitoring began. Used for historical analysis and compliance documentation.' ;
    rdfs:domain ind:MeasurementPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:calibrationFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Calibration Frequency Days' ;
    rdfs:comment 'Planned interval in days between calibration activities for this measurement point. Supports compliance with ISO 9001 and GMP requirements.' ;
    rdfs:domain ind:MeasurementPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calibrationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Calibration Required Flag' ;
    rdfs:comment 'Indicates whether this measurement point requires periodic calibration to maintain accuracy and compliance with quality and safety standards.' ;
    rdfs:domain ind:MeasurementPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:characteristicCode rdf:type rdf:Property ;
    rdfs:label 'Characteristic Code' ;
    rdfs:comment 'Code identifying the physical characteristic being measured (e.g., vibration, temperature, pressure, flow rate, pH, operating hours). Aligns with plant instrumentation standards.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:characteristicDescription rdf:type rdf:Property ;
    rdfs:label 'Characteristic Description' ;
    rdfs:comment 'Human-readable description of the characteristic being measured at this point.' ;
    rdfs:domain ind:MeasurementPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterOverflowValue rdf:type rdf:Property ;
    rdfs:label 'Counter Overflow Value' ;
    rdfs:comment 'Maximum value at which a counter-type measurement point resets to zero. Used for cumulative counters such as operating hours or cycle counts.' ;
    rdfs:domain ind:MeasurementPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:criticalityCode rdf:type rdf:Property ;
    rdfs:label 'Criticality Code' ;
    rdfs:comment 'Classification of the measurement points importance to safety, environmental compliance, product quality, or equipment reliability. Drives prioritization of monitoring and maintenance activities.' ;
    rdfs:domain ind:MeasurementPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSource rdf:type rdf:Property ;
    rdfs:label 'Data Source' ;
    rdfs:comment 'System or method by which measurement readings are captured: manual entry, Distributed Control System (DCS), Supervisory Control and Data Acquisition (SCADA), Laboratory Information Management System (LIMS), or process historian.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decimalPlaces rdf:type rdf:Property ;
    rdfs:label 'Decimal Places' ;
    rdfs:comment 'Number of decimal places to which measurement values should be recorded and displayed, ensuring precision consistency.' ;
    rdfs:domain ind:MeasurementPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:historianTag rdf:type rdf:Property ;
    rdfs:label 'Historian Tag' ;
    rdfs:comment 'Tag identifier in the process historian system (e.g., Aveva PI System) that stores time-series data for this measurement point. Enables integration with real-time process data.' ;
    rdfs:domain ind:MeasurementPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastCalibrationDate rdf:type rdf:Property ;
    rdfs:label 'Last Calibration Date' ;
    rdfs:comment 'Date when the measurement point or associated instrument was last calibrated. Used to track calibration compliance and schedule next calibration.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastReadingDate rdf:type rdf:Property ;
    rdfs:label 'Last Reading Date' ;
    rdfs:comment 'Date when the most recent measurement reading was recorded for this point. Used to track compliance with reading schedules.' ;
    rdfs:domain ind:MeasurementPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastReadingValue rdf:type rdf:Property ;
    rdfs:label 'Last Reading Value' ;
    rdfs:comment 'The most recent measurement value recorded at this point. Provides current state for condition monitoring and trend analysis.' ;
    rdfs:domain ind:MeasurementPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lowerAlarmLimit rdf:type rdf:Property ;
    rdfs:label 'Lower Alarm Limit' ;
    rdfs:comment 'Lower critical threshold that triggers an alarm and may require immediate maintenance action or equipment shutdown per Process Safety Management (PSM) requirements.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lowerWarningLimit rdf:type rdf:Property ;
    rdfs:label 'Lower Warning Limit' ;
    rdfs:comment 'Lower threshold value that triggers a warning alert when measurement falls below this level. Part of condition-based maintenance strategy.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementPointStatus rdf:type rdf:Property ;
    rdfs:label 'Measurement Point Status' ;
    rdfs:comment 'Current lifecycle status of the measurement point. Active points are monitored per schedule; inactive or decommissioned points are no longer in use.' ;
    rdfs:domain ind:MeasurementPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementPosition rdf:type rdf:Property ;
    rdfs:label 'Measurement Position' ;
    rdfs:comment 'Specific physical location or position on the equipment where the measurement is taken (e.g., bearing housing north side, inlet flange, discharge line). References Piping and Instrumentation Diagram (P&ID) tag.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextCalibrationDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Calibration Due Date' ;
    rdfs:comment 'Scheduled date for the next calibration activity based on calibration frequency. Critical for maintaining measurement accuracy and regulatory compliance.' ;
    rdfs:domain ind:MeasurementPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextReadingDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Reading Due Date' ;
    rdfs:comment 'Scheduled date for the next measurement reading based on the reading frequency. Used for work order generation and compliance tracking.' ;
    rdfs:domain ind:MeasurementPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:oeeRelevantFlag rdf:type rdf:Property ;
    rdfs:label 'Oee Relevant Flag' ;
    rdfs:comment 'Indicates whether this measurement point contributes to Overall Equipment Effectiveness (OEE) calculations, such as operating hours, cycle counts, or production rates.' ;
    rdfs:domain ind:MeasurementPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pointCategory rdf:type rdf:Property ;
    rdfs:label 'Point Category' ;
    rdfs:comment 'Classification of the measurement point type: counter (cumulative readings such as operating hours) or measurement (instantaneous readings such as temperature or pressure).' ;
    rdfs:domain ind:MeasurementPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pointDescription rdf:type rdf:Property ;
    rdfs:label 'Point Description' ;
    rdfs:comment 'Detailed textual description of the measurement point, including its physical location on the equipment and what is being measured.' ;
    rdfs:domain ind:MeasurementPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pointNumber rdf:type rdf:Property ;
    rdfs:label 'Point Number' ;
    rdfs:comment 'Business identifier for the measurement point, typically alphanumeric code used in operations and maintenance documentation.' ;
    rdfs:domain ind:MeasurementPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readingFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Reading Frequency Days' ;
    rdfs:comment 'Planned interval in days between successive readings of this measurement point. Supports preventive and condition-based maintenance scheduling.' ;
    rdfs:domain ind:MeasurementPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sensorType rdf:type rdf:Property ;
    rdfs:label 'Sensor Type' ;
    rdfs:comment 'Type of sensor or instrument used to capture the measurement (e.g., thermocouple, pressure transmitter, vibration sensor, flow meter, pH probe).' ;
    rdfs:domain ind:MeasurementPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tagNumber rdf:type rdf:Property ;
    rdfs:label 'Tag Number' ;
    rdfs:comment 'Unique tag identifier from the Piping and Instrumentation Diagram (P&ID) for the instrument or sensor associated with this measurement point. Aligns with ISA standards.' ;
    rdfs:domain ind:MeasurementPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetValue rdf:type rdf:Property ;
    rdfs:label 'Target Value' ;
    rdfs:comment 'The ideal or expected value for this measurement point under normal operating conditions. Used for variance analysis and condition monitoring.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:upperAlarmLimit rdf:type rdf:Property ;
    rdfs:label 'Upper Alarm Limit' ;
    rdfs:comment 'Upper critical threshold that triggers an alarm and may require immediate maintenance action or equipment shutdown per Process Safety Management (PSM) requirements.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:upperWarningLimit rdf:type rdf:Property ;
    rdfs:label 'Upper Warning Limit' ;
    rdfs:comment 'Upper threshold value that triggers a warning alert when measurement exceeds this level. Part of condition-based maintenance strategy.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementReadingId rdf:type rdf:Property ;
    rdfs:label 'Measurement Reading Id' ;
    rdfs:comment 'Unique identifier for the measurement reading record. Primary key for the measurement reading entity.' ;
    rdfs:domain ind:MeasurementReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:annotation rdf:type rdf:Property ;
    rdfs:label 'Annotation' ;
    rdfs:comment 'Free-text notes or comments entered by the reader or reviewer regarding the measurement reading. Used to document unusual conditions, context, or corrective actions taken.' ;
    rdfs:domain ind:MeasurementReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationDueDate rdf:type rdf:Property ;
    rdfs:label 'Calibration Due Date' ;
    rdfs:comment 'The date when the measurement instrument or sensor is next due for calibration. Used to assess the reliability of the reading and trigger calibration work orders.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:counterOverflowFlag rdf:type rdf:Property ;
    rdfs:label 'Counter Overflow Flag' ;
    rdfs:comment 'Boolean indicator that is true when a counter reading has rolled over or reset. Used to maintain accurate cumulative totals across counter resets.' ;
    rdfs:domain ind:MeasurementReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:counterReadingFlag rdf:type rdf:Property ;
    rdfs:label 'Counter Reading Flag' ;
    rdfs:comment 'Boolean indicator that is true when this reading represents a cumulative counter value (such as operating hours, cycle count, production volume) rather than an instantaneous measurement.' ;
    rdfs:domain ind:MeasurementReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deviationFromTarget rdf:type rdf:Property ;
    rdfs:label 'Deviation From Target' ;
    rdfs:comment 'The calculated difference between the measured value and the target value. Positive values indicate readings above target, negative values indicate readings below target. Used for trend analysis and condition monitoring.' ;
    rdfs:domain ind:MeasurementReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deviationPercentage rdf:type rdf:Property ;
    rdfs:label 'Deviation Percentage' ;
    rdfs:comment 'The percentage deviation of the measured value from the target value. Calculated as (measured_value - target_value) / target_value * 100. Enables normalized comparison across different measurement points.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measuredValue rdf:type rdf:Property ;
    rdfs:label 'Measured Value' ;
    rdfs:comment 'The actual numeric value captured by the measurement reading. Represents the observed quantity such as temperature, pressure, flow rate, vibration, pH, or counter reading.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementCharacteristic rdf:type rdf:Property ;
    rdfs:label 'Measurement Characteristic' ;
    rdfs:comment 'The physical or operational characteristic being measured. Examples include temperature, pressure, vibration, flow rate, pH, conductivity, viscosity, level, speed, power consumption.' ;
    rdfs:domain ind:MeasurementReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Measurement Document Number' ;
    rdfs:comment 'External business identifier for the measurement document. Used for traceability and cross-system reference.' ;
    rdfs:domain ind:MeasurementReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityCode rdf:type rdf:Property ;
    rdfs:label 'Quality Code' ;
    rdfs:comment 'Data quality indicator for the measurement reading. Good indicates reliable data, bad indicates known error, uncertain indicates possible error, substituted indicates estimated value, questionable indicates requires review.' ;
    rdfs:domain ind:MeasurementReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readingDate rdf:type rdf:Property ;
    rdfs:label 'Reading Date' ;
    rdfs:comment 'Calendar date when the measurement reading was taken. Used for day-level aggregation and reporting.' ;
    rdfs:domain ind:MeasurementReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:readingStatus rdf:type rdf:Property ;
    rdfs:label 'Reading Status' ;
    rdfs:comment 'Current validation status of the measurement reading. Indicates whether the reading has been reviewed, approved, or flagged for quality issues.' ;
    rdfs:domain ind:MeasurementReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reading Timestamp' ;
    rdfs:comment 'Date and time when the measurement reading was actually captured in the field or by the sensor. Represents the real-world event time of the observation.' ;
    rdfs:domain ind:MeasurementReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:readingType rdf:type rdf:Property ;
    rdfs:label 'Reading Type' ;
    rdfs:comment 'Classification of how the reading was obtained. Actual indicates direct measurement, estimated indicates interpolated or approximated value, calculated indicates derived from other readings, manual indicates human-entered, automatic indicates sensor-captured.' ;
    rdfs:domain ind:MeasurementReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdViolationFlag rdf:type rdf:Property ;
    rdfs:label 'Threshold Violation Flag' ;
    rdfs:comment 'Boolean indicator that is true when the measured value falls outside the defined warning or alarm limits. Used to trigger maintenance notifications and condition-based maintenance workflows.' ;
    rdfs:domain ind:MeasurementReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:calibrationRecordId rdf:type rdf:Property ;
    rdfs:label 'Calibration Record Id' ;
    rdfs:comment 'Unique identifier for the calibration record. Primary key for the calibration record entity.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CalibrationRecord .

ind:calibrationProcedureId rdf:type rdf:Property ;
    rdfs:label 'Calibration Procedure Id' ;
    rdfs:comment 'Reference to the Standard Operating Procedure (SOP) or work instruction used for this calibration. Links to documented calibration method.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CalibrationProcedure .

ind:accuracySpecification rdf:type rdf:Property ;
    rdfs:label 'Accuracy Specification' ;
    rdfs:comment 'Manufacturer or regulatory accuracy requirement for the instrument (e.g., ±0.5%, ±2 degC). Used to determine tolerance limits.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentPerformedFlag rdf:type rdf:Property ;
    rdfs:label 'Adjustment Performed Flag' ;
    rdfs:comment 'Indicates whether the instrument required adjustment or recalibration to bring it within tolerance.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:asFoundValue rdf:type rdf:Property ;
    rdfs:label 'As Found Value' ;
    rdfs:comment 'Measured value of the instrument before calibration adjustment. Documents initial condition and drift since last calibration.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:asLeftValue rdf:type rdf:Property ;
    rdfs:label 'As Left Value' ;
    rdfs:comment 'Measured value of the instrument after calibration adjustment. Documents final calibrated state.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calibrationCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Calibration Certificate Number' ;
    rdfs:comment 'Unique certificate number issued for this calibration event. External business identifier for traceability and audit purposes.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationCost rdf:type rdf:Property ;
    rdfs:label 'Calibration Cost' ;
    rdfs:comment 'Total cost of calibration activity including labor, materials, and external service fees. Supports maintenance budget tracking.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calibrationDate rdf:type rdf:Property ;
    rdfs:label 'Calibration Date' ;
    rdfs:comment 'Date when the calibration was performed. Principal business event timestamp for this calibration record.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:calibrationIntervalDays rdf:type rdf:Property ;
    rdfs:label 'Calibration Interval Days' ;
    rdfs:comment 'Standard calibration frequency in days (e.g., 365 for annual, 180 for semi-annual). Determines next due date calculation.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calibrationPointsTested rdf:type rdf:Property ;
    rdfs:label 'Calibration Points Tested' ;
    rdfs:comment 'Number of measurement points tested during calibration (e.g., 5-point calibration across instrument range).' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calibrationStandardCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Calibration Standard Certificate Number' ;
    rdfs:comment 'Certificate number of the reference standard used, providing traceability to NIST or equivalent national metrology institute.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationStatus rdf:type rdf:Property ;
    rdfs:label 'Calibration Status' ;
    rdfs:comment 'Current lifecycle status of the calibration record: scheduled (planned but not started), in-progress (calibration underway), passed (within tolerance), failed (out of tolerance), conditional (marginal pass with restrictions), cancelled (calibration not performed), overdue (past due date). [ENUM-REF-CANDIDATE: scheduled|in-progress|passed|failed|conditional|cancelled|overdue — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationType rdf:type rdf:Property ;
    rdfs:label 'Calibration Type' ;
    rdfs:comment 'Classification of calibration method: in-house (performed by internal technicians), external (third-party calibration lab), vendor (OEM calibration service), field (on-site calibration), laboratory (off-site lab calibration).' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalHumidity rdf:type rdf:Property ;
    rdfs:label 'Environmental Humidity' ;
    rdfs:comment 'Relative humidity percentage during calibration. Environmental condition documentation required for measurement traceability.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalTemperature rdf:type rdf:Property ;
    rdfs:label 'Environmental Temperature' ;
    rdfs:comment 'Ambient temperature during calibration in degrees Celsius. Environmental condition documentation required for measurement traceability.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gmpRegulatedFlag rdf:type rdf:Property ;
    rdfs:label 'Gmp Regulated Flag' ;
    rdfs:comment 'Indicates whether this calibration is subject to Good Manufacturing Practice (GMP) requirements for pharmaceutical or food-contact chemical production.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:measurementUncertainty rdf:type rdf:Property ;
    rdfs:label 'Measurement Uncertainty' ;
    rdfs:comment 'Quantified uncertainty of the calibration measurement, expressed in the same unit as the measured value. Required for ISO 17025 compliance.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outOfToleranceFlag rdf:type rdf:Property ;
    rdfs:label 'Out Of Tolerance Flag' ;
    rdfs:comment 'Indicates whether the as-found condition was outside acceptable tolerance limits, triggering investigation and potential product impact assessment.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:passFailStatus rdf:type rdf:Property ;
    rdfs:label 'Pass Fail Status' ;
    rdfs:comment 'Calibration result: pass (within tolerance), fail (out of tolerance), conditional (marginal but acceptable with restrictions).' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:psmCriticalInstrumentFlag rdf:type rdf:Property ;
    rdfs:label 'Psm Critical Instrument Flag' ;
    rdfs:comment 'Indicates whether this instrument is designated as PSM-critical under OSHA 1910.119 mechanical integrity requirements, requiring enhanced calibration documentation and frequency.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remarks rdf:type rdf:Property ;
    rdfs:label 'Remarks' ;
    rdfs:comment 'Free-text notes documenting calibration observations, issues encountered, corrective actions taken, or special conditions. Supports root cause investigation and continuous improvement.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewDate rdf:type rdf:Property ;
    rdfs:label 'Review Date' ;
    rdfs:comment 'Date when the calibration record was reviewed and approved by quality assurance.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:technicianCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Technician Certification Number' ;
    rdfs:comment 'Certification or qualification number of the technician performing calibration, demonstrating competency for this calibration type.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toleranceLowerLimit rdf:type rdf:Property ;
    rdfs:label 'Tolerance Lower Limit' ;
    rdfs:comment 'Minimum acceptable value for calibration pass criteria. Defines lower bound of acceptable measurement range.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:toleranceUpperLimit rdf:type rdf:Property ;
    rdfs:label 'Tolerance Upper Limit' ;
    rdfs:comment 'Maximum acceptable value for calibration pass criteria. Defines upper bound of acceptable measurement range.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorLabAccreditation rdf:type rdf:Property ;
    rdfs:label 'Vendor Lab Accreditation' ;
    rdfs:comment 'Accreditation body and certificate number for external calibration laboratory (e.g., A2LA, ANAB, UKAS). Ensures vendor competency.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breakdownEventId rdf:type rdf:Property ;
    rdfs:label 'Breakdown Event Id' ;
    rdfs:comment 'Unique identifier for the breakdown event record. Primary key for the breakdown event entity.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BreakdownEvent .

ind:emissionEventId rdf:type rdf:Property ;
    rdfs:label 'Emission Event Id' ;
    rdfs:comment 'Foreign key linking to ehs.emission_event. Business justification: Equipment breakdowns in chemical manufacturing frequently cause unplanned emission events (e.g., seal failure causing fugitive release). Linking breakdown_event to emission_event supports environmenta' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EmissionEvent .

ind:pmNotificationId rdf:type rdf:Property ;
    rdfs:label 'Pm Notification Id' ;
    rdfs:comment 'Reference to the PM notification that reported this breakdown event. Links to the maintenance notification system.' ;
    rdfs:domain ind:BreakdownEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Notification .

ind:breakdownNumber rdf:type rdf:Property ;
    rdfs:label 'Breakdown Number' ;
    rdfs:comment 'Business identifier for the breakdown event, typically auto-generated or manually assigned for tracking and reporting purposes.' ;
    rdfs:domain ind:BreakdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breakdownStatus rdf:type rdf:Property ;
    rdfs:label 'Breakdown Status' ;
    rdfs:comment 'Current lifecycle status of the breakdown event indicating progression from detection through resolution.' ;
    rdfs:domain ind:BreakdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:damageCode rdf:type rdf:Property ;
    rdfs:label 'Damage Code' ;
    rdfs:comment 'Standardized code classifying the type of damage observed on the equipment, such as crack, deformation, erosion, or contamination.' ;
    rdfs:domain ind:BreakdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionMethod rdf:type rdf:Property ;
    rdfs:label 'Detection Method' ;
    rdfs:comment 'Method by which the breakdown event was first detected, such as operator observation, automated alarm, scheduled inspection, or predictive analytics.' ;
    rdfs:domain ind:BreakdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalReleaseFlag rdf:type rdf:Property ;
    rdfs:label 'Environmental Release Flag' ;
    rdfs:comment 'Indicator of whether the breakdown event resulted in an unplanned release of chemicals or hazardous materials to the environment.' ;
    rdfs:domain ind:BreakdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedRepairCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Repair Cost' ;
    rdfs:comment 'Estimated total cost to repair or restore the equipment following the breakdown event, including labor, materials, and contractor costs.' ;
    rdfs:domain ind:BreakdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:failureCauseCode rdf:type rdf:Property ;
    rdfs:label 'Failure Cause Code' ;
    rdfs:comment 'Standardized code identifying the root cause of the breakdown, such as wear, corrosion, operator error, design defect, or inadequate maintenance.' ;
    rdfs:domain ind:BreakdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureCauseDescription rdf:type rdf:Property ;
    rdfs:label 'Failure Cause Description' ;
    rdfs:comment 'Detailed narrative explanation of the root cause analysis findings for the breakdown event. Supports RCI (Root Cause Investigation) documentation.' ;
    rdfs:domain ind:BreakdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:malfunctionStartIndicator rdf:type rdf:Property ;
    rdfs:label 'Malfunction Start Indicator' ;
    rdfs:comment 'Flag indicating whether this breakdown event marks the initial onset of a malfunction or is a continuation of a previous issue.' ;
    rdfs:domain ind:BreakdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productionImpactSeverity rdf:type rdf:Property ;
    rdfs:label 'Production Impact Severity' ;
    rdfs:comment 'Categorical assessment of the severity of production impact caused by the breakdown, ranging from critical plant shutdown to minimal disruption.' ;
    rdfs:domain ind:BreakdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rciRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Rci Required Flag' ;
    rdfs:comment 'Indicator of whether the breakdown event severity or recurrence pattern requires a formal root cause investigation.' ;
    rdfs:domain ind:BreakdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responseTimeHours rdf:type rdf:Property ;
    rdfs:label 'Response Time Hours' ;
    rdfs:comment 'Elapsed time in hours from breakdown detection to initiation of corrective action. Key metric for maintenance responsiveness.' ;
    rdfs:domain ind:BreakdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:restorationMethod rdf:type rdf:Property ;
    rdfs:label 'Restoration Method' ;
    rdfs:comment 'Method used to restore equipment to operational status, such as on-site repair, component replacement, temporary fix, or operational workaround.' ;
    rdfs:domain ind:BreakdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyIncidentFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Incident Flag' ;
    rdfs:comment 'Indicator of whether the breakdown event resulted in or was associated with a safety incident requiring EHS reporting.' ;
    rdfs:domain ind:BreakdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:permitToWorkId rdf:type rdf:Property ;
    rdfs:label 'Permit To Work Id' ;
    rdfs:comment 'Unique identifier for the permit to work record. Primary key for the permit to work entity.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hazopStudyId rdf:type rdf:Property ;
    rdfs:label 'Hazop Study Id' ;
    rdfs:comment 'Foreign key linking to ehs.hazop_study. Business justification: High-hazard maintenance work (confined space entry, hot work near flammables) in PSM facilities must reference the governing HAZOP study to ensure identified hazard controls are applied during the job' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HazopStudy .

ind:closedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Closed Timestamp' ;
    rdfs:comment 'Date and time when the permit was formally closed after work completion and area inspection confirmed safe conditions restored.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:closureConfirmation rdf:type rdf:Property ;
    rdfs:label 'Closure Confirmation' ;
    rdfs:comment 'Documentation confirming that all work is complete, all tools and materials removed, all isolations restored, area cleaned, and safe conditions verified before permit closure.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confinedSpaceEntryFlag rdf:type rdf:Property ;
    rdfs:label 'Confined Space Entry Flag' ;
    rdfs:comment 'Indicates whether the work involves entry into a permit-required confined space as defined by OSHA 1910.146. Triggers additional safety requirements.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fireWatchRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Fire Watch Required Flag' ;
    rdfs:comment 'Indicates whether a dedicated fire watch person must be present during hot work operations to monitor for ignition and respond to fire emergencies.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gasTestRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Gas Test Required Flag' ;
    rdfs:comment 'Indicates whether atmospheric testing for oxygen, flammable gases, and toxic gases is required before and during the work.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gasTestResults rdf:type rdf:Property ;
    rdfs:label 'Gas Test Results' ;
    rdfs:comment 'Results of atmospheric testing including oxygen percentage, lower explosive limit (LEL) readings, and toxic gas concentrations. Recorded before work begins and at specified intervals.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardIdentification rdf:type rdf:Property ;
    rdfs:label 'Hazard Identification' ;
    rdfs:comment 'Comprehensive identification of all hazards present in the work area including chemical, physical, biological, and process hazards. Critical for risk assessment and control measures.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isolationRequirements rdf:type rdf:Property ;
    rdfs:label 'Isolation Requirements' ;
    rdfs:comment 'Specific isolation and lockout/tagout requirements for the work including electrical isolation, mechanical isolation, line blanking, and energy isolation procedures.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Issued Timestamp' ;
    rdfs:comment 'Date and time when the permit was officially issued and approved by the issuing authority.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lelPercent rdf:type rdf:Property ;
    rdfs:label 'Lel Percent' ;
    rdfs:comment 'Measured flammable gas concentration as percentage of lower explosive limit. Must be below threshold (typically <10% LEL) for hot work authorization.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oxygenLevelPercent rdf:type rdf:Property ;
    rdfs:label 'Oxygen Level Percent' ;
    rdfs:comment 'Measured oxygen concentration in the work area atmosphere expressed as percentage. Must be within safe range (typically 19.5% to 23.5%) for entry.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:permitNumber rdf:type rdf:Property ;
    rdfs:label 'Permit Number' ;
    rdfs:comment 'Externally-known unique permit number assigned to this work authorization. Used for tracking and reference in safety documentation.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitStatus rdf:type rdf:Property ;
    rdfs:label 'Permit Status' ;
    rdfs:comment 'Current lifecycle status of the permit to work. Tracks the permit from initial request through closure. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|active|suspended|closed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitType rdf:type rdf:Property ;
    rdfs:label 'Permit Type' ;
    rdfs:comment 'Classification of the permit based on the nature of hazardous work being authorized. Determines specific safety protocols and approval requirements.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ppeRequirements rdf:type rdf:Property ;
    rdfs:label 'Ppe Requirements' ;
    rdfs:comment 'Mandatory personal protective equipment required for the permitted work including respirators, protective clothing, gloves, eye protection, and fall protection.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rescuePlan rdf:type rdf:Property ;
    rdfs:label 'Rescue Plan' ;
    rdfs:comment 'Documented rescue and emergency response plan for confined space entry or other high-risk work. Includes rescue equipment, procedures, and emergency contacts.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialPrecautions rdf:type rdf:Property ;
    rdfs:label 'Special Precautions' ;
    rdfs:comment 'Additional safety precautions, restrictions, or conditions specific to this permit beyond standard requirements. May include weather restrictions, simultaneous operations restrictions, or special monitoring requirements.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toxicGasPpm rdf:type rdf:Property ;
    rdfs:label 'Toxic Gas Ppm' ;
    rdfs:comment 'Measured concentration of toxic gases in parts per million. Must be below permissible exposure limits for the specific chemicals present.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validFromTimestamp rdf:type rdf:Property ;
    rdfs:label 'Valid From Timestamp' ;
    rdfs:comment 'Date and time when the permit becomes effective and work is authorized to begin. Marks the start of the permits validity period.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:validUntilTimestamp rdf:type rdf:Property ;
    rdfs:label 'Valid Until Timestamp' ;
    rdfs:comment 'Date and time when the permit expires and work must cease. Permits typically have limited duration (e.g., 8 hours, 12 hours, or one shift) and must be renewed if work continues.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:workDescription rdf:type rdf:Property ;
    rdfs:label 'Work Description' ;
    rdfs:comment 'Detailed description of the maintenance or construction activity to be performed under this permit. Includes scope, methods, and expected outcomes.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingPartyId rdf:type rdf:Property ;
    rdfs:label 'Billing Party Id' ;
    rdfs:comment 'Foreign key linking to billing.party. Business justification: Vendor-party master data alignment: in chemical manufacturing ERP systems, vendors are registered as billing parties for intercompany transactions, rebate settlements, and credit memo processing. This' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillingParty .

ind:classification rdf:type rdf:Property ;
    rdfs:label 'Classification' ;
    rdfs:comment 'Primary business classification of the vendor indicating the type of goods or services they provide to the chemical manufacturing operation.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Contract Expiration Date' ;
    rdfs:comment 'Date when the current master supply agreement or contract with the vendor expires requiring renewal or renegotiation.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hazmatHandlingCapable rdf:type rdf:Property ;
    rdfs:label 'Hazmat Handling Capable' ;
    rdfs:comment 'Indicates whether the vendor has certified capabilities and infrastructure to handle, store, and transport hazardous chemical materials in compliance with DOT and OSHA regulations.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:headquartersAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Headquarters Address Line1' ;
    rdfs:comment 'First line of the vendors corporate headquarters street address including building number and street name.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Headquarters Address Line2' ;
    rdfs:comment 'Second line of the vendors corporate headquarters address for suite, floor, or additional location details.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersCity rdf:type rdf:Property ;
    rdfs:label 'Headquarters City' ;
    rdfs:comment 'City or municipality where the vendors corporate headquarters is located.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersCountryCode rdf:type rdf:Property ;
    rdfs:label 'Headquarters Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code indicating the country where the vendors corporate headquarters is domiciled.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersPostalCode rdf:type rdf:Property ;
    rdfs:label 'Headquarters Postal Code' ;
    rdfs:comment 'Postal or ZIP code for the vendors corporate headquarters address used for mail delivery and geographic classification.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersStateProvince rdf:type rdf:Property ;
    rdfs:label 'Headquarters State Province' ;
    rdfs:comment 'State, province, or administrative region where the vendors corporate headquarters is located.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incoterms rdf:type rdf:Property ;
    rdfs:label 'Incoterms' ;
    rdfs:comment 'Preferred Incoterms rule defining the division of costs, risks, and responsibilities between buyer and seller for international shipments. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iso14001Certified rdf:type rdf:Property ;
    rdfs:label 'Iso 14001 Certified' ;
    rdfs:comment 'Indicates whether the vendor holds ISO 14001 certification for environmental management systems demonstrating commitment to environmental stewardship.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minorityOwned rdf:type rdf:Property ;
    rdfs:label 'Minority Owned' ;
    rdfs:comment 'Indicates whether the vendor is certified as a minority-owned business enterprise for supplier diversity program tracking and reporting.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextAuditDueDate rdf:type rdf:Property ;
