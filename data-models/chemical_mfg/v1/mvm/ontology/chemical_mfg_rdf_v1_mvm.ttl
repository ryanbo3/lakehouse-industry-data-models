ind:cocRecordId rdf:type rdf:Property ;
    rdfs:label 'Coc Record Id' ;
    rdfs:comment 'Foreign key linking to quality.coc_record. Business justification: Chemical manufacturing customers require a Certificate of Conformance per invoice line item for regulatory compliance and product traceability. The \'CoC-to-invoice-line traceability\' process — mandate' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CocRecord .

ind:accountingDate rdf:type rdf:Property ;
    rdfs:label 'Accounting Date' ;
    rdfs:comment 'Fiscal date used for posting the line to the ledger.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exchangeRate rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate' ;
    rdfs:comment 'Rate used to convert the line amount to the corporate reporting currency.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:glAccount rdf:type rdf:Property ;
    rdfs:label 'Gl Account' ;
    rdfs:comment 'GL account number used for posting the line\'s financial impact.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
