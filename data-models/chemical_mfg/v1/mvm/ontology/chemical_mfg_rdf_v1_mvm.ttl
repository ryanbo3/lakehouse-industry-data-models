ind:orderConfirmationId rdf:type rdf:Property ;
    rdfs:label 'Order Confirmation Id' ;
    rdfs:comment 'Foreign key linking to product.order_confirmation. Business justification: Invoices in chemical manufacturing are generated after order confirmation is issued. Linking invoice to order_confirmation enables billing teams to verify confirmed quantities, agreed prices, and deli' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrderConfirmation .

ind:dueDate rdf:type rdf:Property ;
    rdfs:label 'Due Date' ;
    rdfs:comment 'Date by which payment is expected according to payment terms.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:externalReferenceNumber rdf:type rdf:Property ;
