    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lotLastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Lot Last Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent update to the lot record.' ;
    rdfs:domain ind:LotRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lotOwnerDepartment rdf:type rdf:Property ;
    rdfs:label 'Lot Owner Department' ;
    rdfs:comment 'Internal department responsible for the lot.' ;
    rdfs:domain ind:LotRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Lot Source System' ;
    rdfs:comment 'Name of the source system that supplied the lot record (e.g., SAP S/4HANA, ERP).' ;
