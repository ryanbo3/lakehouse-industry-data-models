    rdfs:comment 'Result of the effectiveness review after CAPA closure.' ;
    rdfs:domain ind:CapaRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivenessReviewDate rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Review Date' ;
    rdfs:comment 'Date when the effectiveness of the CAPA was evaluated.' ;
    rdfs:domain ind:CapaRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:initiatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Initiated Timestamp' ;
    rdfs:comment 'Date and time when the CAPA was formally initiated.' ;
    rdfs:domain ind:CapaRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:preventiveActionDescription rdf:type rdf:Property ;
    rdfs:label 'Preventive Action Description' ;
    rdfs:comment 'Detailed steps to prevent recurrence of the issue.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reference' ;
    rdfs:comment 'Regulatory framework or standard that prompted the CAPA (e.g., OSHA, EPA).' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewComments rdf:type rdf:Property ;
    rdfs:label 'Review Comments' ;
    rdfs:comment 'Comments entered during the effectiveness review.' ;
    rdfs:domain ind:CapaRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationMethod rdf:type rdf:Property ;
    rdfs:label 'Verification Method' ;
    rdfs:comment 'Method used to verify that the CAPA was effective.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionDueDate rdf:type rdf:Property ;
    rdfs:label 'Action Due Date' ;
    rdfs:comment 'Target completion date for the recommended actions.' ;
    rdfs:domain ind:HazopStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actionOwner rdf:type rdf:Property ;
    rdfs:label 'Action Owner' ;
    rdfs:comment 'Individual or department responsible for implementing the action.' ;
    rdfs:domain ind:HazopStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionStatus rdf:type rdf:Property ;
    rdfs:label 'Action Status' ;
    rdfs:comment 'Current status of the recommended action.' ;
    rdfs:domain ind:HazopStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlMeasures rdf:type rdf:Property ;
    rdfs:label 'Control Measures' ;
    rdfs:comment 'Engineering or administrative controls in place to mitigate identified hazards.' ;
    rdfs:domain ind:HazopStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentationLink rdf:type rdf:Property ;
    rdfs:label 'Documentation Link' ;
    rdfs:comment 'URL or path to the full HAZOP report or supporting documents.' ;
    rdfs:domain ind:HazopStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exposureLimitPpm rdf:type rdf:Property ;
    rdfs:label 'Exposure Limit Ppm' ;
    rdfs:comment 'Permissible exposure limit for the chemical expressed in parts per million.' ;
    rdfs:domain ind:HazopStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazopStudyStatus rdf:type rdf:Property ;
    rdfs:label 'Hazop Study Status' ;
    rdfs:comment 'Current lifecycle status of the study.' ;
    rdfs:domain ind:HazopStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryUnit rdf:type rdf:Property ;
    rdfs:label 'Inventory Unit' ;
    rdfs:comment 'Unit of measure for the maximum intended inventory.' ;
    rdfs:domain ind:HazopStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReviewedBy rdf:type rdf:Property ;
    rdfs:label 'Last Reviewed By' ;
    rdfs:comment 'Name of the person who performed the most recent review of the study.' ;
    rdfs:domain ind:HazopStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReviewedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Reviewed Timestamp' ;
    rdfs:comment 'Date and time of the most recent review.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:maxIntendedInventory rdf:type rdf:Property ;
    rdfs:label 'Max Intended Inventory' ;
    rdfs:comment 'Maximum quantity of the chemical intended to be stored in the unit (numeric value).' ;
    rdfs:domain ind:HazopStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overallRiskRank rdf:type rdf:Property ;
    rdfs:label 'Overall Risk Rank' ;
    rdfs:comment 'Aggregated risk ranking for the study based on likelihood and severity.' ;
    rdfs:domain ind:HazopStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processUnitCode rdf:type rdf:Property ;
    rdfs:label 'Process Unit Code' ;
    rdfs:comment 'Unique identifier of the process unit (e.g., reactor, distillation column) examined in the study.' ;
    rdfs:domain ind:HazopStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recommendedActions rdf:type rdf:Property ;
    rdfs:label 'Recommended Actions' ;
    rdfs:comment 'Summary of corrective or preventive actions proposed by the study.' ;
    rdfs:domain ind:HazopStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revalidationDate rdf:type rdf:Property ;
    rdfs:label 'Revalidation Date' ;
    rdfs:comment 'Date of the most recent revalidation or periodic review of the study.' ;
    rdfs:domain ind:HazopStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:riskLikelihood rdf:type rdf:Property ;
    rdfs:label 'Risk Likelihood' ;
    rdfs:comment 'Numeric rating (1-5) of the likelihood of identified hazards.' ;
    rdfs:domain ind:HazopStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:riskSeverity rdf:type rdf:Property ;
    rdfs:label 'Risk Severity' ;
    rdfs:comment 'Numeric rating (1-5) of the severity of potential consequences.' ;
    rdfs:domain ind:HazopStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scopeDescription rdf:type rdf:Property ;
    rdfs:label 'Scope Description' ;
    rdfs:comment 'Narrative description of the functional and physical scope of the HAZOP study.' ;
    rdfs:domain ind:Ehs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyCode rdf:type rdf:Property ;
    rdfs:label 'Study Code' ;
    rdfs:comment 'Business identifier or reference code assigned to the study (e.g., HZP-2024-001).' ;
    rdfs:domain ind:HazopStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyEndDate rdf:type rdf:Property ;
    rdfs:label 'Study End Date' ;
    rdfs:comment 'Calendar date when the HAZOP study activities were completed.' ;
    rdfs:domain ind:HazopStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:studyStartDate rdf:type rdf:Property ;
    rdfs:label 'Study Start Date' ;
    rdfs:comment 'Calendar date when the HAZOP study activities commenced.' ;
    rdfs:domain ind:HazopStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:studyTitle rdf:type rdf:Property ;
    rdfs:label 'Study Title' ;
    rdfs:comment 'Descriptive title of the HAZOP study.' ;
    rdfs:domain ind:HazopStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyType rdf:type rdf:Property ;
    rdfs:label 'Study Type' ;
    rdfs:comment 'Methodology used for the study (HAZOP, What-If, LOPA, Checklist).' ;
    rdfs:domain ind:HazopStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teamMembers rdf:type rdf:Property ;
    rdfs:label 'Team Members' ;
    rdfs:comment 'Comma-separated list of participants (engineers, operators, safety specialists).' ;
    rdfs:domain ind:HazopStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:logisticsShipmentId rdf:type rdf:Property ;
    rdfs:label 'Logistics Shipment Id' ;
    rdfs:comment 'Foreign key linking to logistics.shipment. Business justification: Transport Emission Tracking associates emission events with the corresponding shipment to calculate greenhouse-gas inventory for regulatory compliance.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shipment .

ind:causeOfRelease rdf:type rdf:Property ;
    rdfs:label 'Cause Of Release' ;
    rdfs:comment 'Primary cause that triggered the emission event.' ;
    rdfs:domain ind:EmissionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cleanupStatus rdf:type rdf:Property ;
    rdfs:label 'Cleanup Status' ;
    rdfs:comment 'Status of any remediation or cleanup activities.' ;
    rdfs:domain ind:EmissionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containmentSuccessFlag rdf:type rdf:Property ;
    rdfs:label 'Containment Success Flag' ;
    rdfs:comment 'Indicates whether containment measures successfully prevented further release.' ;
    rdfs:domain ind:EmissionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataQualityNotes rdf:type rdf:Property ;
    rdfs:label 'Data Quality Notes' ;
    rdfs:comment 'Comments on data quality issues or anomalies.' ;
    rdfs:domain ind:EmissionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyResponseAction rdf:type rdf:Property ;
    rdfs:label 'Emergency Response Action' ;
    rdfs:comment 'Description of emergency response actions taken after the event.' ;
    rdfs:domain ind:EmissionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emissionCategory rdf:type rdf:Property ;
    rdfs:label 'Emission Category' ;
    rdfs:comment 'Classification of emission as point source, fugitive, or accidental.' ;
    rdfs:domain ind:EmissionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emissionEventStatus rdf:type rdf:Property ;
    rdfs:label 'Emission Event Status' ;
    rdfs:comment 'Current lifecycle status of the emission event record.' ;
    rdfs:domain ind:EmissionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emissionFactor rdf:type rdf:Property ;
    rdfs:label 'Emission Factor' ;
    rdfs:comment 'Factor used to estimate emissions when direct measurement is unavailable.' ;
