    rdfs:comment 'Type of equipment used to move the shipment.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exportControlClassification rdf:type rdf:Property ;
