# RDFS Schema for Business: Legal

@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix ind: <http://datamodel.lakehouse.org/business/legal#> .

# --- Root Business Class ---
ind:Business rdf:type rdfs:Class ;
    rdfs:label 'Business' ;
    rdfs:comment 'Root class for all business entities' .

# --- Specific Business: Legal ---
ind:Legal rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Business ;
    rdfs:label 'Legal' ;
    rdfs:comment 'Legal is a professional services industry providing advisory and representation services across corporate transactions, dispute resolution, intellectual property, employment law, and regulatory compliance for organizations and governments.' .

# --- Domain Classes ---
ind:Client rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Legal ;
    rdfs:label 'Client' ;
    rdfs:comment 'Single source of truth for all client entities served by the firm including corporate clients, government agencies, individual clients, and prospective clients. Manages client profiles, organizational hierarchies, contact information, client segments, relationship history, KYC documentation, and client classification for conflict checking and engagement purposes. Supports both B2B and B2C client types across all practice areas.' .

ind:Matter rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Legal ;
    rdfs:label 'Matter' ;
    rdfs:comment 'Core operational domain governing the lifecycle of every legal matter and case from inception to closure. Serves as the central hub linking clients, timekeepers, documents, and billing to a single matter record. Supports matter management, case administration, litigation, corporate transaction advisory, and LPM workflows across all practice groups.' .

ind:Document rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Legal ;
    rdfs:label 'Document' ;
    rdfs:comment 'Manages the full lifecycle of all legal documents including drafting, versioning, review, execution, and records retention. Encompasses DMS metadata from iManage Work and NetDocuments, eDiscovery ESI collections via Relativity, TAR/CAL review workflows, OCR/NLP processing outputs, privilege designations, and LPP classification. Authoritative source for document provenance and chain of custody.' .

ind:Billing rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Legal ;
    rdfs:label 'Billing' ;
    rdfs:comment 'Single source of truth for all revenue cycle operations including timekeeping, WIP management, prebilling, invoice generation, payment processing, accounts receivable, collections, and write-offs. Supports multiple fee arrangements including hourly, contingency, flat fee, AFA, and blended rates. Integrates LEDES and UTBMS standards for electronic billing and task-based management. Covers PPP, PEP, RPE, and ARPU financial KPIs.' .

ind:Conflict rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Legal ;
    rdfs:label 'Conflict' ;
    rdfs:comment 'Manages new business intake, conflict-of-interest screening, ethical wall configuration, and clearance workflows required before any matter may be opened. Integrates Intapp Conflicts as the system of record. Enforces ABA Rule 1.7/1.9/1.10 conflict rules, lateral hire screening, and relationship mapping to protect LPP and firm ethics obligations.' .

ind:Ip rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Legal ;
    rdfs:label 'Ip' ;
    rdfs:comment 'Manages the intellectual property portfolio lifecycle including patent prosecution (PCT, PPH), trademark registration, copyright registration, trade secrets, licensing, FRAND obligations, and IP docketing deadlines. Serves as SSOT for all IP assets, annuity payments, portfolio valuation, and IP ownership records across all jurisdictions.' .

ind:Contract rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Legal ;
    rdfs:label 'Contract' ;
    rdfs:comment 'Governs the full Contract Lifecycle Management (CLM) pipeline for both client-facing engagement letters (LOE, POA, SPA, NDA) and firm vendor/supplier agreements. Owns contract templates, obligation tracking, milestone alerts, renewal management, and executed agreement metadata. Distinct from the matter domain — contract owns the agreement artifact; matter owns the work performed under it.' .

ind:Trust rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Legal ;
    rdfs:label 'Trust' ;
    rdfs:comment 'Dedicated domain for client trust account management in strict compliance with IOLTA rules and jurisdiction-specific trust accounting regulations. Owns trust ledger entries, three-way reconciliations, client fund segregation records, disbursement authorizations, and regulatory trust account reporting. Operationally distinct from the billing domain — trust owns fiduciary client funds; billing owns firm revenue.' .

ind:Compliance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Legal ;
    rdfs:label 'Compliance' ;
    rdfs:comment 'Owns regulatory compliance obligations, control frameworks, and reporting requirements applicable to the firm and its clients. Covers AML/KYC program management, GDPR/CCPA/DPA data privacy controls, SOX compliance tracking, SRA regulatory returns, DPO activities, FATF obligations, and professional indemnity insurance. Distinct from conflict domain — compliance owns firm-level regulatory posture; conflict owns matter-level ethics screening.' .

ind:Service rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Legal ;
    rdfs:label 'Service' ;
    rdfs:comment 'Catalog of legal service offerings such as M&A advisory, litigation, IP counsel, regulatory compliance counseling, employment law, and advisory packages. Manages service definitions, practice area taxonomy, pricing models, SLA terms, and service-to-matter mappings enabling business development and RFP responses.' .

ind:Intake rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Legal ;
    rdfs:label 'Intake' ;
    rdfs:comment 'Manages the end-to-end new business intake and client onboarding pipeline from RFP receipt through LOE execution. Owns prospect qualification, pitch and proposal tracking, engagement scope definition, fee arrangement negotiation (AFA), and handoff to the matter domain upon matter opening. Bridges the CRM pipeline in Microsoft Dynamics 365 with operational matter creation in Elite 3E.' .

ind:Risk rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Legal ;
    rdfs:label 'Risk' ;
    rdfs:comment 'Owns enterprise and matter-level risk identification, assessment, and mitigation records for the firm. Covers professional indemnity exposure, data breach incident management (PII/GDPR), cybersecurity risk (ISO 27001), sanctions screening, and reputational risk flags. Provides the risk register that feeds compliance, conflict, and workforce domains without duplicating their operational data.' .

# --- Data Product Classes (Tables) ---
ind:TimekeeperRate rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Timekeeper Rate' ;
    rdfs:comment 'Master rate card defining billable rates for each timekeeper by client, matter, practice group, and effective date period. Supports standard hourly rates, blended rates, client-negotiated rates, and alternative fee arrangement rate structures. Tracks rate currency, jurisdiction-specific rate tiers, rate approval status, and rate history for audit purposes. Governs the monetary value applied to time entries during WIP calculation.' .

ind:TimeEntry rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Time Entry' ;
    rdfs:comment 'Granular transactional record of billable and non-billable time recorded by timekeepers against a matter. Captures UTBMS task and activity codes, narrative descriptions, hours worked, billable hours, billing rate at time of entry, WIP value, and timekeeper identity. Supports LEDES export format for electronic billing. Tracks entry status through draft, submitted, approved, billed, and written-off lifecycle stages. Primary source record for WIP accumulation and invoice generation.' .

ind:BillingDisbursement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Billing Disbursement' ;
    rdfs:comment 'Transactional record of out-of-pocket expenses and costs incurred on behalf of a client matter, including court filing fees, expert witness fees, travel, courier, photocopying, and third-party vendor costs. Captures UTBMS expense codes, disbursement type, amount, tax treatment, billable flag, and recovery status. Supports both hard disbursements (direct client pass-through costs) and soft disbursements (overhead recoveries). Feeds WIP accumulation alongside time entries.' .

ind:WipLedger rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Wip Ledger' ;
    rdfs:comment 'Accumulated Work in Progress ledger representing unbilled time and disbursements for each matter. Tracks WIP balance by timekeeper, matter, billing period, and fee arrangement type. Provides the authoritative WIP snapshot used in prebilling and financial reporting. Captures WIP aging buckets, write-up/write-down adjustments, and transfer history. Critical for PPP (Profit Per Partner), PEP (Profit Per Equity Partner), and RPE (Revenue Per Employee) financial KPI calculations.' .

ind:Prebill rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Prebill' ;
    rdfs:comment 'Pre-invoice draft generated from WIP for attorney review and approval before final invoice issuance. Captures prebill number, matter reference, billing attorney, billing period, total WIP value, proposed adjustments, write-up/write-down amounts, and prebill status (draft, under review, approved, rejected). Supports the prebilling workflow including partner review, narrative editing, and billing guideline compliance checks. Central to the legal billing quality control process.' .

ind:Invoice rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Invoice' ;
    rdfs:comment 'Authoritative billing document issued to a client for legal services rendered on one or more matters. Captures invoice number, invoice date, billing period, total fees, total disbursements, tax amounts, discounts, net amount due, currency, and invoice status lifecycle (draft, issued, disputed, paid, partially paid, written off, credited). Supports LEDES 1998B and LEDES XML electronic billing formats for corporate clients and insurance carriers. Encompasses credit notes (negative invoices with credit reason, originating invoice reference, and application status) and LEDES e-billing portal submission tracking (submission date, format version, target portal, submission status, rejection reasons, and resubmission history). Provides complete invoice-to-payment lifecycle visibility including dispute resolution and collections integration.' .

ind:InvoiceLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Invoice Line' ;
    rdfs:comment 'Individual line item on a legal invoice representing a single time entry, disbursement, or flat fee component. Captures UTBMS task code, activity code, timekeeper, narrative, quantity, rate, amount, tax code, and line-level write-up/write-down adjustments. Provides the granular detail required for LEDES electronic billing submissions and client billing guideline compliance. Each line traces back to an originating time entry or disbursement record.' .

ind:FeeArrangement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Fee Arrangement' ;
    rdfs:comment 'Master record defining the agreed fee structure between the firm and a client for a specific matter or portfolio of matters. Captures AFA type (hourly, flat fee, contingency, capped fee, blended rate, success fee, retainer, subscription), agreed amounts or rate caps, billing frequency, milestone triggers, and approval metadata. Governs how WIP is converted to invoiced amounts and constrains the billing rules applied during prebilling and invoice generation.' .

ind:BillingPayment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Billing Payment' ;
    rdfs:comment 'Transactional record of funds received from a client against one or more invoices, including the detailed allocation of received funds across outstanding invoices and line items. Captures payment date, payment method (wire transfer, cheque, ACH, credit card), amount received, currency, exchange rate, bank reference, remittance details, and per-invoice/per-line allocation amounts with allocation type (full, partial, retainer drawdown, trust transfer). Supports partial payments, overpayments, unapplied balances, retainer drawdowns, trust-to-office account transfers, and complex multi-matter payment scenarios. Feeds accounts receivable aging and collections workflows.' .

ind:PaymentAllocation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Payment Allocation' ;
    rdfs:comment 'Association record linking a payment to one or more invoice lines, capturing how received funds are distributed across outstanding invoices and line items. Tracks allocated amount, allocation date, allocation type (full, partial, retainer drawdown, trust transfer), and any unapplied balance. Ensures accurate AR aging and supports complex multi-matter payment scenarios common in large corporate client relationships.' .

ind:ArBalance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Ar Balance' ;
    rdfs:comment 'Accounts receivable balance record representing the outstanding amount owed by a client at the matter and invoice level. Tracks current balance, aged buckets (0-30, 31-60, 61-90, 90+ days), last payment date, last statement date, credit terms, and collection status. Serves as the authoritative AR aging ledger for collections management, partner financial reviews, and PPP/PEP reporting.' .

ind:WriteOff rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Write Off' ;
    rdfs:comment 'Transactional record of WIP or AR amounts formally written off or written down following partner approval. Captures write-off type (WIP write-off, bad debt write-off, courtesy discount, billing guideline reduction), original amount, write-off amount, write-off reason code, approving partner, approval date, and GL impact. Critical for realization rate calculations, profitability analysis, and financial period close.' .

ind:Retainer rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Retainer' ;
    rdfs:comment 'Master record of client retainer arrangements including general retainers, matter-specific retainers, and evergreen retainers. Tracks retainer amount, replenishment threshold, current balance, drawdown history, retainer type, and associated trust account reference. Distinct from IOLTA trust accounts (owned by the trust domain) — this entity governs the commercial retainer agreement terms and drawdown authorization rules within the billing cycle.' .

ind:Guideline rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Guideline' ;
    rdfs:comment 'Master record of client-specific billing guidelines and outside counsel guidelines (OCG) that govern invoice compliance requirements. Captures guideline source (client-issued OCG, engagement letter, standing instruction), rule type (rate cap, timekeeper approval, task code restriction, narrative requirement, block billing prohibition, expense limit), effective date, and enforcement action. Used during prebilling review and LEDES submission validation to flag non-compliant entries before invoice issuance.' .

ind:InvoiceDispute rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Invoice Dispute' ;
    rdfs:comment 'Transactional record of client-raised disputes or reductions against a submitted invoice. Captures dispute date, disputed amount, dispute reason (billing guideline violation, rate discrepancy, duplicate entry, unauthorized timekeeper, narrative deficiency), resolution status, agreed reduction amount, and resolution date. Supports dispute resolution workflow and feeds realization rate and write-off analytics.' .

ind:CreditNote rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Credit Note' ;
    rdfs:comment 'Transactional record of credit notes issued to clients to reverse or reduce previously invoiced amounts. Captures credit note number, originating invoice reference, credit reason (overbilling, dispute resolution, goodwill adjustment, fee cap correction), credit amount, tax adjustment, issuance date, and application status (applied to outstanding AR, refunded, held on account). Supports realization rate analysis and AR reconciliation.' .

ind:Register rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Risk ;
    rdfs:label 'Register' ;
    rdfs:comment 'Enterprise-wide and matter-level risk register serving as the authoritative single source of truth for all identified risks across professional indemnity, data breach, cybersecurity, sanctions, reputational, and operational categories. Each record represents a discrete risk item with classification, inherent and residual risk ratings (likelihood × impact matrix), current mitigation status, risk owner, escalation history, exception status (approved deviations from policy with approval metadata), and review cycle scheduling. Supports Risk Committee reporting, SRA regulatory submissions, ISO 31000 alignment, and feeds compliance, conflict, and workforce domains.' .

ind:Category rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Risk ;
    rdfs:label 'Category' ;
    rdfs:comment 'Reference taxonomy of risk categories applicable to a legal services firm, including professional indemnity, data privacy (PII/GDPR), cybersecurity (ISO 27001), sanctions and AML, reputational, operational, and regulatory risk types. Provides standardized classification codes used across the risk register and incident management processes.' .

ind:Assessment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Risk ;
    rdfs:label 'Assessment' ;
    rdfs:comment 'Formal risk assessment record capturing the structured evaluation of a specific risk item at a point in time. Records inherent risk score, control effectiveness rating, residual risk score, likelihood rating, impact rating, risk appetite threshold comparison, assessor identity, assessment methodology (qualitative/quantitative), and next review date. Supports periodic risk review cycles mandated by ISO 27001 and SRA requirements.' .

ind:RiskControl rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Risk ;
    rdfs:label 'Risk Control' ;
    rdfs:comment 'Catalog of risk controls and mitigating measures implemented to address identified risks, including complete control testing and audit history. Each record captures control type (preventive, detective, corrective), control owner, implementation status, operational effectiveness rating, and linkage to mitigated risk items. Embeds the full testing lifecycle: each test instance records test date, tester identity, test methodology, evidence reference, pass/fail outcome, deficiencies identified, remediation required flag, and remediation due date. Provides the consolidated control-and-test audit trail required for ISO 27001 certification and SRA compliance reviews. Aligned to ISO 27001 Annex A control framework.' .

ind:IndemnityExposure rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Risk ;
    rdfs:label 'Indemnity Exposure' ;
    rdfs:comment 'Professional indemnity (PI) exposure record tracking the firm\'s estimated liability exposure on a per-matter or per-claim basis. Captures exposure type (negligence, breach of duty, conflict of interest), estimated claim value, reserve amount, insurer notified flag, notification date, policy year, excess amount, and current exposure status. Feeds the firm\'s PI insurance renewal process and risk appetite monitoring.' .

ind:PiClaim rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Risk ;
    rdfs:label 'Pi Claim' ;
    rdfs:comment 'Professional indemnity (PI) claim record capturing formal claims made against the firm by clients or third parties. Records claimant details, claim date, matter reference, alleged breach description, claim amount, insurer reference, coverage confirmation, legal representation assigned, settlement amount, claim outcome, and closure date. Managed in coordination with the firm\'s PI insurer and external coverage counsel.' .

ind:DataBreachIncident rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Risk ;
    rdfs:label 'Data Breach Incident' ;
    rdfs:comment 'Data breach and privacy incident record tracking all actual or suspected breaches of PII, confidential client data, or LPP-protected information. Captures incident discovery date, breach type (unauthorized access, accidental disclosure, ransomware, insider threat), data subjects affected count, data categories involved (PII, special category, LPP), regulatory notification obligations triggered (GDPR 72-hour, DPA, CCPA), ICO/DPA notification status, and remediation actions taken. Supports GDPR Article 33/34 breach notification obligations.' .

ind:MatterRiskProfile rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Risk ;
    rdfs:label 'Matter Risk Profile' ;
    rdfs:comment 'Matter-level risk profile aggregating all risk dimensions for a specific legal matter including complexity rating, jurisdictional risk, client credit risk, legal professional privilege (LPP) sensitivity, eDiscovery/ESI volume exposure, regulatory scrutiny level, and overall matter risk tier (green/amber/red). Created at matter intake and updated at key lifecycle milestones (mid-matter review, pre-trial, closure). Provides the consolidated risk view consumed by matter management, billing, and partner review processes.' .

ind:MitigationAction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Risk ;
    rdfs:label 'Mitigation Action' ;
    rdfs:comment 'Transactional record of each risk mitigation or remediation action assigned to address an identified risk or control deficiency. Captures action description, action owner, assigned date, due date, priority, completion status, completion date, evidence of completion, and residual risk re-assessment trigger. Provides the action tracking layer that drives risk reduction workflows and management reporting.' .

ind:Asset rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ip ;
    rdfs:label 'Asset' ;
    rdfs:comment 'Master record for every intellectual property asset managed by the firm on behalf of clients, including patents, trademarks, copyrights, trade secrets, and design rights. Serves as the SSOT for IP asset identity, type, status, jurisdiction, ownership, filing dates, registration numbers, and portfolio classification. Anchors all downstream IP lifecycle, docketing, annuity, and licensing records.' .

ind:Patent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ip ;
    rdfs:label 'Patent' ;
    rdfs:comment 'Detailed master record for patent assets including utility, design, and plant patents. Captures patent-specific attributes such as PCT application number, PPH eligibility, claims count, independent claims, priority date, publication number, grant date, expiry date, patent family identifier, IPC/CPC classification codes, prosecution status, and assignee chain. Extends ip_asset for patent-specific prosecution and portfolio management.' .

ind:Trademark rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ip ;
    rdfs:label 'Trademark' ;
    rdfs:comment 'Master record for trademark assets including word marks, device marks, trade dress, and certification marks. Captures Nice Classification codes, goods and services descriptions, application serial number, registration number, registration date, renewal due date, use-in-commerce date, specimen of use, opposition period status, Madrid Protocol designations, and multi-class filing indicators. Extends ip_asset for trademark-specific prosecution and maintenance.' .

ind:ProsecutionEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ip ;
    rdfs:label 'Prosecution Event' ;
    rdfs:comment 'Transactional record of every official prosecution action, office communication, or applicant response in the lifecycle of a patent or trademark application. Captures event type (office action received, response filed, notice of allowance, final rejection, restriction requirement, appeal filed, grant issued, request for continued examination), event date, official deadline, response deadline, examiner name and art unit, attorney of record, response summary, and outcome. Supports docketing trigger automation, deadline management, and prosecution history estoppel analysis.' .

ind:DocketDeadline rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ip ;
    rdfs:label 'Docket Deadline' ;
    rdfs:comment 'Operational record of every docketed deadline associated with an IP asset or prosecution event. Covers statutory deadlines, office action response due dates, annuity/renewal payment dates, PCT national phase entry deadlines (30/31 month), opposition filing windows, priority year expiry, and divisional filing deadlines. Captures deadline type, rule-based calculated due date, extended due date (with extension fee flag), responsible attorney, docketing clerk, reminder cascade schedule, completion status, completion date, and missed-deadline escalation flag. Mission-critical for IP docketing compliance — a missed deadline can result in irrecoverable loss of rights and malpractice liability.' .

ind:IpPayment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ip ;
    rdfs:label 'Ip Payment' ;
    rdfs:comment 'Unified transactional record of every financial payment made or received in connection with IP assets and license agreements. Covers annuity fees, maintenance fees, renewal fees, official surcharges, royalty payments (inbound and outbound), milestone payments, and FRAND commitment payments. Captures payment type (annuity, maintenance_fee, renewal_fee, royalty_inbound, royalty_outbound, surcharge, milestone), associated IP asset or license agreement, due date, payment date, payment amount, currency, IP office receipt number or remittance reference, payment agent, payment method, royalty base and rate (for royalty types), royalty period, withholding tax, late payment surcharge flag, audit adjustment flag, reconciliation status, and payment status. Supports portfolio cost management, annuity forecasting, lapse risk monitoring, royalty accounting, audit rights enforcement, revenue recognition, and unified payment reconciliation.' .

ind:LicenseAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ip ;
    rdfs:label 'License Agreement' ;
    rdfs:comment 'Master record for ALL IP-specific agreements governing the use, transfer, ownership, co-development, or protection of IP assets. Covers license agreements (exclusive, non-exclusive, sole, cross-license, compulsory, FRAND-encumbered), invention assignment agreements, co-ownership agreements, joint development agreements, technology transfer agreements, IP indemnification agreements, confidentiality agreements with IP-specific terms, and settlement agreements with IP covenants. Captures agreement type discriminator, parties (licensor/licensee, assignor/assignee, co-owners, joint developers), licensed/assigned IP assets, territory, field of use, royalty structure (fixed, running, milestone, lump-sum), effective date, expiry date, renewal terms, sublicensing rights, FRAND obligation flag, key obligations, governing law, execution status, termination provisions, and amendment history. SSOT for all IP agreement relationships — the ONLY product in this domain for recording any IP-related agreement. Distinct from the contract domain\'s general CLM pipeline which handles engagement letters and vendor contracts.' .

ind:RoyaltyPayment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ip ;
    rdfs:label 'Royalty Payment' ;
    rdfs:comment 'Transactional record of royalty payments made or received under an IP license agreement. Captures payment period, royalty base (net sales, units, revenue), royalty rate, calculated royalty amount, currency, payment date, payment direction (inbound/outbound), withholding tax amount, audit adjustment flag, and reconciliation status. Supports royalty accounting, audit rights enforcement, and revenue recognition for IP licensing income.' .

ind:Ownership rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ip ;
    rdfs:label 'Ownership' ;
    rdfs:comment 'Master record establishing the chain of title and ownership interests in each IP asset across all jurisdictions. Captures owner entity name, owner type (individual inventor, corporate assignee, joint owner, government), ownership percentage, assignment date, recordal date, IP office recordal number, consideration paid, and ownership status. Supports ownership verification, assignment recordal tracking, and portfolio due diligence for M&A transactions.' .

ind:Inventor rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ip ;
    rdfs:label 'Inventor' ;
    rdfs:comment 'Master record for individual inventors named on patent applications and grants, maintaining independent lifecycle for inventorship determination, derivation proceedings, and assignment chain management. Captures inventor full name, nationality, residence address, employer at time of invention, invention disclosure date, assignment executed flag, oath or declaration status, inventor contribution description, joint inventor flag, and employment agreement reference. Supports inventorship disputes, correction of inventorship filings, assignment chain integrity verification, and derivation proceeding risk management. Linked to patents via many-to-many relationship reflecting that inventors may appear on multiple patent applications.' .

ind:PatentFamily rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ip ;
    rdfs:label 'Patent Family' ;
    rdfs:comment 'Master record grouping related patent applications and grants that share a common priority claim into a patent family. Captures family identifier, priority application reference (earliest filing), priority date, family type (simple/Paris Convention, extended/INPADOC, complete), member jurisdiction count, technology area (IPC/CPC based), strategic importance rating, family status, and continuation/divisional chain indicators. Enables portfolio-level analysis, freedom-to-operate assessments, patent landscape mapping, and coordinated multi-jurisdictional prosecution strategy.' .

ind:Copyright rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ip ;
    rdfs:label 'Copyright' ;
    rdfs:comment 'Master record for copyright assets including both registered and unregistered works managed by the firm on behalf of clients. Covers literary, musical, dramatic, artistic, audiovisual, and software works. Captures work title, work type, author(s), copyright claimant, year of creation, year of first publication, registration status (registered, unregistered, pending), registration number, registration date, jurisdiction, deposit copy status, registration certificate reference, and copyright duration. Extends ip_asset for copyright-specific portfolio management, enforcement readiness, and licensing support.' .

ind:Organisation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Client ;
    rdfs:label 'Organisation' ;
    rdfs:comment 'Master record for all corporate, government, and institutional client entities served by the firm. Captures the legal entity name, registration number, jurisdiction of incorporation, entity type (corporation, partnership, government agency, NGO), industry sector, SIC/NAICS code, parent organisation reference, ultimate beneficial owner flags, public/private status, listed exchange, regulatory identifiers (LEI, DUNS), AML risk tier, KYC status, and relationship inception date. Serves as the B2B anchor entity for all matter, billing, and conflict-check relationships. Sourced primarily from Elite 3E client/matter management and Intapp Conflicts.' .

ind:Individual rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Client ;
    rdfs:label 'Individual' ;
    rdfs:comment 'Master record for natural-person clients including individual (B2C) clients, sole traders, high-net-worth individuals, and personal-capacity contacts who engage the firm directly. Stores salutation, full legal name, preferred name, date of birth, nationality, country of domicile, tax identification number, PII classification flags, LPP status, politically exposed person (PEP) flag, sanctions screening status, preferred language, and communication preferences. Distinct from the organisation entity; supports B2C practice areas such as employment law, estate planning, and personal injury. Sourced from Elite 3E and Microsoft Dynamics 365 CRM.' .

ind:Profile rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Client ;
    rdfs:label 'Profile' ;
    rdfs:comment 'Unified client identity record serving as the firm\'s Single Source of Truth for client master data across all practice areas and systems. Stores the canonical client_number (firm-assigned), client type (corporate, government, individual, prospective), client status (active, inactive, prospect, former, suspended), references to organisation or individual entity, originating partner, responsible relationship partner, primary practice area, client tier (platinum, gold, silver), AFA eligibility flag, preferred billing currency, billing address reference, client segment assignment, and date of first engagement. Acts as the central hub entity linking to KYC records, engagement scope, relationship teams, corporate hierarchies, and all matter/billing/conflict relationships. Every system interaction with a client resolves through this record. Sourced from Elite 3E client master.' .

ind:Contact rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Client ;
    rdfs:label 'Contact' ;
    rdfs:comment 'Individual persons who serve as points of contact, authorised representatives, or signatories for organisation and individual client relationships. Captures contact full name, job title, department, direct phone, mobile, email, preferred communication channel, contact role (primary, billing, legal, signatory, authorised representative, in-house counsel), active flag, LinkedIn/professional profile URL, and PEP/sanctions screening status. A single organisation may have multiple contacts across different roles; a contact may be associated with multiple organisations (e.g., in-house counsel moving between clients). Critical for conflict checking (contacts as parties), engagement letter execution (signatories), and day-to-day matter communication. Sourced from Microsoft Dynamics 365 CRM and Elite 3E.' .

ind:Address rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Client ;
    rdfs:label 'Address' ;
    rdfs:comment 'Multi-purpose address registry for all client-domain entities (organisations, individuals, client profiles). Captures address type (registered office, principal place of business, billing, correspondence, service of process), address lines 1-3, city, state/province, postal code, country ISO code, geocode coordinates, postal validation status, effective date, and expiry date. Supports temporal address tracking for regulatory purposes (service of process requires historical accuracy) and multi-address clients. Critical for billing address resolution, court filing service addresses, and regulatory jurisdiction determination. Sourced from Elite 3E and Microsoft Dynamics 365.' .

ind:CorporateHierarchy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Client ;
    rdfs:label 'Corporate Hierarchy' ;
    rdfs:comment 'Models the parent-subsidiary and affiliated-entity relationships within a corporate client group. Captures parent organisation, child organisation, relationship type (wholly owned subsidiary, majority-owned, minority stake, affiliate, joint venture, branch), ownership percentage, effective date, expiry date, jurisdiction of the relationship, and consolidation flag. Critical for conflict-of-interest checking (Intapp Conflicts), matter origination, and group-level billing arrangements. Enables traversal of the full corporate family tree for AML/KYC and engagement scope purposes.' .

ind:KycRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Client ;
    rdfs:label 'Kyc Record' ;
    rdfs:comment 'Complete KYC/AML due diligence dossier for each client, structured as a header (review assessment) with child document lines. Header captures: KYC review date, reviewer identity, KYC tier (standard, enhanced, simplified), AML risk rating (low, medium, high, prohibited), source of funds verification status, beneficial ownership verification status, sanctions screening result, PEP screening result, next review due date, and KYC expiry date. Child document lines track each supporting document (certificates of incorporation, passports, utility bills, beneficial ownership registers, sanctions clearance certificates) with document type, issuing authority, reference number, issue/expiry dates, verification method (original, certified copy, electronic), verifying officer, DMS storage reference (iManage document_id), and document status (pending, verified, expired, rejected). This product is the SINGLE authoritative owner of all KYC document metadata within the client domain. Each client profile has one active KYC dossier; historical records retained for regulatory audit. Supports FATF, AML, SRA, and GDPR compliance obligations. Sourced from Intapp Conflicts and firm compliance workflows.' .

ind:Segment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Client ;
    rdfs:label 'Segment' ;
    rdfs:comment 'Reference master defining the firms client segmentation taxonomy used for relationship management, pricing strategy, rate card selection, and business development targeting. Each segment record captures segment code, segment name (e.g., Global 500, Mid-Market Corporate, Government & Public Sector, High Net Worth Individual, Start-up & Emerging Growth), segment description, applicable practice areas, minimum revenue threshold, preferred AFA types, assigned BD team, segment review cycle, and segment-level discount authority. Segments drive rate card selection in Elite 3E, pipeline segmentation in Microsoft Dynamics 365 CRM, and partner compensation allocation. Maintained by the firms pricing and BD leadership; changes require partnership approval. Typically 8-15 active segments at any time.' .

ind:RelationshipTeam rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Client ;
    rdfs:label 'Relationship Team' ;
    rdfs:comment 'Defines the firm-side relationship team assigned to a client, capturing the client relationship partner (CRP), originating partner, supervising partner, relationship manager, business development manager, and supporting fee earners. Stores role type, assignment start date, assignment end date, primary contact flag, and notification preferences. Supports RPE/PPP reporting, client satisfaction tracking, and BD pipeline management in Microsoft Dynamics 365. Enables accountability and escalation routing for client service delivery.' .

ind:EngagementScope rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Client ;
    rdfs:label 'Engagement Scope' ;
    rdfs:comment 'Defines the agreed scope of legal services the firm is authorised to provide to a client, as established at the client level (above individual matters). Captures authorised practice areas, geographic jurisdictions covered, excluded services, panel appointment reference, panel start date, panel expiry date, preferred counsel designation, rate card reference, AFA framework type, and scope approval date. Distinct from matter-level engagement letters (owned by the contract domain); this is the client-level standing authority. Sourced from Elite 3E and contract/CLM systems.' .

ind:BeneficialOwner rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Client ;
    rdfs:label 'Beneficial Owner' ;
    rdfs:comment 'Records the ultimate beneficial owners (UBOs) of corporate client entities as required by AML/KYC regulations (FATF, EU 4th/5th AML Directives, FinCEN). Captures UBO full name, date of birth, nationality, country of residence, ownership percentage, nature of control (direct shareholding, indirect, voting rights, other significant influence), PEP status, sanctions status, verification date, and verification method. Linked to the organisation master and KYC record. Supports SRA and FATF beneficial ownership disclosure obligations.' .

ind:OutsideCounselGuideline rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Client ;
    rdfs:label 'Outside Counsel Guideline' ;
    rdfs:comment 'Consolidated record of all client service delivery requirements, encompassing both formal outside counsel guidelines (OCGs) and operational service preferences. For OCGs: captures guideline version, effective date, expiry date, billing rate caps, staffing restrictions, budget approval thresholds, e-billing platform mandate, UTBMS task code requirements, diversity reporting obligations, travel and expense policy, and acceptance status. For operational preferences: captures preferred billing format (LEDES, PDF, e-billing portal), invoice delivery method, reporting frequency, matter update preferences, preferred communication channel, language preference, data residency requirements, and sustainability reporting flags. Represents the complete \'how to serve this client\' specification that governs matter staffing, billing, and reporting. Sourced from Elite 3E billing preferences, Microsoft Dynamics 365 CRM, and client-issued OCG documents.' .

ind:Account rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Trust ;
    rdfs:label 'Account' ;
    rdfs:comment 'Master record for each client trust account maintained by the firm in compliance with IOLTA rules and jurisdiction-specific trust accounting regulations. Captures account type (IOLTA pooled, individual client trust, escrow, retainer), account status, designated financial institution, account number, jurisdiction, opening and closing dates, responsible attorney, and regulatory classification. Serves as the SSOT for all fiduciary client fund accounts — operationally distinct from billing accounts which track firm revenue.' .

ind:LedgerEntry rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Trust ;
    rdfs:label 'Ledger Entry' ;
    rdfs:comment 'Granular double-entry ledger record for every debit and credit movement within a client trust account. The single source of truth (SSOT) for all trust fund transactions — no other product in this domain records financial movements. Covers all transaction types including: receipts (advance retainers, settlement proceeds, escrow deposits, court-ordered funds) with source-of-funds, payment method, client authorization reference, and AML screening attributes; disbursements (third-party payments, fee transfers to operating, settlement distributions, filing fees, expert witness payments) with payee, disbursement category (UTBMS cost code), signatory attorney, and authorization status; transfers between accounts; interest credits; and bank charge reversals. Captures transaction date, value date, transaction type, direction (debit/credit), amount, running balance, matter reference, counterparty identity, payment method (wire, cheque, ACH, SWIFT), authorization reference, and LEDES coding where applicable. Receipt entries include source-of-funds classification and AML screening outcome. Disbursement entries link to disbursement_authorization for approval workflow. The atomic unit of trust accounting — every three-way reconciliation, client balance, and regulatory report is built from these entries.' .

ind:ClientTrustBalance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Trust ;
    rdfs:label 'Client Trust Balance' ;
    rdfs:comment 'Authoritative per-client, per-matter trust balance record representing the current and historical segregated fund position for each client within a pooled or individual trust account. Tracks available balance, held balance (pending disbursements), matter-level sub-ledger balance, last reconciled balance, and balance as-of date. Enforces client fund segregation requirements mandated by bar association rules and IOLTA regulations.' .

ind:Receipt rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Trust ;
    rdfs:label 'Receipt' ;
    rdfs:comment 'Records the receipt of client funds into a trust account including advance retainers, settlement proceeds, escrow deposits, and court-ordered fund receipts. Captures receipt date, source of funds, payment method (wire, cheque, ACH, SWIFT), amount, matter association, client authorization reference, and anti-money laundering (AML) screening status. Triggers the creation of a corresponding trust_ledger_entry credit record.' .

ind:TrustDisbursement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Trust ;
    rdfs:label 'Trust Disbursement' ;
    rdfs:comment 'Records every authorized payment or transfer of client funds out of a trust account including payments to third parties, transfers to firm operating accounts upon fee earning, settlement distributions, court filing fee payments, and expert witness payments. Captures disbursement date, payee, payment method, amount, matter reference, disbursement category (UTBMS cost code), authorization status, and signatory attorney. Core operational record for trust fund outflows.' .

ind:DisbursementAuthorization rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Trust ;
    rdfs:label 'Disbursement Authorization' ;
    rdfs:comment 'Workflow and approval record governing the authorization of each disbursement from a client trust account. Captures the requesting timekeeper, authorization chain (supervising partner, managing partner where required), authorization date and time, approval status, rejection reason, dual-signatory requirements for amounts above threshold, and digital signature references. Enforces the firm\'s internal controls and bar association disbursement authorization rules.' .

ind:ThreeWayReconciliation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Trust ;
    rdfs:label 'Three Way Reconciliation' ;
    rdfs:comment 'Periodic three-way reconciliation record that validates agreement between the firm\'s trust ledger balance, the client sub-ledger total, and the bank statement balance for each trust account. Header captures reconciliation period (monthly mandatory), bank statement balance, book balance, client ledger total, identified variances, variance resolution notes, reconciliation status (in-progress, completed, exception), preparer, reviewer, and sign-off date. Reconciling items (modeled as detail records within this product) capture: item type (outstanding cheque, deposit in transit, bank error, ledger error, timing difference), amount, originating transaction reference, expected clearance date, resolution status, and resolution date. Mandatory under ABA Model Rules and SRA Accounts Rules. Provides the complete audit trail required to clear reconciliation exceptions and satisfy regulatory examination.' .

ind:BankStatement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Trust ;
    rdfs:label 'Bank Statement' ;
    rdfs:comment 'Imported or manually entered bank statement record for each trust account covering a defined statement period, including header-level summary and all constituent line items. Header captures financial institution name, account number, statement period start and end dates, opening balance, closing balance, total credits, total debits, statement source (electronic feed, PDF import, manual entry), and import timestamp. Line items (modeled as detail records within this product) capture transaction date, posting date, description, debit amount, credit amount, running bank balance, transaction reference number, and matching status to a trust_ledger_entry. Enables automated matching during reconciliation and identification of unmatched bank transactions requiring investigation. Serves as the external reference leg of the three-way reconciliation.' .

ind:Transfer rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Trust ;
    rdfs:label 'Transfer' ;
    rdfs:comment 'Records the movement of client funds between trust accounts or between a trust account and the firm\'s operating account upon fee earning. Captures transfer type (inter-trust, trust-to-operating, operating-to-trust top-up), source account, destination account, transfer amount, matter reference, transfer date, authorization reference, and the earned fee invoice linkage when transferring earned fees to operating. Ensures complete audit trail for all inter-account fund movements.' .

ind:RetainerAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Trust ;
    rdfs:label 'Retainer Agreement' ;
    rdfs:comment 'Master record for each client retainer arrangement governing the deposit and replenishment of advance funds held in trust. Captures retainer type (evergreen, fixed, security deposit), agreed retainer amount, replenishment threshold, replenishment amount, matter scope, effective date, expiry date, client authorization reference, and current retainer status. Distinct from the billing domain\'s engagement letter — this record governs the fiduciary fund-holding obligation.' .

ind:EscrowArrangement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Trust ;
    rdfs:label 'Escrow Arrangement' ;
    rdfs:comment 'Master record for escrow accounts established in connection with corporate transactions (M&A, SPA, real estate closings) where the firm acts as escrow agent holding funds pending satisfaction of conditions. Captures escrow purpose, transaction reference, escrow amount, release conditions, release schedule, escrow period start and end dates, counterparty identities, governing escrow agreement reference, and current escrow status. Release events (modeled as detail records within this product) capture: release date, release amount, beneficiary identity, release condition satisfied (description and evidence reference), authorizing parties, payment method, and residual escrow balance post-release. Operationally distinct from general retainer trust accounts. Provides the complete transactional audit trail for escrow fund deposits and distributions.' .

ind:RegulatoryReport rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Trust ;
    rdfs:label 'Regulatory Report' ;
    rdfs:comment 'Periodic regulatory trust account report submitted to bar associations, the SRA, state law societies, or other oversight bodies as required by jurisdiction-specific trust accounting rules. Captures reporting period, jurisdiction, report type (annual trust account certificate, SRA Accounts Rules compliance report, state bar trust account registration), submission date, submitted by, report status (draft, submitted, acknowledged, queried), and regulatory body acknowledgment reference.' .

ind:Prospect rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Intake ;
    rdfs:label 'Prospect' ;
    rdfs:comment 'Master record for prospective clients entering the new business intake pipeline. Captures the pre-engagement identity of an organization or individual before formal client status is established in the client domain. Tracks prospect source (RFP, referral, BD outreach, directory, conference, panel, alumni network), prospect type (corporate, government, individual), referral attribution (referral source type, referring party, relationship owner, referral date), KYC/AML pre-screening status, originating attorney, and pipeline stage. Bridges Microsoft Dynamics 365 CRM lead/account records with the intake workflow. Supports BD attribution reporting and referral network analytics. Distinct from the client domains client entity — prospect represents the pre-onboarding state prior to conflict clearance and LOE execution.' .

ind:RfpSubmission rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Intake ;
    rdfs:label 'Rfp Submission' ;
    rdfs:comment 'Transactional record capturing each Request for Proposal received from a prospective or existing client. Tracks RFP receipt date, issuing organization, RFP reference number, practice area scope, response deadline, assigned pitch team, submission status (received, under review, declined, responded), and the resulting pitch or proposal linkage. Sourced from Microsoft Dynamics 365 opportunity pipeline. Serves as the intake trigger event that initiates the prospect qualification and conflict check workflow.' .

ind:Pitch rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Intake ;
    rdfs:label 'Pitch' ;
    rdfs:comment 'Master record representing a formal pitch or credentials presentation made to a prospective or existing client in response to an RFP or BD opportunity. Tracks pitch type (beauty parade, credentials deck, oral presentation), pitch date, presenting attorneys, practice areas covered, competitive context, pitch outcome (won, lost, pending, withdrawn), and win/loss reason codes. Linked to the originating RFP submission and the resulting engagement opportunity. Sourced from Microsoft Dynamics 365 opportunity and activity records.' .

ind:EngagementOpportunity rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Intake ;
    rdfs:label 'Engagement Opportunity' ;
    rdfs:comment 'Core CRM pipeline entity representing a qualified business development opportunity for a specific legal matter or ongoing client relationship. Tracks opportunity stage (qualification, proposal, negotiation, closed-won, closed-lost), estimated matter value, practice group, responsible partner, probability of conversion, expected matter open date, and AFA type under consideration. Maps directly to Microsoft Dynamics 365 Opportunity records and serves as the commercial anchor linking prospect, pitch, and eventual matter opening in Elite 3E.' .

ind:Request rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Intake ;
    rdfs:label 'Request' ;
    rdfs:comment 'Central workflow orchestration record for the new business intake lifecycle. Represents the formal request submitted by an attorney or BD professional to initiate conflict checking, KYC/AML screening, engagement approval, and ultimately matter opening in Elite 3E. Captures requesting timekeeper, proposed client name, adverse parties, matter description, practice area, office, supervising partner, urgency flag, submission timestamp, and matter opening details (proposed matter number, billing arrangement, approval status). Progresses through stages from submission through conflict clearance, LOE execution, and matter number reservation. Acts as the operational trigger in Intapp Conflicts and the handoff record to the matter domain. Encompasses the full intake-to-open lifecycle including onboarding task tracking and matter opening request details.' .

ind:ConflictSearch rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Intake ;
    rdfs:label 'Conflict Search' ;
    rdfs:comment 'Transactional record of each conflict-of-interest search executed against the firms relationship and matter database during the intake workflow. Tracks search parameters (party names, roles, matter type), execution timestamp, search engine version, number of hits returned, searcher identity, and overall search status (pending, complete, escalated). Each intake request may generate multiple conflict searches for different parties. Sourced from Intapp Conflicts search execution logs. Boundary: this entity captures the search execution act and raw results within the intake workflow; formal clearance decisions, waiver approvals, and ethical wall configurations are owned by the conflict domain.' .

ind:IntakeParty rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Intake ;
    rdfs:label 'Intake Party' ;
    rdfs:comment 'Master record of each party (client, adverse party, related entity, guarantor, subsidiary) associated with a new business intake request. Captures party name, party role (client, adverse, related, guarantor, co-counsel), entity type (corporation, individual, government), jurisdiction of incorporation, parent entity reference, and KYC/AML screening status. Supports multi-party conflict searches and adverse party tracking. Distinct from the client domain\'s client entity — intake_party represents unverified parties at the pre-clearance stage before formal client onboarding.' .

ind:KycScreening rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Intake ;
    rdfs:label 'Kyc Screening' ;
    rdfs:comment 'Transactional record capturing the Know Your Client (KYC) and Anti-Money Laundering (AML) due diligence screening performed on a prospective client or intake party during the onboarding process. Tracks screening type (KYC, AML, sanctions, PEP check), screening provider, screening date, risk rating assigned (low, medium, high), screening outcome (cleared, escalated, rejected), escalation reason, and approving compliance officer. Supports FATF, AML, and SRA regulatory obligations. Each intake party requiring due diligence generates one or more KYC screening records.' .

ind:LetterOfEngagement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Intake ;
    rdfs:label 'Letter Of Engagement' ;
    rdfs:comment 'Master record representing the Letter of Engagement (LOE) issued to a prospective client formalizing the attorney-client relationship, scope of services, fee arrangement, and terms of engagement. Tracks LOE version, issue date, acceptance date, signatory details, governing law, jurisdiction, LPP acknowledgment, data protection consent (GDPR/DPA), conflict waiver references, and execution status (draft, issued, accepted, declined, superseded). The LOE execution event triggers the handoff from the intake domain to the matter domain for matter opening in Elite 3E. Owned by the intake domain as the pre-matter commercial instrument.' .

ind:MatterOpeningRequest rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Intake ;
    rdfs:label 'Matter Opening Request' ;
    rdfs:comment 'Transactional record representing the formal request to open a new matter in Elite 3E following successful conflict clearance and LOE execution. Captures requested matter name, client reference, practice group, responsible partner, billing attorney, originating attorney, office, matter type, proposed matter number, billing arrangement reference, and submission status (pending, approved, rejected, opened). Serves as the handoff record between the intake domain and the matter domain. Triggers matter creation in Elite 3E and closes the intake workflow lifecycle.' .

ind:OriginationCredit rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Intake ;
    rdfs:label 'Origination Credit' ;
    rdfs:comment 'Master record capturing the business origination and relationship credit allocation for a new engagement at the point of intake. Records which attorneys (originating, responsible, billing, cross-selling) receive credit for bringing in the client or matter, including credit type, percentage split, credited timekeeper, practice group, office, and approval status. Established during intake as the commercial attribution record and feeds partner compensation calculations (PPP/PEP) in Elite 3E. Distinct from billing-domain revenue allocation — this captures the agreed credit split at engagement inception before any billing activity occurs.' .

ind:ReferralSource rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Intake ;
    rdfs:label 'Referral Source' ;
    rdfs:comment 'Master reference record identifying the source through which a prospect or new business opportunity was referred to the firm. Captures referral source type (existing client, attorney referral, alumni, intermediary, directory listing, conference, website, panel appointment), referral source name, relationship owner, referral date, and associated engagement opportunity. Supports BD attribution reporting, referral network management, and client relationship analytics. Owned by the intake domain as the commercial origination attribution record.' .

ind:RegulatoryObligation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Regulatory Obligation' ;
    rdfs:comment 'Master registry of all regulatory obligations applicable to the firm across all jurisdictions of operation. Each obligation captures the governing body, jurisdiction, regulatory framework, obligation type (periodic filing, ongoing conduct, event-triggered), effective date, review cycle, current compliance status, and responsible officer. Serves as the authoritative catalog against which controls are designed, policies are written, training is mandated, and returns are filed. The single source of truth for answering \'what must we comply with?\'' .

ind:ControlFramework rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Control Framework' ;
    rdfs:comment 'Master catalog of compliance control frameworks adopted by the firm (e.g., ISO 27001, FATF 40 Recommendations, SRA Code of Conduct, GDPR Article 32 measures, SOX COSO). Each record captures framework name, version, issuing body, adoption date, scope of applicability, and mapping to internal control domains. Provides the structural backbone against which individual controls are designed, tested, and audited.' .

ind:ComplianceControl rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Compliance Control' ;
    rdfs:comment 'Individual internal controls and their testing evidence, designed to satisfy regulatory obligations within a given framework. Control attributes capture identifier, objective, type (preventive, detective, corrective), owner, frequency, testing methodology, and UTBMS alignment. Testing attributes capture test date, tester, methodology (walkthrough, sample testing, re-performance), sample size, exceptions, test conclusion (effective/ineffective), and remediation flags. Serves as the SSOT for the firms control inventory and assurance evidence, supporting SOX, ISO 27001, and SRA compliance programmes.' .

ind:AmlKycProgram rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Aml Kyc Program' ;
    rdfs:comment 'Master record for the firms AML/KYC programme including enterprise-wide and matter-type-level risk assessments, as required by FATF obligations and jurisdiction-specific AML legislation. Programme attributes capture MLRO designation, programme scope, risk appetite, regulatory approval status, and applicable jurisdictions. Risk assessment attributes capture assessment date, assessor, risk categories (client, geographic, product/service, delivery channel), inherent and residual risk ratings, methodology, and findings. Provides the complete firm-level AML governance artifact distinct from individual client KYC checks owned by conflict/intake.' .

ind:SarFiling rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Sar Filing' ;
    rdfs:comment 'Suspicious Activity Report (SAR) filings submitted to the relevant financial intelligence unit (e.g., NCA in the UK, FinCEN in the US) by the firm\'s MLRO. Captures SAR reference number, filing date, subject details (anonymised), transaction or matter reference, suspicion grounds, consent request status, defence against money laundering (DAML) consent outcome, and filing jurisdiction. Critical for FATF and AML regulatory compliance audit trails.' .

ind:DataPrivacyRegister rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Data Privacy Register' ;
    rdfs:comment 'Unified data privacy compliance register combining the Record of Processing Activities (RoPA) under GDPR Article 30 with Data Protection Impact Assessments (DPIAs) under Article 35. RoPA entries document processing activities, legal bases, data categories, subjects, retention periods, processors, and transfer mechanisms. DPIA entries document assessment triggers, necessity analysis, risk identification, mitigation measures, DPO consultation outcomes, and supervisory authority consultation requirements. Managed by the DPO function as the authoritative privacy compliance artifact.' .

ind:ControlTest rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Control Test' ;
    rdfs:comment 'Records of individual control testing activities performed against compliance controls, including design effectiveness testing and operating effectiveness testing. Captures test date, tester, test methodology (walkthrough, sample testing, re-performance), sample size, exceptions identified, exception rate, overall test conclusion (effective/ineffective), remediation required flag, and linkage to the parent compliance control. Supports SOX, ISO 27001, and SRA compliance assurance programmes.' .

ind:IndemnityPolicy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Indemnity Policy' ;
    rdfs:comment 'Professional indemnity insurance records covering both policy master data and claims lifecycle, as required by SRA, Law Society, and other bar regulators. Policy attributes include insurer, policy number, coverage period, limits, excess, retroactive date, qualifying insurer status, and premium. Claims attributes include notification date, claimant details, matter reference, alleged negligence, exposure estimates, insurer acknowledgement, reserve and settlement amounts, and closure status. Provides the unified PI compliance artifact for regulatory reporting and premium renewal actuarial analysis.' .

ind:IndemnityClaim rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Indemnity Claim' ;
    rdfs:comment 'Professional indemnity insurance claims made against or notified under the firm\'s indemnity policy. Captures claim reference, notification date, claimant details, matter reference, alleged negligence description, estimated exposure, insurer acknowledgement date, coverage confirmation status, reserve amount, settlement amount, and claim closure date. Supports SRA compliance obligations and actuarial reporting for premium renewal.' .

ind:Policy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Policy' ;
    rdfs:comment 'Master register of the firm\'s internal compliance policies and procedures, including AML policy, data protection policy, anti-bribery policy, sanctions policy, conflicts of interest policy, and information security policy. Captures policy name, policy owner, version, effective date, review cycle, approval authority, regulatory obligations satisfied, and current status (draft, approved, superseded). Provides the policy governance layer above individual controls.' .

ind:Check rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Conflict ;
    rdfs:label 'Check' ;
    rdfs:comment 'Core transactional record of each conflict-of-interest screening request initiated during new business intake or lateral hire onboarding. Captures the check type (ABA Rule 1.7 current client, Rule 1.9 former client, Rule 1.10 imputed disqualification, lateral hire), the triggering event, requestor, assigned reviewer(s) and their roles, clearance status, and disposition. Reviewer assignments (primary reviewer, ethics partner, supervising partner) with their individual disposition recommendations are tracked directly on this record. This is the primary operational entity of the conflict domain and the system-of-record entry sourced from Intapp Conflicts.' .

ind:ConflictParty rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Conflict ;
    rdfs:label 'Conflict Party' ;
    rdfs:comment 'Master registry of all parties — clients, adverse parties, related entities, individuals, and corporate affiliates — indexed in the conflict search universe. Each party record captures name variants, role classification (client, adverse, related entity, guarantor, beneficial owner), entity type (individual, corporation, government, trust, partnership), jurisdiction of incorporation or domicile, KYC/AML flags, and active/inactive status. Serves as the searchable party index used by every conflict check. Distinct from the client domains client record: this product owns the conflict-specific party classification and search indexing; a party here may or may not be a firm client. For multi-jurisdictional firms, party records are subject to data residency requirements — GDPR-regulated party data (EU/UK natural persons) must be stored and processed within compliant regions, with appropriate cross-border transfer mechanisms documented.' .

ind:SearchExecution rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Conflict ;
    rdfs:label 'Search Execution' ;
    rdfs:comment 'Transactional record of each individual name or entity search executed within a conflict check. Captures the search string, phonetic and fuzzy-match variants applied, search algorithm version, number of hits returned, and the timestamp of execution. One conflict_check may spawn multiple search_execution records (one per party searched). Sourced from Intapp Conflicts search audit log. Note: the logical primary key is conflict_search_id; the physical PK conflict_conflict_search_id reflects the platform naming convention (domain prefix + product-derived name).' .

ind:SearchHit rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Conflict ;
    rdfs:label 'Search Hit' ;
    rdfs:comment 'Each potential conflict match surfaced by a conflict search against the party index and matter history. Records the matched party, the matter or engagement where the relationship was found, the relationship type (current client, former client, adverse party, related entity), the match confidence score, and the reviewing attorneys initial assessment (potential conflict, no conflict, waivable). Central to the conflict clearance workflow. Note: the logical primary key is conflict_hit_id; the physical PK conflict_conflict_hit_id reflects the platform naming convention.' .

ind:Clearance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Conflict ;
    rdfs:label 'Clearance' ;
    rdfs:comment 'Formal clearance decision record issued at the conclusion of a conflict check workflow. Captures the clearance outcome (cleared, cleared with conditions, declined — conflict identified, deferred pending waiver), the authorizing partner or general counsel, the ABA rule basis for any identified conflict, and the date clearance was granted or denied. When conditions are imposed (e.g., mandatory ethical wall erection, restricted matter scope, required client notification, periodic review), each condition is recorded with its type, responsible party, due date, and fulfillment status directly on this record. This record gates matter opening in Elite 3E.' .

ind:Waiver rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Conflict ;
    rdfs:label 'Waiver' ;
    rdfs:comment 'Records informed consent waivers obtained from clients to permit representation despite an identified conflict of interest under ABA Rule 1.7(b). Captures the waiving client, the conflicted matter, the nature of the conflict disclosed, the form of consent (written, verbal with written confirmation), the consenting signatory, waiver execution date, and any scope limitations. Linked to the clearance record and stored in iManage Work.' .

ind:EthicalWall rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Conflict ;
    rdfs:label 'Ethical Wall' ;
    rdfs:comment 'Master record of each ethical screen (information barrier) erected to isolate timekeepers from matters where a conflict or LPP risk exists. Captures the screen name, triggering reason (lateral hire, former client, adverse party, regulatory requirement), effective date, expiration date, screen status (active, expired, dissolved), and the supervising partner responsible for screen integrity. Linked to the clearance or lateral screening record that triggered its creation. Sourced from Intapp Conflicts ethical wall module and enforced in iManage Work and Elite 3E access controls.' .

ind:WallMembership rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Conflict ;
    rdfs:label 'Wall Membership' ;
    rdfs:comment 'Association entity recording which timekeepers (attorneys, paralegals, staff) are included within or excluded from a specific ethical wall. Captures the timekeeper reference, inclusion/exclusion designation, the date added or removed, the reason for the membership change, and the authorizing partner. Enables enforcement of access restrictions in iManage Work and Elite 3E.' .

ind:Rule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Conflict ;
    rdfs:label 'Rule' ;
    rdfs:comment 'Reference catalog of conflict-of-interest rules and ethical obligations configured in the firm\'s conflict system. Each record defines the rule identifier (e.g., ABA 1.7, ABA 1.9, ABA 1.10, SRA Rule 6.1), the governing body, the rule description, the jurisdiction(s) of applicability, the conflict category it governs, and whether the conflict is waivable. Drives automated conflict classification logic in Intapp Conflicts.' .

ind:PartyAlias rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Conflict ;
    rdfs:label 'Party Alias' ;
    rdfs:comment 'Registry of known name aliases, former names, trade names, DBA designations, and transliterated variants for parties in the conflict search universe. Each alias record links to the canonical conflict_party record and captures the alias type, the source of the alias (client disclosure, public registry, prior matter), and the effective date range. Enables comprehensive fuzzy and phonetic matching during conflict searches.' .

ind:Agreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Agreement' ;
    rdfs:comment 'Master record for every executed or in-progress contract artifact owned by the firm, covering client-facing instruments (LOE, NDA, SPA, POA) and firm vendor/supplier agreements. SSOT for agreement identity, counterparty references, effective/expiry dates, governing law, jurisdiction, contract value, currency, confidentiality classification, LPP flag, execution status, and CLM stage.' .

ind:AgreementType rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Agreement Type' ;
    rdfs:comment 'Reference classification of contract instrument types recognized by the firm, including LOE (Letter of Engagement), NDA (Non-Disclosure Agreement), SPA (Share Purchase Agreement), POA (Power of Attorney), MSA (Master Services Agreement), SOW (Statement of Work), vendor agreement, retainer agreement, and ADR arbitration agreement. Carries UTBMS-aligned codes, default renewal terms, standard notice periods, and governing regulatory framework flags (GDPR, SOX, FRAND).' .

ind:Template rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Template' ;
    rdfs:comment 'Approved master template library for each agreement type maintained in the firm\'s document management system. Tracks template version, practice group owner, jurisdiction applicability, language locale, last review date, approval status, precedent reference, and mandatory-use lock flag. Serves as the catalog of approved starting points for contract drafting.' .

ind:ContractParty rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Contract Party' ;
    rdfs:comment 'Records every counterparty, signatory, or named party to a specific agreement, including the firm itself, clients, opposing counsel entities, vendors, guarantors, and government bodies. Captures party role (offeror, offeree, guarantor, witness, notary), legal entity name, jurisdiction of incorporation, KYC/AML clearance status, authorized signatory name, and execution capacity. Supports multi-party M&A and syndicated transaction structures.' .

ind:Obligation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Obligation' ;
    rdfs:comment 'Granular obligation register extracted from executed agreements, capturing each discrete contractual duty, covenant, representation, warranty, or condition precedent as a header record with associated lifecycle event lines. Header stores obligation text, category (payment, delivery, reporting, confidentiality, regulatory, IP assignment), responsible party, due date, recurrence schedule, priority, and fulfillment status. Line-level event records capture the full audit trail: creation, fulfillment, partial completion, breach notice, cure, waiver, and escalation events with actor, timestamp, event type, supporting document reference, and resulting status change. SSOT for all obligation data including lifecycle events. Core to CLM obligation tracking, dispute resolution evidence, and regulatory compliance reporting.' .

ind:ObligationEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Obligation Event' ;
    rdfs:comment 'Transactional record of each obligation lifecycle event — creation, fulfillment, partial completion, breach notice, cure, waiver, or escalation. Captures event timestamp, actor (attorney, client, counterparty), event type, supporting document reference, and resulting obligation status change. Provides the full audit trail required for dispute resolution and regulatory compliance reporting.' .

ind:Milestone rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Milestone' ;
    rdfs:comment 'Scheduled key dates and milestone events tied to an agreement, including execution date, effective date, condition precedent satisfaction deadline, notice periods, option exercise windows, renewal decision dates, expiry date, and termination for convenience windows. Tracks milestone status, alert lead-time configuration, responsible attorney, and whether the milestone triggered an automated notification. Critical for renewal management and M&A transaction timetables.' .

ind:Renewal rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Renewal' ;
    rdfs:comment 'Manages the renewal lifecycle for agreements subject to auto-renewal, optional renewal, or renegotiation. Captures renewal type (auto-renew, opt-in, renegotiate), renewal term length, notice-to-cancel deadline, renewal decision (renew, terminate, renegotiate), decision date, responsible partner, AFA or fee adjustment for the renewal term, and the resulting successor agreement reference. Supports proactive renewal pipeline management.' .

ind:Amendment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Amendment' ;
    rdfs:comment 'Records every formal amendment, addendum, side letter, or variation to an executed agreement. Stores amendment number, amendment type, description of changes, effective date of amendment, parties consenting, execution status, and reference to the redlined document version in the DMS. Maintains the chain of agreement versions for legal enforceability and audit purposes.' .

ind:ExecutionRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Execution Record' ;
    rdfs:comment 'Captures the formal execution event for an agreement, recording execution method (wet ink, electronic signature, notarized, deed), execution date per party, signatory name and title, witness details, notary details where applicable, jurisdiction of execution, and the executed document reference in the DMS. Provides the legally authoritative record of when and how an agreement became binding.' .

ind:Termination rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Termination' ;
    rdfs:comment 'Records the termination or expiry of an agreement, capturing termination type (expiry, termination for convenience, termination for cause, mutual rescission, frustration), effective termination date, notice date, terminating party, grounds for termination, dispute flag, post-termination obligations surviving, and settlement or wind-down terms. Feeds compliance reporting and professional indemnity risk registers.' .

ind:ClauseLibrary rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Clause Library' ;
    rdfs:comment 'Curated repository of approved standard and fallback clauses maintained by knowledge management and CLM teams. Each clause stores type (indemnity, limitation of liability, governing law, force majeure, IP assignment, confidentiality, FRAND, arbitration), approved text, fallback text, jurisdiction applicability, practice group owner, approval date, and usage tier (mandatory, preferred, fallback). Integrates with external standard clause guidance sources.' .

ind:Tribunal rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Matter ;
    rdfs:label 'Tribunal' ;
    rdfs:comment 'Master record for every court, tribunal, arbitral body, and ADR forum the firm interacts with. Captures the official name, jurisdiction level (federal, state, appellate, international), court type (district, circuit, chancery, arbitration panel, ICC, LCIA), geographic jurisdiction, ECF/PACER enrollment status, filing system credentials reference, and operational status. Serves as the authoritative SSOT for court identity across the litigation and dispute resolution practice.' .

ind:Jurisdiction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Matter ;
    rdfs:label 'Jurisdiction' ;
    rdfs:comment 'Reference catalog of legal jurisdictions — federal circuits, state/provincial courts, international arbitral seats, and regulatory jurisdictions. Stores jurisdiction code, governing law system (common law, civil law, mixed), geographic region, applicable rules of civil procedure, statute of limitations defaults, and treaty memberships (e.g., New York Convention for arbitration enforcement). Used to classify matters, filings, and judgments by controlling law.' .

ind:Judge rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Matter ;
    rdfs:label 'Judge' ;
    rdfs:comment 'Master record for judicial officers, arbitrators, and mediators before whom the firm appears. Captures full name, title, court assignment, chamber details, appointment date, judicial philosophy notes, recusal history flags, ADR certification type, and preferred filing/communication protocols. Supports conflict screening, appearance preparation, and relationship intelligence for litigation strategy.' .

ind:Docket rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Matter ;
    rdfs:label 'Docket' ;
    rdfs:comment 'Official docket record linking a matter to a specific court or tribunal. Stores the court-assigned docket number, case caption, filing date, case type (civil, criminal, appellate, arbitration), assigned judge reference, case status (active, stayed, closed, appealed), PACER case ID for federal matters, ECF registration status, and next scheduled event date. Acts as the operational hub for all court-side activity on a matter.' .

ind:Hearing rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Matter ;
    rdfs:label 'Hearing' ;
    rdfs:comment 'Transactional record of each scheduled or completed court hearing, conference, or oral argument. Captures hearing type (status conference, motion hearing, trial, deposition, arbitration session), scheduled date and time, courtroom or virtual platform, presiding judge, duration, outcome summary, continuance flag, and appearance requirements. Feeds the firm-wide court calendar and attorney appearance tracking workflows.' .

ind:Appearance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Matter ;
    rdfs:label 'Appearance' ;
    rdfs:comment 'Records each attorney appearance at a court proceeding, arbitration session, or ADR hearing. Stores timekeeper reference, docket reference, hearing reference, appearance type (lead counsel, co-counsel, local counsel, observer), pro hac vice status, bar admission jurisdiction, appearance date, outcome notes, and time spent. Supports billing verification, court-mandated appearance reporting, and attorney utilization analytics.' .

ind:Filing rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Matter ;
    rdfs:label 'Filing' ;
    rdfs:comment 'Transactional record of every document filed with a court, tribunal, or arbitral body. Captures filing type (complaint, motion, brief, answer, notice, order, judgment), filing date/time, ECF confirmation number, PACER transaction ID, filed-by attorney, filing fee amount, service method, acceptance status (accepted, rejected, pending), and deadline compliance flag. Links to document management for source document reference and supports cost recovery allocation for client billing.' .

ind:Deadline rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Matter ;
    rdfs:label 'Deadline' ;
    rdfs:comment 'Tracks all court-imposed and rule-based deadlines associated with a docket or ADR proceeding. Stores deadline type (answer due, discovery cutoff, motion deadline, trial date, appeal window, briefing deadline), calculated due date, triggering event, applicable court rule citation, responsible attorney, completion status, extension granted flag, extension order reference, and calendar synchronization status. Critical for docket management, malpractice risk avoidance, and firm-wide court calendar views.' .

ind:Order rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Matter ;
    rdfs:label 'Order' ;
    rdfs:comment 'Records judicial orders, rulings, and decisions issued in connection with a docket. Captures order type (procedural, substantive, consent, default, summary judgment, injunction), issue date, issuing judge, order text summary, compliance deadline, appeal deadline, enforcement status, and whether the order is published or unpublished. Distinct from filed documents — this is the authoritative record of what the court has directed.' .

ind:CourtRule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Matter ;
    rdfs:label 'Court Rule' ;
    rdfs:comment 'Reference catalog of procedural rules, local rules, standing orders, and practice directions applicable to each court or tribunal. Stores rule code, rule title, effective date, expiry date, court reference, rule category (filing, service, discovery, evidence, scheduling), page/word limits, mandatory form references, and electronic filing requirements. Enables automated deadline calculation and filing compliance checks.' .

ind:Judgment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Matter ;
    rdfs:label 'Judgment' ;
    rdfs:comment 'Records final judgments, decrees, and court-entered settlements in litigated matters. Stores judgment type (default, consent, summary, trial verdict, appellate), entry date, court reference, docket reference, judgment amount, currency, prevailing party, interest rate, cost award, appeal deadline, satisfaction date, and enforcement status. Distinct from court_order — judgments are final dispositions that close or substantially resolve a docket.' .

ind:LegalDocument rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Document ;
    rdfs:label 'Legal Document' ;
    rdfs:comment 'Master record for every legal document managed within the firm\'s DMS (iManage Work, NetDocuments). Captures document identity, classification, matter association, author, version lineage, LPP/privilege status, retention schedule, and chain-of-custody provenance. Serves as the authoritative SSOT for all document metadata across the document lifecycle from drafting through archival.' .

ind:DocVersion rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Document ;
    rdfs:label 'Doc Version' ;
    rdfs:comment 'Tracks every version of a legal document stored in the DMS including full content metadata. Records version number, author, timestamp, change summary, check-in/check-out state, file format, file size, whether the version is the current authoritative copy, and any OCR/NLP processing outputs (extracted text, confidence score, extraction engine, language detected). Supports full version lineage, rollback capability, full-text search enablement, and TAR model training — all required for LPP compliance and eDiscovery chain-of-custody.' .

ind:DocType rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Document ;
    rdfs:label 'Doc Type' ;
    rdfs:comment 'Reference classification of legal document types used across the firm (e.g., NDA, SPA, POA, LOE, pleading, brief, affidavit, court order, patent application, trademark filing, board resolution, engagement letter). Includes UTBMS task code alignment, retention category, and default privilege classification. Governs document naming conventions and DMS folder taxonomy.' .

ind:DocFolder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Document ;
    rdfs:label 'Doc Folder' ;
    rdfs:comment 'Represents the DMS folder and workspace hierarchy within iManage Work and NetDocuments. Captures workspace name, matter or client association, folder path, parent folder reference for hierarchy traversal, access control group, security classification, and governance policy. Provides the organizational container structure for document storage and retrieval aligned to matter workspaces. Supports workspace provisioning automation and access inheritance rules.' .

ind:DocReviewAssignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Document ;
    rdfs:label 'Doc Review Assignment' ;
    rdfs:comment 'Complete record of document review work product within eDiscovery and collaborative review workflows. Captures reviewer identity, review batch, assignment and completion dates, review decisions (responsive/non-responsive/privilege), TAR/CAL model round, and all associated annotations including issue tags, redactions, coding decisions, highlights, comments, redlines, and annotation metadata (type, timestamp, review round, CAL feedback flag). Supports review throughput management, quality control, second-level review, continuous active learning feedback, privilege log compilation, ad-hoc collaborative annotation outside formal review batches, and annotation-level audit trail. Central operational entity for managing the entire review, annotation, and coding lifecycle from assignment through final production coding.' .

ind:PrivilegeLog rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Document ;
    rdfs:label 'Privilege Log' ;
    rdfs:comment 'Authoritative record of privilege designations applied to documents, capturing LPP (Legal Professional Privilege), attorney-client privilege, work-product doctrine, and common-interest privilege claims. Records the basis for privilege assertion, asserting attorney, date of designation, redaction status, and challenge history. Required for eDiscovery productions and court submissions.' .

ind:EsiCollection rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Document ;
    rdfs:label 'Esi Collection' ;
    rdfs:comment 'Master record for each ESI (Electronically Stored Information) collection event executed via Relativity or other collection tools. Captures custodian identity, collection date range, data sources (email, file share, cloud), collection method, chain-of-custody hash values, volume statistics, and matter linkage. Serves as the authoritative provenance record for all eDiscovery collections.' .

ind:EsiCustodian rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Document ;
    rdfs:label 'Esi Custodian' ;
    rdfs:comment 'Identifies individuals or entities whose ESI is subject to legal hold and collection in litigation or investigation matters. Records custodian name, role, organization, data sources held (email systems, file shares, cloud storage, mobile devices), legal hold acknowledgement status, collection status, and interview notes. This is the document-domain view of a person-as-custodian — the authoritative record of their preservation obligations, data map, and collection history. Supports custodian interview workflows and defensible collection planning under FRCP Rule 26, Practice Direction 31B, and GDPR obligations.' .

ind:LegalHold rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Document ;
    rdfs:label 'Legal Hold' ;
    rdfs:comment 'Records the issuance, scope, and lifecycle of legal hold notices sent to custodians to preserve ESI and physical documents in anticipation of litigation or regulatory investigation. Captures hold trigger event, issuing attorney, custodian acknowledgement status, scope of preservation, suspension of routine destruction, and release date. Critical for defensible litigation readiness and spoliation risk management.' .

ind:DocProduction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Document ;
    rdfs:label 'Doc Production' ;
    rdfs:comment 'Records each eDiscovery production set delivered to opposing counsel or a regulatory body via Relativity. Captures production volume, Bates number range, production format (TIFF, native, PDF), redaction applied, privilege log reference, delivery method, and receiving party. Provides the authoritative audit trail for all productions in litigation and regulatory matters.' .

ind:RetentionSchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Document ;
    rdfs:label 'Retention Schedule' ;
    rdfs:comment 'Reference table defining the firms document retention, destruction, and disposal policies by document type, matter type, jurisdiction, and regulatory framework (GDPR, DPA, SOX, SRA). Specifies minimum and maximum retention periods, destruction method (shredding, secure deletion, degaussing), destruction authorization requirements, legal basis for retention, responsible records manager, and certificate of destruction tracking. Governs automated retention enforcement in iManage Records Management and NetDocuments Governance, including end-of-life destruction event recording.' .

ind:DocExecution rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Document ;
    rdfs:label 'Doc Execution' ;
    rdfs:comment 'Records the formal execution of legal documents including signing parties, execution method (wet ink, DocuSign, Adobe Sign), execution date, counterpart details, governing law, and notarization or witnessing requirements. Tracks execution status through the signing workflow and stores the executed document reference. Authoritative record for contract execution events across M&A, CLM, and engagement letter workflows.' .

ind:DocTemplate rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Document ;
    rdfs:label 'Doc Template' ;
    rdfs:comment 'Catalog of approved document templates and precedent forms maintained in Thomson Reuters Practical Law and the firm\'s knowledge management system. Records template name, practice area, jurisdiction, version, approval status, approving partner, last review date, and associated clause library references. Serves as the authoritative source for standardized drafting starting points across all practice groups.' .

ind:Matter rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Matter ;
    rdfs:label 'Matter' ;
    rdfs:comment 'Core master record for every legal matter and case managed by the firm. Represents the central hub of the matter domain, capturing the full lifecycle from inception to closure. Stores matter number, matter name, practice group, matter type (litigation, transactional, advisory, IP, regulatory), open date, close date, status (active, suspended, closed, archived), responsible attorney, supervising partner, originating attorney, billing attorney, office, jurisdiction, governing law, matter description, LPM classification, budget amount, estimated hours, risk rating, confidentiality flag, LPP flag, and LEDES matter category. Sourced primarily from Elite 3E Client/Matter Management module.' .

ind:Phase rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Matter ;
    rdfs:label 'Phase' ;
    rdfs:comment 'Defines the structured phases within a matter lifecycle used for LPM (Legal Project Management) and UTBMS-aligned task budgeting. Each phase record captures phase code, phase name (e.g., Pleadings, Discovery, Trial, Closing), sequence order, estimated hours, budgeted fees, actual hours to date, phase status, start date, target end date, and actual end date. Enables phase-level budget vs. actual tracking and milestone management across litigation and transactional matters.' .

ind:Task rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Matter ;
    rdfs:label 'Task' ;
    rdfs:comment 'Granular task records within a matter phase, aligned to UTBMS task codes for structured billing and LPM tracking. Captures task code, task name, task description, assigned timekeeper, estimated hours, actual hours, task status (open, in-progress, complete, deferred), due date, completion date, priority level, and billable flag. Supports matter budgeting, workload distribution, and LEDES-compliant billing narratives. Sourced from Elite 3E task management and LPM workflow modules.' .

ind:Team rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Matter ;
    rdfs:label 'Team' ;
    rdfs:comment 'Association entity capturing the assignment of timekeepers and staff to a matter, representing the matter team roster. Records timekeeper role on the matter (responsible attorney, supervising partner, associate, paralegal, billing attorney, originating attorney, co-counsel), assignment start date, assignment end date, billing rate override, hours cap, and active flag. Enables matter-level staffing management, rate governance, and workload reporting. Sourced from Elite 3E and Aderant Expert timekeeper-matter assignment modules.' .

ind:Budget rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Matter ;
    rdfs:label 'Budget' ;
    rdfs:comment 'Formal matter budget, fee arrangement, and rate governance record serving as the single source of truth for all financial planning, approved fee budgets, cost budgets, and matter-level billing rate agreements. Supports AFA (Alternative Fee Arrangement) and hourly billing models. Stores budget type (total fees, phase fees, disbursements, total matter), budget amount, currency, approved date, approved by, budget version, budget status (draft, approved, revised, closed), AFA type (fixed fee, capped fee, blended rate, contingency, success fee), variance threshold percentage. Includes comprehensive rate schedule management: timekeeper role, individual timekeeper reference, rate type (standard, agreed, AFA blended, pro bono), hourly rate amount, rate currency, effective date, expiry date, rate approval status, client-agreed flag, rate source (engagement letter, rate schedule, court order), and rate version history. Enables WIP monitoring, budget vs. actual reporting, rate card management, client budget compliance, LEDES-compliant billing, rate benchmarking analytics, and accurate WIP valuation. This product is the single home for all matter-level rate governance — there is no separate rate entity. Sourced from Elite 3E and Aderant Expert rate and budget management modules.' .

ind:MatterParty rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Matter ;
    rdfs:label 'Matter Party' ;
    rdfs:comment 'All parties to a legal matter beyond the primary client, including adverse parties, co-parties, third parties, intervenors, guarantors, counterparties in transactions, joint venture partners, regulatory bodies, government agencies, and beneficial owners. Captures party name, party type (plaintiff, defendant, counterparty, guarantor, regulator, witness, expert, joint venture partner, licensor, licensee), entity type (individual, corporation, partnership, trust, government), jurisdiction of incorporation or domicile, representation status, party role effective date, party status (active, settled, dismissed, withdrawn), and KYC/AML screening reference. Critical for conflict checking, litigation management, corporate transaction advisory, and regulatory filing party disclosures.' .

ind:Hold rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Matter ;
    rdfs:label 'Hold' ;
    rdfs:comment 'Litigation hold, legal preservation notice, and investigation hold records issued in connection with a matter, capturing ESI (Electronically Stored Information) preservation obligations, eDiscovery scope metadata, and custodian acknowledgement tracking. Records hold type (litigation hold, regulatory hold, internal investigation hold, pre-litigation preservation), hold issuance date, hold custodians (individuals and departments), data categories and sources in scope, collection scope description, data volume estimates, issuing attorney, hold status (active, released, modified, expired), release date and reason, custodian acknowledgement status and date, reminder cadence, eDiscovery vendor reference, and Relativity workspace identifier. Supports eDiscovery readiness, proportionality assessment, ESI protocol compliance, GDPR/DPA data subject request management, and spoliation risk mitigation.' .

ind:PracticeArea rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Service ;
    rdfs:label 'Practice Area' ;
    rdfs:comment 'Master taxonomy of legal practice areas and sub-specializations offered by the firm (e.g., M&A, Litigation, IP, Employment Law, Regulatory Compliance, Real Estate). Supports hierarchical parent-child classification enabling roll-up reporting. Each practice area carries a unique code, description, active/inactive status, and regulatory body alignment. Used to categorize matters, timekeepers, service offerings, and rate cards across all firm systems.' .

ind:LegalService rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Service ;
    rdfs:label 'Legal Service' ;
    rdfs:comment 'Core catalog of legal service offerings available from the firm, including M&A advisory, litigation representation, IP counsel, regulatory compliance counseling, employment law advisory, and structured advisory packages. Each record defines a distinct service offering with its scope, practice area alignment, delivery model, and eligibility criteria. This is the SSOT for what the firm offers commercially and operationally, used in RFP responses, engagement letters (LOE), and business development pipelines in Microsoft Dynamics 365.' .

ind:Tier rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Service ;
    rdfs:label 'Tier' ;
    rdfs:comment 'Defines the tiered packaging levels for legal services (e.g., Standard, Premium, Enterprise, Bespoke). Each tier specifies the scope of coverage, included deliverables, response commitments, and eligibility for alternative fee arrangements (AFA). Used to structure RFP responses and engagement letter (LOE) terms. Enables differentiated pricing and SLA assignment across client segments.' .

ind:PricingModel rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Service ;
    rdfs:label 'Pricing Model' ;
    rdfs:comment 'Defines the fee structures and alternative fee arrangements (AFA) applicable to legal service offerings, including hourly billing, fixed fee, capped fee, blended rate, retainer, contingency, and success fee models. Each record captures the model type, calculation basis, currency, applicable jurisdictions, and LEDES/UTBMS billing code alignment. Serves as the authoritative pricing configuration referenced by billing and matter domains.' .

ind:RateCard rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Service ;
    rdfs:label 'Rate Card' ;
    rdfs:comment 'Stores the standard and negotiated timekeeper billing rates for legal services by practice area, seniority level (partner, associate, paralegal), jurisdiction, and client segment. Captures effective date ranges, currency, rate type (standard, preferred, blended), and UTBMS task code alignment. Feeds directly into Elite 3E and Aderant Expert rate management modules for WIP calculation and prebilling. Distinct from pricing_model which defines the fee structure type.' .

ind:SlaTemplate rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Service ;
    rdfs:label 'Sla Template' ;
    rdfs:comment 'Defines the service level agreement (SLA) templates governing response times, turnaround commitments, escalation thresholds, and quality standards for each legal service offering. Captures SLA type (matter response, document turnaround, court filing deadline, regulatory submission), target metrics, breach thresholds, and remediation terms. Used in LOE drafting, RFP responses, and matter management SLA monitoring. Distinct from individual matter-level SLA instances.' .

ind:Package rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Service ;
    rdfs:label 'Package' ;
    rdfs:comment 'Defines bundled legal service packages combining multiple legal_service offerings into structured advisory packages (e.g., Corporate Governance Bundle, M&A Full-Service Package, IP Portfolio Management Suite). Modeled as header+line: header captures package name, target client segment, minimum engagement term, pricing basis, cross-sell eligibility, and active/inactive status; line-level rows specify each constituent legal_service, its quantity or scope allocation within the package, sequencing order, optionality (mandatory vs. elective component), and any component-level pricing override. This is the SSOT for all package composition data. Enables cross-selling, structured RFP responses, and downstream matter-to-service mapping.' .

ind:JurisdictionCoverage rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Service ;
    rdfs:label 'Jurisdiction Coverage' ;
    rdfs:comment 'Defines the jurisdictional scope in which each legal service offering is available and licensed for delivery. Captures country, state/province, regulatory body (ABA, SRA, IBA, state bar), admission requirements, local counsel requirements, and any jurisdictional restrictions or caveats. Critical for conflict checking, RFP eligibility, and regulatory compliance counseling scope definition. Enables multi-jurisdictional matter staffing decisions.' .

ind:DeliveryModel rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Service ;
    rdfs:label 'Delivery Model' ;
    rdfs:comment 'Reference catalog of operational delivery models through which legal services are provided to clients. Covers traditional partner-led attorney teams, client secondments, ALSP (Alternative Legal Service Provider) co-delivery, managed legal services (MLS), legal process outsourcing (LPO), and hybrid models. Each record defines the staffing model type, resource composition, technology enablement approach, primary delivery geography, cost structure basis, and applicable service types. Referenced by legal_service definitions for default delivery configuration and used in capacity planning, RFP staffing proposals, and client reporting on delivery efficiency.' .

ind:EligibilityRule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Service ;
    rdfs:label 'Eligibility Rule' ;
    rdfs:comment 'Defines configurable business rules governing which clients or matters qualify for specific legal service offerings during new business intake. Rule types include client-type restrictions (corporate, government, individual), minimum matter value thresholds, jurisdictional licensing constraints, industry sector exclusions, and prerequisite clearance requirements. Each rule specifies evaluation logic, enforcement level (hard block preventing engagement vs. advisory warning requiring partner override), and the legal_service scope to which it applies. Consumed by the intake workflow engine during RFP qualification and matter opening. Note: this product defines the eligibility gating rules only — actual conflict-of-interest screening execution is owned by the conflict domain, and KYC/AML program management is owned by the compliance domain. This product references their clearance outcomes as prerequisite inputs.' .

ind:LpmTemplate rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Service ;
    rdfs:label 'Lpm Template' ;
    rdfs:comment 'Stores Legal Project Management (LPM) plan templates associated with specific legal service offerings, defining standard phases, milestones, task sequences, resource role requirements, budget allocation by phase, and risk checkpoints. Each template provides a reusable project structure for matter teams to instantiate when opening a new matter under a given service type. Supports consistent delivery, budget control, and client reporting across matters of the same service type.' .

ind:Line rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Service ;
    rdfs:label 'Line' ;
    rdfs:comment 'Defines the firm\'s operational business lines that group legal service offerings for P&L reporting, partner compensation allocation, strategic planning, and client-facing branding. Each service line (e.g., Corporate Advisory, Disputes & Investigations, Regulatory & Government Affairs, Transactional) aggregates multiple practice areas and legal services into a commercially-managed unit with its own revenue targets, leadership structure, and market positioning. Distinct from practice_area (which is a professional taxonomy) — service_line is the business management layer used in firm financials, lateral hiring decisions, and strategic growth planning.' .

ind:Outcome rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Matter ;
    rdfs:label 'Outcome' ;
    rdfs:comment 'Records the resolution, disposition, or completion of a matter including case outcomes for litigation (judgment, settlement, dismissal, verdict, consent order), transaction completions (signing, closing, abandonment), advisory deliverables (opinion delivered, memo issued), and regulatory outcomes (approval, denial, conditional approval). Captures outcome type, outcome date, outcome description, financial terms (settlement amount, damages awarded, transaction value), prevailing party, outcome status (preliminary, final, appealed), appeal deadline, satisfaction/compliance date, and lessons learned reference. Supports matter closure workflows, financial reporting of contingent outcomes, win/loss analytics, and practice group performance measurement.' .

ind:Assignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Matter ;
    rdfs:label 'Assignment' ;
    rdfs:comment 'This association product represents the Assignment between matter and timekeeper. It captures the staffing relationship where timekeepers are assigned to legal matters in specific roles (responsible attorney, supervising partner, billing attorney, associate, paralegal, etc.) with role-specific billing rates, time allocation budgets, and assignment lifecycle tracking. Each record links one matter to one timekeeper with attributes that exist only in the context of this specific assignment, enabling matter staffing management, resource allocation, billing rate overrides, and workload tracking across the firm.. Existence Justification: In legal practice, matters routinely require multiple timekeepers working in different roles (responsible attorney, supervising partner, associates, paralegals, legal assistants), and timekeepers work on multiple matters concurrently. The matter product already contains four separate FK attributes pointing to timekeeper for specific roles (attorney_profile_id, supervising_partner_attorney_profile_id, originating_attorney_attorney_profile_id, billing_attorney_attorney_profile_id), which is a classic anti-pattern indicating that a proper M:N association is needed. The detection reasoning explicitly states this is \'already modeled via matter_team and matter_assignment junction tables,\' confirming the business recognizes this as an operational M:N relationship.' .

ind:ProductionSet rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Document ;
    rdfs:label 'Production Set' ;
    rdfs:comment 'Master reference table for production_set. Referenced by production_set_id.' .

ind:TemplateClauseAssignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Template Clause Assignment' ;
    rdfs:comment 'This association product represents the deliberate composition relationship between a contract template and a clause from the approved clause library. It captures the operational act of a knowledge management or CLM team assigning a specific clause to a specific template, including whether the clause is mandatory in that template context, its structural position, and whether negotiators may override it. Each record links one template to one clause_library entry with attributes that exist only in the context of this specific template-clause pairing.. Existence Justification: In legal contract lifecycle management, templates are explicitly assembled from a curated library of approved clauses — a template contains many clauses, and a clause is reused across many templates. This is a core operational process actively managed by knowledge management and CLM teams: they assign specific clauses to templates, configure whether each clause is mandatory or optional in that template context, set its position/order, and control override permissions. The relationship is a recognized business concept in CLM systems (iManage, Ironclad, Conga all model this as an explicit junction entity called \'template clause assignment\' or similar).' .

ind:PackageServiceInclusion rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Service ;
    rdfs:label 'Package Service Inclusion' ;
    rdfs:comment 'This association product represents the inclusion contract between a service package and a constituent legal service offering. It captures the operational composition of each package — which legal services are included, in what sequence, at what scope or quantity, whether they are mandatory or elective components, any component-level pricing override, and the validity window for that inclusion. Each record links one package to one legal_service with attributes that exist only in the context of this bundling relationship. This is the SSOT for package composition and enables RFP line-item generation, engagement letter scoping, and cross-sell eligibility evaluation.. Existence Justification: In the legal services business, a package is explicitly defined as a bundle of multiple legal_service offerings — a single package (e.g., \'M&A Full-Service Package\') contains many constituent legal services, and a single legal service (e.g., \'M&A Advisory\') can appear in many different packages. This is a textbook composition relationship: the firm actively designs, manages, and versions these package-to-service inclusions as part of RFP responses, engagement structuring, and cross-sell strategy. The relationship itself carries operationally meaningful data (sequence order, quantity/scope allocation, optionality flag, component-level pricing override, effective dates) that belongs to neither the package header nor the service catalog record alone.' .

# --- Attribute Properties ---
ind:timekeeperRateId rdf:type rdf:Property ;
    rdfs:label 'Timekeeper Rate Id' ;
    rdfs:comment 'Unique surrogate identifier for each timekeeper rate record in the master rate card. Primary key for the timekeeper_rate data product.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TimekeeperRate .

ind:agreementId rdf:type rdf:Property ;
    rdfs:label 'Agreement Id' ;
    rdfs:comment 'Foreign key linking to contract.agreement. Business justification: Timekeeper rates are negotiated in client service agreements. Rate approval workflows verify rates against contracted terms, billing guideline compliance checks rates against agreements, rate disputes' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agreement .

ind:amendmentId rdf:type rdf:Property ;
    rdfs:label 'Amendment Id' ;
    rdfs:comment 'Foreign key linking to contract.amendment. Business justification: Contract amendments are the primary authorization mechanism for timekeeper rate changes in legal services. Linking timekeeper_rate to the authorizing amendment supports rate approval audit trails, bil' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Amendment .

ind:letterOfEngagementId rdf:type rdf:Property ;
    rdfs:label 'Letter Of Engagement Id' ;
    rdfs:comment 'Foreign key linking to intake.letter_of_engagement. Business justification: Timekeeper rates are negotiated and authorized within the LOE. Legal billing managers must verify approved rates against the LOE during rate setup and audits. A legal-services expert would expect to t' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LetterOfEngagement .

ind:matterId rdf:type rdf:Property ;
    rdfs:label 'Matter Id' ;
    rdfs:comment 'Reference to the specific matter for which this rate applies. Null when the rate is client-level or firm-wide rather than matter-specific.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Matter .

ind:practiceAreaId rdf:type rdf:Property ;
    rdfs:label 'Practice Area Id' ;
    rdfs:comment 'Foreign key linking to service.practice_area. Business justification: Timekeeper rates in legal firms are always scoped to a practice area (M&A rates differ from litigation rates). Legal billing managers report and approve rates by practice area for realization analysis' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PracticeArea .

ind:primarySupersededByRateTimekeeperRateId rdf:type rdf:Property ;
    rdfs:label 'Primary Superseded By Rate Timekeeper Rate Id' ;
    rdfs:comment 'Reference to the newer timekeeper_rate record that replaced this one when a rate was updated or renegotiated. Enables full rate history chain traversal for audit and billing dispute resolution.' ;
    rdfs:domain ind:TimekeeperRate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TimekeeperRate .

ind:profileId rdf:type rdf:Property ;
    rdfs:label 'Profile Id' ;
    rdfs:comment 'Reference to the client for whom this negotiated rate applies. Null when the rate is a standard firm-wide or practice-group rate not tied to a specific client.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Profile .

ind:rateCardId rdf:type rdf:Property ;
    rdfs:label 'Rate Card Id' ;
    rdfs:comment 'Foreign key linking to service.rate_card. Business justification: Timekeeper rates are derived from or negotiated against a specific rate card. Legal pricing teams track which rate card a timekeeper rate implements for rate approval workflows and client billing guid' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RateCard .

ind:tierId rdf:type rdf:Property ;
    rdfs:label 'Tier Id' ;
    rdfs:comment 'Foreign key linking to service.tier. Business justification: Timekeeper rates are differentiated by client service tier (Tier 1 clients receive discounted rates vs. standard clients). Legal pricing teams set and approve rates by tier. This link enables tier-bas' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Tier .

ind:afaArrangementCode rdf:type rdf:Property ;
    rdfs:label 'Afa Arrangement Code' ;
    rdfs:comment 'Reference code linking this rate to a specific Alternative Fee Arrangement (AFA) structure such as a fixed fee, capped fee, success fee, or retainer. Populated when rate_type is \'afa\' or \'flat_fee\'.' ;
    rdfs:domain ind:TimekeeperRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalStatus rdf:type rdf:Property ;
    rdfs:label 'Approval Status' ;
    rdfs:comment 'Workflow approval state of this rate record. Rates must progress through the approval workflow before being activated for time entry billing. Distinct from rate_status which reflects the operational lifecycle.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedBy rdf:type rdf:Property ;
    rdfs:label 'Approved By' ;
    rdfs:comment 'Name or identifier of the firm personnel (e.g., billing manager, CFO, managing partner) who approved this rate record. Required for audit trail and rate governance compliance.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approved Timestamp' ;
    rdfs:comment 'Date and time when this rate record received formal approval. Part of the rate governance audit trail.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:billingIncrementMins rdf:type rdf:Property ;
    rdfs:label 'Billing Increment Mins' ;
    rdfs:comment 'Minimum time increment in minutes used for rounding time entries billed at this rate (e.g., 6 minutes = 0.1 hour, 15 minutes = 0.25 hour). Governs WIP calculation granularity.' ;
    rdfs:domain ind:TimekeeperRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:blendedRatePoolCode rdf:type rdf:Property ;
    rdfs:label 'Blended Rate Pool Code' ;
    rdfs:comment 'Identifier for the blended rate pool to which this timekeeper rate contributes. Applicable when rate_type is \'blended\'; allows multiple timekeepers at different levels to be billed at a single agreed blended rate.' ;
    rdfs:domain ind:TimekeeperRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientAgreed rdf:type rdf:Property ;
    rdfs:label 'Client Agreed' ;
    rdfs:comment 'Indicates whether the client has formally agreed to or acknowledged this rate (True) or whether it is a firm-proposed rate pending client acceptance (False). Critical for billing disputes and engagement letter compliance.' ;
    rdfs:domain ind:TimekeeperRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clientAgreementDate rdf:type rdf:Property ;
    rdfs:label 'Client Agreement Date' ;
    rdfs:comment 'Date on which the client formally agreed to or acknowledged this rate, as documented in the engagement letter or rate agreement. Null if client_agreed is False.' ;
    rdfs:domain ind:TimekeeperRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:createdTimestamp rdf:type rdf:Property ;
    rdfs:label 'Created Timestamp' ;
    rdfs:comment 'Date and time when this rate record was first created in the system. Part of the audit trail for rate governance and compliance.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:currencyCode rdf:type rdf:Property ;
    rdfs:label 'Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the hourly rate is denominated (e.g., USD, GBP, EUR). Critical for multi-jurisdictional matters and cross-border billing.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveFrom rdf:type rdf:Property ;
    rdfs:label 'Effective From' ;
    rdfs:comment 'The date from which this rate becomes effective and may be applied to time entries. Defines the start of the rate validity period for WIP calculation and billing.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveUntil rdf:type rdf:Property ;
    rdfs:label 'Effective Until' ;
    rdfs:comment 'The date on which this rate ceases to be effective (inclusive). Null indicates an open-ended rate with no scheduled expiry. Enables rate history tracking and audit compliance.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hourlyRate rdf:type rdf:Property ;
    rdfs:label 'Hourly Rate' ;
    rdfs:comment 'The billable monetary rate per hour applied to time entries for this timekeeper under this rate record. This is the principal quantitative value of the rate card. Used in WIP (Work in Progress) calculation during time entry posting.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:jurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Code' ;
    rdfs:comment 'Code identifying the legal jurisdiction or geographic market to which this rate tier applies (e.g., US-NY, GB-ENG, EU). Supports jurisdiction-specific rate tiers required for multi-office and cross-border billing.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ledesTimekeeperClass rdf:type rdf:Property ;
    rdfs:label 'Ledes Timekeeper Class' ;
    rdfs:comment 'LEDES-standard timekeeper classification code used in electronic billing submissions to corporate clients and insurers (e.g., PT for Partner, AS for Associate, PL for Paralegal). Required for LEDES 1998B and LEDES XML format compliance.' ;
    rdfs:domain ind:TimekeeperRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Modified Timestamp' ;
    rdfs:comment 'Date and time when this rate record was last modified. Used for change tracking, audit compliance, and incremental data loading in the Databricks lakehouse silver layer.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:notes rdf:type rdf:Property ;
    rdfs:label 'Notes' ;
    rdfs:comment 'Free-text field for capturing additional context about this rate record, such as negotiation history, special conditions, client-specific billing instructions, or exceptions to standard rate policy.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:officeCode rdf:type rdf:Property ;
    rdfs:label 'Office Code' ;
    rdfs:comment 'Code identifying the firm office or location associated with this rate (e.g., NYC, LON, HKG). Rates may vary by office due to local market conditions and overhead structures.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proBonoFlag rdf:type rdf:Property ;
    rdfs:label 'Pro Bono Flag' ;
    rdfs:comment 'Indicates whether this rate record applies to pro bono work (True), where the hourly_rate may be zero or nominal. Used for pro bono hour tracking and ABA 50-hour pro bono reporting.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rateBasis rdf:type rdf:Property ;
    rdfs:label 'Rate Basis' ;
    rdfs:comment 'The unit of measure or billing basis against which the rate is applied. Most commonly per hour for standard timekeeping, but may be per day, per matter, per month, or fixed for AFA structures.' ;
    rdfs:domain ind:TimekeeperRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCapAmount rdf:type rdf:Property ;
    rdfs:label 'Rate Cap Amount' ;
    rdfs:comment 'Maximum monetary ceiling applied to this rate arrangement. Applicable for capped fee or AFA structures where total billing under this rate cannot exceed a defined threshold.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateCategory rdf:type rdf:Property ;
    rdfs:label 'Rate Category' ;
    rdfs:comment 'Business classification indicating the commercial basis of the rate: standard firm rate, client-negotiated rate, preferred panel rate, pro bono (zero or reduced), or secondment arrangement.' ;
    rdfs:domain ind:TimekeeperRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCode rdf:type rdf:Property ;
    rdfs:label 'Rate Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this rate record within the billing system (e.g., STD-PRTNR-2024, CLI-ABC-ASSOC). Used for LEDES electronic billing submissions and rate reconciliation.' ;
    rdfs:domain ind:TimekeeperRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateDiscountPct rdf:type rdf:Property ;
    rdfs:label 'Rate Discount Pct' ;
    rdfs:comment 'Percentage discount applied from the standard rate to arrive at the negotiated hourly rate for this client or matter. Used for rate realization analysis and profitability reporting (RPE, PPP, PEP KPIs).' ;
    rdfs:domain ind:TimekeeperRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateFloorAmount rdf:type rdf:Property ;
    rdfs:label 'Rate Floor Amount' ;
    rdfs:comment 'Minimum monetary floor for this rate arrangement. Used in contingency or success-fee structures where a minimum guaranteed fee applies regardless of outcome.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateIncreasePct rdf:type rdf:Property ;
    rdfs:label 'Rate Increase Pct' ;
    rdfs:comment 'Percentage change in the hourly rate compared to the prior rate record for this timekeeper/client/matter combination. Used for rate increase tracking, client notification compliance, and year-over-year rate analytics.' ;
    rdfs:domain ind:TimekeeperRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateReviewDate rdf:type rdf:Property ;
    rdfs:label 'Rate Review Date' ;
    rdfs:comment 'Scheduled date for the next periodic review of this rate. Supports annual rate increase cycles and client rate negotiation planning.' ;
    rdfs:domain ind:TimekeeperRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rateStatus rdf:type rdf:Property ;
    rdfs:label 'Rate Status' ;
    rdfs:comment 'Current lifecycle state of the rate record. Rates must be approved before being applied to time entries. Superseded rates are replaced by a newer version; expired rates have passed their effective end date.' ;
    rdfs:domain ind:TimekeeperRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateType rdf:type rdf:Property ;
    rdfs:label 'Rate Type' ;
    rdfs:comment 'Classification of the fee arrangement type governing this rate. Supports standard hourly, blended rate pools, contingency, flat fee, Alternative Fee Arrangement (AFA), and capped fee structures. [ENUM-REF-CANDIDATE: hourly|blended|contingency|flat_fee|afa|capped|success_fee|retainer — promote to reference product]' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemCode rdf:type rdf:Property ;
    rdfs:label 'Source System Code' ;
    rdfs:comment 'Identifies the operational system of record from which this rate record originated (Elite 3E, Aderant Expert, or manually entered). Supports data lineage and reconciliation in the lakehouse silver layer.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemRateCode rdf:type rdf:Property ;
    rdfs:label 'Source System Rate Code' ;
    rdfs:comment 'The native primary key or identifier of this rate record in the originating operational system (Elite 3E or Aderant Expert). Enables traceability and reconciliation between the lakehouse silver layer and the system of record.' ;
    rdfs:domain ind:TimekeeperRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardRate rdf:type rdf:Property ;
    rdfs:label 'Standard Rate' ;
    rdfs:comment 'The timekeeper\'s published standard rack rate before any client-specific negotiation or discount. Retained alongside the negotiated hourly_rate to enable rate discount analysis and realization reporting.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:timekeeperLevel rdf:type rdf:Property ;
    rdfs:label 'Timekeeper Level' ;
    rdfs:comment 'Professional classification or seniority tier of the timekeeper at the time this rate was set. Used for rate benchmarking, PPP/PEP analytics, and UTBMS task-based billing. [ENUM-REF-CANDIDATE: equity_partner|non_equity_partner|of_counsel|senior_associate|associate|paralegal|legal_assistant|staff_attorney|trainee — promote to reference product]' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utbmsTaskCode rdf:type rdf:Property ;
    rdfs:label 'Utbms Task Code' ;
    rdfs:comment 'UTBMS task code scoping this rate to a specific task category (e.g., L110 Fact Investigation, L210 Pleadings). Enables task-based billing and rate differentiation by activity type as required by corporate clients.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wipRateFlag rdf:type rdf:Property ;
    rdfs:label 'Wip Rate Flag' ;
    rdfs:comment 'Indicates whether this rate is the currently active rate used for WIP (Work in Progress) valuation on time entries. Only one rate per timekeeper/client/matter combination should be flagged True at any point in time.' ;
    rdfs:domain ind:TimekeeperRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:timeEntryId rdf:type rdf:Property ;
    rdfs:label 'Time Entry Id' ;
    rdfs:comment 'Unique system-generated identifier for each time entry record. Primary key for the time_entry data product in the billing domain.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TimeEntry .

ind:assetId rdf:type rdf:Property ;
    rdfs:label 'Asset Id' ;
    rdfs:comment 'Foreign key linking to ip.ip_asset. Business justification: IP prosecution billing requires tracking billable hours per IP asset for portfolio cost analysis and client reporting. Law firms run per-asset time reports to show clients prosecution costs by patent/' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:docReviewAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Doc Review Assignment Id' ;
    rdfs:comment 'Foreign key linking to document.doc_review_assignment. Business justification: Reviewers log time against specific document review assignments. Linking time entries to review assignments enables review productivity reporting (cost per assignment, hours per batch), supports TAR/C' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DocReviewAssignment .

ind:docVersionId rdf:type rdf:Property ;
    rdfs:label 'Doc Version Id' ;
    rdfs:comment 'Foreign key linking to document.doc_version. Business justification: Time entries for drafting, reviewing, or revising documents should reference the specific document version worked on. Enables version-level cost tracking, supports billing narrative accuracy, and is e' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DocVersion .

ind:docketId rdf:type rdf:Property ;
    rdfs:label 'Docket Id' ;
    rdfs:comment 'Foreign key linking to court.docket. Business justification: Attorneys record billable time directly against litigation dockets for LEDES billing, client reporting, and matter profitability analysis. Essential for court-related time tracking and outside counsel' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Docket .

ind:hearingId rdf:type rdf:Property ;
    rdfs:label 'Hearing Id' ;
    rdfs:comment 'Foreign key linking to court.hearing. Business justification: Time entries for hearing preparation, attendance, and follow-up reference specific hearings for accurate UTBMS task coding, client transparency, and billing guideline compliance in litigation matters.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Hearing .

ind:legalDocumentId rdf:type rdf:Property ;
    rdfs:label 'Legal Document Id' ;
    rdfs:comment 'Foreign key linking to document.legal_document. Business justification: Time entries reference specific documents worked on (drafting motions, reviewing contracts, redlining agreements). Required for task-based billing, UTBMS coding validation, and detailed client reporti' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalDocument .

ind:legalServiceId rdf:type rdf:Property ;
    rdfs:label 'Legal Service Id' ;
    rdfs:comment 'Foreign key linking to service.legal_service. Business justification: Time entries record work performed for a specific legal service (e.g., contract drafting, litigation support). Legal billing analysts report time and realization by service type for profitability anal' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalService .

ind:licenseAgreementId rdf:type rdf:Property ;
    rdfs:label 'License Agreement Id' ;
    rdfs:comment 'Foreign key linking to ip.license_agreement. Business justification: Time entries for license negotiation, drafting, and enforcement work are tied to specific license agreements. IP licensing billing requires tracking hours per license agreement for client matter budge' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LicenseAgreement .

ind:primaryTimekeeperRateId rdf:type rdf:Property ;
    rdfs:label 'Primary Timekeeper Rate Id' ;
    rdfs:comment 'Foreign key linking to billing.timekeeper_rate. Business justification: Time entries are billed using specific rate card entries. Currently time_entry has billing_rate (amount) and timekeeper_level (string) but no FK to the authoritative rate record. Adding timekeeper_rat' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TimekeeperRate .

ind:prosecutionEventId rdf:type rdf:Property ;
    rdfs:label 'Prosecution Event Id' ;
    rdfs:comment 'Foreign key linking to ip.prosecution_event. Business justification: Time entries for office action responses, examination interviews, and prosecution filings must link to the triggering prosecution event. IP billing reports require hours-by-prosecution-stage analysis.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProsecutionEvent .

ind:billableHours rdf:type rdf:Property ;
    rdfs:label 'Billable Hours' ;
    rdfs:comment 'Hours approved for billing to the client after any reductions, write-downs, or non-billable designations applied during the prebilling review process. May differ from hours_worked due to courtesy reductions, write-downs, or billing guidelines. Used as the basis for WIP value calculation.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Billed Timestamp' ;
    rdfs:comment 'Date and time when this time entry was included in a finalized invoice and transitioned to billed status. Used for WIP clearance, revenue recognition timing, and billing cycle reporting.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:billingGuidelineCompliant rdf:type rdf:Property ;
    rdfs:label 'Billing Guideline Compliant' ;
    rdfs:comment 'Indicates whether this time entry has been reviewed and confirmed as compliant with the client\'s outside counsel billing guidelines (True) or flagged as non-compliant (False). Non-compliant entries may be subject to write-down or rejection by the client.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billingPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Billing Period End' ;
    rdfs:comment 'End date of the billing period or billing cycle to which this time entry is allocated. Defines the cutoff for WIP inclusion in a billing run and supports period-close reporting.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Billing Period Start' ;
    rdfs:comment 'Start date of the billing period or billing cycle to which this time entry is allocated. Used for period-based WIP reporting, billing cutoff management, and monthly/quarterly revenue recognition.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:entryMethod rdf:type rdf:Property ;
    rdfs:label 'Entry Method' ;
    rdfs:comment 'Method by which the time entry was captured in the system. Manual entries are typed directly; timer entries are captured via running timer tools; mobile entries are submitted via mobile app; bulk_import entries are loaded from external sources; api entries are submitted programmatically.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryNumber rdf:type rdf:Property ;
    rdfs:label 'Entry Number' ;
    rdfs:comment 'Human-readable, externally referenceable identifier for the time entry as generated by the practice management system (e.g., Elite 3E or Aderant Expert). Used in prebilling, invoice line references, and LEDES export.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryStatus rdf:type rdf:Property ;
    rdfs:label 'Entry Status' ;
    rdfs:comment 'Current lifecycle status of the time entry as it progresses through the WIP management and billing workflow. Draft entries are in progress; submitted entries await approval; approved entries are ready for invoicing; billed entries have been included on an invoice; written_off entries have been removed from WIP; rejected entries require correction. [ENUM-REF-CANDIDATE: draft|submitted|approved|billed|written_off|rejected — promote to reference product]' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeArrangementType rdf:type rdf:Property ;
    rdfs:label 'Fee Arrangement Type' ;
    rdfs:comment 'Classification of the fee arrangement governing this time entry. Determines how the entry contributes to billing and revenue recognition. AFA (Alternative Fee Arrangement) entries may include capped fees, fixed fees, or success fees. [ENUM-REF-CANDIDATE: hourly|flat_fee|contingency|blended_rate|afa|pro_bono|retainer — promote to reference product]' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hoursWorked rdf:type rdf:Property ;
    rdfs:label 'Hours Worked' ;
    rdfs:comment 'Actual hours spent performing the work as recorded by the timekeeper, prior to any billing adjustments. Typically recorded in tenths of an hour (0.1 increments) per standard legal billing practice. Serves as the raw input before billable hours are determined.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isBillable rdf:type rdf:Property ;
    rdfs:label 'Is Billable' ;
    rdfs:comment 'Indicates whether this time entry is designated as billable to the client (True) or non-billable (False). Non-billable entries may include pro bono work, administrative time, or courtesy write-offs. Drives WIP accumulation and invoice inclusion logic.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isContingency rdf:type rdf:Property ;
    rdfs:label 'Is Contingency' ;
    rdfs:comment 'Indicates whether this time entry is recorded under a contingency fee arrangement (True), where billing is conditional on case outcome. Contingency entries accumulate WIP but are not invoiced until the contingency event occurs. Supports AFA tracking.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ledesLineItemNumber rdf:type rdf:Property ;
    rdfs:label 'Ledes Line Item Number' ;
    rdfs:comment 'The line item number assigned to this time entry in the LEDES electronic billing file submitted to the client or client billing system. Required for LEDES 1998B and LEDES XML format compliance and for reconciliation of electronic billing submissions.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lppProtected rdf:type rdf:Property ;
    rdfs:label 'Lpp Protected' ;
    rdfs:comment 'Indicates whether the narrative or details of this time entry are subject to Legal Professional Privilege (LPP) or attorney-client privilege protections (True). LPP-protected entries require restricted access controls and must be handled in compliance with privilege preservation obligations during eDiscovery and regulatory inquiries.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:narrative rdf:type rdf:Property ;
    rdfs:label 'Narrative' ;
    rdfs:comment 'Free-text description of the legal work performed, as entered by the timekeeper. Appears on client invoices and prebilling reports. Subject to Legal Professional Privilege (LPP) protections. Must be sufficiently detailed to satisfy ABA Model Rule 1.5 billing transparency requirements and client billing guidelines.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noCharge rdf:type rdf:Property ;
    rdfs:label 'No Charge' ;
    rdfs:comment 'Indicates whether this time entry has been designated as no-charge (True), meaning the work was performed but will not be billed to the client. Distinct from non-billable entries; no-charge entries may appear on invoices at zero value for transparency.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:phaseCode rdf:type rdf:Property ;
    rdfs:label 'Phase Code' ;
    rdfs:comment 'Code identifying the phase or stage of the matter to which this time entry belongs (e.g., pleadings, discovery, trial, closing). Used in Legal Project Management (LPM) for budget tracking against matter phases and milestone-based billing.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:practiceGroupCode rdf:type rdf:Property ;
    rdfs:label 'Practice Group Code' ;
    rdfs:comment 'Code identifying the practice group or department (e.g., Corporate, Litigation, IP, Employment) to which the timekeeper belongs at the time of entry. Supports practice group profitability reporting and resource allocation analytics.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proBonoCategory rdf:type rdf:Property ;
    rdfs:label 'Pro Bono Category' ;
    rdfs:comment 'Classification of the pro bono service type when the time entry is designated as pro bono (e.g., access to justice, nonprofit representation, government service). Null for non-pro-bono entries. Supports ABA pro bono reporting requirements and firm CSR metrics.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystem rdf:type rdf:Property ;
    rdfs:label 'Source System' ;
    rdfs:comment 'Identifies the originating operational system from which this time entry record was sourced into the data lakehouse. Supports data lineage, reconciliation, and audit traceability across the billing technology stack.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submittedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submitted Timestamp' ;
    rdfs:comment 'Date and time when the timekeeper formally submitted the time entry for approval. Marks the transition from draft to submitted status. Used for timekeeping compliance monitoring and late submission reporting.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:taskDescription rdf:type rdf:Property ;
    rdfs:label 'Task Description' ;
    rdfs:comment 'Structured description of the specific legal task performed, distinct from the free-text narrative. May be derived from or supplement the UTBMS task code with matter-specific context. Used in task-based matter management and Legal Project Management (LPM) reporting.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utbmsActivityCode rdf:type rdf:Property ;
    rdfs:label 'Utbms Activity Code' ;
    rdfs:comment 'UTBMS standardized activity code describing the specific activity performed within the task (e.g., A101 for Plan and Prepare, A102 for Research, A103 for Draft/Revise). Used in conjunction with utbms_task_code for granular task-based billing analysis and LEDES export.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utbmsExpenseCode rdf:type rdf:Property ;
    rdfs:label 'Utbms Expense Code' ;
    rdfs:comment 'UTBMS expense code applicable when the time entry is associated with a disbursement or expense component (e.g., E101 for Copying, E106 for Computer Research). Nullable for pure time entries with no expense component.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wipAmount rdf:type rdf:Property ;
    rdfs:label 'Wip Amount' ;
    rdfs:comment 'The monetary value of unbilled work represented by this time entry, calculated as billable_hours multiplied by billing_rate. Represents the WIP balance contribution of this entry. Reduced to zero when the entry is billed or written off.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workDate rdf:type rdf:Property ;
    rdfs:label 'Work Date' ;
    rdfs:comment 'The calendar date on which the legal work was actually performed. This is the principal business event date for the time entry, distinct from the date the entry was created or submitted in the system. Critical for WIP aging, billing period cutoffs, and matter chronology.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:writeDownAmount rdf:type rdf:Property ;
    rdfs:label 'Write Down Amount' ;
    rdfs:comment 'The monetary amount by which the original WIP value of this entry was reduced during prebilling review or billing adjustment. Represents the difference between the originally recorded WIP value and the amount actually billed. Used for realization rate analysis and partner performance reporting.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:writeDownReasonCode rdf:type rdf:Property ;
    rdfs:label 'Write Down Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for any write-down applied to this time entry (e.g., client discount, billing guideline non-compliance, courtesy reduction, duplicate entry). Required for realization analysis and billing adjustment reporting.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingDisbursementId rdf:type rdf:Property ;
    rdfs:label 'Billing Disbursement Id' ;
    rdfs:comment 'Unique surrogate identifier for each disbursement record in the billing domain. Primary key for the disbursement data product in the Databricks Silver Layer.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillingDisbursement .

ind:docketDeadlineId rdf:type rdf:Property ;
    rdfs:label 'Docket Deadline Id' ;
    rdfs:comment 'Foreign key linking to ip.docket_deadline. Business justification: Annuity payments and official fee disbursements are triggered by docket deadlines. Linking disbursement to the deadline that triggered it supports IP compliance cost reporting and confirms that deadli' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DocketDeadline .

ind:feeArrangementId rdf:type rdf:Property ;
    rdfs:label 'Fee Arrangement Id' ;
    rdfs:comment 'Foreign key linking to billing.fee_arrangement. Business justification: Disbursements occur within the context of a fee arrangement, which governs whether expenses are billable, subject to caps, or excluded. Currently disbursement has fee_arrangement_type (string code) bu' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FeeArrangement .

ind:filingId rdf:type rdf:Property ;
    rdfs:label 'Filing Id' ;
    rdfs:comment 'Foreign key linking to court.filing. Business justification: Filing fees are direct costs tied to specific court filings. Firms track disbursements per filing for accurate cost recovery, client transparency, and LEDES compliance.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Filing .

ind:productionSetId rdf:type rdf:Property ;
    rdfs:label 'Production Set Id' ;
    rdfs:comment 'Foreign key linking to document.production_set. Business justification: Document productions incur disbursements (printing, media, delivery, processing vendor fees) tracked at the production set level. Firms bill clients for production costs per set. A litigation billing ' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductionSet .

ind:trustAccountId rdf:type rdf:Property ;
    rdfs:label 'Trust Account Id' ;
    rdfs:comment 'Foreign key linking to trust.account. Business justification: Billing disbursements (court fees, filing costs) are frequently funded directly from client trust accounts. Regulatory compliance and three-way reconciliation require tracing each trust-funded disburs' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:amount rdf:type rdf:Property ;
    rdfs:label 'Amount' ;
    rdfs:comment 'The gross amount of the disbursement as incurred or paid, before any tax, markup, or write-down adjustments. Represents the base cost for WIP accumulation and billing calculations.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedDate rdf:type rdf:Property ;
    rdfs:label 'Approved Date' ;
    rdfs:comment 'The date on which the disbursement was approved for billing by the responsible partner or billing supervisor. Used for billing workflow tracking and audit compliance.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:baseCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Base Currency Amount' ;
    rdfs:comment 'The disbursement amount converted to the firm\'s base billing currency using the applicable exchange rate. Used for consolidated financial reporting, Profit Per Partner (PPP) and Revenue Per Equity Partner (RPE) KPI calculations.' ;
    rdfs:domain ind:BillingDisbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billedAmount rdf:type rdf:Property ;
    rdfs:label 'Billed Amount' ;
    rdfs:comment 'The amount actually billed to the client on the invoice, after applying any markup, write-down, or billing adjustment. May differ from the disbursement amount if a write-down was applied during prebilling review.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingDisbursementDescription rdf:type rdf:Property ;
    rdfs:label 'Billing Disbursement Description' ;
    rdfs:comment 'Narrative description of the disbursement as it will appear on the client invoice and in the billing system. Describes the nature of the expense incurred (e.g., \'Court filing fee — Superior Court of California\', \'Expert witness fee — Dr. J. Smith\'). Supports LEDES line-item narrative requirements.' ;
    rdfs:domain ind:BillingDisbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingPeriod rdf:type rdf:Property ;
    rdfs:label 'Billing Period' ;
    rdfs:comment 'The billing period (YYYY-MM) to which the disbursement is allocated for invoicing purposes. Used for period-based WIP reporting, prebilling, and financial close processes.' ;
    rdfs:domain ind:BillingDisbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCentreCode rdf:type rdf:Property ;
    rdfs:label 'Cost Centre Code' ;
    rdfs:comment 'The internal cost centre code to which the disbursement is attributed for management accounting and profitability reporting purposes.' ;
    rdfs:domain ind:BillingDisbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disbursementNumber rdf:type rdf:Property ;
    rdfs:label 'Disbursement Number' ;
    rdfs:comment 'Externally visible, human-readable reference number assigned to the disbursement record. Used for audit trails, client queries, and cross-system reconciliation with Elite 3E and Aderant Expert.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disbursementStatus rdf:type rdf:Property ;
    rdfs:label 'Disbursement Status' ;
    rdfs:comment 'Current lifecycle state of the disbursement record. \'wip\' indicates the cost is in Work in Progress (WIP) awaiting billing; \'billed\' indicates it has been included on a client invoice; \'written_off\' indicates the amount has been written off and will not be recovered.' ;
    rdfs:domain ind:BillingDisbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disbursementType rdf:type rdf:Property ;
    rdfs:label 'Disbursement Type' ;
    rdfs:comment 'Classifies the disbursement as a hard disbursement (direct out-of-pocket cost paid to a third party on behalf of the client, e.g., court filing fees, expert witness fees) or a soft disbursement (internal overhead recovery, e.g., photocopying, internal printing). Determines pass-through billing treatment.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryDate rdf:type rdf:Property ;
    rdfs:label 'Entry Date' ;
    rdfs:comment 'The date on which the disbursement was entered into the practice management system. May differ from the expense date when costs are posted retrospectively. Used for WIP aging calculations from the entry date perspective.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exchangeRate rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate' ;
    rdfs:comment 'The foreign exchange rate applied to convert the disbursement amount from the transaction currency to the firm\'s base billing currency at the time of entry. Used for multi-currency matter billing and financial consolidation.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expenseCategory rdf:type rdf:Property ;
    rdfs:label 'Expense Category' ;
    rdfs:comment 'Internal firm classification of the disbursement type used for cost management and reporting (e.g., court_filing, expert_witness, travel, courier, photocopying, translation, process_server, deposition). [ENUM-REF-CANDIDATE: court_filing|expert_witness|travel|courier|photocopying|translation|process_server|deposition|search_fee|recording_fee — promote to reference product]' ;
    rdfs:domain ind:BillingDisbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expenseDate rdf:type rdf:Property ;
    rdfs:label 'Expense Date' ;
    rdfs:comment 'The real-world date on which the disbursement was incurred or the expense was paid. This is the principal business event date used for WIP aging, billing period allocation, and financial reporting.' ;
    rdfs:domain ind:BillingDisbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:glAccountCode rdf:type rdf:Property ;
    rdfs:label 'Gl Account Code' ;
    rdfs:comment 'The General Ledger (GL) account code to which the disbursement is posted in the firm\'s accounting system. Used for financial reporting, cost allocation, and Sarbanes-Oxley (SOX) compliance.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isTaxable rdf:type rdf:Property ;
    rdfs:label 'Is Taxable' ;
    rdfs:comment 'Indicates whether the disbursement is subject to applicable taxes (e.g., VAT, GST) when billed to the client. Drives tax calculation logic in the billing system.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ledesExpenseCode rdf:type rdf:Property ;
    rdfs:label 'Ledes Expense Code' ;
    rdfs:comment 'The Legal Electronic Data Exchange Standard (LEDES) expense code used in electronic billing submissions to corporate clients and insurance companies. Aligns with LEDES 1998B and LEDES XML format requirements.' ;
    rdfs:domain ind:BillingDisbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:markupPercentage rdf:type rdf:Property ;
    rdfs:label 'Markup Percentage' ;
    rdfs:comment 'Percentage markup applied to the base disbursement amount when billing to the client. Common for soft disbursements such as photocopying or printing where the firm applies a standard recovery rate above cost. Zero for hard disbursements passed through at cost.' ;
    rdfs:domain ind:BillingDisbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:narrativeForClient rdf:type rdf:Property ;
    rdfs:label 'Narrative For Client' ;
    rdfs:comment 'The client-facing narrative or description of the disbursement as it appears on the client invoice. May differ from the internal description field. Supports compliance with client billing guidelines and Alternative Fee Arrangement (AFA) reporting requirements.' ;
    rdfs:domain ind:BillingDisbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantity rdf:type rdf:Property ;
    rdfs:label 'Quantity' ;
    rdfs:comment 'The quantity or unit count associated with the disbursement where applicable (e.g., number of pages photocopied, number of miles travelled, number of documents served). Used with unit_rate to derive the disbursement amount for volume-based expenses.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receiptReference rdf:type rdf:Property ;
    rdfs:label 'Receipt Reference' ;
    rdfs:comment 'Reference number or identifier for the receipt or proof of payment supporting the disbursement. Used for expense substantiation, audit compliance, and client billing dispute resolution.' ;
    rdfs:domain ind:BillingDisbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recoveryStatus rdf:type rdf:Property ;
    rdfs:label 'Recovery Status' ;
    rdfs:comment 'Indicates the current recovery status of the disbursement cost from the client. \'unrecovered\' means the cost has not yet been billed or paid; \'partially_recovered\' means a portion has been collected; \'fully_recovered\' means the full amount has been received; \'written_off\' means recovery has been abandoned.' ;
    rdfs:domain ind:BillingDisbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Amount' ;
    rdfs:comment 'The tax amount (e.g., VAT, GST, sales tax) applicable to the disbursement as billed to the client. Calculated based on the applicable tax code and jurisdiction. Required for tax compliance reporting.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxCode rdf:type rdf:Property ;
    rdfs:label 'Tax Code' ;
    rdfs:comment 'The tax code applied to the disbursement to determine the applicable tax rate and treatment (e.g., VAT standard rate, zero-rated, exempt). Sourced from the firm\'s tax configuration in Elite 3E.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitRate rdf:type rdf:Property ;
    rdfs:label 'Unit Rate' ;
    rdfs:comment 'The per-unit rate applied to the quantity to calculate the disbursement amount (e.g., cost per page, cost per mile). Used for volume-based soft disbursements such as photocopying and mileage recovery.' ;
    rdfs:domain ind:BillingDisbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:updatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Updated Timestamp' ;
    rdfs:comment 'The timestamp when the disbursement record was last modified in the source system. Used for change data capture (CDC), audit trail, and Silver Layer incremental load processing.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:vendorInvoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Invoice Number' ;
    rdfs:comment 'The invoice or reference number from the third-party vendor\'s invoice supporting the disbursement. Used for accounts payable reconciliation and audit trail purposes.' ;
    rdfs:domain ind:BillingDisbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorName rdf:type rdf:Property ;
    rdfs:label 'Vendor Name' ;
    rdfs:comment 'Name of the third-party vendor, supplier, or service provider from whom the disbursement cost was incurred (e.g., court, expert witness firm, courier company, translation agency). Applicable primarily to hard disbursements.' ;
    rdfs:domain ind:BillingDisbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:writeOffReason rdf:type rdf:Property ;
    rdfs:label 'Write Off Reason' ;
    rdfs:comment 'The reason code explaining why the disbursement was written off or written down. Used for profitability analysis, billing quality management, and partner performance reporting.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wipLedgerId rdf:type rdf:Property ;
    rdfs:label 'Wip Ledger Id' ;
    rdfs:comment 'Unique surrogate identifier for each WIP ledger entry. Primary key for the wip_ledger data product in the billing domain.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WipLedger .

ind:primaryWipMatterId rdf:type rdf:Property ;
    rdfs:label 'Primary Wip Matter Id' ;
    rdfs:comment 'Reference to the matter against which this WIP entry is recorded. Matters are the primary billing unit in legal practice management.' ;
    rdfs:domain ind:WipLedger ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Matter .

ind:wipTimeEntryId rdf:type rdf:Property ;
    rdfs:label 'Wip Time Entry Id' ;
    rdfs:comment 'FK to billing.time_entry.time_entry_id — WIP ledger entries accumulate from time entries. This link enables WIP drill-down to source time records and supports WIP aging analysis at the entry level.' ;
    rdfs:domain ind:WipLedger ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TimeEntry .

ind:agingBucket rdf:type rdf:Property ;
    rdfs:label 'Aging Bucket' ;
    rdfs:comment 'Categorical aging classification of the WIP entry based on wip_age_days. Used in WIP aging reports for financial management, partner reviews, and collections strategy. Buckets align with standard legal industry WIP aging reporting conventions.' ;
    rdfs:domain ind:WipLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingOfficeCode rdf:type rdf:Property ;
    rdfs:label 'Billing Office Code' ;
    rdfs:comment 'Reference to the firm office responsible for billing this WIP entry. Used for office-level revenue attribution, PPP/PEP calculations by office, and financial reporting segmentation.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingRate rdf:type rdf:Property ;
    rdfs:label 'Billing Rate' ;
    rdfs:comment 'The standard billing rate per hour applied to this WIP entry, expressed in the matter currency. Reflects the timekeeper\'s rate for the applicable billing period and client rate agreement. Confidential as it reflects negotiated client pricing.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isContingencyAccrual rdf:type rdf:Property ;
    rdfs:label 'Is Contingency Accrual' ;
    rdfs:comment 'Indicates whether this WIP entry represents an accrued contingency fee amount (True) that is not yet realised pending case outcome. Contingency WIP is tracked separately for financial reporting and is only recognised as revenue upon successful resolution.' ;
    rdfs:domain ind:WipLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Modified Timestamp' ;
    rdfs:comment 'The date and time when this WIP ledger record was most recently updated in the source practice management system. Used for incremental data loading, change detection, and audit trail maintenance in the Silver layer.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:standardAmount rdf:type rdf:Property ;
    rdfs:label 'Standard Amount' ;
    rdfs:comment 'The WIP value calculated at the timekeeper\'s standard rack rate (hours_worked multiplied by standard_rate). Used to measure the variance between standard and billed value, supporting write-up/write-down analysis and profitability reporting.' ;
    rdfs:domain ind:WipLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wipAccumulatesDisbursement rdf:type rdf:Property ;
    rdfs:label 'Wip Accumulates Disbursement' ;
    rdfs:comment 'FK to billing.disbursement.disbursement_id — WIP ledger entries also accumulate from disbursements. This FK enables complete WIP composition analysis.' ;
    rdfs:domain ind:WipLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wipAgeDays rdf:type rdf:Property ;
    rdfs:label 'Wip Age Days' ;
    rdfs:comment 'Number of calendar days elapsed since the work_date of this WIP entry. Used to populate WIP aging buckets (0-30, 31-60, 61-90, 90+ days) for financial reporting, collections prioritisation, and partner performance reviews.' ;
    rdfs:domain ind:WipLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wipAmountFirmCurrency rdf:type rdf:Property ;
    rdfs:label 'Wip Amount Firm Currency' ;
    rdfs:comment 'The WIP amount converted to the firm\'s functional reporting currency using the exchange_rate. Enables consolidated WIP reporting, PPP, PEP, and RPE calculations across matters billed in multiple currencies.' ;
    rdfs:domain ind:WipLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wipEntryNumber rdf:type rdf:Property ;
    rdfs:label 'Wip Entry Number' ;
    rdfs:comment 'Externally visible, human-readable business identifier for this WIP ledger entry as assigned by the practice management system (e.g., Elite 3E transaction number). Used for cross-system reconciliation and audit trails.' ;
    rdfs:domain ind:WipLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wipStatus rdf:type rdf:Property ;
    rdfs:label 'Wip Status' ;
    rdfs:comment 'Current lifecycle state of the WIP ledger entry. \'open\' indicates unbilled WIP available for prebilling; \'billed\' indicates the entry has been included on an invoice; \'written_off\' indicates the amount has been written off; \'transferred\' indicates the WIP has been moved to another matter; \'on_hold\' indicates billing is suspended; \'reversed\' indicates the entry has been reversed.' ;
    rdfs:domain ind:WipLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wipType rdf:type rdf:Property ;
    rdfs:label 'Wip Type' ;
    rdfs:comment 'Classification of the WIP entry by nature of the charge. \'time\' represents billable hours; \'disbursement\' represents client-chargeable out-of-pocket costs; \'expense\' represents firm expenses; \'fixed_fee\' represents flat-fee milestone charges; \'contingency\' represents contingency-based accruals.' ;
    rdfs:domain ind:WipLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workDescription rdf:type rdf:Property ;
    rdfs:label 'Work Description' ;
    rdfs:comment 'Narrative description of the work performed or disbursement incurred as entered by the timekeeper. Appears on prebill and client invoice. Subject to billing guidelines review and may be edited during the prebilling process.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:writeOffAmount rdf:type rdf:Property ;
    rdfs:label 'Write Off Amount' ;
    rdfs:comment 'The monetary value of WIP that has been written off and will not be billed to the client. Populated when wip_status is \'written_off\'. Used in realisation rate calculations and partner performance reviews.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:writeOffReasonCode rdf:type rdf:Property ;
    rdfs:label 'Write Off Reason Code' ;
    rdfs:comment 'Standardised reason code explaining why the WIP entry was written off (e.g., client dispute, fee cap exceeded, courtesy write-off, uncollectable). Populated when wip_status is \'written_off\'. Used in write-off analysis and partner performance reporting. [ENUM-REF-CANDIDATE: client_dispute|fee_cap_exceeded|courtesy|uncollectable|billing_error|matter_closed — promote to reference product]' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:writeUpDownAmount rdf:type rdf:Property ;
    rdfs:label 'Write Up Down Amount' ;
    rdfs:comment 'The monetary adjustment applied to the WIP entry representing the difference between the standard amount and the billed amount. Positive values indicate a write-up (billing above standard); negative values indicate a write-down (billing below standard). Critical for realisation rate analysis and partner performance reporting.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prebillId rdf:type rdf:Property ;
    rdfs:label 'Prebill Id' ;
    rdfs:comment 'Unique system-generated identifier for the prebill record. Primary key for the prebill data product in the billing domain.' ;
    rdfs:domain ind:Prebill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:invoiceId rdf:type rdf:Property ;
    rdfs:label 'Invoice Id' ;
    rdfs:comment 'Reference to the final invoice generated from this approved prebill. Populated once the prebill transitions to approved status and the invoice is created. Null if the prebill has not yet been converted to an invoice.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:prebillLedesMatterId rdf:type rdf:Property ;
    rdfs:label 'Prebill Ledes Matter Id' ;
    rdfs:comment 'Client-assigned matter identifier formatted per LEDES electronic billing standards. Required for electronic invoice submission to corporate clients and insurance carriers using LEDES-compliant billing systems.' ;
    rdfs:domain ind:Prebill ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Matter .

ind:prebillMatterId rdf:type rdf:Property ;
    rdfs:label 'Prebill Matter Id' ;
    rdfs:comment 'Reference to the matter against which this prebill is generated. Links the prebill to the specific legal matter or case being billed.' ;
    rdfs:domain ind:Prebill ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Matter .

ind:billingFrequency rdf:type rdf:Property ;
    rdfs:label 'Billing Frequency' ;
    rdfs:comment 'Cadence at which invoices are issued for this matter, as agreed in the engagement letter. Drives prebill generation scheduling: monthly, quarterly, at defined milestones, on-demand, or annually.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingGuidelineVersion rdf:type rdf:Property ;
    rdfs:label 'Billing Guideline Version' ;
    rdfs:comment 'Version identifier of the client billing guidelines applied during prebill review and compliance checking. Corporate clients and insurers issue versioned billing guidelines that restrict rates, timekeepers, task codes, and narrative formats.' ;
    rdfs:domain ind:Prebill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Billing Period End Date' ;
    rdfs:comment 'Last date of the billing period covered by this prebill. Defines the inclusive end of the Work in Progress (WIP) window extracted for review.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Billing Period Start Date' ;
    rdfs:comment 'First date of the billing period covered by this prebill. Defines the inclusive start of the Work in Progress (WIP) window extracted for review.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disbursementAdjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Disbursement Adjustment Amount' ;
    rdfs:comment 'Net adjustment applied to disbursements on this prebill. Positive values indicate write-up; negative values indicate write-down or non-billable disbursement exclusions.' ;
    rdfs:domain ind:Prebill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feeWritedownAmount rdf:type rdf:Property ;
    rdfs:label 'Fee Writedown Amount' ;
    rdfs:comment 'Negative adjustment applied to WIP fees to reduce the billed amount below the standard rate value. Reflects billing guideline compliance, client relationship management, or billing attorney discretion. Stored as a positive number representing the reduction.' ;
    rdfs:domain ind:Prebill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feeWriteupAmount rdf:type rdf:Property ;
    rdfs:label 'Fee Writeup Amount' ;
    rdfs:comment 'Positive adjustment applied to WIP fees to increase the billed amount above the standard rate value. Reflects premium billing for exceptional work, complexity, or successful outcomes. A zero value indicates no write-up was applied.' ;
    rdfs:domain ind:Prebill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:generatedDate rdf:type rdf:Property ;
    rdfs:label 'Generated Date' ;
    rdfs:comment 'Calendar date on which the prebill draft was generated from the WIP ledger. Represents the principal business event timestamp for the prebill lifecycle.' ;
    rdfs:domain ind:Prebill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:guidelineViolationCount rdf:type rdf:Property ;
    rdfs:label 'Guideline Violation Count' ;
    rdfs:comment 'Number of individual billing guideline violations detected on this prebill during automated compliance checking. A count of zero indicates full compliance. Used to prioritize prebill review effort.' ;
    rdfs:domain ind:Prebill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:narrativeEdited rdf:type rdf:Property ;
    rdfs:label 'Narrative Edited' ;
    rdfs:comment 'Indicates whether any time entry or disbursement narrative was edited during the prebill review process. True = narratives were modified; False = original narratives retained. Supports billing quality audit and Legal Professional Privilege (LPP) review.' ;
    rdfs:domain ind:Prebill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:onAccountCreditApplied rdf:type rdf:Property ;
    rdfs:label 'On Account Credit Applied' ;
    rdfs:comment 'Amount of retainer or on-account funds applied against this prebill to reduce the net amount due. Relevant for matters operating under a retainer or advance payment arrangement. Zero if no on-account funds are applied.' ;
    rdfs:domain ind:Prebill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prebillNumber rdf:type rdf:Property ;
    rdfs:label 'Prebill Number' ;
    rdfs:comment 'Externally visible, human-readable identifier for the prebill draft. Used by billing staff and attorneys to reference the prebill during review and approval workflows. Format: PB-YYYY-NNNNNN.' ;
    rdfs:domain ind:Prebill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prebillStatus rdf:type rdf:Property ;
    rdfs:label 'Prebill Status' ;
    rdfs:comment 'Current workflow state of the prebill in the billing quality control process. Drives routing logic: draft (initial WIP extraction), under_review (sent to billing attorney), approved (ready for invoice generation), rejected (returned for correction), on_hold (pending client instruction), cancelled (abandoned). [ENUM-REF-CANDIDATE: draft|under_review|approved|rejected|on_hold|cancelled — promote to reference product]' ;
    rdfs:domain ind:Prebill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Prior Balance Amount' ;
    rdfs:comment 'Outstanding accounts receivable balance from prior invoices for this matter as of the prebill generation date. Displayed on the prebill for attorney awareness and collections follow-up context.' ;
    rdfs:domain ind:Prebill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proposedDisbursementsAmount rdf:type rdf:Property ;
    rdfs:label 'Proposed Disbursements Amount' ;
    rdfs:comment 'Net disbursement amount proposed for invoicing after applying disbursement adjustments. Represents the billable expense total to be carried forward to the final invoice.' ;
    rdfs:domain ind:Prebill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proposedFeesAmount rdf:type rdf:Property ;
    rdfs:label 'Proposed Fees Amount' ;
    rdfs:comment 'Net fee amount proposed for invoicing after applying write-up and write-down adjustments to WIP fees. Equals wip_fees_amount plus fee_writeup_amount minus fee_writedown_amount.' ;
    rdfs:domain ind:Prebill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proposedTotalAmount rdf:type rdf:Property ;
    rdfs:label 'Proposed Total Amount' ;
    rdfs:comment 'Total proposed invoice value combining adjusted fees and adjusted disbursements. This is the gross amount that will appear on the final invoice if the prebill is approved without further changes.' ;
    rdfs:domain ind:Prebill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rejectionReason rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason' ;
    rdfs:comment 'Free-text or coded reason provided by the reviewing attorney when rejecting the prebill. Documents the basis for rejection (e.g., narrative edits required, rate corrections needed, time entries disputed) to guide billing staff corrections.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sentForReviewTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sent For Review Timestamp' ;
    rdfs:comment 'Timestamp when the prebill was dispatched to the billing attorney for review. Marks the transition from draft to under_review status. Used to measure prebill review cycle time.' ;
    rdfs:domain ind:Prebill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:timekeeperCount rdf:type rdf:Property ;
    rdfs:label 'Timekeeper Count' ;
    rdfs:comment 'Number of distinct timekeepers (attorneys, paralegals, legal assistants) whose time entries are included in this prebill. Used for staffing analysis and billing guideline compliance (e.g., restrictions on number of timekeepers per matter).' ;
    rdfs:domain ind:Prebill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalHoursBilled rdf:type rdf:Property ;
    rdfs:label 'Total Hours Billed' ;
    rdfs:comment 'Aggregate billable hours included in this prebill across all timekeepers and time entries within the billing period. Applicable for hourly and blended-rate fee arrangements.' ;
    rdfs:domain ind:Prebill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wipDisbursementsAmount rdf:type rdf:Property ;
    rdfs:label 'Wip Disbursements Amount' ;
    rdfs:comment 'Total gross value of unbilled disbursement and expense entries extracted for this prebill before any adjustments. Includes hard costs (court fees, filing fees, expert witness fees) and soft costs (photocopying, postage).' ;
    rdfs:domain ind:Prebill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wipFeesAmount rdf:type rdf:Property ;
    rdfs:label 'Wip Fees Amount' ;
    rdfs:comment 'Total gross value of unbilled fee time entries (Work in Progress) extracted for this prebill before any adjustments. Represents the raw billable fees from timekeeper entries within the billing period.' ;
    rdfs:domain ind:Prebill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wipTotalAmount rdf:type rdf:Property ;
    rdfs:label 'Wip Total Amount' ;
    rdfs:comment 'Combined gross value of all WIP fees and disbursements extracted for this prebill prior to any write-up, write-down, or adjustment. Equals wip_fees_amount plus wip_disbursements_amount.' ;
    rdfs:domain ind:Prebill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:governingAmendmentId rdf:type rdf:Property ;
    rdfs:label 'Governing Amendment Id' ;
    rdfs:comment 'Foreign key linking to contract.amendment. Business justification: Post-amendment invoices must reference the governing amendment to ensure correct rate application and billing guideline version compliance. Legal e-billing audits and client disputes frequently requir' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Amendment .

ind:originatingInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Originating Invoice Id' ;
    rdfs:comment 'For credit notes and adjustment invoices, the invoice_id of the original invoice being credited, reversed, or adjusted. Null for standard invoices. Enables full credit note lineage tracing.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:amountPaid rdf:type rdf:Property ;
    rdfs:label 'Amount Paid' ;
    rdfs:comment 'Cumulative amount received against this invoice to date. Used to calculate the outstanding balance and determine partially_paid vs paid status.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditApplicationStatus rdf:type rdf:Property ;
    rdfs:label 'Credit Application Status' ;
    rdfs:comment 'Tracks whether a credit note has been applied against outstanding invoices. Pending means unapplied; applied means fully offset; partially_applied means partially offset; voided means the credit was cancelled. Populated only for credit notes.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditReason rdf:type rdf:Property ;
    rdfs:label 'Credit Reason' ;
    rdfs:comment 'Narrative explanation for the issuance of a credit note, including the business justification (e.g., billing error, fee reduction, client dispute resolution, write-off). Populated only when invoice_type = credit_note.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disbursementsAmount rdf:type rdf:Property ;
    rdfs:label 'Disbursements Amount' ;
    rdfs:comment 'Total of all client disbursements (hard costs and soft costs) billed on this invoice, including court filing fees, expert witness fees, travel, and photocopying charges.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discountAmount rdf:type rdf:Property ;
    rdfs:label 'Discount Amount' ;
    rdfs:comment 'Total monetary discount applied to this invoice, including courtesy discounts, volume discounts, and write-downs negotiated under AFA or client billing guidelines. Reduces the gross fees amount.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeReason rdf:type rdf:Property ;
    rdfs:label 'Dispute Reason' ;
    rdfs:comment 'Client-provided reason for disputing the invoice (e.g., rate discrepancy, unapproved timekeeper, excessive hours, duplicate charge). Populated when invoice_status = disputed.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Date' ;
    rdfs:comment 'Date on which a disputed invoice was resolved, either through client agreement, write-down, or credit note issuance. Used to measure dispute cycle time and collections effectiveness.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dueDate rdf:type rdf:Property ;
    rdfs:label 'Due Date' ;
    rdfs:comment 'Date by which payment is contractually due per the engagement letter or client billing agreement. Used to calculate overdue status and trigger collections workflows.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ebillingPortal rdf:type rdf:Property ;
    rdfs:label 'Ebilling Portal' ;
    rdfs:comment 'Name or identifier of the client\'s e-billing portal to which the LEDES invoice was submitted (e.g., TyMetrix 360, Legal Tracker, BillingPoint, Passport). Null if not submitted electronically.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ebillingRejectionReason rdf:type rdf:Property ;
    rdfs:label 'Ebilling Rejection Reason' ;
    rdfs:comment 'Reason code or narrative returned by the client\'s e-billing portal when an invoice submission is rejected (e.g., invalid UTBMS task code, rate not approved, timekeeper not enrolled). Populated only when ebilling_submission_status = rejected.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ebillingSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Ebilling Submission Date' ;
    rdfs:comment 'Date the LEDES-formatted invoice was submitted to the client\'s e-billing portal. Used to track submission timeliness and SLA compliance with client billing guidelines.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ebillingSubmissionStatus rdf:type rdf:Property ;
    rdfs:label 'Ebilling Submission Status' ;
    rdfs:comment 'Current status of the LEDES e-billing portal submission. Tracks the full submission lifecycle from initial upload through acceptance or rejection by the client\'s billing system.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feesAmount rdf:type rdf:Property ;
    rdfs:label 'Fees Amount' ;
    rdfs:comment 'Gross total of all professional fees (time charges) billed on this invoice before discounts, taxes, or write-downs. Represents the sum of all timekeeper hours multiplied by applicable rates.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceDate rdf:type rdf:Property ;
    rdfs:label 'Invoice Date' ;
    rdfs:comment 'The official date the invoice was issued to the client. This is the principal business event date used for revenue recognition, aging calculations, and LEDES e-billing submission headers.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:invoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Invoice Number' ;
    rdfs:comment 'Externally visible, human-readable invoice reference number assigned by the billing system (e.g., Elite 3E or Aderant Expert). Used on all client-facing documents, LEDES e-billing submissions, and payment remittances.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceStatus rdf:type rdf:Property ;
    rdfs:label 'Invoice Status' ;
    rdfs:comment 'Current lifecycle state of the invoice. Drives AR aging, collections workflow, and revenue recognition. Valid states: draft (prebill stage), issued (sent to client), disputed (client raised objection), paid (fully settled), partially_paid (partial remittance received), written_off (uncollectable balance removed), credited (credit note applied). [ENUM-REF-CANDIDATE: draft|issued|disputed|paid|partially_paid|written_off|credited — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceType rdf:type rdf:Property ;
    rdfs:label 'Invoice Type' ;
    rdfs:comment 'Classification of the invoice document. Standard is a regular bill; credit_note is a negative invoice reversing or adjusting a prior bill; proforma is a preliminary estimate; interim is a progress bill on a long-running matter; final closes out all WIP on a matter.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isElectronicBilling rdf:type rdf:Property ;
    rdfs:label 'Is Electronic Billing' ;
    rdfs:comment 'Indicates whether this invoice is subject to electronic billing via a LEDES-compliant e-billing portal. True = invoice must be submitted electronically; False = paper or email delivery.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ledesFormatVersion rdf:type rdf:Property ;
    rdfs:label 'Ledes Format Version' ;
    rdfs:comment 'Version of the LEDES (Legal Electronic Data Exchange Standard) format used for electronic billing submission to corporate clients or insurance carriers. Null if invoice is not submitted via e-billing portal.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netAmount rdf:type rdf:Property ;
    rdfs:label 'Net Amount' ;
    rdfs:comment 'Total amount due from the client after applying fees, disbursements, discounts, and taxes. This is the amount the client is expected to remit: (fees_amount + disbursements_amount - discount_amount + tax_amount).' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outstandingBalance rdf:type rdf:Property ;
    rdfs:label 'Outstanding Balance' ;
    rdfs:comment 'Remaining unpaid balance on this invoice (net_amount minus amount_paid). Drives AR aging buckets and collections prioritisation. Updated upon each payment application.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentTerms rdf:type rdf:Property ;
    rdfs:label 'Payment Terms' ;
    rdfs:comment 'Contractual payment terms applicable to this invoice as defined in the letter of engagement (LOE) or client billing agreement (e.g., net_30 = payment due within 30 days of invoice date).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resubmissionCount rdf:type rdf:Property ;
    rdfs:label 'Resubmission Count' ;
    rdfs:comment 'Number of times this invoice has been resubmitted to the e-billing portal following a rejection. Tracks resubmission history for operational efficiency and client relationship management.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:taxJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction' ;
    rdfs:comment 'ISO country or state/province code identifying the tax jurisdiction governing the tax calculation on this invoice. Determines applicable VAT, GST, or sales tax rules.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxRate rdf:type rdf:Property ;
    rdfs:label 'Tax Rate' ;
    rdfs:comment 'Applicable tax rate (as a decimal fraction, e.g., 0.2000 for 20% VAT) used to calculate the tax_amount on this invoice. Varies by jurisdiction and service type.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceLineId rdf:type rdf:Property ;
    rdfs:label 'Invoice Line Id' ;
    rdfs:comment 'Unique surrogate identifier for each invoice line item within the billing domain. Primary key for the invoice_line data product in the Databricks Silver Layer.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InvoiceLine .

ind:fromTimeEntryId rdf:type rdf:Property ;
    rdfs:label 'From Time Entry Id' ;
    rdfs:comment 'FK to billing.time_entry.time_entry_id — Invoice lines that represent billed time must trace back to their originating time entry for audit trail, LEDES compliance, and dispute resolution. This is the core traceability link in legal billing.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TimeEntry .

ind:primaryInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Primary Invoice Id' ;
    rdfs:comment 'Reference to the parent invoice header to which this line item belongs. Establishes the header/detail relationship for invoice line aggregation and LEDES electronic billing submissions.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:primaryInvoiceTimeEntryId rdf:type rdf:Property ;
    rdfs:label 'Primary Invoice Time Entry Id' ;
    rdfs:comment 'Reference to the originating time entry record from which this invoice line was generated. Provides full traceability from the billed line back to the WIP time entry in Elite 3E. Null for disbursement or flat fee lines.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TimeEntry .

ind:billingGuidelineExceptionReason rdf:type rdf:Property ;
    rdfs:label 'Billing Guideline Exception Reason' ;
    rdfs:comment 'Free-text description of the reason this line item was flagged as non-compliant with client billing guidelines. Populated when billing_guideline_compliant is False. Used by billing coordinators to resolve exceptions before invoice submission.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientRejected rdf:type rdf:Property ;
    rdfs:label 'Client Rejected' ;
    rdfs:comment 'Indicates whether this line item was rejected by the client or their legal spend management system after invoice submission. Rejected lines require resolution (write-off, resubmission, or dispute) and are excluded from collected revenue until resolved.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clientRejectionReason rdf:type rdf:Property ;
    rdfs:label 'Client Rejection Reason' ;
    rdfs:comment 'The reason provided by the client or their e-billing platform for rejecting this line item. Populated when client_rejected is True. Used to identify systemic billing guideline compliance issues and improve future billing quality.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterCode rdf:type rdf:Property ;
    rdfs:label 'Cost Center Code' ;
    rdfs:comment 'The cost center or profit center code associated with the practice group or office responsible for this line item. Used for internal profitability reporting, partner compensation calculations, and PPP/PEP financial KPI attribution.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fromDisbursement rdf:type rdf:Property ;
    rdfs:label 'From Disbursement' ;
    rdfs:comment 'FK to billing.disbursement.disbursement_id — Invoice lines representing expenses must trace back to the originating disbursement record. Required for LEDES compliance and client billing guideline validation.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ledesExportTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ledes Export Timestamp' ;
    rdfs:comment 'The date and time at which this line item was last exported in a LEDES electronic billing file for submission to the client or their e-billing platform. Null if the line has not yet been exported. Used to track LEDES submission status and prevent duplicate submissions.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lineSequence rdf:type rdf:Property ;
    rdfs:label 'Line Sequence' ;
    rdfs:comment 'Sequential ordering number of this line item within the parent invoice. Used to maintain the presentation order of line items on the invoice as rendered to the client and in LEDES output files.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lineStatus rdf:type rdf:Property ;
    rdfs:label 'Line Status' ;
    rdfs:comment 'Current workflow status of the invoice line item within the billing lifecycle. Draft lines are in prebilling review; approved lines are ready for invoice generation; billed lines have been sent to the client; written_off lines have been removed from AR; on_hold lines are pending client or internal review.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineType rdf:type rdf:Property ;
    rdfs:label 'Line Type' ;
    rdfs:comment 'Classification of the invoice line item indicating whether it represents a time charge, a disbursement/expense, a flat fee component, an Alternative Fee Arrangement (AFA) component, a tax charge, or a credit adjustment. Drives downstream billing logic and LEDES field mapping.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalNarrative rdf:type rdf:Property ;
    rdfs:label 'Original Narrative' ;
    rdfs:comment 'The unedited narrative text from the originating time entry or disbursement record before any prebilling edits were applied. Retained for audit trail purposes and to support billing guideline compliance reviews comparing original versus billed descriptions.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourcesDisbursement rdf:type rdf:Property ;
    rdfs:label 'Sources Disbursement' ;
    rdfs:comment 'FK to billing.disbursement.disbursement_id — Invoice lines that represent billed disbursements must trace back to the originating disbursement record for cost recovery tracking and LEDES compliance.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryModelId rdf:type rdf:Property ;
    rdfs:label 'Delivery Model Id' ;
    rdfs:comment 'Foreign key linking to service.delivery_model. Business justification: The delivery model (managed service, project-based, on-demand) directly determines fee arrangement structure and AFA type. Legal pricing teams structure fee arrangements based on delivery model. This ' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeliveryModel .

ind:engagementOpportunityId rdf:type rdf:Property ;
    rdfs:label 'Engagement Opportunity Id' ;
    rdfs:comment 'Foreign key linking to intake.engagement_opportunity. Business justification: Engagement opportunities capture AFA type and estimated matter value that directly feed fee arrangement setup. Business development reporting on won-opportunity-to-fee-arrangement conversion and AFA a' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EngagementOpportunity .

ind:guidelineId rdf:type rdf:Property ;
    rdfs:label 'Guideline Id' ;
    rdfs:comment 'Foreign key linking to billing.billing_guideline. Business justification: Fee arrangements must comply with client-specific billing guidelines (outside counsel guidelines) that govern rate caps, timekeeper restrictions, and billing format requirements. Currently fee_arrange' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Guideline .

ind:packageId rdf:type rdf:Property ;
    rdfs:label 'Package Id' ;
    rdfs:comment 'Foreign key linking to service.package. Business justification: Fee arrangements are frequently structured around a service package (e.g., fixed-fee litigation package, M&A transaction package). Legal operations teams track which service package a fee arrangement ' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Package .

ind:parentArrangementBillingFeeArrangementId rdf:type rdf:Property ;
    rdfs:label 'Parent Arrangement Billing Fee Arrangement Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the original or predecessor fee arrangement that this record amends or supersedes. Enables reconstruction of the full amendment history chain. Null for original (version 1) arrangements.' ;
    rdfs:domain ind:FeeArrangement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FeeArrangement .

ind:pricingModelId rdf:type rdf:Property ;
    rdfs:label 'Pricing Model Id' ;
    rdfs:comment 'Foreign key linking to service.pricing_model. Business justification: Fee arrangements implement pricing models (hourly, fixed fee, contingency, blended, AFA). Pricing model defines calculation rules, billing frequency, payment terms, and revenue recognition used in eng' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PricingModel .

ind:regulatoryObligationId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Obligation Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_obligation. Business justification: Fee arrangements must comply with specific regulatory obligations (SRA transparency rules, consumer protection pricing disclosure). Legal compliance teams track which regulatory obligation mandates ea' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryObligation .

ind:rfpSubmissionId rdf:type rdf:Property ;
    rdfs:label 'Rfp Submission Id' ;
    rdfs:comment 'Foreign key linking to intake.rfp_submission. Business justification: Won RFP submissions specify fee arrangement types and estimated values that directly govern fee arrangement creation. Pitch-to-revenue reporting and panel compliance tracking require tracing fee arran' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RfpSubmission .

ind:slaTemplateId rdf:type rdf:Property ;
    rdfs:label 'Sla Template Id' ;
    rdfs:comment 'Foreign key linking to service.sla_template. Business justification: Fee arrangements in legal firms incorporate SLA commitments (response time guarantees, delivery milestones tied to fee structure). Legal operations teams link SLA templates to fee arrangements for bre' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SlaTemplate .

ind:agreedAmount rdf:type rdf:Property ;
    rdfs:label 'Agreed Amount' ;
    rdfs:comment 'The total agreed fee amount for flat fee, capped fee, retainer, subscription, and success fee arrangements. Represents the contractually committed monetary value. For hourly and blended rate arrangements, this field is null and rate fields govern billing. Expressed in the arrangement currency.' ;
    rdfs:domain ind:FeeArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amendmentVersion rdf:type rdf:Property ;
    rdfs:label 'Amendment Version' ;
    rdfs:comment 'Sequential version number tracking amendments to the fee arrangement. Version 1 represents the original arrangement; subsequent amendments increment this counter. Supports audit trail and supersession chain tracking in Elite 3E.' ;
    rdfs:domain ind:FeeArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:arrangementNumber rdf:type rdf:Property ;
    rdfs:label 'Arrangement Number' ;
    rdfs:comment 'Externally-known unique business identifier for the fee arrangement, used in client communications, engagement letters (LOE), and billing correspondence. Typically follows firm-defined numbering conventions in Elite 3E.' ;
    rdfs:domain ind:FeeArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arrangementStatus rdf:type rdf:Property ;
    rdfs:label 'Arrangement Status' ;
    rdfs:comment 'Current lifecycle state of the fee arrangement. Controls whether the arrangement is actively governing billing operations. Draft indicates pending approval; active indicates currently in force; suspended indicates temporarily paused; expired indicates past effective end date; terminated indicates early cancellation; superseded indicates replaced by a newer arrangement.' ;
    rdfs:domain ind:FeeArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blendedHourlyRate rdf:type rdf:Property ;
    rdfs:label 'Blended Hourly Rate' ;
    rdfs:comment 'Single agreed hourly rate applied uniformly across all timekeepers on the matter, regardless of individual timekeeper seniority or standard rate. Used for blended rate AFA arrangements. Null for non-blended arrangements.' ;
    rdfs:domain ind:FeeArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contingencyRatePct rdf:type rdf:Property ;
    rdfs:label 'Contingency Rate Pct' ;
    rdfs:comment 'Percentage of the recovery or settlement amount payable to the firm under a contingency fee arrangement. Expressed as a decimal percentage (e.g., 33.3333 for 33.33%). Null for non-contingency arrangement types. Governed by jurisdiction-specific caps on contingency fees.' ;
    rdfs:domain ind:FeeArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discountPct rdf:type rdf:Property ;
    rdfs:label 'Discount Pct' ;
    rdfs:comment 'Negotiated discount percentage applied to standard rates or fees under this arrangement. Expressed as a decimal percentage (e.g., 10.0000 for 10%). Reduces the billable amount during invoice generation. Supports client relationship management and competitive pricing strategies.' ;
    rdfs:domain ind:FeeArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:effectiveDate rdf:type rdf:Property ;
    rdfs:label 'Effective Date' ;
    rdfs:comment 'Date from which the fee arrangement becomes binding and governs billing for the associated matter or client portfolio. Aligns with the engagement commencement date in the Letter of Engagement (LOE).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expenseCapAmount rdf:type rdf:Property ;
    rdfs:label 'Expense Cap Amount' ;
    rdfs:comment 'Maximum disbursement or expense amount the firm may incur and bill to the client under this arrangement without prior written approval. Governs disbursement billing controls during invoice generation.' ;
    rdfs:domain ind:FeeArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expensesBillable rdf:type rdf:Property ;
    rdfs:label 'Expenses Billable' ;
    rdfs:comment 'Indicates whether disbursements and out-of-pocket expenses are billable to the client under this fee arrangement. When false, all expenses are absorbed by the firm. Governs disbursement line inclusion during prebilling.' ;
    rdfs:domain ind:FeeArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:expiryDate rdf:type rdf:Property ;
    rdfs:label 'Expiry Date' ;
    rdfs:comment 'Date on which the fee arrangement ceases to be binding. Nullable for open-ended arrangements. When populated, triggers review or renewal workflows in Elite 3E. Distinct from termination date which reflects early cancellation.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:feeCapAmount rdf:type rdf:Property ;
    rdfs:label 'Fee Cap Amount' ;
    rdfs:comment 'Maximum billable amount under a capped fee or blended rate arrangement. WIP accrued beyond this threshold cannot be invoiced without client approval or a formal cap amendment. Enforced during prebilling in Elite 3E and Aderant Expert.' ;
    rdfs:domain ind:FeeArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ledesBillingFormat rdf:type rdf:Property ;
    rdfs:label 'Ledes Billing Format' ;
    rdfs:comment 'LEDES electronic billing format required by the client for invoice submission. Governs the output format of invoices generated from this arrangement. Clients with e-billing portals (e.g., TyMetrix, Legal Tracker) mandate specific LEDES versions.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermsDays rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Days' ;
    rdfs:comment 'Number of days from invoice date within which the client is contractually required to remit payment. Standard terms include net-30, net-45, net-60. Used to calculate invoice due dates and trigger collections workflows in Elite 3E accounts receivable.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:portfolioArrangement rdf:type rdf:Property ;
    rdfs:label 'Portfolio Arrangement' ;
    rdfs:comment 'Indicates whether this fee arrangement governs a portfolio of multiple matters for the same client rather than a single matter. Portfolio arrangements aggregate WIP and billing across matters and require consolidated invoice generation.' ;
    rdfs:domain ind:FeeArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retainerAmount rdf:type rdf:Property ;
    rdfs:label 'Retainer Amount' ;
    rdfs:comment 'Periodic retainer fee amount payable by the client under a retainer or subscription arrangement. Represents the recurring fixed payment that secures the firm\'s availability. Tracked against IOLTA trust account rules where applicable.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scopeDescription rdf:type rdf:Property ;
    rdfs:label 'Scope Description' ;
    rdfs:comment 'Narrative description of the legal services scope covered by this fee arrangement. Defines the boundaries of work included within the agreed fee, distinguishing in-scope from out-of-scope services that would require a separate arrangement or amendment.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:successFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Success Fee Amount' ;
    rdfs:comment 'Fixed monetary amount payable as a success fee upon achievement of the defined trigger condition. Distinct from contingency_rate_pct which is percentage-based. Null for non-success-fee arrangements.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:successFeeTrigger rdf:type rdf:Property ;
    rdfs:label 'Success Fee Trigger' ;
    rdfs:comment 'Narrative description of the milestone, outcome, or event that triggers the success fee component of the arrangement (e.g., deal closing, favourable judgment, regulatory approval). Applicable only to success fee and hybrid AFA arrangements.' ;
    rdfs:domain ind:FeeArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxApplicable rdf:type rdf:Property ;
    rdfs:label 'Tax Applicable' ;
    rdfs:comment 'Indicates whether applicable taxes (e.g., VAT, GST, sales tax) are chargeable on invoices generated under this fee arrangement. Drives tax calculation logic in Elite 3E and Aderant Expert during invoice generation.' ;
    rdfs:domain ind:FeeArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxRatePct rdf:type rdf:Property ;
    rdfs:label 'Tax Rate Pct' ;
    rdfs:comment 'Applicable tax rate percentage (e.g., VAT, GST) applied to invoices generated under this arrangement when tax_applicable is true. Expressed as a decimal percentage (e.g., 20.0000 for 20% UK VAT). Null when tax_applicable is false.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:terminationDate rdf:type rdf:Property ;
    rdfs:label 'Termination Date' ;
    rdfs:comment 'Date on which the fee arrangement was early-terminated prior to its scheduled expiry date. Populated only when arrangement_status is terminated. Distinct from expiry_date which reflects the originally agreed end date.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:terminationReason rdf:type rdf:Property ;
    rdfs:label 'Termination Reason' ;
    rdfs:comment 'Reason code explaining why the fee arrangement was terminated prior to its scheduled expiry. Supports client relationship analytics and risk management reporting. Populated only when arrangement_status is terminated. [ENUM-REF-CANDIDATE: matter_closed|client_request|firm_withdrawal|superseded|breach|regulatory|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utbmsTaskCodeSet rdf:type rdf:Property ;
    rdfs:label 'Utbms Task Code Set' ;
    rdfs:comment 'UTBMS task code set applicable to this fee arrangement, governing how time entries and disbursements are categorized for task-based billing. Required for LEDES-compliant invoice submission and client billing guideline compliance.' ;
    rdfs:domain ind:FeeArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wipConversionRule rdf:type rdf:Property ;
    rdfs:label 'Wip Conversion Rule' ;
    rdfs:comment 'Rule governing how accumulated WIP is converted to invoiced amounts under this fee arrangement. Determines the timing and method of WIP recognition during prebilling. Critical for revenue recognition and financial reporting under the billing domain.' ;
    rdfs:domain ind:FeeArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:writeOffLimitPct rdf:type rdf:Property ;
    rdfs:label 'Write Off Limit Pct' ;
    rdfs:comment 'Maximum percentage of WIP that the billing attorney may write off during prebilling without escalating to partner or management approval. Enforces write-off governance controls in Aderant Expert and Elite 3E.' ;
    rdfs:domain ind:FeeArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingPaymentId rdf:type rdf:Property ;
    rdfs:label 'Billing Payment Id' ;
    rdfs:comment 'Unique surrogate identifier for each payment transaction record in the billing system. Primary key for the payment data product.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillingPayment .

ind:amlKycProgramId rdf:type rdf:Property ;
    rdfs:label 'Aml Kyc Program Id' ;
    rdfs:comment 'Foreign key linking to compliance.aml_kyc_program. Business justification: Legal firms must screen payments under a specific AML/KYC program (FATF, SRA requirements). Tracing which AML program governed a payment\'s screening is a named compliance process; aml_screening_status' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AmlKycProgram .

ind:billingAccountId rdf:type rdf:Property ;
    rdfs:label 'Billing Account Id' ;
    rdfs:comment 'Reference to the client trust or IOLTA account from which funds were transferred, applicable when payment_type is \'trust_transfer\' or \'retainer_drawdown\'. Supports IOLTA compliance, trust accounting reconciliation, and regulatory reporting.' ;
    rdfs:domain ind:BillingPayment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:billingBankAccountId rdf:type rdf:Property ;
    rdfs:label 'Billing Bank Account Id' ;
    rdfs:comment 'Reference to the firm\'s internal bank account record into which the payment was deposited (e.g., operating account, IOLTA/trust account, client account). Supports bank reconciliation and IOLTA compliance reporting.' ;
    rdfs:domain ind:BillingPayment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:originalPaymentBillingPaymentId rdf:type rdf:Property ;
    rdfs:label 'Original Payment Billing Payment Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the original payment record when this record represents a reversal, reapplication, or correction of a prior payment. Enables payment lineage tracing and audit trail for reversed and reprocessed payments.' ;
    rdfs:domain ind:BillingPayment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillingPayment .

ind:payingOrganisationId rdf:type rdf:Property ;
    rdfs:label 'Paying Organisation Id' ;
    rdfs:comment 'Foreign key linking to client.organisation. Business justification: Corporate treasury departments often make payments on behalf of multiple subsidiaries/client_profiles. Tracking the paying organisation (which may differ from the client_profile\'s organisation) enable' ;
    rdfs:domain ind:BillingPayment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Organisation .

ind:retainerId rdf:type rdf:Property ;
    rdfs:label 'Retainer Id' ;
    rdfs:comment 'Reference to the retainer agreement or retainer balance record from which funds are drawn, applicable when payment_type is \'retainer_drawdown\'. Links the payment to the pre-paid retainer for balance tracking and client reporting.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Retainer .

ind:trustLedgerEntryId rdf:type rdf:Property ;
    rdfs:label 'Trust Ledger Entry Id' ;
    rdfs:comment 'Foreign key linking to trust.ledger_entry. Business justification: Billing payments drawn from trust must be traceable to the corresponding trust ledger entry recording the disbursement. This trust-to-office transfer reconciliation is a mandatory legal trust accounti' ;
    rdfs:domain ind:BillingPayment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LedgerEntry .

ind:allocationType rdf:type rdf:Property ;
    rdfs:label 'Allocation Type' ;
    rdfs:comment 'Describes how the received funds are distributed across outstanding invoices. \'full\' means the entire invoice balance is satisfied; \'partial\' means only a portion of one or more invoices is covered; \'retainer_drawdown\' means funds are drawn from a pre-paid retainer; \'trust_transfer\' means funds originate from a client trust account; \'unapplied\' means no allocation has been made yet.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appliedAmount rdf:type rdf:Property ;
    rdfs:label 'Applied Amount' ;
    rdfs:comment 'The total amount of the received funds that has been allocated and posted against one or more outstanding invoices. For fully applied payments, equals received_amount. For partially applied payments, is less than received_amount.' ;
    rdfs:domain ind:BillingPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:appliedDate rdf:type rdf:Property ;
    rdfs:label 'Applied Date' ;
    rdfs:comment 'The calendar date on which the received funds were allocated and posted against outstanding invoices in the billing system. May differ from received_date when payments are held in unapplied status pending client direction or prebilling approval.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bankReference rdf:type rdf:Property ;
    rdfs:label 'Bank Reference' ;
    rdfs:comment 'The unique transaction reference number assigned by the receiving bank or payment processor for this payment (e.g., SWIFT UETR, CHAPS reference, ACH trace number, cheque number). Used for bank reconciliation, payment tracing, and AML (Anti-Money Laundering) compliance.' ;
    rdfs:domain ind:BillingPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Functional Currency Amount' ;
    rdfs:comment 'The received_amount converted to the firm\'s functional (base) currency using the exchange_rate at the time of receipt. Used for consolidated financial reporting, PPP (Profit Per Partner), PEP (Profit Per Equity Partner), and RPE (Revenue Per Equity Partner) KPI calculations.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:glPeriod rdf:type rdf:Property ;
    rdfs:label 'Gl Period' ;
    rdfs:comment 'The accounting period (YYYY-MM) to which this payment is posted in the General Ledger (GL). Used for period-close financial reporting, revenue recognition, and SOX compliance. May differ from the calendar month of received_date due to period-end adjustments.' ;
    rdfs:domain ind:BillingPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glPostingDate rdf:type rdf:Property ;
    rdfs:label 'Gl Posting Date' ;
    rdfs:comment 'The date on which the payment was posted to the firm\'s General Ledger (GL), which may differ from the received_date or applied_date due to period-end cut-off rules. Critical for financial period reporting, SOX compliance, and revenue recognition.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isMultiMatter rdf:type rdf:Property ;
    rdfs:label 'Is Multi Matter' ;
    rdfs:comment 'Indicates whether this payment has been allocated across two or more matters. When True, the full allocation detail is captured in the payment allocation lines product. Supports complex multi-matter payment scenario reporting and client account management.' ;
    rdfs:domain ind:BillingPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReversed rdf:type rdf:Property ;
    rdfs:label 'Is Reversed' ;
    rdfs:comment 'Indicates whether this payment has been reversed (e.g., due to a returned cheque, failed ACH, or client dispute). When True, the reversal_date and reversal_reason fields are populated and the previously applied invoice balances are reinstated.' ;
    rdfs:domain ind:BillingPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTrustPayment rdf:type rdf:Property ;
    rdfs:label 'Is Trust Payment' ;
    rdfs:comment 'Indicates whether this payment involves a transfer from a client trust or IOLTA account to the firm\'s operating account. When True, the payment is subject to IOLTA compliance rules and trust accounting reconciliation requirements.' ;
    rdfs:domain ind:BillingPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overpaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Overpayment Amount' ;
    rdfs:comment 'The amount by which the received funds exceed the total outstanding balance of the invoices to which the payment was applied. A non-zero value requires a decision to refund, credit, or hold as a retainer. Supports client credit and refund workflows.' ;
    rdfs:domain ind:BillingPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentMethod rdf:type rdf:Property ;
    rdfs:label 'Payment Method' ;
    rdfs:comment 'The instrument or mechanism used by the client to remit funds. \'wire_transfer\' covers SWIFT/CHAPS/SEPA bank wires; \'cheque\' covers paper cheques; \'ach\' covers ACH/BACS electronic transfers; \'credit_card\' covers card payments; \'trust_transfer\' covers transfers from the client\'s trust/IOLTA account to the office account; \'retainer_drawdown\' covers application of a pre-paid retainer balance.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Number' ;
    rdfs:comment 'Externally visible, human-readable business identifier for the payment, used in client remittance advice, bank reconciliation, and collections correspondence. Follows the firm\'s sequential payment numbering convention (e.g., PAY-2024-000123).' ;
    rdfs:domain ind:BillingPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Status' ;
    rdfs:comment 'Current lifecycle state of the payment within the accounts receivable workflow. \'received\' indicates funds have been confirmed in the bank; \'applied\' means fully allocated to invoices; \'partially_applied\' means some funds remain unapplied; \'unapplied\' means no allocation has occurred; \'reversed\' means the payment was reversed after application; \'voided\' means the payment was cancelled before application.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentType rdf:type rdf:Property ;
    rdfs:label 'Payment Type' ;
    rdfs:comment 'Classifies the nature of the payment transaction for accounting and AR purposes. \'standard\' is a regular client remittance; \'retainer_drawdown\' is an application of a pre-paid retainer; \'trust_transfer\' is a transfer from a client trust/IOLTA account; \'overpayment_credit\' is a credit applied from a prior overpayment; \'write_off_reversal\' is a recovery of a previously written-off amount.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivedAmount rdf:type rdf:Property ;
    rdfs:label 'Received Amount' ;
    rdfs:comment 'The gross amount of funds received from the client in the transaction currency, as confirmed by the bank or trust account statement. This is the authoritative amount before any exchange rate conversion or allocation.' ;
    rdfs:domain ind:BillingPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receivedDate rdf:type rdf:Property ;
    rdfs:label 'Received Date' ;
    rdfs:comment 'The calendar date on which the firm confirmed receipt of funds from the client, as recorded in the bank or trust account. This is the principal business event date used for accounts receivable aging, cash flow reporting, and revenue recognition.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remittanceReference rdf:type rdf:Property ;
    rdfs:label 'Remittance Reference' ;
    rdfs:comment 'The reference or description provided by the client on the remittance advice or payment instruction, typically including invoice numbers, matter references, or client-side purchase order numbers. Used to match incoming funds to outstanding invoices during cash application.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalDate rdf:type rdf:Property ;
    rdfs:label 'Reversal Date' ;
    rdfs:comment 'The calendar date on which the payment was reversed in the billing system, reinstating the outstanding invoice balances. Populated only when is_reversed is True. Used for AR aging recalculation and collections workflow re-triggering.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reversalReason rdf:type rdf:Property ;
    rdfs:label 'Reversal Reason' ;
    rdfs:comment 'The reason code explaining why the payment was reversed. \'returned_cheque\' indicates a dishonoured cheque; \'failed_ach\' indicates a failed electronic transfer; \'client_dispute\' indicates the client contested the payment; \'duplicate_payment\' indicates the payment was made twice; \'bank_error\' indicates a banking error; \'other\' covers miscellaneous reasons. Populated only when is_reversed is True.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unappliedAmount rdf:type rdf:Property ;
    rdfs:label 'Unapplied Amount' ;
    rdfs:comment 'The portion of the received funds that has not yet been allocated to any invoice (received_amount minus applied_amount). A non-zero value triggers follow-up in the collections and AR workflow. Supports unapplied balance reporting and client credit management.' ;
    rdfs:domain ind:BillingPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wipClearedAmount rdf:type rdf:Property ;
    rdfs:label 'Wip Cleared Amount' ;
    rdfs:comment 'The amount of Work in Progress (WIP) that was cleared from the WIP ledger as a result of this payment being applied. Relevant for contingency and AFA matters where WIP is recognized upon collection rather than billing. Supports WIP management and revenue recognition reporting.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentAllocationId rdf:type rdf:Property ;
    rdfs:label 'Payment Allocation Id' ;
    rdfs:comment 'Unique surrogate identifier for each payment allocation record. Primary key for the payment_allocation data product in the billing domain.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountId rdf:type rdf:Property ;
    rdfs:label 'Account Id' ;
    rdfs:comment 'Reference to the IOLTA or client trust account from which funds were drawn for this allocation, when allocation_type is \'trust_transfer\'. Required for trust accounting compliance and state bar regulatory reporting.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:allocatedAmount rdf:type rdf:Property ;
    rdfs:label 'Allocated Amount' ;
    rdfs:comment 'The monetary amount from the payment being applied to the referenced invoice or invoice line. Core financial field for AR aging, cash application, and revenue recognition. Must be positive and not exceed the payment\'s unapplied balance.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocatedAmountBase rdf:type rdf:Property ;
    rdfs:label 'Allocated Amount Base' ;
    rdfs:comment 'The allocated amount expressed in the firm\'s functional (base) currency after applying the exchange rate. Used for consolidated financial reporting, PPP, PEP, and RPE KPI calculations.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationDate rdf:type rdf:Property ;
    rdfs:label 'Allocation Date' ;
    rdfs:comment 'The business date on which the payment allocation was applied to the invoice. Determines the AR aging bucket reduction and is the principal event date for cash application reporting and period-end close.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allocationNumber rdf:type rdf:Property ;
    rdfs:label 'Allocation Number' ;
    rdfs:comment 'Externally visible business identifier for this payment allocation record, used in client communications, remittance advice reconciliation, and audit trails. Typically follows firm-defined numbering conventions in Elite 3E or Aderant Expert.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationStatus rdf:type rdf:Property ;
    rdfs:label 'Allocation Status' ;
    rdfs:comment 'Current lifecycle state of the payment allocation record. \'posted\' indicates funds have been applied to the invoice; \'reversed\' indicates a corrective reversal has been processed; \'pending\' indicates awaiting approval or trust transfer confirmation; \'voided\' indicates the allocation was cancelled; \'unapplied\' indicates funds received but not yet matched to an invoice.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glPostDate rdf:type rdf:Property ;
    rdfs:label 'Gl Post Date' ;
    rdfs:comment 'The date on which this allocation was posted to the General Ledger. May differ from allocation_date due to period-end cutoff rules or delayed GL posting. Critical for financial period reconciliation and SOX compliance.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:invoiceBalanceAfter rdf:type rdf:Property ;
    rdfs:label 'Invoice Balance After' ;
    rdfs:comment 'The remaining outstanding invoice balance immediately after this allocation is applied. Enables real-time AR aging bucket calculation and identifies fully satisfied versus partially paid invoices.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceBalanceBefore rdf:type rdf:Property ;
    rdfs:label 'Invoice Balance Before' ;
    rdfs:comment 'The outstanding invoice balance immediately prior to this allocation being applied. Provides a point-in-time snapshot for audit trail purposes and supports AR aging reconciliation.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isAutoAllocated rdf:type rdf:Property ;
    rdfs:label 'Is Auto Allocated' ;
    rdfs:comment 'Indicates whether this allocation was applied automatically by the billing system (True) or manually by a billing administrator (False). Supports audit trail requirements and cash application workflow quality monitoring.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTrustCompliant rdf:type rdf:Property ;
    rdfs:label 'Is Trust Compliant' ;
    rdfs:comment 'Indicates whether this allocation has been reviewed and confirmed as compliant with applicable trust accounting rules (True) or flagged for review (False). Required for IOLTA compliance and state bar regulatory reporting.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ledesBillingPeriod rdf:type rdf:Property ;
    rdfs:label 'Ledes Billing Period' ;
    rdfs:comment 'The billing period (YYYY-MM) associated with the invoice to which this allocation is applied, formatted per LEDES standards. Supports electronic billing reconciliation with corporate clients and insurance carriers.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reversed Timestamp' ;
    rdfs:comment 'The date and time at which this payment allocation was reversed. Populated only when allocation_status is \'reversed\'. Used for AR aging correction and period-end reconciliation.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sourceSystemRef rdf:type rdf:Property ;
    rdfs:label 'Source System Ref' ;
    rdfs:comment 'The native identifier of this payment allocation record in the originating source system (e.g., Elite 3E transaction ID or Aderant Expert allocation key). Enables traceability and reconciliation back to the system of record.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unappliedBalance rdf:type rdf:Property ;
    rdfs:label 'Unapplied Balance' ;
    rdfs:comment 'The portion of the payment that remains unallocated after this allocation record is processed. A non-zero value indicates funds on account that require further application to outstanding invoices or return to the client.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valueDate rdf:type rdf:Property ;
    rdfs:label 'Value Date' ;
    rdfs:comment 'The date on which the funds were considered cleared and available, as confirmed by the bank or payment processor. Used for trust accounting reconciliation and IOLTA compliance reporting.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:arBalanceId rdf:type rdf:Property ;
    rdfs:label 'Ar Balance Id' ;
    rdfs:comment 'Unique surrogate identifier for each accounts receivable balance record in the AR aging ledger. Primary key for the ar_balance data product.' ;
    rdfs:domain ind:ArBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:matterRiskProfileId rdf:type rdf:Property ;
    rdfs:label 'Matter Risk Profile Id' ;
    rdfs:comment 'Foreign key linking to risk.matter_risk_profile. Business justification: Client credit risk reporting: AR aging buckets and collection status directly populate client_credit_risk_rating and client_payment_history_flag on matter_risk_profile. Legal finance teams link AR bal' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MatterRiskProfile .

ind:organisationId rdf:type rdf:Property ;
    rdfs:label 'Organisation Id' ;
    rdfs:comment 'Reference to the client entity who owes the outstanding balance. Links the AR record to the client master for collections management and partner financial reviews.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Organisation .

ind:primaryArInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Primary Ar Invoice Id' ;
    rdfs:comment 'Reference to the originating invoice that generated this AR balance record. Supports invoice-level aging and dispute tracking.' ;
    rdfs:domain ind:ArBalance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:primaryArMatterId rdf:type rdf:Property ;
    rdfs:label 'Primary Ar Matter Id' ;
    rdfs:comment 'Reference to the specific legal matter against which the outstanding balance is recorded. Enables matter-level AR aging and WIP reconciliation.' ;
    rdfs:domain ind:ArBalance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Matter .

ind:writeOffId rdf:type rdf:Property ;
    rdfs:label 'Write Off Id' ;
    rdfs:comment 'Foreign key linking to billing.write_off. Business justification: AR balances may be partially or fully written off when deemed uncollectible. Currently ar_balance has write_off_amount, write_off_date, and write_off_approved_by as denormalized attributes, but no FK ' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WriteOff .

ind:arNumber rdf:type rdf:Property ;
    rdfs:label 'Ar Number' ;
    rdfs:comment 'Externally-visible, human-readable reference number assigned to this AR balance record. Used in client statements, collection correspondence, and LEDES electronic billing submissions.' ;
    rdfs:domain ind:ArBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bucket030Amount rdf:type rdf:Property ;
    rdfs:label 'Bucket 0 30 Amount' ;
    rdfs:comment 'Portion of the outstanding balance aged 0 to 30 days from the invoice date. Used in the standard AR aging report for partner financial reviews and PPP/PEP calculations.' ;
    rdfs:domain ind:ArBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bucket3160Amount rdf:type rdf:Property ;
    rdfs:label 'Bucket 31 60 Amount' ;
    rdfs:comment 'Portion of the outstanding balance aged 31 to 60 days from the invoice date. Elevated aging bucket that may trigger initial collection outreach per firm collections policy.' ;
    rdfs:domain ind:ArBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bucket6190Amount rdf:type rdf:Property ;
    rdfs:label 'Bucket 61 90 Amount' ;
    rdfs:comment 'Portion of the outstanding balance aged 61 to 90 days from the invoice date. Triggers escalated collection action and partner notification under standard firm collections protocols.' ;
    rdfs:domain ind:ArBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bucketOver90Amount rdf:type rdf:Property ;
    rdfs:label 'Bucket Over 90 Amount' ;
    rdfs:comment 'Portion of the outstanding balance aged more than 90 days from the invoice date. Highest-risk aging bucket; typically triggers write-off evaluation, external collections referral, or matter suspension.' ;
    rdfs:domain ind:ArBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clientMatterNumber rdf:type rdf:Property ;
    rdfs:label 'Client Matter Number' ;
    rdfs:comment 'Combined client-matter reference code (e.g., 12345.001) as used in Elite 3E and on client invoices. Standard identifier for cross-referencing billing records with matter management systems.' ;
    rdfs:domain ind:ArBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionStatus rdf:type rdf:Property ;
    rdfs:label 'Collection Status' ;
    rdfs:comment 'Current collections lifecycle state of the AR balance record. Drives workflow routing in Aderant Expert collections management and partner escalation processes. [ENUM-REF-CANDIDATE: current|overdue|in_dispute|sent_to_collections|written_off|settled — promote to reference product if additional statuses are required]' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionsNotes rdf:type rdf:Property ;
    rdfs:label 'Collections Notes' ;
    rdfs:comment 'Free-text notes recorded by the collections team or responsible partner regarding collection activity, client commitments, payment plans, or dispute context for this AR balance.' ;
    rdfs:domain ind:ArBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentBalance rdf:type rdf:Property ;
    rdfs:label 'Current Balance' ;
    rdfs:comment 'The net outstanding amount currently owed by the client on this AR record after applying all payments, credits, and write-offs to date. The authoritative balance figure for collections management and financial reporting.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daysOutstanding rdf:type rdf:Property ;
    rdfs:label 'Days Outstanding' ;
    rdfs:comment 'Number of calendar days elapsed since the invoice date. Used as the primary aging metric for AR bucket assignment and collections prioritisation. Recalculated daily during Silver layer processing.' ;
    rdfs:domain ind:ArBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:disputeFlag rdf:type rdf:Property ;
    rdfs:label 'Dispute Flag' ;
    rdfs:comment 'Indicates whether the client has formally disputed this invoice or AR balance. When true, collections activity is paused pending resolution and the record is flagged for billing partner review.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interestAccrued rdf:type rdf:Property ;
    rdfs:label 'Interest Accrued' ;
    rdfs:comment 'Contractual interest amount accrued on the overdue AR balance where the Letter of Engagement (LOE) provides for late payment interest. Tracked separately from the principal balance for financial reporting.' ;
    rdfs:domain ind:ArBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ioltaFlag rdf:type rdf:Property ;
    rdfs:label 'Iolta Flag' ;
    rdfs:comment 'Indicates whether this AR balance is associated with funds held in an IOLTA trust account. When true, payment processing must comply with IOLTA rules and state bar trust accounting regulations.' ;
    rdfs:domain ind:ArBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastCollectionContactDate rdf:type rdf:Property ;
    rdfs:label 'Last Collection Contact Date' ;
    rdfs:comment 'Date of the most recent collections outreach activity (call, email, or letter) made to the client regarding this outstanding balance. Supports collections workflow management and SLA compliance.' ;
    rdfs:domain ind:ArBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Last Payment Amount' ;
    rdfs:comment 'The monetary value of the most recent payment applied to this AR balance. Supports cash flow analysis and collections follow-up.' ;
    rdfs:domain ind:ArBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Last Payment Date' ;
    rdfs:comment 'Date of the most recent payment received and applied against this AR balance. Used in collections management to assess client payment behaviour and prioritise outreach.' ;
    rdfs:domain ind:ArBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastStatementDate rdf:type rdf:Property ;
    rdfs:label 'Last Statement Date' ;
    rdfs:comment 'Date the most recent client account statement was generated and dispatched for this AR balance. Used to track statement cycle compliance and client communication history.' ;
    rdfs:domain ind:ArBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent modification to this AR balance record, including payment applications, write-offs, credit adjustments, or status changes. Required for incremental Silver layer processing and audit compliance.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:matterTypeCode rdf:type rdf:Property ;
    rdfs:label 'Matter Type Code' ;
    rdfs:comment 'Classification code for the type of legal matter (e.g., M&A, Litigation, IP Prosecution, Employment Advisory) associated with this AR balance. Enables matter-type segmentation in AR analytics.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalInvoiceAmount rdf:type rdf:Property ;
    rdfs:label 'Original Invoice Amount' ;
    rdfs:comment 'The gross billed amount on the original invoice before any payments, credits, or write-offs are applied. Denominated in the billing currency. Forms the basis for AR aging and revenue recognition.' ;
    rdfs:domain ind:ArBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCreditsApplied rdf:type rdf:Property ;
    rdfs:label 'Total Credits Applied' ;
    rdfs:comment 'Cumulative value of credit notes, billing adjustments, and courtesy discounts applied against this AR balance. Distinct from write-offs; represents negotiated or corrective reductions.' ;
    rdfs:domain ind:ArBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPaymentsApplied rdf:type rdf:Property ;
    rdfs:label 'Total Payments Applied' ;
    rdfs:comment 'Cumulative amount of all client payments applied against this AR balance record to date. Reconciles original invoice amount to current outstanding balance.' ;
    rdfs:domain ind:ArBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conflictCheckId rdf:type rdf:Property ;
    rdfs:label 'Conflict Check Id' ;
    rdfs:comment 'Foreign key linking to conflict.check. Business justification: Conflict-driven write-off reporting: when a conflict is discovered post-engagement, fees billed during the conflicted period must be written off. Legal risk and billing teams require the link between ' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Check .

ind:indemnityClaimId rdf:type rdf:Property ;
    rdfs:label 'Indemnity Claim Id' ;
    rdfs:comment 'Foreign key linking to compliance.indemnity_claim. Business justification: Write-offs may be linked to PI claims (settlement amounts, defence costs, fee reductions). Real business process: claim financial impact tracking requires linking write-offs to claims for reserve mana' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IndemnityClaim .

ind:indemnityExposureId rdf:type rdf:Property ;
    rdfs:label 'Indemnity Exposure Id' ;
    rdfs:comment 'Foreign key linking to risk.indemnity_exposure. Business justification: PI claim cost tracking: write-offs are frequently triggered by indemnity exposures (firm writes off fees when settling a PI claim). Legal risk teams need to link write-off amounts to indemnity_exposur' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IndemnityExposure .

ind:piClaimId rdf:type rdf:Property ;
    rdfs:label 'Pi Claim Id' ;
    rdfs:comment 'Foreign key linking to risk.pi_claim. Business justification: PI claim cost quantification for insurance reporting: write-offs directly resulting from PI claim settlements must be linked to the pi_claim record to calculate total claim cost (defence costs + write' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PiClaim .

ind:registerId rdf:type rdf:Property ;
    rdfs:label 'Register Id' ;
    rdfs:comment 'Foreign key linking to risk.risk_register. Business justification: Material write-offs (especially pattern write-offs by timekeeper or client) are risk events requiring registration for trend analysis, partner accountability, and realization rate monitoring. Firms es' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Register .

ind:reversedWriteOffId rdf:type rdf:Property ;
    rdfs:label 'Reversed Write Off Id' ;
    rdfs:comment 'Reference to the original write-off record that this entry reverses. Populated only when is_reversal is True. Enables audit trail linking between original write-offs and their reversals for GL reconciliation and financial period close.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WriteOff .

ind:writeInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Write Invoice Id' ;
    rdfs:comment 'FK to billing.invoice.invoice_id — Bad debt write-offs must reference the invoice being written off from AR. Required for AR balance accuracy and financial close procedures.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:approvalDate rdf:type rdf:Property ;
    rdfs:label 'Approval Date' ;
    rdfs:comment 'The date on which the approving partner formally authorized the write-off. May differ from write_off_date if approval precedes the accounting period posting. Critical for partner approval audit trails and governance compliance.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clientAgreedRate rdf:type rdf:Property ;
    rdfs:label 'Client Agreed Rate' ;
    rdfs:comment 'The negotiated or agreed billing rate for the timekeeper applicable to this client/matter at the time of the write-off. Enables analysis of rate realization versus standard rates and identification of billing guideline-driven write-offs.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fiscalPeriod rdf:type rdf:Property ;
    rdfs:label 'Fiscal Period' ;
    rdfs:comment 'The firm\'s fiscal year and month in which the write-off is recognized for financial reporting purposes, formatted as YYYY-MM. Derived from gl_posting_date but stored explicitly to support period-based aggregation and financial close reporting without date arithmetic.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hoursWrittenOff rdf:type rdf:Property ;
    rdfs:label 'Hours Written Off' ;
    rdfs:comment 'The number of billable hours associated with the write-off, applicable when the write-off relates to time entries. Null for expense or disbursement write-offs. Used to calculate effective realization rates and to measure the volume of written-off effort.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isReversal rdf:type rdf:Property ;
    rdfs:label 'Is Reversal' ;
    rdfs:comment 'Indicates whether this write-off record is a reversal of a previously posted write-off (True) or an original write-off entry (False). Reversals restore WIP or AR balances and must be tracked separately for accurate net write-off reporting and GL reconciliation.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originalAmount rdf:type rdf:Property ;
    rdfs:label 'Original Amount' ;
    rdfs:comment 'The gross value of the WIP or AR balance before the write-off is applied, expressed in the billing currency. Represents the full amount at standard rates prior to any reduction. Used as the denominator in realization rate calculations.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reasonCode rdf:type rdf:Property ;
    rdfs:label 'Reason Code' ;
    rdfs:comment 'Standardized code identifying the business reason for the write-off (e.g., client billing guideline non-compliance, rate cap exceeded, duplicate entry, uncollectable debt, client relationship courtesy, matter budget overrun). Sourced from Elite 3E or Aderant Expert reason code tables. [ENUM-REF-CANDIDATE: billing_guideline|rate_cap|duplicate_entry|bad_debt|courtesy|budget_overrun|staffing_level|task_not_approved — promote to reference product]' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonDescription rdf:type rdf:Property ;
    rdfs:label 'Reason Description' ;
    rdfs:comment 'Free-text narrative explanation provided by the billing timekeeper or approving partner describing the specific circumstances justifying the write-off. Supplements the structured reason_code with contextual detail for audit and partner review purposes.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresSecondaryApproval rdf:type rdf:Property ;
    rdfs:label 'Requires Secondary Approval' ;
    rdfs:comment 'Indicates whether the write-off amount exceeds the firm\'s threshold requiring secondary approval (e.g., managing partner or finance committee sign-off in addition to the billing partner). Supports tiered approval workflow governance and write-off policy compliance.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceSystemReference rdf:type rdf:Property ;
    rdfs:label 'Source System Reference' ;
    rdfs:comment 'The native identifier or transaction reference of this write-off record in the originating source system (Elite 3E or Aderant Expert). Enables reconciliation between the lakehouse Silver layer and the operational system of record.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wipEntryDate rdf:type rdf:Property ;
    rdfs:label 'Wip Entry Date' ;
    rdfs:comment 'The date on which the original WIP time or expense entry being written off was recorded. Used to calculate WIP aging at the time of write-off and to assess how long unbilled time was carried before being written off. Null for AR (post-billing) write-offs.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:writeOffCategory rdf:type rdf:Property ;
    rdfs:label 'Write Off Category' ;
    rdfs:comment 'Distinguishes whether the write-off applies to professional fees (timekeeper charges), disbursements (client-incurred costs), firm expenses, accrued interest on overdue AR, or tax components. Drives GL account mapping and realization rate segmentation.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:writeOffDate rdf:type rdf:Property ;
    rdfs:label 'Write Off Date' ;
    rdfs:comment 'The business event date on which the write-off was formally approved and recorded. This is the principal real-world event date used for financial period close, WIP aging, and realization rate calculations. Distinct from the system audit timestamps.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:writeOffNumber rdf:type rdf:Property ;
    rdfs:label 'Write Off Number' ;
    rdfs:comment 'Externally-known business identifier for the write-off transaction, typically generated by Elite 3E or Aderant Expert. Used in partner approval workflows, GL postings, and audit trails. Format: WO-{YYYY}-{NNNNNN}.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:writeOffStatus rdf:type rdf:Property ;
    rdfs:label 'Write Off Status' ;
    rdfs:comment 'Current lifecycle state of the write-off transaction. Tracks the workflow from initial submission through partner approval, GL posting, and potential reversal. [ENUM-REF-CANDIDATE: pending_approval|approved|rejected|reversed|posted|cancelled — promote to reference product]' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:writeOffType rdf:type rdf:Property ;
    rdfs:label 'Write Off Type' ;
    rdfs:comment 'Classification of the write-off by its business nature. WIP write-off reduces unbilled time/expense value; bad debt eliminates uncollectable AR; courtesy discount reflects client relationship adjustments; billing guideline reduction reflects client-mandated rate or task reductions. [ENUM-REF-CANDIDATE: wip_write_off|bad_debt|courtesy_discount|billing_guideline_reduction|fee_waiver|expense_write_off — promote to reference product]' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:docExecutionId rdf:type rdf:Property ;
    rdfs:label 'Doc Execution Id' ;
    rdfs:comment 'Foreign key linking to document.doc_execution. Business justification: Retainer arrangements are formalized by executed engagement letters or fee agreements. Linking retainer to the doc_execution record proves the retainer was formally executed — critical for trust accou' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DocExecution .

ind:matterOpeningRequestId rdf:type rdf:Property ;
    rdfs:label 'Matter Opening Request Id' ;
    rdfs:comment 'Foreign key linking to intake.matter_opening_request. Business justification: Matter opening requests include a requires_trust_account flag that mandates retainer establishment. Tracing a retainer to the matter opening request that required it is a standard trust accounting com' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MatterOpeningRequest .

ind:requestId rdf:type rdf:Property ;
    rdfs:label 'Request Id' ;
    rdfs:comment 'Foreign key linking to intake.request. Business justification: Intake requests specify whether a retainer is required as a condition of engagement. Linking retainers to the authorizing intake request supports trust account compliance audits and AML/KYC regulatory' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Request .

ind:retainerLedesClientMatterId rdf:type rdf:Property ;
    rdfs:label 'Retainer Ledes Client Matter Id' ;
    rdfs:comment 'The client-assigned matter identifier formatted per the Legal Electronic Data Exchange Standard (LEDES) specification. Required for electronic billing submissions to corporate clients and insurance carriers that mandate LEDES-format invoices.' ;
    rdfs:domain ind:Retainer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Matter .

ind:retainerMatterId rdf:type rdf:Property ;
    rdfs:label 'Retainer Matter Id' ;
    rdfs:comment 'Reference to the specific matter associated with this retainer. Null for general retainers that span all matters for a client; populated for matter-specific retainers.' ;
    rdfs:domain ind:Retainer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Matter .

ind:sarFilingId rdf:type rdf:Property ;
    rdfs:label 'Sar Filing Id' ;
    rdfs:comment 'Foreign key linking to compliance.sar_filing. Business justification: Retainer receipts are screened for AML red flags and may trigger SAR (large cash retainers, third-party funding, high-risk jurisdictions). Real business process: client funds acceptance and AML compli' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SarFiling .

ind:autoApplyToInvoiceFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Apply To Invoice Flag' ;
    rdfs:comment 'Indicates whether retainer funds should be automatically applied to reduce the outstanding balance of invoices upon generation, without requiring manual partner approval for each drawdown.' ;
    rdfs:domain ind:Retainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:drawdownAuthorizationRule rdf:type rdf:Property ;
    rdfs:label 'Drawdown Authorization Rule' ;
    rdfs:comment 'The rule governing when and how funds may be drawn from the retainer balance against earned fees or disbursements. Automatic drawdown applies retainer funds upon invoice generation; manual approval requires explicit partner sign-off; threshold-triggered drawdown applies when WIP reaches a defined level; periodic scheduled drawdown occurs on a fixed calendar basis.' ;
    rdfs:domain ind:Retainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drawdownViaPayment rdf:type rdf:Property ;
    rdfs:label 'Drawdown Via Payment' ;
    rdfs:comment 'FK to billing.payment.payment_id — Retainer drawdowns are processed as payment applications. This FK connects retainer balance management to the payment/AR cycle.' ;
    rdfs:domain ind:Retainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:evergreenFlag rdf:type rdf:Property ;
    rdfs:label 'Evergreen Flag' ;
    rdfs:comment 'Indicates whether this retainer is structured as an evergreen arrangement, meaning the client is contractually obligated to replenish the balance to the target amount whenever it falls below the replenishment threshold. Drives automated replenishment demand workflows.' ;
    rdfs:domain ind:Retainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interestBearingFlag rdf:type rdf:Property ;
    rdfs:label 'Interest Bearing Flag' ;
    rdfs:comment 'Indicates whether the retainer funds held in the associated trust account are subject to interest accrual under IOLTA or client-specific interest arrangements. True if interest is earned and must be reported or remitted.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kycVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Kyc Verified Flag' ;
    rdfs:comment 'Indicates whether the client associated with this retainer has completed Know Your Client (KYC) and Anti-Money Laundering (AML) verification checks prior to the retainer being activated. Mandatory for regulatory compliance before funds are accepted.' ;
    rdfs:domain ind:Retainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastDrawdownDate rdf:type rdf:Property ;
    rdfs:label 'Last Drawdown Date' ;
    rdfs:comment 'The date on which the most recent drawdown was applied against this retainer. Used for activity monitoring, dormancy detection, and collections follow-up.' ;
    rdfs:domain ind:Retainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastReplenishmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Replenishment Date' ;
    rdfs:comment 'The date on which the most recent replenishment payment was received and applied to this retainer balance. Used for cash flow monitoring and client payment behaviour analysis.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:refundableFlag rdf:type rdf:Property ;
    rdfs:label 'Refundable Flag' ;
    rdfs:comment 'Indicates whether any unused retainer balance is refundable to the client upon matter closure or retainer termination. Governs the treatment of residual balances in the billing close-out process.' ;
    rdfs:domain ind:Retainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:replenishmentDemandDate rdf:type rdf:Property ;
    rdfs:label 'Replenishment Demand Date' ;
    rdfs:comment 'The date on which the most recent replenishment demand was issued to the client. Used to track outstanding replenishment requests and calculate days outstanding for collections follow-up.' ;
    rdfs:domain ind:Retainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:replenishmentDueDate rdf:type rdf:Property ;
    rdfs:label 'Replenishment Due Date' ;
    rdfs:comment 'The contractual due date by which the client must remit the replenishment amount following a demand. Drives collections escalation workflows when payment is not received by this date.' ;
    rdfs:domain ind:Retainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:replenishmentTargetAmount rdf:type rdf:Property ;
    rdfs:label 'Replenishment Target Amount' ;
    rdfs:comment 'The amount to which the retainer balance should be restored upon replenishment. May equal the original_amount or a separately negotiated top-up level. Used to calculate the replenishment demand sent to the client.' ;
    rdfs:domain ind:Retainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:replenishmentThreshold rdf:type rdf:Property ;
    rdfs:label 'Replenishment Threshold' ;
    rdfs:comment 'The minimum balance level at which a replenishment request is automatically triggered and sent to the client. When current_balance falls at or below this threshold, the firm initiates a top-up demand. Critical for evergreen retainer management.' ;
    rdfs:domain ind:Retainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retainerNumber rdf:type rdf:Property ;
    rdfs:label 'Retainer Number' ;
    rdfs:comment 'Externally-visible, human-readable business identifier for the retainer arrangement. Used in client correspondence, billing statements, and engagement letters. Format: RET-YYYY-NNNNNN.' ;
    rdfs:domain ind:Retainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retainerStatus rdf:type rdf:Property ;
    rdfs:label 'Retainer Status' ;
    rdfs:comment 'Current lifecycle state of the retainer arrangement. Active indicates funds are available for drawdown; exhausted indicates the balance has been fully applied; replenishment_pending indicates a top-up request has been issued to the client; closed indicates the arrangement has been formally terminated.' ;
    rdfs:domain ind:Retainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retainerType rdf:type rdf:Property ;
    rdfs:label 'Retainer Type' ;
    rdfs:comment 'Classification of the retainer arrangement by its commercial structure. General retainers cover all matters for a client; matter-specific retainers are scoped to a single matter; evergreen retainers auto-replenish; security retainers are held as collateral; advance payment retainers are pre-payments for future services.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExemptFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Exempt Flag' ;
    rdfs:comment 'Indicates whether the fees drawn against this retainer are exempt from applicable taxes (e.g., VAT, GST, sales tax) based on the client\'s tax status or the nature of the legal services provided.' ;
    rdfs:domain ind:Retainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalDrawnToDate rdf:type rdf:Property ;
    rdfs:label 'Total Drawn To Date' ;
    rdfs:comment 'Cumulative monetary amount drawn down from this retainer since its establishment. Represents the sum of all drawdown transactions applied against earned fees and disbursements. Used for retainer utilisation reporting and client billing transparency.' ;
    rdfs:domain ind:Retainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalReplenishedToDate rdf:type rdf:Property ;
    rdfs:label 'Total Replenished To Date' ;
    rdfs:comment 'Cumulative monetary amount received from the client as retainer replenishments since the arrangement was established. Tracks all top-up receipts to support reconciliation and client account management.' ;
    rdfs:domain ind:Retainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:underFeeArrangement rdf:type rdf:Property ;
    rdfs:label 'Under Fee Arrangement' ;
    rdfs:comment 'FK to billing.fee_arrangement.fee_arrangement_id — Retainers are a component of the overall fee arrangement with a client. Linking retainer to fee_arrangement ensures the retainer terms are governed by the broader commercial agreement.' ;
    rdfs:domain ind:Retainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wipDrawdownLimit rdf:type rdf:Property ;
    rdfs:label 'Wip Drawdown Limit' ;
    rdfs:comment 'The maximum Work in Progress (WIP) amount that may accumulate before a mandatory drawdown against the retainer is triggered. Prevents unbilled WIP from exceeding the retainer balance and ensures timely billing.' ;
    rdfs:domain ind:Retainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:docTemplateId rdf:type rdf:Property ;
    rdfs:label 'Doc Template Id' ;
    rdfs:comment 'Foreign key linking to document.doc_template. Business justification: Billing guidelines mandate specific invoice templates, narrative formats, or LEDES formats. Essential for automated billing compliance, client-specific formatting requirements, and reducing billing re' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DocTemplate .

ind:outsideCounselGuidelineId rdf:type rdf:Property ;
    rdfs:label 'Outside Counsel Guideline Id' ;
    rdfs:comment 'Foreign key linking to client.outside_counsel_guideline. Business justification: Billing guidelines in legal firms are directly derived from client-issued Outside Counsel Guidelines (OCGs). This link enables OCG compliance enforcement — rate caps, billing format mandates, expense ' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OutsideCounselGuideline .

ind:supersededByGuidelineId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Guideline Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the newer billing_guideline record that replaces this one when guideline_status is superseded. Enables version chain traceability for audit and historical billing compliance review.' ;
    rdfs:domain ind:Guideline ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Guideline .

ind:afaType rdf:type rdf:Property ;
    rdfs:label 'Afa Type' ;
    rdfs:comment 'The fee arrangement type governed by this guideline. Identifies whether the guideline applies to hourly billing, a flat fee, contingency, blended rate, capped fee, or success fee arrangement. Aligns with the firm\'s AFA (Alternative Fee Arrangement) billing model.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appliesToExpenses rdf:type rdf:Property ;
    rdfs:label 'Applies To Expenses' ;
    rdfs:comment 'Indicates whether this billing guideline applies to expense/disbursement entries in addition to or instead of time entries. When True, expense line items are subject to the same rule enforcement during prebilling review.' ;
    rdfs:domain ind:Guideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appliesToTimeEntries rdf:type rdf:Property ;
    rdfs:label 'Applies To Time Entries' ;
    rdfs:comment 'Indicates whether this billing guideline applies to time entries. When True, time entry records are subject to the rule enforcement during prebilling review and LEDES submission validation.' ;
    rdfs:domain ind:Guideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:blockBillingProhibited rdf:type rdf:Property ;
    rdfs:label 'Block Billing Prohibited' ;
    rdfs:comment 'Indicates whether block billing (combining multiple tasks into a single time entry without itemisation) is prohibited under this guideline. When True, prebilling review must flag any time entries containing multiple tasks in a single narrative.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:budgetCapAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Cap Amount' ;
    rdfs:comment 'Total matter-level or phase-level budget ceiling imposed by the client under this guideline. When WIP (Work in Progress) approaches or exceeds this cap, alerts are triggered for partner review before further billing.' ;
    rdfs:domain ind:Guideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enforcementAction rdf:type rdf:Property ;
    rdfs:label 'Enforcement Action' ;
    rdfs:comment 'The system action triggered when a non-compliant entry is detected during prebilling review or LEDES submission validation. hard_block prevents invoice issuance; soft_warning alerts the billing team; write_off automatically reduces the entry; require_approval routes to partner; flag_for_review marks for manual review.' ;
    rdfs:domain ind:Guideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionNotes rdf:type rdf:Property ;
    rdfs:label 'Exception Notes' ;
    rdfs:comment 'Free-text field capturing any agreed exceptions or carve-outs to this billing guideline, such as approved deviations negotiated with the client or specific matter circumstances where the rule does not apply.' ;
    rdfs:domain ind:Guideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expenseLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Expense Limit Amount' ;
    rdfs:comment 'Maximum allowable disbursement or expense amount per transaction or per category as defined by this guideline. Populated when rule_type is expense_limit. Used to flag non-compliant expense entries during prebilling review.' ;
    rdfs:domain ind:Guideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:guidelineDescription rdf:type rdf:Property ;
    rdfs:label 'Guideline Description' ;
    rdfs:comment 'Full narrative description of the billing rule, including any conditions, exceptions, or qualifications. Provides the complete business context for the guideline as communicated by the client or as agreed in the engagement letter.' ;
    rdfs:domain ind:Guideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guidelineName rdf:type rdf:Property ;
    rdfs:label 'Guideline Name' ;
    rdfs:comment 'Human-readable name or short title of the billing guideline, such as \'Block Billing Prohibition\' or \'Senior Associate Rate Cap\'. Used for display in prebilling dashboards and compliance reports.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guidelineSource rdf:type rdf:Property ;
    rdfs:label 'Guideline Source' ;
    rdfs:comment 'Identifies the originating document or instrument from which this billing guideline derives its authority. Values: ocg (client-issued Outside Counsel Guidelines), engagement_letter (Letter of Engagement / LOE), standing_instruction (ongoing client instruction), matter_specific_agreement (matter-level side agreement), court_order (court-mandated billing restriction).' ;
    rdfs:domain ind:Guideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guidelineStatus rdf:type rdf:Property ;
    rdfs:label 'Guideline Status' ;
    rdfs:comment 'Current lifecycle state of the billing guideline. Active guidelines are enforced during prebilling review. Superseded guidelines are retained for historical audit. Pending_approval guidelines are awaiting client or partner sign-off before enforcement.' ;
    rdfs:domain ind:Guideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceSubmissionDeadlineDays rdf:type rdf:Property ;
    rdfs:label 'Invoice Submission Deadline Days' ;
    rdfs:comment 'Maximum number of days after the billing period end date within which the firm must submit an invoice to the client. Late submissions beyond this threshold may be subject to write-off or rejection per the OCG.' ;
    rdfs:domain ind:Guideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:invoiceSubmissionFrequency rdf:type rdf:Property ;
    rdfs:label 'Invoice Submission Frequency' ;
    rdfs:comment 'The required frequency at which invoices must be submitted to the client under this guideline. Governs billing cycle compliance and WIP (Work in Progress) management cadence.' ;
    rdfs:domain ind:Guideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdiction rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction' ;
    rdfs:comment 'The legal jurisdiction (ISO 3166-1 alpha-2 or alpha-3 country code) to which this billing guideline applies. Relevant for multi-jurisdictional matters where different billing rules may apply per jurisdiction.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReviewedDate rdf:type rdf:Property ;
    rdfs:label 'Last Reviewed Date' ;
    rdfs:comment 'The most recent date on which this billing guideline was reviewed for continued applicability and accuracy. Supports periodic OCG review cycles and ensures guidelines remain current with client instructions.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:minimumTimeIncrementMins rdf:type rdf:Property ;
    rdfs:label 'Minimum Time Increment Mins' ;
    rdfs:comment 'The minimum billable time increment in minutes permitted under this guideline (e.g., 6 minutes = 0.1 hour, 15 minutes = 0.25 hour). Time entries rounded to increments larger than this value may be flagged as non-compliant.' ;
    rdfs:domain ind:Guideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:narrativeMinLength rdf:type rdf:Property ;
    rdfs:label 'Narrative Min Length' ;
    rdfs:comment 'Minimum number of characters required in a time entry or expense narrative to satisfy the client\'s narrative requirement under this guideline. Entries with narratives shorter than this threshold are flagged during prebilling review.' ;
    rdfs:domain ind:Guideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:newTimekeeperRateFreeze rdf:type rdf:Property ;
    rdfs:label 'New Timekeeper Rate Freeze' ;
    rdfs:comment 'Indicates whether the client has imposed a rate freeze on newly introduced timekeepers, requiring them to bill at the same rate as the timekeeper they replace or at a pre-agreed rate. Common OCG provision to control staffing cost escalation.' ;
    rdfs:domain ind:Guideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ocgSectionReference rdf:type rdf:Property ;
    rdfs:label 'Ocg Section Reference' ;
    rdfs:comment 'Specific section, clause, or paragraph number within the OCG document that contains the rule captured by this guideline record. Supports precise audit trail and dispute resolution when a billing entry is challenged.' ;
    rdfs:domain ind:Guideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCapCurrency rdf:type rdf:Property ;
    rdfs:label 'Rate Cap Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code applicable to the rate_cap_amount (e.g., USD, GBP, EUR). Required when rate_cap_amount is populated to ensure multi-currency billing compliance.' ;
    rdfs:domain ind:Guideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateIncreaseNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Rate Increase Notice Days' ;
    rdfs:comment 'Number of calendar days advance notice the firm must provide to the client before implementing a rate increase under this guideline. Enforces the client\'s OCG requirement for rate change notification.' ;
    rdfs:domain ind:Guideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:referenceNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Number' ;
    rdfs:comment 'Externally-known alphanumeric identifier assigned by the client or law firm to uniquely reference this Outside Counsel Guideline (OCG) or billing instruction document. Used for cross-referencing with client-issued OCG documents.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleCategory rdf:type rdf:Property ;
    rdfs:label 'Rule Category' ;
    rdfs:comment 'High-level grouping of the billing rule for reporting and filtering purposes. Segments guidelines into operational categories: timekeeper (rate and staffing rules), expense (disbursement rules), invoice_format (LEDES/UTBMS formatting), matter_budget (budget and cap rules), task_code (UTBMS task code restrictions), narrative (time entry description requirements).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleType rdf:type rdf:Property ;
    rdfs:label 'Rule Type' ;
    rdfs:comment 'Categorical classification of the billing rule being enforced. Defines the nature of the compliance requirement. [ENUM-REF-CANDIDATE: rate_cap|timekeeper_approval|task_code_restriction|narrative_requirement|block_billing_prohibition|expense_limit|staffing_restriction|budget_cap|write_off_threshold|invoice_format_requirement — promote to reference product]' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timekeeperApprovalRequired rdf:type rdf:Property ;
    rdfs:label 'Timekeeper Approval Required' ;
    rdfs:comment 'Indicates whether timekeepers must be pre-approved by the client before their time can be billed under this guideline. When True, any time entry from a non-approved timekeeper is flagged as non-compliant during prebilling review.' ;
    rdfs:domain ind:Guideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wipAgingLimitDays rdf:type rdf:Property ;
    rdfs:label 'Wip Aging Limit Days' ;
    rdfs:comment 'Maximum number of days that unbilled WIP (Work in Progress) may remain outstanding before it must be billed or written off per the client\'s guideline. Supports WIP management and collections compliance.' ;
    rdfs:domain ind:Guideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:invoiceDisputeId rdf:type rdf:Property ;
    rdfs:label 'Invoice Dispute Id' ;
    rdfs:comment 'Unique system-generated identifier for each invoice dispute record. Primary key for the invoice_dispute data product within the billing domain.' ;
    rdfs:domain ind:InvoiceDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contactId rdf:type rdf:Property ;
    rdfs:label 'Contact Id' ;
    rdfs:comment 'Foreign key linking to client.client_contact. Business justification: Invoice disputes are raised by a specific client contact. The plain attributes `client_contact_email` and `client_contact_name` on invoice_dispute are denormalized representations of client.client_con' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:creditNoteId rdf:type rdf:Property ;
    rdfs:label 'Credit Note Id' ;
    rdfs:comment 'Foreign key linking to billing.credit_note. Business justification: Invoice disputes often result in credit notes being issued to adjust the disputed amount. Currently invoice_dispute has credit_note_number (string) but no FK to the credit_note record. Adding credit_n' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CreditNote .

ind:disputedTimeEntryId rdf:type rdf:Property ;
    rdfs:label 'Disputed Time Entry Id' ;
    rdfs:comment 'Reference to the specific time entry record being disputed, where the dispute is at the line-item level. Null when the dispute applies to multiple entries or the full invoice. Enables granular WIP (Work in Progress) and realization analytics.' ;
    rdfs:domain ind:InvoiceDispute ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TimeEntry .

ind:obligationId rdf:type rdf:Property ;
    rdfs:label 'Obligation Id' ;
    rdfs:comment 'Foreign key linking to contract.obligation. Business justification: Invoice disputes in legal services arise from specific contract obligations (rate caps, expense limits, billing guideline clauses). Linking to the specific obligation being disputed enables obligation' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Obligation .

ind:primaryInvoiceMatterId rdf:type rdf:Property ;
    rdfs:label 'Primary Invoice Matter Id' ;
    rdfs:comment 'Reference to the legal matter associated with the disputed invoice. Enables dispute analysis by practice area, matter type, and responsible attorney.' ;
    rdfs:domain ind:InvoiceDispute ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Matter .

ind:tertiaryInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Invoice Id' ;
    rdfs:comment 'FK to billing.invoice.invoice_id — Disputes are raised against specific invoices. This FK enables dispute tracking, resolution workflow, and realization impact analysis.' ;
    rdfs:domain ind:InvoiceDispute ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:agreedReductionAmount rdf:type rdf:Property ;
    rdfs:label 'Agreed Reduction Amount' ;
    rdfs:comment 'The monetary amount agreed between the firm and the client as the final reduction to the invoice following dispute resolution. May be less than, equal to, or zero relative to the disputed amount. Feeds write-off and realization rate calculations.' ;
    rdfs:domain ind:InvoiceDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingGuidelineReference rdf:type rdf:Property ;
    rdfs:label 'Billing Guideline Reference' ;
    rdfs:comment 'Reference to the specific client billing guideline clause or section that the client alleges was violated. Supports billing guideline compliance tracking and AFA (Alternative Fee Arrangement) governance.' ;
    rdfs:domain ind:InvoiceDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysToResolve rdf:type rdf:Property ;
    rdfs:label 'Days To Resolve' ;
    rdfs:comment 'Number of calendar days elapsed between the dispute_date and the resolution_date. Null while the dispute remains open. Supports SLA compliance measurement and dispute cycle time benchmarking. Note: this is a stored operational field populated at resolution, not a real-time derived metric.' ;
    rdfs:domain ind:InvoiceDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:disputeDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Date' ;
    rdfs:comment 'The calendar date on which the client formally raised the invoice dispute. Serves as the principal business event date for aging calculations, SLA tracking, and realization rate analytics.' ;
    rdfs:domain ind:InvoiceDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disputeNumber rdf:type rdf:Property ;
    rdfs:label 'Dispute Number' ;
    rdfs:comment 'Externally-visible, human-readable reference number assigned to the dispute at the time of creation. Used in client correspondence, billing guideline audit trails, and LEDES-compliant dispute tracking. Format: DISP-YYYY-NNNNNN.' ;
    rdfs:domain ind:InvoiceDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeReasonCode rdf:type rdf:Property ;
    rdfs:label 'Dispute Reason Code' ;
    rdfs:comment 'Standardized UTBMS-aligned code categorizing the primary reason the client raised the dispute. Drives root-cause analytics and billing guideline compliance reporting. [ENUM-REF-CANDIDATE: billing_guideline_violation|rate_discrepancy|duplicate_entry|unauthorized_timekeeper|narrative_deficiency|block_billing|excessive_time|staffing_objection — promote to reference product]' ;
    rdfs:domain ind:InvoiceDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Dispute Reason Description' ;
    rdfs:comment 'Free-text narrative provided by the client or billing team elaborating on the specific grounds for the dispute. Supplements the structured reason code with contextual detail for resolution workflow and knowledge management.' ;
    rdfs:domain ind:InvoiceDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeStatus rdf:type rdf:Property ;
    rdfs:label 'Dispute Status' ;
    rdfs:comment 'Current workflow state of the invoice dispute. Drives the dispute resolution lifecycle from initial submission through final resolution or withdrawal. [ENUM-REF-CANDIDATE: open|under_review|pending_client|resolved|withdrawn|escalated — promote to reference product if additional statuses are required]' ;
    rdfs:domain ind:InvoiceDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeType rdf:type rdf:Property ;
    rdfs:label 'Dispute Type' ;
    rdfs:comment 'Classification of the dispute by the category of charge being contested: fees, disbursements, rates, specific timekeeper entries, or the entire invoice. Enables segmented dispute analytics by charge type.' ;
    rdfs:domain ind:InvoiceDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputedAmount rdf:type rdf:Property ;
    rdfs:label 'Disputed Amount' ;
    rdfs:comment 'The gross monetary amount the client is disputing on the invoice, expressed in the invoice currency. Represents the client\'s claimed reduction before any negotiation or resolution. Core input to realization rate and write-off analytics.' ;
    rdfs:domain ind:InvoiceDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ebillingPlatform rdf:type rdf:Property ;
    rdfs:label 'Ebilling Platform' ;
    rdfs:comment 'Name of the client\'s electronic billing platform through which the dispute was submitted (e.g., TyMetrix 360, Legal Tracker, BillerXpert, Passport). Supports e-billing integration and dispute channel analytics.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationDate rdf:type rdf:Property ;
    rdfs:label 'Escalation Date' ;
    rdfs:comment 'The date on which the dispute was escalated to senior management or the responsible partner. Null if the dispute has not been escalated. Supports escalation trend analysis and client relationship risk monitoring.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:escalationFlag rdf:type rdf:Property ;
    rdfs:label 'Escalation Flag' ;
    rdfs:comment 'Indicates whether the dispute has been escalated beyond the standard billing team to senior management, the responsible partner, or the client relationship team. True when escalated; False otherwise.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:invoiceAmount rdf:type rdf:Property ;
    rdfs:label 'Invoice Amount' ;
    rdfs:comment 'The total billed amount on the original invoice at the time the dispute was raised. Provides denominator context for calculating the dispute percentage and realization rate impact.' ;
    rdfs:domain ind:InvoiceDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lppFlag rdf:type rdf:Property ;
    rdfs:label 'Lpp Flag' ;
    rdfs:comment 'Indicates whether any communications or documents associated with this dispute are subject to Legal Professional Privilege (LPP). True when LPP applies; False otherwise. Governs disclosure obligations and eDiscovery handling of dispute records.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Received Timestamp' ;
    rdfs:comment 'Precise date and time at which the dispute was received and logged in the billing system. Used for SLA (Service Level Agreement) response-time measurement and audit trail purposes.' ;
    rdfs:domain ind:InvoiceDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:resolutionDate rdf:type rdf:Property ;
    rdfs:label 'Resolution Date' ;
    rdfs:comment 'The calendar date on which the invoice dispute was formally resolved and a final outcome agreed between the firm and the client. Null while the dispute remains open. Used to calculate dispute cycle time and SLA compliance.' ;
    rdfs:domain ind:InvoiceDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:resolutionNotes rdf:type rdf:Property ;
    rdfs:label 'Resolution Notes' ;
    rdfs:comment 'Free-text narrative documenting the rationale, negotiation outcome, and any conditions agreed during dispute resolution. Supports knowledge management, precedent tracking, and future billing guideline refinement.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionType rdf:type rdf:Property ;
    rdfs:label 'Resolution Type' ;
    rdfs:comment 'Categorizes the outcome of the dispute resolution process: whether the firm accepted the full disputed amount, a partial reduction, rejected the dispute, issued a credit note, wrote off the amount, or the client withdrew the dispute.' ;
    rdfs:domain ind:InvoiceDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:writeOffApproved rdf:type rdf:Property ;
    rdfs:label 'Write Off Approved' ;
    rdfs:comment 'Indicates whether the agreed reduction amount has been formally approved as a write-off in the firm\'s financial system. True when write-off approval has been granted; False when pending or not applicable. Feeds write-off analytics and PPP/PEP impact reporting.' ;
    rdfs:domain ind:InvoiceDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:writeOffApprovedDate rdf:type rdf:Property ;
    rdfs:label 'Write Off Approved Date' ;
    rdfs:comment 'The date on which the write-off of the agreed reduction amount was formally approved by the authorized approver (e.g., managing partner, billing committee). Null if write-off has not been approved. Supports financial period close and SOX controls.' ;
    rdfs:domain ind:InvoiceDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:primaryCreditInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Primary Credit Invoice Id' ;
    rdfs:comment 'Reference to the originating invoice against which this credit note is issued. Establishes the parent-child relationship between the credit note and the billed invoice for accounts receivable (AR) reconciliation.' ;
    rdfs:domain ind:CreditNote ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:primaryCreditMatterId rdf:type rdf:Property ;
    rdfs:label 'Primary Credit Matter Id' ;
    rdfs:comment 'Reference to the legal matter or case associated with the credit note. Enables matter-level profitability analysis and WIP (Work in Progress) reconciliation.' ;
    rdfs:domain ind:CreditNote ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Matter .

ind:applicationMethod rdf:type rdf:Property ;
    rdfs:label 'Application Method' ;
    rdfs:comment 'Describes how the credit note value was or will be applied. \'applied_to_ar\' — offset against an existing outstanding AR balance on the client account; \'cash_refund\' — disbursed as a cash payment back to the client; \'held_on_account\' — retained as a credit balance for future invoices; \'offset_future_invoice\' — earmarked to reduce a specific forthcoming invoice.' ;
    rdfs:domain ind:CreditNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingGuidelineRef rdf:type rdf:Property ;
    rdfs:label 'Billing Guideline Ref' ;
    rdfs:comment 'Reference identifier for the client billing guideline or outside counsel guidelines (OCG) provision that triggered or justified this credit note (e.g., a specific guideline clause number). Supports billing guideline compliance tracking and dispute resolution documentation.' ;
    rdfs:domain ind:CreditNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditNoteNumber rdf:type rdf:Property ;
    rdfs:label 'Credit Note Number' ;
    rdfs:comment 'Externally visible, human-readable unique identifier for the credit note as printed on the document issued to the client. Follows the firm\'s sequential numbering convention (e.g., CN-2024-000123). Used in client correspondence, remittance matching, and LEDES electronic billing submissions.' ;
    rdfs:domain ind:CreditNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditNoteStatus rdf:type rdf:Property ;
    rdfs:label 'Credit Note Status' ;
    rdfs:comment 'Current lifecycle state of the credit note. \'draft\' — prepared but not yet issued; \'issued\' — sent to client; \'applied\' — offset against an outstanding AR balance; \'refunded\' — cash refund disbursed to client; \'held\' — held on account for future application; \'voided\' — cancelled and reversed.' ;
    rdfs:domain ind:CreditNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditReasonCode rdf:type rdf:Property ;
    rdfs:label 'Credit Reason Code' ;
    rdfs:comment 'Standardised classification of the business reason for issuing the credit note. \'overbilling\' — fees or disbursements billed in excess of agreed rates; \'dispute_resolution\' — credit issued as part of a formal billing dispute settlement; \'goodwill_adjustment\' — discretionary reduction to maintain client relationship; \'fee_cap_correction\' — invoice exceeded an agreed AFA (Alternative Fee Arrangement) or matter budget cap; \'billing_error\' — administrative or data entry error on the original invoice; \'write_off\' — uncollectable amount formally written off. [ENUM-REF-CANDIDATE: overbilling|dispute_resolution|goodwill_adjustment|fee_cap_correction|billing_error|write_off — promote to reference product]' ;
    rdfs:domain ind:CreditNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditReasonNarrative rdf:type rdf:Property ;
    rdfs:label 'Credit Reason Narrative' ;
    rdfs:comment 'Free-text description providing the detailed business justification for the credit note, supplementing the structured credit_reason_code. May reference specific time entries, disbursements, or billing guideline violations. Classified confidential as it may contain commercially sensitive negotiation details or LPP (Legal Professional Privilege) adjacent information.' ;
    rdfs:domain ind:CreditNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditType rdf:type rdf:Property ;
    rdfs:label 'Credit Type' ;
    rdfs:comment 'Categorises the nature of the credit note by the component of the original invoice being reversed. \'fee_credit\' — applies only to professional fees; \'disbursement_credit\' — applies only to disbursements and expenses; \'tax_credit\' — applies only to the tax component; \'combined\' — spans multiple invoice components.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disbursementCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Disbursement Credit Amount' ;
    rdfs:comment 'The amount of disbursements and client-chargeable expenses being credited on this credit note. Includes hard costs (court filing fees, expert witness fees) and soft costs (photocopying, courier). Expressed in the billing currency.' ;
    rdfs:domain ind:CreditNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeReference rdf:type rdf:Property ;
    rdfs:label 'Dispute Reference' ;
    rdfs:comment 'Reference number or identifier for the formal billing dispute, client complaint, or ADR (Alternative Dispute Resolution) proceeding that gave rise to this credit note. Populated when credit_reason_code is \'dispute_resolution\'. Classified confidential due to commercially sensitive negotiation context.' ;
    rdfs:domain ind:CreditNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Fee Credit Amount' ;
    rdfs:comment 'The gross amount of professional fees being credited or reversed on this credit note, expressed in the billing currency. Represents the pre-tax fee reduction. Used in realization rate analysis and WIP (Work in Progress) reconciliation.' ;
    rdfs:domain ind:CreditNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:issuedDate rdf:type rdf:Property ;
    rdfs:label 'Issued Date' ;
    rdfs:comment 'The calendar date on which the credit note was formally issued and transmitted to the client. This is the principal business event date for the credit note lifecycle, used for AR ageing, period-end close, and tax reporting.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originatingInvoiceDate rdf:type rdf:Property ;
    rdfs:label 'Originating Invoice Date' ;
    rdfs:comment 'The issuance date of the original invoice being credited. Used to calculate the elapsed time between invoice issuance and credit note issuance for billing dispute analytics and SLA (Service Level Agreement) compliance reporting.' ;
    rdfs:domain ind:CreditNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originatingInvoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Originating Invoice Number' ;
    rdfs:comment 'The human-readable invoice number of the original invoice being reversed or reduced by this credit note. Stored as a denormalised reference to support client-facing documents and LEDES electronic billing submissions without requiring a join.' ;
    rdfs:domain ind:CreditNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Credit Amount' ;
    rdfs:comment 'The tax component (e.g., VAT, GST, sales tax) being reversed or adjusted on this credit note. Must be reported separately for tax authority compliance and VAT/GST return reconciliation.' ;
    rdfs:domain ind:CreditNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxJurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction Code' ;
    rdfs:comment 'ISO country or sub-national jurisdiction code identifying the tax authority under which the VAT, GST, or sales tax credit is calculated and reported. Required for multi-jurisdictional tax compliance and VAT/GST return reconciliation.' ;
    rdfs:domain ind:CreditNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Total Credit Amount' ;
    rdfs:comment 'The total gross value of the credit note inclusive of fees, disbursements, and tax adjustments (fee_credit_amount + disbursement_credit_amount + tax_credit_amount). This is the net amount by which the client\'s AR balance is reduced or refunded. Core field for AR reconciliation and financial reporting.' ;
    rdfs:domain ind:CreditNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:voidedDate rdf:type rdf:Property ;
    rdfs:label 'Voided Date' ;
    rdfs:comment 'The date on which the credit note was voided or cancelled. Populated only when credit_note_status is \'voided\'. Required for audit trail and period-end reversal processing.' ;
    rdfs:domain ind:CreditNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:writeOffApprovedFlag rdf:type rdf:Property ;
    rdfs:label 'Write Off Approved Flag' ;
    rdfs:comment 'Indicates whether the credit note has been formally approved as a write-off (True) by the authorised partner or finance committee. Relevant when credit_reason_code is \'write_off\'. Required for bad debt provisioning, GL (General Ledger) write-off posting, and SOX (Sarbanes-Oxley Act) internal controls.' ;
    rdfs:domain ind:CreditNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:categoryId rdf:type rdf:Property ;
    rdfs:label 'Category Id' ;
    rdfs:comment 'Foreign key linking to risk.risk_category. Business justification: risk_register has risk_category (STRING) attribute that should normalize to risk_category reference table for consistency with risk_assessment and to ensure taxonomy integrity.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Category .

ind:actualClosureDate rdf:type rdf:Property ;
    rdfs:label 'Actual Closure Date' ;
    rdfs:comment 'The date on which the risk was formally closed, either because it was fully mitigated, accepted, or the risk event is no longer applicable. Null for open risks.' ;
    rdfs:domain ind:Register ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:escalationLevel rdf:type rdf:Property ;
    rdfs:label 'Escalation Level' ;
    rdfs:comment 'Current escalation tier for this risk item, indicating the highest governance level to which the risk has been formally escalated. None indicates no escalation beyond the risk owner.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedFinancialExposure rdf:type rdf:Property ;
    rdfs:label 'Estimated Financial Exposure' ;
    rdfs:comment 'Estimated monetary value of the firm\'s financial exposure if this risk materialises, expressed in the firm\'s base currency. Includes potential professional indemnity claims, regulatory fines, and remediation costs. Classified confidential.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exceptionApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Exception Approved By' ;
    rdfs:comment 'Name and role of the senior authority (e.g., Managing Partner, General Counsel, Risk Committee Chair) who formally approved the policy exception for this risk. Populated only when is_exception_approved is True.' ;
    rdfs:domain ind:Register ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Exception Expiry Date' ;
    rdfs:comment 'The date on which the approved policy exception expires and must be re-evaluated or revoked. Null if no exception is in force. Drives exception renewal alerts.' ;
    rdfs:domain ind:Register ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:identifiedDate rdf:type rdf:Property ;
    rdfs:label 'Identified Date' ;
    rdfs:comment 'The calendar date on which this risk was first identified and logged in the risk register. Serves as the principal business event date for the risk lifecycle and is used in ageing analysis.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inherentImpact rdf:type rdf:Property ;
    rdfs:label 'Inherent Impact' ;
    rdfs:comment 'Impact rating of the risk materialising before any controls are applied, scored on a 1–5 scale (1=Negligible, 2=Minor, 3=Moderate, 4=Major, 5=Catastrophic). Combined with inherent_likelihood to produce the inherent risk rating.' ;
    rdfs:domain ind:Register ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inherentLikelihood rdf:type rdf:Property ;
    rdfs:label 'Inherent Likelihood' ;
    rdfs:comment 'Likelihood rating of the risk occurring before any controls are applied, scored on a 1–5 scale (1=Rare, 2=Unlikely, 3=Possible, 4=Likely, 5=Almost Certain) per the firm\'s risk appetite matrix. Used to compute the inherent risk rating.' ;
    rdfs:domain ind:Register ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inherentRiskRating rdf:type rdf:Property ;
    rdfs:label 'Inherent Risk Rating' ;
    rdfs:comment 'Pre-control risk score calculated as inherent_likelihood × inherent_impact (range 1–25). Represents the gross risk exposure before mitigation. Used to prioritise risk treatment and populate the firm\'s risk heat map.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceClaimRef rdf:type rdf:Property ;
    rdfs:label 'Insurance Claim Ref' ;
    rdfs:comment 'Reference number of the professional indemnity insurance claim raised with the firm\'s insurer in relation to this risk event. Populated when a claim has been formally notified to the insurer. Classified confidential.' ;
    rdfs:domain ind:Register ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isExceptionApproved rdf:type rdf:Property ;
    rdfs:label 'Is Exception Approved' ;
    rdfs:comment 'Indicates whether a formal policy exception has been approved for this risk, permitting a deviation from the firm\'s standard risk management policy. True when an approved exception is in force.' ;
    rdfs:domain ind:Register ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lppApplies rdf:type rdf:Property ;
    rdfs:label 'Lpp Applies' ;
    rdfs:comment 'Indicates whether Legal Professional Privilege (LPP) applies to the risk record or associated documentation, restricting disclosure in regulatory investigations or litigation. Governs access controls and eDiscovery handling.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mitigationDescription rdf:type rdf:Property ;
    rdfs:label 'Mitigation Description' ;
    rdfs:comment 'Narrative description of the specific controls, actions, and measures implemented or planned to mitigate this risk. Includes procedural, technical, and contractual controls. Classified confidential as it may reveal security posture.' ;
    rdfs:domain ind:Register ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mitigationStatus rdf:type rdf:Property ;
    rdfs:label 'Mitigation Status' ;
    rdfs:comment 'Current implementation status of the risk mitigation actions. Tracks whether controls have been designed, are being implemented, are fully operational, are overdue, or have been formally deferred.' ;
    rdfs:domain ind:Register ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Review Date' ;
    rdfs:comment 'Scheduled date for the next formal review of this risk record by the risk owner or Risk Committee. Drives the review cycle scheduling process and generates overdue alerts when breached.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:piiInvolved rdf:type rdf:Property ;
    rdfs:label 'Pii Involved' ;
    rdfs:comment 'Indicates whether Personally Identifiable Information (PII) is involved in this risk event (e.g., a data breach affecting client or employee personal data). True triggers GDPR/CCPA data breach assessment workflows.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryBody rdf:type rdf:Property ;
    rdfs:label 'Regulatory Body' ;
    rdfs:comment 'Name of the regulatory authority to which this risk or incident must be reported (e.g., SRA, ICO, FCA, ABA, Law Society). Populated when regulatory_reporting_required is True. Free-text to accommodate multi-jurisdictional reporting.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Date' ;
    rdfs:comment 'Date on which the firm formally notified the relevant regulatory body of this risk event or data breach. Null if notification has not yet been made. Critical for GDPR 72-hour breach notification compliance tracking.' ;
    rdfs:domain ind:Register ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryReportingRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Required' ;
    rdfs:comment 'Indicates whether this risk event or incident requires mandatory notification to a regulatory body (e.g., SRA, ICO under GDPR Article 33, FCA). True triggers the regulatory reporting workflow.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:residualImpact rdf:type rdf:Property ;
    rdfs:label 'Residual Impact' ;
    rdfs:comment 'Impact rating of the risk materialising after all current controls and mitigations have been applied, scored on a 1–5 scale. Combined with residual_likelihood to produce the residual risk rating.' ;
    rdfs:domain ind:Register ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:residualLikelihood rdf:type rdf:Property ;
    rdfs:label 'Residual Likelihood' ;
    rdfs:comment 'Likelihood rating of the risk occurring after all current controls and mitigations have been applied, scored on a 1–5 scale. Reflects the effectiveness of implemented controls.' ;
    rdfs:domain ind:Register ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:residualRiskRating rdf:type rdf:Property ;
    rdfs:label 'Residual Risk Rating' ;
    rdfs:comment 'Post-control risk score calculated as residual_likelihood × residual_impact (range 1–25). Represents the net risk exposure after mitigation. Primary metric for Risk Committee reporting and SRA regulatory submissions.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskDescription rdf:type rdf:Property ;
    rdfs:label 'Risk Description' ;
    rdfs:comment 'Detailed narrative describing the risk event, its potential causes, and the circumstances under which it could materialise. May contain sensitive matter or client information and is classified confidential.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskDomain rdf:type rdf:Property ;
    rdfs:label 'Risk Domain' ;
    rdfs:comment 'Indicates whether the risk is enterprise-wide or scoped to a specific domain such as a matter, client relationship, workforce, technology infrastructure, or third-party supplier.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskRefCode rdf:type rdf:Property ;
    rdfs:label 'Risk Ref Code' ;
    rdfs:comment 'Human-readable, externally referenceable unique code assigned to each risk item (e.g., RSK-2024-00123). Used in Risk Committee reports, SRA submissions, and cross-domain communications.' ;
    rdfs:domain ind:Register ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskStatus rdf:type rdf:Property ;
    rdfs:label 'Risk Status' ;
    rdfs:comment 'Current lifecycle state of the risk record. Open: identified and active. Under_review: being assessed. Mitigated: controls applied. Accepted: formally accepted with approval. Escalated: referred to Risk Committee or senior management. Closed: risk no longer active.' ;
    rdfs:domain ind:Register ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskSubcategory rdf:type rdf:Property ;
    rdfs:label 'Risk Subcategory' ;
    rdfs:comment 'Secondary classification providing granular segmentation within the primary risk category (e.g., \'Phishing Attack\' under cybersecurity, \'Missed Limitation Deadline\' under professional_indemnity, \'GDPR Data Subject Request Failure\' under data_breach). Free-text to accommodate evolving risk taxonomy.' ;
    rdfs:domain ind:Register ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskTitle rdf:type rdf:Property ;
    rdfs:label 'Risk Title' ;
    rdfs:comment 'Short, descriptive title summarising the nature of the risk (e.g., \'Unauthorised disclosure of client PII via email\'). Used as the primary label in risk dashboards and committee reports.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskTreatment rdf:type rdf:Property ;
    rdfs:label 'Risk Treatment' ;
    rdfs:comment 'The chosen treatment approach for this risk: mitigate (apply controls to reduce likelihood/impact), accept (formally acknowledge within appetite), transfer (insurance or contractual transfer), avoid (cease the activity), escalate (refer to senior governance body).' ;
    rdfs:domain ind:Register ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetClosureDate rdf:type rdf:Property ;
    rdfs:label 'Target Closure Date' ;
    rdfs:comment 'The planned date by which the risk is expected to be fully mitigated or closed. Used for tracking mitigation progress and reporting overdue items to the Risk Committee.' ;
    rdfs:domain ind:Register ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:parentCategoryId rdf:type rdf:Property ;
    rdfs:label 'Parent Category Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the parent risk category, enabling a hierarchical taxonomy (e.g., \'Data Privacy – PII/GDPR\' as a child of \'Regulatory Risk\'). Null for top-level categories.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Category .

ind:amlRelevanceFlag rdf:type rdf:Property ;
    rdfs:label 'Aml Relevance Flag' ;
    rdfs:comment 'Indicates whether this risk category is associated with Anti-Money Laundering (AML) or sanctions screening obligations. When true, matters and clients under this category require enhanced Know Your Client (KYC) due diligence and Suspicious Activity Report (SAR) monitoring.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:applicableJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Applicable Jurisdiction' ;
    rdfs:comment 'ISO 3166-1 alpha-2 or alpha-3 country code indicating the primary jurisdiction in which this risk category applies. Use \'GLB\' for globally applicable categories. Supports multi-jurisdictional risk management across the firm\'s international offices.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryCode rdf:type rdf:Property ;
    rdfs:label 'Category Code' ;
    rdfs:comment 'Firm-assigned alphanumeric code uniquely identifying the risk category within the enterprise risk taxonomy (e.g., PI-001 for Professional Indemnity, DP-001 for Data Privacy). Used as the stable business key across risk register, incident management, and compliance reporting systems.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryDescription rdf:type rdf:Property ;
    rdfs:label 'Category Description' ;
    rdfs:comment 'Detailed narrative description of the risk category, including the nature of the risk, typical triggers, and the business functions or matters most exposed. Supports risk awareness training and knowledge management.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryName rdf:type rdf:Property ;
    rdfs:label 'Category Name' ;
    rdfs:comment 'Human-readable name of the risk category as used in firm-wide risk registers, compliance dashboards, and management reporting (e.g., \'Professional Indemnity\', \'Data Privacy – PII/GDPR\', \'Cybersecurity – ISO 27001\', \'Sanctions and AML\', \'Reputational Risk\', \'Operational Risk\', \'Regulatory Compliance Risk\').' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryStatus rdf:type rdf:Property ;
    rdfs:label 'Category Status' ;
    rdfs:comment 'Current lifecycle status of this risk category within the firm\'s taxonomy. \'Active\' categories are available for use in risk register entries; \'deprecated\' categories are retained for historical reporting only; \'under_review\' categories are pending approval for modification.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlFrameworkReference rdf:type rdf:Property ;
    rdfs:label 'Control Framework Reference' ;
    rdfs:comment 'Reference to the specific control framework, standard, or policy document that governs the mitigating controls applicable to this risk category (e.g., \'ISO 27001 Annex A\', \'GDPR Article 32 Technical Measures\', \'SRA AML Policy\', \'FATF Recommendation 10\'). Enables traceability from risk category to control library.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cybersecurityRelevanceFlag rdf:type rdf:Property ;
    rdfs:label 'Cybersecurity Relevance Flag' ;
    rdfs:comment 'Indicates whether this risk category falls within the scope of the firm\'s ISO 27001 Information Security Management System (ISMS). When true, associated risks are subject to ISO 27001 Annex A control requirements and must be included in the Statement of Applicability.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:effectiveFromDate rdf:type rdf:Property ;
    rdfs:label 'Effective From Date' ;
    rdfs:comment 'Date from which this risk category became or becomes effective within the firm\'s risk taxonomy. Supports temporal validity tracking and ensures risk register entries are only associated with categories that were active at the time of the risk event.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveToDate rdf:type rdf:Property ;
    rdfs:label 'Effective To Date' ;
    rdfs:comment 'Date on which this risk category ceases to be effective within the firm\'s risk taxonomy. Null for currently active categories. Enables point-in-time risk reporting and historical taxonomy reconstruction.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:externalReferenceCode rdf:type rdf:Property ;
    rdfs:label 'External Reference Code' ;
    rdfs:comment 'External standard or regulatory reference code that maps this risk category to an industry-standard taxonomy (e.g., ISO 31000 risk category code, COSO ERM category, SRA Risk Outlook category code). Supports benchmarking and regulatory reporting alignment.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingBody rdf:type rdf:Property ;
    rdfs:label 'Governing Body' ;
    rdfs:comment 'Name of the primary regulatory or professional body whose rules or standards give rise to this risk category (e.g., \'Solicitors Regulation Authority\', \'American Bar Association\', \'Financial Action Task Force\', \'Information Commissioner\'s Office\'). Supports jurisdiction-specific risk reporting.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Level' ;
    rdfs:comment 'Numeric depth of this category within the risk taxonomy hierarchy. Level 1 represents top-level domains; higher values represent increasingly granular sub-categories. Supports hierarchical roll-up in risk dashboards and regulatory reports.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hierarchyPath rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Path' ;
    rdfs:comment 'Delimited string representing the full ancestry path of the risk category within the taxonomy (e.g., \'Regulatory Risk > Data Privacy > PII/GDPR\'). Facilitates breadcrumb navigation and hierarchical filtering in risk reporting tools.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inherentRiskScore rdf:type rdf:Property ;
    rdfs:label 'Inherent Risk Score' ;
    rdfs:comment 'Numeric composite score representing the firm\'s inherent (pre-control) exposure for this risk category, calculated as the product of likelihood and impact ratings on the firm\'s standard risk matrix. Provides a baseline for risk prioritisation before mitigating controls are applied.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastReviewedBy rdf:type rdf:Property ;
    rdfs:label 'Last Reviewed By' ;
    rdfs:comment 'Name or identifier of the risk owner, partner, or committee member who last formally reviewed and approved this risk category. Supports accountability and audit trail requirements under the firm\'s risk governance framework.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lppRelevanceFlag rdf:type rdf:Property ;
    rdfs:label 'Lpp Relevance Flag' ;
    rdfs:comment 'Indicates whether this risk category involves matters that may engage Legal Professional Privilege (LPP), requiring special handling protocols to preserve privilege and avoid inadvertent waiver. Relevant for litigation, regulatory investigation, and eDiscovery risk categories.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:matterTypeApplicability rdf:type rdf:Property ;
    rdfs:label 'Matter Type Applicability' ;
    rdfs:comment 'Comma-separated list or description of the matter types or practice areas to which this risk category is most applicable (e.g., \'Litigation, Arbitration\', \'M&A, Corporate Transactions\', \'IP Portfolio Management\', \'All Matters\'). Guides risk assessment scoping during matter intake.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationDeadlineDays rdf:type rdf:Property ;
    rdfs:label 'Notification Deadline Days' ;
    rdfs:comment 'Maximum number of calendar days within which a risk incident under this category must be reported to the relevant regulatory authority (e.g., 72 hours / 3 days for GDPR personal data breaches under Article 33). Null if no mandatory external notification applies.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ownerRole rdf:type rdf:Property ;
    rdfs:label 'Owner Role' ;
    rdfs:comment 'Job title or role designation of the individual or function responsible for owning and managing risks under this category at the firm level (e.g., \'Chief Risk Officer\', \'Data Protection Officer\', \'General Counsel\', \'Head of Compliance\'). Distinct from matter-level risk owners.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:piiRelevanceFlag rdf:type rdf:Property ;
    rdfs:label 'Pii Relevance Flag' ;
    rdfs:comment 'Indicates whether this risk category is directly associated with the handling, processing, or breach of Personally Identifiable Information (PII). When true, risk register entries under this category are subject to GDPR Article 33/34 breach notification obligations and DPA compliance controls.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:professionalIndemnityFlag rdf:type rdf:Property ;
    rdfs:label 'Professional Indemnity Flag' ;
    rdfs:comment 'Indicates whether this risk category is relevant to the firm\'s professional indemnity insurance exposure. When true, incidents under this category must be reported to the firm\'s PI insurer and tracked in the claims management process.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryFramework rdf:type rdf:Property ;
    rdfs:label 'Regulatory Framework' ;
    rdfs:comment 'Primary regulatory or legal framework associated with this risk category (e.g., GDPR, ISO 27001, FATF AML, SOX, SRA Code of Conduct, ABA Model Rules, PCI DSS, CCPA). Used to link risk categories to applicable compliance obligations and regulatory reporting requirements.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualRiskScore rdf:type rdf:Property ;
    rdfs:label 'Residual Risk Score' ;
    rdfs:comment 'Numeric composite score representing the firm\'s residual (post-control) exposure for this risk category after mitigating controls have been applied. Used to assess whether the risk falls within the firm\'s risk appetite threshold.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reviewFrequency rdf:type rdf:Property ;
    rdfs:label 'Review Frequency' ;
    rdfs:comment 'Mandated frequency at which risk register entries under this category must be formally reviewed and updated by the responsible risk owner. Supports the firm\'s periodic risk assessment cycle and regulatory compliance obligations.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskAppetiteLevel rdf:type rdf:Property ;
    rdfs:label 'Risk Appetite Level' ;
    rdfs:comment 'Qualitative risk appetite classification for this category as declared in the firm\'s risk appetite framework. \'Zero tolerance\' applies to categories such as sanctions breaches and money laundering; \'low\' to professional indemnity and data privacy; \'moderate\' to operational risk.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskAppetiteThreshold rdf:type rdf:Property ;
    rdfs:label 'Risk Appetite Threshold' ;
    rdfs:comment 'Maximum acceptable residual risk score for this category as defined in the firm\'s risk appetite statement. Residual scores exceeding this threshold trigger escalation to the Risk Committee or Managing Partner. Aligns with SRA and ABA professional conduct obligations.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:riskImpactRating rdf:type rdf:Property ;
    rdfs:label 'Risk Impact Rating' ;
    rdfs:comment 'Standard impact rating assigned to this risk category, reflecting the potential severity of harm to the firm, its clients, or third parties if the risk materialises. Covers financial, reputational, regulatory, and operational impact dimensions.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskLikelihoodRating rdf:type rdf:Property ;
    rdfs:label 'Risk Likelihood Rating' ;
    rdfs:comment 'Standard likelihood rating assigned to this risk category within the firm\'s risk appetite framework, indicating the probability of occurrence. Used as the default likelihood baseline when creating new risk register entries under this category.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskType rdf:type rdf:Property ;
    rdfs:label 'Risk Type' ;
    rdfs:comment 'Classification of the risk category by its nature within the risk management lifecycle: inherent (pre-control), residual (post-control), emerging (newly identified), or systemic (firm-wide structural exposure). Drives how risk assessments are scoped and reported.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sortOrder rdf:type rdf:Property ;
    rdfs:label 'Sort Order' ;
    rdfs:comment 'Integer value controlling the display sequence of this risk category in risk registers, dashboards, and dropdown selection lists. Lower values appear first. Enables consistent presentation across risk management tools and reports.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assessmentId rdf:type rdf:Property ;
    rdfs:label 'Assessment Id' ;
    rdfs:comment 'Unique surrogate identifier for each formal risk assessment record within the enterprise risk register. Primary key for the risk_assessment data product.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Assessment .

ind:beneficialOwnerId rdf:type rdf:Property ;
    rdfs:label 'Beneficial Owner Id' ;
    rdfs:comment 'Foreign key linking to client.beneficial_owner. Business justification: UBO due diligence assessment: risk assessments are conducted specifically on beneficial owners as part of the AML/KYC programme. Linking the assessment to the assessed beneficial owner is required for' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BeneficialOwner .

ind:kycRecordId rdf:type rdf:Property ;
    rdfs:label 'Kyc Record Id' ;
    rdfs:comment 'Foreign key linking to client.kyc_record. Business justification: Enhanced Due Diligence (EDD) process: risk assessments are formally conducted against KYC records during periodic KYC reviews. Linking the assessment to the specific KYC record it evaluated is require' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:KycRecord .

ind:riskControlId rdf:type rdf:Property ;
    rdfs:label 'Risk Control Id' ;
    rdfs:comment 'Foreign key linking to risk.risk_control. Business justification: Risk assessments evaluate the effectiveness of specific controls. Business semantics: \'this assessment evaluated this control.\' Valid relationship for control effectiveness tracking.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RiskControl .

ind:assessmentDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Date' ;
    rdfs:comment 'The calendar date on which the formal risk assessment was conducted. Represents the principal business event date for this assessment cycle, distinct from record creation timestamp.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assessment Status' ;
    rdfs:comment 'Current lifecycle state of the risk assessment record. Draft indicates work in progress; in_review indicates pending senior sign-off; approved indicates formally accepted; superseded indicates replaced by a newer assessment; closed indicates the risk has been retired.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlEffectivenessRating rdf:type rdf:Property ;
    rdfs:label 'Control Effectiveness Rating' ;
    rdfs:comment 'Assessment of how well the existing controls mitigate the identified risk. Drives the reduction from inherent to residual risk score. Evaluated against the firm\'s control framework aligned with ISO 27001 Annex A controls.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inherentImpactRating rdf:type rdf:Property ;
    rdfs:label 'Inherent Impact Rating' ;
    rdfs:comment 'Qualitative rating of the severity of consequence if the risk event occurs before any controls are applied. Considers financial, reputational, regulatory, and operational dimensions of impact.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inherentLikelihoodRating rdf:type rdf:Property ;
    rdfs:label 'Inherent Likelihood Rating' ;
    rdfs:comment 'Qualitative rating of the probability that the risk event will occur before any controls are applied. Represents the raw, unmitigated likelihood on a five-point scale aligned with the firm\'s risk appetite framework.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDpiaRequired rdf:type rdf:Property ;
    rdfs:label 'Is Dpia Required' ;
    rdfs:comment 'Indicates whether a Data Protection Impact Assessment (DPIA) is required for this risk item under GDPR Article 35. True when the risk involves high-risk processing of personal data, triggering mandatory DPIA before processing commences.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLppSensitive rdf:type rdf:Property ;
    rdfs:label 'Is Lpp Sensitive' ;
    rdfs:comment 'Indicates whether this risk assessment record or its associated matter is subject to Legal Professional Privilege (LPP). When True, access is restricted to authorised legal personnel and the record is excluded from certain regulatory disclosures.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:methodology rdf:type rdf:Property ;
    rdfs:label 'Methodology' ;
    rdfs:comment 'Methodology used to evaluate the risk. Qualitative uses descriptive scales; quantitative uses numerical probability and financial impact modelling; semi_quantitative combines both approaches. Determines how inherent and residual scores are interpreted.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:piiDataInvolved rdf:type rdf:Property ;
    rdfs:label 'Pii Data Involved' ;
    rdfs:comment 'Indicates whether the risk scenario involves Personally Identifiable Information (PII) or personal data as defined under GDPR. True triggers additional data protection controls and potential DPIA requirement.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reference rdf:type rdf:Property ;
    rdfs:label 'Reference' ;
    rdfs:comment 'Externally-known business identifier for the risk assessment, formatted as RA-{YYYY}-{NNNNNN}. Used in correspondence, audit trails, and regulatory submissions to uniquely reference a specific assessment cycle.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualImpactRating rdf:type rdf:Property ;
    rdfs:label 'Residual Impact Rating' ;
    rdfs:comment 'Qualitative rating of the severity of consequence after existing controls have been applied. Used alongside residual likelihood to compute the residual risk score.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualLikelihoodRating rdf:type rdf:Property ;
    rdfs:label 'Residual Likelihood Rating' ;
    rdfs:comment 'Qualitative rating of the probability that the risk event will occur after existing controls have been applied. Reflects the post-control likelihood used to determine whether residual risk is within appetite.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewCycle rdf:type rdf:Property ;
    rdfs:label 'Review Cycle' ;
    rdfs:comment 'The mandated frequency at which this risk assessment must be reviewed and refreshed. Drives scheduling of next_review_date and supports compliance with ISO 27001 periodic review requirements.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskScoreScale rdf:type rdf:Property ;
    rdfs:label 'Risk Score Scale' ;
    rdfs:comment 'The numerical scale used for inherent and residual risk scoring in this assessment (e.g., 1_to_5, 1_to_10, 1_to_25). Ensures correct interpretation of scores when the firm operates multiple scoring frameworks across practice groups.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskTreatmentOption rdf:type rdf:Property ;
    rdfs:label 'Risk Treatment Option' ;
    rdfs:comment 'The selected risk treatment strategy for this assessment. Accept means the firm tolerates the residual risk; mitigate means additional controls will be implemented; transfer means risk is shifted (e.g., via professional indemnity insurance); avoid means the risk-generating activity is discontinued.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sanctionsFlag rdf:type rdf:Property ;
    rdfs:label 'Sanctions Flag' ;
    rdfs:comment 'Indicates whether this risk assessment was triggered by or relates to a sanctions screening alert (e.g., OFAC, UN, EU sanctions lists). True requires escalation to the firm\'s Anti-Money Laundering (AML) compliance officer.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:treatmentDescription rdf:type rdf:Property ;
    rdfs:label 'Treatment Description' ;
    rdfs:comment 'Narrative description of the specific actions, controls, or measures to be implemented under the selected risk treatment option. Classified confidential as it may contain sensitive operational or legal strategy information.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentDueDate rdf:type rdf:Property ;
    rdfs:label 'Treatment Due Date' ;
    rdfs:comment 'Target date by which the agreed risk treatment actions must be completed. Used for tracking remediation progress and escalation when treatment is overdue.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:withinAppetite rdf:type rdf:Property ;
    rdfs:label 'Within Appetite' ;
    rdfs:comment 'Indicates whether the residual risk score falls within the firm\'s defined risk appetite threshold. True means the risk is acceptable; False triggers mandatory escalation and treatment action. Derived from comparing residual_risk_score against risk_appetite_threshold but stored for reporting efficiency.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:automationFlag rdf:type rdf:Property ;
    rdfs:label 'Automation Flag' ;
    rdfs:comment 'Indicates whether the control is automated (True) or manual (False). Automated controls are executed by systems (e.g., Intapp Conflicts automated screening, iManage access controls); manual controls rely on human action. Informs risk appetite assessments and operational resilience planning.' ;
    rdfs:domain ind:RiskControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:controlDescription rdf:type rdf:Property ;
    rdfs:label 'Control Description' ;
    rdfs:comment 'Detailed narrative describing the purpose, scope, and mechanism of the control, including how it addresses the identified risk. Supports ISO 27001 Statement of Applicability (SoA) documentation.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlName rdf:type rdf:Property ;
    rdfs:label 'Control Name' ;
    rdfs:comment 'Short, human-readable title of the risk control (e.g., \'Privileged Access Review\', \'PII Data Encryption at Rest\', \'Conflict Check Gate\'). Used in dashboards, audit reports, and SRA compliance reviews.' ;
    rdfs:domain ind:RiskControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlType rdf:type rdf:Property ;
    rdfs:label 'Control Type' ;
    rdfs:comment 'Classification of the control by its functional purpose in the risk management lifecycle. Preventive controls stop risk events; detective controls identify them; corrective controls remediate them; deterrent controls discourage threats; compensating controls substitute for primary controls; directive controls mandate behaviour.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deficiencyDescription rdf:type rdf:Property ;
    rdfs:label 'Deficiency Description' ;
    rdfs:comment 'Narrative description of any control deficiency, gap, or weakness identified during the most recent test. Null if no deficiency was found. Feeds the remediation workflow and is referenced in ISO 27001 nonconformity reports and SRA compliance submissions.' ;
    rdfs:domain ind:RiskControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designEffectivenessRating rdf:type rdf:Property ;
    rdfs:label 'Design Effectiveness Rating' ;
    rdfs:comment 'Assessment of whether the control is suitably designed to address the risk it targets, independent of whether it is operating correctly. Adequate: design is fit for purpose. Inadequate: design has structural gaps. Not Assessed: design review not yet completed.' ;
    rdfs:domain ind:RiskControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:domain rdf:type rdf:Property ;
    rdfs:label 'Domain' ;
    rdfs:comment 'Business risk domain that this control primarily addresses (e.g., \'Professional Indemnity\', \'Data Privacy / GDPR\', \'Cybersecurity\', \'Sanctions Screening\', \'Reputational Risk\', \'Anti-Money Laundering (AML)\', \'Conflict of Interest\'). [ENUM-REF-CANDIDATE: professional_indemnity|data_privacy|cybersecurity|sanctions_screening|reputational|aml|conflict_of_interest|regulatory_compliance — promote to reference product]' ;
    rdfs:domain ind:RiskControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceReference rdf:type rdf:Property ;
    rdfs:label 'Evidence Reference' ;
    rdfs:comment 'Document Management System (DMS) reference or iManage Work document identifier for the evidence artefact supporting the most recent control test (e.g., screenshots, logs, policy documents, access reports). Required for ISO 27001 audit evidence packages.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprRelevantFlag rdf:type rdf:Property ;
    rdfs:label 'Gdpr Relevant Flag' ;
    rdfs:comment 'Indicates whether this control is relevant to the firm\'s General Data Protection Regulation (GDPR) compliance obligations, including Personally Identifiable Information (PII) protection and data breach prevention (True) or not (False). Supports Data Protection Officer (DPO) reporting.' ;
    rdfs:domain ind:RiskControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:implementationDate rdf:type rdf:Property ;
    rdfs:label 'Implementation Date' ;
    rdfs:comment 'The date on which the control was fully implemented and became operational. Used to calculate control age, schedule periodic reviews, and demonstrate timely remediation to SRA and ISO 27001 auditors.' ;
    rdfs:domain ind:RiskControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:implementationStatus rdf:type rdf:Property ;
    rdfs:label 'Implementation Status' ;
    rdfs:comment 'Current lifecycle state of the control\'s implementation. Planned: approved but not yet started. In Progress: actively being deployed. Implemented: fully operational. Deferred: postponed with documented rationale. Not Applicable: formally excluded from scope with SoA justification.' ;
    rdfs:domain ind:RiskControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isoAnnexAReference rdf:type rdf:Property ;
    rdfs:label 'Iso Annex A Reference' ;
    rdfs:comment 'The specific ISO 27001:2022 Annex A control identifier to which this control maps (e.g., A.5.1, A.8.24). Enables traceability between the firm\'s control catalogue and the ISO certification framework. Required for Statement of Applicability (SoA) reporting.' ;
    rdfs:domain ind:RiskControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isoSoaIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Iso Soa Included Flag' ;
    rdfs:comment 'Indicates whether this control is included in the firm\'s ISO 27001 Statement of Applicability (SoA) (True) or formally excluded with documented justification (False). Mandatory field for ISO 27001 certification maintenance.' ;
    rdfs:domain ind:RiskControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastTestDate rdf:type rdf:Property ;
    rdfs:label 'Last Test Date' ;
    rdfs:comment 'Date on which the most recently completed control test instance was executed. Used to determine whether the control is within its required testing cadence and to flag overdue tests for the compliance team.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastTestOutcome rdf:type rdf:Property ;
    rdfs:label 'Last Test Outcome' ;
    rdfs:comment 'Result of the most recently completed control test instance. Pass: control operated as designed. Fail: control did not operate as designed. Partial Pass: control operated with minor deficiencies. Not Applicable: test was not applicable in the period.' ;
    rdfs:domain ind:RiskControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lppScopeFlag rdf:type rdf:Property ;
    rdfs:label 'Lpp Scope Flag' ;
    rdfs:comment 'Indicates whether this control is specifically designed to protect Legal Professional Privilege (LPP) material from unauthorised disclosure (True) or not (False). Critical for controls governing iManage Work access, Relativity matter workspaces, and client communication channels.' ;
    rdfs:domain ind:RiskControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mitigatesRisk rdf:type rdf:Property ;
    rdfs:label 'Mitigates Risk' ;
    rdfs:comment 'FK to risk.risk_register.risk_register_id — Controls are implemented to mitigate specific risks. This many-to-many relationship (via junction or FK array) is essential for control-to-risk traceability required by ISO 27001.' ;
    rdfs:domain ind:RiskControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operationalEffectivenessRating rdf:type rdf:Property ;
    rdfs:label 'Operational Effectiveness Rating' ;
    rdfs:comment 'Assessment of how well the control is operating in practice to mitigate the associated risk. Derived from the most recent completed test cycle. Effective: control operates as designed. Partially Effective: control operates but with gaps. Ineffective: control fails to mitigate risk. Not Tested: no test has been completed.' ;
    rdfs:domain ind:RiskControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:piiScopeFlag rdf:type rdf:Property ;
    rdfs:label 'Pii Scope Flag' ;
    rdfs:comment 'Indicates whether this control specifically addresses the protection of Personally Identifiable Information (PII) held by the firm (True) or not (False). Used to scope GDPR Article 32 technical and organisational measures documentation.' ;
    rdfs:domain ind:RiskControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priority rdf:type rdf:Property ;
    rdfs:label 'Priority' ;
    rdfs:comment 'Business-assigned priority level for this control, reflecting the criticality of the risk it mitigates and the urgency of maintaining its effectiveness. Used to prioritise control testing resources and remediation efforts.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceCode rdf:type rdf:Property ;
    rdfs:label 'Reference Code' ;
    rdfs:comment 'Externally-known unique alphanumeric code assigned to this control, aligned to the ISO 27001 Annex A control numbering scheme or the firm\'s internal control catalogue (e.g., ISO-A.8.1-001). Used for cross-referencing in audit reports and SRA compliance submissions.' ;
    rdfs:domain ind:RiskControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Remediation Completed Date' ;
    rdfs:comment 'Date on which the remediation action was confirmed as completed and verified. Null if remediation is not yet complete. Used to close the deficiency lifecycle and update the ISO 27001 nonconformity register.' ;
    rdfs:domain ind:RiskControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remediationDueDate rdf:type rdf:Property ;
    rdfs:label 'Remediation Due Date' ;
    rdfs:comment 'Target date by which the identified control deficiency must be remediated. Null if no remediation is required. Used to track overdue remediations and escalate to the Risk Committee and SRA as required.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remediationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Remediation Required Flag' ;
    rdfs:comment 'Indicates whether a remediation action is required as a result of the most recent control test (True) or not (False). Triggers the remediation workflow and escalation process for overdue items.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remediationStatus rdf:type rdf:Property ;
    rdfs:label 'Remediation Status' ;
    rdfs:comment 'Current status of the remediation action for any identified control deficiency. Not Required: no deficiency found. Open: remediation identified but not started. In Progress: remediation underway. Completed: deficiency resolved and verified. Overdue: remediation due date has passed without completion.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soaExclusionJustification rdf:type rdf:Property ;
    rdfs:label 'Soa Exclusion Justification' ;
    rdfs:comment 'Documented rationale for excluding this control from the ISO 27001 Statement of Applicability (SoA). Null if the control is included. Required by ISO 27001:2022 Clause 6.1.3(d) for all excluded Annex A controls.' ;
    rdfs:domain ind:RiskControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sraReportableFlag rdf:type rdf:Property ;
    rdfs:label 'Sra Reportable Flag' ;
    rdfs:comment 'Indicates whether a control failure or deficiency associated with this control is reportable to the Solicitors Regulation Authority (SRA) under mandatory reporting obligations (True) or not (False). Supports regulatory breach management workflows.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:testMethodology rdf:type rdf:Property ;
    rdfs:label 'Test Methodology' ;
    rdfs:comment 'The approach used to test the control in the most recent test instance. Inquiry: interviews with control operators. Observation: direct observation of control execution. Inspection: review of evidence documents. Re-performance: independent re-execution of the control. Walkthrough: end-to-end process trace. Automated Scan: system-generated test.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toRegister rdf:type rdf:Property ;
    rdfs:label 'To Register' ;
    rdfs:comment 'FK to risk.risk_register.risk_register_id — Controls mitigate specific risks. The risk_control description states \'linkage to mitigated risk items\'. This FK is essential for control-to-risk traceability required by ISO 27001.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:toRiskRegister rdf:type rdf:Property ;
    rdfs:label 'To Risk Register' ;
    rdfs:comment 'FK to risk.risk_register.risk_register_id — Controls mitigate specific risks. The many-to-many relationship between controls and risk items is the core of risk management. Without this link, you cannot answer \'what controls address this risk?\' ' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:checkId rdf:type rdf:Property ;
    rdfs:label 'Check Id' ;
    rdfs:comment 'Reference to the conflict check record that identified or is associated with the conflict-of-interest dimension of this exposure. Links to the conflict domain to provide the full conflict screening context without duplicating conflict data.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Check .

ind:indemnityPolicyId rdf:type rdf:Property ;
    rdfs:label 'Indemnity Policy Id' ;
    rdfs:comment 'Foreign key linking to compliance.indemnity_policy. Business justification: Indemnity exposure records track potential claims against a specific PI policy. Risk managers aggregate total exposure per policy for renewal submissions and insurer notifications. policy_number, poli' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IndemnityPolicy .

ind:terminationId rdf:type rdf:Property ;
    rdfs:label 'Termination Id' ;
    rdfs:comment 'Foreign key linking to contract.termination. Business justification: Terminations with disputes, penalties, or wrongful termination allegations directly generate indemnity exposure records. PI teams track termination-triggered exposures separately for insurance notific' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Termination .

ind:estimatedClaimValue rdf:type rdf:Property ;
    rdfs:label 'Estimated Claim Value' ;
    rdfs:comment 'The firm\'s current best estimate of the total monetary value of the potential claim arising from this exposure, expressed in the firm\'s base currency. Used for reserve-setting, PI insurance renewal, and risk appetite monitoring. Reviewed and updated as new information becomes available.' ;
    rdfs:domain ind:IndemnityExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:excessAmount rdf:type rdf:Property ;
    rdfs:label 'Excess Amount' ;
    rdfs:comment 'The amount of the policy excess (deductible) applicable to this exposure under the firm\'s professional indemnity insurance policy. Represents the portion of any claim the firm must bear before insurer coverage is triggered. Critical for net exposure calculation.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exposureLinkedToRisk rdf:type rdf:Property ;
    rdfs:label 'Exposure Linked To Risk' ;
    rdfs:comment 'FK to risk.risk_register.risk_register_id — PI exposures should reference the risk register item they relate to for consolidated risk reporting.' ;
    rdfs:domain ind:IndemnityExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exposureNarrative rdf:type rdf:Property ;
    rdfs:label 'Exposure Narrative' ;
    rdfs:comment 'Free-text description of the circumstances giving rise to this professional indemnity exposure, including the nature of the alleged failing, the client\'s complaint, and any relevant background. Confidential and subject to Legal Professional Privilege (LPP) where applicable.' ;
    rdfs:domain ind:IndemnityExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exposureReference rdf:type rdf:Property ;
    rdfs:label 'Exposure Reference' ;
    rdfs:comment 'Externally-known business reference number assigned to this PI exposure record, used in correspondence with insurers, brokers, and internal risk committees. Format: PI-{YYYY}-{NNNNNN}.' ;
    rdfs:domain ind:IndemnityExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exposureStatus rdf:type rdf:Property ;
    rdfs:label 'Exposure Status' ;
    rdfs:comment 'Current lifecycle status of the indemnity exposure record, from initial identification through insurer notification, active reservation, litigation, and final closure. Drives workflow routing and risk appetite monitoring.' ;
    rdfs:domain ind:IndemnityExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalCounselEngagedFlag rdf:type rdf:Property ;
    rdfs:label 'External Counsel Engaged Flag' ;
    rdfs:comment 'Indicates whether the firm has engaged external legal counsel to advise on or defend the claim arising from this exposure. True if external counsel has been instructed; False if the matter is being handled internally or no claim has been made.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:externalCounselFirm rdf:type rdf:Property ;
    rdfs:label 'External Counsel Firm' ;
    rdfs:comment 'Name of the external law firm engaged to advise on or defend the claim arising from this exposure. Populated when external_counsel_engaged_flag is True. Used for conflict screening and cost tracking.' ;
    rdfs:domain ind:IndemnityExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insurerNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Insurer Notification Date' ;
    rdfs:comment 'The date on which the firm formally notified its professional indemnity insurer of this exposure. Null if insurer_notified_flag is False. Used to verify compliance with policy notification obligations and to anchor the claims-made trigger.' ;
    rdfs:domain ind:IndemnityExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:insurerNotifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Insurer Notified Flag' ;
    rdfs:comment 'Indicates whether the firm\'s professional indemnity insurer has been formally notified of this exposure. A value of True confirms notification has been made; False indicates notification is pending or not yet required.' ;
    rdfs:domain ind:IndemnityExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:internalInvestigationStatus rdf:type rdf:Property ;
    rdfs:label 'Internal Investigation Status' ;
    rdfs:comment 'Current status of the firm\'s internal investigation into the circumstances giving rise to this exposure. Tracks whether a root cause analysis has been initiated, is ongoing, or has been completed and findings documented.' ;
    rdfs:domain ind:IndemnityExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Investigation Completed Date' ;
    rdfs:comment 'The date on which the firm\'s internal investigation into this exposure was formally concluded and findings documented. Null if internal_investigation_status is not \'completed\'. Used for risk governance reporting.' ;
    rdfs:domain ind:IndemnityExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:limitationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Limitation Expiry Date' ;
    rdfs:comment 'The date on which the applicable statute of limitations or limitation period for a claim arising from this exposure expires. Critical for risk management and determining whether an exposure can still give rise to a formal claim. Varies by jurisdiction and exposure type.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lppAppliesFlag rdf:type rdf:Property ;
    rdfs:label 'Lpp Applies Flag' ;
    rdfs:comment 'Indicates whether Legal Professional Privilege (LPP) applies to the documents and communications associated with this exposure record, restricting disclosure in any subsequent litigation or regulatory investigation. True if LPP is asserted; False if not applicable or waived.' ;
    rdfs:domain ind:IndemnityExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:matterCloseDate rdf:type rdf:Property ;
    rdfs:label 'Matter Close Date' ;
    rdfs:comment 'The date on which the underlying legal matter from which this exposure arises was formally closed in the practice management system. Used to calculate the elapsed time between matter closure and exposure identification, informing limitation period analysis.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:piRenewalSubmissionFlag rdf:type rdf:Property ;
    rdfs:label 'Pi Renewal Submission Flag' ;
    rdfs:comment 'Indicates whether this exposure record has been included in the firm\'s most recent professional indemnity insurance renewal submission to the insurer or broker. True confirms inclusion; False indicates it is pending inclusion or not yet due.' ;
    rdfs:domain ind:IndemnityExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:practiceArea rdf:type rdf:Property ;
    rdfs:label 'Practice Area' ;
    rdfs:comment 'The legal practice area (e.g., Corporate, Litigation, Real Estate, Employment, Intellectual Property) associated with the matter giving rise to this exposure. Enables risk concentration analysis by practice group and informs PI insurance underwriting submissions. [ENUM-REF-CANDIDATE: corporate|litigation|real_estate|employment|intellectual_property|regulatory_compliance|tax|private_client|other — promote to reference product]' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReferralFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Referral Flag' ;
    rdfs:comment 'Indicates whether this exposure has been or is required to be referred to a regulatory body (e.g., SRA, State Bar Association, Legal Services Board). True if a regulatory referral has been made or is pending. Drives compliance domain notifications.' ;
    rdfs:domain ind:IndemnityExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reputationalRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Reputational Risk Flag' ;
    rdfs:comment 'Indicates whether this exposure carries a significant reputational risk dimension beyond the financial liability, such as media attention, regulatory scrutiny, or high-profile client involvement. True triggers enhanced monitoring and senior partner escalation.' ;
    rdfs:domain ind:IndemnityExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reserveAmount rdf:type rdf:Property ;
    rdfs:label 'Reserve Amount' ;
    rdfs:comment 'The financial reserve set aside by the firm (or agreed with the insurer) to cover the estimated liability for this exposure. Feeds the firm\'s balance sheet provisioning and PI insurance renewal submissions. Distinct from the estimated claim value as it reflects the agreed reserving position.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reserveLastReviewedDate rdf:type rdf:Property ;
    rdfs:label 'Reserve Last Reviewed Date' ;
    rdfs:comment 'The date on which the financial reserve for this exposure was most recently reviewed and confirmed or updated by the risk committee or responsible partner. Ensures reserves remain current and supports PI insurance renewal accuracy.' ;
    rdfs:domain ind:IndemnityExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:riskSeverity rdf:type rdf:Property ;
    rdfs:label 'Risk Severity' ;
    rdfs:comment 'The firm\'s internal risk severity rating for this exposure, reflecting the combination of estimated financial impact and likelihood of a formal claim being made. Drives escalation protocols, partner notification requirements, and risk committee reporting.' ;
    rdfs:domain ind:IndemnityExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseCategory rdf:type rdf:Property ;
    rdfs:label 'Root Cause Category' ;
    rdfs:comment 'High-level categorisation of the root cause of the professional failing giving rise to this exposure, as determined during the firm\'s internal investigation. Used for risk management trend analysis and process improvement initiatives.' ;
    rdfs:domain ind:IndemnityExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementAmount rdf:type rdf:Property ;
    rdfs:label 'Settlement Amount' ;
    rdfs:comment 'The actual monetary amount agreed in settlement of the claim arising from this exposure. Populated only when exposure_status is \'closed\' and the matter was resolved by settlement. Null for open or litigated exposures. Used for actuarial analysis and PI renewal benchmarking.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementDate rdf:type rdf:Property ;
    rdfs:label 'Settlement Date' ;
    rdfs:comment 'The date on which the claim arising from this exposure was formally settled or resolved. Populated when exposure_status transitions to \'closed\'. Used for claims lifecycle analytics and PI insurance renewal reporting.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dataBreachIncidentId rdf:type rdf:Property ;
    rdfs:label 'Data Breach Incident Id' ;
    rdfs:comment 'Foreign key linking to risk.data_breach_incident. Business justification: pi_claim.data_breach_reference (STRING) is a free-text reference to a data breach incident that triggered or is associated with this PI claim. Normalizing this to a proper FK data_breach_incident_id →' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DataBreachIncident .

ind:adrMethod rdf:type rdf:Property ;
    rdfs:label 'Adr Method' ;
    rdfs:comment 'The Alternative Dispute Resolution (ADR) method employed or proposed for resolving the PI claim outside of formal litigation. Null or \'none\' if the claim is proceeding through court litigation or has been resolved without ADR.' ;
    rdfs:domain ind:PiClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allegedBreachDate rdf:type rdf:Property ;
    rdfs:label 'Alleged Breach Date' ;
    rdfs:comment 'The date on which the alleged act, error, or omission giving rise to the claim is said to have occurred. Relevant for determining the applicable policy period on a claims-made or occurrence basis and for limitation period analysis.' ;
    rdfs:domain ind:PiClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allegedBreachDescription rdf:type rdf:Property ;
    rdfs:label 'Alleged Breach Description' ;
    rdfs:comment 'Narrative description of the alleged act, error, or omission forming the basis of the professional indemnity claim. Includes the nature of the professional failing alleged (e.g., negligent advice, missed deadline, conflict of interest, breach of confidentiality). Protected by Legal Professional Privilege (LPP) considerations.' ;
    rdfs:domain ind:PiClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimAmount rdf:type rdf:Property ;
    rdfs:label 'Claim Amount' ;
    rdfs:comment 'The gross monetary amount claimed by the claimant against the firm, as stated in the formal claim notification or pleadings. Represents the claimant\'s quantification of alleged loss before any negotiation, mitigation, or settlement.' ;
    rdfs:domain ind:PiClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:claimCurrency rdf:type rdf:Property ;
    rdfs:label 'Claim Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the claim amount is denominated (e.g., USD, GBP, EUR). Required for multi-currency PI exposure reporting and insurer communication.' ;
    rdfs:domain ind:PiClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimDate rdf:type rdf:Property ;
    rdfs:label 'Claim Date' ;
    rdfs:comment 'The date on which the formal claim was made against the firm by the claimant or their legal representative. This is the principal business event date for the claim and determines the applicable policy year for PI insurance purposes.' ;
    rdfs:domain ind:PiClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:claimOutcome rdf:type rdf:Property ;
    rdfs:label 'Claim Outcome' ;
    rdfs:comment 'The final resolution outcome of the professional indemnity claim. Populated upon closure of the claim. Used for risk analytics, insurer reporting, and lessons-learned reviews. [ENUM-REF-CANDIDATE: settled|dismissed|judgment_for_claimant|judgment_for_firm|withdrawn|mediated|arbitrated — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PiClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Claim Reference Number' ;
    rdfs:comment 'Externally-known alphanumeric reference number assigned to the claim at inception, used in all correspondence with the PI insurer, coverage counsel, and claimant. Follows the firm\'s PI claim numbering convention (e.g., PI-2024-000123).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimStatus rdf:type rdf:Property ;
    rdfs:label 'Claim Status' ;
    rdfs:comment 'Current lifecycle status of the professional indemnity claim. Tracks progression from initial notification through investigation, insurer notification, litigation or negotiation, and final resolution. [ENUM-REF-CANDIDATE: open|under_investigation|notified_to_insurer|in_litigation|settled|closed|withdrawn — promote to reference product]' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimantJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Claimant Jurisdiction' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code representing the jurisdiction in which the claimant is domiciled or in which the claim is being pursued. Relevant for determining applicable law, limitation periods, and cross-border PI coverage.' ;
    rdfs:domain ind:PiClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimantName rdf:type rdf:Property ;
    rdfs:label 'Claimant Name' ;
    rdfs:comment 'Full legal name of the party making the professional indemnity claim against the firm. May be the firm\'s own client, a third party, or a counterparty to a transaction on which the firm advised. Classified confidential due to sensitivity of claim proceedings.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimantType rdf:type rdf:Property ;
    rdfs:label 'Claimant Type' ;
    rdfs:comment 'Classification of the claimant\'s relationship to the firm. Distinguishes between the firm\'s own clients, third parties who relied on the firm\'s work product, counterparties to transactions, and regulatory bodies bringing disciplinary claims.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureDate rdf:type rdf:Property ;
    rdfs:label 'Closure Date' ;
    rdfs:comment 'The date on which the professional indemnity claim was formally closed, whether by settlement, judgment, withdrawal, or other resolution. Null for open claims. Used to calculate claim duration and for portfolio run-off analysis.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coverageConfirmed rdf:type rdf:Property ;
    rdfs:label 'Coverage Confirmed' ;
    rdfs:comment 'Indicates whether the PI insurer has confirmed that the claim falls within the scope of the firm\'s professional indemnity policy coverage. True when coverage is confirmed; False when coverage is denied or under reservation of rights.' ;
    rdfs:domain ind:PiClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coverageDenialReason rdf:type rdf:Property ;
    rdfs:label 'Coverage Denial Reason' ;
    rdfs:comment 'Narrative explanation provided by the insurer for any denial of coverage or reservation of rights. Populated only when coverage_confirmed is False. Used for coverage dispute management and legal review.' ;
    rdfs:domain ind:PiClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deductibleAmount rdf:type rdf:Property ;
    rdfs:label 'Deductible Amount' ;
    rdfs:comment 'The self-insured retention or deductible amount applicable to this claim under the firm\'s PI policy. Represents the portion of the claim cost borne directly by the firm before insurer indemnity applies.' ;
    rdfs:domain ind:PiClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:defenceCostsIncurred rdf:type rdf:Property ;
    rdfs:label 'Defence Costs Incurred' ;
    rdfs:comment 'Cumulative legal and professional costs incurred by the firm in defending the PI claim, including external coverage counsel fees, expert witness fees, and court costs. Tracked separately from the settlement amount for insurer reimbursement and cost management purposes.' ;
    rdfs:domain ind:PiClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ethicalWallRequired rdf:type rdf:Property ;
    rdfs:label 'Ethical Wall Required' ;
    rdfs:comment 'Indicates whether an ethical wall (information barrier) has been established in Intapp Conflicts to prevent the timekeepers involved in the underlying matter from accessing PI claim information, protecting privilege and avoiding further conflict exposure.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insurerClaimReference rdf:type rdf:Property ;
    rdfs:label 'Insurer Claim Reference' ;
    rdfs:comment 'The reference number assigned to the claim by the PI insurer for tracking within the insurer\'s own claims management system. Used in all insurer correspondence and for reconciliation between the firm\'s records and the insurer\'s records.' ;
    rdfs:domain ind:PiClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationDate rdf:type rdf:Property ;
    rdfs:label 'Notification Date' ;
    rdfs:comment 'The date on which the firm formally notified its PI insurer of the claim or circumstance that may give rise to a claim. Timely notification is a condition of coverage under most PI policies; late notification may prejudice the firm\'s right to indemnity.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryReportDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Date' ;
    rdfs:comment 'The date on which the firm submitted the required regulatory report to the relevant governing body (e.g., SRA, state bar). Null if no regulatory report is required or if the report has not yet been filed.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryReportRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Required' ;
    rdfs:comment 'Indicates whether the PI claim triggers a mandatory regulatory reporting obligation, such as notification to the SRA, state bar association, or other governing body. True when reporting is required under applicable professional conduct rules.' ;
    rdfs:domain ind:PiClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:affectedSystem rdf:type rdf:Property ;
    rdfs:label 'Affected System' ;
    rdfs:comment 'Name or identifier of the IT system, application, or platform where the breach occurred (e.g., iManage Work, Elite 3E, email server, file share).' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachSeverity rdf:type rdf:Property ;
    rdfs:label 'Breach Severity' ;
    rdfs:comment 'Assessed severity level of the data breach based on volume of data, sensitivity, and potential harm to data subjects.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachSource rdf:type rdf:Property ;
    rdfs:label 'Breach Source' ;
    rdfs:comment 'Origin of the breach: internal actor, external threat actor, third-party vendor, or unknown.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientDataFlag rdf:type rdf:Property ;
    rdfs:label 'Client Data Flag' ;
    rdfs:comment 'Indicates whether confidential client data or client matter information was compromised in the breach.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:containmentDate rdf:type rdf:Property ;
    rdfs:label 'Containment Date' ;
    rdfs:comment 'Date when the breach was successfully contained and further unauthorized access or data loss was prevented.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dataCategoriesInvolved rdf:type rdf:Property ;
    rdfs:label 'Data Categories Involved' ;
    rdfs:comment 'Comma-separated list of data categories compromised in the breach (e.g., PII, special category data under GDPR Article 9, LPP-protected information, financial data, health data).' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSubjectNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Data Subject Notification Date' ;
    rdfs:comment 'Date when affected data subjects were notified of the breach, if notification was required.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dataSubjectNotificationMethod rdf:type rdf:Property ;
    rdfs:label 'Data Subject Notification Method' ;
    rdfs:comment 'Method used to notify affected data subjects of the breach (email, postal mail, phone call, public notice).' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSubjectNotificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Data Subject Notification Required Flag' ;
    rdfs:comment 'Indicates whether direct notification to affected data subjects is required under GDPR Article 34 or other applicable privacy laws.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataSubjectsAffectedCount rdf:type rdf:Property ;
    rdfs:label 'Data Subjects Affected Count' ;
    rdfs:comment 'Estimated or confirmed number of individual data subjects (clients, employees, third parties) whose personal data was compromised in the breach.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:discoveredBy rdf:type rdf:Property ;
    rdfs:label 'Discovered By' ;
    rdfs:comment 'Name or role of the individual, team, or automated system that discovered the breach (e.g., IT Security Team, employee report, automated monitoring).' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discoveryDate rdf:type rdf:Property ;
    rdfs:label 'Discovery Date' ;
    rdfs:comment 'Date when the data breach or privacy incident was first discovered or reported to the firm.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:discoveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Discovery Timestamp' ;
    rdfs:comment 'Precise timestamp when the data breach incident was first discovered, critical for GDPR 72-hour notification clock.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dpoNotifiedDate rdf:type rdf:Property ;
    rdfs:label 'Dpo Notified Date' ;
    rdfs:comment 'Date when the firm\'s Data Protection Officer was notified of the breach incident.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:estimatedFinancialImpact rdf:type rdf:Property ;
    rdfs:label 'Estimated Financial Impact' ;
    rdfs:comment 'Estimated financial impact of the breach including investigation costs, remediation costs, regulatory fines, legal fees, and potential compensation to affected parties.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forensicInvestigationFlag rdf:type rdf:Property ;
    rdfs:label 'Forensic Investigation Flag' ;
    rdfs:comment 'Indicates whether a formal forensic investigation was conducted by internal or external cybersecurity experts.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gdpr72HourDeadline rdf:type rdf:Property ;
    rdfs:label 'Gdpr 72 Hour Deadline' ;
    rdfs:comment 'Calculated timestamp representing the 72-hour deadline from discovery for notifying the supervisory authority under GDPR Article 33.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:icoNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Ico Notification Date' ;
    rdfs:comment 'Date when the breach was formally notified to the UK Information Commissioner\'s Office (ICO) or equivalent supervisory authority.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:icoNotificationStatus rdf:type rdf:Property ;
    rdfs:label 'Ico Notification Status' ;
    rdfs:comment 'Current status of the regulatory notification to the ICO or equivalent data protection authority.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icoReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Ico Reference Number' ;
    rdfs:comment 'Reference number assigned by the ICO or supervisory authority upon receipt of the breach notification.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentDate rdf:type rdf:Property ;
    rdfs:label 'Incident Date' ;
    rdfs:comment 'Estimated or confirmed date when the actual breach or unauthorized access occurred, which may differ from discovery date.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:incidentOwner rdf:type rdf:Property ;
    rdfs:label 'Incident Owner' ;
    rdfs:comment 'Name or identifier of the individual responsible for managing the breach incident response and remediation.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Incident Reference Number' ;
    rdfs:comment 'Externally-known unique reference number assigned to the data breach incident for tracking and regulatory reporting purposes. Format: DBI-YYYY-NNNNNN.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentStatus rdf:type rdf:Property ;
    rdfs:label 'Incident Status' ;
    rdfs:comment 'Current lifecycle status of the data breach incident in the investigation and remediation workflow.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceClaimFiledFlag rdf:type rdf:Property ;
    rdfs:label 'Insurance Claim Filed Flag' ;
    rdfs:comment 'Indicates whether a professional indemnity or cyber insurance claim has been filed for this breach incident.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insuranceClaimReference rdf:type rdf:Property ;
    rdfs:label 'Insurance Claim Reference' ;
    rdfs:comment 'Reference number of the insurance claim filed for this breach incident, if applicable.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lawEnforcementNotifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Law Enforcement Notified Flag' ;
    rdfs:comment 'Indicates whether law enforcement authorities were notified of the breach incident.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lawEnforcementReference rdf:type rdf:Property ;
    rdfs:label 'Law Enforcement Reference' ;
    rdfs:comment 'Reference number or case identifier assigned by law enforcement if the breach was reported to police or other authorities.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lppProtectedDataFlag rdf:type rdf:Property ;
    rdfs:label 'Lpp Protected Data Flag' ;
    rdfs:comment 'Indicates whether data protected by Legal Professional Privilege (attorney-client privileged communications) was compromised in the breach.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Notification Required Flag' ;
    rdfs:comment 'Indicates whether regulatory notification to a supervisory authority (ICO, DPA, state attorney general) is required under applicable data protection laws.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:piiCompromisedFlag rdf:type rdf:Property ;
    rdfs:label 'Pii Compromised Flag' ;
    rdfs:comment 'Indicates whether Personally Identifiable Information was compromised in the breach.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remediationActionsTaken rdf:type rdf:Property ;
    rdfs:label 'Remediation Actions Taken' ;
    rdfs:comment 'Detailed description of remediation actions taken to address the breach, prevent recurrence, and mitigate harm to data subjects (e.g., password resets, system patches, access revocation, enhanced monitoring).' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseAnalysis rdf:type rdf:Property ;
    rdfs:label 'Root Cause Analysis' ;
    rdfs:comment 'Summary of the root cause analysis conducted to identify the underlying cause of the breach and prevent future incidents.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialCategoryDataFlag rdf:type rdf:Property ;
    rdfs:label 'Special Category Data Flag' ;
    rdfs:comment 'Indicates whether special category data (sensitive personal data under GDPR Article 9: racial/ethnic origin, political opinions, religious beliefs, health data, biometric data, etc.) was compromised.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:amlRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Aml Risk Flag' ;
    rdfs:comment 'Indicates whether the matter presents elevated anti-money laundering risk requiring enhanced due diligence, source of funds verification, and suspicious activity monitoring.' ;
    rdfs:domain ind:MatterRiskProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clientCreditRiskRating rdf:type rdf:Property ;
    rdfs:label 'Client Credit Risk Rating' ;
    rdfs:comment 'Credit risk assessment of the client using standard rating scale, indicating likelihood of payment default and informing billing arrangements and retainer requirements. [ENUM-REF-CANDIDATE: AAA|AA|A|BBB|BB|B|CCC|CC|C|D — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MatterRiskProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientPaymentHistoryFlag rdf:type rdf:Property ;
    rdfs:label 'Client Payment History Flag' ;
    rdfs:comment 'Historical payment performance indicator for this client based on past matters, informing credit risk and billing strategy.' ;
    rdfs:domain ind:MatterRiskProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conflictRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Conflict Risk Level' ;
    rdfs:comment 'Assessment of potential conflicts of interest based on client relationships, adverse parties, and matter subject matter, informing ethical wall requirements and engagement decisions.' ;
    rdfs:domain ind:MatterRiskProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossBorderFlag rdf:type rdf:Property ;
    rdfs:label 'Cross Border Flag' ;
    rdfs:comment 'Indicates whether the matter involves multiple jurisdictions, triggering additional conflict-of-laws analysis and regulatory compliance requirements.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cybersecurityRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Cybersecurity Risk Level' ;
    rdfs:comment 'Assessment of cybersecurity and data breach risk for this matter based on data sensitivity, technology platforms used, third-party access, and threat landscape, informing ISO 27001 controls.' ;
    rdfs:domain ind:MatterRiskProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediscoveryVolumeExposure rdf:type rdf:Property ;
    rdfs:label 'Ediscovery Volume Exposure' ;
    rdfs:comment 'Assessment of the volume and complexity of Electronically Stored Information (ESI) that may be subject to discovery, impacting matter cost, timeline, and technology-assisted review (TAR) requirements.' ;
    rdfs:domain ind:MatterRiskProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Escalation Required Flag' ;
    rdfs:comment 'Indicates whether this matter risk profile requires escalation to senior management, risk committee, or board level due to risk tier or specific risk factors.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:esiVolumeGb rdf:type rdf:Property ;
    rdfs:label 'Esi Volume Gb' ;
    rdfs:comment 'Estimated volume of ESI in gigabytes that may be subject to collection, review, and production in this matter, driving eDiscovery cost and resource planning.' ;
    rdfs:domain ind:MatterRiskProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedMatterValue rdf:type rdf:Property ;
    rdfs:label 'Estimated Matter Value' ;
    rdfs:comment 'Estimated total value at stake in the matter (transaction value, claim amount, or potential liability), used to assess proportionality of risk and insurance coverage adequacy. Expressed in firm base currency.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Insurance Notification Date' ;
    rdfs:comment 'Date when professional indemnity insurer was notified of this matter, if notification was required.' ;
    rdfs:domain ind:MatterRiskProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:insuranceNotificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Insurance Notification Required Flag' ;
    rdfs:comment 'Indicates whether professional indemnity insurer notification is required for this matter based on risk profile and policy terms.' ;
    rdfs:domain ind:MatterRiskProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jurisdictionalRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Jurisdictional Risk Level' ;
    rdfs:comment 'Risk rating based on the legal jurisdictions involved, considering political stability, judicial predictability, enforcement mechanisms, and regulatory environment.' ;
    rdfs:domain ind:MatterRiskProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Review Date' ;
    rdfs:comment 'Date of the most recent risk profile review, typically conducted at matter milestones (mid-matter review, pre-trial, significant developments).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lppSensitivityLevel rdf:type rdf:Property ;
    rdfs:label 'Lpp Sensitivity Level' ;
    rdfs:comment 'Assessment of the sensitivity of privileged communications and work product in this matter, driving information security controls and ethical wall requirements.' ;
    rdfs:domain ind:MatterRiskProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matterComplexityRating rdf:type rdf:Property ;
    rdfs:label 'Matter Complexity Rating' ;
    rdfs:comment 'Assessment of the legal and factual complexity of the matter considering number of parties, jurisdictions, legal issues, document volume, and expert requirements.' ;
    rdfs:domain ind:MatterRiskProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matterProfileReferencesRisks rdf:type rdf:Property ;
    rdfs:label 'Matter Profile References Risks' ;
    rdfs:comment 'FK to risk.risk_register.risk_register_id — Matter risk profiles aggregate risk dimensions that may reference specific risk register items for that matter.' ;
    rdfs:domain ind:MatterRiskProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:matterValueCurrency rdf:type rdf:Property ;
    rdfs:label 'Matter Value Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the estimated matter value (e.g., USD, GBP, EUR).' ;
    rdfs:domain ind:MatterRiskProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediaExposureLikelihood rdf:type rdf:Property ;
    rdfs:label 'Media Exposure Likelihood' ;
    rdfs:comment 'Probability that the matter will attract media attention or public scrutiny, informing communications strategy and reputational risk management.' ;
    rdfs:domain ind:MatterRiskProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallRiskTier rdf:type rdf:Property ;
    rdfs:label 'Overall Risk Tier' ;
    rdfs:comment 'Consolidated risk rating for the matter using traffic-light classification: green (low risk), amber (medium risk), red (high risk). Drives partner review frequency and approval thresholds.' ;
    rdfs:domain ind:MatterRiskProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:piiDataVolumeCategory rdf:type rdf:Property ;
    rdfs:label 'Pii Data Volume Category' ;
    rdfs:comment 'Classification of the volume of PII involved in the matter, informing GDPR compliance requirements, data breach risk exposure, and data protection impact assessment needs.' ;
    rdfs:domain ind:MatterRiskProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Primary Jurisdiction' ;
    rdfs:comment 'Three-letter ISO country code representing the primary legal jurisdiction governing this matter (e.g., USA, GBR, DEU).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:professionalIndemnityExposure rdf:type rdf:Property ;
    rdfs:label 'Professional Indemnity Exposure' ;
    rdfs:comment 'Assessment of potential professional liability and malpractice risk exposure for this matter, informing insurance notification requirements and risk mitigation protocols.' ;
    rdfs:domain ind:MatterRiskProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileCreatedDate rdf:type rdf:Property ;
    rdfs:label 'Profile Created Date' ;
    rdfs:comment 'Date when this risk profile was initially created, typically at matter intake or new business approval stage.' ;
    rdfs:domain ind:MatterRiskProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:profileCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Profile Created Timestamp' ;
    rdfs:comment 'Precise timestamp when this risk profile record was first created in the system, supporting audit trail and lifecycle tracking.' ;
    rdfs:domain ind:MatterRiskProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:profileReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Profile Reference Number' ;
    rdfs:comment 'Human-readable unique reference code for this matter risk profile, typically formatted as MRP-YYYYNNNN for external communication and audit trails.' ;
    rdfs:domain ind:MatterRiskProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileStatus rdf:type rdf:Property ;
    rdfs:label 'Profile Status' ;
    rdfs:comment 'Current lifecycle status of the risk profile indicating whether it is in draft, actively monitored, under review by risk committee, escalated to senior management, closed upon matter completion, or archived.' ;
    rdfs:domain ind:MatterRiskProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryScrutinyLevel rdf:type rdf:Property ;
    rdfs:label 'Regulatory Scrutiny Level' ;
    rdfs:comment 'Assessment of the level of regulatory oversight and reporting requirements applicable to this matter, considering industry sector, transaction type, and jurisdictional requirements.' ;
    rdfs:domain ind:MatterRiskProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reputationalRiskRating rdf:type rdf:Property ;
    rdfs:label 'Reputational Risk Rating' ;
    rdfs:comment 'Assessment of potential reputational harm to the firm from association with this matter, considering client profile, matter type, public visibility, and ethical considerations.' ;
    rdfs:domain ind:MatterRiskProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskMitigationPlan rdf:type rdf:Property ;
    rdfs:label 'Risk Mitigation Plan' ;
    rdfs:comment 'Summary of key risk mitigation strategies and controls implemented for this matter, including enhanced supervision, ethical walls, insurance notifications, and client communications.' ;
    rdfs:domain ind:MatterRiskProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sanctionsScreeningRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Sanctions Screening Required Flag' ;
    rdfs:comment 'Indicates whether parties, jurisdictions, or transaction elements require screening against international sanctions lists (OFAC, UN, EU) to ensure compliance with economic sanctions regimes.' ;
    rdfs:domain ind:MatterRiskProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:thirdPartyRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Third Party Risk Flag' ;
    rdfs:comment 'Indicates whether the matter involves third-party service providers (expert witnesses, eDiscovery vendors, co-counsel, ALSPs) requiring vendor due diligence and data sharing agreements.' ;
    rdfs:domain ind:MatterRiskProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mitigationActionId rdf:type rdf:Property ;
    rdfs:label 'Mitigation Action Id' ;
    rdfs:comment 'Unique identifier for the risk mitigation action record. Primary key.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MitigationAction .

ind:phaseId rdf:type rdf:Property ;
    rdfs:label 'Phase Id' ;
    rdfs:comment 'Foreign key linking to matter.phase. Business justification: Mitigation actions are assigned to specific matter phases (e.g., discovery-phase e-discovery cost controls, trial-phase witness preparation). Phase-level mitigation tracking is standard in legal proje' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Phase .

ind:actionDescription rdf:type rdf:Property ;
    rdfs:label 'Action Description' ;
    rdfs:comment 'Detailed description of the mitigation or remediation action to be taken, including specific steps, controls, or interventions required.' ;
    rdfs:domain ind:MitigationAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionOwnerName rdf:type rdf:Property ;
    rdfs:label 'Action Owner Name' ;
    rdfs:comment 'Full name of the individual assigned as the action owner, denormalized for reporting convenience.' ;
    rdfs:domain ind:MitigationAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionPriority rdf:type rdf:Property ;
    rdfs:label 'Action Priority' ;
    rdfs:comment 'Priority level assigned to the mitigation action based on risk severity and urgency: critical (immediate), high (urgent), medium (standard), or low (routine).' ;
    rdfs:domain ind:MitigationAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Action Reference Number' ;
    rdfs:comment 'Business-facing unique reference code for the mitigation action, used in reporting and tracking (e.g., RMA-00012345).' ;
    rdfs:domain ind:MitigationAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionStatus rdf:type rdf:Property ;
    rdfs:label 'Action Status' ;
    rdfs:comment 'Current lifecycle status of the mitigation action: assigned (not started), in_progress (underway), pending_review (awaiting approval), completed (finished), overdue (past due date), or cancelled (no longer required).' ;
    rdfs:domain ind:MitigationAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionTitle rdf:type rdf:Property ;
    rdfs:label 'Action Title' ;
    rdfs:comment 'Short descriptive title of the mitigation action for quick identification and reporting.' ;
    rdfs:domain ind:MitigationAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionType rdf:type rdf:Property ;
    rdfs:label 'Action Type' ;
    rdfs:comment 'Classification of the mitigation action by control type: preventive (avoid risk), detective (identify occurrence), corrective (fix issue), compensating (alternative control), directive (policy/procedure), or recovery (restore after event).' ;
    rdfs:domain ind:MitigationAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualCost rdf:type rdf:Property ;
    rdfs:label 'Actual Cost' ;
    rdfs:comment 'Actual financial cost incurred to implement the mitigation action, captured for budget tracking and ROI analysis.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualEffortHours rdf:type rdf:Property ;
    rdfs:label 'Actual Effort Hours' ;
    rdfs:comment 'Actual number of hours spent completing the mitigation action, captured for performance tracking and future estimation.' ;
    rdfs:domain ind:MitigationAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignedDate rdf:type rdf:Property ;
    rdfs:label 'Assigned Date' ;
    rdfs:comment 'Date when the mitigation action was formally assigned to the action owner.' ;
    rdfs:domain ind:MitigationAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:completionDate rdf:type rdf:Property ;
    rdfs:label 'Completion Date' ;
    rdfs:comment 'Actual date when the mitigation action was completed and closed. Null if action is not yet completed.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:completionEvidence rdf:type rdf:Property ;
    rdfs:label 'Completion Evidence' ;
    rdfs:comment 'Description or reference to evidence demonstrating completion of the mitigation action (e.g., document reference, system log, attestation, audit report).' ;
    rdfs:domain ind:MitigationAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionStatus rdf:type rdf:Property ;
    rdfs:label 'Completion Status' ;
    rdfs:comment 'Detailed completion state: not_started (no work done), partial (in progress), complete (finished but not verified), verified (reviewed and approved), or rejected (completion not accepted).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationReason rdf:type rdf:Property ;
    rdfs:label 'Escalation Reason' ;
    rdfs:comment 'Explanation of why the mitigation action was escalated (e.g., overdue, insufficient resources, control ineffective, regulatory deadline).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationRequired rdf:type rdf:Property ;
    rdfs:label 'Escalation Required' ;
    rdfs:comment 'Flag indicating whether this mitigation action requires escalation to senior management or the risk committee due to delays, resource constraints, or effectiveness concerns.' ;
    rdfs:domain ind:MitigationAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost' ;
    rdfs:comment 'Estimated financial cost to implement the mitigation action, including internal labor, external counsel, technology, or other resources.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedEffortHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Effort Hours' ;
    rdfs:comment 'Estimated number of hours required to complete the mitigation action, used for resource planning and capacity management.' ;
    rdfs:domain ind:MitigationAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:residualRiskReassessmentDate rdf:type rdf:Property ;
    rdfs:label 'Residual Risk Reassessment Date' ;
    rdfs:comment 'Date when the residual risk was reassessed following completion of this mitigation action. Null if reassessment not yet performed.' ;
    rdfs:domain ind:MitigationAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:residualRiskReassessmentRequired rdf:type rdf:Property ;
    rdfs:label 'Residual Risk Reassessment Required' ;
    rdfs:comment 'Flag indicating whether completion of this action triggers a formal reassessment of the residual risk rating in the risk register.' ;
    rdfs:domain ind:MitigationAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewComments rdf:type rdf:Property ;
    rdfs:label 'Review Comments' ;
    rdfs:comment 'Comments or notes provided by the reviewer regarding the quality, completeness, or effectiveness of the mitigation action.' ;
    rdfs:domain ind:MitigationAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewDate rdf:type rdf:Property ;
    rdfs:label 'Review Date' ;
    rdfs:comment 'Date when the completed mitigation action was formally reviewed and verified by the reviewer.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ownerOrganisationId rdf:type rdf:Property ;
    rdfs:label 'Owner Organisation Id' ;
    rdfs:comment 'Foreign key linking to client.organisation. Business justification: IP portfolio management and annuity payment processing requires the asset owner to be a linked client organisation for billing, regulatory filings, and ownership recordal. owner_name is a denormalized' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Organisation .

ind:annuityAmount rdf:type rdf:Property ;
    rdfs:label 'Annuity Amount' ;
    rdfs:comment 'Monetary amount due for the next annuity or maintenance fee payment.' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annuityCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Annuity Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the annuity payment amount.' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annuityDueDate rdf:type rdf:Property ;
    rdfs:label 'Annuity Due Date' ;
    rdfs:comment 'Next scheduled date for payment of maintenance fees or annuities to keep the IP asset in force.' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:applicationNumber rdf:type rdf:Property ;
    rdfs:label 'Application Number' ;
    rdfs:comment 'Official application number assigned by the intellectual property office upon filing.' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetNumber rdf:type rdf:Property ;
    rdfs:label 'Asset Number' ;
    rdfs:comment 'Business-facing unique identifier or reference number for the IP asset, often used in client communications and docketing systems.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetType rdf:type rdf:Property ;
    rdfs:label 'Asset Type' ;
    rdfs:comment 'Classification of the intellectual property asset type.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classificationCode rdf:type rdf:Property ;
    rdfs:label 'Classification Code' ;
    rdfs:comment 'International Patent Classification (IPC), Cooperative Patent Classification (CPC), or Nice Classification code assigned to the IP asset.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityLevel rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Level' ;
    rdfs:comment 'Data classification level indicating the sensitivity and access restrictions for the IP asset information.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:docketingSystemCode rdf:type rdf:Property ;
    rdfs:label 'Docketing System Code' ;
    rdfs:comment 'External identifier used in the IP docketing or deadline management system for tracking prosecution milestones.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentRepositoryPath rdf:type rdf:Property ;
    rdfs:label 'Document Repository Path' ;
    rdfs:comment 'File path or URI reference to the location in the document management system (DMS) where IP asset documents are stored.' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expirationDate rdf:type rdf:Property ;
    rdfs:label 'Expiration Date' ;
    rdfs:comment 'Date on which the intellectual property protection expires, subject to maintenance fee payments and renewals.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:filingDate rdf:type rdf:Property ;
    rdfs:label 'Filing Date' ;
    rdfs:comment 'Date on which the intellectual property application was officially filed with the relevant IP office.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:frandDeclarationFlag rdf:type rdf:Property ;
    rdfs:label 'Frand Declaration Flag' ;
    rdfs:comment 'Indicates whether the IP asset is subject to a FRAND declaration to a standards-setting organization.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inventorNames rdf:type rdf:Property ;
    rdfs:label 'Inventor Names' ;
    rdfs:comment 'Comma-separated list of inventor names credited on the patent or IP asset application.' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipAssetDescription rdf:type rdf:Property ;
    rdfs:label 'Ip Asset Description' ;
    rdfs:comment 'Detailed business description of the intellectual property asset, including its purpose, scope, and key features.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipAssetStatus rdf:type rdf:Property ;
    rdfs:label 'Ip Asset Status' ;
    rdfs:comment 'Current lifecycle status of the intellectual property asset in the prosecution or registration process. [ENUM-REF-CANDIDATE: pending|registered|granted|abandoned|expired|lapsed|opposed|cancelled — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipOfficeName rdf:type rdf:Property ;
    rdfs:label 'Ip Office Name' ;
    rdfs:comment 'Name of the intellectual property office or authority responsible for examining and granting the IP asset (e.g., USPTO, EPO, JPO).' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licensingStatus rdf:type rdf:Property ;
    rdfs:label 'Licensing Status' ;
    rdfs:comment 'Current licensing arrangement status for the IP asset, including Fair Reasonable and Non-Discriminatory (FRAND) commitments.' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oppositionFiledFlag rdf:type rdf:Property ;
    rdfs:label 'Opposition Filed Flag' ;
    rdfs:comment 'Indicates whether a third-party opposition or challenge has been filed against the IP asset.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pctApplicationFlag rdf:type rdf:Property ;
    rdfs:label 'Pct Application Flag' ;
    rdfs:comment 'Indicates whether the IP asset was filed under the Patent Cooperation Treaty (PCT) international application process.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:portfolioCategory rdf:type rdf:Property ;
    rdfs:label 'Portfolio Category' ;
    rdfs:comment 'Business classification or grouping of the IP asset within the clients portfolio (e.g., core technology, defensive, licensing).' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pphRequestFlag rdf:type rdf:Property ;
    rdfs:label 'Pph Request Flag' ;
    rdfs:comment 'Indicates whether a Patent Prosecution Highway (PPH) request has been filed to accelerate examination based on a related application.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorityDate rdf:type rdf:Property ;
    rdfs:label 'Priority Date' ;
    rdfs:comment 'Earliest filing date claimed for priority purposes under the Paris Convention or Patent Cooperation Treaty (PCT).' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:registrationDate rdf:type rdf:Property ;
    rdfs:label 'Registration Date' ;
    rdfs:comment 'Date on which the intellectual property asset was officially registered or granted by the IP office.' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:registrationNumber rdf:type rdf:Property ;
    rdfs:label 'Registration Number' ;
    rdfs:comment 'Official registration or grant number assigned by the intellectual property office upon approval.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subtype rdf:type rdf:Property ;
    rdfs:label 'Subtype' ;
    rdfs:comment 'Further classification within the asset type, such as utility patent, design patent, word mark, logo mark, sound mark, etc.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technologyArea rdf:type rdf:Property ;
    rdfs:label 'Technology Area' ;
    rdfs:comment 'Broad technology or industry domain to which the IP asset relates (e.g., pharmaceuticals, software, telecommunications).' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:title rdf:type rdf:Property ;
    rdfs:label 'Title' ;
    rdfs:comment 'The official title or name of the intellectual property asset as registered or filed.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationAmount rdf:type rdf:Property ;
    rdfs:label 'Valuation Amount' ;
    rdfs:comment 'Estimated or appraised monetary value of the intellectual property asset for portfolio management and financial reporting.' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valuationCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Valuation Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the valuation amount.' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationDate rdf:type rdf:Property ;
    rdfs:label 'Valuation Date' ;
    rdfs:comment 'Date on which the IP asset valuation was performed or last updated.' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:patentId rdf:type rdf:Property ;
    rdfs:label 'Patent Id' ;
    rdfs:comment 'Unique identifier for the patent asset record. Primary key for the patent data product.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Patent .

ind:assigneeOrganisationId rdf:type rdf:Property ;
    rdfs:label 'Assignee Organisation Id' ;
    rdfs:comment 'Foreign key linking to client.organisation. Business justification: Patent prosecution and portfolio management requires the assignee to be a linked client organisation for assignment recordal, conflict checks, and ownership chain reporting. assignee_name is a denorma' ;
    rdfs:domain ind:Patent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Organisation .

ind:litigationDocketId rdf:type rdf:Property ;
    rdfs:label 'Litigation Docket Id' ;
    rdfs:comment 'Foreign key linking to court.docket. Business justification: Patent infringement and validity litigation requires direct tracking from patent to court docket. Essential for monitoring enforcement actions, calculating patent portfolio risk, and coordinating pros' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Docket .

ind:litigationJudgmentId rdf:type rdf:Property ;
    rdfs:label 'Litigation Judgment Id' ;
    rdfs:comment 'Foreign key linking to matter.judgment. Business justification: Invalidity, infringement, and damages judgments directly determine patent enforceability, licensing status, and portfolio valuation. Patent portfolio managers require direct linkage to the controlling' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Judgment .

ind:patentAssetId rdf:type rdf:Property ;
    rdfs:label 'Patent Asset Id' ;
    rdfs:comment 'Reference to the parent IP asset record. Links this patent to the broader IP asset portfolio.' ;
    rdfs:domain ind:Patent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:primaryPatentFamilyId rdf:type rdf:Property ;
    rdfs:label 'Primary Patent Family Id' ;
    rdfs:comment 'Identifier linking this patent to its patent family - a group of related patent applications filed in multiple jurisdictions claiming the same priority. Enables portfolio-level analysis and management.' ;
    rdfs:domain ind:Patent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PatentFamily .

ind:toIpAssetId rdf:type rdf:Property ;
    rdfs:label 'To Ip Asset Id' ;
    rdfs:comment 'FK to ip.ip_asset.ip_asset_id — Patent extends ip_asset — every patent record MUST reference its parent ip_asset record. This is the fundamental inheritance/extension FK that connects the type-specific detail to the master asset rec' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:toPatentFamilyId rdf:type rdf:Property ;
    rdfs:label 'To Patent Family Id' ;
    rdfs:comment 'FK to ip.patent_family.patent_family_id — Every patent belongs to a patent family (or is a singleton family). This FK enables family-level portfolio analysis and prosecution strategy.' ;
    rdfs:domain ind:Patent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PatentFamily .

ind:abstract rdf:type rdf:Property ;
    rdfs:label 'Abstract' ;
    rdfs:comment 'A concise summary of the invention disclosed in the patent, typically 150-250 words, providing a high-level overview of the technical problem and solution.' ;
    rdfs:domain ind:Patent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agentName rdf:type rdf:Property ;
    rdfs:label 'Agent Name' ;
    rdfs:comment 'The name of the registered patent agent or patent attorney who is prosecuting the patent application before the patent office.' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annuityPaymentStatus rdf:type rdf:Property ;
    rdfs:label 'Annuity Payment Status' ;
    rdfs:comment 'Current status of the patent maintenance fee (annuity) payment. Tracks whether fees are current, overdue, or if the patent has lapsed due to non-payment.' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentChain rdf:type rdf:Property ;
    rdfs:label 'Assignment Chain' ;
    rdfs:comment 'A chronological record of all ownership transfers (assignments) of the patent rights, tracking the chain of title from original assignee to current owner.' ;
    rdfs:domain ind:Patent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpcClassificationCodes rdf:type rdf:Property ;
    rdfs:label 'Cpc Classification Codes' ;
    rdfs:comment 'Classification codes assigned under the Cooperative Patent Classification system, jointly developed by the EPO and USPTO. Provides more granular technology classification than IPC.' ;
    rdfs:domain ind:Patent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedPortfolioValue rdf:type rdf:Property ;
    rdfs:label 'Estimated Portfolio Value' ;
    rdfs:comment 'The estimated monetary value of this patent asset based on valuation methodologies such as cost approach, market approach, or income approach. Used for portfolio management and financial reporting.' ;
    rdfs:domain ind:Patent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:examinerName rdf:type rdf:Property ;
    rdfs:label 'Examiner Name' ;
    rdfs:comment 'The name of the patent office examiner who examined the patent application.' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:extendsAsset rdf:type rdf:Property ;
    rdfs:label 'Extends Asset' ;
    rdfs:comment 'FK to ip.asset.asset_id — Patent is a subtype extension of the ip_asset master. Every patent record MUST reference its parent asset record for portfolio-level queries, ownership inheritance, and docketing. This is the core inh' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:frandObligationFlag rdf:type rdf:Property ;
    rdfs:label 'Frand Obligation Flag' ;
    rdfs:comment 'Indicates whether this patent is subject to FRAND licensing obligations, typically because it is essential to a technical standard. FRAND patents must be licensed on fair, reasonable, and non-discriminatory terms.' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:grantDate rdf:type rdf:Property ;
    rdfs:label 'Grant Date' ;
    rdfs:comment 'The date the patent was officially granted by the patent office, conferring exclusive rights to the patent holder.' ;
    rdfs:domain ind:Patent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:independentClaimsCount rdf:type rdf:Property ;
    rdfs:label 'Independent Claims Count' ;
    rdfs:comment 'The number of independent claims in the patent. Independent claims stand alone and define the broadest scope of protection, making them particularly valuable for enforcement.' ;
    rdfs:domain ind:Patent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ipcClassificationCodes rdf:type rdf:Property ;
    rdfs:label 'Ipc Classification Codes' ;
    rdfs:comment 'Hierarchical classification codes assigned to the patent based on the International Patent Classification system. Multiple codes may be present, separated by semicolons (e.g., H04L29/06; G06F21/60).' ;
    rdfs:domain ind:Patent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:litigationFlag rdf:type rdf:Property ;
    rdfs:label 'Litigation Flag' ;
    rdfs:comment 'Indicates whether this patent is currently involved in litigation, opposition, or other legal proceedings. Critical for risk assessment and portfolio management.' ;
    rdfs:domain ind:Patent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originalAssigneeName rdf:type rdf:Property ;
    rdfs:label 'Original Assignee Name' ;
    rdfs:comment 'The initial assignee of the patent at the time of filing or grant. Tracks the original owner before any subsequent assignments or transfers.' ;
    rdfs:domain ind:Patent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patentNumber rdf:type rdf:Property ;
    rdfs:label 'Patent Number' ;
    rdfs:comment 'The official patent number assigned by the granting patent office (e.g., US10123456B2, EP3456789A1). This is the externally-known unique identifier for the granted patent.' ;
    rdfs:domain ind:Patent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patentType rdf:type rdf:Property ;
    rdfs:label 'Patent Type' ;
    rdfs:comment 'The classification of patent: utility (functional inventions), design (ornamental designs), or plant (new plant varieties).' ;
    rdfs:domain ind:Patent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pctApplicationNumber rdf:type rdf:Property ;
    rdfs:label 'Pct Application Number' ;
    rdfs:comment 'The PCT international application number if this patent was filed under the Patent Cooperation Treaty, enabling a single application to seek protection in multiple jurisdictions.' ;
    rdfs:domain ind:Patent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pphEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Pph Eligible Flag' ;
    rdfs:comment 'Indicates whether this patent application is eligible for accelerated examination under the Patent Prosecution Highway program, which allows applicants to fast-track examination based on positive results from another participating patent office.' ;
    rdfs:domain ind:Patent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorArtReferences rdf:type rdf:Property ;
    rdfs:label 'Prior Art References' ;
    rdfs:comment 'A list of prior art references cited during patent examination that were considered relevant to patentability. Multiple references are separated by semicolons.' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prosecutionStatus rdf:type rdf:Property ;
    rdfs:label 'Prosecution Status' ;
    rdfs:comment 'Current lifecycle status of the patent in the prosecution process. Tracks the patent from initial drafting through grant, maintenance, or abandonment. [ENUM-REF-CANDIDATE: draft|filed|pending|published|granted|abandoned|expired|lapsed — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Patent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicationDate rdf:type rdf:Property ;
    rdfs:label 'Publication Date' ;
    rdfs:comment 'The date the patent application was published and made publicly available, typically 18 months after the priority date.' ;
    rdfs:domain ind:Patent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:publicationNumber rdf:type rdf:Property ;
    rdfs:label 'Publication Number' ;
    rdfs:comment 'The official publication number assigned when the patent application was published (typically 18 months after filing).' ;
    rdfs:domain ind:Patent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardEssentialPatentFlag rdf:type rdf:Property ;
    rdfs:label 'Standard Essential Patent Flag' ;
    rdfs:comment 'Indicates whether this patent has been declared as essential to implementing a technical standard (e.g., telecommunications, wireless, video compression standards).' ;
    rdfs:domain ind:Patent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalClaimsCount rdf:type rdf:Property ;
    rdfs:label 'Total Claims Count' ;
    rdfs:comment 'The total number of claims in the patent. Claims define the legal scope of patent protection and are critical for enforcement and valuation.' ;
    rdfs:domain ind:Patent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trademarkId rdf:type rdf:Property ;
    rdfs:label 'Trademark Id' ;
    rdfs:comment 'Unique identifier for the trademark asset. Primary key for the trademark product.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Trademark .

ind:trademarkAssetId rdf:type rdf:Property ;
    rdfs:label 'Trademark Asset Id' ;
    rdfs:comment 'Reference to the parent IP asset record. Links this trademark to the broader IP portfolio management system.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:applicationSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Application Serial Number' ;
    rdfs:comment 'The official serial number assigned by the trademark office upon filing. Unique identifier for the trademark application in the jurisdiction\'s registry.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attorneyDocketNumber rdf:type rdf:Property ;
    rdfs:label 'Attorney Docket Number' ;
    rdfs:comment 'Internal docket or reference number assigned by the law firm for tracking this trademark matter. Links to internal matter management and billing systems.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attorneyOfRecord rdf:type rdf:Property ;
    rdfs:label 'Attorney Of Record' ;
    rdfs:comment 'The name of the attorney or law firm representing the applicant/registrant in the trademark prosecution. Links to internal timekeeper records.' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorClaim rdf:type rdf:Property ;
    rdfs:label 'Color Claim' ;
    rdfs:comment 'Description of any color(s) claimed as a feature of the trademark. Relevant for marks where color is a distinguishing element.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclaimerText rdf:type rdf:Property ;
    rdfs:label 'Disclaimer Text' ;
    rdfs:comment 'Text of any disclaimer filed with the trademark application, disclaiming exclusive rights to certain descriptive or generic elements of the mark.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingBasis rdf:type rdf:Property ;
    rdfs:label 'Filing Basis' ;
    rdfs:comment 'The legal basis under which the trademark application was filed (US-specific): actual use in commerce (Section 1(a)), intent to use (Section 1(b)), foreign application (Section 44(d)), or foreign registration (Section 44(e)).' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstUseAnywhereDate rdf:type rdf:Property ;
    rdfs:label 'First Use Anywhere Date' ;
    rdfs:comment 'The date the trademark was first used anywhere in the world, regardless of jurisdiction. May predate use in commerce date.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:goodsServicesDescription rdf:type rdf:Property ;
    rdfs:label 'Goods Services Description' ;
    rdfs:comment 'Detailed description of the goods and/or services for which the trademark is registered or applied. Must conform to acceptable identification standards per the trademark office.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:madridDesignatedCountries rdf:type rdf:Property ;
    rdfs:label 'Madrid Designated Countries' ;
    rdfs:comment 'Comma-separated list of country codes (ISO 3166-1 alpha-3) designated for protection under a Madrid Protocol international registration.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:madridProtocolIndicator rdf:type rdf:Property ;
    rdfs:label 'Madrid Protocol Indicator' ;
    rdfs:comment 'Indicates whether this trademark was filed under the Madrid Protocol for international registration. True if filed via WIPO Madrid System.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:madridRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Madrid Registration Number' ;
    rdfs:comment 'The international registration number assigned by WIPO under the Madrid Protocol. Null if not a Madrid Protocol filing.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:markDescription rdf:type rdf:Property ;
    rdfs:label 'Mark Description' ;
    rdfs:comment 'Detailed description of the trademark, especially for device marks, trade dress, or composite marks. Describes visual elements, colors, design features, and overall appearance.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:markText rdf:type rdf:Property ;
    rdfs:label 'Mark Text' ;
    rdfs:comment 'The literal text of the trademark for word marks. Null for device marks or design-only marks. Core identifier for the trademark asset.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:markType rdf:type rdf:Property ;
    rdfs:label 'Mark Type' ;
    rdfs:comment 'Classification of the trademark by its form: word mark (text only), device mark (logo/design), composite mark (text and design), trade dress (product appearance), certification mark, or collective mark.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:multiClassIndicator rdf:type rdf:Property ;
    rdfs:label 'Multi Class Indicator' ;
    rdfs:comment 'Indicates whether this trademark application covers multiple Nice Classification classes. True if filed under more than one class.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:niceClassificationCodes rdf:type rdf:Property ;
    rdfs:label 'Nice Classification Codes' ;
    rdfs:comment 'Comma-separated list of Nice Classification class numbers (1-45) under which the trademark is registered. Classes 1-34 cover goods; classes 35-45 cover services.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oppositionPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Opposition Period End Date' ;
    rdfs:comment 'The deadline by which third parties may file an opposition to the trademark application. Typically 30 days after publication in the Official Gazette (US) or similar publication.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:oppositionStatus rdf:type rdf:Property ;
    rdfs:label 'Opposition Status' ;
    rdfs:comment 'Status of any opposition proceedings filed against this trademark application. Tracks whether the mark is under challenge by third parties.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portfolioValuationAmount rdf:type rdf:Property ;
    rdfs:label 'Portfolio Valuation Amount' ;
    rdfs:comment 'The estimated financial value of this trademark asset as part of the overall IP portfolio. Used for portfolio management and financial reporting.' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorityClaimCountry rdf:type rdf:Property ;
    rdfs:label 'Priority Claim Country' ;
    rdfs:comment 'The country code (ISO 3166-1 alpha-3) of the jurisdiction where the priority application was filed. Used for Paris Convention priority claims.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityClaimDate rdf:type rdf:Property ;
    rdfs:label 'Priority Claim Date' ;
    rdfs:comment 'The priority date claimed under the Paris Convention or other treaty, based on an earlier foreign filing. Establishes earlier effective filing date.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalDueDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Due Date' ;
    rdfs:comment 'The next deadline for renewing the trademark registration to maintain its active status. Critical for IP docketing and annuity payment management.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:specimenOfUseDescription rdf:type rdf:Property ;
    rdfs:label 'Specimen Of Use Description' ;
    rdfs:comment 'Description of the specimen submitted to demonstrate actual use of the trademark in commerce. Required for US trademark applications.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trademarkStatus rdf:type rdf:Property ;
    rdfs:label 'Trademark Status' ;
    rdfs:comment 'Current lifecycle status of the trademark application or registration. Tracks progression through prosecution and maintenance phases. [ENUM-REF-CANDIDATE: pending|published|registered|opposed|cancelled|abandoned|expired — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:translationText rdf:type rdf:Property ;
    rdfs:label 'Translation Text' ;
    rdfs:comment 'English translation of any foreign wording in the mark, as required by trademark offices for non-English marks.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transliterationText rdf:type rdf:Property ;
    rdfs:label 'Transliteration Text' ;
    rdfs:comment 'Transliteration of any non-Latin characters in the mark into Latin characters, as required by trademark offices.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:useInCommerceDate rdf:type rdf:Property ;
    rdfs:label 'Use In Commerce Date' ;
    rdfs:comment 'The date the trademark was first used in commerce (for US applications). Critical for establishing trademark rights and priority in use-based jurisdictions.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:triggeringOrderId rdf:type rdf:Property ;
    rdfs:label 'Triggering Order Id' ;
    rdfs:comment 'Foreign key linking to matter.order. Business justification: Court orders (ITC exclusion orders, PTAB institution decisions, district court claim construction orders) directly trigger prosecution events such as reexamination requests, IPR petitions, or prosecut' ;
    rdfs:domain ind:ProsecutionEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:artUnit rdf:type rdf:Property ;
    rdfs:label 'Art Unit' ;
    rdfs:comment 'USPTO art unit or technology center code to which the examiner belongs. Indicates the technical classification area for patent examination.' ;
    rdfs:domain ind:ProsecutionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimsAllowedCount rdf:type rdf:Property ;
    rdfs:label 'Claims Allowed Count' ;
    rdfs:comment 'Number of claims allowed by the examiner in this prosecution event. Relevant for notices of allowance and final dispositions.' ;
    rdfs:domain ind:ProsecutionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:claimsRejectedCount rdf:type rdf:Property ;
    rdfs:label 'Claims Rejected Count' ;
    rdfs:comment 'Number of claims rejected by the examiner in this prosecution event. Relevant for office actions and final rejections.' ;
    rdfs:domain ind:ProsecutionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:docketingTriggerFlag rdf:type rdf:Property ;
    rdfs:label 'Docketing Trigger Flag' ;
    rdfs:comment 'Indicates whether this prosecution event triggers an automated docketing action or deadline alert in the IP management system.' ;
    rdfs:domain ind:ProsecutionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:documentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Document Reference Number' ;
    rdfs:comment 'Official document or communication reference number assigned by the patent or trademark office to this prosecution event.' ;
    rdfs:domain ind:ProsecutionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estoppelRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Estoppel Risk Flag' ;
    rdfs:comment 'Indicates whether this prosecution event may create prosecution history estoppel risk, limiting claim scope interpretation in future litigation.' ;
    rdfs:domain ind:ProsecutionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eventDate rdf:type rdf:Property ;
    rdfs:label 'Event Date' ;
    rdfs:comment 'Date on which the prosecution event occurred or was officially recorded by the patent or trademark office.' ;
    rdfs:domain ind:ProsecutionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eventType rdf:type rdf:Property ;
    rdfs:label 'Event Type' ;
    rdfs:comment 'Type of prosecution event. Categorizes the official action or applicant response in the patent or trademark prosecution lifecycle. [ENUM-REF-CANDIDATE: office_action_received|response_filed|notice_of_allowance|final_rejection|restriction_requirement|appeal_filed|grant_issued|request_for_continued_examination|interview_conducted|amendment_filed|information_disclosure_statement|petition_filed|suspension_notice|abandonment_notice — promote to reference product]' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:extensionGrantedFlag rdf:type rdf:Property ;
    rdfs:label 'Extension Granted Flag' ;
    rdfs:comment 'Indicates whether a deadline extension was granted by the patent or trademark office for this prosecution event.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:extensionRequestedFlag rdf:type rdf:Property ;
    rdfs:label 'Extension Requested Flag' ;
    rdfs:comment 'Indicates whether a deadline extension was requested for this prosecution event.' ;
    rdfs:domain ind:ProsecutionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:feeAmount rdf:type rdf:Property ;
    rdfs:label 'Fee Amount' ;
    rdfs:comment 'Official fee amount paid or due for this prosecution event (e.g., response filing fee, extension fee, appeal fee).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Fee Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the fee amount (e.g., USD, EUR, JPY).' ;
    rdfs:domain ind:ProsecutionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forAsset rdf:type rdf:Property ;
    rdfs:label 'For Asset' ;
    rdfs:comment 'FK to ip.asset.asset_id — Every prosecution event occurs in the context of a specific IP asset (patent or trademark application). This FK is essential for prosecution history reconstruction and estoppel analysis.' ;
    rdfs:domain ind:ProsecutionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:interviewConductedFlag rdf:type rdf:Property ;
    rdfs:label 'Interview Conducted Flag' ;
    rdfs:comment 'Indicates whether an examiner interview was conducted as part of this prosecution event.' ;
    rdfs:domain ind:ProsecutionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interviewDate rdf:type rdf:Property ;
    rdfs:label 'Interview Date' ;
    rdfs:comment 'Date on which an examiner interview was conducted, if applicable.' ;
    rdfs:domain ind:ProsecutionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:officeActionType rdf:type rdf:Property ;
    rdfs:label 'Office Action Type' ;
    rdfs:comment 'Specific type of office action issued by the patent or trademark office. Distinguishes between non-final, final, restriction, and other action types.' ;
    rdfs:domain ind:ProsecutionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:officialDeadline rdf:type rdf:Property ;
    rdfs:label 'Official Deadline' ;
    rdfs:comment 'Statutory or official deadline imposed by the patent or trademark office for responding to this event. Critical for docketing and deadline management.' ;
    rdfs:domain ind:ProsecutionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:outcome rdf:type rdf:Property ;
    rdfs:label 'Outcome' ;
    rdfs:comment 'Outcome or result of the prosecution event. Indicates whether claims were allowed, rejected, or the application status changed.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prosecutionStage rdf:type rdf:Property ;
    rdfs:label 'Prosecution Stage' ;
    rdfs:comment 'Current stage of the prosecution lifecycle at the time of this event. Provides context for the event within the overall application timeline.' ;
    rdfs:domain ind:ProsecutionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionBasis rdf:type rdf:Property ;
    rdfs:label 'Rejection Basis' ;
    rdfs:comment 'Legal or technical basis for rejection cited by the examiner. May reference prior art, statutory sections (e.g., 35 USC 102, 103, 112), or formality issues.' ;
    rdfs:domain ind:ProsecutionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseDeadline rdf:type rdf:Property ;
    rdfs:label 'Response Deadline' ;
    rdfs:comment 'Internal or client-agreed deadline for filing a response to this prosecution event. May be earlier than the official deadline to allow for review and preparation.' ;
    rdfs:domain ind:ProsecutionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responseFiledDate rdf:type rdf:Property ;
    rdfs:label 'Response Filed Date' ;
    rdfs:comment 'Date on which the applicant or attorney filed a response to the prosecution event with the patent or trademark office.' ;
    rdfs:domain ind:ProsecutionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responseSummary rdf:type rdf:Property ;
    rdfs:label 'Response Summary' ;
    rdfs:comment 'Brief summary of the applicant\'s response or the substance of the office action. Captures key arguments, amendments, or examiner positions for quick reference.' ;
    rdfs:domain ind:ProsecutionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:docketProsecutionEventId rdf:type rdf:Property ;
    rdfs:label 'Docket Prosecution Event Id' ;
    rdfs:comment 'FK to ip.prosecution_event.prosecution_event_id — Many deadlines are triggered by prosecution events (e.g., office action received triggers response deadline). This FK enables automated deadline calculation from prosecution events.' ;
    rdfs:domain ind:DocketDeadline ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProsecutionEvent .

ind:governingOrderId rdf:type rdf:Property ;
    rdfs:label 'Governing Order Id' ;
    rdfs:comment 'Foreign key linking to matter.order. Business justification: Court orders frequently set or modify IP docket deadlines (e.g., ITC procedural orders, PTAB scheduling orders, district court orders extending prosecution response deadlines). IP docketing teams must' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:primaryDocketIpAssetId rdf:type rdf:Property ;
    rdfs:label 'Primary Docket Ip Asset Id' ;
    rdfs:comment 'Reference to the IP asset (patent, trademark, copyright, trade secret) to which this deadline applies.' ;
    rdfs:domain ind:DocketDeadline ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:primaryDocketProsecutionEventId rdf:type rdf:Property ;
    rdfs:label 'Primary Docket Prosecution Event Id' ;
    rdfs:comment 'Foreign key linking to ip.prosecution_event. Business justification: Docket deadlines are triggered by prosecution events (office actions, examiner responses, etc.). A single prosecution event can generate multiple deadlines (response deadline, appeal deadline, etc.). ' ;
    rdfs:domain ind:DocketDeadline ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProsecutionEvent .

ind:activeFlag rdf:type rdf:Property ;
    rdfs:label 'Active Flag' ;
    rdfs:comment 'Boolean flag indicating whether this deadline is currently active and requires monitoring. False if the deadline has been completed, missed, waived, or the underlying IP asset has been abandoned.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:calculatedDueDate rdf:type rdf:Property ;
    rdfs:label 'Calculated Due Date' ;
    rdfs:comment 'Rule-based calculated due date for the deadline, derived from statutory rules, office action issuance date, priority date, or other triggering event. This is the baseline due date before any extensions.' ;
    rdfs:domain ind:DocketDeadline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clientInstructionReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Client Instruction Received Date' ;
    rdfs:comment 'Date on which client instructions regarding this deadline were received (e.g., instruction to file response, instruction to abandon, instruction to pay annuity). Nullable if client instruction is not yet received or not required.' ;
    rdfs:domain ind:DocketDeadline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clientInstructionSummary rdf:type rdf:Property ;
    rdfs:label 'Client Instruction Summary' ;
    rdfs:comment 'Summary of client instructions regarding this deadline. Confidential and subject to Legal Professional Privilege (LPP).' ;
    rdfs:domain ind:DocketDeadline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Client Notification Date' ;
    rdfs:comment 'Date on which the client was notified of this deadline. Used to demonstrate compliance with duty to inform client and for Service Level Agreement (SLA) tracking.' ;
    rdfs:domain ind:DocketDeadline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:completionConfirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Completion Confirmation Number' ;
    rdfs:comment 'Confirmation or receipt number issued by the patent office or payment processor upon completion of the required action (e.g., filing receipt number, payment transaction ID).' ;
    rdfs:domain ind:DocketDeadline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deadlineDescription rdf:type rdf:Property ;
    rdfs:label 'Deadline Description' ;
    rdfs:comment 'Detailed textual description of the deadline, including the specific action required (e.g., \'Respond to Office Action - Claim Rejection\', \'Pay 5th Year Annuity\', \'Enter National Phase in USA\').' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deadlineForAsset rdf:type rdf:Property ;
    rdfs:label 'Deadline For Asset' ;
    rdfs:comment 'FK to ip.asset.asset_id — Every docketed deadline relates to a specific IP asset. This is mission-critical — deadline management without asset linkage is operationally useless.' ;
    rdfs:domain ind:DocketDeadline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deadlineType rdf:type rdf:Property ;
    rdfs:label 'Deadline Type' ;
    rdfs:comment 'Classification of the deadline. Indicates whether it is a statutory deadline, office action response, annuity/renewal payment, Patent Cooperation Treaty (PCT) national phase entry (30/31 month), opposition filing window, or other IP-specific deadline type. [ENUM-REF-CANDIDATE: statutory|office_action_response|annuity_payment|renewal_payment|pct_national_phase_entry|opposition_filing|priority_claim|divisional_filing|continuation_filing|appeal_filing|hearing_date|examination_request — promote to reference product]' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:docketSystemCode rdf:type rdf:Property ;
    rdfs:label 'Docket System Code' ;
    rdfs:comment 'External identifier for this deadline in the IP docketing system of record (e.g., CPI, Anaqua, PatSnap). Used for system integration and reconciliation.' ;
    rdfs:domain ind:DocketDeadline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationNotes rdf:type rdf:Property ;
    rdfs:label 'Escalation Notes' ;
    rdfs:comment 'Confidential notes documenting the circumstances of a missed deadline, remediation actions taken, and communications with client or insurance carrier. Subject to Legal Professional Privilege (LPP).' ;
    rdfs:domain ind:DocketDeadline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedCostCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the estimated cost (e.g., \'USD\', \'EUR\', \'GBP\').' ;
    rdfs:domain ind:DocketDeadline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:extendedDueDate rdf:type rdf:Property ;
    rdfs:label 'Extended Due Date' ;
    rdfs:comment 'Extended due date if an extension of time has been requested and granted. Nullable if no extension applies. Represents the final enforceable deadline.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:extensionFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Extension Fee Amount' ;
    rdfs:comment 'Monetary amount of the extension fee required to extend the deadline, if applicable. Nullable if no extension fee applies.' ;
    rdfs:domain ind:DocketDeadline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:extensionFeeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Extension Fee Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the extension fee amount (e.g., \'USD\', \'EUR\', \'GBP\', \'JPY\').' ;
    rdfs:domain ind:DocketDeadline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:extensionFeeRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Extension Fee Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether an extension fee must be paid to obtain the extended due date. True if fee is required, False otherwise.' ;
    rdfs:domain ind:DocketDeadline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:missedDeadlineEscalationFlag rdf:type rdf:Property ;
    rdfs:label 'Missed Deadline Escalation Flag' ;
    rdfs:comment 'Boolean flag indicating whether a missed deadline has been escalated to management, risk committee, or malpractice insurance carrier. True if escalated, False otherwise.' ;
    rdfs:domain ind:DocketDeadline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:missedDeadlineFlag rdf:type rdf:Property ;
    rdfs:label 'Missed Deadline Flag' ;
    rdfs:comment 'Boolean flag indicating whether this deadline was missed. True if the deadline passed without completion, False otherwise. Mission-critical for malpractice risk tracking.' ;
    rdfs:domain ind:DocketDeadline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorityLevel rdf:type rdf:Property ;
    rdfs:label 'Priority Level' ;
    rdfs:comment 'Business priority level assigned to this deadline. Critical deadlines (e.g., statutory bar dates, national phase entry) require highest attention. Used for escalation and resource allocation.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reminderSchedule rdf:type rdf:Property ;
    rdfs:label 'Reminder Schedule' ;
    rdfs:comment 'Cascade schedule for deadline reminders, typically expressed as days before due date (e.g., \'90,60,30,14,7,3,1\' indicating reminders at 90 days, 60 days, 30 days, 14 days, 7 days, 3 days, and 1 day before the deadline).' ;
    rdfs:domain ind:DocketDeadline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statutoryRuleReference rdf:type rdf:Property ;
    rdfs:label 'Statutory Rule Reference' ;
    rdfs:comment 'Citation to the statutory rule, regulation, or patent office practice that defines this deadline (e.g., \'37 CFR 1.136\', \'EPC Rule 71(3)\', \'PCT Article 22(1)\').' ;
    rdfs:domain ind:DocketDeadline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipPaymentId rdf:type rdf:Property ;
    rdfs:label 'Ip Payment Id' ;
    rdfs:comment 'Primary key for payment' ;
    rdfs:domain ind:IpPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:disbursementAuthorizationId rdf:type rdf:Property ;
    rdfs:label 'Disbursement Authorization Id' ;
    rdfs:comment 'Foreign key linking to trust.disbursement_authorization. Business justification: Every IP fee payment disbursed from a trust account requires a disbursement authorization under bar rules and IOLTA regulations. Linking ip_payment to disbursement_authorization supports the authoriza' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DisbursementAuthorization .

ind:ledgerEntryId rdf:type rdf:Property ;
    rdfs:label 'Ledger Entry Id' ;
    rdfs:comment 'Foreign key linking to trust.trust_ledger_entry. Business justification: Annuity and royalty payments for IP assets are commonly disbursed from trust accounts. Links IP payment records to specific trust ledger entries for three-way reconciliation, regulatory compliance (IO' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LedgerEntry .

ind:auditAdjustmentFlag rdf:type rdf:Property ;
    rdfs:label 'Audit Adjustment Flag' ;
    rdfs:comment 'Boolean flag indicating whether this payment record has been adjusted as a result of an audit review or correction. True if adjusted, False otherwise.' ;
    rdfs:domain ind:IpPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:auditAdjustmentReason rdf:type rdf:Property ;
    rdfs:label 'Audit Adjustment Reason' ;
    rdfs:comment 'Explanation or reason for any audit adjustment made to the payment record. Populated only when audit_adjustment_flag is True.' ;
    rdfs:domain ind:IpPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipOfficeCode rdf:type rdf:Property ;
    rdfs:label 'Ip Office Code' ;
    rdfs:comment 'Code or identifier of the IP office or jurisdiction where the payment was submitted (e.g., USPTO, EPO, JPO, WIPO).' ;
    rdfs:domain ind:IpPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionCountryCode rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code representing the jurisdiction where the IP asset is registered and the payment is applicable.' ;
    rdfs:domain ind:IpPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:latePaymentFlag rdf:type rdf:Property ;
    rdfs:label 'Late Payment Flag' ;
    rdfs:comment 'Boolean flag indicating whether the payment was made after the official due date. True if late, False if on time. Used for lapse risk monitoring and performance tracking.' ;
    rdfs:domain ind:IpPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:latePaymentSurchargeAmount rdf:type rdf:Property ;
    rdfs:label 'Late Payment Surcharge Amount' ;
    rdfs:comment 'Additional surcharge or penalty amount assessed for late payment beyond the official due date. Common for annuity and maintenance fee payments.' ;
    rdfs:domain ind:IpPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Net Payment Amount' ;
    rdfs:comment 'Net payment amount after deducting withholding tax and adding any surcharges. Represents the actual amount paid or received.' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentDate rdf:type rdf:Property ;
    rdfs:label 'Payment Date' ;
    rdfs:comment 'Actual date the payment was made or received. Used for reconciliation, revenue recognition, and audit trail.' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reconciliationStatus rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Status' ;
    rdfs:comment 'Status of payment reconciliation against bank statements, IP office receipts, or license agreement terms. Unreconciled: not yet matched. Reconciled: fully matched and verified. Partially reconciled: partial match requiring further review. Disputed: discrepancy identified requiring resolution.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:royaltyBaseAmount rdf:type rdf:Property ;
    rdfs:label 'Royalty Base Amount' ;
    rdfs:comment 'Base amount (e.g., net sales, gross revenue, units sold) upon which the royalty rate is applied. Applicable only for royalty payment types.' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:royaltyPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Royalty Period End Date' ;
    rdfs:comment 'End date of the reporting period for which royalty is calculated and paid. Applicable only for royalty payment types.' ;
    rdfs:domain ind:IpPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:royaltyPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Royalty Period Start Date' ;
    rdfs:comment 'Start date of the reporting period for which royalty is calculated and paid. Applicable only for royalty payment types.' ;
    rdfs:domain ind:IpPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:royaltyRatePercent rdf:type rdf:Property ;
    rdfs:label 'Royalty Rate Percent' ;
    rdfs:comment 'Percentage rate applied to the royalty base to calculate the royalty payment amount. Applicable only for royalty payment types.' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:withholdingTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Amount' ;
    rdfs:comment 'Amount of withholding tax deducted from the payment, typically applicable to cross-border royalty payments. Used for tax compliance and net payment calculation.' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeDocketId rdf:type rdf:Property ;
    rdfs:label 'Dispute Docket Id' ;
    rdfs:comment 'Foreign key linking to court.docket. Business justification: License disputes (breach, royalty calculation, scope interpretation, FRAND obligations) frequently result in litigation. Direct link from license_agreement to court docket tracks these disputes, enabl' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Docket .

ind:escrowArrangementId rdf:type rdf:Property ;
    rdfs:label 'Escrow Arrangement Id' ;
    rdfs:comment 'Foreign key linking to trust.escrow_arrangement. Business justification: High-value IP licenses frequently use escrow for source code deposits, technology transfer security, or payment guarantees. Links license agreements to escrow arrangements for tracking release conditi' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EscrowArrangement .

ind:judgmentId rdf:type rdf:Property ;
    rdfs:label 'Judgment Id' ;
    rdfs:comment 'Foreign key linking to matter.judgment. Business justification: Court-ordered licenses (compulsory licensing, FRAND determinations, settlement judgments) require linking the license agreement to the originating judgment for enforcement monitoring, compliance track' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Judgment .

ind:licenseeOrganisationId rdf:type rdf:Property ;
    rdfs:label 'Licensee Organisation Id' ;
    rdfs:comment 'Foreign key linking to client.organisation. Business justification: IP licensing practice requires tracking the licensee as a proper client organisation FK for conflict checks, KYC compliance, royalty reporting, and panel management. licensee_name is a denormalized re' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Organisation .

ind:patentFamilyId rdf:type rdf:Property ;
    rdfs:label 'Patent Family Id' ;
    rdfs:comment 'Foreign key linking to ip.patent_family. Business justification: Portfolio license agreements in IP law frequently cover entire patent families rather than individual patents. A license agreement may grant rights to all current and future members of a patent family' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PatentFamily .

ind:agreementType rdf:type rdf:Property ;
    rdfs:label 'Agreement Type' ;
    rdfs:comment 'Discriminator classifying the type of IP agreement. [ENUM-REF-CANDIDATE: exclusive_license|non_exclusive_license|sole_license|cross_license|compulsory_license|frand_license|invention_assignment|co_ownership_agreement|joint_development_agreement|technology_transfer_agreement|ip_indemnification_agreement|confidentiality_agreement_with_ip_terms|settlement_agreement_with_ip_covenants — promote to reference product]' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentHistory rdf:type rdf:Property ;
    rdfs:label 'Amendment History' ;
    rdfs:comment 'Record of amendments, addenda, or modifications made to the original agreement, including dates and summary of changes.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditRights rdf:type rdf:Property ;
    rdfs:label 'Audit Rights' ;
    rdfs:comment 'Description of the licensor\'s rights to audit the licensee\'s records to verify royalty calculations and compliance.' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityTerms rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Terms' ;
    rdfs:comment 'Summary of confidentiality obligations related to proprietary information exchanged under the agreement.' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeResolutionMechanism rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Mechanism' ;
    rdfs:comment 'Method specified in the agreement for resolving disputes between the parties.' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentStorageLocation rdf:type rdf:Property ;
    rdfs:label 'Document Storage Location' ;
    rdfs:comment 'Reference to the location in the Document Management System (DMS) where the executed agreement and related documents are stored.' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivityTerms rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Terms' ;
    rdfs:comment 'Description of any exclusivity provisions, including exclusive territories, fields of use, or time periods during which the licensee has exclusive rights.' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionStatus rdf:type rdf:Property ;
    rdfs:label 'Execution Status' ;
    rdfs:comment 'Current lifecycle status of the IP license agreement indicating its execution and enforceability state.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fieldOfUse rdf:type rdf:Property ;
    rdfs:label 'Field Of Use' ;
    rdfs:comment 'Specific industry, application, or market segment in which the licensee is permitted to use the licensed IP.' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fixedRoyaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Fixed Royalty Amount' ;
    rdfs:comment 'Fixed monetary amount payable under the license agreement, if applicable. Nullable for non-fixed structures.' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:governingLaw rdf:type rdf:Property ;
    rdfs:label 'Governing Law' ;
    rdfs:comment 'Jurisdiction and legal framework governing the interpretation and enforcement of the IP license agreement.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:improvementRights rdf:type rdf:Property ;
    rdfs:label 'Improvement Rights' ;
    rdfs:comment 'Terms governing ownership and licensing of improvements, modifications, or derivative works created under the agreement.' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indemnificationTerms rdf:type rdf:Property ;
    rdfs:label 'Indemnification Terms' ;
    rdfs:comment 'Summary of indemnification obligations, including IP infringement indemnities and liability caps.' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyObligations rdf:type rdf:Property ;
    rdfs:label 'Key Obligations' ;
    rdfs:comment 'Summary of the principal obligations of each party under the agreement, including performance milestones, reporting requirements, and quality standards.' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licensorName rdf:type rdf:Property ;
    rdfs:label 'Licensor Name' ;
    rdfs:comment 'Legal name of the party granting the IP license or assigning IP rights.' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceMilestones rdf:type rdf:Property ;
    rdfs:label 'Performance Milestones' ;
    rdfs:comment 'Key performance milestones or deliverables required under the agreement, particularly relevant for joint development or technology transfer agreements.' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalTerms rdf:type rdf:Property ;
    rdfs:label 'Renewal Terms' ;
    rdfs:comment 'Description of the conditions and process for renewing the license agreement upon expiry, including notice periods and renewal fees.' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:royaltyCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Royalty Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for royalty payments.' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:royaltyStructure rdf:type rdf:Property ;
    rdfs:label 'Royalty Structure' ;
    rdfs:comment 'Type of royalty or payment structure governing compensation under the license agreement.' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sublicensingPermittedFlag rdf:type rdf:Property ;
    rdfs:label 'Sublicensing Permitted Flag' ;
    rdfs:comment 'Indicates whether the licensee is permitted to grant sublicenses to third parties under this agreement.' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:terminationProvisions rdf:type rdf:Property ;
    rdfs:label 'Termination Provisions' ;
    rdfs:comment 'Summary of the conditions under which either party may terminate the agreement, including breach, insolvency, or convenience termination clauses.' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territory rdf:type rdf:Property ;
    rdfs:label 'Territory' ;
    rdfs:comment 'Geographic scope of the license, specifying countries or regions where the licensed IP may be used. Use ISO 3166-1 alpha-3 country codes where applicable.' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyTerms rdf:type rdf:Property ;
    rdfs:label 'Warranty Terms' ;
    rdfs:comment 'Summary of warranties provided by the licensor regarding IP ownership, validity, and non-infringement.' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:royaltyPaymentId rdf:type rdf:Property ;
    rdfs:label 'Royalty Payment Id' ;
    rdfs:comment 'Unique identifier for the royalty payment transaction. Primary key for the royalty payment record.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryRoyaltyOrganisationId rdf:type rdf:Property ;
    rdfs:label 'Primary Royalty Organisation Id' ;
    rdfs:comment 'Reference to the party making the royalty payment (the licensee using the IP).' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Organisation .

ind:receiptId rdf:type rdf:Property ;
    rdfs:label 'Receipt Id' ;
    rdfs:comment 'Foreign key linking to trust.trust_receipt. Business justification: When royalty payments are received into trust accounts (common in IP licensing), links the royalty payment record to the trust receipt for AML/KYC compliance, source-of-funds verification, and reconci' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Receipt .

ind:trustDisbursementId rdf:type rdf:Property ;
    rdfs:label 'Trust Disbursement Id' ;
    rdfs:comment 'Foreign key linking to trust.trust_disbursement. Business justification: Outbound royalty payments to licensors or inventors disbursed from trust accounts generate trust_disbursement records. royalty_payment.payment_direction indicates bidirectional flows; linking to trust' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TrustDisbursement .

ind:adjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Adjustment Amount' ;
    rdfs:comment 'Any adjustment amount applied to the calculated royalty (e.g., audit adjustments, true-up adjustments, credits, or penalties).' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adjustmentReason rdf:type rdf:Property ;
    rdfs:label 'Adjustment Reason' ;
    rdfs:comment 'Explanation or reason for any adjustment made to the calculated royalty amount (e.g., audit finding, prior period correction, contractual penalty).' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditDate rdf:type rdf:Property ;
    rdfs:label 'Audit Date' ;
    rdfs:comment 'Date on which the royalty payment or underlying royalty calculation was audited.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditFindings rdf:type rdf:Property ;
    rdfs:label 'Audit Findings' ;
    rdfs:comment 'Summary of findings from the royalty audit, including any discrepancies, adjustments, or compliance issues identified.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditFlag rdf:type rdf:Property ;
    rdfs:label 'Audit Flag' ;
    rdfs:comment 'Boolean indicator of whether this royalty payment has been subject to audit or requires audit review.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:calculatedRoyaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Calculated Royalty Amount' ;
    rdfs:comment 'The gross royalty amount calculated by applying the royalty rate to the royalty base, before any adjustments, withholdings, or deductions.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentDirection rdf:type rdf:Property ;
    rdfs:label 'Payment Direction' ;
    rdfs:comment 'Indicates whether the royalty payment is inbound (received by the firm) or outbound (paid by the firm).' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentDueDate rdf:type rdf:Property ;
    rdfs:label 'Payment Due Date' ;
    rdfs:comment 'The contractual due date by which the royalty payment should be made according to the license agreement.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentNotes rdf:type rdf:Property ;
    rdfs:label 'Payment Notes' ;
    rdfs:comment 'Free-text notes or comments regarding the royalty payment, including special circumstances, disputes, or clarifications.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Payment Period End Date' ;
    rdfs:comment 'End date of the reporting period for which royalties are calculated and paid.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Payment Period Start Date' ;
    rdfs:comment 'Start date of the reporting period for which royalties are calculated and paid.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Reference Number' ;
    rdfs:comment 'External reference number or transaction identifier for the royalty payment, used for reconciliation and audit purposes.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationDate rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Date' ;
    rdfs:comment 'Date on which the royalty payment was reconciled with the royalty report and license agreement.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:royaltyBaseType rdf:type rdf:Property ;
    rdfs:label 'Royalty Base Type' ;
    rdfs:comment 'The basis on which royalty is calculated (e.g., net sales, gross sales, units sold, revenue, profit, fixed fee, or minimum guarantee). [ENUM-REF-CANDIDATE: net_sales|gross_sales|units_sold|revenue|profit|fixed_fee|minimum_guarantee — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:royaltyRate rdf:type rdf:Property ;
    rdfs:label 'Royalty Rate' ;
    rdfs:comment 'The percentage or per-unit rate applied to the royalty base to calculate the royalty amount. Expressed as a decimal (e.g., 0.05 for 5%).' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:withholdingTaxRate rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Rate' ;
    rdfs:comment 'The percentage rate of withholding tax applied to the royalty payment, as per tax treaty or domestic law.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ownershipId rdf:type rdf:Property ;
    rdfs:label 'Ownership Id' ;
    rdfs:comment 'Primary key for ownership' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Ownership .

ind:predecessorOwnershipId rdf:type rdf:Property ;
    rdfs:label 'Predecessor Ownership Id' ;
    rdfs:comment 'Reference to the previous ownership record in the chain of title. Enables reconstruction of the complete ownership history for due diligence purposes.' ;
    rdfs:domain ind:Ownership ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Ownership .

ind:assignmentDate rdf:type rdf:Property ;
    rdfs:label 'Assignment Date' ;
    rdfs:comment 'Date on which the ownership rights were assigned or transferred to the current owner. Represents the effective date of the assignment agreement.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:basis rdf:type rdf:Property ;
    rdfs:label 'Basis' ;
    rdfs:comment 'Legal basis or mechanism by which ownership was acquired. Distinguishes between original application, assignment, merger/acquisition, inheritance, court order, license conversion, or other mechanisms. [ENUM-REF-CANDIDATE: original_applicant|assignment|merger_acquisition|inheritance|court_order|license_conversion|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Ownership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficialOwnerIdentifier rdf:type rdf:Property ;
    rdfs:label 'Beneficial Owner Identifier' ;
    rdfs:comment 'Unique identifier for the beneficial owner (e.g., tax ID, national ID, passport number). Required for KYC and AML compliance.' ;
    rdfs:domain ind:Ownership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficialOwnerName rdf:type rdf:Property ;
    rdfs:label 'Beneficial Owner Name' ;
    rdfs:comment 'Name of the ultimate beneficial owner if different from the legal owner. Required for Anti-Money Laundering (AML) and Know Your Client (KYC) compliance.' ;
    rdfs:domain ind:Ownership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:considerationAmount rdf:type rdf:Property ;
    rdfs:label 'Consideration Amount' ;
    rdfs:comment 'Monetary consideration paid for the assignment or transfer of ownership rights. May be zero for assignments without monetary consideration (e.g., employment agreements).' ;
    rdfs:domain ind:Ownership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:considerationCurrency rdf:type rdf:Property ;
    rdfs:label 'Consideration Currency' ;
    rdfs:comment 'Three-letter ISO currency code for the consideration amount. Required when consideration_amount is non-zero.' ;
    rdfs:domain ind:Ownership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveEndDate rdf:type rdf:Property ;
    rdfs:label 'Effective End Date' ;
    rdfs:comment 'Date until which this ownership record is effective. Null for current ownership. Supports temporal tracking of ownership changes and chain of title reconstruction.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Effective Start Date' ;
    rdfs:comment 'Date from which this ownership record is effective. Supports temporal tracking of ownership changes and chain of title reconstruction.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:frandCommitmentReference rdf:type rdf:Property ;
    rdfs:label 'Frand Commitment Reference' ;
    rdfs:comment 'Reference to the FRAND commitment or declaration made to the relevant standards development organization (SDO).' ;
    rdfs:domain ind:Ownership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCurrentOwner rdf:type rdf:Property ;
    rdfs:label 'Is Current Owner' ;
    rdfs:comment 'Flag indicating whether this record represents the current owner of the IP asset. True for the active ownership record, false for historical records.' ;
    rdfs:domain ind:Ownership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jointOwnershipFlag rdf:type rdf:Property ;
    rdfs:label 'Joint Ownership Flag' ;
    rdfs:comment 'Indicates whether the IP asset is subject to joint ownership by multiple parties. True if multiple ownership records exist for the same IP asset.' ;
    rdfs:domain ind:Ownership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:licenseBackFlag rdf:type rdf:Property ;
    rdfs:label 'License Back Flag' ;
    rdfs:comment 'Indicates whether the assignment includes a license-back provision allowing the assignor to continue using the IP. Common in employment and M&A contexts.' ;
    rdfs:domain ind:Ownership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:licenseBackTerms rdf:type rdf:Property ;
    rdfs:label 'License Back Terms' ;
    rdfs:comment 'Summary of the license-back terms if applicable, including scope, duration, and any royalty obligations.' ;
    rdfs:domain ind:Ownership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedBy rdf:type rdf:Property ;
    rdfs:label 'Modified By' ;
    rdfs:comment 'Identifier of the user or system that last modified this ownership record. Used for audit trail and accountability.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ofAsset rdf:type rdf:Property ;
    rdfs:label 'Of Asset' ;
    rdfs:comment 'FK to ip.asset.asset_id — Ownership records establish chain of title for specific IP assets. Essential for assignment tracking and M&A due diligence.' ;
    rdfs:domain ind:Ownership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ownerAddress rdf:type rdf:Property ;
    rdfs:label 'Owner Address' ;
    rdfs:comment 'Full legal address of the owner entity as recorded with the IP office. Required for official correspondence and recordal purposes.' ;
    rdfs:domain ind:Ownership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerContactEmail rdf:type rdf:Property ;
    rdfs:label 'Owner Contact Email' ;
    rdfs:comment 'Primary email address for correspondence with the owner regarding this IP ownership record.' ;
    rdfs:domain ind:Ownership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerContactPhone rdf:type rdf:Property ;
    rdfs:label 'Owner Contact Phone' ;
    rdfs:comment 'Primary telephone number for contacting the owner regarding this IP ownership record.' ;
    rdfs:domain ind:Ownership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerCountryCode rdf:type rdf:Property ;
    rdfs:label 'Owner Country Code' ;
    rdfs:comment 'Three-letter ISO country code representing the country of domicile or incorporation of the owner entity.' ;
    rdfs:domain ind:Ownership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerEntityName rdf:type rdf:Property ;
    rdfs:label 'Owner Entity Name' ;
    rdfs:comment 'Full legal name of the entity or individual that holds ownership rights in the IP asset. May be an individual inventor, corporate assignee, joint owner, or government entity.' ;
    rdfs:domain ind:Ownership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerType rdf:type rdf:Property ;
    rdfs:label 'Owner Type' ;
    rdfs:comment 'Classification of the ownership entity type. Distinguishes between individual inventors, corporate assignees, joint owners, government entities, universities, and trusts.' ;
    rdfs:domain ind:Ownership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipStatus rdf:type rdf:Property ;
    rdfs:label 'Ownership Status' ;
    rdfs:comment 'Current lifecycle status of the ownership record. Tracks whether ownership is active, pending recordal, transferred to another party, terminated, under dispute, or lapsed.' ;
    rdfs:domain ind:Ownership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:percentage rdf:type rdf:Property ;
    rdfs:label 'Percentage' ;
    rdfs:comment 'Percentage of ownership interest held by this owner in the IP asset. For sole ownership, this is 100.00. For joint ownership, reflects the proportional share.' ;
    rdfs:domain ind:Ownership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recordalDate rdf:type rdf:Property ;
    rdfs:label 'Recordal Date' ;
    rdfs:comment 'Date on which the ownership assignment was officially recorded with the relevant IP office or registry. Critical for establishing priority and chain of title.' ;
    rdfs:domain ind:Ownership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recordalNumber rdf:type rdf:Property ;
    rdfs:label 'Recordal Number' ;
    rdfs:comment 'Official recordal or registration number issued by the IP office when the ownership assignment was recorded. Used for verification and audit purposes.' ;
    rdfs:domain ind:Ownership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityInterestDescription rdf:type rdf:Property ;
    rdfs:label 'Security Interest Description' ;
    rdfs:comment 'Description of any security interest, lien, or encumbrance affecting the IP ownership. Includes details of the secured party and nature of the security.' ;
    rdfs:domain ind:Ownership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityInterestFlag rdf:type rdf:Property ;
    rdfs:label 'Security Interest Flag' ;
    rdfs:comment 'Indicates whether the IP asset is subject to a security interest, lien, or encumbrance that affects ownership rights. True if security interest exists.' ;
    rdfs:domain ind:Ownership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:verificationDate rdf:type rdf:Property ;
    rdfs:label 'Verification Date' ;
    rdfs:comment 'Date on which the ownership record was last verified or validated. Critical for due diligence and portfolio audits.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verificationStatus rdf:type rdf:Property ;
    rdfs:label 'Verification Status' ;
    rdfs:comment 'Status of the ownership verification process. Indicates whether the chain of title has been verified, is pending verification, remains unverified, or is disputed.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifiedBy rdf:type rdf:Property ;
    rdfs:label 'Verified By' ;
    rdfs:comment 'Name or identifier of the person or system that performed the ownership verification. Used for audit trail purposes.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdBy rdf:type rdf:Property ;
    rdfs:label 'Created By' ;
    rdfs:comment 'Identifier of the user or system that created this ownership record. Used for audit trail and accountability.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventorId rdf:type rdf:Property ;
    rdfs:label 'Inventor Id' ;
    rdfs:comment 'Unique identifier for the inventor record. Primary key for the inventor entity.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Inventor .

ind:assignmentExecutedFlag rdf:type rdf:Property ;
    rdfs:label 'Assignment Executed Flag' ;
    rdfs:comment 'Indicates whether the inventor has executed a formal assignment of patent rights to the employer or assignee. Critical for chain of title verification.' ;
    rdfs:domain ind:Inventor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assignmentExecutionDate rdf:type rdf:Property ;
    rdfs:label 'Assignment Execution Date' ;
    rdfs:comment 'Date on which the inventor signed the patent assignment document transferring rights to the assignee.' ;
    rdfs:domain ind:Inventor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignmentRecordationNumber rdf:type rdf:Property ;
    rdfs:label 'Assignment Recordation Number' ;
    rdfs:comment 'USPTO or patent office recordation number for the assignment document. Used to verify chain of title in patent prosecution and litigation.' ;
    rdfs:domain ind:Inventor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conceptionDate rdf:type rdf:Property ;
    rdfs:label 'Conception Date' ;
    rdfs:comment 'Date on which the inventor conceived the complete and operative invention. Used for priority determination in interference and derivation proceedings.' ;
    rdfs:domain ind:Inventor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contributionDescription rdf:type rdf:Property ;
    rdfs:label 'Contribution Description' ;
    rdfs:comment 'Detailed description of the inventor\'s specific contribution to the conception of the claimed invention. Used for inventorship determination and correction of inventorship proceedings.' ;
    rdfs:domain ind:Inventor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Data Source System' ;
    rdfs:comment 'Name of the source system from which the inventor record originated (e.g., patent docketing system, invention disclosure system, HR system).' ;
    rdfs:domain ind:Inventor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deceasedDate rdf:type rdf:Property ;
    rdfs:label 'Deceased Date' ;
    rdfs:comment 'Date of death of the inventor, if applicable. Triggers substitute statement requirements for pending applications.' ;
    rdfs:domain ind:Inventor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:derivationProceedingNumber rdf:type rdf:Property ;
    rdfs:label 'Derivation Proceeding Number' ;
    rdfs:comment 'USPTO Patent Trial and Appeal Board (PTAB) proceeding number for any derivation proceeding involving this inventor.' ;
    rdfs:domain ind:Inventor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emailAddress rdf:type rdf:Property ;
    rdfs:label 'Email Address' ;
    rdfs:comment 'Primary email address for inventor correspondence regarding patent prosecution, inventorship disputes, and assignment execution.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employerAtInvention rdf:type rdf:Property ;
    rdfs:label 'Employer At Invention' ;
    rdfs:comment 'Name of the organization employing the inventor at the time the invention was conceived. Critical for determining assignment rights and work-for-hire status.' ;
    rdfs:domain ind:Inventor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employmentAgreementReference rdf:type rdf:Property ;
    rdfs:label 'Employment Agreement Reference' ;
    rdfs:comment 'Reference identifier or document number for the employment agreement containing IP assignment provisions. Used to verify pre-invention assignment obligations.' ;
    rdfs:domain ind:Inventor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:familyName rdf:type rdf:Property ;
    rdfs:label 'Family Name' ;
    rdfs:comment 'Last or family name of the inventor. Used for structured name parsing in international patent filings.' ;
    rdfs:domain ind:Inventor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fullLegalName rdf:type rdf:Property ;
    rdfs:label 'Full Legal Name' ;
    rdfs:comment 'Complete legal name of the inventor as it appears on patent applications and grants. Used for inventorship determination and official USPTO/EPO/WIPO filings.' ;
    rdfs:domain ind:Inventor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:givenName rdf:type rdf:Property ;
    rdfs:label 'Given Name' ;
    rdfs:comment 'First or given name of the inventor. Used for structured name parsing in international patent filings.' ;
    rdfs:domain ind:Inventor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventionDisclosureDate rdf:type rdf:Property ;
    rdfs:label 'Invention Disclosure Date' ;
    rdfs:comment 'Date on which the inventor formally disclosed the invention to the employer or patent counsel. Establishes priority date for derivation proceedings and assignment chain.' ;
    rdfs:domain ind:Inventor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inventorStatus rdf:type rdf:Property ;
    rdfs:label 'Inventor Status' ;
    rdfs:comment 'Current lifecycle status of the inventor record. Affects ability to obtain signatures for continuation applications and assignment documents.' ;
    rdfs:domain ind:Inventor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventorshipDisputeFlag rdf:type rdf:Property ;
    rdfs:label 'Inventorship Dispute Flag' ;
    rdfs:comment 'Indicates whether this inventor is involved in an inventorship dispute, derivation proceeding, or correction of inventorship petition.' ;
    rdfs:domain ind:Inventor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jointInventorFlag rdf:type rdf:Property ;
    rdfs:label 'Joint Inventor Flag' ;
    rdfs:comment 'Indicates whether this inventor is one of multiple joint inventors on one or more patent applications. Joint inventors must each contribute to the conception of at least one claim.' ;
    rdfs:domain ind:Inventor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalRepresentativeName rdf:type rdf:Property ;
    rdfs:label 'Legal Representative Name' ;
    rdfs:comment 'Name of the legal representative (executor, administrator, guardian) authorized to act on behalf of a deceased or incapacitated inventor.' ;
    rdfs:domain ind:Inventor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nationalityCountryCode rdf:type rdf:Property ;
    rdfs:label 'Nationality Country Code' ;
    rdfs:comment 'Three-letter ISO country code representing the inventor\'s nationality. Required for PCT applications and determines eligibility for certain patent prosecution highways.' ;
    rdfs:domain ind:Inventor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oathDeclarationDate rdf:type rdf:Property ;
    rdfs:label 'Oath Declaration Date' ;
    rdfs:comment 'Date on which the inventor executed the oath or declaration for the patent application.' ;
    rdfs:domain ind:Inventor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:oathDeclarationStatus rdf:type rdf:Property ;
    rdfs:label 'Oath Declaration Status' ;
    rdfs:comment 'Status of the inventor\'s oath or declaration required for patent application filing. Indicates whether the inventor has sworn to the accuracy of the application.' ;
    rdfs:domain ind:Inventor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orcidIdentifier rdf:type rdf:Property ;
    rdfs:label 'Orcid Identifier' ;
    rdfs:comment 'Unique persistent digital identifier for the inventor as a researcher. Facilitates disambiguation of inventor names across patent offices and academic publications.' ;
    rdfs:domain ind:Inventor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phoneNumber rdf:type rdf:Property ;
    rdfs:label 'Phone Number' ;
    rdfs:comment 'Primary contact phone number for the inventor. Used for urgent patent prosecution matters and inventorship verification.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorArtDisclosureObligationFlag rdf:type rdf:Property ;
    rdfs:label 'Prior Art Disclosure Obligation Flag' ;
    rdfs:comment 'Indicates whether the inventor has an ongoing duty to disclose known prior art material to patentability under the duty of candor.' ;
    rdfs:domain ind:Inventor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:residenceAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Residence Address Line 1' ;
    rdfs:comment 'Primary street address line of the inventor\'s residence. Required for inventor oath or declaration filings.' ;
    rdfs:domain ind:Inventor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residenceAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Residence Address Line 2' ;
    rdfs:comment 'Secondary street address line of the inventor\'s residence (apartment, suite, building number).' ;
    rdfs:domain ind:Inventor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residenceCity rdf:type rdf:Property ;
    rdfs:label 'Residence City' ;
    rdfs:comment 'City or municipality of the inventor\'s residence address.' ;
    rdfs:domain ind:Inventor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residenceCountryCode rdf:type rdf:Property ;
    rdfs:label 'Residence Country Code' ;
    rdfs:comment 'Three-letter ISO country code representing the inventor\'s country of residence at time of invention. Determines applicable patent law jurisdiction and filing requirements.' ;
    rdfs:domain ind:Inventor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residencePostalCode rdf:type rdf:Property ;
    rdfs:label 'Residence Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the inventor\'s residence address.' ;
    rdfs:domain ind:Inventor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residenceStateProvince rdf:type rdf:Property ;
    rdfs:label 'Residence State Province' ;
    rdfs:comment 'State, province, or administrative region of the inventor\'s residence address.' ;
    rdfs:domain ind:Inventor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicantOrganisationId rdf:type rdf:Property ;
    rdfs:label 'Applicant Organisation Id' ;
    rdfs:comment 'Foreign key linking to client.organisation. Business justification: Patent family prosecution management requires the applicant to be a linked client organisation for PCT filings, national phase entries, and portfolio valuation reporting. applicant_name is a denormali' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Organisation .

ind:abstractText rdf:type rdf:Property ;
    rdfs:label 'Abstract Text' ;
    rdfs:comment 'Brief technical summary of the invention from the priority or representative application. Typically 150-300 words describing the technical problem, solution, and key features.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activeIndicator rdf:type rdf:Property ;
    rdfs:label 'Active Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this patent family record is currently active in the system. True for active records, False for archived or soft-deleted records. Used for data retention and reporting filters.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:continuationChainIndicator rdf:type rdf:Property ;
    rdfs:label 'Continuation Chain Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this family includes continuation, continuation-in-part, or divisional applications. True if continuation chain exists, False otherwise.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cpcClass rdf:type rdf:Property ;
    rdfs:label 'Cpc Class' ;
    rdfs:comment 'Primary CPC classification code. Joint classification system developed by EPO and USPTO providing more granular technical categorization than IPC.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:divisionalChainIndicator rdf:type rdf:Property ;
    rdfs:label 'Divisional Chain Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this family includes divisional applications filed to pursue distinct inventions disclosed in a parent application. True if divisional chain exists, False otherwise.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:docketingSystemReference rdf:type rdf:Property ;
    rdfs:label 'Docketing System Reference' ;
    rdfs:comment 'External reference identifier in the IP docketing system (e.g., CPI, Foundation IP, Alt Legal) used for deadline management and prosecution tracking. Enables cross-system reconciliation.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:familyIdentifier rdf:type rdf:Property ;
    rdfs:label 'Family Identifier' ;
    rdfs:comment 'Externally-known unique identifier for the patent family, typically assigned by the IP management system or patent office. Used for cross-system reference and client communication.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:familyStatus rdf:type rdf:Property ;
    rdfs:label 'Family Status' ;
    rdfs:comment 'Current overall status of the patent family. Active (at least one granted and in-force patent), Pending (applications under prosecution), Expired (all patents reached end of term), Abandoned (all applications withdrawn or rejected), Lapsed (all patents lapsed due to non-payment).' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:familyType rdf:type rdf:Property ;
    rdfs:label 'Family Type' ;
    rdfs:comment 'Classification of the patent family structure. Simple (Paris Convention family sharing same priority), Extended (INPADOC family including all related applications), Complete (all documents sharing technical content).' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frandObligationIndicator rdf:type rdf:Property ;
    rdfs:label 'Frand Obligation Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this patent family is subject to FRAND (Fair, Reasonable, and Non-Discriminatory) licensing obligations due to standard-essential patent (SEP) declarations. True if FRAND-encumbered, False otherwise.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:freedomToOperateStatus rdf:type rdf:Property ;
    rdfs:label 'Freedom To Operate Status' ;
    rdfs:comment 'Status of freedom-to-operate analysis for this patent family. Clear (no blocking patents identified), Risk_identified (potential infringement risk found), Under_review (FTO analysis in progress), Not_assessed (no FTO performed). Business-confidential strategic information.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventionTitle rdf:type rdf:Property ;
    rdfs:label 'Invention Title' ;
    rdfs:comment 'The title of the invention as disclosed in the priority or representative application. Used for quick identification and portfolio reporting.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipcClass rdf:type rdf:Property ;
    rdfs:label 'Ipc Class' ;
    rdfs:comment 'Primary IPC classification code assigned to this patent family. Hierarchical classification system used worldwide for categorizing patent documents by technical field.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:litigationInvolvementIndicator rdf:type rdf:Property ;
    rdfs:label 'Litigation Involvement Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this patent family is currently or has been involved in patent litigation, opposition, or inter partes review proceedings. True if litigation history exists, False otherwise.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:memberJurisdictionCount rdf:type rdf:Property ;
    rdfs:label 'Member Jurisdiction Count' ;
    rdfs:comment 'Total number of distinct jurisdictions (countries or patent offices) where patent applications or grants exist as members of this family. Indicates geographic breadth of protection.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextAnnuityDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Annuity Due Date' ;
    rdfs:comment 'Earliest upcoming annuity or maintenance fee due date across all active family members. Critical for IP docketing and cash flow planning.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:oppositionCount rdf:type rdf:Property ;
    rdfs:label 'Opposition Count' ;
    rdfs:comment 'Total number of opposition or post-grant review proceedings filed against patents in this family. Indicator of competitive interest and patent strength.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pctApplicationIndicator rdf:type rdf:Property ;
    rdfs:label 'Pct Application Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this family includes a PCT international application. True if PCT route was used, False otherwise. Critical for understanding prosecution strategy and timeline.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pphEligibilityIndicator rdf:type rdf:Property ;
    rdfs:label 'Pph Eligibility Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this family is eligible for accelerated examination under Patent Prosecution Highway agreements based on allowance in a participating office. True if eligible, False otherwise.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorityApplicationNumber rdf:type rdf:Property ;
    rdfs:label 'Priority Application Number' ;
    rdfs:comment 'The application number of the earliest filing (priority application) that establishes the priority date for this patent family. Format typically includes country code and serial number.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityCountryCode rdf:type rdf:Property ;
    rdfs:label 'Priority Country Code' ;
    rdfs:comment 'ISO country code of the jurisdiction where the priority application was filed. Three-letter ISO 3166-1 alpha-3 format.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Record Source System' ;
    rdfs:comment 'Name of the source system from which this patent family record originated (e.g., Elite 3E, IP docketing system, patent office data feed). Used for data lineage and reconciliation.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardEssentialPatentIndicator rdf:type rdf:Property ;
    rdfs:label 'Standard Essential Patent Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this patent family has been declared as essential to one or more technical standards. True if declared as SEP, False otherwise.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:strategicImportanceRating rdf:type rdf:Property ;
    rdfs:label 'Strategic Importance Rating' ;
    rdfs:comment 'Business assessment of the strategic value of this patent family to the client\'s IP portfolio. Used for prioritization of prosecution spend, licensing strategy, and portfolio pruning decisions.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:copyrightId rdf:type rdf:Property ;
    rdfs:label 'Copyright Id' ;
    rdfs:comment 'Primary key for copyright' ;
    rdfs:domain ind:Copyright ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:claimantOrganisationId rdf:type rdf:Property ;
    rdfs:label 'Claimant Organisation Id' ;
    rdfs:comment 'Foreign key linking to client.organisation. Business justification: Copyright registration and enforcement requires the claimant to be a linked client organisation for ownership verification, licensing negotiations, and infringement actions. claimant_name is a denorma' ;
    rdfs:domain ind:Copyright ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Organisation .

ind:applicationDate rdf:type rdf:Property ;
    rdfs:label 'Application Date' ;
    rdfs:comment 'The date on which the copyright registration application was filed with the copyright office. Establishes priority and filing date for registration purposes.' ;
    rdfs:domain ind:Copyright ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authorNames rdf:type rdf:Property ;
    rdfs:label 'Author Names' ;
    rdfs:comment 'The name(s) of the individual(s) or entity(ies) who created the work. May include multiple authors separated by delimiters. Author information is critical for determining copyright ownership and duration.' ;
    rdfs:domain ind:Copyright ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depositCopyStatus rdf:type rdf:Property ;
    rdfs:label 'Deposit Copy Status' ;
    rdfs:comment 'Status of the deposit copy requirement for copyright registration. Indicates whether the required copy of the work has been submitted to the copyright office.' ;
    rdfs:domain ind:Copyright ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:derivativeWorkFlag rdf:type rdf:Property ;
    rdfs:label 'Derivative Work Flag' ;
    rdfs:comment 'Indicates whether this work is a derivative work based on one or more preexisting works. Affects copyright scope and registration requirements.' ;
    rdfs:domain ind:Copyright ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:durationYears rdf:type rdf:Property ;
    rdfs:label 'Duration Years' ;
    rdfs:comment 'The calculated duration of copyright protection in years from the date of creation or publication. Varies by jurisdiction and work type.' ;
    rdfs:domain ind:Copyright ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:enforcementActionCount rdf:type rdf:Property ;
    rdfs:label 'Enforcement Action Count' ;
    rdfs:comment 'The total number of enforcement actions (cease and desist letters, litigation, takedown notices) taken to protect this copyright. Used for portfolio risk assessment.' ;
    rdfs:domain ind:Copyright ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fairUseAnalysisFlag rdf:type rdf:Property ;
    rdfs:label 'Fair Use Analysis Flag' ;
    rdfs:comment 'Indicates whether a fair use analysis has been conducted for this work in relation to potential infringement claims. Relevant for enforcement strategy.' ;
    rdfs:domain ind:Copyright ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:infringementDetectedFlag rdf:type rdf:Property ;
    rdfs:label 'Infringement Detected Flag' ;
    rdfs:comment 'Indicates whether any copyright infringement has been detected for this work. True if infringement monitoring has identified unauthorized use.' ;
    rdfs:domain ind:Copyright ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:officeName rdf:type rdf:Property ;
    rdfs:label 'Office Name' ;
    rdfs:comment 'The name of the copyright office or registration authority where the copyright is registered (e.g., U.S. Copyright Office, UK Intellectual Property Office).' ;
    rdfs:domain ind:Copyright ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preexistingWorkReference rdf:type rdf:Property ;
    rdfs:label 'Preexisting Work Reference' ;
    rdfs:comment 'Reference to the preexisting work(s) upon which this derivative work is based. Includes title, author, and registration information of the underlying work.' ;
    rdfs:domain ind:Copyright ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationCertificateReference rdf:type rdf:Property ;
    rdfs:label 'Registration Certificate Reference' ;
    rdfs:comment 'Document reference or file path to the official copyright registration certificate issued by the copyright office. Links to the document management system (DMS).' ;
    rdfs:domain ind:Copyright ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationStatus rdf:type rdf:Property ;
    rdfs:label 'Registration Status' ;
    rdfs:comment 'Current status of the copyright registration with the relevant copyright office. Indicates whether the work has formal registration protection.' ;
    rdfs:domain ind:Copyright ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workMadeForHireFlag rdf:type rdf:Property ;
    rdfs:label 'Work Made For Hire Flag' ;
    rdfs:comment 'Indicates whether the work was created as a work made for hire, affecting copyright ownership and duration. True if the work was created by an employee within the scope of employment or under a written agreement.' ;
    rdfs:domain ind:Copyright ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workTitle rdf:type rdf:Property ;
    rdfs:label 'Work Title' ;
    rdfs:comment 'The title or name of the copyrighted work as registered or claimed. This is the primary human-readable identifier for the work.' ;
    rdfs:domain ind:Copyright ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workType rdf:type rdf:Property ;
    rdfs:label 'Work Type' ;
    rdfs:comment 'The category or type of copyrighted work. Classifies the work according to copyright law categories for registration and enforcement purposes. [ENUM-REF-CANDIDATE: literary|musical|dramatic|artistic|audiovisual|software|architectural|sound_recording|choreographic|pictorial_graphic_sculptural|compilation|derivative — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Copyright ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yearOfCreation rdf:type rdf:Property ;
    rdfs:label 'Year Of Creation' ;
    rdfs:comment 'The year in which the work was created or fixed in tangible form. Critical for determining copyright duration and term calculations.' ;
    rdfs:domain ind:Copyright ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:yearOfFirstPublication rdf:type rdf:Property ;
    rdfs:label 'Year Of First Publication' ;
    rdfs:comment 'The year in which the work was first published or made available to the public. Affects copyright duration and registration requirements.' ;
    rdfs:domain ind:Copyright ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentOrganisationId rdf:type rdf:Property ;
    rdfs:label 'Parent Organisation Id' ;
    rdfs:comment 'Reference to the parent organisation if this entity is part of a corporate group or holding structure. Enables hierarchical relationship tracking for conflict checking and consolidated billing.' ;
    rdfs:domain ind:Client ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Organisation .

ind:primaryUltimateParentOrganisationId rdf:type rdf:Property ;
    rdfs:label 'Primary Ultimate Parent Organisation Id' ;
    rdfs:comment 'Reference to the ultimate parent or holding company at the top of the corporate hierarchy. Used for group-level conflict checking and relationship management.' ;
    rdfs:domain ind:Organisation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Organisation .

ind:segmentId rdf:type rdf:Property ;
    rdfs:label 'Segment Id' ;
    rdfs:comment 'Foreign key linking to client.segment. Business justification: The organisation table currently has a denormalized client_segment STRING column. Corporate/institutional clients are subject to the firm\'s client segmentation taxonomy defined in the segment table. T' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:amlRiskTier rdf:type rdf:Property ;
    rdfs:label 'Aml Risk Tier' ;
    rdfs:comment 'The risk tier assigned to the organisation based on AML risk assessment. Determines the level of due diligence and monitoring required under AML regulations.' ;
    rdfs:domain ind:Organisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualRevenueRange rdf:type rdf:Property ;
    rdfs:label 'Annual Revenue Range' ;
    rdfs:comment 'The approximate annual revenue of the organisation. Used for client segmentation, pricing strategy, and relationship management. [ENUM-REF-CANDIDATE: under_1m|1m_10m|10m_50m|50m_100m|100m_500m|500m_1b|1b_plus — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Organisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingAddressSameAsRegistered rdf:type rdf:Property ;
    rdfs:label 'Billing Address Same As Registered' ;
    rdfs:comment 'Indicates whether the billing address is the same as the registered address. If true, billing address fields may be omitted.' ;
    rdfs:domain ind:Organisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditLimit rdf:type rdf:Property ;
    rdfs:label 'Credit Limit' ;
    rdfs:comment 'The maximum credit limit approved for the organisation for work in progress (WIP) and outstanding accounts receivable. Used for credit risk management and billing controls.' ;
    rdfs:domain ind:Organisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dunsNumber rdf:type rdf:Property ;
    rdfs:label 'Duns Number' ;
    rdfs:comment 'The 9-digit DUNS number issued by Dun & Bradstreet for business identification and credit reporting purposes.' ;
    rdfs:domain ind:Organisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeCountRange rdf:type rdf:Property ;
    rdfs:label 'Employee Count Range' ;
    rdfs:comment 'The approximate size of the organisation by employee count. Used for client segmentation and matter scoping. [ENUM-REF-CANDIDATE: 1_10|11_50|51_200|201_500|501_1000|1001_5000|5001_plus — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Organisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entityType rdf:type rdf:Property ;
    rdfs:label 'Entity Type' ;
    rdfs:comment 'The legal structure or type of the organisation. Indicates whether the entity is a corporation, partnership, LLC, government agency, NGO, or other legal form.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industrySector rdf:type rdf:Property ;
    rdfs:label 'Industry Sector' ;
    rdfs:comment 'The primary industry sector in which the organisation operates. Used for conflict checking, sector-specific regulatory compliance, and business development segmentation.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isUltimateBeneficialOwner rdf:type rdf:Property ;
    rdfs:label 'Is Ultimate Beneficial Owner' ;
    rdfs:comment 'Indicates whether this organisation is identified as an ultimate beneficial owner in the corporate ownership structure. Critical for AML and KYC compliance.' ;
    rdfs:domain ind:Organisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jurisdictionOfIncorporation rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Of Incorporation' ;
    rdfs:comment 'The legal jurisdiction or country where the organisation is incorporated or registered. Use ISO 3166-1 alpha-3 country codes (e.g., USA, GBR, DEU).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kycCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Kyc Completion Date' ;
    rdfs:comment 'The date on which the KYC verification process was completed and approved. Used to track KYC refresh requirements and compliance deadlines.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:kycNextReviewDate rdf:type rdf:Property ;
    rdfs:label 'Kyc Next Review Date' ;
    rdfs:comment 'The scheduled date for the next periodic KYC review. KYC reviews must be refreshed periodically based on risk tier and regulatory requirements.' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:kycStatus rdf:type rdf:Property ;
    rdfs:label 'Kyc Status' ;
    rdfs:comment 'The current status of the KYC verification process for the organisation. Indicates whether the client has passed due diligence checks required for engagement.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalName rdf:type rdf:Property ;
    rdfs:label 'Legal Name' ;
    rdfs:comment 'The full legal name of the organisation as registered with the governing jurisdiction. This is the official name used in all legal documents, contracts, and regulatory filings.' ;
    rdfs:domain ind:Organisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leiCode rdf:type rdf:Property ;
    rdfs:label 'Lei Code' ;
    rdfs:comment 'The 20-character Legal Entity Identifier issued by the Global Legal Entity Identifier Foundation (GLEIF). Used for regulatory reporting and entity identification in financial transactions.' ;
    rdfs:domain ind:Organisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:naicsCode rdf:type rdf:Property ;
    rdfs:label 'Naics Code' ;
    rdfs:comment 'The NAICS code that categorizes the organisations primary business activity for North American jurisdictions. Used for regulatory reporting and industry benchmarking.' ;
    rdfs:domain ind:Organisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Email' ;
    rdfs:comment 'The primary email address for official communications with the organisation. Used for engagement letters, billing notifications, and matter correspondence.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Phone' ;
    rdfs:comment 'The primary telephone number for contacting the organisation. Used for urgent matter communications and client relationship management.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicPrivateStatus rdf:type rdf:Property ;
    rdfs:label 'Public Private Status' ;
    rdfs:comment 'Indicates whether the organisation is publicly traded, privately held, a government entity, or a non-profit organisation. Affects disclosure requirements and conflict checking rules.' ;
    rdfs:domain ind:Organisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Registered Address Line1' ;
    rdfs:comment 'The first line of the organisations registered or legal address as filed with the incorporation authority. Used for legal correspondence and service of process.' ;
    rdfs:domain ind:Organisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Registered Address Line2' ;
    rdfs:comment 'The second line of the organisations registered address, if applicable. Used for suite numbers, building names, or additional address details.' ;
    rdfs:domain ind:Organisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredCity rdf:type rdf:Property ;
    rdfs:label 'Registered City' ;
    rdfs:comment 'The city or locality of the organisations registered address.' ;
    rdfs:domain ind:Organisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredCountry rdf:type rdf:Property ;
    rdfs:label 'Registered Country' ;
    rdfs:comment 'The country of the organisations registered address. Use ISO 3166-1 alpha-3 country codes (e.g., USA, GBR, DEU).' ;
    rdfs:domain ind:Organisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredPostalCode rdf:type rdf:Property ;
    rdfs:label 'Registered Postal Code' ;
    rdfs:comment 'The postal or ZIP code of the organisations registered address.' ;
    rdfs:domain ind:Organisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredStateProvince rdf:type rdf:Property ;
    rdfs:label 'Registered State Province' ;
    rdfs:comment 'The state, province, or region of the organisations registered address. Use standard postal abbreviations where applicable.' ;
    rdfs:domain ind:Organisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipInceptionDate rdf:type rdf:Property ;
    rdfs:label 'Relationship Inception Date' ;
    rdfs:comment 'The date on which the organisation first became a client of the firm. Used for relationship tenure analysis and client lifetime value calculations.' ;
    rdfs:domain ind:Organisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:relationshipStatus rdf:type rdf:Property ;
    rdfs:label 'Relationship Status' ;
    rdfs:comment 'The current status of the client relationship. Indicates whether the organisation is an active client, prospective client, or former client.' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sanctionsScreeningDate rdf:type rdf:Property ;
    rdfs:label 'Sanctions Screening Date' ;
    rdfs:comment 'The date on which the most recent sanctions screening was performed. Sanctions screening must be performed at onboarding and periodically thereafter.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sanctionsScreeningStatus rdf:type rdf:Property ;
    rdfs:label 'Sanctions Screening Status' ;
    rdfs:comment 'The result of sanctions list screening against OFAC, UN, EU, and other sanctions lists. Indicates whether the organisation is clear to engage or requires further review.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sicCode rdf:type rdf:Property ;
    rdfs:label 'Sic Code' ;
    rdfs:comment 'The Standard Industrial Classification code that categorizes the organisations primary business activity. Used for regulatory reporting and industry analysis.' ;
    rdfs:domain ind:Organisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockExchange rdf:type rdf:Property ;
    rdfs:label 'Stock Exchange' ;
    rdfs:comment 'The stock exchange where the organisation is listed, if publicly traded. Examples include NYSE, NASDAQ, LSE, or equivalent. Null for private entities.' ;
    rdfs:domain ind:Organisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxIdentificationNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Identification Number' ;
    rdfs:comment 'The tax identification number assigned by the relevant tax authority. Examples include EIN (US), VAT number (EU), or equivalent. Used for billing and tax compliance.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tickerSymbol rdf:type rdf:Property ;
    rdfs:label 'Ticker Symbol' ;
    rdfs:comment 'The ticker or trading symbol for the organisation if publicly listed. Used for market research and conflict checking against securities matters.' ;
    rdfs:domain ind:Organisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradingName rdf:type rdf:Property ;
    rdfs:label 'Trading Name' ;
    rdfs:comment 'The commercial or trading name under which the organisation operates, if different from the legal name. Also known as DBA (Doing Business As) name.' ;
    rdfs:domain ind:Organisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vatRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Vat Registration Number' ;
    rdfs:comment 'The VAT registration number for organisations operating in VAT jurisdictions. Required for invoicing and tax compliance in EU and other VAT regions.' ;
    rdfs:domain ind:Organisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:websiteUrl rdf:type rdf:Property ;
    rdfs:label 'Website Url' ;
    rdfs:comment 'The primary website URL for the organisation. Used for research, business development, and client profile enrichment.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:individualId rdf:type rdf:Property ;
    rdfs:label 'Individual Id' ;
    rdfs:comment 'Unique identifier for the individual client record. Primary key for natural-person clients including B2C clients, sole traders, high-net-worth individuals, and personal-capacity contacts.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Individual .

ind:clientSinceDate rdf:type rdf:Property ;
    rdfs:label 'Client Since Date' ;
    rdfs:comment 'The date when this individual first became a client of the firm. Used for client tenure analysis, relationship lifecycle tracking, and client retention metrics.' ;
    rdfs:domain ind:Individual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clientStatus rdf:type rdf:Property ;
    rdfs:label 'Client Status' ;
    rdfs:comment 'The current lifecycle status of the individual client. Values: active (current client with open matters), inactive (no current matters but relationship maintained), prospective (potential client), former (relationship ended), suspended (temporarily restricted).' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationPreference rdf:type rdf:Property ;
    rdfs:label 'Communication Preference' ;
    rdfs:comment 'The individual\'s preferred method of communication for non-urgent matters (email, phone, mail, client portal, SMS). Used to optimize client experience and engagement effectiveness.' ;
    rdfs:domain ind:Individual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conflictCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Conflict Check Status' ;
    rdfs:comment 'The current status of conflict checking for this individual. Values: cleared (no conflicts identified), conflict_identified (potential conflict detected), waived (conflict waived by client), pending (conflict check in progress). Required before engagement acceptance.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfDomicile rdf:type rdf:Property ;
    rdfs:label 'Country Of Domicile' ;
    rdfs:comment 'The country where the individual is legally domiciled, represented as a 3-letter ISO country code. Determines applicable jurisdiction for tax, estate planning, and regulatory compliance matters.' ;
    rdfs:domain ind:Individual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditStatus rdf:type rdf:Property ;
    rdfs:label 'Credit Status' ;
    rdfs:comment 'The credit standing of the individual client for billing and payment purposes. Values: approved (standard credit terms), restricted (prepayment or retainer required), hold (no new work until payment received), review_required (credit review pending).' ;
    rdfs:domain ind:Individual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataRetentionCategory rdf:type rdf:Property ;
    rdfs:label 'Data Retention Category' ;
    rdfs:comment 'The data retention classification for this individual\'s records. Values: standard (default retention period), extended (longer retention for regulatory reasons), litigation_hold (preservation order in effect), permanent (indefinite retention required). Drives records management and information governance policies.' ;
    rdfs:domain ind:Individual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dateOfBirth rdf:type rdf:Property ;
    rdfs:label 'Date Of Birth' ;
    rdfs:comment 'The individual\'s date of birth in yyyy-MM-dd format. Required for identity verification, KYC compliance, and age-restricted legal services (e.g., estate planning, employment law).' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalFirstName rdf:type rdf:Property ;
    rdfs:label 'Legal First Name' ;
    rdfs:comment 'The individual\'s legal first name as it appears on official identification documents. Required for KYC (Know Your Client) and AML (Anti-Money Laundering) compliance.' ;
    rdfs:domain ind:Individual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalLastName rdf:type rdf:Property ;
    rdfs:label 'Legal Last Name' ;
    rdfs:comment 'The individual\'s legal last name (surname/family name) as it appears on official identification documents. Required for KYC and AML compliance.' ;
    rdfs:domain ind:Individual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalMiddleName rdf:type rdf:Property ;
    rdfs:label 'Legal Middle Name' ;
    rdfs:comment 'The individual\'s legal middle name or initial as it appears on official identification documents. May be null if not applicable.' ;
    rdfs:domain ind:Individual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lppStatus rdf:type rdf:Property ;
    rdfs:label 'Lpp Status' ;
    rdfs:comment 'Boolean flag indicating whether communications with this individual are protected by Legal Professional Privilege (LPP) or attorney-client privilege. True if privilege applies. Critical for eDiscovery, document review, and information governance.' ;
    rdfs:domain ind:Individual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketingConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Marketing Consent Flag' ;
    rdfs:comment 'Boolean flag indicating whether the individual has consented to receive marketing communications from the firm. True if consent given. Required for GDPR and CCPA compliance in marketing activities.' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mobilePhone rdf:type rdf:Property ;
    rdfs:label 'Mobile Phone' ;
    rdfs:comment 'The individual\'s mobile phone number. Used for SMS notifications, two-factor authentication, and mobile-first client engagement.' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nationality rdf:type rdf:Property ;
    rdfs:label 'Nationality' ;
    rdfs:comment 'The individual\'s nationality represented as a 3-letter ISO country code (e.g., USA, GBR, CAN). Required for cross-border matters, immigration law, and international arbitration.' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passportNumber rdf:type rdf:Property ;
    rdfs:label 'Passport Number' ;
    rdfs:comment 'The individual\'s passport number. Used for identity verification in cross-border transactions, immigration matters, and international dispute resolution.' ;
    rdfs:domain ind:Individual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pepFlag rdf:type rdf:Property ;
    rdfs:label 'Pep Flag' ;
    rdfs:comment 'Boolean flag indicating whether the individual is a Politically Exposed Person (PEP) as defined by FATF guidelines. True if the individual holds or has held a prominent public function. Triggers enhanced due diligence requirements for AML compliance.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferredLanguage rdf:type rdf:Property ;
    rdfs:label 'Preferred Language' ;
    rdfs:comment 'The individual\'s preferred language for communication, represented as a 2-letter ISO language code (e.g., en, fr, es). Ensures culturally appropriate service delivery and compliance with language access requirements.' ;
    rdfs:domain ind:Individual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredName rdf:type rdf:Property ;
    rdfs:label 'Preferred Name' ;
    rdfs:comment 'The name the individual prefers to be called in day-to-day interactions, which may differ from their legal name. Used for personalized communication and relationship management.' ;
    rdfs:domain ind:Individual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Email' ;
    rdfs:comment 'The individual\'s primary email address for official correspondence and engagement communications. Used for LOE (Letter of Engagement) delivery, billing notifications, and matter updates.' ;
    rdfs:domain ind:Individual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Phone' ;
    rdfs:comment 'The individual\'s primary contact phone number. Used for urgent matter communications, appointment scheduling, and client relationship management.' ;
    rdfs:domain ind:Individual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residentialAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Residential Address Line1' ;
    rdfs:comment 'The first line of the individual\'s residential address (street number and name). Required for service of process, correspondence, and KYC compliance.' ;
    rdfs:domain ind:Individual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residentialAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Residential Address Line2' ;
    rdfs:comment 'The second line of the individual\'s residential address (apartment, suite, or unit number). Optional field for additional address details.' ;
    rdfs:domain ind:Individual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residentialCity rdf:type rdf:Property ;
    rdfs:label 'Residential City' ;
    rdfs:comment 'The city or municipality of the individual\'s residential address. Used for jurisdiction determination and venue selection in litigation matters.' ;
    rdfs:domain ind:Individual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residentialCountry rdf:type rdf:Property ;
    rdfs:label 'Residential Country' ;
    rdfs:comment 'The country of the individual\'s residential address, represented as a 3-letter ISO country code. Used for cross-border matters and international client management.' ;
    rdfs:domain ind:Individual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residentialPostalCode rdf:type rdf:Property ;
    rdfs:label 'Residential Postal Code' ;
    rdfs:comment 'The postal or ZIP code of the individual\'s residential address. Used for mail delivery, geographic segmentation, and jurisdiction mapping.' ;
    rdfs:domain ind:Individual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residentialStateProvince rdf:type rdf:Property ;
    rdfs:label 'Residential State Province' ;
    rdfs:comment 'The state, province, or region of the individual\'s residential address. Critical for determining applicable state bar jurisdiction and regulatory compliance requirements.' ;
    rdfs:domain ind:Individual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salutation rdf:type rdf:Property ;
    rdfs:label 'Salutation' ;
    rdfs:comment 'Formal title or honorific used when addressing the individual client (e.g., Mr, Ms, Dr, Prof, Hon).' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPracticeAreaId rdf:type rdf:Property ;
    rdfs:label 'Primary Practice Area Id' ;
    rdfs:comment 'Reference to the practice area that represents the majority of work performed for this client (e.g., Corporate, Litigation, Intellectual Property (IP), Employment, Tax).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PracticeArea .

ind:afaEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Afa Eligible Flag' ;
    rdfs:comment 'Indicates whether the client is eligible for or prefers Alternative Fee Arrangements (AFA) such as fixed fees, capped fees, contingency, or blended rates instead of traditional hourly billing.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:amlRiskRating rdf:type rdf:Property ;
    rdfs:label 'Aml Risk Rating' ;
    rdfs:comment 'Risk classification assigned based on Anti-Money Laundering (AML) assessment. High-risk clients require enhanced due diligence; prohibited indicates clients that cannot be accepted due to sanctions or policy restrictions.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientName rdf:type rdf:Property ;
    rdfs:label 'Client Name' ;
    rdfs:comment 'Full legal name of the client entity or individual as registered. For corporate clients, this is the registered business name; for individuals, the full legal name.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientNumber rdf:type rdf:Property ;
    rdfs:label 'Client Number' ;
    rdfs:comment 'Firm-assigned canonical client identifier used across all systems and matters. This is the business key for client identification in Elite 3E and all downstream systems.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientType rdf:type rdf:Property ;
    rdfs:label 'Client Type' ;
    rdfs:comment 'Classification of the client entity type. Corporate includes all business entities; government includes federal, state, and local agencies; individual includes natural persons; prospective includes potential clients undergoing conflict checking.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Amount' ;
    rdfs:comment 'Maximum credit limit approved for this client for Work in Progress (WIP) and outstanding accounts receivable. Used for credit risk management and billing holds.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataProtectionClassification rdf:type rdf:Property ;
    rdfs:label 'Data Protection Classification' ;
    rdfs:comment 'Highest data protection regime applicable to this clients data. General Data Protection Regulation (GDPR) for EU clients; California Consumer Privacy Act (CCPA) for California residents; Health Insurance Portability and Accountability Act (HIPAA) for healthcare; Payment Card Industry Data Security Standard (PCI DSS) for payment data; Sarbanes-Oxley Act (SOX) for public company financial data.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:electronicBillingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Electronic Billing Required Flag' ;
    rdfs:comment 'Indicates whether the client requires electronic billing submission in Legal Electronic Data Exchange Standard (LEDES) format or through a third-party e-billing platform (e.g., Serengeti, CounselLink, Collaborati).' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:firstEngagementDate rdf:type rdf:Property ;
    rdfs:label 'First Engagement Date' ;
    rdfs:comment 'Date of the first matter or engagement opened for this client. Represents the start of the client relationship with the firm.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastMatterDate rdf:type rdf:Property ;
    rdfs:label 'Last Matter Date' ;
    rdfs:comment 'Date of the most recent matter opened or activity recorded for this client. Used to identify dormant client relationships.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:modifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Modified By User' ;
    rdfs:comment 'Username or identifier of the system user who last modified this client profile record. Used for audit trail and change tracking.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outsideCounselGuidelinesFlag rdf:type rdf:Property ;
    rdfs:label 'Outside Counsel Guidelines Flag' ;
    rdfs:comment 'Indicates whether the client has published Outside Counsel Guidelines that govern billing practices, rate restrictions, staffing requirements, and matter management protocols.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferredBillingCurrency rdf:type rdf:Property ;
    rdfs:label 'Preferred Billing Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code representing the clients preferred currency for invoicing and billing (e.g., USD, GBP, EUR, JPY).' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionPolicyYears rdf:type rdf:Property ;
    rdfs:label 'Retention Policy Years' ;
    rdfs:comment 'Number of years that client records and matter files must be retained per firm policy, client agreement, or regulatory requirement. Typically ranges from 7 to 10 years for legal files.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:taxIdentifier rdf:type rdf:Property ;
    rdfs:label 'Tax Identifier' ;
    rdfs:comment 'Tax identification number for the client entity. For US clients, this is the Employer Identification Number (EIN) or Social Security Number (SSN); for international clients, the equivalent national tax identifier. Used for tax reporting and compliance.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataPrivacyRegisterId rdf:type rdf:Property ;
    rdfs:label 'Data Privacy Register Id' ;
    rdfs:comment 'Foreign key linking to compliance.data_privacy_register. Business justification: Contact data processing must be registered under GDPR Article 30. Links contact records to the privacy register entry documenting lawful basis, retention, and data subject rights for client contact in' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DataPrivacyRegister .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line 1' ;
    rdfs:comment 'First line of the contact\'s business address (street number and name).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line 2' ;
    rdfs:comment 'Second line of the contact\'s business address (suite, floor, building name).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:city rdf:type rdf:Property ;
    rdfs:label 'City' ;
    rdfs:comment 'City or municipality of the contact\'s business address.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactRole rdf:type rdf:Property ;
    rdfs:label 'Contact Role' ;
    rdfs:comment 'The functional role this contact serves in the client relationship (e.g., primary contact, billing contact, legal signatory, authorised representative, in-house counsel). A contact may hold multiple roles. [ENUM-REF-CANDIDATE: primary|billing|legal|signatory|authorised_representative|in_house_counsel|compliance_officer|board_member — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactStatus rdf:type rdf:Property ;
    rdfs:label 'Contact Status' ;
    rdfs:comment 'Current lifecycle status of the contact record (active, inactive, suspended, deceased, left organization).' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryCode rdf:type rdf:Property ;
    rdfs:label 'Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code for the contact\'s business address (e.g., USA, GBR, CAN).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:department rdf:type rdf:Property ;
    rdfs:label 'Department' ;
    rdfs:comment 'Business unit or department within the client organization where the contact is employed (e.g., Legal, Compliance, Corporate Affairs).' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:directPhone rdf:type rdf:Property ;
    rdfs:label 'Direct Phone' ;
    rdfs:comment 'Direct dial telephone number for the contact, bypassing switchboard or reception.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:faxNumber rdf:type rdf:Property ;
    rdfs:label 'Fax Number' ;
    rdfs:comment 'Facsimile number for the contact, used for formal document transmission where required.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstName rdf:type rdf:Property ;
    rdfs:label 'First Name' ;
    rdfs:comment 'Given name of the contact person.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fullName rdf:type rdf:Property ;
    rdfs:label 'Full Name' ;
    rdfs:comment 'Complete legal name of the contact person, typically concatenated from first, middle, and last name components.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isActive rdf:type rdf:Property ;
    rdfs:label 'Is Active' ;
    rdfs:comment 'Indicates whether the contact is currently active and available for engagement communications.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isBillingContact rdf:type rdf:Property ;
    rdfs:label 'Is Billing Contact' ;
    rdfs:comment 'Indicates whether this contact is authorized to receive and approve invoices and billing communications.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPep rdf:type rdf:Property ;
    rdfs:label 'Is Pep' ;
    rdfs:comment 'Indicates whether the contact is identified as a Politically Exposed Person (PEP) for Anti-Money Laundering (AML) and Know Your Client (KYC) compliance purposes.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimaryContact rdf:type rdf:Property ;
    rdfs:label 'Is Primary Contact' ;
    rdfs:comment 'Indicates whether this contact is the primary point of contact for the client organization.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSignatory rdf:type rdf:Property ;
    rdfs:label 'Is Signatory' ;
    rdfs:comment 'Indicates whether this contact has authority to sign engagement letters, Letter of Engagement (LOE), and other binding agreements on behalf of the client.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobTitle rdf:type rdf:Property ;
    rdfs:label 'Job Title' ;
    rdfs:comment 'Professional position or role title held by the contact within their organization (e.g., General Counsel (GC), Chief Legal Officer (CLO), Legal Director, In-House Counsel).' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kycVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Kyc Verification Date' ;
    rdfs:comment 'Date when Know Your Client (KYC) verification was completed for this contact.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:kycVerificationStatus rdf:type rdf:Property ;
    rdfs:label 'Kyc Verification Status' ;
    rdfs:comment 'Status of Know Your Client (KYC) verification for this contact (verified, pending, failed, not required).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languagePreference rdf:type rdf:Property ;
    rdfs:label 'Language Preference' ;
    rdfs:comment 'Two-letter ISO 639-1 language code representing the contact\'s preferred language for communications (e.g., en, fr, es, de).' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastContactDate rdf:type rdf:Property ;
    rdfs:label 'Last Contact Date' ;
    rdfs:comment 'Date of the most recent communication or interaction with this contact.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastName rdf:type rdf:Property ;
    rdfs:label 'Last Name' ;
    rdfs:comment 'Family name or surname of the contact person.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkedinProfileUrl rdf:type rdf:Property ;
    rdfs:label 'Linkedin Profile Url' ;
    rdfs:comment 'URL to the contact\'s professional LinkedIn profile, used for relationship intelligence and business development.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:middleName rdf:type rdf:Property ;
    rdfs:label 'Middle Name' ;
    rdfs:comment 'Middle name or initial of the contact person.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:officePhone rdf:type rdf:Property ;
    rdfs:label 'Office Phone' ;
    rdfs:comment 'Main office telephone number for the contact, may route through switchboard.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postalCode rdf:type rdf:Property ;
    rdfs:label 'Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the contact\'s business address.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredCommunicationChannel rdf:type rdf:Property ;
    rdfs:label 'Preferred Communication Channel' ;
    rdfs:comment 'The contact\'s preferred method of communication for matter updates and correspondence.' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:professionalProfileUrl rdf:type rdf:Property ;
    rdfs:label 'Professional Profile Url' ;
    rdfs:comment 'URL to the contact\'s professional profile on other platforms (e.g., company website, professional directory).' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatoryAuthorityLevel rdf:type rdf:Property ;
    rdfs:label 'Signatory Authority Level' ;
    rdfs:comment 'The level of signing authority the contact holds (unlimited, limited to specific matter types, threshold-based on value, or none).' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateProvince rdf:type rdf:Property ;
    rdfs:label 'State Province' ;
    rdfs:comment 'State, province, or region of the contact\'s business address.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeZone rdf:type rdf:Property ;
    rdfs:label 'Time Zone' ;
    rdfs:comment 'IANA time zone identifier for the contact\'s location (e.g., America/New_York, Europe/London), used for scheduling meetings and calls.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressId rdf:type rdf:Property ;
    rdfs:label 'Address Id' ;
    rdfs:comment 'Unique identifier for the address record. Primary key.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:addressStatus rdf:type rdf:Property ;
    rdfs:label 'Address Status' ;
    rdfs:comment 'Current lifecycle status of the address record. Active indicates currently in use; inactive indicates no longer used but retained for history; pending indicates awaiting validation or approval; historical indicates archived for compliance retention.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressType rdf:type rdf:Property ;
    rdfs:label 'Address Type' ;
    rdfs:comment 'Classification of the address purpose. Registered office is the legal domicile; principal place of business is operational headquarters; billing is for invoicing; correspondence is for general mail; service of process is for legal notice delivery; branch office is for subsidiary locations.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientProfileFk rdf:type rdf:Property ;
    rdfs:label 'Client Profile Fk' ;
    rdfs:comment 'FK to client.client_profile.client_profile_id — Addresses are associated with client profiles for billing, correspondence, and service of process. This is the primary address-to-client association needed for invoice generation and regulatory corres' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isBillingAddress rdf:type rdf:Property ;
    rdfs:label 'Is Billing Address' ;
    rdfs:comment 'Boolean flag indicating whether this address is used for billing and invoicing purposes. True indicates billing address; false indicates non-billing. Critical for invoice delivery and accounts receivable (AR) processing.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimary rdf:type rdf:Property ;
    rdfs:label 'Is Primary' ;
    rdfs:comment 'Boolean flag indicating whether this is the primary address for the client. True indicates primary; false indicates secondary/alternate. Only one address per client per address type should be primary at any given time.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isServiceOfProcessAddress rdf:type rdf:Property ;
    rdfs:label 'Is Service Of Process Address' ;
    rdfs:comment 'Boolean flag indicating whether this address is designated for legal service of process. True indicates service address; false indicates non-service. Critical for litigation, court filings, and regulatory notice delivery. Must maintain historical accuracy for legal compliance.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:latitude rdf:type rdf:Property ;
    rdfs:label 'Latitude' ;
    rdfs:comment 'Geographic latitude coordinate in decimal degrees. Used for geospatial analytics, proximity searches, and location-based reporting. Range: -90.0000000 to +90.0000000.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:line1 rdf:type rdf:Property ;
    rdfs:label 'Line 1' ;
    rdfs:comment 'Primary address line containing street number, street name, and building identifier. Required for all address types. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:line2 rdf:type rdf:Property ;
    rdfs:label 'Line 2' ;
    rdfs:comment 'Secondary address line for suite, floor, apartment, or unit number. Optional field for additional location detail. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:line3 rdf:type rdf:Property ;
    rdfs:label 'Line 3' ;
    rdfs:comment 'Tertiary address line for additional location details such as building name, complex, or district. Optional field. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:longitude rdf:type rdf:Property ;
    rdfs:label 'Longitude' ;
    rdfs:comment 'Geographic longitude coordinate in decimal degrees. Used for geospatial analytics, proximity searches, and location-based reporting. Range: -180.0000000 to +180.0000000.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postalValidationStatus rdf:type rdf:Property ;
    rdfs:label 'Postal Validation Status' ;
    rdfs:comment 'Indicates whether the address has been validated against postal authority databases. Validated addresses ensure accurate service of process and billing delivery. Pending validation indicates address awaiting verification; invalid indicates failed validation.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toClientProfile rdf:type rdf:Property ;
    rdfs:label 'To Client Profile' ;
    rdfs:comment 'FK to client.client_profile.client_profile_id — Addresses resolve to client profiles for billing, correspondence, and service of process' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:validationDate rdf:type rdf:Property ;
    rdfs:label 'Validation Date' ;
    rdfs:comment 'Date when the address was last validated against postal authority databases. Supports audit trail for service of process accuracy and regulatory compliance.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:corporateHierarchyId rdf:type rdf:Property ;
    rdfs:label 'Corporate Hierarchy Id' ;
    rdfs:comment 'Unique identifier for the corporate hierarchy relationship record. Primary key for the corporate hierarchy entity.' ;
    rdfs:domain ind:CorporateHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:childClientClientProfileId rdf:type rdf:Property ;
    rdfs:label 'Child Client Client Profile Id' ;
    rdfs:comment 'Identifier of the child organization in the corporate hierarchy relationship. References the subsidiary, affiliate, or controlled entity in the corporate family tree.' ;
    rdfs:domain ind:CorporateHierarchy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Profile .

ind:childOrganisationId rdf:type rdf:Property ;
    rdfs:label 'Child Organisation Id' ;
    rdfs:comment 'FK to client.organisation.organisation_id — Corporate hierarchy records must reference the child organisation. Both ends of the parent-child relationship must be FK-constrained to organisation.' ;
    rdfs:domain ind:CorporateHierarchy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Organisation .

ind:primaryCorporateOrganisationId rdf:type rdf:Property ;
    rdfs:label 'Primary Corporate Organisation Id' ;
    rdfs:comment 'FK to client.organisation.organisation_id — Corporate hierarchy records must reference the parent organisation. This is definitional — the hierarchy IS the parent-child relationship between organisations.' ;
    rdfs:domain ind:CorporateHierarchy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Organisation .

ind:primaryCorporateProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Corporate Profile Id' ;
    rdfs:comment 'Identifier of the parent organization in the corporate hierarchy relationship. References the controlling or owning entity in the corporate family tree.' ;
    rdfs:domain ind:CorporateHierarchy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Profile .

ind:amlScreeningDate rdf:type rdf:Property ;
    rdfs:label 'Aml Screening Date' ;
    rdfs:comment 'Date when the most recent AML (Anti-Money Laundering) screening was performed for the corporate hierarchy relationship. Used to track compliance with periodic screening requirements.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:amlScreeningStatus rdf:type rdf:Property ;
    rdfs:label 'Aml Screening Status' ;
    rdfs:comment 'Status of AML (Anti-Money Laundering) screening for the corporate hierarchy relationship. Indicates whether the relationship has been screened against sanctions lists and watchlists and the outcome of that screening.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingConsolidationType rdf:type rdf:Property ;
    rdfs:label 'Billing Consolidation Type' ;
    rdfs:comment 'Classification of how billing should be handled for matters involving entities in this corporate hierarchy relationship. Determines whether invoices are consolidated at the parent level or issued separately.' ;
    rdfs:domain ind:CorporateHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conflictCheckScope rdf:type rdf:Property ;
    rdfs:label 'Conflict Check Scope' ;
    rdfs:comment 'Indicator of whether this corporate hierarchy relationship should be automatically included in conflict-of-interest checks. Defines the scope of conflict analysis for engagement acceptance decisions.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationFlag rdf:type rdf:Property ;
    rdfs:label 'Consolidation Flag' ;
    rdfs:comment 'Boolean indicator of whether the child entity should be consolidated with the parent for billing, reporting, or conflict-checking purposes. True indicates consolidation is required; False indicates separate treatment. Used for group-level billing arrangements and consolidated conflict analysis.' ;
    rdfs:domain ind:CorporateHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:controlIndicator rdf:type rdf:Property ;
    rdfs:label 'Control Indicator' ;
    rdfs:comment 'Boolean flag indicating whether the parent organization exercises operational or strategic control over the child organization, regardless of ownership percentage. True indicates control exists; False indicates no control. Critical for conflict-of-interest determinations under ABA (American Bar Association) rules.' ;
    rdfs:domain ind:CorporateHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:createdByUser rdf:type rdf:Property ;
    rdfs:label 'Created By User' ;
    rdfs:comment 'Username or identifier of the user who created the corporate hierarchy relationship record. Supports audit trail and accountability for data entry.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataQualityScore rdf:type rdf:Property ;
    rdfs:label 'Data Quality Score' ;
    rdfs:comment 'Numeric score (0.00 to 1.00) representing the assessed quality and completeness of the corporate hierarchy relationship data. Higher scores indicate more complete and verified data. Used for data governance and prioritizing data improvement efforts.' ;
    rdfs:domain ind:CorporateHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:kycRiskRating rdf:type rdf:Property ;
    rdfs:label 'Kyc Risk Rating' ;
    rdfs:comment 'Risk rating assigned to the corporate hierarchy relationship based on KYC (Know Your Client) and AML (Anti-Money Laundering) assessment. Reflects the compliance risk associated with the relationship structure.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipPercentage rdf:type rdf:Property ;
    rdfs:label 'Ownership Percentage' ;
    rdfs:comment 'Percentage of ownership or equity stake that the parent organization holds in the child organization. Expressed as a decimal percentage (0.00 to 100.00). Used for conflict checking, consolidation decisions, and understanding control relationships.' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:publicDisclosureFlag rdf:type rdf:Property ;
    rdfs:label 'Public Disclosure Flag' ;
    rdfs:comment 'Boolean indicator of whether the corporate hierarchy relationship is publicly disclosed through regulatory filings, annual reports, or other public sources. True indicates public disclosure; False indicates private or undisclosed relationship.' ;
    rdfs:domain ind:CorporateHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryFilingReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Reference' ;
    rdfs:comment 'Reference number or identifier of the regulatory filing or public document that discloses or evidences the corporate hierarchy relationship. Used for verification and audit purposes.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipDescription rdf:type rdf:Property ;
    rdfs:label 'Relationship Description' ;
    rdfs:comment 'Free-text description providing additional context or details about the corporate hierarchy relationship. May include information about the nature of the business relationship, special circumstances, or relevant background for conflict analysis.' ;
    rdfs:domain ind:CorporateHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipSource rdf:type rdf:Property ;
    rdfs:label 'Relationship Source' ;
    rdfs:comment 'Source or origin of the corporate hierarchy relationship information. Indicates how the relationship was identified and documented. Used for data quality assessment and audit trail purposes.' ;
    rdfs:domain ind:CorporateHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipType rdf:type rdf:Property ;
    rdfs:label 'Relationship Type' ;
    rdfs:comment 'Classification of the corporate relationship between parent and child entities. Defines the nature of control, ownership, or affiliation. Critical for conflict-of-interest analysis and engagement scope determination.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyId rdf:type rdf:Property ;
    rdfs:label 'Policy Id' ;
    rdfs:comment 'Foreign key linking to compliance.policy. Business justification: KYC records are conducted under firm compliance policies (e.g. Client Acceptance Policy, AML Policy). Linking kyc_record to the governing compliance policy supports audit trails showing which policy v' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Policy .

ind:adverseMediaScreeningDate rdf:type rdf:Property ;
    rdfs:label 'Adverse Media Screening Date' ;
    rdfs:comment 'Date on which the most recent adverse media screening was performed.' ;
    rdfs:domain ind:KycRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:adverseMediaScreeningResult rdf:type rdf:Property ;
    rdfs:label 'Adverse Media Screening Result' ;
    rdfs:comment 'Outcome of screening for negative news or adverse media coverage related to the client, including fraud, corruption, or financial crime allegations.' ;
    rdfs:domain ind:KycRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficialOwnershipRegisterReference rdf:type rdf:Property ;
    rdfs:label 'Beneficial Ownership Register Reference' ;
    rdfs:comment 'Reference number or document identifier for the beneficial ownership register or declaration submitted by the client.' ;
    rdfs:domain ind:KycRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficialOwnershipVerified rdf:type rdf:Property ;
    rdfs:label 'Beneficial Ownership Verified' ;
    rdfs:comment 'Indicates whether the ultimate beneficial owners (UBOs) of the client entity have been identified and verified, as required for corporate clients.' ;
    rdfs:domain ind:KycRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:businessNatureDescription rdf:type rdf:Property ;
    rdfs:label 'Business Nature Description' ;
    rdfs:comment 'Description of the client\'s business activities, industry sector, and commercial purpose. Used to assess inherent AML risk.' ;
    rdfs:domain ind:KycRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceNotes rdf:type rdf:Property ;
    rdfs:label 'Compliance Notes' ;
    rdfs:comment 'Free-text notes recorded by the compliance officer during the KYC review, including rationale for risk rating, escalation decisions, or special considerations. Business-confidential.' ;
    rdfs:domain ind:KycRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedTransactionVolume rdf:type rdf:Property ;
    rdfs:label 'Expected Transaction Volume' ;
    rdfs:comment 'Anticipated volume of legal services or financial transactions the client will conduct with the firm. Used for ongoing monitoring and anomaly detection.' ;
    rdfs:domain ind:KycRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:highRiskJurisdictionFlag rdf:type rdf:Property ;
    rdfs:label 'High Risk Jurisdiction Flag' ;
    rdfs:comment 'Indicates whether the client is incorporated in or operates from a jurisdiction identified by FATF or other bodies as high-risk for money laundering or terrorist financing.' ;
    rdfs:domain ind:KycRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kycApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Kyc Approval Date' ;
    rdfs:comment 'Date on which the KYC dossier was approved by the compliance officer or designated authority, authorizing client onboarding.' ;
    rdfs:domain ind:KycRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:kycDocumentCount rdf:type rdf:Property ;
    rdfs:label 'Kyc Document Count' ;
    rdfs:comment 'Total number of supporting documents attached to this KYC dossier (certificates, passports, utility bills, etc.). Tracked in child document lines.' ;
    rdfs:domain ind:KycRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:kycExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Kyc Expiry Date' ;
    rdfs:comment 'Date on which the KYC dossier expires and must be refreshed. Typically 1-3 years from approval date depending on risk tier.' ;
    rdfs:domain ind:KycRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:kycReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Kyc Reference Number' ;
    rdfs:comment 'Externally-visible business identifier for the KYC dossier, used in compliance reporting and audit trails.' ;
    rdfs:domain ind:KycRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kycReviewDate rdf:type rdf:Property ;
    rdfs:label 'Kyc Review Date' ;
    rdfs:comment 'Date on which the KYC review assessment was conducted or last updated. Principal business event timestamp for the dossier.' ;
    rdfs:domain ind:KycRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:kycTier rdf:type rdf:Property ;
    rdfs:label 'Kyc Tier' ;
    rdfs:comment 'Level of due diligence applied: standard (normal risk), enhanced (high risk or PEP), simplified (low risk). Determines depth of verification required.' ;
    rdfs:domain ind:KycRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedBy rdf:type rdf:Property ;
    rdfs:label 'Last Modified By' ;
    rdfs:comment 'User ID or name of the person who last modified the KYC record. Audit trail for accountability.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextReviewDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Review Due Date' ;
    rdfs:comment 'Scheduled date for the next periodic KYC review. Triggers compliance workflow to refresh documentation and re-assess risk.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pepScreeningDate rdf:type rdf:Property ;
    rdfs:label 'Pep Screening Date' ;
    rdfs:comment 'Date on which the most recent PEP screening was performed. Must be refreshed periodically per firm policy.' ;
    rdfs:domain ind:KycRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pepScreeningResult rdf:type rdf:Property ;
    rdfs:label 'Pep Screening Result' ;
    rdfs:comment 'Outcome of screening to determine if the client or beneficial owners are politically exposed persons (PEPs), requiring enhanced due diligence.' ;
    rdfs:domain ind:KycRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewerName rdf:type rdf:Property ;
    rdfs:label 'Reviewer Name' ;
    rdfs:comment 'Full name of the compliance officer or partner who conducted the KYC review, for audit trail and accountability.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sanctionsScreeningResult rdf:type rdf:Property ;
    rdfs:label 'Sanctions Screening Result' ;
    rdfs:comment 'Outcome of screening the client and beneficial owners against international sanctions lists (OFAC, UN, EU, etc.). Match found requires escalation.' ;
    rdfs:domain ind:KycRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceOfFundsDescription rdf:type rdf:Property ;
    rdfs:label 'Source Of Funds Description' ;
    rdfs:comment 'Narrative description of the client\'s source of funds (e.g., salary, business income, inheritance, investment returns). Business-confidential information.' ;
    rdfs:domain ind:KycRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceOfFundsVerified rdf:type rdf:Property ;
    rdfs:label 'Source Of Funds Verified' ;
    rdfs:comment 'Indicates whether the origin of the client\'s funds has been verified and documented in accordance with AML requirements.' ;
    rdfs:domain ind:KycRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:versionNumber rdf:type rdf:Property ;
    rdfs:label 'Version Number' ;
    rdfs:comment 'Version number of the KYC dossier. Incremented with each refresh or material update. Supports regulatory audit trail.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicablePracticeAreas rdf:type rdf:Property ;
    rdfs:label 'Applicable Practice Areas' ;
    rdfs:comment 'Comma-separated list of practice area codes where this segment is applicable (e.g., CORP, LIT, IP, TAX, EMPLOY). Used to filter segment options during matter intake based on practice area. Null or ALL indicates segment applies to all practice areas.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedBdTeam rdf:type rdf:Property ;
    rdfs:label 'Assigned Bd Team' ;
    rdfs:comment 'Name or identifier of the BD team responsible for relationship management, pipeline development, and client acquisition for this segment. Used in Microsoft Dynamics 365 CRM for lead routing and opportunity assignment.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientCount rdf:type rdf:Property ;
    rdfs:label 'Client Count' ;
    rdfs:comment 'Current number of active clients assigned to this segment. Updated periodically during segment review cycles. Used for segment size analysis and resource planning.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:conflictCheckIntensity rdf:type rdf:Property ;
    rdfs:label 'Conflict Check Intensity' ;
    rdfs:comment 'Level of conflict checking rigor required for clients in this segment. Standard for routine matters, Enhanced for complex corporate transactions, Comprehensive for high-profile litigation or M&A. Drives Intapp Conflicts search scope and review requirements.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossSellPriority rdf:type rdf:Property ;
    rdfs:label 'Cross Sell Priority' ;
    rdfs:comment 'Priority level for cross-selling additional practice area services to clients in this segment. High priority segments receive proactive cross-sell campaigns and dedicated BD resources. Used in Microsoft Dynamics 365 CRM for opportunity targeting.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountAuthorityLevel rdf:type rdf:Property ;
    rdfs:label 'Discount Authority Level' ;
    rdfs:comment 'Organizational level required to approve discounts beyond the standard discount percentage for this segment. Ensures pricing governance and margin protection aligned with segment strategy.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumRevenueThreshold rdf:type rdf:Property ;
    rdfs:label 'Minimum Revenue Threshold' ;
    rdfs:comment 'Minimum annual revenue threshold (in firm base currency) required for a client to qualify for this segment. Used during client intake and annual segment review processes. Null for segments without revenue criteria (e.g., pro bono, government).' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partnerAttentionRequired rdf:type rdf:Property ;
    rdfs:label 'Partner Attention Required' ;
    rdfs:comment 'Indicates whether clients in this segment require direct partner involvement in all matters. True for strategic segments where partner relationship management is mandatory. Drives matter staffing and partner time allocation.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferredAfaTypes rdf:type rdf:Property ;
    rdfs:label 'Preferred Afa Types' ;
    rdfs:comment 'Comma-separated list of preferred AFA types for this segment (e.g., Fixed Fee, Capped Fee, Success Fee, Blended Rate, Retainer). Guides pricing discussions during engagement setup. Null indicates standard hourly billing preference.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresAmlScreening rdf:type rdf:Property ;
    rdfs:label 'Requires Aml Screening' ;
    rdfs:comment 'Indicates whether clients in this segment require AML sanctions screening and ongoing monitoring. True for segments with elevated financial crime risk. Integrated with Intapp Conflicts for automated screening workflows.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresKycEnhanced rdf:type rdf:Property ;
    rdfs:label 'Requires Kyc Enhanced' ;
    rdfs:comment 'Indicates whether clients in this segment require enhanced KYC due diligence beyond standard intake procedures. True for high-risk segments (e.g., foreign government, high-value transactions). Drives conflict checking and AML screening requirements.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:segmentCode rdf:type rdf:Property ;
    rdfs:label 'Segment Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the segment (e.g., GLOBAL500, MIDMKT, GOVPUB, HNWI, STARTUP). Used as business identifier in Elite 3E rate card selection and Microsoft Dynamics 365 CRM pipeline segmentation.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentDescription rdf:type rdf:Property ;
    rdfs:label 'Segment Description' ;
    rdfs:comment 'Detailed narrative describing the segment characteristics, target client profile, strategic importance, and business rationale for segmentation. Used by BD teams and pricing committees for segment strategy alignment.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentName rdf:type rdf:Property ;
    rdfs:label 'Segment Name' ;
    rdfs:comment 'Full descriptive name of the client segment (e.g., Global 500, Mid-Market Corporate, Government & Public Sector, High Net Worth Individual, Start-up & Emerging Growth). Primary human-readable identifier used across all client-facing and internal reporting.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentStatus rdf:type rdf:Property ;
    rdfs:label 'Segment Status' ;
    rdfs:comment 'Current lifecycle status of the segment. Active segments are used for new client classification and rate card assignment. Inactive segments are retained for historical reporting only. Under review indicates pending partnership approval for changes. Deprecated segments are being phased out.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentTier rdf:type rdf:Property ;
    rdfs:label 'Segment Tier' ;
    rdfs:comment 'Hierarchical tier classification of the segment indicating strategic priority and resource allocation level. Tier 1 represents highest-value segments with dedicated partner attention; Tier 4 represents standard service segments.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaResponseTimeHours rdf:type rdf:Property ;
    rdfs:label 'Sla Response Time Hours' ;
    rdfs:comment 'Maximum hours for initial response to client inquiries for this segment. Used to set client expectations and measure service delivery performance. Tier 1 segments typically have shorter response times (e.g., 4 hours) than lower tiers.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:standardDiscountPercentage rdf:type rdf:Property ;
    rdfs:label 'Standard Discount Percentage' ;
    rdfs:comment 'Standard discount percentage off standard rates approved for this segment. Applied automatically in Elite 3E rate card selection unless matter-specific override is authorized. Null indicates no standard discount.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetClientType rdf:type rdf:Property ;
    rdfs:label 'Target Client Type' ;
    rdfs:comment 'Primary client entity type this segment is designed to serve. Corporate for business entities, Government for public sector agencies, Individual for HNWIs and personal clients, Non-Profit for charitable organizations, Mixed for segments serving multiple types.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetRealizationRate rdf:type rdf:Property ;
    rdfs:label 'Target Realization Rate' ;
    rdfs:comment 'Target realization rate (percentage of standard rates actually billed and collected) for this segment. Used to measure pricing effectiveness and write-off performance. Typically ranges from 85% to 100%.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetRpe rdf:type rdf:Property ;
    rdfs:label 'Target Rpe' ;
    rdfs:comment 'Target annual revenue per equity partner for clients in this segment. Used for segment performance measurement and partner compensation allocation. Null for segments without RPE targets.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:relationshipTeamId rdf:type rdf:Property ;
    rdfs:label 'Relationship Team Id' ;
    rdfs:comment 'Unique identifier for the relationship team assignment record.' ;
    rdfs:domain ind:RelationshipTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignmentEndDate rdf:type rdf:Property ;
    rdfs:label 'Assignment End Date' ;
    rdfs:comment 'The date on which this timekeeper\'s assignment to this relationship team role ended. Null indicates an active assignment.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignmentNotes rdf:type rdf:Property ;
    rdfs:label 'Assignment Notes' ;
    rdfs:comment 'Additional free-text notes or comments regarding this relationship team assignment. May include special instructions, client preferences, or coordination requirements.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentReason rdf:type rdf:Property ;
    rdfs:label 'Assignment Reason' ;
    rdfs:comment 'Free-text explanation of why this timekeeper was assigned to this relationship team role. May reference practice area expertise, industry knowledge, geographic coverage, client preference, or succession planning.' ;
    rdfs:domain ind:RelationshipTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentStartDate rdf:type rdf:Property ;
    rdfs:label 'Assignment Start Date' ;
    rdfs:comment 'The date on which this timekeeper was assigned to this relationship team role for the client.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assignment Status' ;
    rdfs:comment 'Current lifecycle status of this relationship team assignment. Active assignments are operational; Inactive assignments are historical; Suspended assignments are temporarily paused; Pending Approval assignments await partner approval.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingAuthorityLevel rdf:type rdf:Property ;
    rdfs:label 'Billing Authority Level' ;
    rdfs:comment 'Defines the level of billing authority this timekeeper has for matters related to this client. Full Authority can approve invoices independently; Approval Required must escalate; View Only can review but not approve; No Access cannot view billing information.' ;
    rdfs:domain ind:RelationshipTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientContactFrequency rdf:type rdf:Property ;
    rdfs:label 'Client Contact Frequency' ;
    rdfs:comment 'The expected frequency of proactive client contact for this timekeeper in this role. Used in relationship management planning and client engagement tracking.' ;
    rdfs:domain ind:RelationshipTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientSatisfactionResponsibility rdf:type rdf:Property ;
    rdfs:label 'Client Satisfaction Responsibility' ;
    rdfs:comment 'Indicates whether this timekeeper is responsible for monitoring and reporting on client satisfaction metrics for this client. Used in client retention and service quality tracking.' ;
    rdfs:domain ind:RelationshipTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conflictCheckAuthority rdf:type rdf:Property ;
    rdfs:label 'Conflict Check Authority' ;
    rdfs:comment 'Indicates whether this timekeeper has authority to approve conflict check clearances for new matters involving this client. Typically granted to Client Relationship Partners and Supervising Partners.' ;
    rdfs:domain ind:RelationshipTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crossSellTargetFlag rdf:type rdf:Property ;
    rdfs:label 'Cross Sell Target Flag' ;
    rdfs:comment 'Indicates whether this timekeeper has active cross-sell or upsell targets for this client relationship. Used in Business Development (BD) pipeline management and opportunity tracking in Microsoft Dynamics 365.' ;
    rdfs:domain ind:RelationshipTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalationPriority rdf:type rdf:Property ;
    rdfs:label 'Escalation Priority' ;
    rdfs:comment 'Numeric priority order for escalating client issues to this timekeeper. Lower numbers indicate higher priority. Used in automated escalation routing for client service delivery.' ;
    rdfs:domain ind:RelationshipTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:geographicCoverageRegion rdf:type rdf:Property ;
    rdfs:label 'Geographic Coverage Region' ;
    rdfs:comment 'The geographic region or jurisdiction this timekeeper is responsible for covering within the client relationship. Supports multi-jurisdictional client service coordination.' ;
    rdfs:domain ind:RelationshipTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastClientContactDate rdf:type rdf:Property ;
    rdfs:label 'Last Client Contact Date' ;
    rdfs:comment 'The most recent date this timekeeper had documented contact with the client in this relationship role. Used for relationship health monitoring and engagement gap analysis.' ;
    rdfs:domain ind:RelationshipTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextScheduledContactDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Contact Date' ;
    rdfs:comment 'The next planned date for this timekeeper to contact the client in this relationship role. Supports proactive relationship management and follow-up tracking.' ;
    rdfs:domain ind:RelationshipTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notificationPreference rdf:type rdf:Property ;
    rdfs:label 'Notification Preference' ;
    rdfs:comment 'Defines the level of client-related notifications this timekeeper wishes to receive for this assignment. Supports communication workflow automation in Microsoft Dynamics 365.' ;
    rdfs:domain ind:RelationshipTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originationCreditPercentage rdf:type rdf:Property ;
    rdfs:label 'Origination Credit Percentage' ;
    rdfs:comment 'The percentage of origination credit allocated to this timekeeper for this client relationship. Used in Revenue Per Equity Partner (RPE) and Profit Per Partner (PPP) calculations. Sum across all team members for a client should equal 100%.' ;
    rdfs:domain ind:RelationshipTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:relationshipRoleType rdf:type rdf:Property ;
    rdfs:label 'Relationship Role Type' ;
    rdfs:comment 'The specific role this timekeeper plays in the client relationship team. Client Relationship Partner (CRP) is the primary relationship owner; Originating Partner brought the client to the firm; Supervising Partner oversees matter execution; Relationship Manager handles day-to-day coordination; Business Development Manager drives pipeline and cross-sell; Supporting Fee Earner provides specialized expertise.' ;
    rdfs:domain ind:RelationshipTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibilityPercentage rdf:type rdf:Property ;
    rdfs:label 'Responsibility Percentage' ;
    rdfs:comment 'The percentage of relationship responsibility allocated to this timekeeper for ongoing client management and service delivery. Used in partner performance evaluation and compensation allocation.' ;
    rdfs:domain ind:RelationshipTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:successionPlanFlag rdf:type rdf:Property ;
    rdfs:label 'Succession Plan Flag' ;
    rdfs:comment 'Indicates whether this assignment is part of a formal succession plan to transition client relationship ownership. Used in partner retirement planning and relationship continuity management.' ;
    rdfs:domain ind:RelationshipTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:engagementScopeId rdf:type rdf:Property ;
    rdfs:label 'Engagement Scope Id' ;
    rdfs:comment 'Unique identifier for the client-level engagement scope record. Primary key.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EngagementScope .

ind:compliancePolicyId rdf:type rdf:Property ;
    rdfs:label 'Compliance Policy Id' ;
    rdfs:comment 'Foreign key linking to compliance.policy. Business justification: Panel appointments and engagement scopes must comply with firm compliance policies (conflicts, AML, data protection). Links engagement terms to governing policies, ensuring client acceptance criteria ' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Policy .

ind:afaFrameworkType rdf:type rdf:Property ;
    rdfs:label 'Afa Framework Type' ;
    rdfs:comment 'Type of Alternative Fee Arrangement (AFA) framework agreed for this engagement scope. Fixed_fee indicates a flat fee per matter; capped_fee indicates a maximum fee limit; contingency indicates success-based fees; blended_rate indicates a single rate for all timekeepers; hourly indicates traditional time-based billing. [ENUM-REF-CANDIDATE: fixed_fee|capped_fee|contingency|blended_rate|success_fee|retainer|hourly — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:EngagementScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorisedPracticeAreas rdf:type rdf:Property ;
    rdfs:label 'Authorised Practice Areas' ;
    rdfs:comment 'Comma-separated list or structured text describing the practice areas the firm is authorized to provide services in under this scope (e.g., \'Corporate M&A, Employment Law, Intellectual Property\'). Defines the substantive legal domains covered.' ;
    rdfs:domain ind:EngagementScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoRenewalFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Flag' ;
    rdfs:comment 'Boolean flag indicating whether this engagement scope automatically renews upon expiry unless either party provides termination notice. True indicates auto-renewal; false indicates explicit renewal required.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conflictCheckRequired rdf:type rdf:Property ;
    rdfs:label 'Conflict Check Required' ;
    rdfs:comment 'Boolean flag indicating whether a conflict check is required for each new matter opened under this engagement scope. True indicates conflict checks are mandatory; false indicates standing clearance has been granted.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:createdByUserCode rdf:type rdf:Property ;
    rdfs:label 'Created By User Code' ;
    rdfs:comment 'User identifier of the person who created this engagement scope record. Used for audit trail and accountability.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:electronicBillingRequired rdf:type rdf:Property ;
    rdfs:label 'Electronic Billing Required' ;
    rdfs:comment 'Boolean flag indicating whether the client requires electronic billing submission (e.g., LEDES format) for invoices under this engagement scope. True indicates e-billing is mandatory; false indicates paper or PDF invoices are acceptable.' ;
    rdfs:domain ind:EngagementScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:excludedServices rdf:type rdf:Property ;
    rdfs:label 'Excluded Services' ;
    rdfs:comment 'Free-text description of services or practice areas explicitly excluded from this engagement scope. Clarifies boundaries and limitations of the firm\'s authority (e.g., \'Litigation services excluded\', \'No criminal defense work\').' ;
    rdfs:domain ind:EngagementScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprProcessingBasis rdf:type rdf:Property ;
    rdfs:label 'Gdpr Processing Basis' ;
    rdfs:comment 'Legal basis under GDPR Article 6 for processing personal data under this engagement scope. Contract indicates processing is necessary for contract performance; legal_obligation indicates processing is required by law; legitimate_interest indicates processing is necessary for legitimate business interests.' ;
    rdfs:domain ind:EngagementScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicJurisdictionsCovered rdf:type rdf:Property ;
    rdfs:label 'Geographic Jurisdictions Covered' ;
    rdfs:comment 'Comma-separated list of geographic jurisdictions (countries, states, regions) where the firm is authorized to provide services under this scope. Uses ISO 3166-1 alpha-3 country codes where applicable (e.g., \'USA, GBR, DEU\').' ;
    rdfs:domain ind:EngagementScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kycDocumentationStatus rdf:type rdf:Property ;
    rdfs:label 'Kyc Documentation Status' ;
    rdfs:comment 'Status of Know Your Client (KYC) documentation and due diligence for this engagement scope. Complete indicates all required KYC documents are on file and current; expired indicates KYC refresh is needed.' ;
    rdfs:domain ind:EngagementScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matterBudgetApprovalRequired rdf:type rdf:Property ;
    rdfs:label 'Matter Budget Approval Required' ;
    rdfs:comment 'Boolean flag indicating whether the client requires formal budget approval before commencing work on individual matters under this engagement scope. True indicates budgets must be submitted and approved; false indicates no formal budget process.' ;
    rdfs:domain ind:EngagementScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:modifiedByUserCode rdf:type rdf:Property ;
    rdfs:label 'Modified By User Code' ;
    rdfs:comment 'User identifier of the person who last modified this engagement scope record. Used for audit trail and change accountability.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originatingOfficeCode rdf:type rdf:Property ;
    rdfs:label 'Originating Office Code' ;
    rdfs:comment 'Code identifying the firm office that originated this engagement scope and is responsible for client relationship management. Used for revenue allocation and reporting.' ;
    rdfs:domain ind:EngagementScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:panelAppointmentReference rdf:type rdf:Property ;
    rdfs:label 'Panel Appointment Reference' ;
    rdfs:comment 'External reference number or identifier for the panel appointment issued by the client, if this scope is a panel arrangement. Null for non-panel scopes.' ;
    rdfs:domain ind:EngagementScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:panelExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Panel Expiry Date' ;
    rdfs:comment 'Date on which the panel appointment or engagement scope expires. Null for open-ended arrangements. After this date, the firm must seek renewal or new authority.' ;
    rdfs:domain ind:EngagementScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:panelStartDate rdf:type rdf:Property ;
    rdfs:label 'Panel Start Date' ;
    rdfs:comment 'Date on which the panel appointment or engagement scope becomes effective. Marks the beginning of the firm\'s authority to provide services under this scope.' ;
    rdfs:domain ind:EngagementScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preferredCounselDesignation rdf:type rdf:Property ;
    rdfs:label 'Preferred Counsel Designation' ;
    rdfs:comment 'Boolean flag indicating whether the firm has been designated as preferred counsel for the client under this scope. True indicates preferred status; false indicates standard panel or non-preferred status.' ;
    rdfs:domain ind:EngagementScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rateCardReference rdf:type rdf:Property ;
    rdfs:label 'Rate Card Reference' ;
    rdfs:comment 'Reference identifier for the rate card or fee schedule applicable to this engagement scope. Links to the billing rate structure agreed with the client.' ;
    rdfs:domain ind:EngagementScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Notice Days' ;
    rdfs:comment 'Number of days before panel_expiry_date that the firm must provide notice of intent to renew or terminate the engagement scope. Used for proactive relationship management and renewal planning.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:retentionPeriodYears rdf:type rdf:Property ;
    rdfs:label 'Retention Period Years' ;
    rdfs:comment 'Number of years that records and documents related to matters under this engagement scope must be retained after matter closure, per client requirements and regulatory obligations. Typical values range from 6 to 10 years.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scopeApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Scope Approval Date' ;
    rdfs:comment 'Date on which the engagement scope was formally approved by the client and the firm\'s conflicts and risk committees. Represents the date of mutual agreement.' ;
    rdfs:domain ind:EngagementScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scopeName rdf:type rdf:Property ;
    rdfs:label 'Scope Name' ;
    rdfs:comment 'Descriptive name or title for this engagement scope, summarizing the nature of the standing authority (e.g., \'Corporate Legal Panel 2024\', \'Employment Law Retainer\').' ;
    rdfs:domain ind:EngagementScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Scope Reference Number' ;
    rdfs:comment 'Business-facing unique reference number for this engagement scope, used in communications and documentation. Typically alphanumeric code assigned by the firm.' ;
    rdfs:domain ind:EngagementScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeStatus rdf:type rdf:Property ;
    rdfs:label 'Scope Status' ;
    rdfs:comment 'Current lifecycle status of the engagement scope. Active indicates the firm is currently authorized to provide services under this scope; expired indicates the scope has lapsed.' ;
    rdfs:domain ind:EngagementScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeType rdf:type rdf:Property ;
    rdfs:label 'Scope Type' ;
    rdfs:comment 'Classification of the engagement scope arrangement. Panel indicates the firm is on a legal panel; retainer indicates ongoing retained services; framework indicates a master services agreement; ad_hoc indicates project-based authority; preferred_counsel indicates designated counsel status.' ;
    rdfs:domain ind:EngagementScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utbmsTaskCodesRequired rdf:type rdf:Property ;
    rdfs:label 'Utbms Task Codes Required' ;
    rdfs:comment 'Boolean flag indicating whether the client requires Uniform Task-Based Management System (UTBMS) task and activity codes on time entries and invoices under this engagement scope. True indicates UTBMS coding is mandatory.' ;
    rdfs:domain ind:EngagementScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryBeneficialKycRecordId rdf:type rdf:Property ;
    rdfs:label 'Primary Beneficial Kyc Record Id' ;
    rdfs:comment 'Reference to the KYC record under which this beneficial owner was identified and verified.' ;
    rdfs:domain ind:BeneficialOwner ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:KycRecord .

ind:primaryBeneficialOrganisationId rdf:type rdf:Property ;
    rdfs:label 'Primary Beneficial Organisation Id' ;
    rdfs:comment 'Reference to the corporate client entity for which this beneficial ownership is declared. Links to the organisation master data.' ;
    rdfs:domain ind:BeneficialOwner ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Organisation .

ind:toKycRecordId rdf:type rdf:Property ;
    rdfs:label 'To Kyc Record Id' ;
    rdfs:comment 'FK to client.kyc_record.kyc_record_id — Beneficial ownership verification is part of the KYC dossier — linked for audit trail' ;
    rdfs:domain ind:BeneficialOwner ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:KycRecord .

ind:toOrganisationId rdf:type rdf:Property ;
    rdfs:label 'To Organisation Id' ;
    rdfs:comment 'FK to client.organisation.organisation_id — UBOs are recorded against corporate entities for AML compliance' ;
    rdfs:domain ind:BeneficialOwner ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Organisation .

ind:adverseMediaFlag rdf:type rdf:Property ;
    rdfs:label 'Adverse Media Flag' ;
    rdfs:comment 'Indicates whether adverse media or negative news has been identified for this beneficial owner during screening. True if adverse media is present.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:adverseMediaSummary rdf:type rdf:Property ;
    rdfs:label 'Adverse Media Summary' ;
    rdfs:comment 'Summary of adverse media findings, including the nature of the negative news and the source. Populated when adverse_media_flag is true.' ;
    rdfs:domain ind:BeneficialOwner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficialOwnerStatus rdf:type rdf:Property ;
    rdfs:label 'Beneficial Owner Status' ;
    rdfs:comment 'The current status of the beneficial owner record: active (current UBO), inactive (no longer a UBO), under review (verification in progress), rejected (failed verification), or superseded (replaced by updated record).' ;
    rdfs:domain ind:BeneficialOwner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfResidence rdf:type rdf:Property ;
    rdfs:label 'Country Of Residence' ;
    rdfs:comment 'The country where the beneficial owner primarily resides, represented as a 3-letter ISO 3166-1 alpha-3 country code.' ;
    rdfs:domain ind:BeneficialOwner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclosureDate rdf:type rdf:Property ;
    rdfs:label 'Disclosure Date' ;
    rdfs:comment 'The date on which the beneficial owner information was disclosed to the firm by the client organisation. Marks the start of the KYC record for this UBO.' ;
    rdfs:domain ind:BeneficialOwner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastModifiedByUserCode rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User Code' ;
    rdfs:comment 'Reference to the user who last modified this beneficial owner record. Used for audit trail and accountability.' ;
    rdfs:domain ind:BeneficialOwner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:natureOfControl rdf:type rdf:Property ;
    rdfs:label 'Nature Of Control' ;
    rdfs:comment 'The mechanism by which the beneficial owner exercises control over the client organisation: direct shareholding, indirect shareholding through intermediaries, voting rights, power to appoint board members, significant influence, or other means.' ;
    rdfs:domain ind:BeneficialOwner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pepRoleDescription rdf:type rdf:Property ;
    rdfs:label 'Pep Role Description' ;
    rdfs:comment 'Description of the political or public role held by the PEP, or the relationship to the PEP if the beneficial owner is a family member or close associate.' ;
    rdfs:domain ind:BeneficialOwner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pepStatus rdf:type rdf:Property ;
    rdfs:label 'Pep Status' ;
    rdfs:comment 'Indicates whether the beneficial owner is a Politically Exposed Person (PEP), a family member of a PEP, or a close associate of a PEP. PEP status triggers enhanced due diligence requirements.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residentialAddress rdf:type rdf:Property ;
    rdfs:label 'Residential Address' ;
    rdfs:comment 'The full residential address of the beneficial owner, including street, city, postal code, and country. Used for verification and correspondence.' ;
    rdfs:domain ind:BeneficialOwner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Date' ;
    rdfs:comment 'The date on which the risk rating was last assessed or updated. Used to trigger periodic risk re-assessment.' ;
    rdfs:domain ind:BeneficialOwner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:riskRating rdf:type rdf:Property ;
    rdfs:label 'Risk Rating' ;
    rdfs:comment 'The AML/KYC risk rating assigned to this beneficial owner based on PEP status, sanctions screening, adverse media, country risk, and other factors. Determines the level of ongoing monitoring required.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sanctionsListMatch rdf:type rdf:Property ;
    rdfs:label 'Sanctions List Match' ;
    rdfs:comment 'Details of any sanctions list match, including the list name, match score, and reason for the match. Populated when sanctions_status is \'match\' or \'potential_match\'.' ;
    rdfs:domain ind:BeneficialOwner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sanctionsStatus rdf:type rdf:Property ;
    rdfs:label 'Sanctions Status' ;
    rdfs:comment 'Result of sanctions screening against OFAC, UN, EU, and other sanctions lists. Indicates whether the beneficial owner is sanctioned, potentially sanctioned, or clear.' ;
    rdfs:domain ind:BeneficialOwner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceOfFunds rdf:type rdf:Property ;
    rdfs:label 'Source Of Funds' ;
    rdfs:comment 'Description of the origin of the funds used in the specific transaction or relationship with the firm. Distinct from source of wealth; focuses on the immediate source of capital.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceOfWealth rdf:type rdf:Property ;
    rdfs:label 'Source Of Wealth' ;
    rdfs:comment 'Description of the origin of the beneficial owner\'s total wealth, such as inheritance, business ownership, employment, investments, or other sources. Required for enhanced due diligence on high-risk clients.' ;
    rdfs:domain ind:BeneficialOwner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusChangeDate rdf:type rdf:Property ;
    rdfs:label 'Status Change Date' ;
    rdfs:comment 'The date on which the status of the beneficial owner record was last changed. Used for audit trail and lifecycle tracking.' ;
    rdfs:domain ind:BeneficialOwner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:statusChangeReason rdf:type rdf:Property ;
    rdfs:label 'Status Change Reason' ;
    rdfs:comment 'Free-text explanation of the reason for the most recent status change, such as ownership transfer, verification failure, or periodic review outcome.' ;
    rdfs:domain ind:BeneficialOwner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxResidenceCountry rdf:type rdf:Property ;
    rdfs:label 'Tax Residence Country' ;
    rdfs:comment 'The country where the beneficial owner is considered a tax resident, represented as a 3-letter ISO 3166-1 alpha-3 country code. May differ from country of residence.' ;
    rdfs:domain ind:BeneficialOwner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationMethod rdf:type rdf:Property ;
    rdfs:label 'Verification Method' ;
    rdfs:comment 'The method or document type used to verify the identity and ownership of the beneficial owner: passport, national ID, drivers license, utility bill, bank statement, corporate registry extract, third-party database, or other. [ENUM-REF-CANDIDATE: passport|national_id|drivers_license|utility_bill|bank_statement|corporate_registry|third_party_database|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BeneficialOwner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acceptanceDate rdf:type rdf:Property ;
    rdfs:label 'Acceptance Date' ;
    rdfs:comment 'Date on which the firm formally accepted or acknowledged the guideline.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:acceptanceStatus rdf:type rdf:Property ;
    rdfs:label 'Acceptance Status' ;
    rdfs:comment 'Firms acceptance status of the client guideline: accepted (firm agrees to comply), rejected (firm declines engagement under these terms), under review, conditionally accepted (with negotiated exceptions), or not applicable.' ;
    rdfs:domain ind:OutsideCounselGuideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:afaPermitted rdf:type rdf:Property ;
    rdfs:label 'Afa Permitted' ;
    rdfs:comment 'Indicates whether the client permits or encourages alternative fee arrangements (fixed fee, capped fee, contingency, blended rate) as opposed to hourly billing.' ;
    rdfs:domain ind:OutsideCounselGuideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:afaPreference rdf:type rdf:Property ;
    rdfs:label 'Afa Preference' ;
    rdfs:comment 'Description of the clients preferred alternative fee arrangement structures if AFAs are permitted (e.g., fixed fee for transactional work, success fee for litigation).' ;
    rdfs:domain ind:OutsideCounselGuideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingRateCapAssociate rdf:type rdf:Property ;
    rdfs:label 'Billing Rate Cap Associate' ;
    rdfs:comment 'Maximum hourly billing rate permitted for associates under this guideline. Null if no cap specified.' ;
    rdfs:domain ind:OutsideCounselGuideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingRateCapParalegal rdf:type rdf:Property ;
    rdfs:label 'Billing Rate Cap Paralegal' ;
    rdfs:comment 'Maximum hourly billing rate permitted for paralegals under this guideline. Null if no cap specified.' ;
    rdfs:domain ind:OutsideCounselGuideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingRateCapPartner rdf:type rdf:Property ;
    rdfs:label 'Billing Rate Cap Partner' ;
    rdfs:comment 'Maximum hourly billing rate permitted for equity partners under this guideline. Null if no cap specified.' ;
    rdfs:domain ind:OutsideCounselGuideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetApprovalThreshold rdf:type rdf:Property ;
    rdfs:label 'Budget Approval Threshold' ;
    rdfs:comment 'Monetary threshold above which matter budgets or budget overruns require explicit client approval before proceeding.' ;
    rdfs:domain ind:OutsideCounselGuideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetThresholdCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Budget Threshold Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the budget approval threshold.' ;
    rdfs:domain ind:OutsideCounselGuideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataResidencyRequirement rdf:type rdf:Property ;
    rdfs:label 'Data Residency Requirement' ;
    rdfs:comment 'Geographic or jurisdictional data residency requirements imposed by the client (e.g., all matter data must remain within EU, UK-only storage). Null if no restriction.' ;
    rdfs:domain ind:OutsideCounselGuideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diversityReportingRequired rdf:type rdf:Property ;
    rdfs:label 'Diversity Reporting Required' ;
    rdfs:comment 'Indicates whether the client requires periodic diversity and inclusion reporting on matter staffing (e.g., gender, ethnicity, LGBTQ+ representation).' ;
    rdfs:domain ind:OutsideCounselGuideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ebillingPlatformMandate rdf:type rdf:Property ;
    rdfs:label 'Ebilling Platform Mandate' ;
    rdfs:comment 'Name of the e-billing platform the client mandates for invoice submission (e.g., Serengeti Tracker, Legal Tracker, Collaborati, Brightflag). Null if no specific platform required.' ;
    rdfs:domain ind:OutsideCounselGuideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guidelineType rdf:type rdf:Property ;
    rdfs:label 'Guideline Type' ;
    rdfs:comment 'Classification of the guideline: formal outside counsel guideline issued by client, operational service preference, or hybrid combining both.' ;
    rdfs:domain ind:OutsideCounselGuideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceDeliveryEmail rdf:type rdf:Property ;
    rdfs:label 'Invoice Delivery Email' ;
    rdfs:comment 'Email address to which invoices should be sent if email delivery method is specified.' ;
    rdfs:domain ind:OutsideCounselGuideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceDeliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Invoice Delivery Method' ;
    rdfs:comment 'Method by which invoices should be delivered to the client: email, e-billing portal upload, postal mail, or secure file transfer (SFTP).' ;
    rdfs:domain ind:OutsideCounselGuideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matterUpdatePreference rdf:type rdf:Property ;
    rdfs:label 'Matter Update Preference' ;
    rdfs:comment 'Clients preference for how matter updates should be communicated: format, level of detail, and escalation triggers.' ;
    rdfs:domain ind:OutsideCounselGuideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumTimeIncrement rdf:type rdf:Property ;
    rdfs:label 'Minimum Time Increment' ;
    rdfs:comment 'Minimum time increment for billing entries in hours (e.g., 0.10 for 6-minute increments, 0.25 for 15-minute increments). Null if no specific requirement.' ;
    rdfs:domain ind:OutsideCounselGuideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ocgClientProfileFk rdf:type rdf:Property ;
    rdfs:label 'Ocg Client Profile Fk' ;
    rdfs:comment 'FK to client.client_profile.client_profile_id — OCGs govern service delivery per client. Required for billing compliance and staffing decisions.' ;
    rdfs:domain ind:OutsideCounselGuideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ocgToClientProfile rdf:type rdf:Property ;
    rdfs:label 'Ocg To Client Profile' ;
    rdfs:comment 'FK to client.client_profile.client_profile_id — OCGs are issued by clients and govern service delivery — must link to the client they apply to' ;
    rdfs:domain ind:OutsideCounselGuideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:outsideCounselEvaluatorEmail rdf:type rdf:Property ;
    rdfs:label 'Outside Counsel Evaluator Email' ;
    rdfs:comment 'Email address of the client-side outside counsel evaluator for guideline-related inquiries and compliance reporting.' ;
    rdfs:domain ind:OutsideCounselGuideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outsideCounselEvaluatorName rdf:type rdf:Property ;
    rdfs:label 'Outside Counsel Evaluator Name' ;
    rdfs:comment 'Name of the client-side individual responsible for evaluating and approving outside counsel guideline compliance (typically General Counsel or Legal Operations Manager).' ;
    rdfs:domain ind:OutsideCounselGuideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outsideCounselGuidelineStatus rdf:type rdf:Property ;
    rdfs:label 'Outside Counsel Guideline Status' ;
    rdfs:comment 'Current lifecycle status of the guideline record: active (currently in force), inactive (temporarily suspended), superseded (replaced by newer version), archived (historical record).' ;
    rdfs:domain ind:OutsideCounselGuideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredBillingFormat rdf:type rdf:Property ;
    rdfs:label 'Preferred Billing Format' ;
    rdfs:comment 'Clients preferred invoice format: LEDES electronic standard, PDF narrative, e-billing portal submission, Excel spreadsheet, or custom format.' ;
    rdfs:domain ind:OutsideCounselGuideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCapCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Rate Cap Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for billing rate caps (e.g., USD, GBP, EUR).' ;
    rdfs:domain ind:OutsideCounselGuideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingFrequency rdf:type rdf:Property ;
    rdfs:label 'Reporting Frequency' ;
    rdfs:comment 'Frequency at which the client expects matter status reports and updates: weekly, biweekly, monthly, quarterly, on-demand, or milestone-based.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:staffingRestriction rdf:type rdf:Property ;
    rdfs:label 'Staffing Restriction' ;
    rdfs:comment 'Free-text description of any staffing restrictions imposed by the client (e.g., maximum number of timekeepers, seniority mix requirements, named attorney requirements).' ;
    rdfs:domain ind:OutsideCounselGuideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityReportingRequired rdf:type rdf:Property ;
    rdfs:label 'Sustainability Reporting Required' ;
    rdfs:comment 'Indicates whether the client requires sustainability or environmental impact reporting (e.g., carbon footprint of legal services, paperless billing compliance).' ;
    rdfs:domain ind:OutsideCounselGuideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:travelExpensePolicy rdf:type rdf:Property ;
    rdfs:label 'Travel Expense Policy' ;
    rdfs:comment 'Summary of client travel and expense reimbursement policy: permissible travel classes, accommodation standards, meal per diems, and approval requirements.' ;
    rdfs:domain ind:OutsideCounselGuideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utbmsTaskCodeRequired rdf:type rdf:Property ;
    rdfs:label 'Utbms Task Code Required' ;
    rdfs:comment 'Indicates whether the client requires UTBMS task codes on all time entries and invoices for standardized billing categorization.' ;
    rdfs:domain ind:OutsideCounselGuideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:accountName rdf:type rdf:Property ;
    rdfs:label 'Account Name' ;
    rdfs:comment 'The legal name of the trust account as registered with the financial institution. Typically includes firm name, client name, and trust designation.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountNumber rdf:type rdf:Property ;
    rdfs:label 'Account Number' ;
    rdfs:comment 'The bank account number assigned by the financial institution for this trust account. Externally-known identifier used for banking transactions and reconciliations.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountStatus rdf:type rdf:Property ;
    rdfs:label 'Account Status' ;
    rdfs:comment 'Current lifecycle status of the trust account. Active accounts are operational and accepting transactions; inactive accounts are dormant but not closed; closed accounts have been formally terminated; suspended accounts are temporarily frozen pending investigation or resolution; pending closure accounts are in the process of being wound down.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountType rdf:type rdf:Property ;
    rdfs:label 'Account Type' ;
    rdfs:comment 'Classification of the trust account based on regulatory and operational purpose. IOLTA (Interest on Lawyers Trust Accounts) pooled accounts hold commingled client funds with interest benefiting legal aid; individual client trust accounts segregate funds for a single client; escrow accounts hold transaction funds; retainer accounts hold advance fee deposits; settlement accounts hold litigation proceeds; qualified settlement funds hold structured settlement amounts.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amlKycStatus rdf:type rdf:Property ;
    rdfs:label 'Aml Kyc Status' ;
    rdfs:comment 'Status of Anti-Money Laundering and Know Your Client verification for this trust account. Trust accounts holding client funds must comply with AML regulations and verify client identity.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditFrequency rdf:type rdf:Property ;
    rdfs:label 'Audit Frequency' ;
    rdfs:comment 'Frequency at which this trust account is subject to internal or external audit. High-value or high-risk accounts may require more frequent audits.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:branchAddress rdf:type rdf:Property ;
    rdfs:label 'Branch Address' ;
    rdfs:comment 'Physical address of the bank branch where the trust account is maintained. Required for regulatory filings and audit documentation.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:branchName rdf:type rdf:Property ;
    rdfs:label 'Branch Name' ;
    rdfs:comment 'Name of the specific branch location where the trust account is maintained. May be required for regulatory reporting in some jurisdictions.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedDate rdf:type rdf:Property ;
    rdfs:label 'Closed Date' ;
    rdfs:comment 'Date when the trust account was formally closed. Null for active accounts. Closing a trust account requires zero balance and completion of all regulatory reporting obligations.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:externalReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'External Reference Number' ;
    rdfs:comment 'External reference number or identifier assigned by the financial institution, regulatory body, or third party. Used for cross-system reconciliation and regulatory reporting.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialInstitutionCode rdf:type rdf:Property ;
    rdfs:label 'Financial Institution Code' ;
    rdfs:comment 'Routing number, SWIFT code, or other standard identifier for the financial institution holding the trust account. Used for electronic funds transfers and reconciliation.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialInstitutionName rdf:type rdf:Property ;
    rdfs:label 'Financial Institution Name' ;
    rdfs:comment 'Name of the bank or financial institution where the trust account is maintained. Must be an approved institution per jurisdiction-specific trust accounting regulations.' ;
    rdfs:domain ind:Trust ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interestBeneficiary rdf:type rdf:Property ;
    rdfs:label 'Interest Beneficiary' ;
    rdfs:comment 'Entity that receives interest earned on the trust account. For IOLTA accounts, interest goes to the state IOLTA foundation or legal aid programs. For individual client trust accounts, interest typically belongs to the client.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interestRate rdf:type rdf:Property ;
    rdfs:label 'Interest Rate' ;
    rdfs:comment 'Annual interest rate applied to the trust account balance, expressed as a decimal (e.g., 0.0125 for 1.25%). Applicable only for interest-bearing accounts.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ioltaReportingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Iolta Reporting Required Flag' ;
    rdfs:comment 'Indicates whether this trust account is subject to IOLTA reporting requirements. IOLTA accounts must report interest earned and remit it to the designated legal aid foundation.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastAuditDate rdf:type rdf:Property ;
    rdfs:label 'Last Audit Date' ;
    rdfs:comment 'Date of the most recent internal or external audit performed on this trust account. Trust accounts are subject to periodic audits to ensure compliance with fiduciary obligations.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastAuditResult rdf:type rdf:Property ;
    rdfs:label 'Last Audit Result' ;
    rdfs:comment 'Outcome of the most recent audit. Pass indicates full compliance; pass with observations indicates minor issues noted; fail indicates material deficiencies requiring remediation.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReconciliationDate rdf:type rdf:Property ;
    rdfs:label 'Last Reconciliation Date' ;
    rdfs:comment 'Date of the most recent three-way reconciliation performed for this trust account. Trust accounts must be reconciled monthly, comparing bank statement balance, trust ledger balance, and client ledger balances.' ;
    rdfs:domain ind:Trust ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:minimumBalanceRequired rdf:type rdf:Property ;
    rdfs:label 'Minimum Balance Required' ;
    rdfs:comment 'Minimum balance that must be maintained in the trust account per bank requirements or firm policy. Some jurisdictions or account types require a minimum balance to remain open.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextReconciliationDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Reconciliation Due Date' ;
    rdfs:comment 'Date by which the next three-way reconciliation must be completed. Typically set to the end of the following month after the last reconciliation.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:openedDate rdf:type rdf:Property ;
    rdfs:label 'Opened Date' ;
    rdfs:comment 'Date when the trust account was opened at the financial institution. Marks the beginning of the accounts operational lifecycle.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:purposeOfAccount rdf:type rdf:Property ;
    rdfs:label 'Purpose Of Account' ;
    rdfs:comment 'Business purpose for which this trust account was established. Examples include holding litigation settlement funds, managing real estate transaction escrow, holding retainer for ongoing legal services, managing estate administration funds.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryClassification rdf:type rdf:Property ;
    rdfs:label 'Regulatory Classification' ;
    rdfs:comment 'Classification of the trust account for regulatory reporting purposes. Different classifications may have different reporting requirements, audit frequencies, and compliance obligations.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterpartyIntakePartyId rdf:type rdf:Property ;
    rdfs:label 'Counterparty Intake Party Id' ;
    rdfs:comment 'Foreign key linking to intake.intake_party. Business justification: Ledger entry counterparties are intake parties with KYC/AML screening records. Replacing denormalized counterparty_name with a FK to intake_party enforces 3NF and supports AML transaction monitoring, ' ;
    rdfs:domain ind:LedgerEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IntakeParty .

ind:retainerAgreementId rdf:type rdf:Property ;
    rdfs:label 'Retainer Agreement Id' ;
    rdfs:comment 'Foreign key linking to trust.retainer_agreement. Business justification: A ledger entry recording a retainer deposit, replenishment, or draw-down is directly tied to the governing retainer agreement. Adding retainer_agreement_id to ledger_entry enables traceability from in' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RetainerAgreement .

ind:reversedEntryLedgerEntryId rdf:type rdf:Property ;
    rdfs:label 'Reversed Entry Ledger Entry Id' ;
    rdfs:comment 'Reference to the original trust ledger entry that this transaction reverses. Null for non-reversal entries.' ;
    rdfs:domain ind:LedgerEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LedgerEntry .

ind:authorizationReference rdf:type rdf:Property ;
    rdfs:label 'Authorization Reference' ;
    rdfs:comment 'Client authorization document reference or approval identifier. Required for disbursements and transfers.' ;
    rdfs:domain ind:Trust ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankStatementDate rdf:type rdf:Property ;
    rdfs:label 'Bank Statement Date' ;
    rdfs:comment 'Date of the bank statement on which this transaction appeared. Used for three-way reconciliation matching.' ;
    rdfs:domain ind:Trust ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:counterpartyAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Counterparty Account Number' ;
    rdfs:comment 'Bank account number of the counterparty. Required for wire transfers and ACH transactions.' ;
    rdfs:domain ind:LedgerEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disbursementCategory rdf:type rdf:Property ;
    rdfs:label 'Disbursement Category' ;
    rdfs:comment 'UTBMS expense code or disbursement classification for payments. Used for client billing and matter cost tracking.' ;
    rdfs:domain ind:Trust ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryDirection rdf:type rdf:Property ;
    rdfs:label 'Entry Direction' ;
    rdfs:comment 'Double-entry accounting direction. Debit increases trust liability to client; credit decreases it.' ;
    rdfs:domain ind:LedgerEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalNotes rdf:type rdf:Property ;
    rdfs:label 'Internal Notes' ;
    rdfs:comment 'Confidential internal notes for firm use only. Not disclosed to clients. Used for operational context and issue tracking.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ledesCode rdf:type rdf:Property ;
    rdfs:label 'Ledes Code' ;
    rdfs:comment 'LEDES billing code for trust transactions that will be billed to clients. Enables electronic invoice submission.' ;
    rdfs:domain ind:LedgerEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ledgerEntryDescription rdf:type rdf:Property ;
    rdfs:label 'Ledger Entry Description' ;
    rdfs:comment 'Detailed narrative description of the trust transaction purpose. Required for client reporting and regulatory audit.' ;
    rdfs:domain ind:LedgerEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payeeAddress rdf:type rdf:Property ;
    rdfs:label 'Payee Address' ;
    rdfs:comment 'Mailing address of the disbursement recipient. Required for cheque mailing and wire transfer compliance.' ;
    rdfs:domain ind:LedgerEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payeeName rdf:type rdf:Property ;
    rdfs:label 'Payee Name' ;
    rdfs:comment 'Name of the recipient for disbursement transactions. Required for cheque printing and payment audit trail.' ;
    rdfs:domain ind:LedgerEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentReference rdf:type rdf:Property ;
    rdfs:label 'Payment Reference' ;
    rdfs:comment 'External payment identifier such as cheque number, wire confirmation, or ACH trace number. Used for bank reconciliation.' ;
    rdfs:domain ind:LedgerEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postedToGlFlag rdf:type rdf:Property ;
    rdfs:label 'Posted To Gl Flag' ;
    rdfs:comment 'Indicates whether this trust transaction has been posted to the firm general ledger. Used for financial close process.' ;
    rdfs:domain ind:LedgerEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Flag' ;
    rdfs:comment 'Indicates whether this transaction must be included in regulatory trust account reports to bar associations or oversight bodies.' ;
    rdfs:domain ind:Trust ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reversalFlag rdf:type rdf:Property ;
    rdfs:label 'Reversal Flag' ;
    rdfs:comment 'Indicates whether this entry is a reversal of a previous transaction. True for correction entries.' ;
    rdfs:domain ind:LedgerEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:runningBalance rdf:type rdf:Property ;
    rdfs:label 'Running Balance' ;
    rdfs:comment 'Cumulative client trust balance after this transaction. Used for real-time balance verification and overdraft prevention.' ;
    rdfs:domain ind:LedgerEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionDate rdf:type rdf:Property ;
    rdfs:label 'Transaction Date' ;
    rdfs:comment 'The business date on which the trust transaction occurred. Used for ledger sequencing and regulatory reporting periods.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transactionNumber rdf:type rdf:Property ;
    rdfs:label 'Transaction Number' ;
    rdfs:comment 'Externally-visible unique transaction reference number for audit trail and client reporting. Sequentially assigned per trust account.' ;
    rdfs:domain ind:LedgerEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transaction Timestamp' ;
    rdfs:comment 'Precise date and time when the trust transaction was recorded in the system. Used for audit trail and chronological sequencing.' ;
    rdfs:domain ind:LedgerEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:transactionType rdf:type rdf:Property ;
    rdfs:label 'Transaction Type' ;
    rdfs:comment 'Classification of the trust transaction. Determines accounting treatment and regulatory reporting category. [ENUM-REF-CANDIDATE: receipt|disbursement|transfer_in|transfer_out|interest_credit|bank_charge|reversal|adjustment — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientTrustBalanceId rdf:type rdf:Property ;
    rdfs:label 'Client Trust Balance Id' ;
    rdfs:comment 'Unique identifier for the client trust balance record. Primary key for this entity.' ;
    rdfs:domain ind:ClientTrustBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryClientAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Client Account Id' ;
    rdfs:comment 'Identifier of the trust bank account (pooled IOLTA or individual client account) in which the funds are held.' ;
    rdfs:domain ind:ClientTrustBalance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:threeWayReconciliationId rdf:type rdf:Property ;
    rdfs:label 'Three Way Reconciliation Id' ;
    rdfs:comment 'Foreign key linking to trust.three_way_reconciliation. Business justification: The client_trust_balance has last_reconciliation_date and last_reconciled_balance_amount fields that are populated during the three-way reconciliation process. Adding a FK to the most recent three_way' ;
    rdfs:domain ind:Trust ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ThreeWayReconciliation .

ind:toAccountId rdf:type rdf:Property ;
    rdfs:label 'To Account Id' ;
    rdfs:comment 'FK to trust.trust_account.trust_account_id — Each client balance record must reference the trust account it represents a position within. Required for pooled IOLTA accounts where multiple client balances exist within one bank account.' ;
    rdfs:domain ind:Trust ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:auditFindingsNotes rdf:type rdf:Property ;
    rdfs:label 'Audit Findings Notes' ;
    rdfs:comment 'Summary of findings from the last trust account audit for this balance. Documents any discrepancies, corrective actions, or compliance issues identified.' ;
    rdfs:domain ind:ClientTrustBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availableBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Available Balance Amount' ;
    rdfs:comment 'Net available balance for immediate disbursement, calculated as current_balance_amount minus held_balance_amount. Represents funds that can be disbursed without restriction.' ;
    rdfs:domain ind:ClientTrustBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:balanceAsOfDate rdf:type rdf:Property ;
    rdfs:label 'Balance As Of Date' ;
    rdfs:comment 'Date as of which the current_balance_amount is accurate. Represents the effective date of the balance snapshot.' ;
    rdfs:domain ind:ClientTrustBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:balanceStatus rdf:type rdf:Property ;
    rdfs:label 'Balance Status' ;
    rdfs:comment 'Current lifecycle status of the trust balance record. Active indicates ongoing trust activity; dormant indicates no recent activity but positive balance; closed indicates zero balance and matter closure; reconciliation_pending indicates awaiting three-way reconciliation; under_review indicates regulatory or internal audit review.' ;
    rdfs:domain ind:ClientTrustBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientAuthorizationOnFileFlag rdf:type rdf:Property ;
    rdfs:label 'Client Authorization On File Flag' ;
    rdfs:comment 'Indicator of whether written client authorization for trust fund handling is on file. Required for compliance with engagement letter and trust accounting requirements.' ;
    rdfs:domain ind:ClientTrustBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currentBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Current Balance Amount' ;
    rdfs:comment 'Current available trust balance for the client-matter combination as of the balance_as_of_date. Represents funds available for authorized disbursements.' ;
    rdfs:domain ind:ClientTrustBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dormancyThresholdDays rdf:type rdf:Property ;
    rdfs:label 'Dormancy Threshold Days' ;
    rdfs:comment 'Number of days without activity after which the trust balance is considered dormant and subject to escheatment review. Varies by jurisdiction (typically 180-365 days).' ;
    rdfs:domain ind:ClientTrustBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:escheatmentEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Escheatment Eligible Flag' ;
    rdfs:comment 'Indicator of whether the trust balance is eligible for escheatment to the state due to dormancy and inability to locate the client. True triggers escheatment reporting and remittance process.' ;
    rdfs:domain ind:ClientTrustBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escheatmentReviewDate rdf:type rdf:Property ;
    rdfs:label 'Escheatment Review Date' ;
    rdfs:comment 'Date when the trust balance was last reviewed for escheatment eligibility. Required for compliance with unclaimed property reporting deadlines.' ;
    rdfs:domain ind:ClientTrustBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:heldBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Held Balance Amount' ;
    rdfs:comment 'Amount of trust funds held pending disbursement authorization or clearance. Represents funds committed but not yet disbursed (e.g., checks issued but not cleared, pending wire transfers).' ;
    rdfs:domain ind:ClientTrustBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interestDisbursedAmount rdf:type rdf:Property ;
    rdfs:label 'Interest Disbursed Amount' ;
    rdfs:comment 'Total interest disbursed to the client from this trust balance. Used to reconcile interest earned vs. interest paid out.' ;
    rdfs:domain ind:ClientTrustBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interestEarnedAmount rdf:type rdf:Property ;
    rdfs:label 'Interest Earned Amount' ;
    rdfs:comment 'Total interest earned on this client trust balance if held in an individual interest-bearing account (not pooled IOLTA). Interest belongs to the client and must be tracked separately.' ;
    rdfs:domain ind:ClientTrustBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastActivityDate rdf:type rdf:Property ;
    rdfs:label 'Last Activity Date' ;
    rdfs:comment 'Date of the most recent trust activity (deposit, disbursement, or transfer) for this client-matter. Used to identify dormant accounts subject to escheatment or closure.' ;
    rdfs:domain ind:ClientTrustBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastDepositDate rdf:type rdf:Property ;
    rdfs:label 'Last Deposit Date' ;
    rdfs:comment 'Date of the most recent deposit into trust for this client-matter. Used to identify dormant accounts and trigger escheatment reviews.' ;
    rdfs:domain ind:ClientTrustBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastDisbursementDate rdf:type rdf:Property ;
    rdfs:label 'Last Disbursement Date' ;
    rdfs:comment 'Date of the most recent disbursement from trust for this client-matter. Used to identify dormant accounts and assess matter closure readiness.' ;
    rdfs:domain ind:ClientTrustBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastReconciledBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Last Reconciled Balance Amount' ;
    rdfs:comment 'Trust balance amount as of the last completed three-way reconciliation (bank statement, trust ledger, client sub-ledger). Used to detect discrepancies and ensure compliance.' ;
    rdfs:domain ind:ClientTrustBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumBalanceRequiredAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Balance Required Amount' ;
    rdfs:comment 'Minimum trust balance amount required to be maintained for this client-matter per engagement terms or regulatory requirements. Used to trigger alerts for low balance conditions.' ;
    rdfs:domain ind:ClientTrustBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:negativeBalanceDate rdf:type rdf:Property ;
    rdfs:label 'Negative Balance Date' ;
    rdfs:comment 'Date when the trust balance first went negative, if applicable. Used for regulatory reporting and disciplinary investigation.' ;
    rdfs:domain ind:ClientTrustBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:negativeBalanceFlag rdf:type rdf:Property ;
    rdfs:label 'Negative Balance Flag' ;
    rdfs:comment 'Indicator of whether the trust balance has ever gone negative, which is a serious ethical violation. True indicates a historical or current negative balance condition requiring immediate remediation.' ;
    rdfs:domain ind:ClientTrustBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:openingBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Opening Balance Amount' ;
    rdfs:comment 'Initial trust balance amount when the client-matter trust sub-ledger was established. Represents the first deposit or transfer into trust for this matter.' ;
    rdfs:domain ind:ClientTrustBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryReportingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Required Flag' ;
    rdfs:comment 'Indicator of whether this trust balance requires special regulatory reporting (e.g., large cash transactions, suspicious activity, cross-border transfers). True triggers compliance review and reporting workflow.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalDepositsAmount rdf:type rdf:Property ;
    rdfs:label 'Total Deposits Amount' ;
    rdfs:comment 'Cumulative total of all deposits into trust for this client-matter since inception. Used for reconciliation and audit trail purposes.' ;
    rdfs:domain ind:ClientTrustBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDisbursementsAmount rdf:type rdf:Property ;
    rdfs:label 'Total Disbursements Amount' ;
    rdfs:comment 'Cumulative total of all disbursements from trust for this client-matter since inception. Used for reconciliation and audit trail purposes.' ;
    rdfs:domain ind:ClientTrustBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trustAccountType rdf:type rdf:Property ;
    rdfs:label 'Trust Account Type' ;
    rdfs:comment 'Type of trust account holding the funds: pooled IOLTA account for multiple clients, individual client trust account, or escrow account for specific transactions.' ;
    rdfs:domain ind:ClientTrustBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trustAccountingNotes rdf:type rdf:Property ;
    rdfs:label 'Trust Accounting Notes' ;
    rdfs:comment 'Free-text notes regarding special trust accounting considerations, client instructions, or regulatory exceptions applicable to this balance. Used for audit trail and compliance documentation.' ;
    rdfs:domain ind:ClientTrustBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceControlId rdf:type rdf:Property ;
    rdfs:label 'Compliance Control Id' ;
    rdfs:comment 'Foreign key linking to compliance.compliance_control. Business justification: Incoming trust funds are subject to compliance controls (source-of-funds verification, AML acceptance controls). Compliance audit of receipts requires linking each receipt to the control governing acc' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ComplianceControl .

ind:kycScreeningId rdf:type rdf:Property ;
    rdfs:label 'Kyc Screening Id' ;
    rdfs:comment 'Foreign key linking to intake.kyc_screening. Business justification: Receipt of trust funds requires KYC/AML screening of the payor per AML regulations. Linking receipt to the payor\'s kyc_screening record supports IOLTA compliance, source-of-funds verification, and SAR' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:KycScreening .

ind:payorIntakePartyId rdf:type rdf:Property ;
    rdfs:label 'Payor Intake Party Id' ;
    rdfs:comment 'Foreign key linking to intake.intake_party. Business justification: The receipt payor is an intake party with KYC/AML screening records. Replacing denormalized payor_name with a FK to intake_party enforces 3NF and links incoming trust funds to the screened party recor' ;
    rdfs:domain ind:Receipt ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IntakeParty .

ind:amlRiskScore rdf:type rdf:Property ;
    rdfs:label 'Aml Risk Score' ;
    rdfs:comment 'Numeric risk score assigned by the AML screening system. Higher scores indicate elevated risk requiring additional review.' ;
    rdfs:domain ind:Receipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bankStatementLineReference rdf:type rdf:Property ;
    rdfs:label 'Bank Statement Line Reference' ;
    rdfs:comment 'Reference to the corresponding line item on the trust account bank statement. Used for three-way reconciliation (firm records, client ledger, bank statement).' ;
    rdfs:domain ind:Receipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearedDate rdf:type rdf:Property ;
    rdfs:label 'Cleared Date' ;
    rdfs:comment 'Date on which the deposited funds cleared and became available in the trust account. Critical for three-way reconciliation and disbursement authorization.' ;
    rdfs:domain ind:Trust ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clientAuthorizationReference rdf:type rdf:Property ;
    rdfs:label 'Client Authorization Reference' ;
    rdfs:comment 'Reference to the client\'s written authorization or engagement letter permitting the firm to receive and hold these funds in trust. Required for compliance and dispute resolution.' ;
    rdfs:domain ind:Receipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depositDate rdf:type rdf:Property ;
    rdfs:label 'Deposit Date' ;
    rdfs:comment 'The date on which the funds were deposited into the trust account. Must comply with jurisdiction-specific prompt deposit rules (typically within 1-3 business days of receipt).' ;
    rdfs:domain ind:Receipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ioltaEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Iolta Eligible Flag' ;
    rdfs:comment 'Indicates whether this receipt is eligible for deposit into an IOLTA account (typically small or short-term client funds where individual interest accounting is impractical).' ;
    rdfs:domain ind:Receipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:payorAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Payor Account Number' ;
    rdfs:comment 'Bank account number or payment instrument identifier from which the funds originated. Masked for security; used for reconciliation and AML screening.' ;
    rdfs:domain ind:Receipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payorBankName rdf:type rdf:Property ;
    rdfs:label 'Payor Bank Name' ;
    rdfs:comment 'Name of the financial institution from which the funds were sent. Supports AML due diligence and wire transfer verification.' ;
    rdfs:domain ind:Receipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purposeDescription rdf:type rdf:Property ;
    rdfs:label 'Purpose Description' ;
    rdfs:comment 'Detailed narrative describing the purpose for which the funds were received (e.g., \'Advance retainer for litigation services in Smith v. Jones\', \'Settlement proceeds from mediation on 2024-01-15\').' ;
    rdfs:domain ind:Receipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptDate rdf:type rdf:Property ;
    rdfs:label 'Receipt Date' ;
    rdfs:comment 'The date on which the client funds were received by the firm. Critical for trust accounting reconciliation and interest calculation.' ;
    rdfs:domain ind:Receipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:receiptNumber rdf:type rdf:Property ;
    rdfs:label 'Receipt Number' ;
    rdfs:comment 'Externally visible unique receipt number assigned to this trust receipt for audit trail and client communication purposes.' ;
    rdfs:domain ind:Receipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptStatus rdf:type rdf:Property ;
    rdfs:label 'Receipt Status' ;
    rdfs:comment 'Current lifecycle status of the trust receipt. Tracks the receipt from initial recording through deposit, clearing, and any subsequent reversals.' ;
    rdfs:domain ind:Receipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptType rdf:type rdf:Property ;
    rdfs:label 'Receipt Type' ;
    rdfs:comment 'Classification of the trust receipt based on the purpose and source of the funds. Determines handling and disbursement rules.' ;
    rdfs:domain ind:Receipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartyPaymentFlag rdf:type rdf:Property ;
    rdfs:label 'Third Party Payment Flag' ;
    rdfs:comment 'Indicates whether the funds were provided by a third party (not the client). Triggers additional conflict checking and client consent requirements.' ;
    rdfs:domain ind:Receipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:payeeIntakePartyId rdf:type rdf:Property ;
    rdfs:label 'Payee Intake Party Id' ;
    rdfs:comment 'Foreign key linking to intake.intake_party. Business justification: The disbursement payee is an intake party with KYC/AML screening records. Replacing denormalized payee_name with a FK to intake_party enforces 3NF and links disbursements to the screened party record ' ;
    rdfs:domain ind:TrustDisbursement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IntakeParty .

ind:reversedByDisbursementTrustDisbursementId rdf:type rdf:Property ;
    rdfs:label 'Reversed By Disbursement Trust Disbursement Id' ;
    rdfs:comment 'Reference to the reversing disbursement transaction if this disbursement was reversed. Creates audit trail for corrections.' ;
    rdfs:domain ind:TrustDisbursement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TrustDisbursement .

ind:authorizationDate rdf:type rdf:Property ;
    rdfs:label 'Authorization Date' ;
    rdfs:comment 'The date on which the disbursement was authorized by the responsible attorney. Part of the audit trail.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authorizationStatus rdf:type rdf:Property ;
    rdfs:label 'Authorization Status' ;
    rdfs:comment 'Current approval and execution status of the disbursement. Tracks the disbursement through its lifecycle from request to completion.' ;
    rdfs:domain ind:Trust ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Bank Account Number' ;
    rdfs:comment 'The trust bank account number from which the disbursement was made. Required for bank reconciliation and regulatory reporting.' ;
    rdfs:domain ind:Trust ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankName rdf:type rdf:Property ;
    rdfs:label 'Bank Name' ;
    rdfs:comment 'The name of the financial institution holding the trust account. Required for regulatory reporting.' ;
    rdfs:domain ind:Trust ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankRoutingNumber rdf:type rdf:Property ;
    rdfs:label 'Bank Routing Number' ;
    rdfs:comment 'The ABA routing number for the trust account bank. Used for electronic funds transfers and wire transfers.' ;
    rdfs:domain ind:TrustDisbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkNumber rdf:type rdf:Property ;
    rdfs:label 'Check Number' ;
    rdfs:comment 'The check number if payment method is check. Used for bank reconciliation and audit trail.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courtCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Court Case Number' ;
    rdfs:comment 'The court case number if the disbursement is related to court filing fees or litigation costs. Used for matter cost tracking.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disbursementDate rdf:type rdf:Property ;
    rdfs:label 'Disbursement Date' ;
    rdfs:comment 'The date on which the disbursement was executed and funds left the trust account. Core business event timestamp for trust fund outflows.' ;
    rdfs:domain ind:TrustDisbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disbursementDescription rdf:type rdf:Property ;
    rdfs:label 'Disbursement Description' ;
    rdfs:comment 'Detailed narrative description of the purpose and nature of the disbursement. Required for client reporting and audit trail.' ;
    rdfs:domain ind:TrustDisbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isIoltaReportable rdf:type rdf:Property ;
    rdfs:label 'Is Iolta Reportable' ;
    rdfs:comment 'Flag indicating whether this disbursement must be included in IOLTA regulatory reporting. Determined by jurisdiction rules.' ;
    rdfs:domain ind:TrustDisbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isThreeWayReconciled rdf:type rdf:Property ;
    rdfs:label 'Is Three Way Reconciled' ;
    rdfs:comment 'Flag indicating whether this disbursement has been reconciled across trust ledger, bank statement, and client ledger. Required for compliance.' ;
    rdfs:domain ind:TrustDisbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:payeeType rdf:type rdf:Property ;
    rdfs:label 'Payee Type' ;
    rdfs:comment 'Classification of the payee receiving the disbursement. Used for segregation of duties and conflict checking.' ;
    rdfs:domain ind:TrustDisbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processedDate rdf:type rdf:Property ;
    rdfs:label 'Processed Date' ;
    rdfs:comment 'The date on which the disbursement was processed and submitted for payment. May differ from disbursement date due to clearing time.' ;
    rdfs:domain ind:TrustDisbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:taxTreatmentCode rdf:type rdf:Property ;
    rdfs:label 'Tax Treatment Code' ;
    rdfs:comment 'Tax classification code for the disbursement. Used for 1099 reporting and tax compliance when disbursements are made to vendors or experts.' ;
    rdfs:domain ind:TrustDisbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wireReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Wire Reference Number' ;
    rdfs:comment 'The wire transfer reference or confirmation number if payment method is wire transfer. Used for bank reconciliation.' ;
    rdfs:domain ind:TrustDisbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disbursementLedgerEntryId rdf:type rdf:Property ;
    rdfs:label 'Disbursement Ledger Entry Id' ;
    rdfs:comment 'FK to trust.trust_ledger_entry.trust_ledger_entry_id — Each authorization governs a specific disbursement transaction recorded in the ledger. Required for audit trail and compliance.' ;
    rdfs:domain ind:DisbursementAuthorization ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LedgerEntry .

ind:primaryDisbursementLedgerEntryId rdf:type rdf:Property ;
    rdfs:label 'Primary Disbursement Ledger Entry Id' ;
    rdfs:comment 'Reference to the trust ledger entry that this authorization governs. Links to the specific trust transaction requiring authorization.' ;
    rdfs:domain ind:DisbursementAuthorization ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LedgerEntry .

ind:toLedgerEntryId rdf:type rdf:Property ;
    rdfs:label 'To Ledger Entry Id' ;
    rdfs:comment 'FK to trust.trust_ledger_entry.trust_ledger_entry_id — Each authorization governs a specific disbursement transaction (now a ledger entry of disbursement type). Without this link, authorizations are disconnected from the transactions they approve.' ;
    rdfs:domain ind:DisbursementAuthorization ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LedgerEntry .

ind:authorizationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Authorization Expiry Date' ;
    rdfs:comment 'Date after which the authorization becomes invalid if disbursement has not been executed. Enforces time-bound authorization controls.' ;
    rdfs:domain ind:DisbursementAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authorizationNumber rdf:type rdf:Property ;
    rdfs:label 'Authorization Number' ;
    rdfs:comment 'Unique business identifier for the disbursement authorization. Human-readable reference number used in audit trails and regulatory reporting.' ;
    rdfs:domain ind:DisbursementAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientConsentDate rdf:type rdf:Property ;
    rdfs:label 'Client Consent Date' ;
    rdfs:comment 'Date on which client consent was obtained for the disbursement. Null if consent not required or not yet obtained.' ;
    rdfs:domain ind:DisbursementAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clientConsentMethod rdf:type rdf:Property ;
    rdfs:label 'Client Consent Method' ;
    rdfs:comment 'Method by which client consent was obtained. Required for audit trail and regulatory compliance when consent is mandatory.' ;
    rdfs:domain ind:DisbursementAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientConsentObtainedFlag rdf:type rdf:Property ;
    rdfs:label 'Client Consent Obtained Flag' ;
    rdfs:comment 'Indicates whether explicit client consent was obtained for the disbursement. Required for certain disbursement types per bar association rules.' ;
    rdfs:domain ind:DisbursementAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:digitalSignatureReference1 rdf:type rdf:Property ;
    rdfs:label 'Digital Signature Reference 1' ;
    rdfs:comment 'Reference identifier or hash of the first digital signature applied to the authorization. Used for non-repudiation and regulatory compliance.' ;
    rdfs:domain ind:DisbursementAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalSignatureReference2 rdf:type rdf:Property ;
    rdfs:label 'Digital Signature Reference 2' ;
    rdfs:comment 'Reference identifier or hash of the second digital signature applied when dual signatory is required. Null if single signature sufficient.' ;
    rdfs:domain ind:DisbursementAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disbursementAmount rdf:type rdf:Property ;
    rdfs:label 'Disbursement Amount' ;
    rdfs:comment 'The monetary amount being authorized for disbursement from the client trust account. Must not exceed available trust balance.' ;
    rdfs:domain ind:DisbursementAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disbursementCurrency rdf:type rdf:Property ;
    rdfs:label 'Disbursement Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the disbursement amount. Required for multi-currency trust accounting.' ;
    rdfs:domain ind:DisbursementAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disbursementPurpose rdf:type rdf:Property ;
    rdfs:label 'Disbursement Purpose' ;
    rdfs:comment 'Detailed business justification and purpose for the trust fund disbursement. Required for regulatory compliance and audit trail.' ;
    rdfs:domain ind:DisbursementAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dualSignatoryRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Dual Signatory Required Flag' ;
    rdfs:comment 'Indicates whether dual signatory approval is required for this disbursement based on amount threshold or disbursement type. True if managing partner approval is mandatory.' ;
    rdfs:domain ind:DisbursementAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dualSignatoryThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Dual Signatory Threshold Amount' ;
    rdfs:comment 'The monetary threshold above which dual signatory approval is required. Captured at time of authorization for audit purposes.' ;
    rdfs:domain ind:DisbursementAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:finalAuthorizationDate rdf:type rdf:Property ;
    rdfs:label 'Final Authorization Date' ;
    rdfs:comment 'Date on which the disbursement received final authorization and became executable. Represents completion of approval workflow.' ;
    rdfs:domain ind:DisbursementAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:finalAuthorizationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Final Authorization Timestamp' ;
    rdfs:comment 'Precise date and time when the disbursement authorization workflow was completed and funds became available for disbursement.' ;
    rdfs:domain ind:DisbursementAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:managingPartnerApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Managing Partner Approval Date' ;
    rdfs:comment 'Date on which the managing partner approved the disbursement. Null if not required, not yet approved, or rejected.' ;
    rdfs:domain ind:DisbursementAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:managingPartnerApprovalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Managing Partner Approval Timestamp' ;
    rdfs:comment 'Precise date and time of managing partner approval. Required for high-value disbursements exceeding dual-signatory threshold.' ;
    rdfs:domain ind:DisbursementAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rejectionDate rdf:type rdf:Property ;
    rdfs:label 'Rejection Date' ;
    rdfs:comment 'Date on which the disbursement authorization was rejected. Null if not rejected.' ;
    rdfs:domain ind:DisbursementAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rejectionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason Code' ;
    rdfs:comment 'Standardized code categorizing the reason for rejection. Used for reporting and trend analysis of authorization failures.' ;
    rdfs:domain ind:DisbursementAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Rejection Timestamp' ;
    rdfs:comment 'Precise date and time when the disbursement authorization was rejected by an approver in the authorization chain.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requestDate rdf:type rdf:Property ;
    rdfs:label 'Request Date' ;
    rdfs:comment 'Date on which the disbursement authorization was initially requested. Used for aging analysis and SLA tracking.' ;
    rdfs:domain ind:DisbursementAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestTimestamp rdf:type rdf:Property ;
    rdfs:label 'Request Timestamp' ;
    rdfs:comment 'Precise date and time when the disbursement authorization request was submitted. Required for audit trail and workflow tracking.' ;
    rdfs:domain ind:DisbursementAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:supervisingPartnerApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Supervising Partner Approval Date' ;
    rdfs:comment 'Date on which the supervising partner approved the disbursement. Null if not yet approved or if rejected.' ;
    rdfs:domain ind:DisbursementAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:supervisingPartnerApprovalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Supervising Partner Approval Timestamp' ;
    rdfs:comment 'Precise date and time of supervising partner approval. Required for audit trail and regulatory compliance.' ;
    rdfs:domain ind:DisbursementAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:supportingDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Supporting Document Reference' ;
    rdfs:comment 'Reference identifier to supporting documentation stored in the document management system. Links authorization to invoices, receipts, or court orders.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankStatementId rdf:type rdf:Property ;
    rdfs:label 'Bank Statement Id' ;
    rdfs:comment 'FK to trust.bank_statement.bank_statement_id — Each reconciliation references the specific bank statement used as the external balance source. Critical for audit trail.' ;
    rdfs:domain ind:Trust ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BankStatement .

ind:primaryThreeAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Three Account Id' ;
    rdfs:comment 'Reference to the specific trust account being reconciled. Links to the trust account master record.' ;
    rdfs:domain ind:ThreeWayReconciliation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:auditTrailReference rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Reference' ;
    rdfs:comment 'Reference to supporting documentation (bank statements, ledger reports, reconciliation worksheets) stored in the document management system. Required for regulatory examination.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankErrorsTotal rdf:type rdf:Property ;
    rdfs:label 'Bank Errors Total' ;
    rdfs:comment 'Total amount of errors identified on the bank statement (incorrect charges, duplicate transactions, posting errors). Requires bank correction and documentation.' ;
    rdfs:domain ind:ThreeWayReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bankStatementBalance rdf:type rdf:Property ;
    rdfs:label 'Bank Statement Balance' ;
    rdfs:comment 'The ending balance reported on the bank statement for the trust account as of the reconciliation period end date. First leg of the three-way reconciliation.' ;
    rdfs:domain ind:ThreeWayReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bookBalance rdf:type rdf:Property ;
    rdfs:label 'Book Balance' ;
    rdfs:comment 'The trust ledger balance per the firm\'s accounting system (Elite 3E GL trust account) as of the reconciliation period end date. Second leg of the three-way reconciliation.' ;
    rdfs:domain ind:ThreeWayReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clientLedgerTotal rdf:type rdf:Property ;
    rdfs:label 'Client Ledger Total' ;
    rdfs:comment 'The sum of all individual client sub-ledger balances as of the reconciliation period end date. Third leg of the three-way reconciliation. Must equal book_balance when no variances exist.' ;
    rdfs:domain ind:ThreeWayReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depositsInTransitTotal rdf:type rdf:Property ;
    rdfs:label 'Deposits In Transit Total' ;
    rdfs:comment 'Total amount of deposits recorded in the trust ledger but not yet reflected on the bank statement as of the reconciliation date. Reconciling item between book and bank balances.' ;
    rdfs:domain ind:ThreeWayReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exceptionCount rdf:type rdf:Property ;
    rdfs:label 'Exception Count' ;
    rdfs:comment 'The number of reconciling items (outstanding checks, deposits in transit, errors) identified during this reconciliation. Zero indicates clean reconciliation.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ledgerErrorsTotal rdf:type rdf:Property ;
    rdfs:label 'Ledger Errors Total' ;
    rdfs:comment 'Total amount of errors identified in the firm\'s trust ledger (posting errors, incorrect amounts, duplicate entries). Requires correcting journal entries and audit trail.' ;
    rdfs:domain ind:ThreeWayReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outstandingChecksTotal rdf:type rdf:Property ;
    rdfs:label 'Outstanding Checks Total' ;
    rdfs:comment 'Total amount of checks issued from the trust account that have not yet cleared the bank as of the reconciliation date. Reconciling item between book and bank balances.' ;
    rdfs:domain ind:ThreeWayReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorPeriodUnresolvedVariance rdf:type rdf:Property ;
    rdfs:label 'Prior Period Unresolved Variance' ;
    rdfs:comment 'The unresolved variance amount carried forward from the previous reconciliation period. Should be resolved in current period or escalated.' ;
    rdfs:domain ind:ThreeWayReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reconciliationMethod rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Method' ;
    rdfs:comment 'The method used to perform the reconciliation: manual (spreadsheet-based), semi_automated (system-assisted with manual review), fully_automated (system-generated with exception-only review).' ;
    rdfs:domain ind:ThreeWayReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationNumber rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Number' ;
    rdfs:comment 'Business identifier for the reconciliation record, typically formatted as RECON-YYYYMM-NNNN for monthly reconciliations.' ;
    rdfs:domain ind:ThreeWayReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationPerformedDate rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Performed Date' ;
    rdfs:comment 'The date on which the reconciliation work was completed by the preparer. Must be within regulatory timeframes (typically within 30 days of period end).' ;
    rdfs:domain ind:ThreeWayReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reconciliationPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Period End Date' ;
    rdfs:comment 'The last day of the period covered by this reconciliation, typically the last day of the month. Mandatory monthly reconciliation under most jurisdictions.' ;
    rdfs:domain ind:ThreeWayReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reconciliationPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Period Start Date' ;
    rdfs:comment 'The first day of the period covered by this reconciliation, typically the first day of the month.' ;
    rdfs:domain ind:ThreeWayReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryFilingDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Date' ;
    rdfs:comment 'The date on which this reconciliation was submitted to the regulatory authority, if required. Null if no filing is required or filing is pending.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryFilingRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Required' ;
    rdfs:comment 'Indicates whether this reconciliation must be submitted to the regulatory authority (e.g., annual IOLTA report, SRA accountant\'s report). True if filing is required.' ;
    rdfs:domain ind:ThreeWayReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Review Completed Date' ;
    rdfs:comment 'The date on which the reviewer completed their review of the reconciliation. Required for audit trail and regulatory compliance.' ;
    rdfs:domain ind:ThreeWayReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:timingDifferencesTotal rdf:type rdf:Property ;
    rdfs:label 'Timing Differences Total' ;
    rdfs:comment 'Total amount of legitimate timing differences between book and bank that will self-resolve in subsequent periods (e.g., end-of-month transactions posted next business day).' ;
    rdfs:domain ind:ThreeWayReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalVarianceAmount rdf:type rdf:Property ;
    rdfs:label 'Total Variance Amount' ;
    rdfs:comment 'The net difference between the three reconciliation legs. Calculated as (bank_statement_balance + outstanding_items) - book_balance. Zero indicates perfect reconciliation.' ;
    rdfs:domain ind:ThreeWayReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unresolvedExceptionCount rdf:type rdf:Property ;
    rdfs:label 'Unresolved Exception Count' ;
    rdfs:comment 'The number of reconciling items that remain unresolved as of the current date. Non-zero values require follow-up and escalation.' ;
    rdfs:domain ind:ThreeWayReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unresolvedVarianceAmount rdf:type rdf:Property ;
    rdfs:label 'Unresolved Variance Amount' ;
    rdfs:comment 'Amount of variance that remains unexplained after all reconciling items have been identified and documented. Non-zero values require escalation and investigation.' ;
    rdfs:domain ind:ThreeWayReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceResolutionNotes rdf:type rdf:Property ;
    rdfs:label 'Variance Resolution Notes' ;
    rdfs:comment 'Detailed narrative explaining identified variances, root cause analysis, corrective actions taken, and resolution status. Required for regulatory examination audit trail.' ;
    rdfs:domain ind:ThreeWayReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryBankAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Bank Account Id' ;
    rdfs:comment 'Reference to the trust account for which this statement was issued. Links to the trust account master record.' ;
    rdfs:domain ind:BankStatement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:averageDailyBalance rdf:type rdf:Property ;
    rdfs:label 'Average Daily Balance' ;
    rdfs:comment 'The average daily balance for the trust account during the statement period as calculated by the financial institution. Used for interest calculation verification.' ;
    rdfs:domain ind:BankStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:branchCode rdf:type rdf:Property ;
    rdfs:label 'Branch Code' ;
    rdfs:comment 'The branch or office code of the financial institution where the trust account is held. May be used for multi-branch reconciliation.' ;
    rdfs:domain ind:BankStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closingBalance rdf:type rdf:Property ;
    rdfs:label 'Closing Balance' ;
    rdfs:comment 'The account balance at the end of the statement period as reported by the financial institution. This is the external reference balance for three-way reconciliation.' ;
    rdfs:domain ind:BankStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discrepancyAmount rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Amount' ;
    rdfs:comment 'The net difference between the bank statement closing balance and the trust ledger balance at the end of the statement period. Zero indicates a balanced reconciliation.' ;
    rdfs:domain ind:Trust ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:importTimestamp rdf:type rdf:Property ;
    rdfs:label 'Import Timestamp' ;
    rdfs:comment 'The date and time when this bank statement was imported or entered into the trust accounting system.' ;
    rdfs:domain ind:BankStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:interestEarned rdf:type rdf:Property ;
    rdfs:label 'Interest Earned' ;
    rdfs:comment 'The total interest earned on the trust account during this statement period. Critical for IOLTA reporting and remittance to state bar foundations.' ;
    rdfs:domain ind:BankStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ioltaReportingPeriod rdf:type rdf:Property ;
    rdfs:label 'Iolta Reporting Period' ;
    rdfs:comment 'The IOLTA reporting period identifier (e.g., Q1-2024, 2024-01) to which this statement belongs. Used for regulatory reporting aggregation.' ;
    rdfs:domain ind:BankStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isFinalStatement rdf:type rdf:Property ;
    rdfs:label 'Is Final Statement' ;
    rdfs:comment 'Indicates whether this is the final statement for a closed trust account. Used for account closure workflows and compliance reporting.' ;
    rdfs:domain ind:BankStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:openingBalance rdf:type rdf:Property ;
    rdfs:label 'Opening Balance' ;
    rdfs:comment 'The account balance at the beginning of the statement period as reported by the financial institution.' ;
    rdfs:domain ind:BankStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:routingNumber rdf:type rdf:Property ;
    rdfs:label 'Routing Number' ;
    rdfs:comment 'The nine-digit ABA routing number for the financial institution. Used for electronic funds transfer and account identification.' ;
    rdfs:domain ind:BankStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceCharges rdf:type rdf:Property ;
    rdfs:label 'Service Charges' ;
    rdfs:comment 'The total bank fees and service charges deducted during the statement period. Must be tracked separately for IOLTA compliance.' ;
    rdfs:domain ind:BankStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:statementDate rdf:type rdf:Property ;
    rdfs:label 'Statement Date' ;
    rdfs:comment 'The official statement date as printed on the bank statement by the financial institution. Typically the same as the statement period end date.' ;
    rdfs:domain ind:BankStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:statementFileHash rdf:type rdf:Property ;
    rdfs:label 'Statement File Hash' ;
    rdfs:comment 'The cryptographic hash (e.g., SHA-256) of the original statement file. Ensures document integrity and detects tampering for compliance purposes.' ;
    rdfs:domain ind:BankStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statementFilePath rdf:type rdf:Property ;
    rdfs:label 'Statement File Path' ;
    rdfs:comment 'The storage location or document management system path where the original bank statement file is archived. Used for audit retrieval.' ;
    rdfs:domain ind:BankStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statementFormat rdf:type rdf:Property ;
    rdfs:label 'Statement Format' ;
    rdfs:comment 'The file format or data standard of the original statement document. Used for parsing and validation logic.' ;
    rdfs:domain ind:BankStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statementNotes rdf:type rdf:Property ;
    rdfs:label 'Statement Notes' ;
    rdfs:comment 'Free-text notes or comments regarding this bank statement. May include reconciliation notes, exception explanations, or special instructions.' ;
    rdfs:domain ind:BankStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statementNumber rdf:type rdf:Property ;
    rdfs:label 'Statement Number' ;
    rdfs:comment 'The unique statement number or reference assigned by the financial institution for this statement period.' ;
    rdfs:domain ind:BankStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statementPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Statement Period End Date' ;
    rdfs:comment 'The last date covered by this bank statement period.' ;
    rdfs:domain ind:BankStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:statementPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Statement Period Start Date' ;
    rdfs:comment 'The first date covered by this bank statement period.' ;
    rdfs:domain ind:BankStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:statementSource rdf:type rdf:Property ;
    rdfs:label 'Statement Source' ;
    rdfs:comment 'The method by which this bank statement was imported or entered into the system. Indicates data provenance for audit purposes.' ;
    rdfs:domain ind:BankStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCreditCount rdf:type rdf:Property ;
    rdfs:label 'Total Credit Count' ;
    rdfs:comment 'The number of credit transactions posted during the statement period.' ;
    rdfs:domain ind:BankStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalCredits rdf:type rdf:Property ;
    rdfs:label 'Total Credits' ;
    rdfs:comment 'The sum of all credit transactions (deposits, interest, reversals) posted during the statement period.' ;
    rdfs:domain ind:BankStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDebitCount rdf:type rdf:Property ;
    rdfs:label 'Total Debit Count' ;
    rdfs:comment 'The number of debit transactions posted during the statement period.' ;
    rdfs:domain ind:BankStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalDebits rdf:type rdf:Property ;
    rdfs:label 'Total Debits' ;
    rdfs:comment 'The sum of all debit transactions (withdrawals, fees, disbursements) posted during the statement period.' ;
    rdfs:domain ind:BankStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unmatchedTransactionCount rdf:type rdf:Property ;
    rdfs:label 'Unmatched Transaction Count' ;
    rdfs:comment 'The number of bank statement line items that have not been matched to a corresponding trust ledger entry. Used to identify reconciliation exceptions.' ;
    rdfs:domain ind:BankStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transferId rdf:type rdf:Property ;
    rdfs:label 'Transfer Id' ;
    rdfs:comment 'Unique identifier for the trust transfer transaction. Primary key.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:destinationAccountId rdf:type rdf:Property ;
    rdfs:label 'Destination Account Id' ;
    rdfs:comment 'Identifier of the trust account or operating account to which funds are being transferred. Links to the account master record.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:primaryReversalOfTransferId rdf:type rdf:Property ;
    rdfs:label 'Primary Reversal Of Transfer Id' ;
    rdfs:comment 'If this transfer is a reversal or correction of a prior transfer, this field contains the trust_transfer_id of the original transaction being reversed. Null for original transfers.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Transfer .

ind:sourceAccountId rdf:type rdf:Property ;
    rdfs:label 'Source Account Id' ;
    rdfs:comment 'Identifier of the trust account from which funds are being transferred. Links to the trust account master record.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:sourceLedgerEntryId rdf:type rdf:Property ;
    rdfs:label 'Source Ledger Entry Id' ;
    rdfs:comment 'Foreign key linking to trust.trust_ledger_entry. Business justification: Links the trust transfer to the ledger entry representing the debit from the source account. Every transfer generates at least two ledger entries (debit source, credit destination) for double-entry ac' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LedgerEntry .

ind:authorizedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Authorized Timestamp' ;
    rdfs:comment 'Date and time when the trust transfer was authorized by the responsible user. Part of the audit trail for trust account governance.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:bankReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Bank Reference Number' ;
    rdfs:comment 'The external bank transaction reference, confirmation number, or trace ID provided by the financial institution for this transfer. Used for three-way reconciliation between firm ledger, bank statement, and client ledger.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:earnedFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Earned Fee Amount' ;
    rdfs:comment 'The portion of the transfer amount that represents earned legal fees being moved from trust to operating account. Null for non-fee transfers.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ioltaApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Iolta Applicable Flag' ;
    rdfs:comment 'Indicates whether this transfer involves an IOLTA account and is subject to IOLTA reporting and interest allocation rules. True if IOLTA rules apply, false otherwise.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reason rdf:type rdf:Property ;
    rdfs:label 'Reason' ;
    rdfs:comment 'Business justification or narrative explanation for the trust transfer, such as \'Earned fees per invoice INV-2024-001\', \'Client disbursement for settlement\', or \'Inter-trust reallocation per matter closure\'. Required for audit and client communication.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferDate rdf:type rdf:Property ;
    rdfs:label 'Transfer Date' ;
    rdfs:comment 'The business date on which the trust transfer was executed or is scheduled to be executed. This is the effective date for trust ledger posting and three-way reconciliation purposes.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transferNumber rdf:type rdf:Property ;
    rdfs:label 'Transfer Number' ;
    rdfs:comment 'Externally-visible business identifier for the trust transfer, formatted as TT-YYYYMMDD-NNNN for audit trail and reference purposes.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferStatus rdf:type rdf:Property ;
    rdfs:label 'Transfer Status' ;
    rdfs:comment 'Current lifecycle state of the trust transfer: draft (being prepared), pending_approval (awaiting authorization), approved (authorized but not yet executed), in_transit (processing), completed (successfully executed), failed (execution error), reversed (unwound), or cancelled (voided before execution). [ENUM-REF-CANDIDATE: draft|pending_approval|approved|in_transit|completed|failed|reversed|cancelled — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transfer Timestamp' ;
    rdfs:comment 'Precise date and time when the trust transfer transaction was executed in the system, used for audit trail and chronological sequencing.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:transferType rdf:type rdf:Property ;
    rdfs:label 'Transfer Type' ;
    rdfs:comment 'Classification of the trust transfer movement: inter-trust (between client trust accounts), trust-to-operating (earned fees transferred to firm operating account), operating-to-trust (replenishment or correction), trust-to-client (disbursement to client), client-to-trust (initial deposit), or trust-refund (return of unearned funds).' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryRetainerAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Retainer Account Id' ;
    rdfs:comment 'Reference to the specific trust account (IOLTA or client trust account) in which the retainer funds are held.' ;
    rdfs:domain ind:RetainerAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:agreedRetainerAmount rdf:type rdf:Property ;
    rdfs:label 'Agreed Retainer Amount' ;
    rdfs:comment 'The total retainer amount agreed upon in the retainer agreement, representing the initial or target balance to be held in trust.' ;
    rdfs:domain ind:RetainerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:autoReplenishmentEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Replenishment Enabled' ;
    rdfs:comment 'Indicates whether automatic replenishment is enabled for this retainer agreement. True for evergreen retainers with automatic replenishment; false otherwise.' ;
    rdfs:domain ind:RetainerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Compliance Review Date' ;
    rdfs:comment 'The date of the most recent compliance review of this retainer agreement against IOLTA rules and jurisdiction-specific trust accounting regulations.' ;
    rdfs:domain ind:RetainerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Status' ;
    rdfs:comment 'The compliance status of this retainer agreement as determined by the most recent trust accounting audit or compliance review.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initialDepositDate rdf:type rdf:Property ;
    rdfs:label 'Initial Deposit Date' ;
    rdfs:comment 'The date on which the initial retainer deposit was received and posted to the trust account.' ;
    rdfs:domain ind:RetainerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:interestBearing rdf:type rdf:Property ;
    rdfs:label 'Interest Bearing' ;
    rdfs:comment 'Indicates whether the retainer funds are held in an interest-bearing trust account (IOLTA) or a non-interest-bearing account, per jurisdiction-specific trust accounting rules.' ;
    rdfs:domain ind:RetainerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:refundDueAmount rdf:type rdf:Property ;
    rdfs:label 'Refund Due Amount' ;
    rdfs:comment 'The amount due to be refunded to the client upon termination or conclusion of the retainer agreement, representing unused retainer funds.' ;
    rdfs:domain ind:RetainerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:refundProcessedDate rdf:type rdf:Property ;
    rdfs:label 'Refund Processed Date' ;
    rdfs:comment 'The date on which any refund of unused retainer funds was processed and returned to the client. Null if no refund has been processed.' ;
    rdfs:domain ind:RetainerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:replenishmentAmount rdf:type rdf:Property ;
    rdfs:label 'Replenishment Amount' ;
    rdfs:comment 'The amount to be deposited when the retainer balance falls below the replenishment threshold (applicable to evergreen retainers). Null for non-evergreen retainers.' ;
    rdfs:domain ind:RetainerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:replenishmentThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Replenishment Threshold Amount' ;
    rdfs:comment 'The minimum balance threshold below which the retainer must be replenished (applicable to evergreen retainers). Null for non-evergreen retainers.' ;
    rdfs:domain ind:RetainerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retainerAgreementStatus rdf:type rdf:Property ;
    rdfs:label 'Retainer Agreement Status' ;
    rdfs:comment 'Current lifecycle status of the retainer agreement: draft (not yet executed), active (in force and available for draw), suspended (temporarily inactive), depleted (balance exhausted), expired (past end date), terminated (closed by client or firm).' ;
    rdfs:domain ind:RetainerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retainerDescription rdf:type rdf:Property ;
    rdfs:label 'Retainer Description' ;
    rdfs:comment 'Detailed description of the retainer agreement, including the scope of work covered, any special terms, and client-specific arrangements.' ;
    rdfs:domain ind:RetainerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalDeposits rdf:type rdf:Property ;
    rdfs:label 'Total Deposits' ;
    rdfs:comment 'The cumulative total of all deposits made to this retainer agreement since inception, including initial deposit and all replenishments.' ;
    rdfs:domain ind:RetainerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDisbursements rdf:type rdf:Property ;
    rdfs:label 'Total Disbursements' ;
    rdfs:comment 'The cumulative total of all disbursements drawn from this retainer agreement since inception, representing work performed and billed against the retainer.' ;
    rdfs:domain ind:RetainerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depositorIntakePartyId rdf:type rdf:Property ;
    rdfs:label 'Depositor Intake Party Id' ;
    rdfs:comment 'Foreign key linking to intake.intake_party. Business justification: The escrow depositor is an intake party with KYC/AML screening records. Replacing denormalized depositor_party_name/role with a FK to intake_party enforces 3NF and links escrow funds to the screened p' ;
    rdfs:domain ind:EscrowArrangement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IntakeParty .

ind:primaryEscrowAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Escrow Account Id' ;
    rdfs:comment 'Reference to the underlying trust bank account holding the escrowed funds, subject to IOLTA regulations.' ;
    rdfs:domain ind:EscrowArrangement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:beneficiaryPartyName rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Party Name' ;
    rdfs:comment 'Name of the party or entity entitled to receive funds upon satisfaction of release conditions (e.g., seller, indemnified party).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficiaryPartyRole rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Party Role' ;
    rdfs:comment 'Role of the beneficiary party in the underlying transaction.' ;
    rdfs:domain ind:EscrowArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureReason rdf:type rdf:Property ;
    rdfs:label 'Closure Reason' ;
    rdfs:comment 'Reason for closing the escrow arrangement, documenting the final disposition of the escrow.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeDescription rdf:type rdf:Property ;
    rdfs:label 'Dispute Description' ;
    rdfs:comment 'Detailed description of any active dispute affecting the escrow, including parties involved, nature of disagreement, and current resolution status.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escrowAgentName rdf:type rdf:Property ;
    rdfs:label 'Escrow Agent Name' ;
    rdfs:comment 'Name of the law firm, attorney, or third-party institution acting as escrow agent and fiduciary holder of the funds.' ;
    rdfs:domain ind:EscrowArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escrowAgreementReference rdf:type rdf:Property ;
    rdfs:label 'Escrow Agreement Reference' ;
    rdfs:comment 'Document reference or identifier for the governing escrow agreement that defines terms, conditions, and release triggers.' ;
    rdfs:domain ind:EscrowArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escrowAmount rdf:type rdf:Property ;
    rdfs:label 'Escrow Amount' ;
    rdfs:comment 'Total monetary amount held in escrow at establishment, representing the initial deposit or holdback amount.' ;
    rdfs:domain ind:EscrowArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:escrowPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Escrow Period End Date' ;
    rdfs:comment 'Scheduled end date of the escrow holding period, after which remaining funds may be released per agreement terms or extended by mutual consent.' ;
    rdfs:domain ind:EscrowArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:escrowPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Escrow Period Start Date' ;
    rdfs:comment 'Start date of the escrow holding period as defined in the escrow agreement, from which release conditions and timelines are measured.' ;
    rdfs:domain ind:EscrowArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:escrowPurpose rdf:type rdf:Property ;
    rdfs:label 'Escrow Purpose' ;
    rdfs:comment 'Detailed description of the business purpose for which the escrow was established (e.g., M&A purchase price holdback, indemnity reserve, real estate deposit, earnout payment reserve).' ;
    rdfs:domain ind:EscrowArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escrowStatus rdf:type rdf:Property ;
    rdfs:label 'Escrow Status' ;
    rdfs:comment 'Current lifecycle status of the escrow arrangement indicating its operational state and release progress.' ;
    rdfs:domain ind:EscrowArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:establishmentDate rdf:type rdf:Property ;
    rdfs:label 'Establishment Date' ;
    rdfs:comment 'Date on which the escrow arrangement was formally established and funds were initially deposited into escrow.' ;
    rdfs:domain ind:EscrowArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:governingLawJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Governing Law Jurisdiction' ;
    rdfs:comment 'Legal jurisdiction whose laws govern the escrow agreement and fund administration (e.g., State of Delaware, England and Wales).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interestAllocationMethod rdf:type rdf:Property ;
    rdfs:label 'Interest Allocation Method' ;
    rdfs:comment 'Method by which accrued interest on escrowed funds is allocated, in compliance with IOLTA regulations and escrow agreement.' ;
    rdfs:domain ind:EscrowArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Last Release Date' ;
    rdfs:comment 'Date of the most recent release or disbursement event from this escrow arrangement.' ;
    rdfs:domain ind:EscrowArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:releaseConditions rdf:type rdf:Property ;
    rdfs:label 'Release Conditions' ;
    rdfs:comment 'Detailed description of the conditions, milestones, or events that must be satisfied before funds can be released from escrow (e.g., completion of due diligence, satisfaction of indemnity claims, passage of time).' ;
    rdfs:domain ind:EscrowArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseScheduleType rdf:type rdf:Property ;
    rdfs:label 'Release Schedule Type' ;
    rdfs:comment 'Classification of the release mechanism governing how and when escrowed funds are disbursed.' ;
    rdfs:domain ind:EscrowArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalReleasedAmount rdf:type rdf:Property ;
    rdfs:label 'Total Released Amount' ;
    rdfs:comment 'Cumulative total amount released from escrow to date across all release events. Calculated field maintained for reporting and reconciliation.' ;
    rdfs:domain ind:EscrowArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryReportId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Id' ;
    rdfs:comment 'Unique identifier for the trust regulatory report. Primary key.' ;
    rdfs:domain ind:RegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acknowledgmentDate rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Date' ;
    rdfs:comment 'Date on which the regulatory body acknowledged receipt of the report.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:acknowledgmentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Reference Number' ;
    rdfs:comment 'Reference number or confirmation code issued by the regulatory body upon receipt or acknowledgment of the report.' ;
    rdfs:domain ind:RegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditReportReference rdf:type rdf:Property ;
    rdfs:label 'Audit Report Reference' ;
    rdfs:comment 'Reference number or identifier of the external audit report accompanying this regulatory submission, if applicable.' ;
    rdfs:domain ind:RegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationDate rdf:type rdf:Property ;
    rdfs:label 'Certification Date' ;
    rdfs:comment 'Date on which the certifying attorney signed and certified the report.' ;
    rdfs:domain ind:RegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceCertificationFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Certification Flag' ;
    rdfs:comment 'Boolean flag indicating whether the report includes a formal compliance certification by a responsible attorney or accountant.' ;
    rdfs:domain ind:RegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discrepancyExplanation rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Explanation' ;
    rdfs:comment 'Detailed explanation of any discrepancies or irregularities identified in the trust account reconciliation.' ;
    rdfs:domain ind:RegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalAuditorName rdf:type rdf:Property ;
    rdfs:label 'External Auditor Name' ;
    rdfs:comment 'Name of the external auditor or accounting firm that reviewed or audited the trust account records for this report, if applicable.' ;
    rdfs:domain ind:RegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ioltaInterestEarned rdf:type rdf:Property ;
    rdfs:label 'Iolta Interest Earned' ;
    rdfs:comment 'Total interest earned on IOLTA accounts during the reporting period, if applicable.' ;
    rdfs:domain ind:RegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ioltaInterestRemitted rdf:type rdf:Property ;
    rdfs:label 'Iolta Interest Remitted' ;
    rdfs:comment 'Total interest remitted to the IOLTA program or designated beneficiary during the reporting period.' ;
    rdfs:domain ind:RegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isOverdue rdf:type rdf:Property ;
    rdfs:label 'Is Overdue' ;
    rdfs:comment 'Boolean flag indicating whether the report submission is past its regulatory due date.' ;
    rdfs:domain ind:RegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:numberOfClientAccounts rdf:type rdf:Property ;
    rdfs:label 'Number Of Client Accounts' ;
    rdfs:comment 'Count of individual client trust accounts included in this regulatory report.' ;
    rdfs:domain ind:RegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numberOfTransactions rdf:type rdf:Property ;
    rdfs:label 'Number Of Transactions' ;
    rdfs:comment 'Total count of trust transactions (receipts and disbursements) during the reporting period.' ;
    rdfs:domain ind:RegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preparedDate rdf:type rdf:Property ;
    rdfs:label 'Prepared Date' ;
    rdfs:comment 'Date on which the regulatory report was prepared and finalized internally.' ;
    rdfs:domain ind:RegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:queryDetails rdf:type rdf:Property ;
    rdfs:label 'Query Details' ;
    rdfs:comment 'Details of any queries or follow-up requests issued by the regulatory body in response to this report.' ;
    rdfs:domain ind:RegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryBodyName rdf:type rdf:Property ;
    rdfs:label 'Regulatory Body Name' ;
    rdfs:comment 'Name of the regulatory authority or oversight body to which this report is submitted (e.g., State Bar Association, Solicitors Regulation Authority, Law Society).' ;
    rdfs:domain ind:RegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryQueryFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Query Flag' ;
    rdfs:comment 'Boolean flag indicating whether the regulatory body has raised queries or requested additional information regarding this report.' ;
    rdfs:domain ind:RegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportFormat rdf:type rdf:Property ;
    rdfs:label 'Report Format' ;
    rdfs:comment 'File format or medium in which the report was prepared and submitted.' ;
    rdfs:domain ind:RegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportNumber rdf:type rdf:Property ;
    rdfs:label 'Report Number' ;
    rdfs:comment 'Unique business identifier for the regulatory report, often assigned by the firm or regulatory body.' ;
    rdfs:domain ind:RegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportStatus rdf:type rdf:Property ;
    rdfs:label 'Report Status' ;
    rdfs:comment 'Current lifecycle status of the regulatory report in the submission and review workflow. [ENUM-REF-CANDIDATE: draft|submitted|acknowledged|under_review|queried|accepted|rejected — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportType rdf:type rdf:Property ;
    rdfs:label 'Report Type' ;
    rdfs:comment 'Classification of the regulatory report type as required by the governing jurisdiction or regulatory body.' ;
    rdfs:domain ind:RegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Reporting Period End Date' ;
    rdfs:comment 'End date of the period covered by this regulatory report.' ;
    rdfs:domain ind:RegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Start Date' ;
    rdfs:comment 'Start date of the period covered by this regulatory report.' ;
    rdfs:domain ind:RegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responseDueDate rdf:type rdf:Property ;
    rdfs:label 'Response Due Date' ;
    rdfs:comment 'Deadline by which the firm must respond to regulatory queries or provide additional information.' ;
    rdfs:domain ind:RegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:submissionDate rdf:type rdf:Property ;
    rdfs:label 'Submission Date' ;
    rdfs:comment 'Date on which the report was officially submitted to the regulatory authority.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:submissionMethod rdf:type rdf:Property ;
    rdfs:label 'Submission Method' ;
    rdfs:comment 'Method or channel used to submit the report to the regulatory body.' ;
    rdfs:domain ind:RegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalTrustBalanceReported rdf:type rdf:Property ;
    rdfs:label 'Total Trust Balance Reported' ;
    rdfs:comment 'Total balance of client trust funds reported for the period, as declared in the regulatory report.' ;
    rdfs:domain ind:RegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prospectId rdf:type rdf:Property ;
    rdfs:label 'Prospect Id' ;
    rdfs:comment 'Unique identifier for the prospect record. Primary key for the prospect entity representing a pre-engagement organization or individual in the new business intake pipeline.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Prospect .

ind:competitorFirms rdf:type rdf:Property ;
    rdfs:label 'Competitor Firms' ;
    rdfs:comment 'Names of competing law firms known to be pitching for the same engagement. Used for competitive intelligence and win/loss analysis.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conflictsSystemReference rdf:type rdf:Property ;
    rdfs:label 'Conflicts System Reference' ;
    rdfs:comment 'External identifier linking this prospect to the new business intake record in Intapp Conflicts system. Used for conflict check workflow integration.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:convertedToClientDate rdf:type rdf:Property ;
    rdfs:label 'Converted To Client Date' ;
    rdfs:comment 'Date on which the prospect was successfully converted to a formal client upon Letter of Engagement (LOE) execution and matter opening. Nullable until conversion occurs.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:crmAccountReference rdf:type rdf:Property ;
    rdfs:label 'Crm Account Reference' ;
    rdfs:comment 'External identifier linking this prospect to the corresponding account or lead record in Microsoft Dynamics 365 CRM. Enables bi-directional synchronization.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disqualificationReason rdf:type rdf:Property ;
    rdfs:label 'Disqualification Reason' ;
    rdfs:comment 'Reason for disqualifying or declining the prospect opportunity. Populated when pipeline stage moves to lost or declined. Used for loss analysis and process improvement.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementScopeSummary rdf:type rdf:Property ;
    rdfs:label 'Engagement Scope Summary' ;
    rdfs:comment 'High-level description of the prospective engagement scope, legal services required, and business objectives. Used for practice group routing and conflict assessment.' ;
    rdfs:domain ind:Intake ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedValueCurrency rdf:type rdf:Property ;
    rdfs:label 'Estimated Value Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the estimated matter value. Supports multi-currency pipeline reporting.' ;
    rdfs:domain ind:Intake ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedDecisionDate rdf:type rdf:Property ;
    rdfs:label 'Expected Decision Date' ;
    rdfs:comment 'Anticipated date by which the prospect is expected to make a decision on the engagement. Used for pipeline forecasting and follow-up scheduling.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pipelineStage rdf:type rdf:Property ;
    rdfs:label 'Pipeline Stage' ;
    rdfs:comment 'Current stage of the prospect in the new business intake pipeline. Tracks progression from initial lead through to engagement or disqualification. [ENUM-REF-CANDIDATE: lead|qualified|pitch_scheduled|proposal_submitted|negotiation|won|lost|on_hold — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pitchDate rdf:type rdf:Property ;
    rdfs:label 'Pitch Date' ;
    rdfs:comment 'Date of the formal pitch or presentation to the prospect. Nullable if no pitch meeting is scheduled or has occurred.' ;
    rdfs:domain ind:Intake ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:primaryContactName rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Name' ;
    rdfs:comment 'Full name of the primary contact person at the prospect organization or the individual prospect themselves. Key relationship owner for intake communications.' ;
    rdfs:domain ind:Intake ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposalSubmittedDate rdf:type rdf:Property ;
    rdfs:label 'Proposal Submitted Date' ;
    rdfs:comment 'Date on which the formal engagement proposal or fee quote was submitted to the prospect.' ;
    rdfs:domain ind:Intake ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:proposedFeeArrangementType rdf:type rdf:Property ;
    rdfs:label 'Proposed Fee Arrangement Type' ;
    rdfs:comment 'The proposed billing structure or Alternative Fee Arrangement (AFA) for the prospective engagement. Influences pricing strategy and profitability analysis. [ENUM-REF-CANDIDATE: hourly|fixed_fee|contingency|afa_blended|afa_capped|retainer|success_fee|hybrid — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Intake ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prospectName rdf:type rdf:Property ;
    rdfs:label 'Prospect Name' ;
    rdfs:comment 'The legal or trading name of the prospective client organization or individual. For organizations, this is the registered business name; for individuals, the full legal name.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prospectType rdf:type rdf:Property ;
    rdfs:label 'Prospect Type' ;
    rdfs:comment 'Classification of the prospect entity type. Determines the intake workflow, KYC requirements, and conflict checking scope.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralDate rdf:type rdf:Property ;
    rdfs:label 'Referral Date' ;
    rdfs:comment 'Date on which the prospect was referred to the firm. Nullable if the prospect source is not a referral. Used for referral attribution and relationship tracking.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:referralSourceType rdf:type rdf:Property ;
    rdfs:label 'Referral Source Type' ;
    rdfs:comment 'Classification of the referring party when the prospect source is a referral. Used for referral network analytics and attribution reporting.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referringPartyName rdf:type rdf:Property ;
    rdfs:label 'Referring Party Name' ;
    rdfs:comment 'Name of the individual or organization that referred this prospect. Nullable if the prospect source is not a referral.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfpReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Rfp Received Date' ;
    rdfs:comment 'Date on which a formal Request for Proposal (RFP) or engagement inquiry was received from the prospect. Nullable if no formal RFP was issued.' ;
    rdfs:domain ind:Intake ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rfpResponseDueDate rdf:type rdf:Property ;
    rdfs:label 'Rfp Response Due Date' ;
    rdfs:comment 'Deadline for submitting the proposal or RFP response to the prospect. Used for intake workflow prioritization and resource scheduling.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceType rdf:type rdf:Property ;
    rdfs:label 'Source Type' ;
    rdfs:comment 'The channel or method through which the prospect entered the new business intake pipeline. Used for business development attribution and marketing effectiveness analysis. [ENUM-REF-CANDIDATE: rfp|referral|bd_outreach|directory|conference|panel|alumni_network|existing_client|website_inquiry|cold_contact — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Intake ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:winProbabilityPercent rdf:type rdf:Property ;
    rdfs:label 'Win Probability Percent' ;
    rdfs:comment 'Estimated probability of winning the engagement expressed as a percentage (0.00 to 100.00). Used for weighted pipeline forecasting and resource planning.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:issuingOrganisationId rdf:type rdf:Property ;
    rdfs:label 'Issuing Organisation Id' ;
    rdfs:comment 'Reference to the prospective or existing client organisation that issued this RFP.' ;
    rdfs:domain ind:RfpSubmission ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Organisation .

ind:primaryProspectId rdf:type rdf:Property ;
    rdfs:label 'Primary Prospect Id' ;
    rdfs:comment 'FK to intake.prospect.prospect_id — Every RFP is received from a prospect — this FK is required for pipeline attribution and BD reporting. Without it, RFPs cannot be associated with their originating prospect.' ;
    rdfs:domain ind:RfpSubmission ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Prospect .

ind:resultingMatterId rdf:type rdf:Property ;
    rdfs:label 'Resulting Matter Id' ;
    rdfs:comment 'Reference to the matter record created in Elite 3E if the RFP was awarded and the engagement proceeded to matter opening.' ;
    rdfs:domain ind:RfpSubmission ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Matter .

ind:rfpProspectId rdf:type rdf:Property ;
    rdfs:label 'Rfp Prospect Id' ;
    rdfs:comment 'FK to intake.prospect.prospect_id — Every RFP is received from a prospect or existing client. The prospect FK is essential for tracking which prospects are generating RFP activity and for pipeline reporting.' ;
    rdfs:domain ind:RfpSubmission ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Prospect .

ind:competitiveFirms rdf:type rdf:Property ;
    rdfs:label 'Competitive Firms' ;
    rdfs:comment 'Names or identifiers of other law firms known to be competing for this RFP, if disclosed by the client or identified through market intelligence.' ;
    rdfs:domain ind:RfpSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conflictCheckCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Conflict Check Completed Date' ;
    rdfs:comment 'The date on which the conflict check process was completed for this RFP submission.' ;
    rdfs:domain ind:Intake ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:decisionOutcome rdf:type rdf:Property ;
    rdfs:label 'Decision Outcome' ;
    rdfs:comment 'The final outcome of the RFP process from the client\'s perspective (awarded to the firm, declined, no decision made, or withdrawn by client).' ;
    rdfs:domain ind:RfpSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Decision Received Date' ;
    rdfs:comment 'The date on which the firm received notification of the client\'s decision regarding the RFP (awarded, declined, or no decision).' ;
    rdfs:domain ind:RfpSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:declineReason rdf:type rdf:Property ;
    rdfs:label 'Decline Reason' ;
    rdfs:comment 'The reason why the firm declined to respond to the RFP or why the client declined the firm\'s proposal. [ENUM-REF-CANDIDATE: conflict_of_interest|capacity_constraints|fee_expectations|practice_area_mismatch|strategic_fit|competitive_pricing|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RfpSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declineReasonNotes rdf:type rdf:Property ;
    rdfs:label 'Decline Reason Notes' ;
    rdfs:comment 'Additional free-text notes providing context or details about the decline reason.' ;
    rdfs:domain ind:RfpSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedValueAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Value Amount' ;
    rdfs:comment 'The estimated monetary value of the engagement or matter if it proceeds, as assessed by the business development team during initial qualification.' ;
    rdfs:domain ind:RfpSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gdprCompliant rdf:type rdf:Property ;
    rdfs:label 'Gdpr Compliant' ;
    rdfs:comment 'Boolean flag indicating whether the RFP and proposed engagement scope comply with GDPR requirements, relevant for EU-based clients or matters involving EU personal data.' ;
    rdfs:domain ind:RfpSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isExistingClient rdf:type rdf:Property ;
    rdfs:label 'Is Existing Client' ;
    rdfs:comment 'Boolean flag indicating whether the issuing organisation is an existing client of the firm (True) or a prospective new client (False).' ;
    rdfs:domain ind:RfpSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:matterType rdf:type rdf:Property ;
    rdfs:label 'Matter Type' ;
    rdfs:comment 'The specific type of legal matter or engagement being requested (e.g., M&A transaction, patent prosecution, employment dispute, regulatory investigation).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresPanelApproval rdf:type rdf:Property ;
    rdfs:label 'Requires Panel Approval' ;
    rdfs:comment 'Boolean flag indicating whether this RFP requires approval from a client\'s legal panel or preferred provider list.' ;
    rdfs:domain ind:RfpSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responseDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Response Deadline Date' ;
    rdfs:comment 'The date by which the firm must submit its response to the RFP, as specified by the issuing organisation.' ;
    rdfs:domain ind:RfpSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responseDeadlineTime rdf:type rdf:Property ;
    rdfs:label 'Response Deadline Time' ;
    rdfs:comment 'The precise timestamp (including time of day) by which the RFP response must be submitted, if specified by the issuing organisation.' ;
    rdfs:domain ind:RfpSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rfpDescription rdf:type rdf:Property ;
    rdfs:label 'Rfp Description' ;
    rdfs:comment 'Detailed description of the legal services being requested, including scope, objectives, and key requirements outlined in the RFP document.' ;
    rdfs:domain ind:RfpSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfpReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Rfp Reference Number' ;
    rdfs:comment 'The external reference number or identifier assigned by the issuing organisation to this RFP. This is the business identifier used in client communications.' ;
    rdfs:domain ind:RfpSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfpTitle rdf:type rdf:Property ;
    rdfs:label 'Rfp Title' ;
    rdfs:comment 'The title or subject of the RFP as provided by the issuing organisation.' ;
    rdfs:domain ind:RfpSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceChannel rdf:type rdf:Property ;
    rdfs:label 'Source Channel' ;
    rdfs:comment 'The channel or method through which the RFP was received by the firm (e.g., email, client portal, direct mail, referral, existing client relationship). [ENUM-REF-CANDIDATE: email|portal|direct_mail|referral|existing_client|conference|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RfpSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionStatus rdf:type rdf:Property ;
    rdfs:label 'Submission Status' ;
    rdfs:comment 'The current lifecycle status of the RFP submission within the firm\'s intake workflow (received, under review, declined, responded, withdrawn, awarded).' ;
    rdfs:domain ind:RfpSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:winProbabilityPercentage rdf:type rdf:Property ;
    rdfs:label 'Win Probability Percentage' ;
    rdfs:comment 'The estimated probability (0-100%) that the firm will win this RFP, as assessed by the pitch team or business development team.' ;
    rdfs:domain ind:RfpSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pitchId rdf:type rdf:Property ;
    rdfs:label 'Pitch Id' ;
    rdfs:comment 'Unique identifier for the pitch record. Primary key.' ;
    rdfs:domain ind:Intake ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Pitch .

ind:pitchLegalDocumentId rdf:type rdf:Property ;
    rdfs:label 'Pitch Legal Document Id' ;
    rdfs:comment 'Reference to the pitch deck or credentials presentation document stored in the Document Management System (iManage Work or NetDocuments).' ;
    rdfs:domain ind:Pitch ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalDocument .

ind:pitchProposalLegalDocumentId rdf:type rdf:Property ;
    rdfs:label 'Pitch Proposal Legal Document Id' ;
    rdfs:comment 'Reference to the written proposal document submitted as part of the pitch, stored in the Document Management System.' ;
    rdfs:domain ind:Pitch ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalDocument .

ind:clientAttendees rdf:type rdf:Property ;
    rdfs:label 'Client Attendees' ;
    rdfs:comment 'Names and titles of client representatives who attended the pitch, captured for relationship tracking and follow-up. Comma-separated list.' ;
    rdfs:domain ind:Pitch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competingFirms rdf:type rdf:Property ;
    rdfs:label 'Competing Firms' ;
    rdfs:comment 'Names of known competing law firms participating in the pitch process, if disclosed by the client. Comma-separated list.' ;
    rdfs:domain ind:Pitch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitiveContext rdf:type rdf:Property ;
    rdfs:label 'Competitive Context' ;
    rdfs:comment 'Indicates whether the pitch was sole-sourced or competitive, and if competitive, the approximate number of competing firms: sole_pitch (no competition), competitive_2_firms, competitive_3_firms, competitive_4plus_firms, or unknown.' ;
    rdfs:domain ind:Pitch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costEstimate rdf:type rdf:Property ;
    rdfs:label 'Cost Estimate' ;
    rdfs:comment 'Estimated total cost to the firm of pursuing the pitch, including attorney time, travel, materials, and external consultants. Used for BD ROI analysis.' ;
    rdfs:domain ind:Pitch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:durationMinutes rdf:type rdf:Property ;
    rdfs:label 'Duration Minutes' ;
    rdfs:comment 'Total duration of the pitch presentation in minutes, including Q&A if applicable.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:followUpDueDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Due Date' ;
    rdfs:comment 'Target date by which post-pitch follow-up actions must be completed, if applicable.' ;
    rdfs:domain ind:Pitch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:followUpRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Follow Up Required Flag' ;
    rdfs:comment 'Indicates whether post-pitch follow-up actions are required (e.g., additional information requests, clarifications, supplemental proposals). True if follow-up is needed, False otherwise.' ;
    rdfs:domain ind:Pitch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:location rdf:type rdf:Property ;
    rdfs:label 'Location' ;
    rdfs:comment 'Physical location or virtual platform where the pitch was delivered (e.g., client office address, firm office, video conference platform).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lossReasonCode rdf:type rdf:Property ;
    rdfs:label 'Loss Reason Code' ;
    rdfs:comment 'Standardized code or category explaining why the pitch was lost, if applicable (e.g., fee too high, lack of experience, conflict of interest, relationship with competitor, client chose incumbent). Used for win/loss analysis and BD strategy refinement.' ;
    rdfs:domain ind:Pitch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outcomeDate rdf:type rdf:Property ;
    rdfs:label 'Outcome Date' ;
    rdfs:comment 'Date on which the pitch outcome was communicated to the firm by the client or became known.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pitchName rdf:type rdf:Property ;
    rdfs:label 'Pitch Name' ;
    rdfs:comment 'Descriptive name or title of the pitch, typically reflecting the matter type or client engagement scope being pursued.' ;
    rdfs:domain ind:Pitch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pitchStatus rdf:type rdf:Property ;
    rdfs:label 'Pitch Status' ;
    rdfs:comment 'Current lifecycle status of the pitch: scheduled (pitch date set but not yet delivered), delivered (pitch completed, awaiting outcome), won (firm selected), lost (firm not selected), pending (outcome not yet known), withdrawn (firm withdrew from consideration), or no_decision (client did not proceed with engagement). [ENUM-REF-CANDIDATE: scheduled|delivered|won|lost|pending|withdrawn|no_decision — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Pitch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pitchType rdf:type rdf:Property ;
    rdfs:label 'Pitch Type' ;
    rdfs:comment 'Classification of the pitch format: beauty parade (competitive multi-firm presentation), credentials deck (written credentials submission), oral presentation (in-person or virtual pitch), written proposal (detailed written submission), panel interview (Q&A with client panel), or finalist presentation (final round competitive pitch).' ;
    rdfs:domain ind:Pitch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preparationHours rdf:type rdf:Property ;
    rdfs:label 'Preparation Hours' ;
    rdfs:comment 'Total non-billable hours invested by the firm in preparing for the pitch, including research, deck creation, rehearsal, and travel. Used for BD cost analysis.' ;
    rdfs:domain ind:Pitch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proposedFeeArrangement rdf:type rdf:Property ;
    rdfs:label 'Proposed Fee Arrangement' ;
    rdfs:comment 'Type of fee arrangement proposed in the pitch: hourly (standard time-based billing), fixed_fee (flat fee for scope), capped_fee (hourly with upper limit), contingency (success-based), blended_rate (single rate for all timekeepers), afa_other (alternative fee arrangement not otherwise specified), retainer (ongoing monthly/quarterly fee), or success_fee (bonus upon outcome). [ENUM-REF-CANDIDATE: hourly|fixed_fee|capped_fee|contingency|blended_rate|afa_other|retainer|success_fee — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Pitch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfp rdf:type rdf:Property ;
    rdfs:label 'Rfp' ;
    rdfs:comment 'FK to intake.rfp_submission.rfp_submission_id — Pitches are made in response to RFPs — this FK links the response activity to the triggering request. Critical for win/loss analysis.' ;
    rdfs:domain ind:Pitch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rfpSubmission rdf:type rdf:Property ;
    rdfs:label 'Rfp Submission' ;
    rdfs:comment 'FK to intake.rfp_submission.rfp_submission_id — Pitches are made in response to RFPs. This link is critical for tracking RFP-to-pitch conversion rates and pipeline progression.' ;
    rdfs:domain ind:Pitch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:score rdf:type rdf:Property ;
    rdfs:label 'Score' ;
    rdfs:comment 'Internal qualitative or quantitative score assigned to the pitch performance by the pitch team or BD leadership, used for continuous improvement. Scale and methodology defined by firm policy.' ;
    rdfs:domain ind:Pitch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:teamSize rdf:type rdf:Property ;
    rdfs:label 'Team Size' ;
    rdfs:comment 'Total number of attorneys and professionals from the firm who participated in the pitch presentation or preparation.' ;
    rdfs:domain ind:Pitch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:winLossNotes rdf:type rdf:Property ;
    rdfs:label 'Win Loss Notes' ;
    rdfs:comment 'Free-text narrative capturing detailed feedback from the client or internal debrief regarding the pitch outcome, including strengths, weaknesses, and lessons learned.' ;
    rdfs:domain ind:Pitch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:winReasonCode rdf:type rdf:Property ;
    rdfs:label 'Win Reason Code' ;
    rdfs:comment 'Standardized code or category explaining why the pitch was won, if applicable (e.g., expertise, relationship, fee competitiveness, innovation, diversity). Used for win/loss analysis and BD strategy refinement.' ;
    rdfs:domain ind:Pitch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryEngagementProspectId rdf:type rdf:Property ;
    rdfs:label 'Primary Engagement Prospect Id' ;
    rdfs:comment 'Reference to the prospective client or existing client organization pursuing this opportunity.' ;
    rdfs:domain ind:EngagementOpportunity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Prospect .

ind:actualCloseDate rdf:type rdf:Property ;
    rdfs:label 'Actual Close Date' ;
    rdfs:comment 'Actual date the opportunity was closed (won or lost).' ;
    rdfs:domain ind:EngagementOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:competitorName rdf:type rdf:Property ;
    rdfs:label 'Competitor Name' ;
    rdfs:comment 'Name of the competing law firm or ALSP that won the engagement, if known.' ;
    rdfs:domain ind:EngagementOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dynamicsOpportunityGuid rdf:type rdf:Property ;
    rdfs:label 'Dynamics Opportunity Guid' ;
    rdfs:comment 'Globally unique identifier (GUID) of the corresponding Opportunity record in Microsoft Dynamics 365 CRM.' ;
    rdfs:domain ind:EngagementOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eliteMatterNumber rdf:type rdf:Property ;
    rdfs:label 'Elite Matter Number' ;
    rdfs:comment 'The matter number assigned in Elite 3E if the opportunity was converted to an active matter.' ;
    rdfs:domain ind:EngagementOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementProspect rdf:type rdf:Property ;
    rdfs:label 'Engagement Prospect' ;
    rdfs:comment 'FK to intake.prospect.prospect_id — Each engagement opportunity is associated with a prospect. This is the core CRM pipeline link.' ;
    rdfs:domain ind:EngagementOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expectedCloseDate rdf:type rdf:Property ;
    rdfs:label 'Expected Close Date' ;
    rdfs:comment 'Forecasted date by which the opportunity will reach a closed-won or closed-lost decision.' ;
    rdfs:domain ind:EngagementOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expectedMatterOpenDate rdf:type rdf:Property ;
    rdfs:label 'Expected Matter Open Date' ;
    rdfs:comment 'Anticipated date the matter will be opened in Elite 3E if the opportunity is won.' ;
    rdfs:domain ind:EngagementOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:kycCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Kyc Completed Date' ;
    rdfs:comment 'Date the KYC and AML due diligence was completed for this opportunity.' ;
    rdfs:domain ind:EngagementOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leadSource rdf:type rdf:Property ;
    rdfs:label 'Lead Source' ;
    rdfs:comment 'Channel or method through which the opportunity was generated. [ENUM-REF-CANDIDATE: referral|existing_client|rfp|conference|website|cold_outreach|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:EngagementOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loeExecutedDate rdf:type rdf:Property ;
    rdfs:label 'Loe Executed Date' ;
    rdfs:comment 'Date the Letter of Engagement was signed by both the firm and the client, formalizing the engagement.' ;
    rdfs:domain ind:Intake ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lossReason rdf:type rdf:Property ;
    rdfs:label 'Loss Reason' ;
    rdfs:comment 'Primary reason the opportunity was lost (e.g., fee, competitor selected, timing, conflict).' ;
    rdfs:domain ind:EngagementOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matterOpenedInEliteFlag rdf:type rdf:Property ;
    rdfs:label 'Matter Opened In Elite Flag' ;
    rdfs:comment 'Indicates whether a corresponding matter has been opened in Elite 3E following a closed-won opportunity.' ;
    rdfs:domain ind:EngagementOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:opportunityName rdf:type rdf:Property ;
    rdfs:label 'Opportunity Name' ;
    rdfs:comment 'Descriptive name of the engagement opportunity, typically reflecting the matter type or transaction name.' ;
    rdfs:domain ind:EngagementOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opportunityNumber rdf:type rdf:Property ;
    rdfs:label 'Opportunity Number' ;
    rdfs:comment 'Business-facing unique identifier for the opportunity, typically generated by Microsoft Dynamics 365 CRM.' ;
    rdfs:domain ind:EngagementOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opportunityStage rdf:type rdf:Property ;
    rdfs:label 'Opportunity Stage' ;
    rdfs:comment 'Current stage of the opportunity in the business development pipeline.' ;
    rdfs:domain ind:EngagementOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pitchTeamNotes rdf:type rdf:Property ;
    rdfs:label 'Pitch Team Notes' ;
    rdfs:comment 'Internal notes and observations from the pitch team regarding client needs, competitive positioning, and strategy.' ;
    rdfs:domain ind:EngagementOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:probabilityPercent rdf:type rdf:Property ;
    rdfs:label 'Probability Percent' ;
    rdfs:comment 'Estimated probability of converting this opportunity to a matter, expressed as a percentage (0.00 to 100.00).' ;
    rdfs:domain ind:EngagementOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proposalDueDate rdf:type rdf:Property ;
    rdfs:label 'Proposal Due Date' ;
    rdfs:comment 'Deadline by which the firm must submit its proposal or pitch to the prospect.' ;
    rdfs:domain ind:EngagementOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:prospect rdf:type rdf:Property ;
    rdfs:label 'Prospect' ;
    rdfs:comment 'FK to intake.prospect.prospect_id — Each engagement opportunity is associated with a prospect. Required for pipeline conversion reporting.' ;
    rdfs:domain ind:EngagementOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceCampaign rdf:type rdf:Property ;
    rdfs:label 'Source Campaign' ;
    rdfs:comment 'Marketing campaign or business development initiative that generated this opportunity.' ;
    rdfs:domain ind:EngagementOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibilityRuleId rdf:type rdf:Property ;
    rdfs:label 'Eligibility Rule Id' ;
    rdfs:comment 'Foreign key linking to service.eligibility_rule. Business justification: Eligibility rules are evaluated during intake to determine if a client qualifies for a service; this link provides the audit trail of which rule was applied and enables automated eligibility checking ' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EligibilityRule .

ind:adverseParties rdf:type rdf:Property ;
    rdfs:label 'Adverse Parties' ;
    rdfs:comment 'Names of opposing parties, counterparties, or other entities adverse to the client\'s interests. Critical for conflict checking and ethical wall determination.' ;
    rdfs:domain ind:Request ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approval Timestamp' ;
    rdfs:comment 'Date and time when the engagement was formally approved and authorized to proceed to matter opening.' ;
    rdfs:domain ind:Intake ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:conflictCheckCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Conflict Check Completed Timestamp' ;
    rdfs:comment 'Date and time when the conflict check process was completed and a determination was made.' ;
    rdfs:domain ind:Request ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:conflictWaiverObtained rdf:type rdf:Property ;
    rdfs:label 'Conflict Waiver Obtained' ;
    rdfs:comment 'Indicates whether a formal conflict waiver was obtained from affected parties to proceed despite an identified conflict.' ;
    rdfs:domain ind:Request ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Fee Amount' ;
    rdfs:comment 'Estimated total professional fees for the matter. Used for budgeting, resource planning, and client communication.' ;
    rdfs:domain ind:Intake ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:intakeStatus rdf:type rdf:Property ;
    rdfs:label 'Intake Status' ;
    rdfs:comment 'Current stage of the intake request in the workflow lifecycle. Progresses from submission through conflict clearance, compliance screening, approval, and matter opening. [ENUM-REF-CANDIDATE: Submitted|Conflict Check In Progress|KYC In Progress|Pending Approval|Approved|Rejected|Matter Opened|Withdrawn — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Request ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loeRequired rdf:type rdf:Property ;
    rdfs:label 'Loe Required' ;
    rdfs:comment 'Indicates whether a formal letter of engagement or engagement letter must be executed before matter opening.' ;
    rdfs:domain ind:Request ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loeStatus rdf:type rdf:Property ;
    rdfs:label 'Loe Status' ;
    rdfs:comment 'Status of the engagement letter execution process. Tracks whether the LOE has been drafted, sent, and signed by the client.' ;
    rdfs:domain ind:Intake ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matterDescription rdf:type rdf:Property ;
    rdfs:label 'Matter Description' ;
    rdfs:comment 'Detailed description of the proposed legal matter, including nature of work, transaction details, or dispute summary. Used for conflict checking and scope definition.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matterOpenedFlag rdf:type rdf:Property ;
    rdfs:label 'Matter Opened Flag' ;
    rdfs:comment 'Indicates whether the matter has been successfully opened in Elite 3E and the intake process is complete.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:matterOpenedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Matter Opened Timestamp' ;
    rdfs:comment 'Date and time when the matter was formally opened in Elite 3E and transitioned from intake to active matter management.' ;
    rdfs:domain ind:Intake ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:proposedClientName rdf:type rdf:Property ;
    rdfs:label 'Proposed Client Name' ;
    rdfs:comment 'Name of the prospective client or organization for whom legal services are being requested. May be an existing client for a new matter or a completely new client.' ;
    rdfs:domain ind:Request ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposedMatterNumber rdf:type rdf:Property ;
    rdfs:label 'Proposed Matter Number' ;
    rdfs:comment 'Reserved or proposed matter number that will be assigned in Elite 3E upon matter opening. May follow firm numbering conventions.' ;
    rdfs:domain ind:Intake ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestNumber rdf:type rdf:Property ;
    rdfs:label 'Request Number' ;
    rdfs:comment 'Business-facing unique identifier for the intake request, typically formatted as office code followed by sequential number. Used for tracking and reference in communications.' ;
    rdfs:domain ind:Request ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submission Timestamp' ;
    rdfs:comment 'Date and time when the intake request was formally submitted into the workflow system. Marks the start of the intake lifecycle.' ;
    rdfs:domain ind:Intake ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:targetMatterOpenDate rdf:type rdf:Property ;
    rdfs:label 'Target Matter Open Date' ;
    rdfs:comment 'Requested or target date by which the matter should be opened in Elite 3E and work can commence.' ;
    rdfs:domain ind:Request ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:urgencyFlag rdf:type rdf:Property ;
    rdfs:label 'Urgency Flag' ;
    rdfs:comment 'Indicates whether this intake request requires expedited processing due to time-sensitive business needs, court deadlines, or transaction timelines.' ;
    rdfs:domain ind:Request ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conflictSearchId rdf:type rdf:Property ;
    rdfs:label 'Conflict Search Id' ;
    rdfs:comment 'Primary key for conflict_search' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConflictSearch .

ind:alternateNamesSearched rdf:type rdf:Property ;
    rdfs:label 'Alternate Names Searched' ;
    rdfs:comment 'Comma-separated list of alternate names, aliases, DBA names, former names, or related entity names included in the conflict search parameters to ensure comprehensive coverage.' ;
    rdfs:domain ind:ConflictSearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:automatedSearchFlag rdf:type rdf:Property ;
    rdfs:label 'Automated Search Flag' ;
    rdfs:comment 'Boolean indicator (True/False) whether this conflict search was triggered automatically by system workflow rules (True) or manually initiated by a user (False).' ;
    rdfs:domain ind:ConflictSearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:databaseSnapshotTimestamp rdf:type rdf:Property ;
    rdfs:label 'Database Snapshot Timestamp' ;
    rdfs:comment 'The timestamp of the relationship and matter database snapshot against which this search was executed, important for understanding data currency and reproducibility.' ;
    rdfs:domain ind:ConflictSearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:errorMessage rdf:type rdf:Property ;
    rdfs:label 'Error Message' ;
    rdfs:comment 'Technical error message or exception details if the conflict search failed or encountered issues during execution. Null for successful searches.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Escalation Timestamp' ;
    rdfs:comment 'Date and time when the conflict search was escalated to conflicts counsel for review. Null if no escalation occurred.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:highRiskHitsCount rdf:type rdf:Property ;
    rdfs:label 'High Risk Hits Count' ;
    rdfs:comment 'Number of search results flagged by the system as high-risk conflicts requiring immediate escalation and review by conflicts counsel.' ;
    rdfs:domain ind:ConflictSearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:intakeRequest rdf:type rdf:Property ;
    rdfs:label 'Intake Request' ;
    rdfs:comment 'FK to intake.intake_request.intake_request_id — Conflict searches are executed as part of processing an intake request. This is the core operational trigger link.' ;
    rdfs:domain ind:Intake ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:jurisdictionFilter rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Filter' ;
    rdfs:comment 'Geographic or legal jurisdiction filter applied to the conflict search to limit results to matters in specific regions or court systems.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lowRiskHitsCount rdf:type rdf:Property ;
    rdfs:label 'Low Risk Hits Count' ;
    rdfs:comment 'Number of search results flagged as low-risk or informational matches that may not constitute actual conflicts but warrant awareness.' ;
    rdfs:domain ind:ConflictSearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:matchThresholdPercentage rdf:type rdf:Property ;
    rdfs:label 'Match Threshold Percentage' ;
    rdfs:comment 'The minimum similarity percentage threshold (0-100) used to determine whether a potential match is included in search results. Lower thresholds return more results but may include false positives.' ;
    rdfs:domain ind:ConflictSearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:matterTypeFilter rdf:type rdf:Property ;
    rdfs:label 'Matter Type Filter' ;
    rdfs:comment 'The matter type or practice area filter applied to the conflict search (e.g., M&A, litigation, IP prosecution) to narrow results to relevant engagements.' ;
    rdfs:domain ind:ConflictSearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediumRiskHitsCount rdf:type rdf:Property ;
    rdfs:label 'Medium Risk Hits Count' ;
    rdfs:comment 'Number of search results flagged as medium-risk conflicts requiring standard review and potential waiver or ethical wall consideration.' ;
    rdfs:domain ind:ConflictSearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:officeLocationCode rdf:type rdf:Property ;
    rdfs:label 'Office Location Code' ;
    rdfs:comment 'Code identifying the firm office location from which the conflict search was initiated, used for multi-office conflict management and jurisdiction-specific rules.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partyNameSearched rdf:type rdf:Property ;
    rdfs:label 'Party Name Searched' ;
    rdfs:comment 'The primary party name (individual or organization) that was the subject of this conflict search. May be client, adverse party, or related entity.' ;
    rdfs:domain ind:ConflictSearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partyRole rdf:type rdf:Property ;
    rdfs:label 'Party Role' ;
    rdfs:comment 'The role of the party being searched in the context of the prospective engagement. Prospective_client indicates the party seeking representation; adverse_party indicates opposing party; related_entity indicates affiliated organization; counterparty indicates transaction opposite party.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partyType rdf:type rdf:Property ;
    rdfs:label 'Party Type' ;
    rdfs:comment 'Classification of the party being searched: individual person, corporate/organizational entity, or government/public sector entity.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultsExportTimestamp rdf:type rdf:Property ;
    rdfs:label 'Results Export Timestamp' ;
    rdfs:comment 'Date and time when the conflict search results were exported. Null if results have not been exported.' ;
    rdfs:domain ind:ConflictSearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:resultsExportedFlag rdf:type rdf:Property ;
    rdfs:label 'Results Exported Flag' ;
    rdfs:comment 'Boolean indicator (True/False) whether the conflict search results were exported to external format (PDF, Excel, or report) for distribution or review.' ;
    rdfs:domain ind:ConflictSearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:searchAlgorithmType rdf:type rdf:Property ;
    rdfs:label 'Search Algorithm Type' ;
    rdfs:comment 'The matching algorithm used for this conflict search. Exact_match requires precise name matches; fuzzy_match allows for spelling variations; phonetic_match uses soundex-style matching; ai_enhanced uses natural language processing and machine learning.' ;
    rdfs:domain ind:ConflictSearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:searchCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Search Completed Timestamp' ;
    rdfs:comment 'Date and time when the conflict search processing completed and results were returned. Null if search is still in progress or failed.' ;
    rdfs:domain ind:ConflictSearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:searchDateRangeEnd rdf:type rdf:Property ;
    rdfs:label 'Search Date Range End' ;
    rdfs:comment 'End date of the matter date range filter applied to the conflict search, if search_scope is specific_date_range. Null for other scopes.' ;
    rdfs:domain ind:ConflictSearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:searchDateRangeStart rdf:type rdf:Property ;
    rdfs:label 'Search Date Range Start' ;
    rdfs:comment 'Start date of the matter date range filter applied to the conflict search, if search_scope is specific_date_range. Null for other scopes.' ;
    rdfs:domain ind:ConflictSearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:searchEngineVersion rdf:type rdf:Property ;
    rdfs:label 'Search Engine Version' ;
    rdfs:comment 'Version identifier of the Intapp Conflicts search engine used to execute this search, important for audit trail and result reproducibility.' ;
    rdfs:domain ind:ConflictSearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:searchExecutedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Search Executed Timestamp' ;
    rdfs:comment 'Date and time when the conflict search was executed against the relationship and matter database. This is the principal business event timestamp for the search.' ;
    rdfs:domain ind:ConflictSearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:searchExecutionDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Search Execution Duration Seconds' ;
    rdfs:comment 'The elapsed time in seconds from search initiation to completion, used for performance monitoring and system optimization.' ;
    rdfs:domain ind:ConflictSearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:searchIntake rdf:type rdf:Property ;
    rdfs:label 'Search Intake' ;
    rdfs:comment 'FK to intake.intake_request.intake_request_id — Conflict searches are executed as part of an intake request workflow. Required for tracking which searches belong to which intake.' ;
    rdfs:domain ind:ConflictSearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:searchNotes rdf:type rdf:Property ;
    rdfs:label 'Search Notes' ;
    rdfs:comment 'Free-text notes entered by the searcher documenting search rationale, special considerations, or preliminary assessment of results. May contain attorney work product.' ;
    rdfs:domain ind:ConflictSearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:searchPriority rdf:type rdf:Property ;
    rdfs:label 'Search Priority' ;
    rdfs:comment 'The business priority assigned to this conflict search. Urgent indicates time-sensitive RFP or pitch deadline; high indicates important prospective client; normal indicates standard intake workflow; low indicates preliminary inquiry.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:searchReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Search Reference Number' ;
    rdfs:comment 'Business-facing unique reference number for the conflict search, typically generated by Intapp Conflicts system in format CS-YYYYMMDD-NNNN.' ;
    rdfs:domain ind:ConflictSearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:searchRetryCount rdf:type rdf:Property ;
    rdfs:label 'Search Retry Count' ;
    rdfs:comment 'Number of times this conflict search was re-executed due to technical failures, timeout errors, or user-requested refinement. Zero indicates first successful execution.' ;
    rdfs:domain ind:ConflictSearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:searchScope rdf:type rdf:Property ;
    rdfs:label 'Search Scope' ;
    rdfs:comment 'The temporal scope of the conflict search. Current_matters searches only active engagements; all_matters includes historical; closed_matters searches only concluded engagements; specific_date_range searches a defined period.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:searchStatus rdf:type rdf:Property ;
    rdfs:label 'Search Status' ;
    rdfs:comment 'Current lifecycle status of the conflict search execution. Pending indicates queued; in_progress indicates actively running; complete indicates search finished with results; escalated indicates potential conflicts requiring review; cancelled indicates search was aborted; failed indicates technical error.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:searcherName rdf:type rdf:Property ;
    rdfs:label 'Searcher Name' ;
    rdfs:comment 'Full name of the individual who executed the conflict search, captured for audit trail purposes.' ;
    rdfs:domain ind:ConflictSearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalHitsReturned rdf:type rdf:Property ;
    rdfs:label 'Total Hits Returned' ;
    rdfs:comment 'The total number of potential conflict matches (matters, clients, or relationships) returned by the search engine. Zero indicates no conflicts found; higher numbers indicate potential issues requiring review.' ;
    rdfs:domain ind:ConflictSearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:intakePartyId rdf:type rdf:Property ;
    rdfs:label 'Intake Party Id' ;
    rdfs:comment 'Unique identifier for the intake party record. Primary key for the intake party entity representing unverified parties at the pre-clearance stage before formal client onboarding.' ;
    rdfs:domain ind:IntakeParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:businessAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Business Address Line1' ;
    rdfs:comment 'The first line of the partys primary business address. For individuals, the primary residence or business location.' ;
    rdfs:domain ind:IntakeParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Business Address Line2' ;
    rdfs:comment 'The second line of the partys primary business address, including suite, floor, or building information.' ;
    rdfs:domain ind:IntakeParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessCity rdf:type rdf:Property ;
    rdfs:label 'Business City' ;
    rdfs:comment 'The city of the partys primary business address.' ;
    rdfs:domain ind:IntakeParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessCountryCode rdf:type rdf:Property ;
    rdfs:label 'Business Country Code' ;
    rdfs:comment 'The three-letter ISO country code of the partys primary business address. Used for jurisdiction analysis and regulatory compliance.' ;
    rdfs:domain ind:IntakeParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessPostalCode rdf:type rdf:Property ;
    rdfs:label 'Business Postal Code' ;
    rdfs:comment 'The postal or ZIP code of the partys primary business address.' ;
    rdfs:domain ind:IntakeParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessStateProvince rdf:type rdf:Property ;
    rdfs:label 'Business State Province' ;
    rdfs:comment 'The state or province of the partys primary business address.' ;
    rdfs:domain ind:IntakeParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conflictCheckDate rdf:type rdf:Property ;
    rdfs:label 'Conflict Check Date' ;
    rdfs:comment 'The date when the conflict check was performed for this party. Required for ethics compliance and audit documentation.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conflictDescription rdf:type rdf:Property ;
    rdfs:label 'Conflict Description' ;
    rdfs:comment 'Detailed description of any identified conflicts, including the nature of the conflict, related matters, and affected parties. Used for conflict resolution and waiver analysis.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conflictIdentifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Conflict Identified Flag' ;
    rdfs:comment 'Indicates whether a conflict of interest was identified for this party during conflict checking. True requires conflict resolution or engagement rejection.' ;
    rdfs:domain ind:IntakeParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conflictWaiverObtainedFlag rdf:type rdf:Property ;
    rdfs:label 'Conflict Waiver Obtained Flag' ;
    rdfs:comment 'Indicates whether informed consent waivers have been obtained from all affected parties to proceed despite an identified conflict.' ;
    rdfs:domain ind:IntakeParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:intakeRequestFk rdf:type rdf:Property ;
    rdfs:label 'Intake Request Fk' ;
    rdfs:comment 'FK to intake.intake_request.intake_request_id — Parties are associated with a specific intake request for conflict checking purposes. Core operational link.' ;
    rdfs:domain ind:IntakeParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:kycScreeningDate rdf:type rdf:Property ;
    rdfs:label 'Kyc Screening Date' ;
    rdfs:comment 'The date when KYC screening was completed for this party. Used for compliance audit trails and periodic re-screening requirements.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:kycScreeningStatus rdf:type rdf:Property ;
    rdfs:label 'Kyc Screening Status' ;
    rdfs:comment 'Status of the KYC due diligence process for this party. Tracks completion of identity verification, sanctions screening, and AML checks required before engagement.' ;
    rdfs:domain ind:IntakeParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partyName rdf:type rdf:Property ;
    rdfs:label 'Party Name' ;
    rdfs:comment 'The full legal name of the party as it appears in official records. For individuals, includes full given and family names. For organizations, the registered legal entity name.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partyStatus rdf:type rdf:Property ;
    rdfs:label 'Party Status' ;
    rdfs:comment 'Current lifecycle status of the party within the intake process. Pending indicates initial capture, screening indicates KYC/AML checks in progress, cleared indicates conflict-free and approved, rejected indicates conflicts identified or failed screening, escalated indicates manual review required.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sanctionsMatchFlag rdf:type rdf:Property ;
    rdfs:label 'Sanctions Match Flag' ;
    rdfs:comment 'Indicates whether the party matched any sanctions lists during screening (OFAC, UN, EU, etc.). True indicates a match requiring investigation or rejection.' ;
    rdfs:domain ind:IntakeParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:controlFrameworkId rdf:type rdf:Property ;
    rdfs:label 'Control Framework Id' ;
    rdfs:comment 'Foreign key linking to compliance.control_framework. Business justification: KYC screening is executed under a specific compliance control framework (e.g., FATF CDD framework, internal AML controls). Legal firms must evidence which control framework governed each screening for' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ControlFramework .

ind:primaryIntakePartyId rdf:type rdf:Property ;
    rdfs:label 'Primary Intake Party Id' ;
    rdfs:comment 'FK to intake.intake_party.intake_party_id — KYC screenings are performed on specific intake parties. Required for compliance traceability.' ;
    rdfs:domain ind:KycScreening ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IntakeParty .

ind:adverseMediaHitFlag rdf:type rdf:Property ;
    rdfs:label 'Adverse Media Hit Flag' ;
    rdfs:comment 'Boolean indicator of whether adverse media or negative news was found associated with the party. True if adverse media found, False otherwise.' ;
    rdfs:domain ind:KycScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvalNotes rdf:type rdf:Property ;
    rdfs:label 'Approval Notes' ;
    rdfs:comment 'Detailed notes or rationale provided by the compliance officer explaining the approval or rejection decision, including any conditions or mitigating factors.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:comments rdf:type rdf:Property ;
    rdfs:label 'Comments' ;
    rdfs:comment 'Additional free-text comments or notes related to the screening process, findings, or decision-making rationale.' ;
    rdfs:domain ind:KycScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataClassification rdf:type rdf:Property ;
    rdfs:label 'Data Classification' ;
    rdfs:comment 'Data classification level assigned to this screening record based on sensitivity and regulatory requirements.' ;
    rdfs:domain ind:KycScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eddCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Edd Completion Date' ;
    rdfs:comment 'Date on which Enhanced Due Diligence procedures were completed, if required.' ;
    rdfs:domain ind:KycScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eddRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Edd Required Flag' ;
    rdfs:comment 'Boolean indicator of whether Enhanced Due Diligence is required for this party based on risk rating or regulatory requirements. True if EDD required, False otherwise.' ;
    rdfs:domain ind:KycScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jurisdictionRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Risk Level' ;
    rdfs:comment 'Risk level associated with the jurisdiction or country of the party being screened, based on FATF assessments, corruption indices, and regulatory environment.' ;
    rdfs:domain ind:KycScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchCount rdf:type rdf:Property ;
    rdfs:label 'Match Count' ;
    rdfs:comment 'Number of potential matches or hits returned by the screening provider against sanctions lists, PEP databases, or adverse media sources.' ;
    rdfs:domain ind:KycScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:party rdf:type rdf:Property ;
    rdfs:label 'Party' ;
    rdfs:comment 'FK to intake.party.party_id — KYC/AML screenings are performed on specific parties. This link is essential for compliance audit trails.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pepHitFlag rdf:type rdf:Property ;
    rdfs:label 'Pep Hit Flag' ;
    rdfs:comment 'Boolean indicator of whether the party is identified as a Politically Exposed Person or close associate. True if PEP match found, False otherwise.' ;
    rdfs:domain ind:KycScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reScreeningRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Re Screening Required Flag' ;
    rdfs:comment 'Boolean indicator of whether periodic re-screening is required for this party. True if re-screening required, False otherwise.' ;
    rdfs:domain ind:KycScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryFilingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Required Flag' ;
    rdfs:comment 'Boolean indicator of whether a Suspicious Activity Report (SAR) or other regulatory filing is required based on the screening results. True if filing required, False otherwise.' ;
    rdfs:domain ind:KycScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riskScore rdf:type rdf:Property ;
    rdfs:label 'Risk Score' ;
    rdfs:comment 'Numeric risk score assigned by the screening provider or internal risk model, typically on a scale of 0-100.' ;
    rdfs:domain ind:KycScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sanctionsHitFlag rdf:type rdf:Property ;
    rdfs:label 'Sanctions Hit Flag' ;
    rdfs:comment 'Boolean indicator of whether the party matched any sanctions lists (OFAC, UN, EU, HMT, etc.). True if match found, False otherwise.' ;
    rdfs:domain ind:KycScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sarFilingDate rdf:type rdf:Property ;
    rdfs:label 'Sar Filing Date' ;
    rdfs:comment 'Date on which a Suspicious Activity Report was filed with the relevant authority (e.g., National Crime Agency in UK, FinCEN in US) based on screening findings.' ;
    rdfs:domain ind:KycScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sarReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Sar Reference Number' ;
    rdfs:comment 'Reference number assigned by the regulatory authority upon submission of the Suspicious Activity Report.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningCostAmount rdf:type rdf:Property ;
    rdfs:label 'Screening Cost Amount' ;
    rdfs:comment 'Cost incurred for conducting the screening, typically charged by the third-party screening provider.' ;
    rdfs:domain ind:KycScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:screeningCostCurrency rdf:type rdf:Property ;
    rdfs:label 'Screening Cost Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the screening cost amount (e.g., USD, GBP, EUR).' ;
    rdfs:domain ind:KycScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningDate rdf:type rdf:Property ;
    rdfs:label 'Screening Date' ;
    rdfs:comment 'Date on which the KYC or AML screening was performed.' ;
    rdfs:domain ind:KycScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:screeningExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Screening Expiry Date' ;
    rdfs:comment 'Date on which the current screening results expire and re-screening is required, typically based on firm policy or regulatory requirements (e.g., annual re-screening).' ;
    rdfs:domain ind:KycScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:screeningOutcome rdf:type rdf:Property ;
    rdfs:label 'Screening Outcome' ;
    rdfs:comment 'Final outcome of the screening: cleared (no issues found), escalated (flagged for further review), rejected (onboarding declined), pending review, or requires EDD (Enhanced Due Diligence).' ;
    rdfs:domain ind:KycScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningParty rdf:type rdf:Property ;
    rdfs:label 'Screening Party' ;
    rdfs:comment 'FK to intake.party.party_id — KYC/AML screenings are performed on specific intake parties. Required for compliance audit trail.' ;
    rdfs:domain ind:KycScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:screeningProvider rdf:type rdf:Property ;
    rdfs:label 'Screening Provider' ;
    rdfs:comment 'Name of the third-party screening service provider or internal system used to conduct the screening (e.g., Dow Jones Risk & Compliance, LexisNexis Bridger, World-Check, internal compliance database).' ;
    rdfs:domain ind:KycScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Screening Reference Number' ;
    rdfs:comment 'External reference number or case identifier assigned by the screening provider or internal compliance system.' ;
    rdfs:domain ind:KycScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningStatus rdf:type rdf:Property ;
    rdfs:label 'Screening Status' ;
    rdfs:comment 'Current lifecycle status of the screening record: initiated, in progress, completed, expired (requires re-screening), or cancelled.' ;
    rdfs:domain ind:KycScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningTimestamp rdf:type rdf:Property ;
    rdfs:label 'Screening Timestamp' ;
    rdfs:comment 'Precise timestamp when the screening was initiated or completed, including time zone information.' ;
    rdfs:domain ind:KycScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:screeningType rdf:type rdf:Property ;
    rdfs:label 'Screening Type' ;
    rdfs:comment 'Type of due diligence screening performed: KYC (Know Your Client), AML (Anti-Money Laundering), sanctions list check, PEP (Politically Exposed Person) check, adverse media search, or credit check.' ;
    rdfs:domain ind:KycScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceOfFundsVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Source Of Funds Verified Flag' ;
    rdfs:comment 'Boolean indicator of whether the source of funds or wealth for the party has been verified as part of the KYC process. True if verified, False otherwise.' ;
    rdfs:domain ind:KycScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:agreementTypeId rdf:type rdf:Property ;
    rdfs:label 'Agreement Type Id' ;
    rdfs:comment 'Foreign key linking to contract.agreement_type. Business justification: The LOE type must align with the contract agreement_type to ensure correct billing codes, approval workflows, and compliance requirements are applied. Legal operations teams classify LOEs by agreement' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AgreementType .

ind:signatoryClientContactId rdf:type rdf:Property ;
    rdfs:label 'Signatory Client Contact Id' ;
    rdfs:comment 'Foreign key linking to client.client_contact. Business justification: The LOE signatory must be a verified client contact with tracked authority level (signatory_authority_level on client_contact). client_signatory_name/email/title are denormalized representations of th' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:supersededByLoeLetterOfEngagementId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Loe Letter Of Engagement Id' ;
    rdfs:comment 'Reference to the newer Letter of Engagement that supersedes this one. Nullable if this LOE is current or was not superseded. Used to track LOE version history.' ;
    rdfs:domain ind:LetterOfEngagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LetterOfEngagement .

ind:templateId rdf:type rdf:Property ;
    rdfs:label 'Template Id' ;
    rdfs:comment 'Foreign key linking to contract.template. Business justification: LOEs are generated from contract templates. Linking LOE to the template used supports document generation audit, template usage tracking, and ensures LOE version aligns with the approved template — a ' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Template .

ind:acceptanceDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Acceptance Deadline Date' ;
    rdfs:comment 'Date by which the client must accept and sign the Letter of Engagement. After this date, the LOE may expire or require reissuance.' ;
    rdfs:domain ind:LetterOfEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conflictWaiverReference rdf:type rdf:Property ;
    rdfs:label 'Conflict Waiver Reference' ;
    rdfs:comment 'Reference to any conflict of interest waiver or ethical wall arrangement documented in the conflict checking system (Intapp Conflicts). Nullable if no conflicts identified.' ;
    rdfs:domain ind:LetterOfEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataProtectionJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Data Protection Jurisdiction' ;
    rdfs:comment 'Primary data protection regulatory framework applicable to this engagement. GDPR = EU General Data Protection Regulation; CCPA = California Consumer Privacy Act; DPA UK = UK Data Protection Act; Other = jurisdiction-specific; Not Applicable = no specific data protection requirements.' ;
    rdfs:domain ind:LetterOfEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeResolutionMethod rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Method' ;
    rdfs:comment 'Agreed method for resolving disputes arising from the engagement. Litigation = court proceedings; Arbitration = binding arbitration; Mediation = facilitated negotiation; ADR = other alternative dispute resolution.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveUntilDate rdf:type rdf:Property ;
    rdfs:label 'Effective Until Date' ;
    rdfs:comment 'Date on which the engagement terms expire or the matter is expected to conclude. Nullable for open-ended engagements.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:firmSignatoryName rdf:type rdf:Property ;
    rdfs:label 'Firm Signatory Name' ;
    rdfs:comment 'Full name of the law firm partner or authorized representative signing the Letter of Engagement on behalf of the firm.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firmSignatoryTitle rdf:type rdf:Property ;
    rdfs:label 'Firm Signatory Title' ;
    rdfs:comment 'Title or role of the firm signatory (e.g., Managing Partner, Equity Partner, Practice Group Leader).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Flag' ;
    rdfs:comment 'Indicates whether the client has provided consent for data processing under GDPR or equivalent data protection regulations. True = consent given; False = consent not given. Required for EU/UK clients.' ;
    rdfs:domain ind:LetterOfEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issueDate rdf:type rdf:Property ;
    rdfs:label 'Issue Date' ;
    rdfs:comment 'Date on which the Letter of Engagement was formally issued to the prospective client. Represents the business event timestamp for LOE issuance.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:kycAmlCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Kyc Aml Completed Flag' ;
    rdfs:comment 'Indicates whether Know Your Client and Anti-Money Laundering due diligence has been completed and cleared for this engagement. True = completed and cleared; False = pending or not completed. Required before LOE can be issued.' ;
    rdfs:domain ind:LetterOfEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loeFeeArrangement rdf:type rdf:Property ;
    rdfs:label 'Loe Fee Arrangement' ;
    rdfs:comment 'FK to intake.fee_arrangement.fee_arrangement_id — The LOE incorporates the agreed fee arrangement. Essential for ensuring commercial terms are properly documented.' ;
    rdfs:domain ind:LetterOfEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:loeNumber rdf:type rdf:Property ;
    rdfs:label 'Loe Number' ;
    rdfs:comment 'Business-facing unique identifier for the Letter of Engagement, typically formatted as LOE-YYYYNNNNNN. Used for external reference and client communication.' ;
    rdfs:domain ind:LetterOfEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loeType rdf:type rdf:Property ;
    rdfs:label 'Loe Type' ;
    rdfs:comment 'Classification of the Letter of Engagement purpose. New Matter = initial engagement; Additional Scope = expansion of existing matter; Amendment = modification of terms; Renewal = extension of existing engagement.' ;
    rdfs:domain ind:LetterOfEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loeVersion rdf:type rdf:Property ;
    rdfs:label 'Loe Version' ;
    rdfs:comment 'Version number of this Letter of Engagement. Increments when the LOE is revised or reissued. Version 1 is the initial issuance.' ;
    rdfs:domain ind:LetterOfEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lppAcknowledgmentFlag rdf:type rdf:Property ;
    rdfs:label 'Lpp Acknowledgment Flag' ;
    rdfs:comment 'Indicates whether the client has acknowledged and agreed to the terms regarding Legal Professional Privilege and attorney-client confidentiality. True = acknowledged; False = not acknowledged.' ;
    rdfs:domain ind:LetterOfEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scopeOfServices rdf:type rdf:Property ;
    rdfs:label 'Scope Of Services' ;
    rdfs:comment 'Detailed description of the legal services to be provided under this engagement. Defines the boundaries of the attorney-client relationship and the work to be performed.' ;
    rdfs:domain ind:LetterOfEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eliteMatterId rdf:type rdf:Property ;
    rdfs:label 'Elite Matter Id' ;
    rdfs:comment 'The system-generated matter identifier assigned by Elite 3E upon matter creation. Nullable until matter is opened. Used for cross-system reconciliation.' ;
    rdfs:domain ind:MatterOpeningRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Matter .

ind:lpmTemplateId rdf:type rdf:Property ;
    rdfs:label 'Lpm Template Id' ;
    rdfs:comment 'Foreign key linking to service.lpm_template. Business justification: LPM templates define the project management framework for the matter; selecting at opening enables budget, milestone, and phase tracking from day one, supporting legal project management and AFAs.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LpmTemplate .

ind:departmentCode rdf:type rdf:Property ;
    rdfs:label 'Department Code' ;
    rdfs:comment 'Code representing the department or cost center to which the matter will be allocated for financial reporting and profitability analysis.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedDisbursementAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Disbursement Amount' ;
    rdfs:comment 'Estimated total disbursements (out-of-pocket expenses) for the matter, as projected at the time of opening request. Includes court fees, filing fees, expert witness costs, travel, etc.' ;
    rdfs:domain ind:MatterOpeningRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedDurationMonths rdf:type rdf:Property ;
    rdfs:label 'Estimated Duration Months' ;
    rdfs:comment 'Estimated duration of the matter in months, as projected at the time of opening request. Used for resource planning and Legal Project Management (LPM).' ;
    rdfs:domain ind:MatterOpeningRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ledesBillingRequired rdf:type rdf:Property ;
    rdfs:label 'Ledes Billing Required' ;
    rdfs:comment 'Boolean flag indicating whether invoices for this matter must be submitted in Legal Electronic Data Exchange Standard (LEDES) format for electronic billing. True if LEDES submission is required by the client.' ;
    rdfs:domain ind:MatterOpeningRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:matterName rdf:type rdf:Property ;
    rdfs:label 'Matter Name' ;
    rdfs:comment 'Descriptive name for the matter. Typically includes client name, transaction type, and brief description (e.g., \'Acme Corp - Series B Financing\' or \'Smith v. Jones - Employment Dispute\').' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestStatus rdf:type rdf:Property ;
    rdfs:label 'Request Status' ;
    rdfs:comment 'Current lifecycle status of the matter opening request. Values: draft (being prepared), submitted (awaiting review), pending_approval (under partner review), approved (authorized to open), rejected (denied), opened (matter created in Elite 3E), cancelled (request withdrawn). [ENUM-REF-CANDIDATE: draft|submitted|pending_approval|approved|rejected|opened|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MatterOpeningRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresOutsideCounselGuidelines rdf:type rdf:Property ;
    rdfs:label 'Requires Outside Counsel Guidelines' ;
    rdfs:comment 'Boolean flag indicating whether the client has imposed Outside Counsel Guidelines (OCG) that must be followed for billing, staffing, and matter administration. True if OCG compliance is mandatory.' ;
    rdfs:domain ind:MatterOpeningRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresTrustAccount rdf:type rdf:Property ;
    rdfs:label 'Requires Trust Account' ;
    rdfs:comment 'Boolean flag indicating whether this matter requires a client trust account (IOLTA - Interest on Lawyers Trust Accounts) for holding client funds. True if trust accounting is required per engagement terms or jurisdictional rules.' ;
    rdfs:domain ind:MatterOpeningRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:utbmsCodingRequired rdf:type rdf:Property ;
    rdfs:label 'Utbms Coding Required' ;
    rdfs:comment 'Boolean flag indicating whether time entries and invoices for this matter must include Uniform Task-Based Management System (UTBMS) task and activity codes. True if UTBMS coding is required by the client.' ;
    rdfs:domain ind:MatterOpeningRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originationCreditId rdf:type rdf:Property ;
    rdfs:label 'Origination Credit Id' ;
    rdfs:comment 'Unique identifier for the origination credit record. Primary key for this entity.' ;
    rdfs:domain ind:OriginationCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originationEngagementOpportunityId rdf:type rdf:Property ;
    rdfs:label 'Origination Engagement Opportunity Id' ;
    rdfs:comment 'FK to intake.engagement_opportunity.engagement_opportunity_id — Origination credits are allocated per engagement opportunity. Required for partner compensation attribution.' ;
    rdfs:domain ind:OriginationCredit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EngagementOpportunity .

ind:primaryOriginationEngagementOpportunityId rdf:type rdf:Property ;
    rdfs:label 'Primary Origination Engagement Opportunity Id' ;
    rdfs:comment 'Reference to the engagement scope record established during intake. Links to the Letter of Engagement (LOE) and scope definition.' ;
    rdfs:domain ind:OriginationCredit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EngagementOpportunity .

ind:businessDevelopmentNotes rdf:type rdf:Property ;
    rdfs:label 'Business Development Notes' ;
    rdfs:comment 'Free-text notes capturing the business development context, relationship history, competitive positioning, and strategic importance of this origination. Used for internal knowledge management and future business development planning.' ;
    rdfs:domain ind:OriginationCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compensationYear rdf:type rdf:Property ;
    rdfs:label 'Compensation Year' ;
    rdfs:comment 'Fiscal or calendar year in which this origination credit is recognized for partner compensation purposes. Typically the year of engagement acceptance or Letter of Engagement (LOE) execution.' ;
    rdfs:domain ind:OriginationCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:creditAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Amount' ;
    rdfs:comment 'Monetary value of origination credit allocated to this timekeeper. May be calculated as a percentage of expected engagement value or Alternative Fee Arrangement (AFA) amount. Denominated in the firm\'s base currency.' ;
    rdfs:domain ind:OriginationCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditIntake rdf:type rdf:Property ;
    rdfs:label 'Credit Intake' ;
    rdfs:comment 'FK to intake.intake_request.intake_request_id — Origination credits are allocated at the point of intake. Required for partner compensation attribution.' ;
    rdfs:domain ind:OriginationCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:creditPercentage rdf:type rdf:Property ;
    rdfs:label 'Credit Percentage' ;
    rdfs:comment 'Percentage of origination credit allocated to this timekeeper for this engagement. Multiple timekeepers may share credit with percentages summing to 100% across all credit records for the same engagement. Used in partner compensation calculations including Profit Per Equity Partner (PEP) and Revenue Per Equity Partner (RPE).' ;
    rdfs:domain ind:OriginationCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditedOffice rdf:type rdf:Property ;
    rdfs:label 'Credited Office' ;
    rdfs:comment 'Office location of the credited timekeeper at the time of origination. Used for office-level revenue attribution and geographic performance analysis.' ;
    rdfs:domain ind:OriginationCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedEngagementValue rdf:type rdf:Property ;
    rdfs:label 'Expected Engagement Value' ;
    rdfs:comment 'Estimated total revenue expected from this engagement at the time of origination. Used as the basis for calculating origination credit amounts. May be based on Alternative Fee Arrangement (AFA) fixed fees, estimated hours, or historical matter value.' ;
    rdfs:domain ind:OriginationCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isCrossBorder rdf:type rdf:Property ;
    rdfs:label 'Is Cross Border' ;
    rdfs:comment 'Boolean flag indicating whether this engagement involves cross-border legal work spanning multiple jurisdictions. Cross-border matters may warrant additional origination credit due to complexity and coordination requirements.' ;
    rdfs:domain ind:OriginationCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isStrategicClient rdf:type rdf:Property ;
    rdfs:label 'Is Strategic Client' ;
    rdfs:comment 'Boolean flag indicating whether this engagement is with a client designated as strategically important to the firm. Strategic clients may receive enhanced origination credit recognition or special compensation treatment.' ;
    rdfs:domain ind:OriginationCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lockDate rdf:type rdf:Property ;
    rdfs:label 'Lock Date' ;
    rdfs:comment 'Date on which this origination credit record was locked for final compensation calculations. Once locked, changes require special authorization from the compensation committee. Null if not yet locked.' ;
    rdfs:domain ind:OriginationCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originationSource rdf:type rdf:Property ;
    rdfs:label 'Origination Source' ;
    rdfs:comment 'Source or channel through which this engagement was originated. New client indicates first engagement with a new client; existing client new matter indicates additional work for current client; cross-sell indicates expansion of services; referral external indicates referral from outside the firm; referral internal indicates referral from another practice group; Request for Proposal (RFP) response indicates competitive bid; direct approach indicates proactive business development; marketing event indicates conference or seminar lead; alumni network indicates former firm member referral. [ENUM-REF-CANDIDATE: new_client|existing_client_new_matter|cross_sell|referral_external|referral_internal|rfp_response|direct_approach|marketing_event|alumni_network — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:OriginationCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionNumber rdf:type rdf:Property ;
    rdfs:label 'Revision Number' ;
    rdfs:comment 'Sequential revision number tracking changes to this origination credit allocation. Incremented each time the allocation is revised and resubmitted for approval. Initial allocation is revision 1.' ;
    rdfs:domain ind:OriginationCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revisionReason rdf:type rdf:Property ;
    rdfs:label 'Revision Reason' ;
    rdfs:comment 'Free-text explanation for why this origination credit allocation was revised. Null if this is the initial allocation (revision 1).' ;
    rdfs:domain ind:OriginationCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralSourceId rdf:type rdf:Property ;
    rdfs:label 'Referral Source Id' ;
    rdfs:comment 'Unique identifier for the referral source record. Primary key.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReferralSource .

ind:acknowledgmentProtocol rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Protocol' ;
    rdfs:comment 'Description of the standard acknowledgment or thank-you protocol for referrals from this source (e.g., partner phone call, gift, event invitation). Used to maintain relationship quality.' ;
    rdfs:domain ind:ReferralSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactEmail rdf:type rdf:Property ;
    rdfs:label 'Contact Email' ;
    rdfs:comment 'Primary email address for the referral source contact. Used for relationship management and acknowledgment communications.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactName rdf:type rdf:Property ;
    rdfs:label 'Contact Name' ;
    rdfs:comment 'Name of the primary contact person at the referral source organization or the individual referrer.' ;
    rdfs:domain ind:ReferralSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPhone rdf:type rdf:Property ;
    rdfs:label 'Contact Phone' ;
    rdfs:comment 'Primary telephone number for the referral source contact.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dynamicsContactGuid rdf:type rdf:Property ;
    rdfs:label 'Dynamics Contact Guid' ;
    rdfs:comment 'Globally unique identifier linking this referral source to the corresponding contact record in Microsoft Dynamics 365 CRM. Used for system integration and data synchronization.' ;
    rdfs:domain ind:ReferralSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstReferralDate rdf:type rdf:Property ;
    rdfs:label 'First Referral Date' ;
    rdfs:comment 'Date when the first engagement opportunity was referred by this source. Marks the beginning of the referral relationship.' ;
    rdfs:domain ind:ReferralSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:industrySectorFocus rdf:type rdf:Property ;
    rdfs:label 'Industry Sector Focus' ;
    rdfs:comment 'Primary industry sector or vertical associated with referrals from this source (e.g., Technology, Financial Services, Healthcare). Used for market segmentation.' ;
    rdfs:domain ind:ReferralSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReferralDate rdf:type rdf:Property ;
    rdfs:label 'Last Referral Date' ;
    rdfs:comment 'Date of the most recent engagement opportunity referred by this source. Used to identify active vs dormant referral relationships.' ;
    rdfs:domain ind:ReferralSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:referralAgreementDate rdf:type rdf:Property ;
    rdfs:label 'Referral Agreement Date' ;
    rdfs:comment 'Date when the referral agreement was executed. Null if no formal agreement exists.' ;
    rdfs:domain ind:ReferralSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:referralAgreementExecutedFlag rdf:type rdf:Property ;
    rdfs:label 'Referral Agreement Executed Flag' ;
    rdfs:comment 'Indicates whether a formal referral agreement or memorandum of understanding has been executed with this source. True if agreement is in place; False otherwise.' ;
    rdfs:domain ind:ReferralSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:referralAgreementExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Referral Agreement Expiry Date' ;
    rdfs:comment 'Date when the referral agreement expires or requires renewal. Null for evergreen agreements or when no formal agreement exists.' ;
    rdfs:domain ind:ReferralSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:referralFeeArrangement rdf:type rdf:Property ;
    rdfs:label 'Referral Fee Arrangement' ;
    rdfs:comment 'Type of fee arrangement or compensation structure associated with referrals from this source. Values: none (no fee), percentage (percentage of fees), flat_fee (fixed amount per referral), reciprocal (mutual referral agreement).' ;
    rdfs:domain ind:ReferralSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralFeePercentage rdf:type rdf:Property ;
    rdfs:label 'Referral Fee Percentage' ;
    rdfs:comment 'Percentage of fees paid to the referral source when referral_fee_arrangement is percentage-based. Expressed as a decimal (e.g., 10.00 for 10%).' ;
    rdfs:domain ind:ReferralSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceCategory rdf:type rdf:Property ;
    rdfs:label 'Source Category' ;
    rdfs:comment 'High-level categorization of the referral source for segmentation and reporting. Values: individual (person-based referral), organization (company or institution referral), digital_channel (website, online directory, social media), event (conference, seminar, networking event), publication (legal publication, directory listing).' ;
    rdfs:domain ind:ReferralSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceName rdf:type rdf:Property ;
    rdfs:label 'Source Name' ;
    rdfs:comment 'The full name or title of the referral source entity (individual, organization, or channel).' ;
    rdfs:domain ind:ReferralSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceNumber rdf:type rdf:Property ;
    rdfs:label 'Source Number' ;
    rdfs:comment 'Business identifier for the referral source, typically assigned by the business development or intake system. Format: RS-NNNNNN.' ;
    rdfs:domain ind:ReferralSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceQualityRating rdf:type rdf:Property ;
    rdfs:label 'Source Quality Rating' ;
    rdfs:comment 'Qualitative assessment of the referral source based on conversion rate, matter value, and client quality. Used for relationship prioritization and BD resource allocation.' ;
    rdfs:domain ind:ReferralSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceStatus rdf:type rdf:Property ;
    rdfs:label 'Source Status' ;
    rdfs:comment 'Current lifecycle status of the referral source. Active sources are currently generating referrals; inactive sources are no longer producing leads; suspended sources are temporarily paused; archived sources are historical records.' ;
    rdfs:domain ind:ReferralSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceTier rdf:type rdf:Property ;
    rdfs:label 'Source Tier' ;
    rdfs:comment 'Strategic tier classification of the referral source for relationship management prioritization. Tier 1 sources are highest value and receive most attention.' ;
    rdfs:domain ind:ReferralSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:successfulReferralsCount rdf:type rdf:Property ;
    rdfs:label 'Successful Referrals Count' ;
    rdfs:comment 'Count of referred opportunities that resulted in executed Letter of Engagement (LOE) and opened matters. Measures referral source conversion quality.' ;
    rdfs:domain ind:ReferralSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalReferralsCount rdf:type rdf:Property ;
    rdfs:label 'Total Referrals Count' ;
    rdfs:comment 'Cumulative count of engagement opportunities referred by this source since inception. Used for referral source performance tracking.' ;
    rdfs:domain ind:ReferralSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicabilityScope rdf:type rdf:Property ;
    rdfs:label 'Applicability Scope' ;
    rdfs:comment 'Description of the scope of applicability within the firm (e.g., all offices, specific practice groups, client-facing roles, data processing activities).' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exemptionApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Exemption Applicable Flag' ;
    rdfs:comment 'Indicates whether the firm qualifies for any exemption or waiver from this obligation. True if an exemption applies, False otherwise.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exemptionDetails rdf:type rdf:Property ;
    rdfs:label 'Exemption Details' ;
    rdfs:comment 'Details of any exemption or waiver that applies to the firm for this obligation, including the basis and expiry date of the exemption.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalAuditRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'External Audit Required Flag' ;
    rdfs:comment 'Indicates whether an external audit or third-party assessment is required to verify compliance with this obligation. True if external audit is required, False otherwise.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:filingFrequency rdf:type rdf:Property ;
    rdfs:label 'Filing Frequency' ;
    rdfs:comment 'Frequency at which regulatory filings or submissions are required for this obligation. Not applicable for ongoing conduct obligations.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Assessment Date' ;
    rdfs:comment 'Date when the most recent compliance assessment or audit was performed for this obligation.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastExternalAuditDate rdf:type rdf:Property ;
    rdfs:label 'Last External Audit Date' ;
    rdfs:comment 'Date when the most recent external audit or third-party assessment was conducted for this obligation. Null if no external audit has been performed.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maximumPenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Penalty Amount' ;
    rdfs:comment 'Maximum monetary penalty or fine that can be imposed for non-compliance with this obligation, in the currency of the jurisdiction.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextExternalAuditDate rdf:type rdf:Property ;
    rdfs:label 'Next External Audit Date' ;
    rdfs:comment 'Scheduled date for the next external audit or third-party assessment of compliance with this obligation. Null if not applicable.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextFilingDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Filing Due Date' ;
    rdfs:comment 'Due date for the next regulatory filing or submission required under this obligation. Null if not applicable.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:obligationCategory rdf:type rdf:Property ;
    rdfs:label 'Obligation Category' ;
    rdfs:comment 'Business category of the obligation (e.g., AML/KYC, Data Privacy, Professional Conduct, Financial Reporting, Client Protection, Professional Indemnity).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationCode rdf:type rdf:Property ;
    rdfs:label 'Obligation Code' ;
    rdfs:comment 'Unique business identifier code for the regulatory obligation, used for external reference and reporting.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationDescription rdf:type rdf:Property ;
    rdfs:label 'Obligation Description' ;
    rdfs:comment 'Detailed description of the regulatory obligation, including scope, requirements, and applicability to the firm.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationName rdf:type rdf:Property ;
    rdfs:label 'Obligation Name' ;
    rdfs:comment 'Full name or title of the regulatory obligation as defined by the governing body.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationType rdf:type rdf:Property ;
    rdfs:label 'Obligation Type' ;
    rdfs:comment 'Classification of the obligation by its nature: periodic filing (regular submissions), ongoing conduct (continuous compliance), event-triggered (specific event response), registration, disclosure, or reporting.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Penalty Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the maximum penalty amount (e.g., USD, GBP, EUR).' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyForNonCompliance rdf:type rdf:Property ;
    rdfs:label 'Penalty For Non Compliance' ;
    rdfs:comment 'Description of penalties, sanctions, or consequences that may result from non-compliance with this obligation (e.g., fines, license suspension, disciplinary action).' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleDepartment rdf:type rdf:Property ;
    rdfs:label 'Responsible Department' ;
    rdfs:comment 'Department or business unit within the firm responsible for managing compliance with this obligation (e.g., Compliance, Risk Management, Legal Operations).' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleOfficer rdf:type rdf:Property ;
    rdfs:label 'Responsible Officer' ;
    rdfs:comment 'Name or title of the individual responsible for ensuring compliance with this obligation (e.g., Data Protection Officer, Chief Legal Officer, Compliance Partner).' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceLegislationUrl rdf:type rdf:Property ;
    rdfs:label 'Source Legislation Url' ;
    rdfs:comment 'URL or hyperlink to the official source legislation, regulation, or guidance document that defines this obligation.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingFrequency rdf:type rdf:Property ;
    rdfs:label 'Training Frequency' ;
    rdfs:comment 'Frequency at which compliance training must be completed for this obligation. Not applicable if training is not required.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Training Required Flag' ;
    rdfs:comment 'Indicates whether mandatory training is required for personnel to ensure compliance with this obligation. True if training is required, False otherwise.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:adoptionDate rdf:type rdf:Property ;
    rdfs:label 'Adoption Date' ;
    rdfs:comment 'Date on which the firm formally adopted this control framework for compliance purposes. Marks the start of internal applicability.' ;
    rdfs:domain ind:ControlFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationBody rdf:type rdf:Property ;
    rdfs:label 'Certification Body' ;
    rdfs:comment 'Name of the accredited certification or audit body that conducts third-party assessments for this framework (e.g., BSI, UKAS, Big Four Audit Firm). Null if no certification is required.' ;
    rdfs:domain ind:ControlFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Certification Required Flag' ;
    rdfs:comment 'Indicates whether the firm is required to obtain third-party certification or attestation for compliance with this framework (e.g., ISO 27001 certification, SOC 2 audit). True if certification is mandatory or pursued; False otherwise.' ;
    rdfs:domain ind:ControlFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:compliancePercentage rdf:type rdf:Property ;
    rdfs:label 'Compliance Percentage' ;
    rdfs:comment 'Current percentage of framework controls that are fully implemented and compliant, calculated as (compliant_controls / total_controls) * 100. Used for compliance dashboards and reporting.' ;
    rdfs:domain ind:ControlFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:controlCount rdf:type rdf:Property ;
    rdfs:label 'Control Count' ;
    rdfs:comment 'Total number of individual controls or requirements defined within this framework that the firm must implement and monitor. Derived from framework documentation.' ;
    rdfs:domain ind:ControlFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:controlDomainMapping rdf:type rdf:Property ;
    rdfs:label 'Control Domain Mapping' ;
    rdfs:comment 'Mapping of this framework to internal control domains or categories (e.g., Information Security, Data Privacy, Financial Controls, Ethical Conduct, Client Confidentiality). Pipe-separated if multiple domains.' ;
    rdfs:domain ind:ControlFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frameworkCode rdf:type rdf:Property ;
    rdfs:label 'Framework Code' ;
    rdfs:comment 'Short alphanumeric code or abbreviation used to reference the framework internally (e.g., ISO27001, FATF40, SRA-CODE, GDPR-A32, SOX-COSO).' ;
    rdfs:domain ind:ControlFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frameworkDescription rdf:type rdf:Property ;
    rdfs:label 'Framework Description' ;
    rdfs:comment 'Detailed narrative description of the frameworks purpose, objectives, and key requirements. Provides business context for compliance teams.' ;
    rdfs:domain ind:ControlFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frameworkName rdf:type rdf:Property ;
    rdfs:label 'Framework Name' ;
    rdfs:comment 'Official name of the compliance control framework (e.g., ISO 27001, FATF 40 Recommendations, SRA Code of Conduct, GDPR Article 32 Technical and Organizational Measures, SOX COSO Framework).' ;
    rdfs:domain ind:ControlFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frameworkStatus rdf:type rdf:Property ;
    rdfs:label 'Framework Status' ;
    rdfs:comment 'Current lifecycle status of the framework within the firm: active (in force), superseded (replaced by newer version), retired (no longer applicable), under_review (being evaluated for adoption), pending_adoption (approved but not yet effective).' ;
    rdfs:domain ind:ControlFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frameworkType rdf:type rdf:Property ;
    rdfs:label 'Framework Type' ;
    rdfs:comment 'Classification of the framework origin and authority: regulatory (mandated by law), industry_standard (voluntary consensus standard), internal (firm-developed), best_practice (guidance), certification (third-party audit), contractual (client-imposed).' ;
    rdfs:domain ind:ControlFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frameworkUrl rdf:type rdf:Property ;
    rdfs:label 'Framework Url' ;
    rdfs:comment 'Web link to the official framework documentation, standard text, or regulatory guidance published by the issuing body.' ;
    rdfs:domain ind:ControlFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frameworkVersion rdf:type rdf:Property ;
    rdfs:label 'Framework Version' ;
    rdfs:comment 'Version or edition of the control framework (e.g., 2013, 2022, v4.0). Tracks updates and revisions to the framework standard.' ;
    rdfs:domain ind:ControlFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingBody rdf:type rdf:Property ;
    rdfs:label 'Issuing Body' ;
    rdfs:comment 'Name of the regulatory authority, standards organization, or governing body that published and maintains the framework (e.g., International Organization for Standardization, Financial Action Task Force, Solicitors Regulation Authority, European Commission).' ;
    rdfs:domain ind:ControlFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastCertificationDate rdf:type rdf:Property ;
    rdfs:label 'Last Certification Date' ;
    rdfs:comment 'Date of the most recent successful certification or audit for this framework. Null if never certified or certification not required.' ;
    rdfs:domain ind:ControlFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mandatoryFlag rdf:type rdf:Property ;
    rdfs:label 'Mandatory Flag' ;
    rdfs:comment 'Indicates whether compliance with this framework is legally or contractually mandatory for the firm (True) or voluntary/best-practice (False).' ;
    rdfs:domain ind:ControlFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextCertificationDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Certification Due Date' ;
    rdfs:comment 'Scheduled date for the next certification audit or recertification cycle. Used for compliance planning and audit scheduling.' ;
    rdfs:domain ind:ControlFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scopeOfApplicability rdf:type rdf:Property ;
    rdfs:label 'Scope Of Applicability' ;
    rdfs:comment 'Description of the business functions, departments, practice areas, or data domains to which this framework applies (e.g., All Client Data Processing, Information Security, AML/KYC Program, Financial Reporting, Data Privacy for EU Clients).' ;
    rdfs:domain ind:ControlFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceControlFrameworkId rdf:type rdf:Property ;
    rdfs:label 'Compliance Control Framework Id' ;
    rdfs:comment 'FK to compliance.control_framework.control_framework_id — Every control must reference its parent framework — this is the fundamental structural relationship in control management. Without this FK, you cannot answer \'which controls implement ISO 27001?\' whic' ;
    rdfs:domain ind:ComplianceControl ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ControlFramework .

ind:primaryComplianceControlFrameworkId rdf:type rdf:Property ;
    rdfs:label 'Primary Compliance Control Framework Id' ;
    rdfs:comment 'Reference to the parent compliance framework (e.g., SOX, ISO 27001, GDPR, SRA Code of Conduct) under which this control is defined. Links to the compliance_framework product.' ;
    rdfs:domain ind:ComplianceControl ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ControlFramework .

ind:primaryComplianceRegulatoryObligationId rdf:type rdf:Property ;
    rdfs:label 'Primary Compliance Regulatory Obligation Id' ;
    rdfs:comment 'Reference to the specific regulatory obligation or requirement that this control is designed to satisfy. Links to the compliance_obligation product.' ;
    rdfs:domain ind:ComplianceControl ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryObligation .

ind:toControlFrameworkId rdf:type rdf:Property ;
    rdfs:label 'To Control Framework Id' ;
    rdfs:comment 'FK to compliance.control_framework.control_framework_id — Every control must belong to a control framework. This is the fundamental parent-child relationship in control management — controls are designed WITHIN a framework. Without this FK, the control inven' ;
    rdfs:domain ind:ComplianceControl ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ControlFramework .

ind:toRegulatoryObligationId rdf:type rdf:Property ;
    rdfs:label 'To Regulatory Obligation Id' ;
    rdfs:comment 'FK to compliance.regulatory_obligation.regulatory_obligation_id — Controls exist to satisfy regulatory obligations. This many-to-many relationship (or FK to primary obligation) is essential for demonstrating regulatory coverage and identifying gaps. Required for any' ;
    rdfs:domain ind:ComplianceControl ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryObligation .

ind:compensatingControlFlag rdf:type rdf:Property ;
    rdfs:label 'Compensating Control Flag' ;
    rdfs:comment 'Indicates whether this control serves as a compensating control for another control that is ineffective or not feasible. True if this control mitigates risk in lieu of a primary control; false otherwise.' ;
    rdfs:domain ind:ComplianceControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:controlStatus rdf:type rdf:Property ;
    rdfs:label 'Control Status' ;
    rdfs:comment 'Current operational status of the control within the firm\'s control framework. Active controls are currently enforced; inactive controls are not operational; suspended controls are temporarily paused; under_review indicates controls being assessed for effectiveness; retired controls are no longer applicable.' ;
    rdfs:domain ind:ComplianceControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentationReference rdf:type rdf:Property ;
    rdfs:label 'Documentation Reference' ;
    rdfs:comment 'Reference to supporting documentation for the control, including policies, procedures, system configurations, and evidence repositories. May include document management system (DMS) identifiers or file paths.' ;
    rdfs:domain ind:ComplianceControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivenessRating rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Rating' ;
    rdfs:comment 'Overall assessment of control effectiveness based on testing history, exception trends, and management evaluation. Used for control maturity reporting and prioritizing control enhancements.' ;
    rdfs:domain ind:ComplianceControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionDescription rdf:type rdf:Property ;
    rdfs:label 'Exception Description' ;
    rdfs:comment 'Detailed narrative of any exceptions or control failures identified during testing, including root cause analysis, impact assessment, and context. Used for remediation planning and management reporting.' ;
    rdfs:domain ind:ComplianceControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frequency rdf:type rdf:Property ;
    rdfs:label 'Frequency' ;
    rdfs:comment 'Frequency at which the control is executed or reviewed. Continuous controls operate in real-time; event-driven controls are triggered by specific business events (e.g., new client intake, matter opening). [ENUM-REF-CANDIDATE: continuous|daily|weekly|monthly|quarterly|annually|event_driven — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ComplianceControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprArticleReference rdf:type rdf:Property ;
    rdfs:label 'Gdpr Article Reference' ;
    rdfs:comment 'Reference to the specific GDPR article(s) that this control addresses (e.g., Article 32 for Security of Processing, Article 25 for Data Protection by Design). Used for GDPR compliance documentation and Data Protection Officer (DPO) reporting.' ;
    rdfs:domain ind:ComplianceControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identifier rdf:type rdf:Property ;
    rdfs:label 'Identifier' ;
    rdfs:comment 'External business identifier for the control, typically following framework naming conventions (e.g., SOX-001, ISO-27001-A.5.1, SRA-COMP-042). Used for cross-referencing with audit documentation and regulatory submissions.' ;
    rdfs:domain ind:ComplianceControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iso27001ControlReference rdf:type rdf:Property ;
    rdfs:label 'Iso 27001 Control Reference' ;
    rdfs:comment 'Reference to the corresponding ISO 27001:2013 Annex A control (e.g., A.9.2.1 for User Registration, A.18.1.1 for Identification of Applicable Legislation). Used for ISO 27001 certification and audit mapping.' ;
    rdfs:domain ind:ComplianceControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyControlFlag rdf:type rdf:Property ;
    rdfs:label 'Key Control Flag' ;
    rdfs:comment 'Indicates whether this control is designated as a key control within the firm\'s control framework. Key controls are those that directly address significant risks and require enhanced monitoring and testing.' ;
    rdfs:domain ind:ComplianceControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastTestConclusion rdf:type rdf:Property ;
    rdfs:label 'Last Test Conclusion' ;
    rdfs:comment 'Outcome of the most recent control test. Effective indicates the control operated as designed with no exceptions; ineffective indicates control failures or design deficiencies; partially_effective indicates minor exceptions that do not materially impact control objective.' ;
    rdfs:domain ind:ComplianceControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nature rdf:type rdf:Property ;
    rdfs:label 'Nature' ;
    rdfs:comment 'Indicates whether the control is executed manually by personnel, automated through system processes, or a hybrid combination requiring both human and system intervention.' ;
    rdfs:domain ind:ComplianceControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextTestDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Test Due Date' ;
    rdfs:comment 'Scheduled date for the next control test based on control frequency, risk rating, and regulatory requirements. Used for test planning and resource allocation.' ;
    rdfs:domain ind:ComplianceControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:objective rdf:type rdf:Property ;
    rdfs:label 'Objective' ;
    rdfs:comment 'Detailed statement of the control\'s intended outcome and the risk it is designed to mitigate. Describes what the control is meant to achieve in terms of regulatory compliance, risk reduction, or operational assurance.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procedure rdf:type rdf:Property ;
    rdfs:label 'Procedure' ;
    rdfs:comment 'Step-by-step procedural instructions for executing the control, including specific actions, system interactions, approval workflows, and documentation requirements. Used by control operators and auditors.' ;
    rdfs:domain ind:ComplianceControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationPlan rdf:type rdf:Property ;
    rdfs:label 'Remediation Plan' ;
    rdfs:comment 'Detailed plan for addressing identified control deficiencies, including specific corrective actions, responsible parties, timelines, and success criteria. Used to track remediation progress and closure.' ;
    rdfs:domain ind:ComplianceControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleSize rdf:type rdf:Property ;
    rdfs:label 'Sample Size' ;
    rdfs:comment 'Number of control instances or transactions examined during the most recent control test. Used to assess the statistical validity of test conclusions and determine whether sample size meets audit standards.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:soxScopingFlag rdf:type rdf:Property ;
    rdfs:label 'Sox Scoping Flag' ;
    rdfs:comment 'Indicates whether this control is in scope for SOX Section 404 compliance testing. True if the control is material to financial reporting and requires annual testing; false if out of scope.' ;
    rdfs:domain ind:ComplianceControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sraStandardReference rdf:type rdf:Property ;
    rdfs:label 'Sra Standard Reference' ;
    rdfs:comment 'Reference to the SRA Standards and Regulations that this control supports (e.g., SRA Accounts Rules, SRA Code of Conduct for Firms). Used for SRA regulatory returns and compliance reporting.' ;
    rdfs:domain ind:ComplianceControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testingMethodology rdf:type rdf:Property ;
    rdfs:label 'Testing Methodology' ;
    rdfs:comment 'Method used to test the control\'s design and operating effectiveness. Walkthrough involves tracing a transaction through the control process; reperformance involves independently executing the control; sample testing involves examining a subset of control instances. [ENUM-REF-CANDIDATE: walkthrough|inquiry|observation|inspection|reperformance|sample_testing|analytical_review — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ComplianceControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableJurisdictions rdf:type rdf:Property ;
    rdfs:label 'Applicable Jurisdictions' ;
    rdfs:comment 'Comma-separated list of jurisdictions (ISO 3166-1 alpha-3 codes) where the AML/KYC program applies.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditFindingsSummary rdf:type rdf:Property ;
    rdfs:label 'Audit Findings Summary' ;
    rdfs:comment 'Summary of findings and recommendations from the most recent independent audit of the AML/KYC program.' ;
    rdfs:domain ind:AmlKycProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boardApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Board Approval Date' ;
    rdfs:comment 'Date when the firm\'s board or governing body approved the AML/KYC program.' ;
    rdfs:domain ind:AmlKycProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clientRiskRating rdf:type rdf:Property ;
    rdfs:label 'Client Risk Rating' ;
    rdfs:comment 'Overall risk rating for client-related AML/KYC risks based on the most recent assessment.' ;
    rdfs:domain ind:AmlKycProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryChannelRiskRating rdf:type rdf:Property ;
    rdfs:label 'Delivery Channel Risk Rating' ;
    rdfs:comment 'Overall risk rating for delivery channel-related AML/KYC risks (e.g., remote onboarding, in-person) based on the most recent assessment.' ;
    rdfs:domain ind:AmlKycProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicRiskRating rdf:type rdf:Property ;
    rdfs:label 'Geographic Risk Rating' ;
    rdfs:comment 'Overall risk rating for geographic/jurisdictional AML/KYC risks based on the most recent assessment.' ;
    rdfs:domain ind:AmlKycProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastRiskAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Risk Assessment Date' ;
    rdfs:comment 'Date when the most recent enterprise-wide AML/KYC risk assessment was completed.' ;
    rdfs:domain ind:AmlKycProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastUpdatedBy rdf:type rdf:Property ;
    rdfs:label 'Last Updated By' ;
    rdfs:comment 'Name or identifier of the user who last updated the AML/KYC program record.' ;
    rdfs:domain ind:AmlKycProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mlroEmail rdf:type rdf:Property ;
    rdfs:label 'Mlro Email' ;
    rdfs:comment 'Official email address of the Money Laundering Reporting Officer for regulatory communications.' ;
    rdfs:domain ind:AmlKycProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mlroName rdf:type rdf:Property ;
    rdfs:label 'Mlro Name' ;
    rdfs:comment 'Full name of the designated Money Laundering Reporting Officer responsible for the AML/KYC program.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mlroPhone rdf:type rdf:Property ;
    rdfs:label 'Mlro Phone' ;
    rdfs:comment 'Direct contact phone number for the Money Laundering Reporting Officer.' ;
    rdfs:domain ind:AmlKycProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextAuditDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Audit Due Date' ;
    rdfs:comment 'Scheduled date for the next independent audit of the AML/KYC program.' ;
    rdfs:domain ind:AmlKycProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextRiskAssessmentDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Risk Assessment Due Date' ;
    rdfs:comment 'Scheduled date for the next mandatory enterprise-wide AML/KYC risk assessment.' ;
    rdfs:domain ind:AmlKycProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:productServiceRiskRating rdf:type rdf:Property ;
    rdfs:label 'Product Service Risk Rating' ;
    rdfs:comment 'Overall risk rating for product and service-related AML/KYC risks based on the most recent assessment.' ;
    rdfs:domain ind:AmlKycProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programName rdf:type rdf:Property ;
    rdfs:label 'Program Name' ;
    rdfs:comment 'Official name or title of the AML/KYC program as registered with regulatory authorities.' ;
    rdfs:domain ind:AmlKycProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programScope rdf:type rdf:Property ;
    rdfs:label 'Program Scope' ;
    rdfs:comment 'Detailed description of the scope of the AML/KYC program, including covered business lines, matter types, and jurisdictions.' ;
    rdfs:domain ind:AmlKycProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programStatus rdf:type rdf:Property ;
    rdfs:label 'Program Status' ;
    rdfs:comment 'Current lifecycle status of the AML/KYC program indicating its operational state.' ;
    rdfs:domain ind:AmlKycProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programVersion rdf:type rdf:Property ;
    rdfs:label 'Program Version' ;
    rdfs:comment 'Version identifier for the AML/KYC program, tracking iterations and updates over time.' ;
    rdfs:domain ind:AmlKycProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Date' ;
    rdfs:comment 'Date when the AML/KYC program received regulatory approval or acknowledgment.' ;
    rdfs:domain ind:AmlKycProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Status' ;
    rdfs:comment 'Status of regulatory approval or acknowledgment of the AML/KYC program by relevant authorities.' ;
    rdfs:domain ind:AmlKycProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskAppetiteStatement rdf:type rdf:Property ;
    rdfs:label 'Risk Appetite Statement' ;
    rdfs:comment 'Formal statement defining the firm\'s tolerance for AML/KYC risk across client types, geographies, and service lines.' ;
    rdfs:domain ind:AmlKycProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskAssessmentFrequency rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Frequency' ;
    rdfs:comment 'Frequency at which enterprise-wide AML/KYC risk assessments are conducted.' ;
    rdfs:domain ind:AmlKycProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskMethodology rdf:type rdf:Property ;
    rdfs:label 'Risk Methodology' ;
    rdfs:comment 'Description of the methodology, framework, or standard used to conduct the AML/KYC risk assessment.' ;
    rdfs:domain ind:AmlKycProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suspiciousActivityReportsFiled rdf:type rdf:Property ;
    rdfs:label 'Suspicious Activity Reports Filed' ;
    rdfs:comment 'Total number of Suspicious Activity Reports filed under this program during the current reporting period.' ;
    rdfs:domain ind:AmlKycProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trainingCompletionRate rdf:type rdf:Property ;
    rdfs:label 'Training Completion Rate' ;
    rdfs:comment 'Percentage of required staff who have completed mandatory AML/KYC training as of the last assessment date.' ;
    rdfs:domain ind:AmlKycProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryAmlKycProgramId rdf:type rdf:Property ;
    rdfs:label 'Primary Aml Kyc Program Id' ;
    rdfs:comment 'FK to compliance.aml_kyc_program.aml_kyc_program_id — SAR filings are made under the authority of the AML programme and by the MLRO designated in that programme. This link is essential for programme-level reporting on SAR activity.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AmlKycProgram .

ind:acknowledgmentReference rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Reference' ;
    rdfs:comment 'Reference number or confirmation code provided by the financial intelligence unit upon acknowledgment of the SAR.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentOutcome rdf:type rdf:Property ;
    rdfs:label 'Consent Outcome' ;
    rdfs:comment 'Outcome of the Defence Against Money Laundering (DAML) consent request: granted, refused, or no response within statutory period.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentOutcomeDate rdf:type rdf:Property ;
    rdfs:label 'Consent Outcome Date' ;
    rdfs:comment 'Date on which the consent outcome was received or the statutory notice period expired.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consentRequestDate rdf:type rdf:Property ;
    rdfs:label 'Consent Request Date' ;
    rdfs:comment 'Date on which consent was requested from the financial intelligence unit to proceed with the transaction.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consentRequestFlag rdf:type rdf:Property ;
    rdfs:label 'Consent Request Flag' ;
    rdfs:comment 'Indicates whether the SAR includes a request for consent to proceed with the transaction (Defence Against Money Laundering - DAML).' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:filingAuthority rdf:type rdf:Property ;
    rdfs:label 'Filing Authority' ;
    rdfs:comment 'Name of the financial intelligence unit or regulatory authority to which the SAR was submitted (e.g., National Crime Agency, FinCEN).' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Filing Jurisdiction' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the jurisdiction to which the SAR was filed (e.g., GBR for UK NCA, USA for FinCEN). [ENUM-REF-CANDIDATE: GBR|USA|CAN|AUS|DEU|FRA|NLD|CHE — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingStatus rdf:type rdf:Property ;
    rdfs:label 'Filing Status' ;
    rdfs:comment 'Current status of the SAR filing in its lifecycle from draft through submission and acknowledgment.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Filing Timestamp' ;
    rdfs:comment 'Precise timestamp when the SAR was submitted to the financial intelligence unit.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:followUpActionDescription rdf:type rdf:Property ;
    rdfs:label 'Follow Up Action Description' ;
    rdfs:comment 'Description of any follow-up actions taken or required by the firm in response to the SAR filing.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpActionRequired rdf:type rdf:Property ;
    rdfs:label 'Follow Up Action Required' ;
    rdfs:comment 'Indicates whether follow-up action is required by the firm (e.g., enhanced due diligence, relationship termination).' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:internalReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Internal Reference Number' ;
    rdfs:comment 'Internal tracking reference number assigned by the firm for SAR management and audit purposes.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalReportDate rdf:type rdf:Property ;
    rdfs:label 'Internal Report Date' ;
    rdfs:comment 'Date on which the suspicious activity was first reported internally to the MLRO or compliance team.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:relationshipTerminatedFlag rdf:type rdf:Property ;
    rdfs:label 'Relationship Terminated Flag' ;
    rdfs:comment 'Indicates whether the client or matter relationship was terminated as a result of the suspicious activity.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:relationshipTerminationDate rdf:type rdf:Property ;
    rdfs:label 'Relationship Termination Date' ;
    rdfs:comment 'Date on which the client or matter relationship was terminated following the SAR filing.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reporterName rdf:type rdf:Property ;
    rdfs:label 'Reporter Name' ;
    rdfs:comment 'Full name of the individual who initially identified and reported the suspicious activity internally.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Retention Expiry Date' ;
    rdfs:comment 'Date on which the SAR record is eligible for deletion or archival per regulatory retention requirements (typically 5-7 years post-filing).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewNotes rdf:type rdf:Property ;
    rdfs:label 'Review Notes' ;
    rdfs:comment 'Internal notes and commentary from the MLRO or compliance team regarding the review and decision to file the SAR.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectIdentifierType rdf:type rdf:Property ;
    rdfs:label 'Subject Identifier Type' ;
    rdfs:comment 'Type of identifier used to identify the subject of the SAR (e.g., passport number, company registration number).' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectIdentifierValue rdf:type rdf:Property ;
    rdfs:label 'Subject Identifier Value' ;
    rdfs:comment 'The actual identifier value for the subject (e.g., passport number, company registration number), stored securely.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:subjectNameAnonymised rdf:type rdf:Property ;
    rdfs:label 'Subject Name Anonymised' ;
    rdfs:comment 'Anonymised or pseudonymised name of the individual or organisation that is the subject of the SAR, for internal audit trail purposes.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectType rdf:type rdf:Property ;
    rdfs:label 'Subject Type' ;
    rdfs:comment 'Type of entity that is the subject of the suspicious activity report.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suspicionCategory rdf:type rdf:Property ;
    rdfs:label 'Suspicion Category' ;
    rdfs:comment 'Primary category of suspicious activity being reported (e.g., money laundering, terrorist financing, fraud).' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suspicionGrounds rdf:type rdf:Property ;
    rdfs:label 'Suspicion Grounds' ;
    rdfs:comment 'Detailed narrative describing the grounds for suspicion, including red flags, unusual patterns, and rationale for filing the SAR.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tippingOffRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Tipping Off Risk Flag' ;
    rdfs:comment 'Indicates whether there is a risk of tipping off the subject if certain actions are taken, requiring special handling.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transactionAmount rdf:type rdf:Property ;
    rdfs:label 'Transaction Amount' ;
    rdfs:comment 'Monetary value of the suspicious transaction or cumulative value of related transactions.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionCurrency rdf:type rdf:Property ;
    rdfs:label 'Transaction Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the transaction amount (e.g., GBP, USD, EUR).' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionReference rdf:type rdf:Property ;
    rdfs:label 'Transaction Reference' ;
    rdfs:comment 'Reference number or identifier of the specific transaction or series of transactions that triggered the SAR.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controllerContactEmail rdf:type rdf:Property ;
    rdfs:label 'Controller Contact Email' ;
    rdfs:comment 'Email address of the data controller contact person.' ;
    rdfs:domain ind:DataPrivacyRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controllerContactName rdf:type rdf:Property ;
    rdfs:label 'Controller Contact Name' ;
    rdfs:comment 'Name of the representative or contact person for the data controller.' ;
    rdfs:domain ind:DataPrivacyRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controllerName rdf:type rdf:Property ;
    rdfs:label 'Controller Name' ;
    rdfs:comment 'Legal name of the data controller responsible for determining the purposes and means of processing. Typically the law firm or its legal entity.' ;
    rdfs:domain ind:DataPrivacyRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataPrivacyRegisterStatus rdf:type rdf:Property ;
    rdfs:label 'Data Privacy Register Status' ;
    rdfs:comment 'Current lifecycle status of the register entry: draft (being prepared), active (in force), under_review (periodic review or audit), suspended (temporarily inactive), archived (historical record).' ;
    rdfs:domain ind:DataPrivacyRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSubjectCategories rdf:type rdf:Property ;
    rdfs:label 'Data Subject Categories' ;
    rdfs:comment 'Categories of individuals whose personal data is processed (e.g., clients, employees, opposing parties, witnesses, vendors, job applicants). Pipe-separated list.' ;
    rdfs:domain ind:DataPrivacyRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dpiaCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Dpia Completion Date' ;
    rdfs:comment 'Date on which the DPIA was completed, if applicable.' ;
    rdfs:domain ind:DataPrivacyRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dpiaMitigationMeasures rdf:type rdf:Property ;
    rdfs:label 'Dpia Mitigation Measures' ;
    rdfs:comment 'Measures envisaged to address the identified risks, including safeguards, security measures, and mechanisms to ensure protection of personal data, as required under GDPR Article 35(7)(d).' ;
    rdfs:domain ind:DataPrivacyRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dpiaRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Dpia Required Flag' ;
    rdfs:comment 'Indicates whether a DPIA is required for this processing activity under GDPR Article 35 (high risk to rights and freedoms of data subjects).' ;
    rdfs:domain ind:DataPrivacyRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dpiaTriggerReason rdf:type rdf:Property ;
    rdfs:label 'Dpia Trigger Reason' ;
    rdfs:comment 'Reason why a DPIA is required, if dpia_required_flag is true (e.g., systematic monitoring, large-scale processing of special category data, automated decision-making with legal effects).' ;
    rdfs:domain ind:DataPrivacyRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dpoConsultationDate rdf:type rdf:Property ;
    rdfs:label 'Dpo Consultation Date' ;
    rdfs:comment 'Date on which the Data Protection Officer was consulted regarding the DPIA, as required under GDPR Article 35(2).' ;
    rdfs:domain ind:DataPrivacyRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dpoConsultationOutcome rdf:type rdf:Property ;
    rdfs:label 'Dpo Consultation Outcome' ;
    rdfs:comment 'Summary of the DPO\'s advice and recommendations following consultation on the DPIA.' ;
    rdfs:domain ind:DataPrivacyRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dpoContactEmail rdf:type rdf:Property ;
    rdfs:label 'Dpo Contact Email' ;
    rdfs:comment 'Email address of the Data Protection Officer for inquiries and consultation.' ;
    rdfs:domain ind:DataPrivacyRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dpoName rdf:type rdf:Property ;
    rdfs:label 'Dpo Name' ;
    rdfs:comment 'Name of the Data Protection Officer responsible for overseeing this processing activity and ensuring GDPR compliance.' ;
    rdfs:domain ind:DataPrivacyRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryType rdf:type rdf:Property ;
    rdfs:label 'Entry Type' ;
    rdfs:comment 'Type of privacy register entry: Record of Processing Activities (RoPA) under GDPR Article 30, Data Protection Impact Assessment (DPIA) under GDPR Article 35, or combined entry covering both.' ;
    rdfs:domain ind:DataPrivacyRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalBasis rdf:type rdf:Property ;
    rdfs:label 'Legal Basis' ;
    rdfs:comment 'The lawful basis under GDPR Article 6 for processing personal data: consent, contract performance, legal obligation, vital interests, public task, or legitimate interests.' ;
    rdfs:domain ind:DataPrivacyRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legitimateInterestDescription rdf:type rdf:Property ;
    rdfs:label 'Legitimate Interest Description' ;
    rdfs:comment 'Detailed explanation of the legitimate interests pursued by the controller or third party, if legal_basis is legitimate_interests. Required under GDPR Article 6(1)(f).' ;
    rdfs:domain ind:DataPrivacyRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organizationalSecurityMeasures rdf:type rdf:Property ;
    rdfs:label 'Organizational Security Measures' ;
    rdfs:comment 'Description of organizational security measures implemented to protect personal data (e.g., staff training, access policies, data breach response procedures, confidentiality agreements).' ;
    rdfs:domain ind:DataPrivacyRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:personalDataCategories rdf:type rdf:Property ;
    rdfs:label 'Personal Data Categories' ;
    rdfs:comment 'Categories of personal data being processed (e.g., identification data, contact details, financial information, employment records, legal case details). Pipe-separated list.' ;
    rdfs:domain ind:DataPrivacyRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingActivityCode rdf:type rdf:Property ;
    rdfs:label 'Processing Activity Code' ;
    rdfs:comment 'Unique business identifier or reference code for the processing activity, used for cross-referencing with operational systems and audit trails.' ;
    rdfs:domain ind:DataPrivacyRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingActivityName rdf:type rdf:Property ;
    rdfs:label 'Processing Activity Name' ;
    rdfs:comment 'Human-readable name of the data processing activity (e.g., Client Onboarding KYC, Matter Document Management, Employee Performance Review).' ;
    rdfs:domain ind:DataPrivacyRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingPurpose rdf:type rdf:Property ;
    rdfs:label 'Processing Purpose' ;
    rdfs:comment 'Detailed description of the purposes of the data processing activity (e.g., client conflict checking, matter billing, employee recruitment, regulatory reporting).' ;
    rdfs:domain ind:DataPrivacyRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientCategories rdf:type rdf:Property ;
    rdfs:label 'Recipient Categories' ;
    rdfs:comment 'Categories of recipients to whom personal data may be disclosed (e.g., courts, regulators, external counsel, IT service providers, cloud storage vendors). Pipe-separated list.' ;
    rdfs:domain ind:DataPrivacyRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionJustification rdf:type rdf:Property ;
    rdfs:label 'Retention Justification' ;
    rdfs:comment 'Business or legal justification for the retention period, including references to applicable statutes of limitation, regulatory requirements, or legitimate business needs.' ;
    rdfs:domain ind:DataPrivacyRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionPeriod rdf:type rdf:Property ;
    rdfs:label 'Retention Period' ;
    rdfs:comment 'The time period for which personal data will be retained, or the criteria used to determine that period (e.g., 7 years post-matter closure, duration of employment plus 6 years).' ;
    rdfs:domain ind:DataPrivacyRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialCategoryDataTypes rdf:type rdf:Property ;
    rdfs:label 'Special Category Data Types' ;
    rdfs:comment 'Specific types of special category data processed, if special_category_data_flag is true (e.g., health, racial origin, criminal convictions). Pipe-separated list.' ;
    rdfs:domain ind:DataPrivacyRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supervisoryAuthorityConsultationDate rdf:type rdf:Property ;
    rdfs:label 'Supervisory Authority Consultation Date' ;
    rdfs:comment 'Date on which the supervisory authority was consulted, if supervisory_authority_consultation_required_flag is true.' ;
    rdfs:domain ind:DataPrivacyRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:supervisoryAuthorityConsultationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Supervisory Authority Consultation Required Flag' ;
    rdfs:comment 'Indicates whether prior consultation with the supervisory authority is required under GDPR Article 36 (when DPIA indicates high residual risk).' ;
    rdfs:domain ind:DataPrivacyRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supervisoryAuthorityResponse rdf:type rdf:Property ;
    rdfs:label 'Supervisory Authority Response' ;
    rdfs:comment 'Summary of the supervisory authority\'s response and any conditions or recommendations provided.' ;
    rdfs:domain ind:DataPrivacyRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalSecurityMeasures rdf:type rdf:Property ;
    rdfs:label 'Technical Security Measures' ;
    rdfs:comment 'Description of technical security measures implemented to protect personal data (e.g., encryption at rest and in transit, access controls, multi-factor authentication, pseudonymization).' ;
    rdfs:domain ind:DataPrivacyRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdCountryNames rdf:type rdf:Property ;
    rdfs:label 'Third Country Names' ;
    rdfs:comment 'Names of third countries or international organizations to which data is transferred, if third_country_transfer_flag is true. Pipe-separated list of ISO 3166-1 alpha-3 country codes.' ;
    rdfs:domain ind:DataPrivacyRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdCountryTransferFlag rdf:type rdf:Property ;
    rdfs:label 'Third Country Transfer Flag' ;
    rdfs:comment 'Indicates whether personal data is transferred to a third country or international organization outside the EEA.' ;
    rdfs:domain ind:DataPrivacyRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transferSafeguardDetails rdf:type rdf:Property ;
    rdfs:label 'Transfer Safeguard Details' ;
    rdfs:comment 'Additional details about the transfer safeguard mechanism, including reference to documentation or approval decisions.' ;
    rdfs:domain ind:DataPrivacyRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferSafeguardMechanism rdf:type rdf:Property ;
    rdfs:label 'Transfer Safeguard Mechanism' ;
    rdfs:comment 'The safeguard mechanism used for third country transfers: adequacy decision, standard contractual clauses (SCCs), binding corporate rules (BCRs), certification, code of conduct, or other approved mechanism.' ;
    rdfs:domain ind:DataPrivacyRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlTestId rdf:type rdf:Property ;
    rdfs:label 'Control Test Id' ;
    rdfs:comment 'Unique identifier for the control test record. Primary key.' ;
    rdfs:domain ind:ControlTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceFramework rdf:type rdf:Property ;
    rdfs:label 'Compliance Framework' ;
    rdfs:comment 'The regulatory or compliance framework under which this control test is being performed. SOX (Sarbanes-Oxley Act) for financial controls, ISO 27001 for information security, GDPR (General Data Protection Regulation) for data privacy, SRA (Solicitors Regulation Authority) for legal practice compliance, FATF (Financial Action Task Force) for anti-money laundering. [ENUM-REF-CANDIDATE: sox|iso_27001|gdpr|ccpa|sra|fatf|pci_dss|aml|kyc — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ControlTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlDeficiencySeverity rdf:type rdf:Property ;
    rdfs:label 'Control Deficiency Severity' ;
    rdfs:comment 'Classification of the severity of any control deficiency identified during testing. Material weakness is a deficiency that results in a reasonable possibility of material misstatement. Significant deficiency is less severe than a material weakness but important enough to merit attention. Deficiency is a control shortcoming that does not rise to the level of significant deficiency.' ;
    rdfs:domain ind:ControlTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionDetails rdf:type rdf:Property ;
    rdfs:label 'Exception Details' ;
    rdfs:comment 'Detailed description of any exceptions or control failures identified during testing, including root cause analysis and potential impact.' ;
    rdfs:domain ind:ControlTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Exception Rate Percentage' ;
    rdfs:comment 'The calculated percentage of exceptions relative to the sample size. Expressed as a percentage (e.g., 2.50 for 2.5%). Used to assess control effectiveness and project population error rates.' ;
    rdfs:domain ind:ControlTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exceptionsIdentifiedCount rdf:type rdf:Property ;
    rdfs:label 'Exceptions Identified Count' ;
    rdfs:comment 'The number of exceptions, deviations, or control failures identified during testing. An exception occurs when the control did not operate as designed or was not performed.' ;
    rdfs:domain ind:ControlTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:externalAuditorFlag rdf:type rdf:Property ;
    rdfs:label 'External Auditor Flag' ;
    rdfs:comment 'Indicates whether this test was performed by an external auditor (True) or internal compliance/audit team (False).' ;
    rdfs:domain ind:ControlTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:populationSize rdf:type rdf:Property ;
    rdfs:label 'Population Size' ;
    rdfs:comment 'The total number of items or transactions in the population from which the sample was drawn. Used to calculate sampling risk and exception rates.' ;
    rdfs:domain ind:ControlTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:samplingMethod rdf:type rdf:Property ;
    rdfs:label 'Sampling Method' ;
    rdfs:comment 'The statistical or non-statistical approach used to select the sample from the population. [ENUM-REF-CANDIDATE: random|systematic|stratified|judgmental|haphazard|monetary_unit|attribute — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ControlTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Test Completion Date' ;
    rdfs:comment 'The date on which all testing procedures were completed and results were finalized.' ;
    rdfs:domain ind:ControlTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:testConclusion rdf:type rdf:Property ;
    rdfs:label 'Test Conclusion' ;
    rdfs:comment 'The overall conclusion reached by the tester regarding the effectiveness of the control based on test results. Effective means the control is operating as designed with no material exceptions. Ineffective means the control has failed or has material exceptions. Partially effective indicates some deficiencies but not material failures.' ;
    rdfs:domain ind:ControlTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testDate rdf:type rdf:Property ;
    rdfs:label 'Test Date' ;
    rdfs:comment 'The date on which the control test was performed. This is the principal business event timestamp for the test activity.' ;
    rdfs:domain ind:ControlTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:testObjective rdf:type rdf:Property ;
    rdfs:label 'Test Objective' ;
    rdfs:comment 'A description of the specific objective or assertion being tested. Defines what the test is intended to validate about the control (e.g., completeness, accuracy, authorization, existence).' ;
    rdfs:domain ind:ControlTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Test Period End Date' ;
    rdfs:comment 'The ending date of the period covered by this control test. For operating effectiveness tests, defines the end of the observation window.' ;
    rdfs:domain ind:ControlTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:testPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Test Period Start Date' ;
    rdfs:comment 'The beginning date of the period covered by this control test. For operating effectiveness tests, defines the start of the observation window.' ;
    rdfs:domain ind:ControlTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:testProcedureDescription rdf:type rdf:Property ;
    rdfs:label 'Test Procedure Description' ;
    rdfs:comment 'Detailed narrative description of the specific procedures performed during the test, including steps taken, evidence examined, and criteria applied.' ;
    rdfs:domain ind:ControlTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Test Reference Number' ;
    rdfs:comment 'Business-facing unique reference number for the control test, used in audit documentation and reporting.' ;
    rdfs:domain ind:ControlTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testResultsSummary rdf:type rdf:Property ;
    rdfs:label 'Test Results Summary' ;
    rdfs:comment 'Summary narrative of the test findings, including observations, exceptions identified, and overall assessment of control performance.' ;
    rdfs:domain ind:ControlTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testStatus rdf:type rdf:Property ;
    rdfs:label 'Test Status' ;
    rdfs:comment 'Current lifecycle status of the control test activity.' ;
    rdfs:domain ind:ControlTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testType rdf:type rdf:Property ;
    rdfs:label 'Test Type' ;
    rdfs:comment 'Classification of the control test methodology. Design effectiveness tests evaluate whether the control is properly designed to prevent or detect errors. Operating effectiveness tests evaluate whether the control is functioning as designed over a period of time. [ENUM-REF-CANDIDATE: design_effectiveness|operating_effectiveness|walkthrough|inquiry|observation|inspection|reperformance — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ControlTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testingFrequency rdf:type rdf:Property ;
    rdfs:label 'Testing Frequency' ;
    rdfs:comment 'The planned frequency at which this control is tested as part of the compliance assurance program.' ;
    rdfs:domain ind:ControlTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineId rdf:type rdf:Property ;
    rdfs:label 'Line Id' ;
    rdfs:comment 'Foreign key linking to service.line. Business justification: Law firms structure professional indemnity cover by service line (e.g., separate PI limits for litigation vs. corporate finance). Line-level insurance coverage reporting and renewal negotiations with ' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Line .

ind:annualPremiumAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Premium Amount' ;
    rdfs:comment 'The total annual premium paid or payable for this professional indemnity insurance policy.' ;
    rdfs:domain ind:IndemnityPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brokerContactEmail rdf:type rdf:Property ;
    rdfs:label 'Broker Contact Email' ;
    rdfs:comment 'Primary email address for the insurance broker handling this policy.' ;
    rdfs:domain ind:IndemnityPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brokerContactPhone rdf:type rdf:Property ;
    rdfs:label 'Broker Contact Phone' ;
    rdfs:comment 'Primary telephone number for the insurance broker handling this policy.' ;
    rdfs:domain ind:IndemnityPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brokerName rdf:type rdf:Property ;
    rdfs:label 'Broker Name' ;
    rdfs:comment 'Name of the insurance broker or intermediary who arranged the professional indemnity policy.' ;
    rdfs:domain ind:IndemnityPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimsMadeBasisFlag rdf:type rdf:Property ;
    rdfs:label 'Claims Made Basis Flag' ;
    rdfs:comment 'Indicates whether the policy operates on a claims-made basis (true) or occurrence basis (false), determining when coverage is triggered.' ;
    rdfs:domain ind:IndemnityPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:claimsNotificationEmail rdf:type rdf:Property ;
    rdfs:label 'Claims Notification Email' ;
    rdfs:comment 'Email address to which claims and potential claims must be notified under the terms of this policy.' ;
    rdfs:domain ind:IndemnityPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimsNotificationPhone rdf:type rdf:Property ;
    rdfs:label 'Claims Notification Phone' ;
    rdfs:comment 'Telephone number for notifying claims and potential claims to the insurer.' ;
    rdfs:domain ind:IndemnityPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceCertificateIssuedFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Certificate Issued Flag' ;
    rdfs:comment 'Indicates whether a certificate of compliance or certificate of insurance has been issued confirming the policy meets regulatory minimum requirements.' ;
    rdfs:domain ind:IndemnityPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coveragePeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Coverage Period End Date' ;
    rdfs:comment 'The date on which the professional indemnity insurance coverage expires or terminates.' ;
    rdfs:domain ind:IndemnityPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coveragePeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Coverage Period Start Date' ;
    rdfs:comment 'The date on which the professional indemnity insurance coverage becomes effective and binding.' ;
    rdfs:domain ind:IndemnityPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coverageTerritory rdf:type rdf:Property ;
    rdfs:label 'Coverage Territory' ;
    rdfs:comment 'Geographic scope of coverage defining where claims arising from professional services will be covered (e.g., worldwide, UK only, EU, excluding USA).' ;
    rdfs:domain ind:IndemnityPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusionsSummary rdf:type rdf:Property ;
    rdfs:label 'Exclusions Summary' ;
    rdfs:comment 'Summary of key exclusions, limitations, and circumstances under which coverage does not apply.' ;
    rdfs:domain ind:IndemnityPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:extendedReportingPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Extended Reporting Period Months' ;
    rdfs:comment 'Number of months of extended reporting period (tail coverage) included in the policy, allowing claims to be reported after the policy expiration date for incidents that occurred during the coverage period.' ;
    rdfs:domain ind:IndemnityPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:insurerName rdf:type rdf:Property ;
    rdfs:label 'Insurer Name' ;
    rdfs:comment 'Legal name of the insurance company providing the professional indemnity coverage.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insurerReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Insurer Reference Number' ;
    rdfs:comment 'Internal reference number assigned by the insurer for tracking and correspondence purposes.' ;
    rdfs:domain ind:IndemnityPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limitOfIndemnityAmount rdf:type rdf:Property ;
    rdfs:label 'Limit Of Indemnity Amount' ;
    rdfs:comment 'The maximum amount the insurer will pay for all claims and associated costs during the policy period, representing the aggregate coverage limit.' ;
    rdfs:domain ind:IndemnityPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:limitPerClaimAmount rdf:type rdf:Property ;
    rdfs:label 'Limit Per Claim Amount' ;
    rdfs:comment 'The maximum amount the insurer will pay for any single claim or related series of claims, representing the per-occurrence limit.' ;
    rdfs:domain ind:IndemnityPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextPremiumDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Premium Due Date' ;
    rdfs:comment 'The date on which the next premium payment is due for this policy.' ;
    rdfs:domain ind:IndemnityPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:policyDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Policy Document Reference' ;
    rdfs:comment 'Reference identifier or document management system location for the full policy wording, schedule, and endorsements.' ;
    rdfs:domain ind:IndemnityPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyNumber rdf:type rdf:Property ;
    rdfs:label 'Policy Number' ;
    rdfs:comment 'The externally-known unique policy number assigned by the insurer for this professional indemnity insurance policy.' ;
    rdfs:domain ind:IndemnityPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyStatus rdf:type rdf:Property ;
    rdfs:label 'Policy Status' ;
    rdfs:comment 'Current lifecycle status of the professional indemnity insurance policy.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyType rdf:type rdf:Property ;
    rdfs:label 'Policy Type' ;
    rdfs:comment 'Classification of the professional indemnity policy indicating whether it is primary coverage, excess layer, run-off coverage for closed practices, top-up coverage, or successor practice coverage.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:premiumPaymentFrequency rdf:type rdf:Property ;
    rdfs:label 'Premium Payment Frequency' ;
    rdfs:comment 'The frequency at which premium payments are made for this policy.' ;
    rdfs:domain ind:IndemnityPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:premiumPaymentStatus rdf:type rdf:Property ;
    rdfs:label 'Premium Payment Status' ;
    rdfs:comment 'Current status of premium payment obligations for this policy period.' ;
    rdfs:domain ind:IndemnityPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualifyingInsurerFlag rdf:type rdf:Property ;
    rdfs:label 'Qualifying Insurer Flag' ;
    rdfs:comment 'Indicates whether the insurer is a qualifying insurer as defined by the SRA or relevant regulatory authority, meeting minimum financial strength and regulatory requirements.' ;
    rdfs:domain ind:IndemnityPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Date' ;
    rdfs:comment 'The date on which this policy is scheduled for renewal or replacement with a successor policy.' ;
    rdfs:domain ind:IndemnityPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalNoticeSentDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Notice Sent Date' ;
    rdfs:comment 'The date on which the renewal notice was sent to the firm by the insurer or broker.' ;
    rdfs:domain ind:IndemnityPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responsiblePartnerName rdf:type rdf:Property ;
    rdfs:label 'Responsible Partner Name' ;
    rdfs:comment 'Name of the partner or senior officer responsible for managing this professional indemnity insurance policy and ensuring regulatory compliance.' ;
    rdfs:domain ind:IndemnityPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retroactiveDate rdf:type rdf:Property ;
    rdfs:label 'Retroactive Date' ;
    rdfs:comment 'The earliest date from which claims arising from professional services will be covered under this policy, establishing the backward coverage limit for claims-made policies.' ;
    rdfs:domain ind:IndemnityPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allegedNegligenceDescription rdf:type rdf:Property ;
    rdfs:label 'Alleged Negligence Description' ;
    rdfs:comment 'Detailed narrative description of the alleged professional negligence, error, omission, or breach of duty that forms the basis of the claim. Includes circumstances, timeline, and alleged impact.' ;
    rdfs:domain ind:IndemnityClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimClosureDate rdf:type rdf:Property ;
    rdfs:label 'Claim Closure Date' ;
    rdfs:comment 'Date on which the claim was formally closed by the insurer and the firm, either through settlement, withdrawal, or dismissal.' ;
    rdfs:domain ind:IndemnityClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:claimType rdf:type rdf:Property ;
    rdfs:label 'Claim Type' ;
    rdfs:comment 'Classification of the nature of the professional indemnity claim based on the type of alleged error or omission. [ENUM-REF-CANDIDATE: negligence|breach_of_duty|conflict_of_interest|missed_deadline|inadequate_advice|document_error|fraud|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:IndemnityClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimantContactEmail rdf:type rdf:Property ;
    rdfs:label 'Claimant Contact Email' ;
    rdfs:comment 'Primary email address for correspondence with the claimant or their legal representative.' ;
    rdfs:domain ind:IndemnityClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimantContactPhone rdf:type rdf:Property ;
    rdfs:label 'Claimant Contact Phone' ;
    rdfs:comment 'Primary telephone number for the claimant or their legal representative.' ;
    rdfs:domain ind:IndemnityClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimsHandlerName rdf:type rdf:Property ;
    rdfs:label 'Claims Handler Name' ;
    rdfs:comment 'Name of the individual at the insurer or third-party administrator responsible for managing this claim.' ;
    rdfs:domain ind:IndemnityClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageConfirmationDate rdf:type rdf:Property ;
    rdfs:label 'Coverage Confirmation Date' ;
    rdfs:comment 'Date on which the insurer confirmed or denied coverage for the claim.' ;
    rdfs:domain ind:IndemnityClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coverageConfirmationStatus rdf:type rdf:Property ;
    rdfs:label 'Coverage Confirmation Status' ;
    rdfs:comment 'Status of the insurer\'s determination regarding whether the claim is covered under the professional indemnity policy.' ;
    rdfs:domain ind:IndemnityClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defenceCostsAmount rdf:type rdf:Property ;
    rdfs:label 'Defence Costs Amount' ;
    rdfs:comment 'Total costs incurred in defending the claim, including legal fees, expert witness fees, and other litigation expenses. May be covered by the insurer depending on policy terms.' ;
    rdfs:domain ind:IndemnityClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:defenceCostsCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Defence Costs Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the defence costs amount.' ;
    rdfs:domain ind:IndemnityClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedExposureAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Exposure Amount' ;
    rdfs:comment 'Initial estimate of the firm\'s potential financial exposure or liability for this claim, including damages, costs, and interest. Updated as the claim progresses.' ;
    rdfs:domain ind:IndemnityClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedExposureCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Estimated Exposure Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the estimated exposure amount.' ;
    rdfs:domain ind:IndemnityClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insurerAcknowledgementDate rdf:type rdf:Property ;
    rdfs:label 'Insurer Acknowledgement Date' ;
    rdfs:comment 'Date on which the insurer formally acknowledged receipt of the claim notification.' ;
    rdfs:domain ind:IndemnityClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:policyYear rdf:type rdf:Property ;
    rdfs:label 'Policy Year' ;
    rdfs:comment 'Insurance policy year during which the claim was notified or the incident occurred, depending on policy terms (claims-made vs occurrence basis).' ;
    rdfs:domain ind:IndemnityClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reserveCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Reserve Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the reserve amount.' ;
    rdfs:domain ind:IndemnityClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reserveLastUpdatedDate rdf:type rdf:Property ;
    rdfs:label 'Reserve Last Updated Date' ;
    rdfs:comment 'Date on which the reserve amount was last reviewed and updated by the insurer or claims handler.' ;
    rdfs:domain ind:IndemnityClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:settlementCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Settlement Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the settlement amount.' ;
    rdfs:domain ind:IndemnityClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sraReportDate rdf:type rdf:Property ;
    rdfs:label 'Sra Report Date' ;
    rdfs:comment 'Date on which the claim was reported to the Solicitors Regulation Authority, if applicable.' ;
    rdfs:domain ind:IndemnityClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:implementingControlFrameworkId rdf:type rdf:Property ;
    rdfs:label 'Implementing Control Framework Id' ;
    rdfs:comment 'Foreign key linking to compliance.control_framework. Business justification: Policies are often written to implement specific control framework requirements (e.g., \'Information Security Policy\' implements ISO 27001, \'Data Retention Policy\' implements GDPR requirements). The po' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ControlFramework .

ind:approvalAuthority rdf:type rdf:Property ;
    rdfs:label 'Approval Authority' ;
    rdfs:comment 'Name or title of the individual or committee with authority to approve the policy (e.g., Chief Legal Officer, Compliance Committee, Board of Directors).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachReportingProcedure rdf:type rdf:Property ;
    rdfs:label 'Breach Reporting Procedure' ;
    rdfs:comment 'Description of the procedure for reporting breaches or violations of this policy.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentLocation rdf:type rdf:Property ;
    rdfs:label 'Document Location' ;
    rdfs:comment 'File path, DMS reference, or URL where the full policy document is stored (e.g., iManage workspace ID, NetDocuments link).' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerDepartment rdf:type rdf:Property ;
    rdfs:label 'Owner Department' ;
    rdfs:comment 'Department or business unit responsible for the policy (e.g., Compliance, Risk Management, Legal Operations).' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyCode rdf:type rdf:Property ;
    rdfs:label 'Policy Code' ;
    rdfs:comment 'Unique business identifier code for the policy, typically following firm naming convention (e.g., AML-001, GDPR-002, SOX-003).' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyName rdf:type rdf:Property ;
    rdfs:label 'Policy Name' ;
    rdfs:comment 'Full name of the compliance policy (e.g., Anti-Money Laundering Policy, Data Protection Policy, Conflicts of Interest Policy).' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryObligationsSatisfied rdf:type rdf:Property ;
    rdfs:label 'Regulatory Obligations Satisfied' ;
    rdfs:comment 'Comma-separated list or description of specific regulatory obligations that this policy satisfies (e.g., GDPR Article 5, FATF Recommendation 10, SOX Section 404).' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewCycleMonths rdf:type rdf:Property ;
    rdfs:label 'Review Cycle Months' ;
    rdfs:comment 'Frequency in months at which the policy must be reviewed and reaffirmed (e.g., 12, 24, 36).' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trainingFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Training Frequency Months' ;
    rdfs:comment 'Frequency in months at which training must be completed by applicable staff (e.g., 12, 24).' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:governingPolicyId rdf:type rdf:Property ;
    rdfs:label 'Governing Policy Id' ;
    rdfs:comment 'Foreign key linking to compliance.policy. Business justification: Client acceptance and conflicts-of-interest policies govern every conflict check — the policy defines screening scope, waiver conditions, and documentation requirements. Compliance officers and audito' ;
    rdfs:domain ind:Check ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Policy .

ind:actualTurnaroundHours rdf:type rdf:Property ;
    rdfs:label 'Actual Turnaround Hours' ;
    rdfs:comment 'Actual elapsed time in hours from submission to final disposition, used for Service Level Agreement (SLA) compliance monitoring and process improvement.' ;
    rdfs:domain ind:Check ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assigned Timestamp' ;
    rdfs:comment 'Date and time when the conflict check was assigned to the primary reviewer for analysis.' ;
    rdfs:domain ind:Check ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:checkType rdf:type rdf:Property ;
    rdfs:label 'Check Type' ;
    rdfs:comment 'Classification of the conflict check based on the triggering event and applicable American Bar Association (ABA) Model Rules of Professional Conduct. ABA Rule 1.7 addresses concurrent conflicts of interest with current clients, Rule 1.9 addresses conflicts with former clients, and Rule 1.10 addresses imputed disqualification within the firm.' ;
    rdfs:domain ind:Check ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearanceStatus rdf:type rdf:Property ;
    rdfs:label 'Clearance Status' ;
    rdfs:comment 'Current lifecycle status of the conflict check indicating whether the matter or engagement has been cleared to proceed, rejected due to conflicts, or is pending further review.' ;
    rdfs:domain ind:Conflict ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cleared Timestamp' ;
    rdfs:comment 'Date and time when the conflict check received final clearance approval, allowing the matter or engagement to proceed.' ;
    rdfs:domain ind:Check ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:clientWaiverObtained rdf:type rdf:Property ;
    rdfs:label 'Client Waiver Obtained' ;
    rdfs:comment 'Indicates whether the required client waiver has been obtained and documented in accordance with professional conduct rules.' ;
    rdfs:domain ind:Check ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clientWaiverRequired rdf:type rdf:Property ;
    rdfs:label 'Client Waiver Required' ;
    rdfs:comment 'Indicates whether informed consent and waiver from affected clients is required to proceed with the engagement despite identified conflicts.' ;
    rdfs:domain ind:Check ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conflictSeverity rdf:type rdf:Property ;
    rdfs:label 'Conflict Severity' ;
    rdfs:comment 'Assessment of the severity or risk level of identified conflicts, used to prioritize review and determine escalation requirements.' ;
    rdfs:domain ind:Conflict ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposition rdf:type rdf:Property ;
    rdfs:label 'Disposition' ;
    rdfs:comment 'Final outcome of the conflict check process, including any conditions or mitigation measures such as ethical wall implementation or client waiver requirements.' ;
    rdfs:domain ind:Check ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ethicsPartnerDisposition rdf:type rdf:Property ;
    rdfs:label 'Ethics Partner Disposition' ;
    rdfs:comment 'Final recommendation or decision rendered by the ethics partner regarding clearance of the conflict check.' ;
    rdfs:domain ind:Check ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ethicsPartnerName rdf:type rdf:Property ;
    rdfs:label 'Ethics Partner Name' ;
    rdfs:comment 'Full name of the ethics partner responsible for final review and approval authority.' ;
    rdfs:domain ind:Check ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mitigationMeasures rdf:type rdf:Property ;
    rdfs:label 'Mitigation Measures' ;
    rdfs:comment 'Description of measures implemented to mitigate identified conflicts, such as ethical walls, client waivers, or engagement scope limitations.' ;
    rdfs:domain ind:Check ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryReviewerDisposition rdf:type rdf:Property ;
    rdfs:label 'Primary Reviewer Disposition' ;
    rdfs:comment 'Recommendation or decision rendered by the primary reviewer regarding clearance of the conflict check.' ;
    rdfs:domain ind:Check ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryReviewerName rdf:type rdf:Property ;
    rdfs:label 'Primary Reviewer Name' ;
    rdfs:comment 'Full name of the primary reviewer assigned to conduct the conflict analysis.' ;
    rdfs:domain ind:Check ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Rejected Timestamp' ;
    rdfs:comment 'Date and time when the conflict check was formally rejected due to unresolvable conflicts or failure to obtain required waivers.' ;
    rdfs:domain ind:Check ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requestorEmail rdf:type rdf:Property ;
    rdfs:label 'Requestor Email' ;
    rdfs:comment 'Email address of the conflict check requestor for communication and notification purposes.' ;
    rdfs:domain ind:Check ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestorName rdf:type rdf:Property ;
    rdfs:label 'Requestor Name' ;
    rdfs:comment 'Full name of the individual who submitted the conflict check request.' ;
    rdfs:domain ind:Check ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reviewed Timestamp' ;
    rdfs:comment 'Date and time when the primary reviewer completed their analysis and rendered a disposition.' ;
    rdfs:domain ind:Check ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reviewerNotes rdf:type rdf:Property ;
    rdfs:label 'Reviewer Notes' ;
    rdfs:comment 'Internal notes and analysis documented by the conflicts review team during the screening and clearance process.' ;
    rdfs:domain ind:Check ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaMetFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Met Flag' ;
    rdfs:comment 'Indicates whether the conflict check was completed within the target Service Level Agreement (SLA) timeframe.' ;
    rdfs:domain ind:Check ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaTargetHours rdf:type rdf:Property ;
    rdfs:label 'Sla Target Hours' ;
    rdfs:comment 'Target number of hours within which the conflict check should be completed, based on firm Service Level Agreement (SLA) policies and priority level.' ;
    rdfs:domain ind:Check ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supervisingPartnerDisposition rdf:type rdf:Property ;
    rdfs:label 'Supervising Partner Disposition' ;
    rdfs:comment 'Recommendation or decision rendered by the supervising partner regarding acceptance of the engagement subject to conflict clearance.' ;
    rdfs:domain ind:Check ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supervisingPartnerName rdf:type rdf:Property ;
    rdfs:label 'Supervising Partner Name' ;
    rdfs:comment 'Full name of the supervising partner who will manage the engagement if approved.' ;
    rdfs:domain ind:Check ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggeringEvent rdf:type rdf:Property ;
    rdfs:label 'Triggering Event' ;
    rdfs:comment 'Detailed description of the business event that initiated the conflict check, such as new matter intake, lateral hire onboarding, merger or acquisition activity, or client relationship change.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverObtainedDate rdf:type rdf:Property ;
    rdfs:label 'Waiver Obtained Date' ;
    rdfs:comment 'Date on which the client waiver was formally obtained and documented.' ;
    rdfs:domain ind:Check ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conflictPartyId rdf:type rdf:Property ;
    rdfs:label 'Conflict Party Id' ;
    rdfs:comment 'Unique identifier for the conflict party record. Primary key for the conflict party registry. This is the system-generated identifier used internally for conflict search indexing and relationship mapping.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConflictParty .

ind:ccpaSubjectFlag rdf:type rdf:Property ;
    rdfs:label 'Ccpa Subject Flag' ;
    rdfs:comment 'Indicates whether this party is a consumer under CCPA (California resident). True indicates CCPA applies, requiring compliance with consumer rights (right to know, right to delete, right to opt-out of sale). False indicates CCPA does not apply. Used to enforce data governance policies for California-based parties.' ;
    rdfs:domain ind:ConflictParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conflictSearchIndexedFlag rdf:type rdf:Property ;
    rdfs:label 'Conflict Search Indexed Flag' ;
    rdfs:comment 'Indicates whether this party record has been indexed in the conflict search engine and is available for conflict checking. True indicates the party is searchable; false indicates indexing is pending or failed. Used to ensure data quality and completeness of the conflict search universe.' ;
    rdfs:domain ind:ConflictParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataResidencyJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Data Residency Jurisdiction' ;
    rdfs:comment 'The jurisdiction in which this party\'s data must be stored and processed to comply with data protection regulations. For EU/UK natural persons, this must be an EU/UK region per GDPR Article 44-50 (cross-border data transfers). For parties in other jurisdictions, this reflects applicable data localization laws. Critical for multi-jurisdictional firms to ensure compliant data storage and processing.' ;
    rdfs:domain ind:ConflictParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalPartyReference rdf:type rdf:Property ;
    rdfs:label 'External Party Reference' ;
    rdfs:comment 'An external reference identifier for this party, such as a client-provided reference number, a court case number, or a third-party system identifier. Used for cross-referencing with external systems and documents. Optional field for additional context.' ;
    rdfs:domain ind:ConflictParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprSubjectFlag rdf:type rdf:Property ;
    rdfs:label 'Gdpr Subject Flag' ;
    rdfs:comment 'Indicates whether this party is a data subject under GDPR (EU/UK natural person or entity operating in EU/UK). True indicates GDPR applies, requiring compliance with data subject rights (access, rectification, erasure, portability) and cross-border transfer restrictions. False indicates GDPR does not apply. Used to enforce data governance policies and access controls.' ;
    rdfs:domain ind:ConflictParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:identifierType rdf:type rdf:Property ;
    rdfs:label 'Identifier Type' ;
    rdfs:comment 'The type of official identifier associated with this party. Tax_id represents a tax identification number (EIN, SSN, VAT); company_registration represents a corporate registry number; passport represents a passport number; national_id represents a government-issued ID; duns_number represents a Dun & Bradstreet identifier; LEI (Legal Entity Identifier) represents an ISO 17442 identifier for financial entities. Used in conjunction with party_identifier_value for KYC/AML verification.' ;
    rdfs:domain ind:ConflictParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identifierValue rdf:type rdf:Property ;
    rdfs:label 'Identifier Value' ;
    rdfs:comment 'The actual identifier value corresponding to the party_identifier_type. For example, the EIN number, company registration number, passport number, or LEI code. This field is restricted due to PII sensitivity and is used for definitive party matching and KYC/AML verification. Must be encrypted at rest and subject to access controls per firm data governance policy.' ;
    rdfs:domain ind:ConflictParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:jurisdictionOfPrimaryOperations rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Of Primary Operations' ;
    rdfs:comment 'The primary geographic jurisdiction where the party conducts business operations or resides. May differ from jurisdiction of incorporation for multinational entities. Used for conflict analysis when parties operate across multiple jurisdictions and for assessing cross-border data transfer requirements.' ;
    rdfs:domain ind:ConflictParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nameVariant1 rdf:type rdf:Property ;
    rdfs:label 'Name Variant 1' ;
    rdfs:comment 'First alternate name or alias for the party. Used to capture DBA (Doing Business As) names, trade names, former legal names, or common abbreviations. Critical for comprehensive conflict search coverage to ensure all name variations are indexed.' ;
    rdfs:domain ind:ConflictParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nameVariant2 rdf:type rdf:Property ;
    rdfs:label 'Name Variant 2' ;
    rdfs:comment 'Second alternate name or alias for the party. Captures additional name variations such as translated names, historical names, or subsidiary brand names to ensure thorough conflict screening.' ;
    rdfs:domain ind:ConflictParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nameVariant3 rdf:type rdf:Property ;
    rdfs:label 'Name Variant 3' ;
    rdfs:comment 'Third alternate name or alias for the party. Provides additional name variant coverage for complex entities with multiple operating names or jurisdictional variations.' ;
    rdfs:domain ind:ConflictParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordVersion rdf:type rdf:Property ;
    rdfs:label 'Record Version' ;
    rdfs:comment 'The version number of this party record, incremented with each modification. Used for optimistic locking and change tracking. Starts at 1 when the record is created.' ;
    rdfs:domain ind:ConflictParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:roleClassification rdf:type rdf:Property ;
    rdfs:label 'Role Classification' ;
    rdfs:comment 'The role this party plays in conflict analysis. Client indicates a current or former client of the firm; adverse_party indicates an opposing party in litigation or transaction; related_entity indicates a corporate affiliate, subsidiary, or parent; guarantor indicates a party providing financial backing; beneficial_owner indicates the ultimate controlling individual; witness indicates a party who may provide testimony. This classification drives conflict rule application per ABA Model Rules 1.7, 1.9, and 1.10.' ;
    rdfs:domain ind:ConflictParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemPartyReference rdf:type rdf:Property ;
    rdfs:label 'Source System Party Reference' ;
    rdfs:comment 'The unique identifier for this party in the source system (e.g., the client ID in Elite 3E, the account ID in CRM). Used for cross-system reconciliation and data lineage tracking. Null if the party was created directly in the conflict system.' ;
    rdfs:domain ind:ConflictParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ultimateBeneficialOwnerName rdf:type rdf:Property ;
    rdfs:label 'Ultimate Beneficial Owner Name' ;
    rdfs:comment 'The name of the ultimate beneficial owner (UBO) — the natural person(s) who ultimately own or control the entity, typically defined as owning 25% or more of the entity or exercising control through other means. Required for KYC/AML compliance and for identifying individual-level conflicts when representing corporate entities. Restricted due to PII sensitivity.' ;
    rdfs:domain ind:ConflictParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:searchExecutionId rdf:type rdf:Property ;
    rdfs:label 'Search Execution Id' ;
    rdfs:comment 'Primary key for search_execution' ;
    rdfs:domain ind:Conflict ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SearchExecution .

ind:primaryCheckId rdf:type rdf:Property ;
    rdfs:label 'Primary Check Id' ;
    rdfs:comment 'FK to conflict.conflict_check.conflict_check_id — Each search execution belongs to exactly one conflict check. This is the header-to-line relationship that enables reconstructing the full search scope of a check.' ;
    rdfs:domain ind:SearchExecution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Check .

ind:toCheckId rdf:type rdf:Property ;
    rdfs:label 'To Check Id' ;
    rdfs:comment 'FK to conflict.conflict_check.conflict_check_id — Every search execution is spawned by a specific conflict check — this is the core parent-child relationship in the screening workflow. Without this FK, you cannot reconstruct which searches belong to ' ;
    rdfs:domain ind:Conflict ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Check .

ind:ethicalWallConsiderationFlag rdf:type rdf:Property ;
    rdfs:label 'Ethical Wall Consideration Flag' ;
    rdfs:comment 'Indicates whether this search execution considered existing ethical walls (information barriers) in the conflict analysis. When true, conflicts may be waivable if an effective ethical wall can be established per ABA Rule 1.10.' ;
    rdfs:domain ind:SearchExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exactMatchCount rdf:type rdf:Property ;
    rdfs:label 'Exact Match Count' ;
    rdfs:comment 'The number of hits that were exact string matches (case-insensitive). Subset of total hit_count. Exact matches typically require immediate escalation.' ;
    rdfs:domain ind:SearchExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fuzzyMatchApplied rdf:type rdf:Property ;
    rdfs:label 'Fuzzy Match Applied' ;
    rdfs:comment 'Indicates whether fuzzy matching algorithms were applied to capture approximate string matches, accounting for typos, abbreviations, and minor variations.' ;
    rdfs:domain ind:SearchExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fuzzyMatchCount rdf:type rdf:Property ;
    rdfs:label 'Fuzzy Match Count' ;
    rdfs:comment 'The number of hits that were fuzzy matches (approximate string similarity). Subset of total hit_count. Requires review to determine relevance.' ;
    rdfs:domain ind:SearchExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fuzzyMatchThreshold rdf:type rdf:Property ;
    rdfs:label 'Fuzzy Match Threshold' ;
    rdfs:comment 'The similarity threshold percentage (0-100) used for fuzzy matching. Higher values require closer matches. Typically set between 70-90% depending on firm policy.' ;
    rdfs:domain ind:SearchExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hitCount rdf:type rdf:Property ;
    rdfs:label 'Hit Count' ;
    rdfs:comment 'The total number of potential conflict matches returned by this search execution. A hit count of zero indicates no conflicts found; non-zero requires human review.' ;
    rdfs:domain ind:SearchExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:includeFormerNamesFlag rdf:type rdf:Property ;
    rdfs:label 'Include Former Names Flag' ;
    rdfs:comment 'Indicates whether the search included historical names and aliases (e.g., maiden names, previous corporate names, DBA names). Essential for comprehensive conflict detection.' ;
    rdfs:domain ind:SearchExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:includeSubsidiariesFlag rdf:type rdf:Property ;
    rdfs:label 'Include Subsidiaries Flag' ;
    rdfs:comment 'Indicates whether the search included subsidiary and affiliate entities of the searched organization. Critical for corporate family conflict detection.' ;
    rdfs:domain ind:SearchExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:industryFilter rdf:type rdf:Property ;
    rdfs:label 'Industry Filter' ;
    rdfs:comment 'Optional industry sector filter applied to narrow the search scope to specific client industries (e.g., Financial Services, Healthcare, Technology). May contain comma-separated industry codes.' ;
    rdfs:domain ind:SearchExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lateralHireScreenFlag rdf:type rdf:Property ;
    rdfs:label 'Lateral Hire Screen Flag' ;
    rdfs:comment 'Indicates whether this search was executed as part of a lateral hire screening process. Lateral hire searches require broader scope to identify conflicts the incoming attorney may bring from their previous firm.' ;
    rdfs:domain ind:SearchExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:phoneticMatchCount rdf:type rdf:Property ;
    rdfs:label 'Phonetic Match Count' ;
    rdfs:comment 'The number of hits that were phonetic matches (sound-alike names). Subset of total hit_count. Requires review to determine if they represent the same entity.' ;
    rdfs:domain ind:SearchExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:phoneticVariantApplied rdf:type rdf:Property ;
    rdfs:label 'Phonetic Variant Applied' ;
    rdfs:comment 'Indicates whether phonetic matching algorithms (e.g., Soundex, Metaphone) were applied to capture names that sound similar but are spelled differently.' ;
    rdfs:domain ind:SearchExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:practiceAreaFilter rdf:type rdf:Property ;
    rdfs:label 'Practice Area Filter' ;
    rdfs:comment 'Optional practice area filter applied to narrow the search scope to specific legal practice areas (e.g., M&A, IP, Litigation). May contain comma-separated practice area codes.' ;
    rdfs:domain ind:SearchExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Created Timestamp' ;
    rdfs:comment 'The timestamp when this search execution record was first created in the conflict system. Typically identical or very close to search_execution_timestamp.' ;
    rdfs:domain ind:SearchExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Updated Timestamp' ;
    rdfs:comment 'The timestamp when this search execution record was last modified. Updates may occur if search results are re-analyzed or if additional metadata is appended.' ;
    rdfs:domain ind:SearchExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:relationshipDepth rdf:type rdf:Property ;
    rdfs:label 'Relationship Depth' ;
    rdfs:comment 'The number of relationship hops traversed during the search. Depth of 1 searches direct relationships; depth of 2+ searches related entities (e.g., subsidiaries, affiliates, beneficial owners). Higher depth increases search comprehensiveness but also processing time.' ;
    rdfs:domain ind:SearchExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:searchAlgorithmVersion rdf:type rdf:Property ;
    rdfs:label 'Search Algorithm Version' ;
    rdfs:comment 'The version identifier of the conflict search algorithm used for this execution. Enables audit trail and reproducibility when algorithms are updated or tuned.' ;
    rdfs:domain ind:SearchExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:searchDurationMilliseconds rdf:type rdf:Property ;
    rdfs:label 'Search Duration Milliseconds' ;
    rdfs:comment 'The elapsed time in milliseconds from search initiation to result return. Used for performance monitoring and system optimization.' ;
    rdfs:domain ind:SearchExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:searchExecutionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Search Execution Timestamp' ;
    rdfs:comment 'The precise date and time when this search was executed in the conflict system. Critical for audit trail and establishing the temporal context of conflict clearance.' ;
    rdfs:domain ind:SearchExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:searchResultHash rdf:type rdf:Property ;
    rdfs:label 'Search Result Hash' ;
    rdfs:comment 'Cryptographic hash of the search result set. Enables detection of result changes if the same search is re-executed later, supporting audit and change tracking.' ;
    rdfs:domain ind:SearchExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:searchString rdf:type rdf:Property ;
    rdfs:label 'Search String' ;
    rdfs:comment 'The exact name or entity string submitted for conflict search. This is the raw input text used to query the conflict database for potential matches.' ;
    rdfs:domain ind:SearchExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:searchType rdf:type rdf:Property ;
    rdfs:label 'Search Type' ;
    rdfs:comment 'The category of entity being searched. Determines which conflict rules and matching algorithms are applied.' ;
    rdfs:domain ind:SearchExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:searchHitId rdf:type rdf:Property ;
    rdfs:label 'Search Hit Id' ;
    rdfs:comment 'Primary key for search_hit' ;
    rdfs:domain ind:SearchHit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:conflictRuleId rdf:type rdf:Property ;
    rdfs:label 'Conflict Rule Id' ;
    rdfs:comment 'Foreign key linking to conflict.rule. Business justification: Links each conflict hit to the specific rule it potentially violates. search_hit currently has conflict_severity and initial_assessment but no reference to which rule is triggered. This FK enables rul' ;
    rdfs:domain ind:Conflict ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rule .

ind:ethicalWallId rdf:type rdf:Property ;
    rdfs:label 'Ethical Wall Id' ;
    rdfs:comment 'Reference to the ethical wall configuration established to address this conflict. Null if no ethical wall is required.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EthicalWall .

ind:hitDocketId rdf:type rdf:Property ;
    rdfs:label 'Hit Docket Id' ;
    rdfs:comment 'Foreign key linking to court.docket. Business justification: Search hits identify conflicts with existing litigation matters. Real process: hit analysis requires linking to the court docket for adverse party and relationship assessment. New attribute; matched_m' ;
    rdfs:domain ind:SearchHit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Docket .

ind:judgeId rdf:type rdf:Property ;
    rdfs:label 'Judge Id' ;
    rdfs:comment 'Foreign key linking to court.judge. Business justification: Conflict hits may identify prior appearances before the same judge. Real process: judicial relationship tracking for recusal analysis and strategic litigation planning. New attribute needed; no existi' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Judge .

ind:matchedIpAssetId rdf:type rdf:Property ;
    rdfs:label 'Matched Ip Asset Id' ;
    rdfs:comment 'Foreign key linking to ip.asset. Business justification: Search hits identify conflicts arising from prior representation on specific IP assets (firm prosecuted Patent A for Client X, now adverse party in litigation). Critical for IP conflict analysis and c' ;
    rdfs:domain ind:SearchHit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:matchedMatterId rdf:type rdf:Property ;
    rdfs:label 'Matched Matter Id' ;
    rdfs:comment 'Reference to the matter or engagement where the conflicting relationship was found. May be null if the hit is based on party relationship only.' ;
    rdfs:domain ind:SearchHit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Matter .

ind:matchedPatentId rdf:type rdf:Property ;
    rdfs:label 'Matched Patent Id' ;
    rdfs:comment 'Foreign key linking to ip.patent. Business justification: Patent conflict reporting requires direct access to patent-specific data (prosecution_status, patent_type, claims count) not available on ip_asset. When a conflict search hits a patent, attorneys need' ;
    rdfs:domain ind:SearchHit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Patent .

ind:primarySearchConflictPartyId rdf:type rdf:Property ;
    rdfs:label 'Primary Search Conflict Party Id' ;
    rdfs:comment 'Reference to the party record that matched the search criteria. Links to the intake_party product.' ;
    rdfs:domain ind:SearchHit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConflictParty .

ind:primarySearchExecutionId rdf:type rdf:Property ;
    rdfs:label 'Primary Search Execution Id' ;
    rdfs:comment 'Reference to the parent conflict search that generated this hit. Links to the conflict_search product.' ;
    rdfs:domain ind:SearchHit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SearchExecution .

ind:toConflictPartyId rdf:type rdf:Property ;
    rdfs:label 'To Conflict Party Id' ;
    rdfs:comment 'FK to conflict.party.party_id — Each search hit references the matched party record from the conflict party index. Critical for resolving what entity was matched.' ;
    rdfs:domain ind:SearchHit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConflictParty .

ind:toSearchExecutionId rdf:type rdf:Property ;
    rdfs:label 'To Search Execution Id' ;
    rdfs:comment 'FK to conflict.search_execution.search_execution_id — Each hit is produced by a specific search execution. This is the fundamental lineage link from hit back to the search that produced it.' ;
    rdfs:domain ind:SearchHit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SearchExecution .

ind:assessmentNotes rdf:type rdf:Property ;
    rdfs:label 'Assessment Notes' ;
    rdfs:comment 'Free-text notes recorded by the reviewing attorney explaining the rationale for the initial assessment. Critical for audit trail and ethics compliance.' ;
    rdfs:domain ind:SearchHit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalatedToPartner rdf:type rdf:Property ;
    rdfs:label 'Escalated To Partner' ;
    rdfs:comment 'Indicates whether this conflict hit has been escalated to a partner for senior-level review. Required for high-severity conflicts.' ;
    rdfs:domain ind:SearchHit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hitSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Hit Sequence Number' ;
    rdfs:comment 'Sequential ordering of this hit within the parent conflict search results. Used for display and review prioritization.' ;
    rdfs:domain ind:SearchHit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hitSourceRecordReference rdf:type rdf:Property ;
    rdfs:label 'Hit Source Record Reference' ;
    rdfs:comment 'The unique identifier of the source record in the originating system. Used for drill-back and data reconciliation.' ;
    rdfs:domain ind:SearchHit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hitSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Hit Source System' ;
    rdfs:comment 'The system or database that provided the data for this conflict hit. Used for data lineage and quality assessment.' ;
    rdfs:domain ind:SearchHit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initialAssessment rdf:type rdf:Property ;
    rdfs:label 'Initial Assessment' ;
    rdfs:comment 'The reviewing attorneys initial assessment of the conflict hit. Drives the clearance workflow and escalation path.' ;
    rdfs:domain ind:SearchHit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isFalsePositive rdf:type rdf:Property ;
    rdfs:label 'Is False Positive' ;
    rdfs:comment 'Indicates whether this conflict hit has been determined to be a false positive (e.g., name collision, unrelated entity). Used for machine learning model training.' ;
    rdfs:domain ind:SearchHit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lppRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Lpp Risk Flag' ;
    rdfs:comment 'Indicates whether this conflict hit presents a risk to Legal Professional Privilege (attorney-client privilege). High-risk hits require senior partner review.' ;
    rdfs:domain ind:SearchHit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:matchConfidenceScore rdf:type rdf:Property ;
    rdfs:label 'Match Confidence Score' ;
    rdfs:comment 'Algorithmic confidence score (0.00 to 100.00) indicating the likelihood that the matched party is the same entity as the search subject. Based on name similarity, identifier matching, and relationship graph analysis.' ;
    rdfs:domain ind:SearchHit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:matchMethod rdf:type rdf:Property ;
    rdfs:label 'Match Method' ;
    rdfs:comment 'The matching technique that surfaced this hit (exact name match, fuzzy name match, identifier match, corporate family relationship, etc.). Used for quality assessment and false-positive filtering. [ENUM-REF-CANDIDATE: exact_name|fuzzy_name|identifier|alias|corporate_family|address|email|phone — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SearchHit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchedClientName rdf:type rdf:Property ;
    rdfs:label 'Matched Client Name' ;
    rdfs:comment 'The name of the client on the historical matter where the conflict was found. Critical for assessing current vs. former client conflicts under ABA Rule 1.9.' ;
    rdfs:domain ind:SearchHit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchedMatterDescription rdf:type rdf:Property ;
    rdfs:label 'Matched Matter Description' ;
    rdfs:comment 'Brief description of the historical matter where the conflict was identified. Provides context for conflict reviewers.' ;
    rdfs:domain ind:SearchHit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchedPartyName rdf:type rdf:Property ;
    rdfs:label 'Matched Party Name' ;
    rdfs:comment 'The name of the party as recorded in the historical matter or party index. Denormalized for display and review efficiency.' ;
    rdfs:domain ind:SearchHit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matterOpenDate rdf:type rdf:Property ;
    rdfs:label 'Matter Open Date' ;
    rdfs:comment 'The date the historical matter was opened. Used to determine recency and relevance of the conflict.' ;
    rdfs:domain ind:SearchHit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:matterStatus rdf:type rdf:Property ;
    rdfs:label 'Matter Status' ;
    rdfs:comment 'Current status of the historical matter where the conflict was identified. Active matters present higher conflict risk.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipRole rdf:type rdf:Property ;
    rdfs:label 'Relationship Role' ;
    rdfs:comment 'Specific role the matched party played in the historical matter (e.g., plaintiff, defendant, guarantor, shareholder). Provides context for conflict assessment.' ;
    rdfs:domain ind:SearchHit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresWaiver rdf:type rdf:Property ;
    rdfs:label 'Requires Waiver' ;
    rdfs:comment 'Indicates whether this conflict hit requires a formal conflict waiver from the affected client(s) under ABA Rule 1.7. Drives waiver workflow.' ;
    rdfs:domain ind:SearchHit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resolutionStatus rdf:type rdf:Property ;
    rdfs:label 'Resolution Status' ;
    rdfs:comment 'Current resolution status of the conflict hit within the clearance workflow. Drives matter opening approval.' ;
    rdfs:domain ind:SearchHit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Resolution Timestamp' ;
    rdfs:comment 'Date and time when the conflict hit was resolved (cleared, declined, or waived). Null if still pending.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:responsibleAttorneyName rdf:type rdf:Property ;
    rdfs:label 'Responsible Attorney Name' ;
    rdfs:comment 'Name of the attorney who was responsible for the historical matter. Denormalized for display and conflict review.' ;
    rdfs:domain ind:SearchHit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewTimestamp rdf:type rdf:Property ;
    rdfs:label 'Review Timestamp' ;
    rdfs:comment 'Date and time when the conflict hit was reviewed by the attorney. Used for SLA tracking and compliance reporting.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reviewedByAttorneyName rdf:type rdf:Property ;
    rdfs:label 'Reviewed By Attorney Name' ;
    rdfs:comment 'Name of the attorney who performed the initial review. Denormalized for display and reporting.' ;
    rdfs:domain ind:SearchHit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substantiallyRelatedMatter rdf:type rdf:Property ;
    rdfs:label 'Substantially Related Matter' ;
    rdfs:comment 'Indicates whether the historical matter is substantially related to the proposed new matter under ABA Rule 1.9. Substantially related matters create a presumption of conflict.' ;
    rdfs:domain ind:SearchHit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waiverDate rdf:type rdf:Property ;
    rdfs:label 'Waiver Date' ;
    rdfs:comment 'Date on which the conflict waiver was obtained. Null if no waiver is required or if waiver has not yet been obtained.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:waiverObtained rdf:type rdf:Property ;
    rdfs:label 'Waiver Obtained' ;
    rdfs:comment 'Indicates whether a formal conflict waiver has been obtained from the affected client(s). Required before matter opening can proceed.' ;
    rdfs:domain ind:SearchHit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clearanceId rdf:type rdf:Property ;
    rdfs:label 'Clearance Id' ;
    rdfs:comment 'Unique identifier for the conflict clearance decision record. Primary key. Inferred role: TRANSACTION_HEADER (clearance is a discrete business event with a clear lifecycle: requested, reviewed, cleared/declined/deferred).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Clearance .

ind:primaryClearanceCheckId rdf:type rdf:Property ;
    rdfs:label 'Primary Clearance Check Id' ;
    rdfs:comment 'FK to conflict.conflict_check.conflict_check_id — Each clearance decision is the terminal outcome of a conflict check. One-to-one or one-to-many relationship that gates matter opening.' ;
    rdfs:domain ind:Clearance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Check .

ind:restrictedIpAssetId rdf:type rdf:Property ;
    rdfs:label 'Restricted Ip Asset Id' ;
    rdfs:comment 'Foreign key linking to ip.asset. Business justification: Clearances impose asset-specific scope restrictions (approved for Trademark B prosecution but not Patent C due to adverse representation). Enables granular conflict management in IP portfolios with pa' ;
    rdfs:domain ind:Clearance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:adversePartyIdentifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Adverse Party Identified Flag' ;
    rdfs:comment 'Boolean indicator whether an adverse party (opposing party in litigation or transaction) has been identified that creates a conflict with an existing client. True if adverse party conflict exists; False otherwise.' ;
    rdfs:domain ind:Clearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clearanceNumber rdf:type rdf:Property ;
    rdfs:label 'Clearance Number' ;
    rdfs:comment 'Business-facing unique identifier for the clearance decision, typically formatted as CLR-YYYY-NNNNNN. Used in correspondence and audit trails.' ;
    rdfs:domain ind:Clearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientNotificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Client Notification Required Flag' ;
    rdfs:comment 'Boolean indicator whether the client must be formally notified of the conflict and provide informed consent as a condition of clearance. True if client notification and consent are required; False otherwise.' ;
    rdfs:domain ind:Clearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clientWaiverObtainedFlag rdf:type rdf:Property ;
    rdfs:label 'Client Waiver Obtained Flag' ;
    rdfs:comment 'Boolean indicator whether informed written consent (waiver) has been obtained from all affected clients. True if all required waivers are on file; False if waivers are pending or not obtained.' ;
    rdfs:domain ind:Clearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conditionDueDate rdf:type rdf:Property ;
    rdfs:label 'Condition Due Date' ;
    rdfs:comment 'The date by which all clearance conditions must be fulfilled before the matter may proceed. Null if no conditions or no specific due date.' ;
    rdfs:domain ind:Clearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conditionFulfilledDate rdf:type rdf:Property ;
    rdfs:label 'Condition Fulfilled Date' ;
    rdfs:comment 'The date on which all clearance conditions were confirmed as fulfilled and the matter was authorized to proceed. Null if conditions are not yet fulfilled.' ;
    rdfs:domain ind:Clearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conditionFulfillmentStatus rdf:type rdf:Property ;
    rdfs:label 'Condition Fulfillment Status' ;
    rdfs:comment 'Overall status of compliance with all imposed clearance conditions. Not Applicable: no conditions imposed; Pending: conditions not yet started; In Progress: conditions being implemented; Fulfilled: all conditions satisfied; Overdue: one or more conditions past due date.' ;
    rdfs:domain ind:Clearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionsImposedFlag rdf:type rdf:Property ;
    rdfs:label 'Conditions Imposed Flag' ;
    rdfs:comment 'Boolean indicator whether the clearance was granted subject to conditions (ethical wall, scope restriction, client notification, periodic review). True if conditions exist; False if unconditional clearance or denial.' ;
    rdfs:domain ind:Clearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:decisionDate rdf:type rdf:Property ;
    rdfs:label 'Decision Date' ;
    rdfs:comment 'The date the authorizing partner or general counsel issued the final clearance decision (cleared, declined, or deferred). This date gates matter opening in Elite 3E.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deferralReason rdf:type rdf:Property ;
    rdfs:label 'Deferral Reason' ;
    rdfs:comment 'Explanation of why the clearance decision was deferred, including what additional information or client waiver is required before a final decision can be made. Empty if clearance was not deferred.' ;
    rdfs:domain ind:Clearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:denialReason rdf:type rdf:Property ;
    rdfs:label 'Denial Reason' ;
    rdfs:comment 'Detailed explanation of why the clearance was denied, including the specific conflict identified, the parties involved, and the ethical rule violated. Empty if clearance was approved. Confidential business information protected by Legal Professional Privilege (LPP).' ;
    rdfs:domain ind:Clearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ethicalWallRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Ethical Wall Required Flag' ;
    rdfs:comment 'Boolean indicator whether an ethical wall (information barrier) must be erected as a condition of clearance. True if ethical wall is mandatory; False otherwise. Ethical walls prevent information flow between conflicted timekeepers and the matter team.' ;
    rdfs:domain ind:Clearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:imputedConflictFlag rdf:type rdf:Property ;
    rdfs:label 'Imputed Conflict Flag' ;
    rdfs:comment 'Boolean indicator whether the conflict is imputed to the entire firm under ABA Rule 1.10 (conflicts of interest imputed to all lawyers in the firm). True if conflict is firm-wide; False if conflict is limited to specific timekeepers.' ;
    rdfs:domain ind:Clearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lateralHireScreeningFlag rdf:type rdf:Property ;
    rdfs:label 'Lateral Hire Screening Flag' ;
    rdfs:comment 'Boolean indicator whether this clearance is part of a lateral hire conflict screening process (evaluating conflicts that a new attorney would bring to the firm). True if lateral hire screening; False for standard new matter clearance.' ;
    rdfs:domain ind:Clearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:periodicReviewRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Periodic Review Required Flag' ;
    rdfs:comment 'Boolean indicator whether the clearance decision requires periodic re-evaluation (e.g., quarterly review of ongoing conflict status). True if periodic review is mandated; False for one-time clearance.' ;
    rdfs:domain ind:Clearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:relationshipMappingCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Relationship Mapping Completed Flag' ;
    rdfs:comment 'Boolean indicator whether comprehensive relationship mapping (identifying all corporate affiliates, subsidiaries, beneficial owners, and related parties) has been completed as part of the clearance process. True if mapping is complete; False if pending.' ;
    rdfs:domain ind:Clearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requestedDate rdf:type rdf:Property ;
    rdfs:label 'Requested Date' ;
    rdfs:comment 'The date the clearance request was formally submitted for review, typically following completion of the conflict search.' ;
    rdfs:domain ind:Clearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scopeRestrictionDescription rdf:type rdf:Property ;
    rdfs:label 'Scope Restriction Description' ;
    rdfs:comment 'Detailed description of any scope restrictions imposed as a condition of clearance. Examples: matter limited to specific transaction phase, prohibited from representing client in certain jurisdictions, restricted to advisory role only. Empty if no scope restrictions.' ;
    rdfs:domain ind:Clearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Waiver Document Reference' ;
    rdfs:comment 'Reference identifier or document management system (DMS) path to the signed client waiver or informed consent letter. Typically an iManage or NetDocuments document ID. Empty if no waiver required or not yet obtained.' ;
    rdfs:domain ind:Clearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverId rdf:type rdf:Property ;
    rdfs:label 'Waiver Id' ;
    rdfs:comment 'Unique identifier for the conflict waiver record. Primary key.' ;
    rdfs:domain ind:Waiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:signingContractPartyId rdf:type rdf:Property ;
    rdfs:label 'Signing Contract Party Id' ;
    rdfs:comment 'Foreign key linking to contract.contract_party. Business justification: A conflict waiver must be signed by an authorized representative who is a contract party. Linking to contract_party replaces denormalized signatory_name/email/title fields and enables compliance teams' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContractParty .

ind:toClearanceId rdf:type rdf:Property ;
    rdfs:label 'To Clearance Id' ;
    rdfs:comment 'FK to conflict.clearance.clearance_id — A waiver is obtained in response to a conflict identified during clearance. The waiver record must link to the clearance that required it for audit trail completeness.' ;
    rdfs:domain ind:Conflict ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Clearance .

ind:waiverClearanceId rdf:type rdf:Property ;
    rdfs:label 'Waiver Clearance Id' ;
    rdfs:comment 'FK to conflict.clearance.clearance_id — A waiver is obtained when clearance identifies a waivable conflict. The waiver must reference the clearance record that triggered the need for informed consent.' ;
    rdfs:domain ind:Waiver ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Clearance .

ind:adversePartyName rdf:type rdf:Property ;
    rdfs:label 'Adverse Party Name' ;
    rdfs:comment 'Name of the adverse party or conflicted party disclosed in the waiver, if applicable.' ;
    rdfs:domain ind:Conflict ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditTrail rdf:type rdf:Property ;
    rdfs:label 'Audit Trail' ;
    rdfs:comment 'Chronological record of all actions taken on the waiver record, including creation, approvals, modifications, and revocations.' ;
    rdfs:domain ind:Waiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conflictNatureDescription rdf:type rdf:Property ;
    rdfs:label 'Conflict Nature Description' ;
    rdfs:comment 'Detailed description of the nature of the conflict disclosed to the client, including the parties involved and the relationship creating the conflict.' ;
    rdfs:domain ind:Waiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conflictType rdf:type rdf:Property ;
    rdfs:label 'Conflict Type' ;
    rdfs:comment 'Classification of the conflict requiring waiver under ABA Model Rules (e.g., current client conflict per Rule 1.7, former client conflict per Rule 1.9). [ENUM-REF-CANDIDATE: current_client|former_client|personal_interest|third_party|positional|issue|transactional|litigation|lateral_hire|other — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Conflict ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentDocumentPath rdf:type rdf:Property ;
    rdfs:label 'Consent Document Path' ;
    rdfs:comment 'Full path or URL to the consent document in the DMS for retrieval and audit purposes.' ;
    rdfs:domain ind:Waiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentFormType rdf:type rdf:Property ;
    rdfs:label 'Consent Form Type' ;
    rdfs:comment 'The form in which informed consent was obtained from the client.' ;
    rdfs:domain ind:Waiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionDate rdf:type rdf:Property ;
    rdfs:label 'Execution Date' ;
    rdfs:comment 'Date on which the waiver was executed by the client signatory.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isScopeLimited rdf:type rdf:Property ;
    rdfs:label 'Is Scope Limited' ;
    rdfs:comment 'Indicates whether the waiver contains scope limitations or conditions.' ;
    rdfs:domain ind:Waiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revocationDate rdf:type rdf:Property ;
    rdfs:label 'Revocation Date' ;
    rdfs:comment 'Date on which the waiver was revoked by the client or the firm, if applicable.' ;
    rdfs:domain ind:Waiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revocationReason rdf:type rdf:Property ;
    rdfs:label 'Revocation Reason' ;
    rdfs:comment 'Explanation for why the waiver was revoked, if applicable.' ;
    rdfs:domain ind:Waiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeLimitationDescription rdf:type rdf:Property ;
    rdfs:label 'Scope Limitation Description' ;
    rdfs:comment 'Description of any limitations or conditions placed on the scope of the waiver (e.g., limited to specific matters, specific time periods, or specific adverse parties).' ;
    rdfs:domain ind:Waiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverStatus rdf:type rdf:Property ;
    rdfs:label 'Waiver Status' ;
    rdfs:comment 'Current lifecycle status of the waiver record. [ENUM-REF-CANDIDATE: draft|pending_review|approved|executed|declined|expired|revoked|superseded — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ethicalClearanceId rdf:type rdf:Property ;
    rdfs:label 'Ethical Clearance Id' ;
    rdfs:comment 'FK to conflict.clearance.clearance_id — Ethical walls are erected as a condition of clearance. The wall must reference the clearance decision that mandated its creation.' ;
    rdfs:domain ind:EthicalWall ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Clearance .

ind:primaryEthicalClearanceId rdf:type rdf:Property ;
    rdfs:label 'Primary Ethical Clearance Id' ;
    rdfs:comment 'Identifier of the conflict clearance record that triggered the creation of this ethical wall, establishing audit trail linkage.' ;
    rdfs:domain ind:EthicalWall ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Clearance .

ind:protectedIpAssetId rdf:type rdf:Property ;
    rdfs:label 'Protected Ip Asset Id' ;
    rdfs:comment 'Foreign key linking to ip.asset. Business justification: Ethical walls erected around specific high-value IP assets (standard-essential patents, trade secrets from lateral hire\'s prior firm). Essential for IP practice screening and information barrier enfor' ;
    rdfs:domain ind:EthicalWall ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:acknowledgmentCompletionRate rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Completion Rate' ;
    rdfs:comment 'The percentage of screened timekeepers who have completed the required acknowledgment of the ethical wall, expressed as a decimal (e.g., 0.95 for 95%).' ;
    rdfs:domain ind:EthicalWall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acknowledgmentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Required Flag' ;
    rdfs:comment 'Indicates whether screened timekeepers are required to formally acknowledge their understanding of and compliance with the ethical wall (True) or not (False).' ;
    rdfs:domain ind:Conflict ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:breachIncidentCount rdf:type rdf:Property ;
    rdfs:label 'Breach Incident Count' ;
    rdfs:comment 'The total number of documented breach or violation incidents associated with this ethical wall, tracked for compliance and risk management.' ;
    rdfs:domain ind:EthicalWall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dissolutionApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Dissolution Approved By' ;
    rdfs:comment 'Name or identifier of the partner or conflicts committee member who approved the dissolution of the ethical wall.' ;
    rdfs:domain ind:EthicalWall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dissolutionDate rdf:type rdf:Property ;
    rdfs:label 'Dissolution Date' ;
    rdfs:comment 'The actual date on which the ethical wall was formally dissolved or terminated, which may differ from the originally scheduled expiration date.' ;
    rdfs:domain ind:EthicalWall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dissolutionReason rdf:type rdf:Property ;
    rdfs:label 'Dissolution Reason' ;
    rdfs:comment 'The business or ethical reason for dissolving or expiring the ethical wall (e.g., matter concluded, lateral hire departed, conflict resolved, time-based expiration).' ;
    rdfs:domain ind:EthicalWall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eliteEnforcementFlag rdf:type rdf:Property ;
    rdfs:label 'Elite Enforcement Flag' ;
    rdfs:comment 'Indicates whether matter and timekeeper access restrictions for this ethical wall are actively enforced in the Elite 3E practice management system.' ;
    rdfs:domain ind:EthicalWall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:enforcementMechanism rdf:type rdf:Property ;
    rdfs:label 'Enforcement Mechanism' ;
    rdfs:comment 'The primary method or combination of methods used to enforce the ethical wall (e.g., system access controls in iManage and Elite 3E, physical office separation, document access restrictions).' ;
    rdfs:domain ind:EthicalWall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imanageEnforcementFlag rdf:type rdf:Property ;
    rdfs:label 'Imanage Enforcement Flag' ;
    rdfs:comment 'Indicates whether document access restrictions for this ethical wall are actively enforced in the iManage Work Document Management System (DMS).' ;
    rdfs:domain ind:EthicalWall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationSentFlag rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Flag' ;
    rdfs:comment 'Indicates whether formal notification of the ethical wall has been sent to all affected timekeepers and relevant stakeholders (True) or not (False).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryAuthority rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority' ;
    rdfs:comment 'The name of the regulatory body or jurisdiction whose rules or requirements mandate or govern this ethical wall (e.g., State Bar, SRA, specific court order).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reference' ;
    rdfs:comment 'Specific citation or reference to the regulatory rule, statute, or court order that mandates or governs this ethical wall (e.g., ABA Rule 1.10, court docket number).' ;
    rdfs:domain ind:EthicalWall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screenedTimekeeperCount rdf:type rdf:Property ;
    rdfs:label 'Screened Timekeeper Count' ;
    rdfs:comment 'The total number of timekeepers (attorneys, paralegals, staff) who are subject to this ethical wall and restricted from accessing the protected information.' ;
    rdfs:domain ind:EthicalWall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:systemEnforcementFlag rdf:type rdf:Property ;
    rdfs:label 'System Enforcement Flag' ;
    rdfs:comment 'Indicates whether the ethical wall is enforced through automated system access controls in practice management and document management systems (True) or relies on manual compliance (False).' ;
    rdfs:domain ind:EthicalWall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:triggeringReason rdf:type rdf:Property ;
    rdfs:label 'Triggering Reason' ;
    rdfs:comment 'The business or ethical circumstance that necessitated the creation of this information barrier (e.g., lateral hire with prior client relationships, adverse party representation, regulatory mandate).' ;
    rdfs:domain ind:EthicalWall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggeringReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Triggering Reason Description' ;
    rdfs:comment 'Detailed narrative explanation of the specific circumstances, parties, or matters that required the establishment of this ethical wall.' ;
    rdfs:domain ind:EthicalWall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wallCode rdf:type rdf:Property ;
    rdfs:label 'Wall Code' ;
    rdfs:comment 'Unique business identifier or reference code for the ethical wall, typically used in system integrations and reporting.' ;
    rdfs:domain ind:EthicalWall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wallName rdf:type rdf:Property ;
    rdfs:label 'Wall Name' ;
    rdfs:comment 'Business-friendly name or title assigned to this ethical screen for identification and reference purposes.' ;
    rdfs:domain ind:EthicalWall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wallStatus rdf:type rdf:Property ;
    rdfs:label 'Wall Status' ;
    rdfs:comment 'Current lifecycle status of the ethical screen indicating whether it is currently enforced or has been terminated.' ;
    rdfs:domain ind:EthicalWall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wallMembershipId rdf:type rdf:Property ;
    rdfs:label 'Wall Membership Id' ;
    rdfs:comment 'Unique identifier for the ethical wall membership record. Primary key.' ;
    rdfs:domain ind:WallMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryEthicalWallId rdf:type rdf:Property ;
    rdfs:label 'Primary Ethical Wall Id' ;
    rdfs:comment 'Reference to the ethical wall (information barrier) to which this membership record applies. Links to the ethical_wall product.' ;
    rdfs:domain ind:WallMembership ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EthicalWall .

ind:tertiaryEthicalWallId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Ethical Wall Id' ;
    rdfs:comment 'FK to conflict.ethical_wall.ethical_wall_id — Each wall membership record belongs to exactly one ethical wall. This is the master-detail relationship enabling wall enforcement.' ;
    rdfs:domain ind:WallMembership ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EthicalWall .

ind:toEthicalWallId rdf:type rdf:Property ;
    rdfs:label 'To Ethical Wall Id' ;
    rdfs:comment 'FK to conflict.ethical_wall.ethical_wall_id — Each wall membership record belongs to a specific ethical wall. This is the classic header-line relationship for screen enforcement.' ;
    rdfs:domain ind:WallMembership ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EthicalWall .

ind:accessRestrictionLevel rdf:type rdf:Property ;
    rdfs:label 'Access Restriction Level' ;
    rdfs:comment 'Granular specification of the type and scope of access restrictions enforced by this membership, such as full block (no access to any information), document block (DMS restrictions), matter block (Elite 3E restrictions), client block (all client matters), or no restriction.' ;
    rdfs:domain ind:WallMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dmsEnforcementFlag rdf:type rdf:Property ;
    rdfs:label 'Dms Enforcement Flag' ;
    rdfs:comment 'Boolean indicator (True/False) specifying whether this ethical wall membership triggers automated access control enforcement in the document management system (iManage Work or NetDocuments).' ;
    rdfs:domain ind:WallMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastOverrideDate rdf:type rdf:Property ;
    rdfs:label 'Last Override Date' ;
    rdfs:comment 'The most recent date on which an ethical wall access restriction was temporarily overridden for this timekeeper. Nullable if no overrides have occurred.' ;
    rdfs:domain ind:WallMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:membershipStatus rdf:type rdf:Property ;
    rdfs:label 'Membership Status' ;
    rdfs:comment 'Current lifecycle status of the ethical wall membership record indicating whether the membership is currently enforced, pending approval, terminated, or temporarily suspended.' ;
    rdfs:domain ind:WallMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:membershipType rdf:type rdf:Property ;
    rdfs:label 'Membership Type' ;
    rdfs:comment 'Designation indicating whether the timekeeper is included within the ethical wall (restricted from accessing matter information), excluded from the wall (permitted access), restricted (partial access with conditions), or observer (read-only monitoring role).' ;
    rdfs:domain ind:WallMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideCount rdf:type rdf:Property ;
    rdfs:label 'Override Count' ;
    rdfs:comment 'The cumulative number of times that ethical wall access restrictions have been temporarily overridden for this timekeeper membership. Used for audit and compliance monitoring.' ;
    rdfs:domain ind:WallMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overridePermittedFlag rdf:type rdf:Property ;
    rdfs:label 'Override Permitted Flag' ;
    rdfs:comment 'Boolean indicator (True/False) specifying whether temporary overrides of the ethical wall restrictions are permitted under specific circumstances (e.g., emergency access, partner approval).' ;
    rdfs:domain ind:WallMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:practiceManagementEnforcementFlag rdf:type rdf:Property ;
    rdfs:label 'Practice Management Enforcement Flag' ;
    rdfs:comment 'Boolean indicator (True/False) specifying whether this ethical wall membership triggers automated access control enforcement in the practice management system (Elite 3E or Aderant Expert) to prevent time entry, billing, or matter visibility.' ;
    rdfs:domain ind:WallMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewOutcome rdf:type rdf:Property ;
    rdfs:label 'Review Outcome' ;
    rdfs:comment 'The result of the most recent periodic review, indicating whether the ethical wall membership was continued unchanged, modified, terminated, or escalated for further analysis.' ;
    rdfs:domain ind:WallMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleId rdf:type rdf:Property ;
    rdfs:label 'Rule Id' ;
    rdfs:comment 'Primary key for rule' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:appliesToLateralHires rdf:type rdf:Property ;
    rdfs:label 'Applies To Lateral Hires' ;
    rdfs:comment 'Indicates whether this conflict rule applies to lateral hire screening (i.e., checking for conflicts when a lawyer joins the firm from another firm). True if the rule governs imputed conflicts from prior representation; False otherwise.' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appliesToProspectiveClients rdf:type rdf:Property ;
    rdfs:label 'Applies To Prospective Clients' ;
    rdfs:comment 'Indicates whether this conflict rule applies to prospective clients (i.e., individuals or organizations who consult with the firm but do not retain the firm). True if the rule governs duties to prospective clients; False otherwise.' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:automatedCheckEnabled rdf:type rdf:Property ;
    rdfs:label 'Automated Check Enabled' ;
    rdfs:comment 'Indicates whether automated conflict checking logic in Intapp Conflicts is enabled for this rule. True if the system automatically flags potential conflicts based on this rule; False if manual review is required.' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:checkLogicDescription rdf:type rdf:Property ;
    rdfs:label 'Check Logic Description' ;
    rdfs:comment 'Description of the automated conflict checking logic or algorithm used to detect violations of this rule in Intapp Conflicts. Includes the data elements checked (e.g., client relationships, matter types, adverse parties, practice areas) and the matching criteria.' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:citation rdf:type rdf:Property ;
    rdfs:label 'Citation' ;
    rdfs:comment 'The formal legal citation or reference to the source document for this conflict rule (e.g., \'ABA Model Rules of Professional Conduct Rule 1.7\', \'SRA Standards and Regulations 2019, Rule 6.1\', \'New York Rules of Professional Conduct Rule 1.7\').' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityObligation rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Obligation' ;
    rdfs:comment 'The level of confidentiality obligation imposed by this conflict rule. Absolute: no disclosure permitted; Qualified: disclosure permitted with consent or under specific circumstances; Limited: disclosure permitted for certain purposes; None: no confidentiality obligation.' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentFormRequired rdf:type rdf:Property ;
    rdfs:label 'Consent Form Required' ;
    rdfs:comment 'Indicates whether a written consent form is required from the client(s) to waive the conflict governed by this rule. True if written consent is mandatory; False if oral consent is sufficient or if the conflict is non-waivable.' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disclosureRequirements rdf:type rdf:Property ;
    rdfs:label 'Disclosure Requirements' ;
    rdfs:comment 'Description of the disclosure requirements that must be met when seeking a waiver or managing a conflict under this rule. Includes the information that must be disclosed to clients, the form of disclosure (written, oral), and the timing of disclosure.' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentationRequirements rdf:type rdf:Property ;
    rdfs:label 'Documentation Requirements' ;
    rdfs:comment 'Description of the documentation that must be maintained when managing a conflict under this rule. Includes conflict check records, waiver forms, ethical wall memos, client communications, and any other records required for compliance and audit purposes.' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isWaivable rdf:type rdf:Property ;
    rdfs:label 'Is Waivable' ;
    rdfs:comment 'Indicates whether the conflict governed by this rule may be waived by informed client consent. True if waivable under certain conditions; False if non-waivable (e.g., direct adverse representation in the same matter).' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationRecipients rdf:type rdf:Property ;
    rdfs:label 'Notification Recipients' ;
    rdfs:comment 'Description of the parties who must be notified when a conflict governed by this rule is identified (e.g., \'All affected clients\', \'Opposing counsel\', \'Tribunal\', \'Firm management\'). Null if no notification is required.' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationRequired rdf:type rdf:Property ;
    rdfs:label 'Notification Required' ;
    rdfs:comment 'Indicates whether notification to affected parties (clients, opposing counsel, tribunal) is required when a conflict governed by this rule is identified. True if notification is mandatory; False otherwise.' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresEthicalWall rdf:type rdf:Property ;
    rdfs:label 'Requires Ethical Wall' ;
    rdfs:comment 'Indicates whether this conflict rule requires the establishment of an ethical wall (information barrier, Chinese wall) to screen conflicted individuals from the matter. True if an ethical wall is a permissible or required mitigation; False otherwise.' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ruleCode rdf:type rdf:Property ;
    rdfs:label 'Rule Code' ;
    rdfs:comment 'Business identifier for the conflict rule (e.g., ABA_1.7, ABA_1.9, ABA_1.10, SRA_6.1, IBA_CONFLICT_01). Used as the externally-known unique code for the rule in Intapp Conflicts and other systems.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleDescription rdf:type rdf:Property ;
    rdfs:label 'Rule Description' ;
    rdfs:comment 'Detailed description of the conflict-of-interest rule, including the ethical obligation, the conditions under which it applies, and the rationale. May include excerpts from the governing body\'s rule text.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleName rdf:type rdf:Property ;
    rdfs:label 'Rule Name' ;
    rdfs:comment 'Human-readable name or title of the conflict rule (e.g., \'Concurrent Conflict of Interest\', \'Former Client Conflict\', \'Imputed Conflict\').' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleStatus rdf:type rdf:Property ;
    rdfs:label 'Rule Status' ;
    rdfs:comment 'Current lifecycle status of the conflict rule. Active: currently in force; Superseded: replaced by a newer version; Proposed: under consideration but not yet adopted; Withdrawn: no longer applicable.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningScope rdf:type rdf:Property ;
    rdfs:label 'Screening Scope' ;
    rdfs:comment 'The organizational scope at which conflict screening must be performed for this rule (e.g., Individual timekeeper, Practice Group, Office, Firm-Wide). Determines the breadth of relationship and matter checks required.' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severityLevel rdf:type rdf:Property ;
    rdfs:label 'Severity Level' ;
    rdfs:comment 'The severity or risk level associated with a violation of this conflict rule. Critical: non-waivable, direct adverse representation; High: waivable only with stringent conditions; Medium: waivable with informed consent; Low: administrative or positional conflict.' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverConditions rdf:type rdf:Property ;
    rdfs:label 'Waiver Conditions' ;
    rdfs:comment 'Detailed description of the conditions under which the conflict may be waived, if applicable. Includes requirements for informed consent, written disclosure, independent legal advice, and any other conditions mandated by the governing body. Null if the conflict is non-waivable.' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partyAliasId rdf:type rdf:Property ;
    rdfs:label 'Party Alias Id' ;
    rdfs:comment 'Unique identifier for the party alias record. Primary key.' ;
    rdfs:domain ind:PartyAlias ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryConflictPartyId rdf:type rdf:Property ;
    rdfs:label 'Primary Conflict Party Id' ;
    rdfs:comment 'Foreign key reference to the canonical conflict_party record to which this alias belongs. Links the alias to the authoritative party entity in the conflict search universe.' ;
    rdfs:domain ind:PartyAlias ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConflictParty .

ind:tertiaryConflictPartyId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Conflict Party Id' ;
    rdfs:comment 'FK to conflict.party.party_id — Each alias record links to its canonical party record. This FK is essential for the fuzzy matching engine to resolve aliases back to the master party.' ;
    rdfs:domain ind:PartyAlias ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConflictParty .

ind:aliasName rdf:type rdf:Property ;
    rdfs:label 'Alias Name' ;
    rdfs:comment 'The alternate name, former name, trade name, DBA (Doing Business As) designation, or transliterated variant of the party. This is the searchable alias string used during conflict searches to identify potential matches.' ;
    rdfs:domain ind:PartyAlias ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aliasSource rdf:type rdf:Property ;
    rdfs:label 'Alias Source' ;
    rdfs:comment 'The origin or source from which the alias was obtained. Values: client_disclosure (provided by client during intake), public_registry (obtained from government or corporate registry), prior_matter (identified in historical matter records), lateral_hire_screening (discovered during lateral attorney conflict check), third_party_database (sourced from external data provider), manual_entry (manually added by conflicts team).' ;
    rdfs:domain ind:PartyAlias ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aliasType rdf:type rdf:Property ;
    rdfs:label 'Alias Type' ;
    rdfs:comment 'Classification of the alias indicating the nature of the alternate name. Values: legal_name (official registered name), former_name (historical name prior to change), trade_name (commercial operating name), dba (Doing Business As designation), transliteration (name rendered in different script or alphabet), phonetic_variant (phonetically similar name for fuzzy matching).' ;
    rdfs:domain ind:PartyAlias ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPrimaryAlias rdf:type rdf:Property ;
    rdfs:label 'Is Primary Alias' ;
    rdfs:comment 'Boolean flag indicating whether this alias is the primary or preferred alternate name for the party in conflict searches. True if this is the main alias to be used; False otherwise.' ;
    rdfs:domain ind:PartyAlias ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:languageCode rdf:type rdf:Property ;
    rdfs:label 'Language Code' ;
    rdfs:comment 'Three-letter ISO 639-2 language code indicating the language or script in which the alias is expressed. Used for transliterated variants and multilingual conflict searches. Examples: ENG (English), FRA (French), DEU (German), CHI (Chinese), ARA (Arabic).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phoneticEncoding rdf:type rdf:Property ;
    rdfs:label 'Phonetic Encoding' ;
    rdfs:comment 'Phonetic encoding of the alias name using algorithms such as Soundex, Metaphone, or Double Metaphone. Enables fuzzy matching and phonetic similarity searches during conflict checks to identify parties with similar-sounding names.' ;
    rdfs:domain ind:PartyAlias ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationSource rdf:type rdf:Property ;
    rdfs:label 'Verification Source' ;
    rdfs:comment 'The authoritative source or registry used to verify the alias. Examples: Companies House (UK), SEC EDGAR (USA), state business registry, corporate charter, court records, client-provided documentation.' ;
    rdfs:domain ind:PartyAlias ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionId rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Id' ;
    rdfs:comment 'Foreign key linking to matter.jurisdiction. Business justification: contract_agreement has a plain text \'jurisdiction\' attribute (denormalized). Normalizing to matter.jurisdiction enables jurisdiction-based contract compliance reporting, choice-of-law analysis, and re' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Jurisdiction .

ind:parentAgreementContractAgreementId rdf:type rdf:Property ;
    rdfs:label 'Parent Agreement Contract Agreement Id' ;
    rdfs:comment 'Reference to the parent or master agreement if this is a subsidiary agreement, amendment, or SOW. Nullable for standalone agreements.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agreement .

ind:agreementNumber rdf:type rdf:Property ;
    rdfs:label 'Agreement Number' ;
    rdfs:comment 'Externally-known unique business identifier for the agreement, used in correspondence and filings.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementStatus rdf:type rdf:Property ;
    rdfs:label 'Agreement Status' ;
    rdfs:comment 'Current lifecycle status of the agreement within the CLM pipeline. [ENUM-REF-CANDIDATE: Draft|Under Review|Pending Execution|Executed|Active|Suspended|Terminated|Expired|Cancelled — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentCount rdf:type rdf:Property ;
    rdfs:label 'Amendment Count' ;
    rdfs:comment 'Total number of formal amendments executed against this agreement.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:amlKycVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Aml Kyc Verified Flag' ;
    rdfs:comment 'Indicates whether AML and KYC checks have been completed and verified for the counterparty prior to agreement execution.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:confidentialityClassification rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Classification' ;
    rdfs:comment 'Data classification level assigned to the agreement document and its contents.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractValue rdf:type rdf:Property ;
    rdfs:label 'Contract Value' ;
    rdfs:comment 'Total monetary value of the agreement as stated in the contract terms. Nullable for non-monetary agreements.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:counterpartyName rdf:type rdf:Property ;
    rdfs:label 'Counterparty Name' ;
    rdfs:comment 'Legal name of the counterparty organization or individual who is the other signatory to the agreement.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterpartyType rdf:type rdf:Property ;
    rdfs:label 'Counterparty Type' ;
    rdfs:comment 'Classification of the counterparty by relationship type to the firm. [ENUM-REF-CANDIDATE: Client|Vendor|Supplier|Partner|Government Entity|Individual|Other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentStoragePath rdf:type rdf:Property ;
    rdfs:label 'Document Storage Path' ;
    rdfs:comment 'File path or URI to the executed agreement document in the Document Management System (DMS).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Gdpr Compliant Flag' ;
    rdfs:comment 'Indicates whether the agreement includes GDPR-compliant data processing terms and clauses.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:indemnityClauseFlag rdf:type rdf:Property ;
    rdfs:label 'Indemnity Clause Flag' ;
    rdfs:comment 'Indicates whether the agreement contains an indemnity or hold-harmless clause.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:limitationOfLiabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Limitation Of Liability Flag' ;
    rdfs:comment 'Indicates whether the agreement contains a limitation of liability clause.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originatingOffice rdf:type rdf:Property ;
    rdfs:label 'Originating Office' ;
    rdfs:comment 'Firm office or practice location that originated and owns this agreement.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Termination Notice Days' ;
    rdfs:comment 'Number of days advance notice required for termination as specified in the agreement terms.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:defaultPricingModelId rdf:type rdf:Property ;
    rdfs:label 'Default Pricing Model Id' ;
    rdfs:comment 'Foreign key linking to service.pricing_model. Business justification: Agreement types have default pricing models that auto-populate during engagement letter generation. Supports template configuration, new matter intake automation, and ensures consistent fee arrangemen' ;
    rdfs:domain ind:AgreementType ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PricingModel .

ind:defaultSlaTemplateId rdf:type rdf:Property ;
    rdfs:label 'Default Sla Template Id' ;
    rdfs:comment 'Foreign key linking to service.sla_template. Business justification: Each agreement type (MSA, Retainer, NDA) has default SLA commitments. Linking to a default sla_template enables automated SLA assignment during contract creation, ensuring consistency across all contr' ;
    rdfs:domain ind:AgreementType ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SlaTemplate .

ind:agreementTypeCategory rdf:type rdf:Property ;
    rdfs:label 'Agreement Type Category' ;
    rdfs:comment 'High-level classification of the agreement type by business function: client engagement (LOE, retainer), vendor/supplier (MSA, SOW), internal administrative, regulatory compliance, intellectual property (IP licensing, PCT filings), or dispute resolution (ADR, arbitration).' ;
    rdfs:domain ind:AgreementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amlKycRequired rdf:type rdf:Property ;
    rdfs:label 'Aml Kyc Required' ;
    rdfs:comment 'Indicates whether agreements of this type require Anti-Money Laundering (AML) and Know Your Client (KYC) checks before execution. True if AML/KYC is mandatory; False otherwise.' ;
    rdfs:domain ind:AgreementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvalWorkflowRequired rdf:type rdf:Property ;
    rdfs:label 'Approval Workflow Required' ;
    rdfs:comment 'Indicates whether agreements of this type require formal approval workflow (e.g., partner sign-off, risk committee review) before execution. True if approval workflow is mandatory; False otherwise.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:defaultDisputeResolution rdf:type rdf:Property ;
    rdfs:label 'Default Dispute Resolution' ;
    rdfs:comment 'Standard dispute resolution mechanism for this agreement type: litigation (court proceedings), arbitration (binding arbitration under ICC, LCIA, or other rules), mediation (facilitated negotiation), or negotiation (direct party-to-party resolution).' ;
    rdfs:domain ind:AgreementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultGoverningLaw rdf:type rdf:Property ;
    rdfs:label 'Default Governing Law' ;
    rdfs:comment 'Default jurisdiction whose laws govern agreements of this type (e.g., New York, England and Wales, Delaware). Null if no standard governing law applies.' ;
    rdfs:domain ind:AgreementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultNoticePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Default Notice Period Days' ;
    rdfs:comment 'Standard number of days required for termination or non-renewal notice for this agreement type. Null if no standard notice period applies.' ;
    rdfs:domain ind:AgreementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:defaultTermMonths rdf:type rdf:Property ;
    rdfs:label 'Default Term Months' ;
    rdfs:comment 'Standard duration in months for this agreement type. Null if the agreement type does not have a standard term (e.g., perpetual agreements or one-time transactions).' ;
    rdfs:domain ind:AgreementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:electronicSignatureAllowed rdf:type rdf:Property ;
    rdfs:label 'Electronic Signature Allowed' ;
    rdfs:comment 'Indicates whether agreements of this type can be executed using electronic signatures (e.g., DocuSign, Adobe Sign). True if electronic signature is legally acceptable; False if wet signature is required.' ;
    rdfs:domain ind:AgreementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:financialThresholdUsd rdf:type rdf:Property ;
    rdfs:label 'Financial Threshold Usd' ;
    rdfs:comment 'Monetary threshold in USD above which agreements of this type require additional approval or review (e.g., partner sign-off for engagements over $100,000). Null if no financial threshold applies.' ;
    rdfs:domain ind:AgreementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:frandApplicable rdf:type rdf:Property ;
    rdfs:label 'Frand Applicable' ;
    rdfs:comment 'Indicates whether agreements of this type are subject to Fair Reasonable and Non-Discriminatory (FRAND) licensing terms, typically for standard-essential patents. True if FRAND terms apply; False otherwise.' ;
    rdfs:domain ind:AgreementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gdprApplicable rdf:type rdf:Property ;
    rdfs:label 'Gdpr Applicable' ;
    rdfs:comment 'Indicates whether agreements of this type typically involve processing of personal data subject to GDPR. True if GDPR compliance clauses are standard; False otherwise.' ;
    rdfs:domain ind:AgreementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ledesBillingCode rdf:type rdf:Property ;
    rdfs:label 'Ledes Billing Code' ;
    rdfs:comment 'LEDES billing code associated with this agreement type for electronic invoice submission. Null if no specific LEDES code applies.' ;
    rdfs:domain ind:AgreementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneTrackingRequired rdf:type rdf:Property ;
    rdfs:label 'Milestone Tracking Required' ;
    rdfs:comment 'Indicates whether agreements of this type require milestone and obligation tracking (e.g., deliverable dates, payment schedules, renewal dates). True if milestone tracking is standard; False otherwise.' ;
    rdfs:domain ind:AgreementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresCountersignature rdf:type rdf:Property ;
    rdfs:label 'Requires Countersignature' ;
    rdfs:comment 'Indicates whether agreements of this type require countersignature by the counterparty to be legally binding. True if countersignature is required; False if unilateral execution is sufficient.' ;
    rdfs:domain ind:AgreementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresNotarization rdf:type rdf:Property ;
    rdfs:label 'Requires Notarization' ;
    rdfs:comment 'Indicates whether agreements of this type require notarization or witnessing to be legally enforceable. True if notarization is required; False otherwise.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:soxApplicable rdf:type rdf:Property ;
    rdfs:label 'Sox Applicable' ;
    rdfs:comment 'Indicates whether agreements of this type are subject to Sarbanes-Oxley Act compliance requirements (e.g., financial controls, audit trails). True if SOX compliance is required; False otherwise.' ;
    rdfs:domain ind:AgreementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:templateAvailable rdf:type rdf:Property ;
    rdfs:label 'Template Available' ;
    rdfs:comment 'Indicates whether a standard template is available for this agreement type in the firm\'s document management system (DMS). True if template exists; False if agreements are drafted from scratch.' ;
    rdfs:domain ind:AgreementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:typeCode rdf:type rdf:Property ;
    rdfs:label 'Type Code' ;
    rdfs:comment 'Short alphanumeric code representing the agreement type (e.g., LOE, NDA, SPA, POA, MSA, SOW). Used for system integration and UTBMS alignment.' ;
    rdfs:domain ind:AgreementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typeDescription rdf:type rdf:Property ;
    rdfs:label 'Type Description' ;
    rdfs:comment 'Detailed description of the agreement type, including its purpose, typical use cases, and key characteristics within the legal services context.' ;
    rdfs:domain ind:AgreementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typeName rdf:type rdf:Property ;
    rdfs:label 'Type Name' ;
    rdfs:comment 'Full business name of the agreement type (e.g., Letter of Engagement, Non-Disclosure Agreement, Share Purchase Agreement, Power of Attorney, Master Services Agreement, Statement of Work, Vendor Agreement, Retainer Agreement, Alternative Dispute Resolution (ADR) Arbitration Agreement).' ;
    rdfs:domain ind:AgreementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByTemplateId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Template Id' ;
    rdfs:comment 'Reference to the contract_template_id of the newer template version that replaces this one. Null if this is the current active version.' ;
    rdfs:domain ind:Template ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Template .

ind:accessControlLevel rdf:type rdf:Property ;
    rdfs:label 'Access Control Level' ;
    rdfs:comment 'Access control classification determining which users or groups can view and use this template within the firm.' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientFacingFlag rdf:type rdf:Property ;
    rdfs:label 'Client Facing Flag' ;
    rdfs:comment 'Indicates whether this template is used for client-facing engagement agreements (True) or internal/vendor agreements (False).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceTags rdf:type rdf:Property ;
    rdfs:label 'Compliance Tags' ;
    rdfs:comment 'Comma-separated list of compliance frameworks and regulatory requirements this template addresses (e.g., GDPR, SOX, AML, CCPA, FRAND).' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dmsDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Dms Document Reference' ;
    rdfs:comment 'Unique identifier of the template document in the firm\'s Document Management System (iManage Work or NetDocuments) for retrieval and version control.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dmsFolderPath rdf:type rdf:Property ;
    rdfs:label 'Dms Folder Path' ;
    rdfs:comment 'Hierarchical folder path or workspace location in the DMS where the template is stored for organizational and access control purposes.' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentFormat rdf:type rdf:Property ;
    rdfs:label 'Document Format' ;
    rdfs:comment 'File format of the template document stored in the Document Management System (DMS).' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keywords rdf:type rdf:Property ;
    rdfs:label 'Keywords' ;
    rdfs:comment 'Comma-separated list of keywords and search terms to facilitate template discovery and retrieval in the knowledge management system.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageLocale rdf:type rdf:Property ;
    rdfs:label 'Language Locale' ;
    rdfs:comment 'Language and locale code for the template content following ISO 639-1 and ISO 3166-1 standards (e.g., en-US, en-GB, fr-FR, de-DE).' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mandatoryUseFlag rdf:type rdf:Property ;
    rdfs:label 'Mandatory Use Flag' ;
    rdfs:comment 'Indicates whether use of this template is mandatory for the specified agreement type and jurisdiction (True) or optional (False). Enforces firm policy and risk management standards.' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optionalClausesCount rdf:type rdf:Property ;
    rdfs:label 'Optional Clauses Count' ;
    rdfs:comment 'Number of optional or conditional clauses in the template that may be included or excluded based on the specific engagement requirements.' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pageCount rdf:type rdf:Property ;
    rdfs:label 'Page Count' ;
    rdfs:comment 'Number of pages in the template document at standard formatting, useful for estimating review and negotiation effort.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Review Frequency Months' ;
    rdfs:comment 'Number of months between scheduled reviews of the template (e.g., 12 for annual review, 24 for biennial review).' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:templateCode rdf:type rdf:Property ;
    rdfs:label 'Template Code' ;
    rdfs:comment 'Unique business identifier code for the template used for cataloging and reference (e.g., NDA-STD-001, SPA-M&A-002).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateDescription rdf:type rdf:Property ;
    rdfs:label 'Template Description' ;
    rdfs:comment 'Detailed description of the template\'s purpose, scope, and appropriate use cases to guide attorneys in selecting the correct template for their matter.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateName rdf:type rdf:Property ;
    rdfs:label 'Template Name' ;
    rdfs:comment 'Human-readable name of the contract template (e.g., Standard NDA, Share Purchase Agreement, Letter of Engagement).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateStatus rdf:type rdf:Property ;
    rdfs:label 'Template Status' ;
    rdfs:comment 'Current lifecycle status of the template indicating whether it is available for use, under review, or retired from active service.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageCount rdf:type rdf:Property ;
    rdfs:label 'Usage Count' ;
    rdfs:comment 'Number of times this template has been used to generate executed agreements, indicating popularity and proven reliability.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:usageInstructions rdf:type rdf:Property ;
    rdfs:label 'Usage Instructions' ;
    rdfs:comment 'Guidance and instructions for attorneys on how to properly customize and use this template, including required fields, optional clauses, and approval workflows.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variableFieldsCount rdf:type rdf:Property ;
    rdfs:label 'Variable Fields Count' ;
    rdfs:comment 'Number of variable fields or merge fields in the template that require customization for each specific engagement or transaction.' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wordCount rdf:type rdf:Property ;
    rdfs:label 'Word Count' ;
    rdfs:comment 'Approximate word count of the template document, useful for estimating review time and complexity.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractPartyId rdf:type rdf:Property ;
    rdfs:label 'Contract Party Id' ;
    rdfs:comment 'Unique identifier for the contract party record. Primary key.' ;
    rdfs:domain ind:ContractParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line1' ;
    rdfs:comment 'The first line of the party\'s registered or principal business address (street number and name).' ;
    rdfs:domain ind:ContractParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line2' ;
    rdfs:comment 'The second line of the party\'s registered or principal business address (suite, floor, building name).' ;
    rdfs:domain ind:ContractParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedSignatoryName rdf:type rdf:Property ;
    rdfs:label 'Authorized Signatory Name' ;
    rdfs:comment 'The full name of the individual authorized to sign the contract on behalf of this party.' ;
    rdfs:domain ind:ContractParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityObligationFlag rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Obligation Flag' ;
    rdfs:comment 'Boolean flag indicating whether this party is bound by confidentiality or Non-Disclosure Agreement (NDA) obligations under the contract (True) or not (False).' ;
    rdfs:domain ind:ContractParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:email rdf:type rdf:Property ;
    rdfs:label 'Email' ;
    rdfs:comment 'The primary email address for the party organization or individual for contract-related communications.' ;
    rdfs:domain ind:ContractParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionMethod rdf:type rdf:Property ;
    rdfs:label 'Execution Method' ;
    rdfs:comment 'The method by which this party executed the contract (wet signature, electronic signature, digital signature, corporate seal, notarized).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indemnityObligationFlag rdf:type rdf:Property ;
    rdfs:label 'Indemnity Obligation Flag' ;
    rdfs:comment 'Boolean flag indicating whether this party has indemnity obligations under the contract (True) or not (False).' ;
    rdfs:domain ind:ContractParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isClient rdf:type rdf:Property ;
    rdfs:label 'Is Client' ;
    rdfs:comment 'Boolean flag indicating whether this party is a client of the firm (True) or not (False).' ;
    rdfs:domain ind:ContractParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFirmEntity rdf:type rdf:Property ;
    rdfs:label 'Is Firm Entity' ;
    rdfs:comment 'Boolean flag indicating whether this party represents the law firm itself (True) or an external counterparty (False).' ;
    rdfs:domain ind:ContractParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOpposingCounsel rdf:type rdf:Property ;
    rdfs:label 'Is Opposing Counsel' ;
    rdfs:comment 'Boolean flag indicating whether this party represents opposing counsel or an adverse party in a matter (True) or not (False).' ;
    rdfs:domain ind:ContractParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVendor rdf:type rdf:Property ;
    rdfs:label 'Is Vendor' ;
    rdfs:comment 'Boolean flag indicating whether this party is a vendor or supplier to the firm (True) or not (False).' ;
    rdfs:domain ind:ContractParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:liabilityCapAmount rdf:type rdf:Property ;
    rdfs:label 'Liability Cap Amount' ;
    rdfs:comment 'The maximum liability amount applicable to this party under the contract terms, if specified.' ;
    rdfs:domain ind:ContractParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:liabilityCapCurrency rdf:type rdf:Property ;
    rdfs:label 'Liability Cap Currency' ;
    rdfs:comment 'The ISO 4217 three-letter currency code for the liability cap amount (e.g., USD, GBP, EUR).' ;
    rdfs:domain ind:ContractParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notaryCommissionNumber rdf:type rdf:Property ;
    rdfs:label 'Notary Commission Number' ;
    rdfs:comment 'The commission number or registration number of the notary public who notarized the signature, if applicable.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notaryExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Notary Expiration Date' ;
    rdfs:comment 'The expiration date of the notary public\'s commission at the time of notarization, if applicable.' ;
    rdfs:domain ind:ContractParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notaryName rdf:type rdf:Property ;
    rdfs:label 'Notary Name' ;
    rdfs:comment 'The name of the notary public who witnessed and notarized the party\'s signature, if applicable.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onAgreement rdf:type rdf:Property ;
    rdfs:label 'On Agreement' ;
    rdfs:comment 'FK to contract.agreement.agreement_id — contract_party is a junction/detail record linking parties to agreements. Without this FK, party records are orphaned with no agreement context.' ;
    rdfs:domain ind:ContractParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentEntityName rdf:type rdf:Property ;
    rdfs:label 'Parent Entity Name' ;
    rdfs:comment 'The name of the parent company or controlling entity of this party, if applicable (used for corporate hierarchy tracking).' ;
    rdfs:domain ind:ContractParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phone rdf:type rdf:Property ;
    rdfs:label 'Phone' ;
    rdfs:comment 'The primary contact phone number for the party organization or individual.' ;
    rdfs:domain ind:ContractParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatoryCapacity rdf:type rdf:Property ;
    rdfs:label 'Signatory Capacity' ;
    rdfs:comment 'The legal capacity in which the signatory is executing the contract (individual, corporate officer, attorney-in-fact under Power of Attorney (POA), trustee, executor, guardian).' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatoryEmail rdf:type rdf:Property ;
    rdfs:label 'Signatory Email' ;
    rdfs:comment 'The primary email address of the authorized signatory for contract-related communications.' ;
    rdfs:domain ind:ContractParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatoryPhone rdf:type rdf:Property ;
    rdfs:label 'Signatory Phone' ;
    rdfs:comment 'The primary contact phone number for the authorized signatory.' ;
    rdfs:domain ind:ContractParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatoryTitle rdf:type rdf:Property ;
    rdfs:label 'Signatory Title' ;
    rdfs:comment 'The job title or official position of the authorized signatory (e.g., Chief Executive Officer, General Counsel, Director).' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatureLocation rdf:type rdf:Property ;
    rdfs:label 'Signature Location' ;
    rdfs:comment 'The city, state, or country where the party executed the contract, as stated in the signature block.' ;
    rdfs:domain ind:ContractParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toAgreement rdf:type rdf:Property ;
    rdfs:label 'To Agreement' ;
    rdfs:comment 'FK to contract.agreement.agreement_id — Every contract_party record identifies a party TO a specific agreement. This is a mandatory associative relationship — parties are meaningless without their agreement context.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ultimateBeneficialOwner rdf:type rdf:Property ;
    rdfs:label 'Ultimate Beneficial Owner' ;
    rdfs:comment 'The name of the ultimate beneficial owner (UBO) of the party entity, as required for KYC and AML compliance.' ;
    rdfs:domain ind:ContractParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clauseLibraryId rdf:type rdf:Property ;
    rdfs:label 'Clause Library Id' ;
    rdfs:comment 'Foreign key linking to contract.clause_library. Business justification: obligation.clause_reference is a free-text string referencing the contractual clause from which the obligation was extracted. clause_library is the authoritative curated repository of approved clauses' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClauseLibrary .

ind:courtOrderId rdf:type rdf:Property ;
    rdfs:label 'Court Order Id' ;
    rdfs:comment 'Foreign key linking to court.order. Business justification: Court orders frequently impose contractual obligations (injunctions, specific performance, consent decrees). Legal teams must track which court order created or modified each obligation for compliance' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:dependentObligationId rdf:type rdf:Property ;
    rdfs:label 'Dependent Obligation Id' ;
    rdfs:comment 'Reference to another obligation that must be fulfilled before this obligation becomes active. Null if no dependency exists.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Obligation .

ind:responsibleContractPartyId rdf:type rdf:Property ;
    rdfs:label 'Responsible Contract Party Id' ;
    rdfs:comment 'Foreign key linking to contract.contract_party. Business justification: obligation.responsible_party_name and responsible_party_type are denormalized string references to a party already registered in contract_party. Adding responsible_contract_party_id normalizes the res' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContractParty .

ind:breachConsequence rdf:type rdf:Property ;
    rdfs:label 'Breach Consequence' ;
    rdfs:comment 'Description of the contractual consequences if the obligation is breached (e.g., liquidated damages, termination right, indemnity trigger, regulatory penalty).' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachNoticeRequired rdf:type rdf:Property ;
    rdfs:label 'Breach Notice Required' ;
    rdfs:comment 'Indicates whether the contract requires formal written notice before a breach is deemed to have occurred (True) or if breach is automatic upon deadline passage (False).' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conditionPrecedentFlag rdf:type rdf:Property ;
    rdfs:label 'Condition Precedent Flag' ;
    rdfs:comment 'Indicates whether this obligation is a condition precedent (True) that must be satisfied before other contract terms become effective, or a standard ongoing obligation (False).' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:curePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Cure Period Days' ;
    rdfs:comment 'Number of days allowed to remedy a breach after notice is given, as specified in the contract. Null if no cure period is granted.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:escalationThresholdDays rdf:type rdf:Property ;
    rdfs:label 'Escalation Threshold Days' ;
    rdfs:comment 'Number of days before due_date when the obligation should be escalated to senior management or responsible partner for review.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fromAgreement rdf:type rdf:Property ;
    rdfs:label 'From Agreement' ;
    rdfs:comment 'FK to contract.agreement.agreement_id — Obligations are extracted from executed agreements. This is the core parent-child relationship enabling obligation tracking per contract.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fulfillmentPercentage rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Percentage' ;
    rdfs:comment 'Percentage completion of the obligation (0.00 to 100.00). Used for tracking partial fulfillment of multi-step or phased obligations.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fulfillmentStatus rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Status' ;
    rdfs:comment 'Current lifecycle state of the obligation: pending (not started), in_progress (work underway), fulfilled (completed), partially_fulfilled (incomplete), breached (deadline missed), waived (obligation released), terminated (contract ended). [ENUM-REF-CANDIDATE: pending|in_progress|fulfilled|partially_fulfilled|breached|waived|terminated — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monetaryValue rdf:type rdf:Property ;
    rdfs:label 'Monetary Value' ;
    rdfs:comment 'Financial value associated with the obligation (e.g., payment amount, penalty exposure, indemnity cap). Null for non-monetary obligations.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:obligationText rdf:type rdf:Property ;
    rdfs:label 'Obligation Text' ;
    rdfs:comment 'Full verbatim text of the contractual obligation, covenant, representation, warranty, or condition precedent as extracted from the source agreement.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recurrenceRule rdf:type rdf:Property ;
    rdfs:label 'Recurrence Rule' ;
    rdfs:comment 'Detailed recurrence pattern specification for custom schedules, expressed in iCalendar RRULE format or plain text description.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recurrenceSchedule rdf:type rdf:Property ;
    rdfs:label 'Recurrence Schedule' ;
    rdfs:comment 'Frequency pattern for recurring obligations: one_time (single event), daily, weekly, monthly, quarterly, annually, custom (irregular pattern defined in recurrence_rule). [ENUM-REF-CANDIDATE: one_time|daily|weekly|monthly|quarterly|annually|custom — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryObligationFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Obligation Flag' ;
    rdfs:comment 'Indicates whether this obligation is mandated by law or regulation (True) versus being a purely contractual commitment (False). Used for compliance reporting.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:subcategory rdf:type rdf:Property ;
    rdfs:label 'Subcategory' ;
    rdfs:comment 'Granular classification within the obligation category (e.g., milestone payment, quarterly report, data protection compliance, patent assignment).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverAuthority rdf:type rdf:Property ;
    rdfs:label 'Waiver Authority' ;
    rdfs:comment 'Name and title of the individual who authorized the waiver of this obligation.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverReason rdf:type rdf:Property ;
    rdfs:label 'Waiver Reason' ;
    rdfs:comment 'Business justification or legal rationale for waiving the obligation.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationEventId rdf:type rdf:Property ;
    rdfs:label 'Obligation Event Id' ;
    rdfs:comment 'Unique identifier for the obligation event record. Primary key for the obligation event entity.' ;
    rdfs:domain ind:ObligationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actorType rdf:type rdf:Property ;
    rdfs:label 'Actor Type' ;
    rdfs:comment 'The category of party or system that triggered or recorded the obligation event. Identifies whether the actor was an attorney, client, counterparty, automated system, or third party.' ;
    rdfs:domain ind:ObligationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachNoticeDate rdf:type rdf:Property ;
    rdfs:label 'Breach Notice Date' ;
    rdfs:comment 'The date on which formal notice of the breach was provided to the breaching party, if applicable. Critical for calculating cure periods and contractual remedies.' ;
    rdfs:domain ind:ObligationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:completionPercentage rdf:type rdf:Property ;
    rdfs:label 'Completion Percentage' ;
    rdfs:comment 'The percentage of the obligation that has been completed as of this event. Used for tracking partial fulfillment (e.g., 50.00 indicates 50% completion). Range: 0.00 to 100.00.' ;
    rdfs:domain ind:ObligationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Flag' ;
    rdfs:comment 'Indicates whether this obligation event has compliance or regulatory reporting implications. True if the event must be included in regulatory reports, False otherwise.' ;
    rdfs:domain ind:ObligationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cureDeadline rdf:type rdf:Property ;
    rdfs:label 'Cure Deadline' ;
    rdfs:comment 'The deadline by which the breaching party must cure the breach to avoid further consequences. Derived from contract terms and breach notice date.' ;
    rdfs:domain ind:ObligationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eventDescription rdf:type rdf:Property ;
    rdfs:label 'Event Description' ;
    rdfs:comment 'Detailed narrative description of the obligation event. Captures context, circumstances, and any relevant details about what occurred and why.' ;
    rdfs:domain ind:ObligationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventStatus rdf:type rdf:Property ;
    rdfs:label 'Event Status' ;
    rdfs:comment 'Current processing status of the obligation event. Indicates whether the event is pending review, confirmed as valid, disputed by a party, resolved after dispute, or cancelled.' ;
    rdfs:domain ind:ObligationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event Timestamp' ;
    rdfs:comment 'The precise date and time when the obligation event occurred in the real world. This is the business event time, distinct from system audit timestamps.' ;
    rdfs:domain ind:ObligationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:financialImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Amount' ;
    rdfs:comment 'The monetary value associated with this obligation event, if applicable. May represent payment made, penalty incurred, or financial consequence of the event.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financialImpactCurrency rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Currency' ;
    rdfs:comment 'The three-letter ISO 4217 currency code for the financial impact amount (e.g., USD, GBP, EUR). Null if no financial impact.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationRecipientList rdf:type rdf:Property ;
    rdfs:label 'Notification Recipient List' ;
    rdfs:comment 'Comma-separated list of email addresses or user identifiers who received notification of this obligation event. Provides audit trail of communication.' ;
    rdfs:domain ind:ObligationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Notification Timestamp' ;
    rdfs:comment 'The date and time when the notification about this obligation event was sent to relevant parties. Null if no notification was sent.' ;
    rdfs:domain ind:ObligationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:priorObligationStatus rdf:type rdf:Property ;
    rdfs:label 'Prior Obligation Status' ;
    rdfs:comment 'The status of the parent obligation immediately before this event occurred. Enables tracking of status transitions and audit trail reconstruction.' ;
    rdfs:domain ind:ObligationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultingObligationStatus rdf:type rdf:Property ;
    rdfs:label 'Resulting Obligation Status' ;
    rdfs:comment 'The status of the parent obligation immediately after this event was processed. Captures the state transition caused by the event (e.g., from active to fulfilled, or from active to breached).' ;
    rdfs:domain ind:ObligationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemEventReference rdf:type rdf:Property ;
    rdfs:label 'Source System Event Reference' ;
    rdfs:comment 'The unique identifier of this obligation event in the source operational system. Enables traceability back to the originating system.' ;
    rdfs:domain ind:ObligationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneId rdf:type rdf:Property ;
    rdfs:label 'Milestone Id' ;
    rdfs:comment 'Unique identifier for the contract milestone record. Primary key.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deadlineId rdf:type rdf:Property ;
    rdfs:label 'Deadline Id' ;
    rdfs:comment 'Foreign key linking to matter.matter_deadline. Business justification: Contract milestones are formally docketed as matter deadlines for malpractice risk management — a standard legal ops workflow. Linking milestone to matter_deadline enables automated deadline creation ' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Deadline .

ind:actualDate rdf:type rdf:Property ;
    rdfs:label 'Actual Date' ;
    rdfs:comment 'The date on which the milestone event actually occurred or was completed. Null if the milestone has not yet been completed. Used for performance tracking and compliance reporting.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:alertLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Alert Lead Time Days' ;
    rdfs:comment 'Number of days before the scheduled milestone date that an automated alert or notification should be triggered. Configurable per milestone to support proactive management.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:completionNotes rdf:type rdf:Property ;
    rdfs:label 'Completion Notes' ;
    rdfs:comment 'Free-text notes documenting how the milestone was satisfied, any issues encountered, or deviations from the scheduled plan. Captured at milestone completion for audit and knowledge management purposes.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalSystemReference rdf:type rdf:Property ;
    rdfs:label 'External System Reference' ;
    rdfs:comment 'Reference identifier or key from an external Contract Lifecycle Management (CLM) system, practice management system, or client portal. Supports system integration and data lineage tracking.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCriticalPathFlag rdf:type rdf:Property ;
    rdfs:label 'Is Critical Path Flag' ;
    rdfs:comment 'Boolean indicator of whether this milestone is on the critical path for transaction completion or contract effectiveness. Used for prioritization in Mergers and Acquisitions (M&A) and complex transactions.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRegulatoryMilestoneFlag rdf:type rdf:Property ;
    rdfs:label 'Is Regulatory Milestone Flag' ;
    rdfs:comment 'Boolean indicator of whether this milestone is driven by regulatory or statutory requirements (e.g., filing deadlines, compliance notice periods). Used for regulatory reporting and compliance tracking.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:milestoneDescription rdf:type rdf:Property ;
    rdfs:label 'Milestone Description' ;
    rdfs:comment 'Detailed textual description of the milestone event, including any specific contractual obligations, conditions precedent, or actions required to satisfy the milestone.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneName rdf:type rdf:Property ;
    rdfs:label 'Milestone Name' ;
    rdfs:comment 'Business-friendly name or label for the milestone event (e.g., Execution Date, Effective Date, First Renewal Notice, Termination Deadline).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneStatus rdf:type rdf:Property ;
    rdfs:label 'Milestone Status' ;
    rdfs:comment 'Current lifecycle status of the milestone. Tracks whether the milestone is pending, approaching its due date, completed, missed, or waived. [ENUM-REF-CANDIDATE: pending|approaching|due|completed|missed|waived|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneType rdf:type rdf:Property ;
    rdfs:label 'Milestone Type' ;
    rdfs:comment 'Classification of the milestone event type. Categorizes the nature of the contractual milestone for reporting and workflow automation. [ENUM-REF-CANDIDATE: execution|effective_date|condition_precedent|notice_period|option_exercise|renewal_decision|expiry|termination_window|payment_due|deliverable_due|regulatory_filing — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextOccurrenceDate rdf:type rdf:Property ;
    rdfs:label 'Next Occurrence Date' ;
    rdfs:comment 'For recurring milestones, the date of the next scheduled occurrence. Null for one-time milestones. Used to generate future milestone records automatically.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notificationSentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Timestamp' ;
    rdfs:comment 'Timestamp when the automated notification or alert was sent to the responsible party. Null if no notification has been sent. Supports audit trail for milestone management.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:notificationTriggeredFlag rdf:type rdf:Property ;
    rdfs:label 'Notification Triggered Flag' ;
    rdfs:comment 'Boolean indicator of whether an automated notification or alert has been triggered for this milestone. Used to track alert delivery and prevent duplicate notifications.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recurrencePattern rdf:type rdf:Property ;
    rdfs:label 'Recurrence Pattern' ;
    rdfs:comment 'Defines whether the milestone is a one-time event or recurs on a regular schedule (e.g., annual renewal notice, quarterly compliance review). Supports automated milestone generation for recurring obligations.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsiblePartyName rdf:type rdf:Property ;
    rdfs:label 'Responsible Party Name' ;
    rdfs:comment 'Name of the individual, team, or external party responsible for satisfying the milestone obligation. May be internal attorney, client contact, or third-party vendor.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Date' ;
    rdfs:comment 'The planned or contractually agreed date on which the milestone event is scheduled to occur. Core date for milestone tracking and alerting.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalId rdf:type rdf:Property ;
    rdfs:label 'Renewal Id' ;
    rdfs:comment 'Unique identifier for the contract renewal record. Primary key.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewalAgreementId rdf:type rdf:Property ;
    rdfs:label 'Renewal Agreement Id' ;
    rdfs:comment 'Reference to the parent contract subject to renewal. Links to the contract master record.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agreement .

ind:renewalSuccessorContractAgreementId rdf:type rdf:Property ;
    rdfs:label 'Renewal Successor Contract Agreement Id' ;
    rdfs:comment 'Reference to the new contract record created as a result of this renewal. Null if renewal was declined or not yet executed.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agreement .

ind:autoRenewFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renew Flag' ;
    rdfs:comment 'Indicates whether the contract is subject to automatic renewal unless notice to cancel is provided (true) or requires affirmative action to renew (false).' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clientApprovalReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Client Approval Received Date' ;
    rdfs:comment 'Date on which client approval for the renewal was formally received. Null if approval not yet received or not required.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clientApprovalRequired rdf:type rdf:Property ;
    rdfs:label 'Client Approval Required' ;
    rdfs:comment 'Indicates whether explicit client approval is required for the renewal to proceed (true) or if the renewal is automatic per contract terms (false).' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:decision rdf:type rdf:Property ;
    rdfs:label 'Decision' ;
    rdfs:comment 'Final decision outcome for the renewal: renew (proceed with renewal as-is or with minor adjustments), terminate (end the contract), renegotiate (material terms require negotiation), pending (decision not yet made).' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeAdjustmentPercentage rdf:type rdf:Property ;
    rdfs:label 'Fee Adjustment Percentage' ;
    rdfs:comment 'Percentage change in fees from the prior term to the renewal term. Positive values indicate fee increases; negative values indicate discounts or reductions.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feeAdjustmentReason rdf:type rdf:Property ;
    rdfs:label 'Fee Adjustment Reason' ;
    rdfs:comment 'Business rationale for any fee adjustment applied during renewal (e.g., inflation adjustment, scope expansion, client loyalty discount, competitive pressure).' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeCurrency rdf:type rdf:Property ;
    rdfs:label 'Fee Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the renewal fee amount (e.g., USD, GBP, EUR).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiatedBy rdf:type rdf:Property ;
    rdfs:label 'Initiated By' ;
    rdfs:comment 'Party that initiated the renewal process: client (client requested renewal), firm (firm proactively proposed renewal), auto_trigger (system-generated based on contract terms).' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noticePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Notice Period Days' ;
    rdfs:comment 'Number of days prior to renewal effective date that notice to cancel must be provided, as stipulated in the contract terms (e.g., 30, 60, 90 days).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:noticeToCancelDeadline rdf:type rdf:Property ;
    rdfs:label 'Notice To Cancel Deadline' ;
    rdfs:comment 'Last date by which either party must provide written notice to prevent automatic renewal or to terminate the agreement. Critical for proactive renewal pipeline management.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notificationSentDate rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Date' ;
    rdfs:comment 'Date on which the renewal notification or reminder was sent to the client or responsible partner.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ofAgreement rdf:type rdf:Property ;
    rdfs:label 'Of Agreement' ;
    rdfs:comment 'FK to contract.agreement.agreement_id — Renewals manage the continuation lifecycle of a specific agreement. The FK to agreement is mandatory for renewal pipeline management.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewalNumber rdf:type rdf:Property ;
    rdfs:label 'Renewal Number' ;
    rdfs:comment 'Business-facing identifier for the renewal event, typically formatted as contract number plus renewal sequence (e.g., LOE-2024-001-R2).' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalStatus rdf:type rdf:Property ;
    rdfs:label 'Renewal Status' ;
    rdfs:comment 'Current lifecycle state of the renewal: pending (awaiting decision), under_review (partner evaluation in progress), approved (client/firm agreed to renew), declined (non-renewal decision made), executed (successor agreement signed), cancelled (renewal process aborted).' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalType rdf:type rdf:Property ;
    rdfs:label 'Renewal Type' ;
    rdfs:comment 'Classification of the renewal mechanism: auto_renew (automatic rollover per contract terms), opt_in (requires affirmative client election), renegotiate (new terms required), extend (one-time extension without full renewal), terminate (non-renewal decision).' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termLength rdf:type rdf:Property ;
    rdfs:label 'Term Length' ;
    rdfs:comment 'Duration of the renewal term in months. For example, a 12-month renewal or a 36-month multi-year extension.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:termUnit rdf:type rdf:Property ;
    rdfs:label 'Term Unit' ;
    rdfs:comment 'Unit of measure for the renewal term length: month, year, or quarter.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentCleanLegalDocumentId rdf:type rdf:Property ;
    rdfs:label 'Amendment Clean Legal Document Id' ;
    rdfs:comment 'Reference identifier to the clean (final executed) version of the amendment document stored in the Document Management System (DMS).' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalDocument .

ind:amendmentLegalDocumentId rdf:type rdf:Property ;
    rdfs:label 'Amendment Legal Document Id' ;
    rdfs:comment 'Reference identifier to the redlined (track-changes) version of the amendment document stored in the Document Management System (DMS). Enables retrieval of the marked-up comparison showing changes from the original agreement.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalDocument .

ind:counterpartyContractPartyId rdf:type rdf:Property ;
    rdfs:label 'Counterparty Contract Party Id' ;
    rdfs:comment 'Foreign key linking to contract.contract_party. Business justification: amendment.counterparty_name is a denormalized string reference to the counterparty executing the amendment. contract_party is the authoritative registry of all parties to the agreement. Adding counter' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContractParty .

ind:parentAmendmentId rdf:type rdf:Property ;
    rdfs:label 'Parent Amendment Id' ;
    rdfs:comment 'Self-referencing foreign key to a prior amendment that this amendment further modifies or supersedes. Enables tracking of amendment chains (e.g., Amendment 2.1 amends Amendment 2).' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Amendment .

ind:primarySupersededByAmendmentId rdf:type rdf:Property ;
    rdfs:label 'Primary Superseded By Amendment Id' ;
    rdfs:comment 'Reference to a later amendment that supersedes or replaces this amendment. Used to maintain the chain of agreement versions for audit and enforceability.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Amendment .

ind:amendmentDescription rdf:type rdf:Property ;
    rdfs:label 'Amendment Description' ;
    rdfs:comment 'Detailed narrative describing the changes introduced by this amendment, including clauses modified, obligations added or removed, and business rationale.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentNumber rdf:type rdf:Property ;
    rdfs:label 'Amendment Number' ;
    rdfs:comment 'Sequential or hierarchical amendment identifier (e.g., Amendment 1, Amendment 2.1). Business-facing reference number for the amendment.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentType rdf:type rdf:Property ;
    rdfs:label 'Amendment Type' ;
    rdfs:comment 'Classification of the amendment instrument: amendment (formal modification), addendum (supplemental terms), side letter (ancillary agreement), variation (scope change), waiver (temporary relief), novation (party substitution).' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Approval Required Flag' ;
    rdfs:comment 'Indicates whether this amendment required formal internal approval (e.g., management committee, conflicts committee) before execution. True if approval was required, False otherwise.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clausesModified rdf:type rdf:Property ;
    rdfs:label 'Clauses Modified' ;
    rdfs:comment 'Comma-separated list or structured reference to the specific clauses, sections, or articles of the parent agreement that are modified by this amendment (e.g., \'Section 3.2, Exhibit A, Schedule 1\').' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterpartySignatoryName rdf:type rdf:Property ;
    rdfs:label 'Counterparty Signatory Name' ;
    rdfs:comment 'Name of the individual who signed the amendment on behalf of the counterparty.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterpartySignatoryTitle rdf:type rdf:Property ;
    rdfs:label 'Counterparty Signatory Title' ;
    rdfs:comment 'Job title or role of the counterparty signatory (e.g., \'Chief Legal Officer\', \'General Counsel\', \'Authorized Signatory\').' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newExpirationDate rdf:type rdf:Property ;
    rdfs:label 'New Expiration Date' ;
    rdfs:comment 'Revised expiration or termination date of the agreement as a result of this amendment. Null if amendment does not change the expiration date.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:retentionEndDate rdf:type rdf:Property ;
    rdfs:label 'Retention End Date' ;
    rdfs:comment 'Date after which the amendment record may be eligible for archival or destruction per the firm\'s records retention policy and applicable regulatory requirements.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:termExtensionMonths rdf:type rdf:Property ;
    rdfs:label 'Term Extension Months' ;
    rdfs:comment 'Number of months by which the agreement term is extended by this amendment. Null if amendment does not affect term duration.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:executionRecordId rdf:type rdf:Property ;
    rdfs:label 'Execution Record Id' ;
    rdfs:comment 'Unique identifier for the execution record. Primary key.' ;
    rdfs:domain ind:ExecutionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bindingEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Binding Effective Date' ;
    rdfs:comment 'The date on which the executed agreement became legally effective and binding. May differ from execution date if the agreement specifies a delayed effective date.' ;
    rdfs:domain ind:ExecutionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:boardResolutionReference rdf:type rdf:Property ;
    rdfs:label 'Board Resolution Reference' ;
    rdfs:comment 'Reference to the board resolution or corporate authorization that empowered the signatory to execute the agreement on behalf of the organization, if applicable.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterpartyExecutionDate rdf:type rdf:Property ;
    rdfs:label 'Counterparty Execution Date' ;
    rdfs:comment 'The date on which the counterparty executed the agreement. May differ from the primary execution date in counterpart execution scenarios.' ;
    rdfs:domain ind:ExecutionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:electronicSignatureCertificateReference rdf:type rdf:Property ;
    rdfs:label 'Electronic Signature Certificate Reference' ;
    rdfs:comment 'Digital certificate identifier associated with the electronic signature, providing cryptographic proof of authenticity.' ;
    rdfs:domain ind:ExecutionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:electronicSignaturePlatform rdf:type rdf:Property ;
    rdfs:label 'Electronic Signature Platform' ;
    rdfs:comment 'Name of the electronic signature platform or service used for execution (e.g., DocuSign, Adobe Sign, HelloSign), if applicable.' ;
    rdfs:domain ind:ExecutionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:electronicSignatureTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Electronic Signature Transaction Reference' ;
    rdfs:comment 'Unique transaction or envelope identifier assigned by the electronic signature platform, used for audit trail and verification.' ;
    rdfs:domain ind:ExecutionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executingPartyName rdf:type rdf:Property ;
    rdfs:label 'Executing Party Name' ;
    rdfs:comment 'Legal name of the party (organization or individual) on whose behalf the agreement was executed.' ;
    rdfs:domain ind:ExecutionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionLocation rdf:type rdf:Property ;
    rdfs:label 'Execution Location' ;
    rdfs:comment 'Physical location (city, office, venue) where the execution took place, if applicable.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionNotes rdf:type rdf:Property ;
    rdfs:label 'Execution Notes' ;
    rdfs:comment 'Free-text notes or comments regarding the execution event, including any special circumstances, conditions, or observations recorded by the responsible attorney or legal operations team.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionOfAgreement rdf:type rdf:Property ;
    rdfs:label 'Execution Of Agreement' ;
    rdfs:comment 'FK to contract.agreement.agreement_id — The execution record captures when and how a specific agreement became binding. This is the legally authoritative link between the execution event and the agreement.' ;
    rdfs:domain ind:ExecutionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:executionReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Execution Reference Number' ;
    rdfs:comment 'Business-facing reference number or code assigned to this execution event for tracking and audit purposes.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Execution Sequence Number' ;
    rdfs:comment 'Sequential number indicating the order of execution events for the same contract, used to track amendments, renewals, and counterpart executions.' ;
    rdfs:domain ind:ExecutionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:executionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Execution Timestamp' ;
    rdfs:comment 'Precise timestamp (including time of day) when the execution event occurred, particularly relevant for electronic signatures and time-sensitive agreements.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:executionToAgreement rdf:type rdf:Property ;
    rdfs:label 'Execution To Agreement' ;
    rdfs:comment 'FK to contract.agreement.agreement_id — Each execution record captures the formal execution event for a specific agreement. One-to-one or one-to-many (multi-party sequential execution) relationship.' ;
    rdfs:domain ind:ExecutionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:executionType rdf:type rdf:Property ;
    rdfs:label 'Execution Type' ;
    rdfs:comment 'Classification of the execution event: original (first execution of the agreement), amendment (execution of an amendment), renewal (execution of a renewal), counterpart (execution of a counterpart copy), or duplicate (duplicate execution for record purposes).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBindingFlag rdf:type rdf:Property ;
    rdfs:label 'Is Binding Flag' ;
    rdfs:comment 'Indicates whether this execution event resulted in a legally binding agreement. False if execution was conditional, incomplete, or subsequently invalidated.' ;
    rdfs:domain ind:ExecutionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOriginalExecutionFlag rdf:type rdf:Property ;
    rdfs:label 'Is Original Execution Flag' ;
    rdfs:comment 'Indicates whether this is the original execution record for the agreement (true) or a subsequent execution event such as an amendment or counterpart (false).' ;
    rdfs:domain ind:ExecutionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jurisdictionOfExecution rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Of Execution' ;
    rdfs:comment 'The legal jurisdiction (state, province, country) in which the execution took place. Relevant for determining applicable execution formalities and legal validity.' ;
    rdfs:domain ind:ExecutionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notaryCommissionExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Notary Commission Expiry Date' ;
    rdfs:comment 'Expiration date of the notary public\'s commission at the time of notarization.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notarySealAffixedFlag rdf:type rdf:Property ;
    rdfs:label 'Notary Seal Affixed Flag' ;
    rdfs:comment 'Indicates whether the notary public\'s official seal was affixed to the executed document.' ;
    rdfs:domain ind:ExecutionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:powerOfAttorneyReference rdf:type rdf:Property ;
    rdfs:label 'Power Of Attorney Reference' ;
    rdfs:comment 'Reference to the Power of Attorney document or authorization under which the signatory executed the agreement, if applicable.' ;
    rdfs:domain ind:ExecutionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatoryName rdf:type rdf:Property ;
    rdfs:label 'Signatory Name' ;
    rdfs:comment 'Full legal name of the individual who signed the agreement on behalf of the executing party.' ;
    rdfs:domain ind:ExecutionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:witnessAddress rdf:type rdf:Property ;
    rdfs:label 'Witness Address' ;
    rdfs:comment 'Address of the witness, required in certain jurisdictions for deed execution and notarization.' ;
    rdfs:domain ind:ExecutionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:witnessName rdf:type rdf:Property ;
    rdfs:label 'Witness Name' ;
    rdfs:comment 'Full legal name of the witness who attested to the execution, if applicable. Required for certain deed and notarized executions.' ;
    rdfs:domain ind:ExecutionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminatingContractPartyId rdf:type rdf:Property ;
    rdfs:label 'Terminating Contract Party Id' ;
    rdfs:comment 'Foreign key linking to contract.contract_party. Business justification: termination.terminating_party_name and terminating_party_type are denormalized string references to the party exercising the termination right. contract_party is the authoritative registry of all part' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContractParty .

ind:effectiveTerminationDate rdf:type rdf:Property ;
    rdfs:label 'Effective Termination Date' ;
    rdfs:comment 'The date on which the contract termination becomes legally effective and the agreement ceases to bind the parties (except for surviving obligations).' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:groundsForTermination rdf:type rdf:Property ;
    rdfs:label 'Grounds For Termination' ;
    rdfs:comment 'Detailed narrative explanation of the legal, contractual, or business grounds cited for the termination, including reference to specific contract clauses or breaches.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noticeDate rdf:type rdf:Property ;
    rdfs:label 'Notice Date' ;
    rdfs:comment 'The date on which formal notice of termination was given to the counterparty, triggering any contractual notice period.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:penaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Penalty Amount' ;
    rdfs:comment 'Any contractual penalty, liquidated damages, or early termination fee payable as a result of the termination.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postTerminationObligations rdf:type rdf:Property ;
    rdfs:label 'Post Termination Obligations' ;
    rdfs:comment 'Description of contractual obligations that survive termination, such as confidentiality, non-compete, indemnity, data return, or wind-down duties.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundAmount rdf:type rdf:Property ;
    rdfs:label 'Refund Amount' ;
    rdfs:comment 'Any refund or reimbursement due to the client or counterparty as a result of the termination (e.g., unused retainer, prepaid fees).' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementReachedFlag rdf:type rdf:Property ;
    rdfs:label 'Settlement Reached Flag' ;
    rdfs:comment 'Indicates whether a settlement or resolution has been reached regarding the termination dispute. True if settled; False otherwise.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:settlementTerms rdf:type rdf:Property ;
    rdfs:label 'Settlement Terms' ;
    rdfs:comment 'Summary of the key terms and conditions agreed upon in the settlement of the termination dispute, including any financial or performance obligations.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:survivingClauses rdf:type rdf:Property ;
    rdfs:label 'Surviving Clauses' ;
    rdfs:comment 'List or citation of specific contract clauses that expressly survive termination (e.g., \'Sections 8 (Confidentiality), 10 (Indemnity), 14 (Governing Law)\').' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationStatus rdf:type rdf:Property ;
    rdfs:label 'Termination Status' ;
    rdfs:comment 'Current lifecycle status of the termination: pending (notice given but not yet effective), effective (termination complete), disputed (contested by one or more parties), settled (dispute resolved), withdrawn (termination notice retracted).' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationType rdf:type rdf:Property ;
    rdfs:label 'Termination Type' ;
    rdfs:comment 'Classification of the termination event: expiry (natural end of term), termination for convenience (voluntary exit without cause), termination for cause (breach or default), mutual rescission (agreed cancellation), frustration (impossibility of performance), or breach (material violation).' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:windDownCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Wind Down Completion Date' ;
    rdfs:comment 'The date by which all wind-down activities, handovers, and post-termination obligations are expected to be completed.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:windDownPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Wind Down Period Days' ;
    rdfs:comment 'The number of days allowed or required for orderly wind-down of services, handover of work product, or transition activities following the effective termination date.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supersededByClauseClauseLibraryId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Clause Clause Library Id' ;
    rdfs:comment 'Identifier of the clause that supersedes this one when this clause is deprecated or replaced. Maintains version lineage and ensures users are directed to the current approved version.' ;
    rdfs:domain ind:ClauseLibrary ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClauseLibrary .

ind:amlKycRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Aml Kyc Required Flag' ;
    rdfs:comment 'Indicates whether the clause includes or requires Anti-Money Laundering (AML) and Know Your Client (KYC) provisions for client identification and due diligence.' ;
    rdfs:domain ind:ClauseLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvedText rdf:type rdf:Property ;
    rdfs:label 'Approved Text' ;
    rdfs:comment 'The full approved legal text of the clause as vetted and authorized by the knowledge management team, practice group leaders, and General Counsel (GC). This is the primary version for use in client-facing agreements.' ;
    rdfs:domain ind:ClauseLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clauseCategory rdf:type rdf:Property ;
    rdfs:label 'Clause Category' ;
    rdfs:comment 'High-level business category grouping clauses by strategic purpose: risk allocation, compliance, operational, commercial, dispute resolution, or termination provisions.' ;
    rdfs:domain ind:ClauseLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clauseLibraryDescription rdf:type rdf:Property ;
    rdfs:label 'Clause Library Description' ;
    rdfs:comment 'Detailed description of the clause purpose, legal effect, and guidance on when and how to use it. Includes notes on negotiation strategy and common counterparty objections.' ;
    rdfs:domain ind:ClauseLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clauseLibraryStatus rdf:type rdf:Property ;
    rdfs:label 'Clause Library Status' ;
    rdfs:comment 'Current lifecycle status of the clause: active (approved for use), under review (being evaluated), deprecated (no longer recommended), archived (historical reference only), or draft (not yet approved).' ;
    rdfs:domain ind:ClauseLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clauseType rdf:type rdf:Property ;
    rdfs:label 'Clause Type' ;
    rdfs:comment 'Classification of the clause by legal function. Common types include indemnity, limitation of liability, governing law, force majeure, Intellectual Property (IP) assignment, confidentiality, Fair Reasonable and Non-Discriminatory (FRAND), and Alternative Dispute Resolution (ADR) arbitration provisions. [ENUM-REF-CANDIDATE: indemnity|limitation_of_liability|governing_law|force_majeure|ip_assignment|confidentiality|frand|arbitration|termination|warranty|data_protection|audit_rights|insurance|severability|entire_agreement|amendment|waiver|notice|assignment|subcontracting — promote to reference product]' ;
    rdfs:domain ind:ClauseLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalSourceReference rdf:type rdf:Property ;
    rdfs:label 'External Source Reference' ;
    rdfs:comment 'Reference to external standard clause guidance sources such as Thomson Reuters Practical Law, LexisNexis, American Bar Association (ABA) model clauses, or International Chamber of Commerce (ICC) standard terms.' ;
    rdfs:domain ind:ClauseLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fallbackText rdf:type rdf:Property ;
    rdfs:label 'Fallback Text' ;
    rdfs:comment 'Alternative or fallback clause text to be used when the approved text is not acceptable to the counterparty or when negotiation requires a softer position. Provides flexibility during contract negotiation.' ;
    rdfs:domain ind:ClauseLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frandApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Frand Applicable Flag' ;
    rdfs:comment 'Indicates whether the clause is designed for or applicable to Fair Reasonable and Non-Discriminatory (FRAND) licensing scenarios common in Intellectual Property (IP) and standards-essential patent agreements.' ;
    rdfs:domain ind:ClauseLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastUsedDate rdf:type rdf:Property ;
    rdfs:label 'Last Used Date' ;
    rdfs:comment 'Date when this clause was most recently included in a contract. Helps identify obsolete or underutilized clauses.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:negotiationNotes rdf:type rdf:Property ;
    rdfs:label 'Negotiation Notes' ;
    rdfs:comment 'Internal notes and best practices for negotiating this clause with counterparties, including common objections, acceptable modifications, and red lines that should not be crossed.' ;
    rdfs:domain ind:ClauseLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Sox Compliant Flag' ;
    rdfs:comment 'Indicates whether the clause meets Sarbanes-Oxley Act (SOX) requirements for financial controls, audit rights, and corporate governance in contracts with public companies.' ;
    rdfs:domain ind:ClauseLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:usageGuidance rdf:type rdf:Property ;
    rdfs:label 'Usage Guidance' ;
    rdfs:comment 'Practical guidance for attorneys on when to use this clause, including recommended matter types, client profiles, transaction structures, and risk scenarios where the clause is most appropriate.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageTier rdf:type rdf:Property ;
    rdfs:label 'Usage Tier' ;
    rdfs:comment 'Designation of the clause usage priority within the firm: mandatory (must be included), preferred (strongly recommended), fallback (use when primary is rejected), optional (discretionary), or deprecated (no longer recommended).' ;
    rdfs:domain ind:ClauseLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tribunalId rdf:type rdf:Property ;
    rdfs:label 'Tribunal Id' ;
    rdfs:comment 'Unique identifier for the tribunal, court, arbitral body, or ADR (Alternative Dispute Resolution) forum. Primary key for the tribunal master record.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Tribunal .

ind:jurisdictionCoverageId rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Coverage Id' ;
    rdfs:comment 'Foreign key linking to service.jurisdiction_coverage. Business justification: Firms track which tribunals they have admission/coverage for to determine pro hac vice requirements, local counsel needs, and matter acceptance criteria. Drives conflict checks and staffing decisions ' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JurisdictionCoverage .

ind:presidingJudgeId rdf:type rdf:Property ;
    rdfs:label 'Presiding Judge Id' ;
    rdfs:comment 'FK to court.judge' ;
    rdfs:domain ind:Tribunal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Judge .

ind:adrProgramDescription rdf:type rdf:Property ;
    rdfs:label 'Adr Program Description' ;
    rdfs:comment 'Textual description of the ADR programs offered by the tribunal, including mediation panels, arbitration services, early neutral evaluation, and settlement conference procedures. Null if ADR services are not available.' ;
    rdfs:domain ind:Tribunal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adrServicesAvailable rdf:type rdf:Property ;
    rdfs:label 'Adr Services Available' ;
    rdfs:comment 'Indicates whether the tribunal offers or requires Alternative Dispute Resolution (ADR) services such as mediation, arbitration, or settlement conferences as part of its case management process. True if ADR programs are available, False otherwise.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:arbitrationRulesReference rdf:type rdf:Property ;
    rdfs:label 'Arbitration Rules Reference' ;
    rdfs:comment 'Reference to the arbitration rules governing proceedings before this tribunal if it is an arbitral body (e.g., \'ICC Arbitration Rules 2021\', \'LCIA Arbitration Rules 2020\', \'UNCITRAL Arbitration Rules\', \'AAA Commercial Arbitration Rules\'). Null for non-arbitration tribunals.' ;
    rdfs:domain ind:Tribunal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessHours rdf:type rdf:Property ;
    rdfs:label 'Business Hours' ;
    rdfs:comment 'The standard business hours during which the tribunal\'s clerk\'s office is open for filings, inquiries, and in-person visits (e.g., \'Monday-Friday 9:00 AM - 5:00 PM\', \'08:30-16:30 GMT\'). Used to determine filing deadlines and availability for emergency motions.' ;
    rdfs:domain ind:Matter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clerkOfCourtName rdf:type rdf:Property ;
    rdfs:label 'Clerk Of Court Name' ;
    rdfs:comment 'The name of the clerk of court or court administrator responsible for managing case filings, dockets, and administrative functions. Primary contact for procedural questions and filing issues.' ;
    rdfs:domain ind:Tribunal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ecfEnabled rdf:type rdf:Property ;
    rdfs:label 'Ecf Enabled' ;
    rdfs:comment 'Indicates whether the tribunal supports Electronic Case Filing (ECF) for electronic submission of pleadings, motions, and other court documents. True if ECF is available, False if paper filing is required or ECF is not yet implemented.' ;
    rdfs:domain ind:Tribunal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ecfEnrollmentStatus rdf:type rdf:Property ;
    rdfs:label 'Ecf Enrollment Status' ;
    rdfs:comment 'The firm\'s enrollment status with the tribunal\'s ECF system. \'Enrolled\' means the firm has active credentials and can file electronically. \'Pending\' indicates an application is in progress. \'Not Enrolled\' means the firm must enroll before filing. \'Not Applicable\' if the tribunal does not offer ECF.' ;
    rdfs:domain ind:Tribunal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ecfSystemName rdf:type rdf:Property ;
    rdfs:label 'Ecf System Name' ;
    rdfs:comment 'The name or identifier of the electronic filing system used by the tribunal (e.g., \'CM/ECF\' for federal courts, \'NYSCEF\' for New York State courts, \'File & ServeXpress\' for California). Null if ECF is not enabled.' ;
    rdfs:domain ind:Matter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:establishedDate rdf:type rdf:Property ;
    rdfs:label 'Established Date' ;
    rdfs:comment 'The date the tribunal was officially established or chartered. For historical courts, this may be the date of enabling legislation. For arbitration panels, the date the institution was founded.' ;
    rdfs:domain ind:Tribunal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:filingDeadlineTime rdf:type rdf:Property ;
    rdfs:label 'Filing Deadline Time' ;
    rdfs:comment 'The cutoff time by which electronic or physical filings must be submitted to be considered filed on that business day (e.g., \'11:59 PM local time\' for ECF, \'5:00 PM\' for paper filings). Critical for calculating compliance with procedural deadlines.' ;
    rdfs:domain ind:Tribunal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:filingFeeScheduleUrl rdf:type rdf:Property ;
    rdfs:label 'Filing Fee Schedule Url' ;
    rdfs:comment 'URL to the tribunal\'s published schedule of filing fees for various document types and motions. Used by billing and matter management systems to estimate litigation costs and validate disbursements.' ;
    rdfs:domain ind:Matter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionLevel rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Level' ;
    rdfs:comment 'The hierarchical level of legal authority for the tribunal. Federal courts have nationwide jurisdiction, state courts operate within state boundaries, county and municipal courts handle local matters, international tribunals (ICC, LCIA, ICJ) handle cross-border disputes, and tribal courts operate within sovereign tribal lands. [ENUM-REF-CANDIDATE: federal|state|county|municipal|international|regional|tribal — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Tribunal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languagePrimary rdf:type rdf:Property ;
    rdfs:label 'Language Primary' ;
    rdfs:comment 'The primary language in which proceedings are conducted and documents must be filed (e.g., \'English\', \'French\', \'Spanish\', \'Mandarin\'). For international tribunals, this may be the official working language.' ;
    rdfs:domain ind:Matter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageSecondary rdf:type rdf:Property ;
    rdfs:label 'Language Secondary' ;
    rdfs:comment 'A secondary language accepted by the tribunal for filings or proceedings, if applicable. Common in bilingual jurisdictions (e.g., \'French\' in Canadian federal courts, \'Spanish\' in Puerto Rico). Null if only one language is accepted.' ;
    rdfs:domain ind:Matter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localRulesUrl rdf:type rdf:Property ;
    rdfs:label 'Local Rules Url' ;
    rdfs:comment 'URL to the tribunal\'s local rules of procedure, which supplement federal or state rules with court-specific requirements for formatting, filing deadlines, motion practice, and courtroom decorum. Essential reference for litigation teams.' ;
    rdfs:domain ind:Matter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationalStatus rdf:type rdf:Property ;
    rdfs:label 'Operational Status' ;
    rdfs:comment 'Current operational status of the tribunal. \'Active\' indicates the tribunal is fully operational and accepting filings. \'Inactive\' means the tribunal is no longer hearing cases. \'Temporarily Closed\' indicates a temporary suspension (e.g., due to emergency, renovation). \'Merged\' indicates the tribunal has been consolidated with another. \'Dissolved\' indicates permanent closure.' ;
    rdfs:domain ind:Tribunal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pacerEnabled rdf:type rdf:Property ;
    rdfs:label 'Pacer Enabled' ;
    rdfs:comment 'Indicates whether the tribunal provides access to case dockets and documents through PACER (Public Access to Court Electronic Records), the federal judiciary\'s electronic public access service. True for federal courts with PACER access, False otherwise.' ;
    rdfs:domain ind:Tribunal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pacerSiteCode rdf:type rdf:Property ;
    rdfs:label 'Pacer Site Code' ;
    rdfs:comment 'The unique site code assigned by PACER to identify the tribunal in the PACER system (e.g., \'nysd\' for Southern District of New York, \'ca9\' for Ninth Circuit). Used to construct PACER URLs and retrieve docket information programmatically. Null if PACER is not enabled.' ;
    rdfs:domain ind:Tribunal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standingOrdersUrl rdf:type rdf:Property ;
    rdfs:label 'Standing Orders Url' ;
    rdfs:comment 'URL to the tribunal\'s standing orders, which are general directives issued by the court or individual judges that govern case management, scheduling, and procedural matters. May include COVID-19 protocols, electronic filing requirements, or case management procedures.' ;
    rdfs:domain ind:Tribunal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:translationRequired rdf:type rdf:Property ;
    rdfs:label 'Translation Required' ;
    rdfs:comment 'Indicates whether documents filed in a language other than the tribunal\'s primary language must be accompanied by certified translations. True if translation is required, False otherwise.' ;
    rdfs:domain ind:Tribunal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tribunalCode rdf:type rdf:Property ;
    rdfs:label 'Tribunal Code' ;
    rdfs:comment 'Short alphanumeric code or abbreviation used internally or externally to identify the tribunal (e.g., \'SDNY\', \'ICC\', \'LCIA\', \'CA9\' for Ninth Circuit Court of Appeals). Used for quick reference in matter management and docket tracking.' ;
    rdfs:domain ind:Tribunal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tribunalName rdf:type rdf:Property ;
    rdfs:label 'Tribunal Name' ;
    rdfs:comment 'The official legal name of the court, tribunal, arbitral body, or ADR forum as recognized by the governing jurisdiction (e.g., \'United States District Court for the Southern District of New York\', \'International Chamber of Commerce (ICC) International Court of Arbitration\', \'London Court of International Arbitration (LCIA)\').' ;
    rdfs:domain ind:Tribunal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tribunalType rdf:type rdf:Property ;
    rdfs:label 'Tribunal Type' ;
    rdfs:comment 'Classification of the tribunal by its legal function and authority. Distinguishes between trial courts (district), appellate courts (circuit, appellate, supreme), specialized courts (chancery, bankruptcy, tax, family), and ADR forums (arbitration panel, mediation forum, ICC, LCIA). Critical for determining procedural rules and filing requirements. [ENUM-REF-CANDIDATE: district|circuit|appellate|supreme|chancery|bankruptcy|tax|family|arbitration_panel|mediation_forum|adr_body|international_tribunal|administrative_tribunal — 13 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Tribunal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appellateJurisdictionId rdf:type rdf:Property ;
    rdfs:label 'Appellate Jurisdiction Id' ;
    rdfs:comment 'Foreign key reference to the next-level appellate jurisdiction for this court. Null for courts of last resort. Used for appellate pathway analysis and escalation planning.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Jurisdiction .

ind:adrAvailable rdf:type rdf:Property ;
    rdfs:label 'Adr Available' ;
    rdfs:comment 'Indicates whether Alternative Dispute Resolution (ADR) mechanisms (mediation, arbitration, conciliation) are formally available or mandated in this jurisdiction.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:arbitrationInstitution rdf:type rdf:Property ;
    rdfs:label 'Arbitration Institution' ;
    rdfs:comment 'Name of the primary arbitration institution administering disputes in this jurisdiction (e.g., \'International Chamber of Commerce (ICC)\', \'London Court of International Arbitration (LCIA)\', \'American Arbitration Association (AAA)\'). Null if not an arbitral jurisdiction.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arbitrationSeat rdf:type rdf:Property ;
    rdfs:label 'Arbitration Seat' ;
    rdfs:comment 'Indicates whether this jurisdiction serves as a recognized arbitral seat under international arbitration conventions (e.g., New York Convention, UNCITRAL Model Law). True for jurisdictions like London, Paris, Singapore, New York.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:civilProcedureRules rdf:type rdf:Property ;
    rdfs:label 'Civil Procedure Rules' ;
    rdfs:comment 'Name or citation of the governing rules of civil procedure applicable in this jurisdiction (e.g., \'Federal Rules of Civil Procedure\', \'CPR 1998\', \'Code of Civil Procedure\'). Determines pleading standards, discovery scope, and motion practice.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courtLevel rdf:type rdf:Property ;
    rdfs:label 'Court Level' ;
    rdfs:comment 'Hierarchical level of the court within its jurisdiction (trial court of first instance, intermediate appellate, court of last resort, or specialized tribunal).' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courtWebsiteUrl rdf:type rdf:Property ;
    rdfs:label 'Court Website Url' ;
    rdfs:comment 'Official website URL for the court or tribunal. Used for accessing public dockets, forms, and administrative information.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criminalProcedureRules rdf:type rdf:Property ;
    rdfs:label 'Criminal Procedure Rules' ;
    rdfs:comment 'Name or citation of the governing rules of criminal procedure applicable in this jurisdiction. Null if jurisdiction does not handle criminal matters.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ecfIntegrationEnabled rdf:type rdf:Property ;
    rdfs:label 'Ecf Integration Enabled' ;
    rdfs:comment 'Indicates whether automated Electronic Case Filing (ECF) integration is enabled for this jurisdiction. True if the firm has technical integration with the court\'s filing system.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:electronicFilingDeadlineTime rdf:type rdf:Property ;
    rdfs:label 'Electronic Filing Deadline Time' ;
    rdfs:comment 'Cut-off time for same-day electronic filings in local time (e.g., \'11:59 PM\', \'5:00 PM\'). Critical for deadline compliance in Electronic Case Filing (ECF) systems.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:evidenceRules rdf:type rdf:Property ;
    rdfs:label 'Evidence Rules' ;
    rdfs:comment 'Name or citation of the governing rules of evidence (e.g., \'Federal Rules of Evidence\', \'Evidence Act 1995\'). Determines admissibility standards for documents, testimony, and expert opinions.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicRegion rdf:type rdf:Property ;
    rdfs:label 'Geographic Region' ;
    rdfs:comment 'Geographic area or circuit covered by the jurisdiction (e.g., \'Ninth Circuit\', \'England and Wales\', \'State of California\'). Used for venue analysis and conflict-of-laws determination.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionName rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Name' ;
    rdfs:comment 'Full legal name of the jurisdiction (e.g., \'United States Court of Appeals for the Ninth Circuit\', \'Supreme Court of the United Kingdom\', \'International Chamber of Commerce (ICC) Arbitration\').' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionStatus rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Status' ;
    rdfs:comment 'Current operational status of the jurisdiction. Inactive or abolished jurisdictions are retained for historical matter reference.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionType rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Type' ;
    rdfs:comment 'Classification of the jurisdiction by governmental or institutional level. Determines applicable procedural rules and appellate pathways. [ENUM-REF-CANDIDATE: federal|state|provincial|municipal|international|arbitral|administrative|tribal — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalSystem rdf:type rdf:Property ;
    rdfs:label 'Legal System' ;
    rdfs:comment 'Governing legal tradition of the jurisdiction (common law, civil law, mixed system, Sharia law, or customary law). Influences case law precedent, statutory interpretation, and evidentiary standards.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pacerCourtCode rdf:type rdf:Property ;
    rdfs:label 'Pacer Court Code' ;
    rdfs:comment 'PACER-specific court identifier for federal courts. Used for automated docket retrieval and case monitoring via Public Access to Court Electronic Records (PACER) integration. Null for non-federal jurisdictions.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateProvinceCode rdf:type rdf:Property ;
    rdfs:label 'State Province Code' ;
    rdfs:comment 'Two-letter state or province code for sub-national jurisdictions (e.g., \'CA\' for California, \'ON\' for Ontario). Null for federal or international jurisdictions.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statuteOfLimitationsDefaultYears rdf:type rdf:Property ;
    rdfs:label 'Statute Of Limitations Default Years' ;
    rdfs:comment 'Default statute of limitations period in years for general civil claims in this jurisdiction. Used for matter intake risk assessment and calendar management. Actual limitations vary by claim type.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:treatyMemberships rdf:type rdf:Property ;
    rdfs:label 'Treaty Memberships' ;
    rdfs:comment 'Comma-separated list of international treaties and conventions to which this jurisdiction is a signatory (e.g., \'New York Convention\', \'Hague Convention\', \'Patent Cooperation Treaty (PCT)\'). Used for cross-border enforcement and recognition analysis.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courtJurisdictionId rdf:type rdf:Property ;
    rdfs:label 'Court Jurisdiction Id' ;
    rdfs:comment 'Identifier of the court or tribunal to which this judicial officer is assigned.' ;
    rdfs:domain ind:Matter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Jurisdiction .

ind:adrCertificationType rdf:type rdf:Property ;
    rdfs:label 'Adr Certification Type' ;
    rdfs:comment 'Type of Alternative Dispute Resolution (ADR) certification held by the judicial officer or neutral party.' ;
    rdfs:domain ind:Judge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adrPanelMembership rdf:type rdf:Property ;
    rdfs:label 'Adr Panel Membership' ;
    rdfs:comment 'Names of ADR panels or rosters to which the judicial officer or neutral belongs (e.g., ICC, LCIA, AAA, JAMS).' ;
    rdfs:domain ind:Judge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appearanceCount rdf:type rdf:Property ;
    rdfs:label 'Appearance Count' ;
    rdfs:comment 'Number of times the firm has appeared before this judicial officer. Used for relationship intelligence and conflict screening.' ;
    rdfs:domain ind:Judge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:appointmentDate rdf:type rdf:Property ;
    rdfs:label 'Appointment Date' ;
    rdfs:comment 'Date when the judicial officer was appointed or elected to the bench.' ;
    rdfs:domain ind:Judge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:appointmentType rdf:type rdf:Property ;
    rdfs:label 'Appointment Type' ;
    rdfs:comment 'Method by which the judicial officer obtained their position (e.g., Appointed, Elected, Designated).' ;
    rdfs:domain ind:Judge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:barAdmissionDate rdf:type rdf:Property ;
    rdfs:label 'Bar Admission Date' ;
    rdfs:comment 'Date when the judicial officer was first admitted to the bar.' ;
    rdfs:domain ind:Judge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:barAdmissionJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Bar Admission Jurisdiction' ;
    rdfs:comment 'Jurisdiction(s) where the judicial officer is admitted to practice law (prior to appointment).' ;
    rdfs:domain ind:Matter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseManagementStyle rdf:type rdf:Property ;
    rdfs:label 'Case Management Style' ;
    rdfs:comment 'Characterization of the judicial officer\'s approach to case management and courtroom procedure.' ;
    rdfs:domain ind:Judge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chamberNumber rdf:type rdf:Property ;
    rdfs:label 'Chamber Number' ;
    rdfs:comment 'Physical chamber or courtroom number where the judicial officer typically presides.' ;
    rdfs:domain ind:Judge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chambersEmail rdf:type rdf:Property ;
    rdfs:label 'Chambers Email' ;
    rdfs:comment 'Official email address for the judicial officer\'s chambers or administrative staff.' ;
    rdfs:domain ind:Judge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chambersPhone rdf:type rdf:Property ;
    rdfs:label 'Chambers Phone' ;
    rdfs:comment 'Primary phone number for the judicial officer\'s chambers.' ;
    rdfs:domain ind:Judge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courtName rdf:type rdf:Property ;
    rdfs:label 'Court Name' ;
    rdfs:comment 'Name of the court or tribunal where the judicial officer presides.' ;
    rdfs:domain ind:Judge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courtroomTechnologyPreferences rdf:type rdf:Property ;
    rdfs:label 'Courtroom Technology Preferences' ;
    rdfs:comment 'Notes on the judicial officer\'s preferences or requirements for courtroom technology (e.g., electronic presentations, video conferencing, document display systems).' ;
    rdfs:domain ind:Judge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ecfParticipantIdentifier rdf:type rdf:Property ;
    rdfs:label 'Ecf Participant Identifier' ;
    rdfs:comment 'Unique identifier for the judicial officer in the Electronic Case Filing (ECF) system.' ;
    rdfs:domain ind:Judge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:educationBackground rdf:type rdf:Property ;
    rdfs:label 'Education Background' ;
    rdfs:comment 'Educational background of the judicial officer, including law school and undergraduate institutions.' ;
    rdfs:domain ind:Judge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:honorific rdf:type rdf:Property ;
    rdfs:label 'Honorific' ;
    rdfs:comment 'Formal honorific used when addressing or referring to the judicial officer.' ;
    rdfs:domain ind:Judge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:judgeStatus rdf:type rdf:Property ;
    rdfs:label 'Judge Status' ;
    rdfs:comment 'Current status of the judicial officer in their role.' ;
    rdfs:domain ind:Judge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:judicialPhilosophyNotes rdf:type rdf:Property ;
    rdfs:label 'Judicial Philosophy Notes' ;
    rdfs:comment 'Internal notes capturing the judicial officer\'s known legal philosophy, tendencies, or approach to case management. Used for litigation strategy and appearance preparation.' ;
    rdfs:domain ind:Judge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAppearanceDate rdf:type rdf:Property ;
    rdfs:label 'Last Appearance Date' ;
    rdfs:comment 'Date of the most recent appearance by the firm before this judicial officer.' ;
    rdfs:domain ind:Judge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lawClerkName rdf:type rdf:Property ;
    rdfs:label 'Law Clerk Name' ;
    rdfs:comment 'Name of the primary law clerk or judicial assistant supporting the judicial officer.' ;
    rdfs:domain ind:Judge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:motionPracticePreferences rdf:type rdf:Property ;
    rdfs:label 'Motion Practice Preferences' ;
    rdfs:comment 'Known preferences or requirements for motion practice, including page limits, oral argument preferences, and briefing schedules.' ;
    rdfs:domain ind:Judge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notableRulingsSummary rdf:type rdf:Property ;
    rdfs:label 'Notable Rulings Summary' ;
    rdfs:comment 'Summary of notable or landmark rulings issued by the judicial officer. Used for litigation strategy and appearance preparation.' ;
    rdfs:domain ind:Judge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pacerIdentifier rdf:type rdf:Property ;
    rdfs:label 'Pacer Identifier' ;
    rdfs:comment 'Unique identifier for the judicial officer in the PACER (Public Access to Court Electronic Records) system for federal courts.' ;
    rdfs:domain ind:Judge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredCommunicationMethod rdf:type rdf:Property ;
    rdfs:label 'Preferred Communication Method' ;
    rdfs:comment 'Preferred method for communicating with the judicial officer or their chambers.' ;
    rdfs:domain ind:Judge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredFilingProtocol rdf:type rdf:Property ;
    rdfs:label 'Preferred Filing Protocol' ;
    rdfs:comment 'Preferred method or protocol for filing documents with this judicial officer (e.g., ECF, paper, specific formatting requirements).' ;
    rdfs:domain ind:Judge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorFirmAffiliation rdf:type rdf:Property ;
    rdfs:label 'Prior Firm Affiliation' ;
    rdfs:comment 'Name of law firm or organization where the judicial officer practiced prior to appointment. Used for conflict screening.' ;
    rdfs:domain ind:Judge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:professionalAffiliations rdf:type rdf:Property ;
    rdfs:label 'Professional Affiliations' ;
    rdfs:comment 'Professional organizations, bar associations, or judicial conferences to which the judicial officer belongs.' ;
    rdfs:domain ind:Judge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publishedOpinionsCount rdf:type rdf:Property ;
    rdfs:label 'Published Opinions Count' ;
    rdfs:comment 'Number of published judicial opinions authored by this judicial officer. Used for relationship intelligence and litigation strategy.' ;
    rdfs:domain ind:Judge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recusalHistoryFlag rdf:type rdf:Property ;
    rdfs:label 'Recusal History Flag' ;
    rdfs:comment 'Indicates whether the judicial officer has a history of recusals involving the firm or its clients. Used for conflict screening and appearance planning.' ;
    rdfs:domain ind:Judge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recusalNotes rdf:type rdf:Property ;
    rdfs:label 'Recusal Notes' ;
    rdfs:comment 'Detailed notes on past recusals, conflicts, or ethical wall considerations involving this judicial officer.' ;
    rdfs:domain ind:Judge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipStrength rdf:type rdf:Property ;
    rdfs:label 'Relationship Strength' ;
    rdfs:comment 'Assessment of the firm\'s relationship strength with this judicial officer based on past appearances and interactions. Used for relationship intelligence.' ;
    rdfs:domain ind:Judge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalRateNotes rdf:type rdf:Property ;
    rdfs:label 'Reversal Rate Notes' ;
    rdfs:comment 'Internal notes on the judicial officer\'s appellate reversal rate or patterns. Used for litigation strategy.' ;
    rdfs:domain ind:Judge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schedulingPreferences rdf:type rdf:Property ;
    rdfs:label 'Scheduling Preferences' ;
    rdfs:comment 'Known preferences or constraints for scheduling hearings, motions, or trials with this judicial officer.' ;
    rdfs:domain ind:Judge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Term Expiration Date' ;
    rdfs:comment 'Date when the current judicial term expires, if applicable. Null for lifetime appointments.' ;
    rdfs:domain ind:Judge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trialExperienceLevel rdf:type rdf:Property ;
    rdfs:label 'Trial Experience Level' ;
    rdfs:comment 'Assessment of the judicial officer\'s level of trial experience and comfort with jury or bench trials.' ;
    rdfs:domain ind:Judge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedJudgeId rdf:type rdf:Property ;
    rdfs:label 'Assigned Judge Id' ;
    rdfs:comment 'Reference to the judge assigned to preside over this case. Links to the judge master data.' ;
    rdfs:domain ind:Docket ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Judge .

ind:adrProceedingType rdf:type rdf:Property ;
    rdfs:label 'Adr Proceeding Type' ;
    rdfs:comment 'Type of ADR proceeding associated with this docket, if any. Tracks alternative dispute resolution efforts.' ;
    rdfs:domain ind:Matter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appealStatus rdf:type rdf:Property ;
    rdfs:label 'Appeal Status' ;
    rdfs:comment 'Status of any appeal filed in this case. Tracks whether the case has been or is being appealed.' ;
    rdfs:domain ind:Docket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appellateDocketNumber rdf:type rdf:Property ;
    rdfs:label 'Appellate Docket Number' ;
    rdfs:comment 'Docket number assigned by the appellate court if the case has been appealed. Links the trial court docket to the appellate docket.' ;
    rdfs:domain ind:Docket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arbitrationCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Arbitration Case Number' ;
    rdfs:comment 'Case number assigned by the arbitration forum. Used for tracking arbitration proceedings.' ;
    rdfs:domain ind:Docket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arbitrationForum rdf:type rdf:Property ;
    rdfs:label 'Arbitration Forum' ;
    rdfs:comment 'Name of the arbitration institution or forum if the case is being arbitrated (e.g., ICC, LCIA, AAA, JAMS).' ;
    rdfs:domain ind:Docket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseCaption rdf:type rdf:Property ;
    rdfs:label 'Case Caption' ;
    rdfs:comment 'The formal title of the case as it appears on court documents, typically in the format \'Plaintiff v. Defendant\' or \'In re: Matter Name\'.' ;
    rdfs:domain ind:Docket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseClosedDate rdf:type rdf:Property ;
    rdfs:label 'Case Closed Date' ;
    rdfs:comment 'Date when the case was officially closed by the court. Null for active cases.' ;
    rdfs:domain ind:Docket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:caseComplexityLevel rdf:type rdf:Property ;
    rdfs:label 'Case Complexity Level' ;
    rdfs:comment 'Assessment of the case complexity based on legal issues, number of parties, document volume, and procedural requirements. Used for resource planning and matter management.' ;
    rdfs:domain ind:Docket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseStatus rdf:type rdf:Property ;
    rdfs:label 'Case Status' ;
    rdfs:comment 'Current procedural status of the case in the court system. Indicates the lifecycle stage of the docket. [ENUM-REF-CANDIDATE: active|stayed|closed|appealed|settled|dismissed|pending — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Docket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseSubtype rdf:type rdf:Property ;
    rdfs:label 'Case Subtype' ;
    rdfs:comment 'More granular classification of the case (e.g., contract dispute, personal injury, securities fraud, patent infringement). Provides additional detail beyond the primary case type.' ;
    rdfs:domain ind:Docket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseType rdf:type rdf:Property ;
    rdfs:label 'Case Type' ;
    rdfs:comment 'Classification of the case type indicating the nature of the legal proceeding.' ;
    rdfs:domain ind:Docket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseValueCurrency rdf:type rdf:Property ;
    rdfs:label 'Case Value Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the estimated case value.' ;
    rdfs:domain ind:Docket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courtAccessUrl rdf:type rdf:Property ;
    rdfs:label 'Court Access Url' ;
    rdfs:comment 'URL for accessing the case in the court\'s electronic filing system or PACER. Provides direct link to court records.' ;
    rdfs:domain ind:Docket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:docketNumber rdf:type rdf:Property ;
    rdfs:label 'Docket Number' ;
    rdfs:comment 'Court-assigned docket number or case number. This is the official identifier used by the court system to track the case.' ;
    rdfs:domain ind:Docket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ecfRegistrationDate rdf:type rdf:Property ;
    rdfs:label 'Ecf Registration Date' ;
    rdfs:comment 'Date when the firm completed ECF registration for this case.' ;
    rdfs:domain ind:Docket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ecfRegistrationStatus rdf:type rdf:Property ;
    rdfs:label 'Ecf Registration Status' ;
    rdfs:comment 'Status of the firm\'s registration for electronic case filing in this matter. Indicates whether the firm is authorized to file documents electronically.' ;
    rdfs:domain ind:Docket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedCaseValue rdf:type rdf:Property ;
    rdfs:label 'Estimated Case Value' ;
    rdfs:comment 'Estimated monetary value at stake in the case. Used for risk assessment and matter prioritization.' ;
    rdfs:domain ind:Docket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextScheduledEventDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Event Date' ;
    rdfs:comment 'Date of the next scheduled court event, hearing, or deadline. Used for calendar management and appearance tracking.' ;
    rdfs:domain ind:Docket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextScheduledEventType rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Event Type' ;
    rdfs:comment 'Type of the next scheduled event (e.g., hearing, trial, motion deadline, status conference, deposition).' ;
    rdfs:domain ind:Docket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opposingCounselFirm rdf:type rdf:Property ;
    rdfs:label 'Opposing Counsel Firm' ;
    rdfs:comment 'Name of the law firm representing the opposing party.' ;
    rdfs:domain ind:Docket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opposingCounselName rdf:type rdf:Property ;
    rdfs:label 'Opposing Counsel Name' ;
    rdfs:comment 'Name of the primary opposing counsel or law firm representing the adverse party.' ;
    rdfs:domain ind:Matter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pacerCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Pacer Case Number' ;
    rdfs:comment 'Unique identifier for federal court cases in the PACER system. Used for electronic access to federal court records.' ;
    rdfs:domain ind:Matter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trialDate rdf:type rdf:Property ;
    rdfs:label 'Trial Date' ;
    rdfs:comment 'Scheduled date for trial commencement. May be null if trial date has not been set.' ;
    rdfs:domain ind:Matter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:venue rdf:type rdf:Property ;
    rdfs:label 'Venue' ;
    rdfs:comment 'Geographic location or district where the case is being heard (e.g., Southern District of New York, Los Angeles Superior Court).' ;
    rdfs:domain ind:Docket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorHearingId rdf:type rdf:Property ;
    rdfs:label 'Prior Hearing Id' ;
    rdfs:comment 'Reference to the previous hearing record if this hearing is a continuation.' ;
    rdfs:domain ind:Hearing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Hearing .

ind:actualEndTime rdf:type rdf:Property ;
    rdfs:label 'Actual End Time' ;
    rdfs:comment 'The actual date and time when the hearing concluded.' ;
    rdfs:domain ind:Hearing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualStartTime rdf:type rdf:Property ;
    rdfs:label 'Actual Start Time' ;
    rdfs:comment 'The actual date and time when the hearing commenced.' ;
    rdfs:domain ind:Hearing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:adrProceedingFlag rdf:type rdf:Property ;
    rdfs:label 'Adr Proceeding Flag' ;
    rdfs:comment 'Indicates whether this hearing is part of an Alternative Dispute Resolution proceeding such as mediation or arbitration.' ;
    rdfs:domain ind:Matter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appearanceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Appearance Required Flag' ;
    rdfs:comment 'Indicates whether attorney or client appearance is mandatory for this hearing.' ;
    rdfs:domain ind:Hearing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appearanceType rdf:type rdf:Property ;
    rdfs:label 'Appearance Type' ;
    rdfs:comment 'The mode of appearance permitted or required for this hearing.' ;
    rdfs:domain ind:Matter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arbitrationBody rdf:type rdf:Property ;
    rdfs:label 'Arbitration Body' ;
    rdfs:comment 'The name of the arbitration institution administering the proceeding (e.g., International Chamber of Commerce (ICC), London Court of International Arbitration (LCIA)).' ;
    rdfs:domain ind:Hearing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientAttendanceFlag rdf:type rdf:Property ;
    rdfs:label 'Client Attendance Flag' ;
    rdfs:comment 'Indicates whether the client attended or was present at the hearing.' ;
    rdfs:domain ind:Hearing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:continuanceFlag rdf:type rdf:Property ;
    rdfs:label 'Continuance Flag' ;
    rdfs:comment 'Indicates whether this hearing has been continued or rescheduled from a prior date.' ;
    rdfs:domain ind:Hearing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:continuanceReason rdf:type rdf:Property ;
    rdfs:label 'Continuance Reason' ;
    rdfs:comment 'The reason provided for continuing or rescheduling the hearing.' ;
    rdfs:domain ind:Hearing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courtroomNumber rdf:type rdf:Property ;
    rdfs:label 'Courtroom Number' ;
    rdfs:comment 'The physical courtroom or chamber number where the hearing is held.' ;
    rdfs:domain ind:Hearing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hearingNumber rdf:type rdf:Property ;
    rdfs:label 'Hearing Number' ;
    rdfs:comment 'External business identifier or docket number assigned to this hearing by the court or firm.' ;
    rdfs:domain ind:Hearing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hearingStatus rdf:type rdf:Property ;
    rdfs:label 'Hearing Status' ;
    rdfs:comment 'Current lifecycle status of the hearing in the court calendar and matter workflow. [ENUM-REF-CANDIDATE: scheduled|confirmed|in progress|completed|continued|cancelled|vacated — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Hearing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hearingType rdf:type rdf:Property ;
    rdfs:label 'Hearing Type' ;
    rdfs:comment 'Classification of the hearing event. [ENUM-REF-CANDIDATE: status conference|motion hearing|trial|deposition|arbitration session|preliminary hearing|sentencing|oral argument|case management conference|settlement conference — promote to reference product]' ;
    rdfs:domain ind:Hearing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outcomeSummary rdf:type rdf:Property ;
    rdfs:label 'Outcome Summary' ;
    rdfs:comment 'A brief narrative summary of the hearing outcome, ruling, or decision rendered.' ;
    rdfs:domain ind:Hearing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rulingDate rdf:type rdf:Property ;
    rdfs:label 'Ruling Date' ;
    rdfs:comment 'The date on which the judge issued a ruling or order following the hearing.' ;
    rdfs:domain ind:Hearing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rulingIssuedFlag rdf:type rdf:Property ;
    rdfs:label 'Ruling Issued Flag' ;
    rdfs:comment 'Indicates whether a formal ruling or order was issued as a result of this hearing.' ;
    rdfs:domain ind:Hearing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledEndTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Time' ;
    rdfs:comment 'The anticipated date and time when the hearing is expected to conclude.' ;
    rdfs:domain ind:Hearing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledStartTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Time' ;
    rdfs:comment 'The precise date and time when the hearing is scheduled to begin.' ;
    rdfs:domain ind:Hearing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:transcriptAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Transcript Available Flag' ;
    rdfs:comment 'Indicates whether an official court transcript of the hearing is available.' ;
    rdfs:domain ind:Hearing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transcriptOrderedDate rdf:type rdf:Property ;
    rdfs:label 'Transcript Ordered Date' ;
    rdfs:comment 'The date on which the hearing transcript was ordered from the court reporter.' ;
    rdfs:domain ind:Hearing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transcriptReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Transcript Received Date' ;
    rdfs:comment 'The date on which the official transcript was received by the firm.' ;
    rdfs:domain ind:Hearing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:virtualMeetingUrl rdf:type rdf:Property ;
    rdfs:label 'Virtual Meeting Url' ;
    rdfs:comment 'The URL or meeting link for accessing the virtual hearing session.' ;
    rdfs:domain ind:Hearing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:virtualPlatform rdf:type rdf:Property ;
    rdfs:label 'Virtual Platform' ;
    rdfs:comment 'The name of the virtual conferencing platform used for remote hearings (e.g., Zoom, Microsoft Teams, CourtCall).' ;
    rdfs:domain ind:Hearing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appearanceId rdf:type rdf:Property ;
    rdfs:label 'Appearance Id' ;
    rdfs:comment 'Unique identifier for the attorney appearance record. Primary key.' ;
    rdfs:domain ind:Appearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adrForum rdf:type rdf:Property ;
    rdfs:label 'Adr Forum' ;
    rdfs:comment 'The name or identifier of the ADR forum or arbitration body if the appearance was for an arbitration or mediation proceeding (e.g., ICC, LCIA, AAA). Null for court appearances.' ;
    rdfs:domain ind:Appearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appearanceDate rdf:type rdf:Property ;
    rdfs:label 'Appearance Date' ;
    rdfs:comment 'The calendar date on which the attorney made the court appearance. Used for billing verification, court-mandated reporting, and attorney utilization analytics.' ;
    rdfs:domain ind:Appearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:appearanceStatus rdf:type rdf:Property ;
    rdfs:label 'Appearance Status' ;
    rdfs:comment 'Current status of the appearance record in its lifecycle. Tracks whether the appearance was completed as scheduled, cancelled, postponed, or if the attorney did not appear.' ;
    rdfs:domain ind:Appearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billableFlag rdf:type rdf:Property ;
    rdfs:label 'Billable Flag' ;
    rdfs:comment 'Indicates whether the time spent on this appearance is billable to the client. True if billable, False if non-billable (e.g., pro bono, internal matter).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billedFlag rdf:type rdf:Property ;
    rdfs:label 'Billed Flag' ;
    rdfs:comment 'Indicates whether the time for this appearance has been included in a client invoice. True if already billed, False if unbilled Work in Progress (WIP).' ;
    rdfs:domain ind:Appearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:continuanceGranted rdf:type rdf:Property ;
    rdfs:label 'Continuance Granted' ;
    rdfs:comment 'Indicates whether a continuance or postponement was granted during this appearance. True if continuance was granted, False otherwise.' ;
    rdfs:domain ind:Appearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:courtJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Court Jurisdiction' ;
    rdfs:comment 'The jurisdiction of the court or tribunal where the appearance took place. Identifies the legal authority under which the proceeding was conducted.' ;
    rdfs:domain ind:Appearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courtReporterPresent rdf:type rdf:Property ;
    rdfs:label 'Court Reporter Present' ;
    rdfs:comment 'Indicates whether a court reporter was present to create an official transcript of the proceeding. True if reporter present, False otherwise.' ;
    rdfs:domain ind:Appearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:durationHours rdf:type rdf:Property ;
    rdfs:label 'Duration Hours' ;
    rdfs:comment 'Total time spent by the attorney at the appearance, measured in hours. Calculated from start and end times or manually entered. Used for billing and timekeeper utilization analysis.' ;
    rdfs:domain ind:Appearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ecfFilingReference rdf:type rdf:Property ;
    rdfs:label 'Ecf Filing Reference' ;
    rdfs:comment 'Reference number or identifier from the Electronic Case Filing system linking this appearance to the official court record. Used for PACER integration and docket tracking.' ;
    rdfs:domain ind:Appearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endTime rdf:type rdf:Property ;
    rdfs:label 'End Time' ;
    rdfs:comment 'The precise timestamp when the attorney\'s appearance concluded. Used to calculate total time spent for billing and resource allocation.' ;
    rdfs:domain ind:Appearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:nextHearingDate rdf:type rdf:Property ;
    rdfs:label 'Next Hearing Date' ;
    rdfs:comment 'The date of the next scheduled hearing or appearance resulting from this proceeding. Null if no follow-up hearing was scheduled.' ;
    rdfs:domain ind:Appearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:outcomeNotes rdf:type rdf:Property ;
    rdfs:label 'Outcome Notes' ;
    rdfs:comment 'Free-text narrative describing the outcome or key events of the appearance. May include rulings, decisions, next steps, or observations. Confidential attorney work product.' ;
    rdfs:domain ind:Appearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preparationTimeHours rdf:type rdf:Property ;
    rdfs:label 'Preparation Time Hours' ;
    rdfs:comment 'Time spent preparing for the appearance, including research, document review, and strategy sessions. Measured in hours and typically billable to the client matter.' ;
    rdfs:domain ind:Appearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proHacViceStatus rdf:type rdf:Property ;
    rdfs:label 'Pro Hac Vice Status' ;
    rdfs:comment 'Indicates whether the attorney appeared under pro hac vice admission (temporary admission to practice in a jurisdiction where they are not regularly licensed). True if pro hac vice, False if admitted in the jurisdiction.' ;
    rdfs:domain ind:Appearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:proceedingType rdf:type rdf:Property ;
    rdfs:label 'Proceeding Type' ;
    rdfs:comment 'Classification of the type of legal proceeding at which the appearance was made. Distinguishes between court hearings, trials, depositions, Alternative Dispute Resolution (ADR) sessions, arbitration, and mediation.' ;
    rdfs:domain ind:Appearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remoteAppearanceFlag rdf:type rdf:Property ;
    rdfs:label 'Remote Appearance Flag' ;
    rdfs:comment 'Indicates whether the appearance was conducted remotely via video conference or telephone rather than in person. True if remote, False if in-person.' ;
    rdfs:domain ind:Appearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rulingReceived rdf:type rdf:Property ;
    rdfs:label 'Ruling Received' ;
    rdfs:comment 'Indicates whether a judicial ruling or decision was issued during or as a result of this appearance. True if a ruling was received, False otherwise.' ;
    rdfs:domain ind:Appearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:startTime rdf:type rdf:Property ;
    rdfs:label 'Start Time' ;
    rdfs:comment 'The precise timestamp when the attorney\'s appearance began. Supports accurate time tracking for billing and utilization reporting.' ;
    rdfs:domain ind:Appearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:transcriptOrdered rdf:type rdf:Property ;
    rdfs:label 'Transcript Ordered' ;
    rdfs:comment 'Indicates whether a transcript of the proceeding has been ordered. True if transcript ordered, False otherwise. Used for document management and billing tracking.' ;
    rdfs:domain ind:Appearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:travelTimeHours rdf:type rdf:Property ;
    rdfs:label 'Travel Time Hours' ;
    rdfs:comment 'Time spent traveling to and from the appearance location, measured in hours. May be billable or non-billable depending on client agreement and Alternative Fee Arrangement (AFA) terms.' ;
    rdfs:domain ind:Appearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amendedFilingId rdf:type rdf:Property ;
    rdfs:label 'Amended Filing Id' ;
    rdfs:comment 'Reference to the original filing that this filing amends or supersedes, if applicable.' ;
    rdfs:domain ind:Filing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Filing .

ind:confidentialFlag rdf:type rdf:Property ;
    rdfs:label 'Confidential Flag' ;
    rdfs:comment 'Indicates whether the filing contains confidential or sealed information subject to restricted access.' ;
    rdfs:domain ind:Filing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costAllocationCode rdf:type rdf:Property ;
    rdfs:label 'Cost Allocation Code' ;
    rdfs:comment 'The code used to allocate filing costs to specific client billing categories or cost centers.' ;
    rdfs:domain ind:Filing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deadlineComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Deadline Compliance Flag' ;
    rdfs:comment 'Indicates whether the filing was submitted on or before the applicable deadline (True) or was late (False).' ;
    rdfs:domain ind:Filing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deadlineDate rdf:type rdf:Property ;
    rdfs:label 'Deadline Date' ;
    rdfs:comment 'The court-imposed or procedural deadline by which the filing must be submitted.' ;
    rdfs:domain ind:Matter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:docketEntryNumber rdf:type rdf:Property ;
    rdfs:label 'Docket Entry Number' ;
    rdfs:comment 'The sequential number assigned to this filing on the court docket or case register.' ;
    rdfs:domain ind:Filing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ecfConfirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Ecf Confirmation Number' ;
    rdfs:comment 'The confirmation number issued by the Electronic Case Filing system upon successful submission of the filing.' ;
    rdfs:domain ind:Filing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exhibitCount rdf:type rdf:Property ;
    rdfs:label 'Exhibit Count' ;
    rdfs:comment 'The number of exhibits or attachments included with the filing.' ;
    rdfs:domain ind:Filing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expeditedFlag rdf:type rdf:Property ;
    rdfs:label 'Expedited Flag' ;
    rdfs:comment 'Indicates whether the filing was submitted under expedited or emergency procedures.' ;
    rdfs:domain ind:Filing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:filingDescription rdf:type rdf:Property ;
    rdfs:label 'Filing Description' ;
    rdfs:comment 'A brief textual description or summary of the filing content and purpose.' ;
    rdfs:domain ind:Filing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingNumber rdf:type rdf:Property ;
    rdfs:label 'Filing Number' ;
    rdfs:comment 'The court-assigned or system-generated unique filing number for tracking and reference purposes.' ;
    rdfs:domain ind:Filing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingType rdf:type rdf:Property ;
    rdfs:label 'Filing Type' ;
    rdfs:comment 'The category or type of document being filed with the court. [ENUM-REF-CANDIDATE: complaint|motion|brief|answer|notice|order|judgment|petition|affidavit|exhibit — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Filing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:format rdf:type rdf:Property ;
    rdfs:label 'Format' ;
    rdfs:comment 'The format in which the filing was submitted to the court.' ;
    rdfs:domain ind:Filing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hearingDate rdf:type rdf:Property ;
    rdfs:label 'Hearing Date' ;
    rdfs:comment 'The scheduled date for any hearing or court appearance associated with this filing.' ;
    rdfs:domain ind:Filing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:judgeAssigned rdf:type rdf:Property ;
    rdfs:label 'Judge Assigned' ;
    rdfs:comment 'The name of the judge or judicial officer assigned to review or rule on this filing.' ;
    rdfs:domain ind:Filing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pacerTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Pacer Transaction Reference' ;
    rdfs:comment 'The transaction identifier assigned by PACER for federal court filings, used for tracking and retrieval.' ;
    rdfs:domain ind:Filing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sealedFlag rdf:type rdf:Property ;
    rdfs:label 'Sealed Flag' ;
    rdfs:comment 'Indicates whether the filing has been sealed by court order and is not available for public access.' ;
    rdfs:domain ind:Filing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceDate rdf:type rdf:Property ;
    rdfs:label 'Service Date' ;
    rdfs:comment 'The date on which the filing was served on the opposing parties or other required recipients.' ;
    rdfs:domain ind:Filing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:serviceMethod rdf:type rdf:Property ;
    rdfs:label 'Service Method' ;
    rdfs:comment 'The method by which the filing was served on opposing parties or the court.' ;
    rdfs:domain ind:Filing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courtRuleId rdf:type rdf:Property ;
    rdfs:label 'Court Rule Id' ;
    rdfs:comment 'Foreign key linking to matter.court_rule. Business justification: Matter deadlines are frequently governed by specific procedural court rules (e.g., FRCP Rule 26 disclosure deadlines, local rules for motion practice). The matter_deadline table currently stores court' ;
    rdfs:domain ind:Matter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CourtRule .

ind:orderId rdf:type rdf:Property ;
    rdfs:label 'Order Id' ;
    rdfs:comment 'Foreign key linking to matter.order. Business justification: Court orders frequently impose deadlines (e.g., deadline to respond to a motion, deadline to produce documents). The matter_deadline table has court_rule_citation and triggering_event fields but no di' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:alertDaysBefore rdf:type rdf:Property ;
    rdfs:label 'Alert Days Before' ;
    rdfs:comment 'Number of days before the due date when alerts or reminders should be triggered.' ;
    rdfs:domain ind:Deadline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:alertSentFlag rdf:type rdf:Property ;
    rdfs:label 'Alert Sent Flag' ;
    rdfs:comment 'Indicates whether an alert or reminder has been sent for this deadline (True/False).' ;
    rdfs:domain ind:Deadline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:alertSentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Alert Sent Timestamp' ;
    rdfs:comment 'The timestamp when the most recent alert was sent. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Deadline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:calendarEntryReference rdf:type rdf:Property ;
    rdfs:label 'Calendar Entry Reference' ;
    rdfs:comment 'Reference to the calendar or docket control system entry associated with this deadline for tracking and reminder purposes.' ;
    rdfs:domain ind:Deadline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calendarSyncStatus rdf:type rdf:Property ;
    rdfs:label 'Calendar Sync Status' ;
    rdfs:comment 'Status indicating whether this deadline has been successfully synchronized with the firm-wide court calendar system.' ;
    rdfs:domain ind:Deadline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calendarSyncTimestamp rdf:type rdf:Property ;
    rdfs:label 'Calendar Sync Timestamp' ;
    rdfs:comment 'The timestamp when the deadline was last synchronized with the calendar system. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Deadline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:clientNotifiedDate rdf:type rdf:Property ;
    rdfs:label 'Client Notified Date' ;
    rdfs:comment 'The date on which the client was notified of this deadline, particularly important for critical deadlines requiring client input or approval.' ;
    rdfs:domain ind:Matter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:completionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Completion Timestamp' ;
    rdfs:comment 'The precise timestamp when the deadline was marked as completed. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Deadline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deadlineTime rdf:type rdf:Property ;
    rdfs:label 'Deadline Time' ;
    rdfs:comment 'The precise timestamp (date and time) by which the action must be completed, used when time-of-day precision is required (e.g., court filing cutoff at 11:59 PM).' ;
    rdfs:domain ind:Deadline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dueTime rdf:type rdf:Property ;
    rdfs:label 'Due Time' ;
    rdfs:comment 'The precise timestamp by which the deadline must be met, including time of day. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Deadline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ecfFilingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Ecf Filing Required Flag' ;
    rdfs:comment 'Indicates whether this deadline requires an electronic filing through the courts ECF system (True/False).' ;
    rdfs:domain ind:Deadline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:extendedDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Extended Deadline Date' ;
    rdfs:comment 'The new deadline date after an extension has been granted. Null if no extension has been granted.' ;
    rdfs:domain ind:Deadline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:extensionGrantedDate rdf:type rdf:Property ;
    rdfs:label 'Extension Granted Date' ;
    rdfs:comment 'The date on which an extension to the original deadline was granted by the court, opposing counsel, or regulatory body.' ;
    rdfs:domain ind:Deadline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:extensionOrderReference rdf:type rdf:Property ;
    rdfs:label 'Extension Order Reference' ;
    rdfs:comment 'Reference number or citation to the court order granting the extension of time.' ;
    rdfs:domain ind:Deadline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingMethod rdf:type rdf:Property ;
    rdfs:label 'Filing Method' ;
    rdfs:comment 'The method by which the deadline action must be filed or delivered (electronic filing, paper filing, hand delivery, certified mail).' ;
    rdfs:domain ind:Matter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingRuleReference rdf:type rdf:Property ;
    rdfs:label 'Governing Rule Reference' ;
    rdfs:comment 'Citation to the statute, rule, regulation, or contractual provision that establishes this deadline (e.g., FRCP Rule 56(c), 28 U.S.C. § 1658, Contract Section 12.3).' ;
    rdfs:domain ind:Matter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:malpracticeInsuranceNotified rdf:type rdf:Property ;
    rdfs:label 'Malpractice Insurance Notified' ;
    rdfs:comment 'Indicates whether the firms malpractice insurance carrier has been notified of a missed deadline or potential claim related to this deadline.' ;
    rdfs:domain ind:Deadline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:malpracticeRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Malpractice Risk Flag' ;
    rdfs:comment 'Indicates whether missing this deadline poses a significant malpractice risk (True/False). Used for risk management and quality control.' ;
    rdfs:domain ind:Deadline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reminderLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Reminder Lead Time Days' ;
    rdfs:comment 'Number of days before the deadline date when the first reminder notification should be triggered to the responsible timekeeper.' ;
    rdfs:domain ind:Deadline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responsibleTeam rdf:type rdf:Property ;
    rdfs:label 'Responsible Team' ;
    rdfs:comment 'Name or identifier of the practice group or team responsible for this deadline.' ;
    rdfs:domain ind:Deadline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskLevel rdf:type rdf:Property ;
    rdfs:label 'Risk Level' ;
    rdfs:comment 'Assessment of the malpractice or business risk associated with missing this deadline (high, medium, low).' ;
    rdfs:domain ind:Matter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggeringEventDate rdf:type rdf:Property ;
    rdfs:label 'Triggering Event Date' ;
    rdfs:comment 'The date on which the triggering event occurred. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Deadline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:issuingJudgeId rdf:type rdf:Property ;
    rdfs:label 'Issuing Judge Id' ;
    rdfs:comment 'Reference to the judge who issued or signed the order.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Judge .

ind:appealDeadline rdf:type rdf:Property ;
    rdfs:label 'Appeal Deadline' ;
    rdfs:comment 'The last date on which a party may file an appeal or motion to reconsider this order, as determined by applicable court rules.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceDeadline rdf:type rdf:Property ;
    rdfs:label 'Compliance Deadline' ;
    rdfs:comment 'The date by which parties must comply with the directives or obligations set forth in the order. Null if no specific deadline is imposed.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ecfDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Ecf Document Number' ;
    rdfs:comment 'The document number assigned by the court\'s Electronic Case Filing (ECF) system. Used for PACER retrieval and docket tracking.' ;
    rdfs:domain ind:Matter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enforcementStatus rdf:type rdf:Property ;
    rdfs:label 'Enforcement Status' ;
    rdfs:comment 'Current status of enforcement or compliance activities: not_required (order is declaratory or self-executing), pending (enforcement not yet initiated), in_progress (active enforcement), completed (obligations fulfilled), or contested (enforcement disputed).' ;
    rdfs:domain ind:Matter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAppealable rdf:type rdf:Property ;
    rdfs:label 'Is Appealable' ;
    rdfs:comment 'Indicates whether the order is immediately appealable (true) or interlocutory and not subject to immediate appeal (false).' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFinal rdf:type rdf:Property ;
    rdfs:label 'Is Final' ;
    rdfs:comment 'Indicates whether the order is a final order disposing of all claims and parties (true) or an interlocutory order (false).' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPublished rdf:type rdf:Property ;
    rdfs:label 'Is Published' ;
    rdfs:comment 'Indicates whether the order is published in official court reporters or legal databases (true) or remains unpublished (false). Published orders may have precedential value.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSealed rdf:type rdf:Property ;
    rdfs:label 'Is Sealed' ;
    rdfs:comment 'Indicates whether the order is under seal (true) and subject to restricted access, or publicly accessible (false).' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:monetaryAwardAmount rdf:type rdf:Property ;
    rdfs:label 'Monetary Award Amount' ;
    rdfs:comment 'The total monetary amount awarded or ordered to be paid, if the order includes a financial judgment or damages award. Null if the order does not involve monetary relief.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderCategory rdf:type rdf:Property ;
    rdfs:label 'Order Category' ;
    rdfs:comment 'High-level categorization of the order\'s subject matter: discovery (document production, depositions), motion (ruling on a motion), scheduling (case management), judgment (final disposition), sentencing (criminal penalty), or relief (equitable remedy).' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderNumber rdf:type rdf:Property ;
    rdfs:label 'Order Number' ;
    rdfs:comment 'The court-assigned or internally-assigned unique number identifying this order. This is the externally-known business identifier.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderStatus rdf:type rdf:Property ;
    rdfs:label 'Order Status' ;
    rdfs:comment 'Current lifecycle status of the order: draft (prepared but not issued), issued (entered by court), stayed (temporarily suspended), vacated (nullified), appealed (under appellate review), enforced (execution in progress), or complied (obligations fulfilled). [ENUM-REF-CANDIDATE: draft|issued|stayed|vacated|appealed|enforced|complied — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderText rdf:type rdf:Property ;
    rdfs:label 'Order Text' ;
    rdfs:comment 'The complete text of the court order as issued. May contain confidential case details and party information.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderType rdf:type rdf:Property ;
    rdfs:label 'Order Type' ;
    rdfs:comment 'Classification of the order by its legal nature: procedural (scheduling, discovery), substantive (merits decision), consent (agreed by parties), default (non-appearance), summary judgment (pre-trial disposition), or injunction (equitable relief).' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pacerUrl rdf:type rdf:Property ;
    rdfs:label 'Pacer Url' ;
    rdfs:comment 'Direct URL to the order document in the PACER (Public Access to Court Electronic Records) system for federal court orders.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prevailingParty rdf:type rdf:Property ;
    rdfs:label 'Prevailing Party' ;
    rdfs:comment 'Identifies which party or side prevailed or was granted relief by the order. \'none\' indicates the order was neutral or procedural without a clear prevailing party. [ENUM-REF-CANDIDATE: plaintiff|defendant|petitioner|respondent|movant|non_movant|none — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Matter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:summary rdf:type rdf:Property ;
    rdfs:label 'Summary' ;
    rdfs:comment 'A concise textual summary of the order\'s content, directives, and key holdings. Provides quick reference without reading the full order text.' ;
    rdfs:domain ind:Matter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentRuleCourtRuleId rdf:type rdf:Property ;
    rdfs:label 'Parent Rule Court Rule Id' ;
    rdfs:comment 'Reference to the parent rule if this is a sub-rule or subsection. Enables hierarchical rule structures (e.g., Rule 26(a)(1) is a child of Rule 26).' ;
    rdfs:domain ind:CourtRule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CourtRule .

ind:primarySupersededByRuleCourtRuleId rdf:type rdf:Property ;
    rdfs:label 'Primary Superseded By Rule Court Rule Id' ;
    rdfs:comment 'Reference to the court rule that supersedes or replaces this rule. Null if the rule is still active or was retired without replacement.' ;
    rdfs:domain ind:CourtRule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CourtRule .

ind:advisoryCommitteeNotes rdf:type rdf:Property ;
    rdfs:label 'Advisory Committee Notes' ;
    rdfs:comment 'Summary or reference to advisory committee notes or official commentary explaining the purpose and application of this rule. Provides interpretive guidance.' ;
    rdfs:domain ind:CourtRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableCaseTypes rdf:type rdf:Property ;
    rdfs:label 'Applicable Case Types' ;
    rdfs:comment 'Comma-separated list of case types to which this rule applies (e.g., civil, criminal, bankruptcy, family, probate). Null if the rule applies to all case types in the court.' ;
    rdfs:domain ind:CourtRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:citationFormat rdf:type rdf:Property ;
    rdfs:label 'Citation Format' ;
    rdfs:comment 'The standard citation format for this rule as used in legal briefs and filings (e.g., Fed. R. Civ. P. 26(a), Local Rule 7.1(a)).' ;
    rdfs:domain ind:CourtRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceChecklist rdf:type rdf:Property ;
    rdfs:label 'Compliance Checklist' ;
    rdfs:comment 'Structured checklist or list of requirements that must be satisfied to comply with this rule. Supports automated compliance verification and attorney guidance.' ;
    rdfs:domain ind:CourtRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courtRuleStatus rdf:type rdf:Property ;
    rdfs:label 'Court Rule Status' ;
    rdfs:comment 'Current lifecycle status of the court rule. Active rules are enforceable; superseded rules have been replaced; proposed rules are pending adoption.' ;
    rdfs:domain ind:CourtRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deadlineCalculationRule rdf:type rdf:Property ;
    rdfs:label 'Deadline Calculation Rule' ;
    rdfs:comment 'Formula or logic for calculating deadlines under this rule (e.g., 30 days from service, 14 days before hearing, within 21 days of order). Enables automated deadline tracking and calendar management.' ;
    rdfs:domain ind:CourtRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ecfEventCode rdf:type rdf:Property ;
    rdfs:label 'Ecf Event Code' ;
    rdfs:comment 'The ECF event code associated with filings governed by this rule. Used for automated docket entry and deadline calculation in CM/ECF systems.' ;
    rdfs:domain ind:CourtRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:electronicFilingRequired rdf:type rdf:Property ;
    rdfs:label 'Electronic Filing Required' ;
    rdfs:comment 'Indicates whether this rule mandates electronic filing through ECF (Electronic Case Filing) or similar systems. True if electronic filing is required; false if paper filing is permitted.' ;
    rdfs:domain ind:CourtRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exceptionsAndExemptions rdf:type rdf:Property ;
    rdfs:label 'Exceptions And Exemptions' ;
    rdfs:comment 'Description of any exceptions, exemptions, or circumstances under which this rule does not apply or may be waived.' ;
    rdfs:domain ind:CourtRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pageLimit rdf:type rdf:Property ;
    rdfs:label 'Page Limit' ;
    rdfs:comment 'Maximum number of pages allowed for filings governed by this rule. Null if no page limit applies.' ;
    rdfs:domain ind:CourtRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:penaltyForNoncompliance rdf:type rdf:Property ;
    rdfs:label 'Penalty For Noncompliance' ;
    rdfs:comment 'Description of sanctions, penalties, or consequences for failing to comply with this rule (e.g., dismissal, striking of pleadings, monetary sanctions, contempt).' ;
    rdfs:domain ind:CourtRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleText rdf:type rdf:Property ;
    rdfs:label 'Rule Text' ;
    rdfs:comment 'The full text of the court rule or a summary of its key provisions. May include subsections, clauses, and commentary.' ;
    rdfs:domain ind:CourtRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleTitle rdf:type rdf:Property ;
    rdfs:label 'Rule Title' ;
    rdfs:comment 'The full official title or short description of the court rule (e.g., Duty to Disclose; General Provisions Governing Discovery, Motion Practice).' ;
    rdfs:domain ind:CourtRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceMethodRequired rdf:type rdf:Property ;
    rdfs:label 'Service Method Required' ;
    rdfs:comment 'The method of service required or permitted by this rule (e.g., personal service, certified mail, electronic service). Critical for compliance with service of process requirements.' ;
    rdfs:domain ind:CourtRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Source Document Url' ;
    rdfs:comment 'URL or hyperlink to the authoritative source document for this rule (e.g., court website, legal research platform, official government publication).' ;
    rdfs:domain ind:CourtRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wordLimit rdf:type rdf:Property ;
    rdfs:label 'Word Limit' ;
    rdfs:comment 'Maximum number of words allowed for filings governed by this rule. Null if no word limit applies.' ;
    rdfs:domain ind:CourtRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:appealCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Appeal Case Number' ;
    rdfs:comment 'Case number assigned by the appellate court for the appeal of this judgment.' ;
    rdfs:domain ind:Judgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appealCourtName rdf:type rdf:Property ;
    rdfs:label 'Appeal Court Name' ;
    rdfs:comment 'Name of the appellate court where an appeal was filed, if applicable.' ;
    rdfs:domain ind:Judgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appealDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Appeal Deadline Date' ;
    rdfs:comment 'Final date by which an appeal of this judgment must be filed.' ;
    rdfs:domain ind:Matter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:appealFiledDate rdf:type rdf:Property ;
    rdfs:label 'Appeal Filed Date' ;
    rdfs:comment 'Date on which an appeal of this judgment was filed, if applicable.' ;
    rdfs:domain ind:Matter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:attorneyFeesAwarded rdf:type rdf:Property ;
    rdfs:label 'Attorney Fees Awarded' ;
    rdfs:comment 'Amount of attorney fees awarded as part of the judgment, if applicable.' ;
    rdfs:domain ind:Judgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consentJudgmentFlag rdf:type rdf:Property ;
    rdfs:label 'Consent Judgment Flag' ;
    rdfs:comment 'Indicates whether this is a consent judgment agreed to by all parties.' ;
    rdfs:domain ind:Judgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costAwardAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Award Amount' ;
    rdfs:comment 'Amount of court costs and litigation expenses awarded as part of the judgment.' ;
    rdfs:domain ind:Judgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:declaratoryReliefFlag rdf:type rdf:Property ;
    rdfs:label 'Declaratory Relief Flag' ;
    rdfs:comment 'Indicates whether the judgment provides declaratory relief clarifying rights and obligations.' ;
    rdfs:domain ind:Judgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:defaultJudgmentFlag rdf:type rdf:Property ;
    rdfs:label 'Default Judgment Flag' ;
    rdfs:comment 'Indicates whether this judgment was entered by default due to failure to respond or appear.' ;
    rdfs:domain ind:Judgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:entryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Entry Timestamp' ;
    rdfs:comment 'Precise timestamp when the judgment was entered into the court record.' ;
    rdfs:domain ind:Judgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:finalJudgmentFlag rdf:type rdf:Property ;
    rdfs:label 'Final Judgment Flag' ;
    rdfs:comment 'Indicates whether this is a final judgment that disposes of all claims and parties.' ;
    rdfs:domain ind:Judgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:forClient rdf:type rdf:Property ;
    rdfs:label 'For Client' ;
    rdfs:comment 'Indicates whether the judgment was favorable to the firm\'s client.' ;
    rdfs:domain ind:Judgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:injunctiveReliefFlag rdf:type rdf:Property ;
    rdfs:label 'Injunctive Relief Flag' ;
    rdfs:comment 'Indicates whether the judgment includes injunctive relief or equitable remedies.' ;
    rdfs:domain ind:Judgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:judgmentNumber rdf:type rdf:Property ;
    rdfs:label 'Judgment Number' ;
    rdfs:comment 'Court-assigned judgment number or docket entry number for this judgment.' ;
    rdfs:domain ind:Judgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:judgmentStatus rdf:type rdf:Property ;
    rdfs:label 'Judgment Status' ;
    rdfs:comment 'Current lifecycle status of the judgment indicating its enforceability and procedural state. [ENUM-REF-CANDIDATE: entered|appealed|affirmed|reversed|vacated|satisfied|enforced — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Judgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:judgmentText rdf:type rdf:Property ;
    rdfs:label 'Judgment Text' ;
    rdfs:comment 'Full text of the judgment as entered by the court, or reference to the document location.' ;
    rdfs:domain ind:Judgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:judgmentType rdf:type rdf:Property ;
    rdfs:label 'Judgment Type' ;
    rdfs:comment 'Classification of the judgment based on how it was obtained or entered.' ;
    rdfs:domain ind:Judgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lienFiledFlag rdf:type rdf:Property ;
    rdfs:label 'Lien Filed Flag' ;
    rdfs:comment 'Indicates whether a judgment lien has been filed to secure the judgment amount.' ;
    rdfs:domain ind:Judgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:partialJudgmentFlag rdf:type rdf:Property ;
    rdfs:label 'Partial Judgment Flag' ;
    rdfs:comment 'Indicates whether this is a partial judgment resolving some but not all claims.' ;
    rdfs:domain ind:Judgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:prevailingPartyName rdf:type rdf:Property ;
    rdfs:label 'Prevailing Party Name' ;
    rdfs:comment 'Name of the party or parties that prevailed in the judgment.' ;
    rdfs:domain ind:Judgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:satisfactionDate rdf:type rdf:Property ;
    rdfs:label 'Satisfaction Date' ;
    rdfs:comment 'Date on which the judgment was satisfied or paid in full.' ;
    rdfs:domain ind:Matter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:settlementJudgmentFlag rdf:type rdf:Property ;
    rdfs:label 'Settlement Judgment Flag' ;
    rdfs:comment 'Indicates whether this judgment reflects a court-entered settlement agreement.' ;
    rdfs:domain ind:Judgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalDocFolderId rdf:type rdf:Property ;
    rdfs:label 'Legal Doc Folder Id' ;
    rdfs:comment 'FK to document.doc_folder.doc_folder_id — Documents are organized into DMS folders/workspaces. This FK enables workspace-based retrieval, access control inheritance, and matter-workspace association.' ;
    rdfs:domain ind:LegalDocument ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DocFolder .

ind:legalDocTypeId rdf:type rdf:Property ;
    rdfs:label 'Legal Doc Type Id' ;
    rdfs:comment 'FK to document.doc_type.doc_type_id — Every document has a type classification. This FK enables filtering by document type, applying retention rules, and enforcing naming conventions. Core to DMS taxonomy and retention governance.' ;
    rdfs:domain ind:LegalDocument ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DocType .

ind:primaryLegalDocFolderId rdf:type rdf:Property ;
    rdfs:label 'Primary Legal Doc Folder Id' ;
    rdfs:comment 'Foreign key linking to document.doc_folder. Business justification: legal_document has folder_path: STRING and workspace_id: STRING. doc_folder represents the DMS folder hierarchy. Documents are stored IN folders (1:N relationship). Adding doc_folder_id FK normalizes ' ;
    rdfs:domain ind:LegalDocument ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DocFolder .

ind:primaryLegalDocTypeId rdf:type rdf:Property ;
    rdfs:label 'Primary Legal Doc Type Id' ;
    rdfs:comment 'Foreign key linking to document.doc_type. Business justification: legal_document has document_type: STRING (not an FK). doc_type is the authoritative reference table for document type classifications. This is a standard lookup relationship. Adding doc_type_id FK all' ;
    rdfs:domain ind:LegalDocument ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DocType .

ind:primaryLegalRetentionScheduleId rdf:type rdf:Property ;
    rdfs:label 'Primary Legal Retention Schedule Id' ;
    rdfs:comment 'Foreign key linking to document.retention_schedule. Business justification: legal_document has retention_schedule: STRING (not an FK). retention_schedule is the authoritative reference table defining retention policies. Each document is governed by one retention schedule. Add' ;
    rdfs:domain ind:LegalDocument ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RetentionSchedule .

ind:toDocFolderId rdf:type rdf:Property ;
    rdfs:label 'To Doc Folder Id' ;
    rdfs:comment 'FK to document.doc_folder.doc_folder_id — Documents are stored within DMS folder/workspace hierarchy. This FK enables the organizational container structure described in doc_folder and is essential for workspace-based access control and matte' ;
    rdfs:domain ind:LegalDocument ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DocFolder .

ind:toDocTypeId rdf:type rdf:Property ;
    rdfs:label 'To Doc Type Id' ;
    rdfs:comment 'FK to document.doc_type.doc_type_id — Every document must be classified by type. The doc_type reference table exists specifically to classify legal_document records. Without this FK, document classification, retention policy assignment, a' ;
    rdfs:domain ind:LegalDocument ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DocType .

ind:toRetentionScheduleId rdf:type rdf:Property ;
    rdfs:label 'To Retention Schedule Id' ;
    rdfs:comment 'FK to document.retention_schedule.retention_schedule_id — Documents must be linked to their applicable retention policy for automated retention enforcement. Without this FK, the retention_schedule cannot govern document lifecycle as described.' ;
    rdfs:domain ind:LegalDocument ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RetentionSchedule .

ind:containsPii rdf:type rdf:Property ;
    rdfs:label 'Contains Pii' ;
    rdfs:comment 'Boolean flag indicating whether the document contains Personally Identifiable Information (PII) subject to GDPR, CCPA, or other data privacy regulations.' ;
    rdfs:domain ind:LegalDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:createdDate rdf:type rdf:Property ;
    rdfs:label 'Created Date' ;
    rdfs:comment 'Date on which the document was originally created or authored.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dmsSystem rdf:type rdf:Property ;
    rdfs:label 'Dms System' ;
    rdfs:comment 'Name of the Document Management System where the document is stored (e.g., iManage Work, NetDocuments, Relativity, SharePoint, Other).' ;
    rdfs:domain ind:LegalDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentCategory rdf:type rdf:Property ;
    rdfs:label 'Document Category' ;
    rdfs:comment 'High-level business category of the document aligned with practice area (e.g., Transactional, Litigation, Advisory, Compliance, IP, Employment, Regulatory, Corporate Governance). [ENUM-REF-CANDIDATE: transactional|litigation|advisory|compliance|ip|employment|regulatory|corporate_governance — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LegalDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentNumber rdf:type rdf:Property ;
    rdfs:label 'Document Number' ;
    rdfs:comment 'Business-facing unique document number or identifier assigned by the Document Management System (DMS). Used for external reference and tracking.' ;
    rdfs:domain ind:LegalDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentStatus rdf:type rdf:Property ;
    rdfs:label 'Document Status' ;
    rdfs:comment 'Current lifecycle status of the document (e.g., Draft, Under Review, Approved, Executed, Archived, Obsolete, Superseded). [ENUM-REF-CANDIDATE: draft|under_review|approved|executed|archived|obsolete|superseded — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LegalDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executedDate rdf:type rdf:Property ;
    rdfs:label 'Executed Date' ;
    rdfs:comment 'Date on which the document was executed, signed, or became legally effective (applicable to contracts, agreements, and other binding documents).' ;
    rdfs:domain ind:LegalDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fileExtension rdf:type rdf:Property ;
    rdfs:label 'File Extension' ;
    rdfs:comment 'File format extension indicating the document type (e.g., docx, pdf, xlsx, pptx, msg, eml, txt, rtf, html, xml). [ENUM-REF-CANDIDATE: docx|pdf|xlsx|pptx|msg|eml|txt|rtf|html|xml — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LegalDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileName rdf:type rdf:Property ;
    rdfs:label 'File Name' ;
    rdfs:comment 'Original file name of the document as stored in the DMS, including file extension (e.g., Contract_Draft_v2.docx).' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileSizeBytes rdf:type rdf:Property ;
    rdfs:label 'File Size Bytes' ;
    rdfs:comment 'Size of the document file in bytes, used for storage management and transfer tracking.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hashValue rdf:type rdf:Property ;
    rdfs:label 'Hash Value' ;
    rdfs:comment 'Cryptographic hash (e.g., MD5, SHA-256) of the document file, used for integrity verification, deduplication, and chain of custody in eDiscovery.' ;
    rdfs:domain ind:LegalDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isCurrentVersion rdf:type rdf:Property ;
    rdfs:label 'Is Current Version' ;
    rdfs:comment 'Boolean flag indicating whether this version is the current active version of the document (True) or a historical version (False).' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalDocumentDescription rdf:type rdf:Property ;
    rdfs:label 'Legal Document Description' ;
    rdfs:comment 'Free-text description or summary of the documents content, purpose, and context, used for search and reference.' ;
    rdfs:domain ind:LegalDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Legal Hold Flag' ;
    rdfs:comment 'Boolean flag indicating whether the document is subject to a legal hold (litigation hold, preservation order) preventing its destruction.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mimeType rdf:type rdf:Property ;
    rdfs:label 'Mime Type' ;
    rdfs:comment 'Multipurpose Internet Mail Extensions (MIME) type of the document file (e.g., application/pdf, application/vnd.openxmlformats-officedocument.wordprocessingml.document).' ;
    rdfs:domain ind:LegalDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedDate rdf:type rdf:Property ;
    rdfs:label 'Modified Date' ;
    rdfs:comment 'Date on which the document was last modified or updated.' ;
    rdfs:domain ind:LegalDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nlpProcessed rdf:type rdf:Property ;
    rdfs:label 'Nlp Processed' ;
    rdfs:comment 'Boolean flag indicating whether the document has been processed through Natural Language Processing (NLP) for entity extraction, sentiment analysis, or other AI-driven analysis.' ;
    rdfs:domain ind:LegalDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ocrProcessed rdf:type rdf:Property ;
    rdfs:label 'Ocr Processed' ;
    rdfs:comment 'Boolean flag indicating whether the document has been processed through Optical Character Recognition (OCR) to extract text from images or scanned documents.' ;
    rdfs:domain ind:LegalDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:privilegeStatus rdf:type rdf:Property ;
    rdfs:label 'Privilege Status' ;
    rdfs:comment 'Designation indicating whether the document is protected by Legal Professional Privilege (LPP), attorney-client privilege, work product doctrine, or is non-privileged. Critical for eDiscovery and disclosure obligations.' ;
    rdfs:domain ind:LegalDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewStatus rdf:type rdf:Property ;
    rdfs:label 'Review Status' ;
    rdfs:comment 'Status of the document within the eDiscovery review workflow (e.g., Not Reviewed, Under Review, Reviewed, Responsive, Non-Responsive, Privileged, Redacted, Produced). [ENUM-REF-CANDIDATE: not_reviewed|under_review|reviewed|responsive|non_responsive|privileged|redacted|produced — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageLocation rdf:type rdf:Property ;
    rdfs:label 'Storage Location' ;
    rdfs:comment 'Physical or logical storage path or URI where the document is stored in the DMS (e.g., iManage workspace path, NetDocuments cabinet/folder path, cloud storage URI).' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workspaceCode rdf:type rdf:Property ;
    rdfs:label 'Workspace Code' ;
    rdfs:comment 'Identifier of the DMS workspace, cabinet, or container where the document resides, used for organizational hierarchy and access control.' ;
    rdfs:domain ind:LegalDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryLegalDocumentId rdf:type rdf:Property ;
    rdfs:label 'Primary Legal Document Id' ;
    rdfs:comment 'Reference to the parent document entity. Links this version to the master document record that spans all versions. Essential for version lineage and rollback capability.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalDocument .

ind:toLegalDocumentId rdf:type rdf:Property ;
    rdfs:label 'To Legal Document Id' ;
    rdfs:comment 'FK to document.legal_document.legal_document_id — Every version must reference its parent document. This is the most fundamental FK in the domain — without it, versions are orphaned and the version lineage described in both product descriptions canno' ;
    rdfs:domain ind:Document ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalDocument .

ind:batesNumber rdf:type rdf:Property ;
    rdfs:label 'Bates Number' ;
    rdfs:comment 'Unique Bates stamp or control number assigned to this version during eDiscovery production. Provides a permanent, sequential identifier for produced documents and facilitates citation in legal proceedings.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeSummary rdf:type rdf:Property ;
    rdfs:label 'Change Summary' ;
    rdfs:comment 'Brief description of changes made in this version compared to the previous version. Authored by the user during check-in. Supports version comparison and audit trails.' ;
    rdfs:domain ind:DocVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkedInTimestamp rdf:type rdf:Property ;
    rdfs:label 'Checked In Timestamp' ;
    rdfs:comment 'Timestamp when this version was checked back into the DMS after editing. Marks the completion of the edit session and availability for others to access.' ;
    rdfs:domain ind:DocVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:checkedOutTimestamp rdf:type rdf:Property ;
    rdfs:label 'Checked Out Timestamp' ;
    rdfs:comment 'Timestamp when this version was checked out for editing. Null if currently checked in. Used to track document lock duration and identify stale checkouts.' ;
    rdfs:domain ind:DocVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:extractedText rdf:type rdf:Property ;
    rdfs:label 'Extracted Text' ;
    rdfs:comment 'Full text content extracted from the document via OCR or native text extraction. Enables full-text search, keyword analysis, and TAR/Continuous Active Learning (CAL) model training. May be very large; consider external storage for production systems.' ;
    rdfs:domain ind:DocVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileFormat rdf:type rdf:Property ;
    rdfs:label 'File Format' ;
    rdfs:comment 'MIME type or file format of this version (e.g., \'application/pdf\', \'application/vnd.openxmlformats-officedocument.wordprocessingml.document\'). Critical for rendering, conversion, and eDiscovery processing.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileHash rdf:type rdf:Property ;
    rdfs:label 'File Hash' ;
    rdfs:comment 'Cryptographic hash (e.g., SHA-256) of the file content. Ensures file integrity, detects tampering, and supports deduplication in eDiscovery collections. Critical for chain of custody.' ;
    rdfs:domain ind:DocVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nlpEntitiesExtracted rdf:type rdf:Property ;
    rdfs:label 'Nlp Entities Extracted' ;
    rdfs:comment 'JSON or delimited list of named entities extracted from the document via Natural Language Processing (NLP) (e.g., person names, organizations, dates, monetary amounts). Enables advanced search, analytics, and contract intelligence.' ;
    rdfs:domain ind:DocVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ocrConfidenceScore rdf:type rdf:Property ;
    rdfs:label 'Ocr Confidence Score' ;
    rdfs:comment 'Confidence score (0.00 to 100.00) indicating the OCR engine\'s certainty in the accuracy of extracted text. Low scores flag documents requiring manual review. Critical for TAR model training quality.' ;
    rdfs:domain ind:DocVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ocrEngine rdf:type rdf:Property ;
    rdfs:label 'Ocr Engine' ;
    rdfs:comment 'Name and version of the OCR engine used to process this version (e.g., \'Tesseract 4.1\', \'ABBYY FineReader 15\', \'Adobe Acrobat DC\'). Documents processing provenance for eDiscovery defensibility.' ;
    rdfs:domain ind:DocVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ocrProcessedFlag rdf:type rdf:Property ;
    rdfs:label 'Ocr Processed Flag' ;
    rdfs:comment 'Boolean flag indicating whether this version has been processed through Optical Character Recognition (OCR) to extract text from images or scanned documents. Required for full-text search and Technology-Assisted Review (TAR).' ;
    rdfs:domain ind:DocVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:privilegeDesignation rdf:type rdf:Property ;
    rdfs:label 'Privilege Designation' ;
    rdfs:comment 'Classification of this version\'s privilege status under Legal Professional Privilege (LPP) or attorney-client privilege. Critical for eDiscovery privilege logs and redaction workflows.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionDate rdf:type rdf:Property ;
    rdfs:label 'Production Date' ;
    rdfs:comment 'Date when this version was produced to external parties. Null if never produced. Essential for tracking disclosure timelines and compliance with discovery deadlines.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:productionFlag rdf:type rdf:Property ;
    rdfs:label 'Production Flag' ;
    rdfs:comment 'Boolean flag indicating whether this version has been produced (disclosed) to opposing parties or regulators in eDiscovery or regulatory response. Tracks disclosure history for privilege and confidentiality management.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:redactedFlag rdf:type rdf:Property ;
    rdfs:label 'Redacted Flag' ;
    rdfs:comment 'Boolean flag indicating whether this version contains redactions (e.g., for privilege, confidentiality, or Personally Identifiable Information (PII) protection). Signals special handling for productions and disclosures.' ;
    rdfs:domain ind:DocVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:redactionReason rdf:type rdf:Property ;
    rdfs:label 'Redaction Reason' ;
    rdfs:comment 'Explanation of why redactions were applied to this version (e.g., \'Attorney-client privilege\', \'Trade secret\', \'PII protection\'). Required for privilege logs and transparency in eDiscovery productions.' ;
    rdfs:domain ind:DocVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionCategory rdf:type rdf:Property ;
    rdfs:label 'Retention Category' ;
    rdfs:comment 'Records retention category assigned to this version based on document type and regulatory requirements. Determines retention period and disposition rules per the firm\'s records retention schedule.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storagePath rdf:type rdf:Property ;
    rdfs:label 'Storage Path' ;
    rdfs:comment 'Physical or logical storage path where this version is stored in the DMS or cloud repository (e.g., iManage workspace path, NetDocuments cabinet/folder path). Confidential for security reasons.' ;
    rdfs:domain ind:DocVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tarRelevanceScore rdf:type rdf:Property ;
    rdfs:label 'Tar Relevance Score' ;
    rdfs:comment 'Relevance score (0.00 to 100.00) assigned by a Technology-Assisted Review (TAR) or Continuous Active Learning (CAL) model. Higher scores indicate greater predicted relevance to the matter. Supports prioritization of review efforts.' ;
    rdfs:domain ind:DocVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:versionLabel rdf:type rdf:Property ;
    rdfs:label 'Version Label' ;
    rdfs:comment 'Human-readable version label or tag assigned by the author (e.g., \'Draft 1\', \'Final\', \'Executed\', \'Client Review\'). Provides business context beyond numeric versioning.' ;
    rdfs:domain ind:DocVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionStatus rdf:type rdf:Property ;
    rdfs:label 'Version Status' ;
    rdfs:comment 'Current lifecycle status of this document version. Tracks progression through drafting, review, approval, execution, and archival stages. Essential for workflow management and compliance. [ENUM-REF-CANDIDATE: draft|in_review|approved|final|executed|superseded|archived — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DocVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:docTypeId rdf:type rdf:Property ;
    rdfs:label 'Doc Type Id' ;
    rdfs:comment 'Unique identifier for the document type. Primary key.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DocType .

ind:billableActivity rdf:type rdf:Property ;
    rdfs:label 'Billable Activity' ;
    rdfs:comment 'Indicates whether time spent drafting, reviewing, or managing documents of this type is typically billable to clients (true for client-facing work product; false for internal administrative documents).' ;
    rdfs:domain ind:DocType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:chainOfCustodyTracking rdf:type rdf:Property ;
    rdfs:label 'Chain Of Custody Tracking' ;
    rdfs:comment 'Indicates whether documents of this type require formal chain of custody tracking for evidentiary purposes (e.g., exhibits, evidence, forensic documents require chain of custody; routine correspondence does not).' ;
    rdfs:domain ind:DocType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:courtFilingEligible rdf:type rdf:Property ;
    rdfs:label 'Court Filing Eligible' ;
    rdfs:comment 'Indicates whether documents of this type can be filed with courts or tribunals via Electronic Case Filing (ECF) systems. True for pleadings, motions, briefs, exhibits; false for internal work product.' ;
    rdfs:domain ind:DocType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:defaultPrivilegeClassification rdf:type rdf:Property ;
    rdfs:label 'Default Privilege Classification' ;
    rdfs:comment 'Default privilege designation for documents of this type: privileged (attorney-client privilege), work_product (attorney work product doctrine), confidential (business confidential but not privileged), public (no privilege or confidentiality). Used in eDiscovery and document review workflows.' ;
    rdfs:domain ind:DocType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dmsFolderPathTemplate rdf:type rdf:Property ;
    rdfs:label 'Dms Folder Path Template' ;
    rdfs:comment 'Standard folder path template in the DMS for storing documents of this type (e.g., /Matters/{matter_id}/Agreements/{doc_type_code}, /Matters/{matter_id}/Pleadings/{doc_type_code}). Supports automated filing and retrieval.' ;
    rdfs:domain ind:DocType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:docTypeCategory rdf:type rdf:Property ;
    rdfs:label 'Doc Type Category' ;
    rdfs:comment 'High-level classification of the document type by legal practice area: transactional (contracts, agreements), litigation (pleadings, motions, briefs), intellectual property (patents, trademarks), corporate (resolutions, governance), regulatory (compliance filings), advisory (opinions, memos), administrative (engagement letters, billing). [ENUM-REF-CANDIDATE: transactional|litigation|ip|corporate|regulatory|advisory|administrative — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DocType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:docTypeCode rdf:type rdf:Property ;
    rdfs:label 'Doc Type Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the document type (e.g., NDA, SPA, POA, LOE, BRIEF, AFFIDAVIT). Used for system integration and DMS folder taxonomy.' ;
    rdfs:domain ind:DocType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:docTypeDescription rdf:type rdf:Property ;
    rdfs:label 'Doc Type Description' ;
    rdfs:comment 'Detailed description of the document type, including its purpose, typical use cases, key characteristics, and any special handling requirements. Provides guidance to attorneys and staff on when to use this classification.' ;
    rdfs:domain ind:DocType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:docTypeName rdf:type rdf:Property ;
    rdfs:label 'Doc Type Name' ;
    rdfs:comment 'Full descriptive name of the document type (e.g., Non-Disclosure Agreement, Share Purchase Agreement, Power of Attorney, Letter of Engagement, Pleading, Brief, Affidavit, Court Order, Patent Application, Trademark Filing, Board Resolution, Engagement Letter).' ;
    rdfs:domain ind:DocType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:docTypeStatus rdf:type rdf:Property ;
    rdfs:label 'Doc Type Status' ;
    rdfs:comment 'Current lifecycle status of this document type classification: active (in current use), deprecated (phased out but historical documents exist), archived (no longer used, retained for records), under_review (being evaluated for changes).' ;
    rdfs:domain ind:DocType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediscoveryReviewable rdf:type rdf:Property ;
    rdfs:label 'Ediscovery Reviewable' ;
    rdfs:comment 'Indicates whether documents of this type are subject to eDiscovery review and production in litigation (e.g., emails, contracts, memos are reviewable; attorney work product may be withheld). Used in Relativity TAR/CAL workflows.' ;
    rdfs:domain ind:DocType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:encryptionRequired rdf:type rdf:Property ;
    rdfs:label 'Encryption Required' ;
    rdfs:comment 'Indicates whether documents of this type must be encrypted at rest and in transit due to sensitivity (e.g., documents containing trade secrets, M&A deal documents, client financial information).' ;
    rdfs:domain ind:DocType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:endDate rdf:type rdf:Property ;
    rdfs:label 'End Date' ;
    rdfs:comment 'Date when this document type classification was deprecated or archived. Null for active document types.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:externalSharingAllowed rdf:type rdf:Property ;
    rdfs:label 'External Sharing Allowed' ;
    rdfs:comment 'Indicates whether documents of this type can be shared with external parties (clients, opposing counsel, courts) or are restricted to internal use only (e.g., internal strategy memos, conflict check results are internal-only).' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:matterAssociationRequired rdf:type rdf:Property ;
    rdfs:label 'Matter Association Required' ;
    rdfs:comment 'Indicates whether documents of this type must be associated with a specific client matter in the practice management system (Elite 3E). True for all client work product; false for firm-wide administrative documents.' ;
    rdfs:domain ind:DocType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:metadataPreservationCritical rdf:type rdf:Property ;
    rdfs:label 'Metadata Preservation Critical' ;
    rdfs:comment 'Indicates whether preservation of document metadata (author, creation date, modification history, email headers) is critical for legal or evidentiary purposes. True for ESI in litigation; false for routine business documents.' ;
    rdfs:domain ind:DocType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:namingConventionPattern rdf:type rdf:Property ;
    rdfs:label 'Naming Convention Pattern' ;
    rdfs:comment 'Standard naming pattern for documents of this type (e.g., {matter_number}_{doc_type_code}_{party_name}_{version}_{date}.docx). Ensures consistent document identification and version control.' ;
    rdfs:domain ind:DocType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nlpExtractionEnabled rdf:type rdf:Property ;
    rdfs:label 'Nlp Extraction Enabled' ;
    rdfs:comment 'Indicates whether documents of this type are processed through NLP pipelines to extract entities, clauses, obligations, dates, parties, and other structured metadata for contract analytics and legal AI applications.' ;
    rdfs:domain ind:DocType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ocrRequired rdf:type rdf:Property ;
    rdfs:label 'Ocr Required' ;
    rdfs:comment 'Indicates whether documents of this type require OCR processing to extract text from scanned images or PDFs for full-text search and NLP analysis.' ;
    rdfs:domain ind:DocType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:piiLikely rdf:type rdf:Property ;
    rdfs:label 'Pii Likely' ;
    rdfs:comment 'Indicates whether documents of this type are likely to contain PII requiring GDPR, CCPA, or other data privacy compliance measures (e.g., employment agreements, client intake forms contain PII; corporate resolutions typically do not).' ;
    rdfs:domain ind:DocType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:redactionProtocol rdf:type rdf:Property ;
    rdfs:label 'Redaction Protocol' ;
    rdfs:comment 'Level of redaction protocol required for documents of this type when produced in discovery or released publicly: none (no redaction needed), standard (redact PII and confidential business information per standard rules), enhanced (additional redaction for trade secrets, privileged content), custom (case-specific redaction rules apply).' ;
    rdfs:domain ind:DocType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresConflictCheck rdf:type rdf:Property ;
    rdfs:label 'Requires Conflict Check' ;
    rdfs:comment 'Indicates whether creation of documents of this type triggers a mandatory conflict check in Intapp Conflicts (e.g., engagement letters, new matter documents require conflict checks; routine correspondence does not).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresExecution rdf:type rdf:Property ;
    rdfs:label 'Requires Execution' ;
    rdfs:comment 'Indicates whether documents of this type require formal execution (signature, seal, notarization) to be legally binding. True for contracts, agreements, powers of attorney; false for internal memos, research notes, drafts.' ;
    rdfs:domain ind:DocType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresWitness rdf:type rdf:Property ;
    rdfs:label 'Requires Witness' ;
    rdfs:comment 'Indicates whether documents of this type require witness signatures for legal validity (e.g., wills, certain contracts).' ;
    rdfs:domain ind:DocType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:versionControlRequired rdf:type rdf:Property ;
    rdfs:label 'Version Control Required' ;
    rdfs:comment 'Indicates whether documents of this type must be tracked with formal version control in the DMS (major/minor version numbering, change tracking, approval workflows). True for contracts, agreements, policies; false for one-off correspondence.' ;
    rdfs:domain ind:DocType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:docFolderId rdf:type rdf:Property ;
    rdfs:label 'Doc Folder Id' ;
    rdfs:comment 'Unique identifier for the document folder within the Document Management System (DMS). Primary key for the doc_folder entity.' ;
    rdfs:domain ind:DocFolder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentFolderDocFolderId rdf:type rdf:Property ;
    rdfs:label 'Parent Folder Doc Folder Id' ;
    rdfs:comment 'Reference to the parent folder in the DMS hierarchy. Enables hierarchical folder structure traversal and nested workspace organization. Null for root-level folders.' ;
    rdfs:domain ind:DocFolder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DocFolder .

ind:retentionScheduleId rdf:type rdf:Property ;
    rdfs:label 'Retention Schedule Id' ;
    rdfs:comment 'Foreign key linking to document.retention_schedule. Business justification: DMS folders in iManage Work and NetDocuments are configured with retention policies that govern all documents within them. doc_folder has retention_policy_code (STRING) and retention_end_date, retenti' ;
    rdfs:domain ind:Document ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RetentionSchedule .

ind:accessControlGroup rdf:type rdf:Property ;
    rdfs:label 'Access Control Group' ;
    rdfs:comment 'Name or identifier of the security group that governs read/write/delete permissions for this folder. Typically maps to Active Directory groups or DMS-native security groups.' ;
    rdfs:domain ind:DocFolder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:archivedDate rdf:type rdf:Property ;
    rdfs:label 'Archived Date' ;
    rdfs:comment 'Date when the folder was moved to archive storage tier. Indicates transition from active to long-term retention storage with reduced access frequency.' ;
    rdfs:domain ind:DocFolder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditLogEnabled rdf:type rdf:Property ;
    rdfs:label 'Audit Log Enabled' ;
    rdfs:comment 'Indicates whether detailed access and modification audit logging is enabled for this folder. True when audit logging is active for compliance and security monitoring.' ;
    rdfs:domain ind:DocFolder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:collaborationEnabled rdf:type rdf:Property ;
    rdfs:label 'Collaboration Enabled' ;
    rdfs:comment 'Indicates whether real-time collaboration features (co-authoring, commenting, annotations) are enabled for documents in this folder. True when collaboration is active.' ;
    rdfs:domain ind:DocFolder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:confidentialityAgreementRequired rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Agreement Required' ;
    rdfs:comment 'Indicates whether users must acknowledge a Non-Disclosure Agreement (NDA) or confidentiality agreement before accessing this folder. True when NDA is required.' ;
    rdfs:domain ind:DocFolder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dmsSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Dms Source System' ;
    rdfs:comment 'Identifies the source DMS platform from which this folder metadata was ingested. Supports multi-DMS environments and data lineage tracking.' ;
    rdfs:domain ind:DocFolder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:docFolderDescription rdf:type rdf:Property ;
    rdfs:label 'Doc Folder Description' ;
    rdfs:comment 'Free-text description of the folders purpose, scope, or contents. Provides additional context for workspace identification and search.' ;
    rdfs:domain ind:DocFolder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentCount rdf:type rdf:Property ;
    rdfs:label 'Document Count' ;
    rdfs:comment 'Total number of documents currently stored within this folder, excluding subfolders. Used for capacity planning and workspace analytics.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:encryptionEnabled rdf:type rdf:Property ;
    rdfs:label 'Encryption Enabled' ;
    rdfs:comment 'Indicates whether documents in this folder are encrypted at rest and in transit. True when encryption is enforced per security classification requirements.' ;
    rdfs:domain ind:DocFolder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ethicalWallFlag rdf:type rdf:Property ;
    rdfs:label 'Ethical Wall Flag' ;
    rdfs:comment 'Indicates whether this folder is subject to an ethical wall (information barrier) to prevent conflicts of interest. True when ethical wall restrictions apply.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:folderName rdf:type rdf:Property ;
    rdfs:label 'Folder Name' ;
    rdfs:comment 'Human-readable name of the folder as displayed in the DMS. Typically reflects the matter name, document category, or organizational purpose.' ;
    rdfs:domain ind:DocFolder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:folderPath rdf:type rdf:Property ;
    rdfs:label 'Folder Path' ;
    rdfs:comment 'Full hierarchical path from root to this folder, typically in forward-slash notation (e.g., /Client/Matter/Correspondence). Enables breadcrumb navigation and path-based search.' ;
    rdfs:domain ind:DocFolder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:folderStatus rdf:type rdf:Property ;
    rdfs:label 'Folder Status' ;
    rdfs:comment 'Current lifecycle status of the folder. Active folders are in use, closed folders are complete but retained, archived folders are moved to long-term storage, suspended folders are temporarily inactive, and pending_deletion folders are marked for removal.' ;
    rdfs:domain ind:DocFolder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:folderType rdf:type rdf:Property ;
    rdfs:label 'Folder Type' ;
    rdfs:comment 'Classification of the folder purpose within the DMS. Distinguishes between matter workspaces, client-level folders, project folders, administrative containers, templates, and archived workspaces.' ;
    rdfs:domain ind:DocFolder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAccessedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Accessed Timestamp' ;
    rdfs:comment 'Date and time when any document within this folder was last accessed by any user. Used for inactive workspace identification and archival candidate analysis.' ;
    rdfs:domain ind:DocFolder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:legalHoldReference rdf:type rdf:Property ;
    rdfs:label 'Legal Hold Reference' ;
    rdfs:comment 'Reference number or identifier of the legal hold order or litigation matter requiring preservation of this folder. Populated when legal_hold_flag is true.' ;
    rdfs:domain ind:DocFolder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerUserCode rdf:type rdf:Property ;
    rdfs:label 'Owner User Code' ;
    rdfs:comment 'User identifier of the folder owner or primary responsible attorney. Typically the matter partner or lead counsel with administrative rights over the workspace.' ;
    rdfs:domain ind:DocFolder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentHierarchy rdf:type rdf:Property ;
    rdfs:label 'Parent Hierarchy' ;
    rdfs:comment 'FK to document.doc_folder.doc_folder_id — Folders have a parent-child hierarchy (workspace > client > matter > subfolder). Self-referential FK required for hierarchy traversal and access inheritance.' ;
    rdfs:domain ind:DocFolder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:retentionStartDate rdf:type rdf:Property ;
    rdfs:label 'Retention Start Date' ;
    rdfs:comment 'Date from which the retention period begins, typically the matter close date or document finalization date. Used to calculate disposition eligibility.' ;
    rdfs:domain ind:DocFolder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:securityClassification rdf:type rdf:Property ;
    rdfs:label 'Security Classification' ;
    rdfs:comment 'Data classification level governing access and handling requirements for all documents within this folder. Privileged designation indicates Legal Professional Privilege (LPP) protection.' ;
    rdfs:domain ind:DocFolder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subfolderCount rdf:type rdf:Property ;
    rdfs:label 'Subfolder Count' ;
    rdfs:comment 'Total number of immediate child folders within this folder. Used for hierarchy depth analysis and navigation optimization.' ;
    rdfs:domain ind:DocFolder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:syncEnabled rdf:type rdf:Property ;
    rdfs:label 'Sync Enabled' ;
    rdfs:comment 'Indicates whether this folder is enabled for offline synchronization or desktop sync in the DMS client application. True when sync is enabled.' ;
    rdfs:domain ind:DocFolder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalStorageBytes rdf:type rdf:Property ;
    rdfs:label 'Total Storage Bytes' ;
    rdfs:comment 'Total storage size in bytes consumed by all documents within this folder, excluding subfolders. Used for storage capacity management and billing allocation.' ;
    rdfs:domain ind:DocFolder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:versionControlEnabled rdf:type rdf:Property ;
    rdfs:label 'Version Control Enabled' ;
    rdfs:comment 'Indicates whether document version control and check-in/check-out workflows are enforced for documents in this folder. True when version control is active.' ;
    rdfs:domain ind:DocFolder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workspaceTemplateCode rdf:type rdf:Property ;
    rdfs:label 'Workspace Template Code' ;
    rdfs:comment 'Code identifying the template used to provision this workspace or folder structure. Enables standardized folder hierarchies for matter types (e.g., M&A, Litigation, IP).' ;
    rdfs:domain ind:DocFolder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esiCollectionId rdf:type rdf:Property ;
    rdfs:label 'Esi Collection Id' ;
    rdfs:comment 'Foreign key linking to document.esi_collection. Business justification: Review assignments in eDiscovery workflows (Relativity) are scoped to specific ESI collection events. A doc_review_assignment is the work product of reviewing documents gathered in an esi_collection. ' ;
    rdfs:domain ind:Document ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EsiCollection .

ind:legalHoldId rdf:type rdf:Property ;
    rdfs:label 'Legal Hold Id' ;
    rdfs:comment 'Foreign key linking to document.legal_hold. Business justification: In litigation eDiscovery workflows, review assignments are triggered by and scoped to specific legal holds. Knowing which legal hold initiated a review assignment is operationally critical for complia' ;
    rdfs:domain ind:Document ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalHold .

ind:annotationCount rdf:type rdf:Property ;
    rdfs:label 'Annotation Count' ;
    rdfs:comment 'Total number of annotations (highlights, comments, notes) added by the reviewer to the document.' ;
    rdfs:domain ind:DocReviewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignmentMethod rdf:type rdf:Property ;
    rdfs:label 'Assignment Method' ;
    rdfs:comment 'Method by which the document was assigned to the reviewer, indicating whether assignment was manual, automated by workflow rules, or balanced by workload distribution algorithm.' ;
    rdfs:domain ind:DocReviewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assignment Timestamp' ;
    rdfs:comment 'Precise timestamp when the document review assignment was created and assigned to the reviewer.' ;
    rdfs:domain ind:DocReviewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:calFeedbackFlag rdf:type rdf:Property ;
    rdfs:label 'Cal Feedback Flag' ;
    rdfs:comment 'Indicates whether this review assignment was used as feedback to train or refine the CAL predictive coding model.' ;
    rdfs:domain ind:DocReviewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:confidentialityDesignation rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Designation' ;
    rdfs:comment 'Confidentiality level assigned to the document during review, typically governed by protective order terms.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:custodianName rdf:type rdf:Property ;
    rdfs:label 'Custodian Name' ;
    rdfs:comment 'Name of the document custodian (the individual or entity from whose files the document was collected), used for ESI provenance tracking.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issueTags rdf:type rdf:Property ;
    rdfs:label 'Issue Tags' ;
    rdfs:comment 'Comma-separated list of issue codes or tags applied by the reviewer to categorize the document by legal issue, topic, or relevance area.' ;
    rdfs:domain ind:DocReviewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:privilegeType rdf:type rdf:Property ;
    rdfs:label 'Privilege Type' ;
    rdfs:comment 'Type of legal privilege asserted if the document is coded as privileged, used for privilege log compilation.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redactionCount rdf:type rdf:Property ;
    rdfs:label 'Redaction Count' ;
    rdfs:comment 'Number of redactions applied to the document during review.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:redactionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Redaction Required Flag' ;
    rdfs:comment 'Indicates whether the document requires redaction of sensitive information (PII, trade secrets, privileged content) before production.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:relevanceScore rdf:type rdf:Property ;
    rdfs:label 'Relevance Score' ;
    rdfs:comment 'Predictive coding relevance score assigned by the TAR or CAL model, ranging from 0 to 1, indicating the likelihood that the document is responsive.' ;
    rdfs:domain ind:DocReviewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reviewCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Review Completion Timestamp' ;
    rdfs:comment 'Timestamp when the reviewer completed the review and submitted their coding decision.' ;
    rdfs:domain ind:DocReviewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reviewDecision rdf:type rdf:Property ;
    rdfs:label 'Review Decision' ;
    rdfs:comment 'Primary coding decision made by the reviewer indicating whether the document is responsive to the discovery request, non-responsive, or subject to privilege.' ;
    rdfs:domain ind:DocReviewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Review Duration Minutes' ;
    rdfs:comment 'Total time in minutes spent by the reviewer on this document, used for throughput analysis and quality control.' ;
    rdfs:domain ind:DocReviewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reviewPriority rdf:type rdf:Property ;
    rdfs:label 'Review Priority' ;
    rdfs:comment 'Priority level assigned to the review assignment, used for workload management and deadline adherence.' ;
    rdfs:domain ind:DocReviewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Review Start Timestamp' ;
    rdfs:comment 'Timestamp when the reviewer first opened or began reviewing the document.' ;
    rdfs:domain ind:DocReviewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reviewType rdf:type rdf:Property ;
    rdfs:label 'Review Type' ;
    rdfs:comment 'Type or purpose of the review assignment, distinguishing between first-pass review, quality control, privilege review, hot document flagging, or ad-hoc collaborative annotation.' ;
    rdfs:domain ind:DocReviewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewerComments rdf:type rdf:Property ;
    rdfs:label 'Reviewer Comments' ;
    rdfs:comment 'Free-text comments or notes entered by the reviewer to explain coding decisions, flag issues, or provide context for second-level review.' ;
    rdfs:domain ind:DocReviewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondLevelReviewDecision rdf:type rdf:Property ;
    rdfs:label 'Second Level Review Decision' ;
    rdfs:comment 'Decision made by the second-level reviewer, indicating whether the initial review decision was confirmed, overridden, or escalated for further review.' ;
    rdfs:domain ind:DocReviewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondLevelReviewRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Second Level Review Required Flag' ;
    rdfs:comment 'Indicates whether the document requires a second-level or senior attorney review for quality control or privilege validation.' ;
    rdfs:domain ind:DocReviewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:secondLevelReviewTimestamp rdf:type rdf:Property ;
    rdfs:label 'Second Level Review Timestamp' ;
    rdfs:comment 'Timestamp when the second-level review was completed.' ;
    rdfs:domain ind:DocReviewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:tarModelRound rdf:type rdf:Property ;
    rdfs:label 'Tar Model Round' ;
    rdfs:comment 'The TAR or CAL model training round during which this document was reviewed, used to track continuous active learning feedback cycles.' ;
    rdfs:domain ind:DocReviewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:privilegeLogId rdf:type rdf:Property ;
    rdfs:label 'Privilege Log Id' ;
    rdfs:comment 'Unique identifier for the privilege log entry. Primary key.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PrivilegeLog .

ind:primaryPrivilegeLegalDocumentId rdf:type rdf:Property ;
    rdfs:label 'Primary Privilege Legal Document Id' ;
    rdfs:comment 'Reference to the document for which privilege is being asserted. Links to the document master record in the DMS (iManage Work or NetDocuments).' ;
    rdfs:domain ind:PrivilegeLog ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalDocument .

ind:privilegeLegalDocumentId rdf:type rdf:Property ;
    rdfs:label 'Privilege Legal Document Id' ;
    rdfs:comment 'FK to document.legal_document.legal_document_id — Privilege designations are applied to specific documents. This FK enables privilege status lookup per document and privilege log generation for productions.' ;
    rdfs:domain ind:PrivilegeLog ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalDocument .

ind:authorName rdf:type rdf:Property ;
    rdfs:label 'Author Name' ;
    rdfs:comment 'The name of the person who authored or created the privileged document. May be an attorney, client representative, or other party.' ;
    rdfs:domain ind:PrivilegeLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:challengeDate rdf:type rdf:Property ;
    rdfs:label 'Challenge Date' ;
    rdfs:comment 'The date on which the privilege assertion was challenged by opposing counsel or the court. Null if unchallenged.' ;
    rdfs:domain ind:PrivilegeLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:challengeNotes rdf:type rdf:Property ;
    rdfs:label 'Challenge Notes' ;
    rdfs:comment 'Free-text notes describing the nature of the privilege challenge, arguments made, and the outcome or current status.' ;
    rdfs:domain ind:PrivilegeLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:challengeResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Challenge Resolution Date' ;
    rdfs:comment 'The date on which a privilege challenge was resolved by the court or through agreement. Null if challenge is pending or no challenge occurred.' ;
    rdfs:domain ind:PrivilegeLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:challengeStatus rdf:type rdf:Property ;
    rdfs:label 'Challenge Status' ;
    rdfs:comment 'Indicates whether the privilege assertion has been challenged by opposing counsel or the court, and the outcome of any challenge.' ;
    rdfs:domain ind:PrivilegeLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clawbackDate rdf:type rdf:Property ;
    rdfs:label 'Clawback Date' ;
    rdfs:comment 'The date on which a clawback request was made to opposing counsel or the court. Null if no clawback has been requested.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clawbackRequested rdf:type rdf:Property ;
    rdfs:label 'Clawback Requested' ;
    rdfs:comment 'Indicates whether a clawback (return of inadvertently disclosed privileged document) has been requested under Federal Rule of Evidence 502(b) or similar provisions.' ;
    rdfs:domain ind:PrivilegeLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clawbackStatus rdf:type rdf:Property ;
    rdfs:label 'Clawback Status' ;
    rdfs:comment 'The current status of the clawback request. Indicates whether the request was granted, denied, or is still pending.' ;
    rdfs:domain ind:PrivilegeLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designationDate rdf:type rdf:Property ;
    rdfs:label 'Designation Date' ;
    rdfs:comment 'The date on which the privilege designation was applied to the document.' ;
    rdfs:domain ind:PrivilegeLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:designationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Designation Timestamp' ;
    rdfs:comment 'The precise timestamp when the privilege designation was recorded in the system.' ;
    rdfs:domain ind:PrivilegeLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:documentDate rdf:type rdf:Property ;
    rdfs:label 'Document Date' ;
    rdfs:comment 'The date the privileged document was created or executed. Critical metadata for privilege log submissions.' ;
    rdfs:domain ind:PrivilegeLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentDescription rdf:type rdf:Property ;
    rdfs:label 'Document Description' ;
    rdfs:comment 'A brief, non-privileged description of the document sufficient to identify it without waiving privilege. Required for privilege log submissions to courts.' ;
    rdfs:domain ind:PrivilegeLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentTitle rdf:type rdf:Property ;
    rdfs:label 'Document Title' ;
    rdfs:comment 'The title or name of the privileged document as it appears in the DMS. Used for identification in privilege logs submitted to courts or opposing counsel.' ;
    rdfs:domain ind:PrivilegeLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lppClassification rdf:type rdf:Property ;
    rdfs:label 'Lpp Classification' ;
    rdfs:comment 'Classification of the document under Legal Professional Privilege (LPP) framework, primarily applicable in UK and Commonwealth jurisdictions. Distinguishes between advice privilege and litigation privilege.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:privilegeBasis rdf:type rdf:Property ;
    rdfs:label 'Privilege Basis' ;
    rdfs:comment 'Detailed explanation of the legal basis and rationale for asserting privilege over this document. Describes why the document qualifies for the claimed privilege type.' ;
    rdfs:domain ind:PrivilegeLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionStatus rdf:type rdf:Property ;
    rdfs:label 'Production Status' ;
    rdfs:comment 'The status of the document in the eDiscovery production workflow. Indicates whether the document was withheld on privilege grounds, produced with redactions, or produced without redactions.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientNames rdf:type rdf:Property ;
    rdfs:label 'Recipient Names' ;
    rdfs:comment 'Comma-separated list of recipients to whom the privileged document was sent or distributed. Used to establish the scope of confidential communication.' ;
    rdfs:domain ind:PrivilegeLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redactionStatus rdf:type rdf:Property ;
    rdfs:label 'Redaction Status' ;
    rdfs:comment 'Indicates whether the document has been redacted for production. Fully redacted or withheld documents are not produced; partially redacted documents are produced with privileged portions removed.' ;
    rdfs:domain ind:PrivilegeLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionHold rdf:type rdf:Property ;
    rdfs:label 'Retention Hold' ;
    rdfs:comment 'Indicates whether the document is subject to a litigation hold or records retention hold, preventing destruction or alteration.' ;
    rdfs:domain ind:PrivilegeLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fromEsiCustodianId rdf:type rdf:Property ;
    rdfs:label 'From Esi Custodian Id' ;
    rdfs:comment 'FK to document.esi_custodian.esi_custodian_id — Collections are executed against specific custodians. This FK enables custodian-level collection tracking, volume reporting, and defensibility documentation.' ;
    rdfs:domain ind:EsiCollection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EsiCustodian .

ind:holdId rdf:type rdf:Property ;
    rdfs:label 'Hold Id' ;
    rdfs:comment 'Foreign key linking to matter.hold. Business justification: ESI collections are executed under specific litigation holds. Linking collection to the originating matter hold demonstrates preservation compliance and chain of custody required in discovery. esi_col' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Hold .

ind:primaryEsiCustodianId rdf:type rdf:Property ;
    rdfs:label 'Primary Esi Custodian Id' ;
    rdfs:comment 'Foreign key linking to document.esi_custodian. Business justification: esi_collection has custodian_name, custodian_email, custodian_employee_id, custodian_department (all strings, denormalized). esi_custodian is the master custodian record. One collection is FROM one cu' ;
    rdfs:domain ind:EsiCollection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EsiCustodian .

ind:toEsiCustodianId rdf:type rdf:Property ;
    rdfs:label 'To Esi Custodian Id' ;
    rdfs:comment 'FK to document.esi_custodian.esi_custodian_id — Collections are executed against specific custodians. The esi_collection description explicitly references custodian identity as a core attribute. This FK is essential for defensible collection tracki' ;
    rdfs:domain ind:EsiCollection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EsiCustodian .

ind:chainOfCustodyHash rdf:type rdf:Property ;
    rdfs:label 'Chain Of Custody Hash' ;
    rdfs:comment 'Cryptographic hash value (e.g., MD5, SHA-256) computed at collection time to ensure data integrity and establish chain of custody.' ;
    rdfs:domain ind:EsiCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionCostAmount rdf:type rdf:Property ;
    rdfs:label 'Collection Cost Amount' ;
    rdfs:comment 'Total cost incurred for this ESI collection event, including vendor fees, labor, and technology costs.' ;
    rdfs:domain ind:EsiCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collectionCostCurrency rdf:type rdf:Property ;
    rdfs:label 'Collection Cost Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the collection cost amount.' ;
    rdfs:domain ind:EsiCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionEndDate rdf:type rdf:Property ;
    rdfs:label 'Collection End Date' ;
    rdfs:comment 'Date on which the ESI collection activity was completed or terminated.' ;
    rdfs:domain ind:EsiCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:collectionMethod rdf:type rdf:Property ;
    rdfs:label 'Collection Method' ;
    rdfs:comment 'Detailed description of the technical method or tool used to perform the collection (e.g., Relativity Collect, EnCase, FTK Imager).' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionName rdf:type rdf:Property ;
    rdfs:label 'Collection Name' ;
    rdfs:comment 'Business-friendly name or label assigned to this ESI collection event for identification and tracking purposes.' ;
    rdfs:domain ind:EsiCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionNotes rdf:type rdf:Property ;
    rdfs:label 'Collection Notes' ;
    rdfs:comment 'Free-text notes documenting any issues, observations, or special circumstances encountered during the collection process.' ;
    rdfs:domain ind:EsiCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionNumber rdf:type rdf:Property ;
    rdfs:label 'Collection Number' ;
    rdfs:comment 'Externally-known unique identifier or reference number for this ESI collection, often used in legal filings and correspondence.' ;
    rdfs:domain ind:EsiCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionScopeDescription rdf:type rdf:Property ;
    rdfs:label 'Collection Scope Description' ;
    rdfs:comment 'Detailed narrative description of the scope, parameters, and boundaries of the ESI collection (e.g., search terms, file types, folders included/excluded).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionStartDate rdf:type rdf:Property ;
    rdfs:label 'Collection Start Date' ;
    rdfs:comment 'Date on which the ESI collection activity commenced.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:collectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Collection Timestamp' ;
    rdfs:comment 'Precise date and time when the ESI collection event was executed. Principal business event timestamp.' ;
    rdfs:domain ind:EsiCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:collectionToolName rdf:type rdf:Property ;
    rdfs:label 'Collection Tool Name' ;
    rdfs:comment 'Name of the software tool or platform used to perform the ESI collection (e.g., Relativity Collect, Nuix, Exterro).' ;
    rdfs:domain ind:EsiCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionToolVersion rdf:type rdf:Property ;
    rdfs:label 'Collection Tool Version' ;
    rdfs:comment 'Version number of the collection tool used, important for reproducibility and defensibility.' ;
    rdfs:domain ind:EsiCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionType rdf:type rdf:Property ;
    rdfs:label 'Collection Type' ;
    rdfs:comment 'Classification of the collection method used to acquire the ESI.' ;
    rdfs:domain ind:EsiCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectorName rdf:type rdf:Property ;
    rdfs:label 'Collector Name' ;
    rdfs:comment 'Full name of the individual or team member who performed the ESI collection.' ;
    rdfs:domain ind:EsiCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSourceLocation rdf:type rdf:Property ;
    rdfs:label 'Data Source Location' ;
    rdfs:comment 'Physical or logical location of the data source (e.g., server name, file path, cloud tenant, device serial number).' ;
    rdfs:domain ind:EsiCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSourceType rdf:type rdf:Property ;
    rdfs:label 'Data Source Type' ;
    rdfs:comment 'Category of data source from which ESI was collected (e.g., email, file share, cloud storage, mobile device, database, social media).' ;
    rdfs:domain ind:EsiCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dateRangeEnd rdf:type rdf:Property ;
    rdfs:label 'Date Range End' ;
    rdfs:comment 'End date of the custodial data date range targeted for collection (e.g., collect all emails up to this date).' ;
    rdfs:domain ind:EsiCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dateRangeStart rdf:type rdf:Property ;
    rdfs:label 'Date Range Start' ;
    rdfs:comment 'Start date of the custodial data date range targeted for collection (e.g., collect all emails from this date forward).' ;
    rdfs:domain ind:EsiCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deduplicationApplied rdf:type rdf:Property ;
    rdfs:label 'Deduplication Applied' ;
    rdfs:comment 'Indicates whether deduplication was applied during or after the collection process to remove duplicate items.' ;
    rdfs:domain ind:EsiCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:encryptionDetected rdf:type rdf:Property ;
    rdfs:label 'Encryption Detected' ;
    rdfs:comment 'Indicates whether encrypted files or data were detected during the collection process.' ;
    rdfs:domain ind:EsiCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hashAlgorithm rdf:type rdf:Property ;
    rdfs:label 'Hash Algorithm' ;
    rdfs:comment 'Cryptographic hash algorithm used to generate the chain of custody hash value.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passwordProtectedItemsCount rdf:type rdf:Property ;
    rdfs:label 'Password Protected Items Count' ;
    rdfs:comment 'Count of items that were found to be password-protected or encrypted during collection.' ;
    rdfs:domain ind:EsiCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preservationNoticeDate rdf:type rdf:Property ;
    rdfs:label 'Preservation Notice Date' ;
    rdfs:comment 'Date on which the legal hold or preservation notice was issued to the custodian.' ;
    rdfs:domain ind:EsiCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preservationNoticeIssued rdf:type rdf:Property ;
    rdfs:label 'Preservation Notice Issued' ;
    rdfs:comment 'Indicates whether a legal hold or preservation notice was issued to the custodian prior to collection.' ;
    rdfs:domain ind:EsiCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:privilegeReviewRequired rdf:type rdf:Property ;
    rdfs:label 'Privilege Review Required' ;
    rdfs:comment 'Indicates whether the collected ESI requires privilege review to identify and protect attorney-client privileged or work product materials.' ;
    rdfs:domain ind:EsiCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productionEligible rdf:type rdf:Property ;
    rdfs:label 'Production Eligible' ;
    rdfs:comment 'Indicates whether the collected ESI is eligible for production to opposing counsel or regulatory authorities.' ;
    rdfs:domain ind:EsiCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:relativityWorkspaceReference rdf:type rdf:Property ;
    rdfs:label 'Relativity Workspace Reference' ;
    rdfs:comment 'Identifier of the Relativity workspace into which the collected ESI was loaded for review and analysis.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalItemsCollected rdf:type rdf:Property ;
    rdfs:label 'Total Items Collected' ;
    rdfs:comment 'Total count of individual items (documents, emails, files, records) collected during this ESI collection event.' ;
    rdfs:domain ind:EsiCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalSizeBytes rdf:type rdf:Property ;
    rdfs:label 'Total Size Bytes' ;
    rdfs:comment 'Total size of all collected ESI measured in bytes.' ;
    rdfs:domain ind:EsiCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalSizeGb rdf:type rdf:Property ;
    rdfs:label 'Total Size Gb' ;
    rdfs:comment 'Total size of all collected ESI measured in gigabytes for human-readable reporting.' ;
    rdfs:domain ind:EsiCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:esiCustodianId rdf:type rdf:Property ;
    rdfs:label 'Esi Custodian Id' ;
    rdfs:comment 'Unique identifier for the ESI custodian record. Primary key.' ;
    rdfs:domain ind:EsiCustodian ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:custodianOrganisationId rdf:type rdf:Property ;
    rdfs:label 'Custodian Organisation Id' ;
    rdfs:comment 'Foreign key linking to client.organisation. Business justification: E-discovery collection scoping requires identifying which client organisation the custodian belongs to. custodian_organization is a denormalized text field; a proper FK enables collection authorisatio' ;
    rdfs:domain ind:EsiCustodian ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Organisation .

ind:chainOfCustodyVerified rdf:type rdf:Property ;
    rdfs:label 'Chain Of Custody Verified' ;
    rdfs:comment 'Indicates whether the chain of custody for the custodian\'s ESI collection has been verified and documented to ensure defensibility and admissibility.' ;
    rdfs:domain ind:EsiCustodian ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:collectionCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Collection Completion Date' ;
    rdfs:comment 'Date on which ESI collection activities were completed for this custodian.' ;
    rdfs:domain ind:EsiCustodian ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:collectionFileCount rdf:type rdf:Property ;
    rdfs:label 'Collection File Count' ;
    rdfs:comment 'Total number of files and documents collected from this custodian\'s data sources.' ;
    rdfs:domain ind:EsiCustodian ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:collectionVolumeGb rdf:type rdf:Property ;
    rdfs:label 'Collection Volume Gb' ;
    rdfs:comment 'Total volume of ESI collected from this custodian, measured in gigabytes.' ;
    rdfs:domain ind:EsiCustodian ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:custodianActiveFlag rdf:type rdf:Property ;
    rdfs:label 'Custodian Active Flag' ;
    rdfs:comment 'Indicates whether the custodian is currently an active employee or affiliated party with the organization.' ;
    rdfs:domain ind:EsiCustodian ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:custodianDepartment rdf:type rdf:Property ;
    rdfs:label 'Custodian Department' ;
    rdfs:comment 'Business unit or department to which the custodian belongs (e.g., Corporate Legal, Litigation, Compliance, Finance).' ;
    rdfs:domain ind:EsiCustodian ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:custodianDepartureDate rdf:type rdf:Property ;
    rdfs:label 'Custodian Departure Date' ;
    rdfs:comment 'Date on which the custodian departed the organization (termination, resignation, retirement), triggering expedited collection requirements.' ;
    rdfs:domain ind:EsiCustodian ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:custodianEmail rdf:type rdf:Property ;
    rdfs:label 'Custodian Email' ;
    rdfs:comment 'Primary email address of the custodian, used for legal hold notifications and collection coordination.' ;
    rdfs:domain ind:EsiCustodian ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:custodianFullName rdf:type rdf:Property ;
    rdfs:label 'Custodian Full Name' ;
    rdfs:comment 'Full legal name of the individual or entity whose electronically stored information is subject to preservation and collection.' ;
    rdfs:domain ind:EsiCustodian ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:custodianRole rdf:type rdf:Property ;
    rdfs:label 'Custodian Role' ;
    rdfs:comment 'Job title or functional role of the custodian at the time of legal hold issuance (e.g., Senior Associate, Paralegal, General Counsel, IT Administrator).' ;
    rdfs:domain ind:EsiCustodian ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:custodianStatus rdf:type rdf:Property ;
    rdfs:label 'Custodian Status' ;
    rdfs:comment 'Current lifecycle status of the custodian in the legal hold and collection workflow. [ENUM-REF-CANDIDATE: identified|notified|acknowledged|interviewed|collection_in_progress|collection_complete|released — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:EsiCustodian ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:custodianType rdf:type rdf:Property ;
    rdfs:label 'Custodian Type' ;
    rdfs:comment 'Classification of the custodian based on relevance and data volume: key (high relevance, decision-maker), standard (moderate relevance), peripheral (low relevance), third_party (external), non_employee (contractor, consultant).' ;
    rdfs:domain ind:EsiCustodian ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataResidencyCountry rdf:type rdf:Property ;
    rdfs:label 'Data Residency Country' ;
    rdfs:comment 'Three-letter ISO country code indicating the primary geographic location where the custodian\'s ESI resides (e.g., USA, GBR, DEU).' ;
    rdfs:domain ind:EsiCustodian ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSourcesCloudStorage rdf:type rdf:Property ;
    rdfs:label 'Data Sources Cloud Storage' ;
    rdfs:comment 'Comma-separated list of cloud storage platforms and accounts used by the custodian (e.g., OneDrive, SharePoint, Dropbox, Google Drive, Box).' ;
    rdfs:domain ind:EsiCustodian ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSourcesCollaborationTools rdf:type rdf:Property ;
    rdfs:label 'Data Sources Collaboration Tools' ;
    rdfs:comment 'Comma-separated list of collaboration and messaging platforms used by the custodian (e.g., Microsoft Teams, Slack, Zoom, WebEx).' ;
    rdfs:domain ind:EsiCustodian ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSourcesEmail rdf:type rdf:Property ;
    rdfs:label 'Data Sources Email' ;
    rdfs:comment 'Comma-separated list of email systems and accounts held by the custodian (e.g., Exchange, Gmail, Outlook PST files, archived mailboxes).' ;
    rdfs:domain ind:EsiCustodian ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSourcesFileShares rdf:type rdf:Property ;
    rdfs:label 'Data Sources File Shares' ;
    rdfs:comment 'Comma-separated list of network file shares, shared drives, and document repositories accessible to the custodian (e.g., departmental drives, project folders).' ;
    rdfs:domain ind:EsiCustodian ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSourcesLocalDrives rdf:type rdf:Property ;
    rdfs:label 'Data Sources Local Drives' ;
    rdfs:comment 'Comma-separated list of local hard drives, laptops, desktops, and removable media held by the custodian (e.g., C: drive, external USB drives).' ;
    rdfs:domain ind:EsiCustodian ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSourcesMobileDevices rdf:type rdf:Property ;
    rdfs:label 'Data Sources Mobile Devices' ;
    rdfs:comment 'Comma-separated list of mobile devices issued to or used by the custodian (e.g., iPhone, Android, tablet, device serial numbers).' ;
    rdfs:domain ind:EsiCustodian ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSourcesOther rdf:type rdf:Property ;
    rdfs:label 'Data Sources Other' ;
    rdfs:comment 'Additional or specialized data sources not covered by standard categories (e.g., social media accounts, CRM systems, proprietary applications).' ;
    rdfs:domain ind:EsiCustodian ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprDataSubjectFlag rdf:type rdf:Property ;
    rdfs:label 'Gdpr Data Subject Flag' ;
    rdfs:comment 'Indicates whether the custodian is an EU/EEA data subject whose personal data is subject to GDPR protections and cross-border transfer restrictions.' ;
    rdfs:domain ind:EsiCustodian ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalEsiCustodianId rdf:type rdf:Property ;
    rdfs:label 'Legal Esi Custodian Id' ;
    rdfs:comment 'FK to document.esi_custodian.esi_custodian_id — Legal holds are issued to specific custodians. This FK enables hold compliance tracking per custodian and defensible preservation documentation.' ;
    rdfs:domain ind:LegalHold ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EsiCustodian .

ind:primaryLegalEsiCustodianId rdf:type rdf:Property ;
    rdfs:label 'Primary Legal Esi Custodian Id' ;
    rdfs:comment 'FK to document.esi_custodian.esi_custodian_id — Legal holds are issued to custodians. The hold-custodian relationship is the core operational link for preservation obligations. Without it, hold compliance tracking is impossible.' ;
    rdfs:domain ind:LegalHold ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EsiCustodian .

ind:acknowledgedCount rdf:type rdf:Property ;
    rdfs:label 'Acknowledged Count' ;
    rdfs:comment 'Number of custodians who have formally acknowledged receipt and understanding of the legal hold notice and their preservation obligations.' ;
    rdfs:domain ind:LegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceMonitoringFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Monitoring Flag' ;
    rdfs:comment 'Indicates whether active compliance monitoring and auditing is in place to verify custodians are adhering to preservation obligations. True means monitoring is active; False means passive hold only.' ;
    rdfs:domain ind:LegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:custodianCount rdf:type rdf:Property ;
    rdfs:label 'Custodian Count' ;
    rdfs:comment 'Total number of custodians (individuals or entities) to whom the legal hold notice has been issued and who are under preservation obligation.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataSourcesInScope rdf:type rdf:Property ;
    rdfs:label 'Data Sources In Scope' ;
    rdfs:comment 'Description of data sources and systems from which ESI must be preserved, including email servers, file shares, DMS repositories, collaboration platforms, mobile devices, cloud storage, and backup tapes.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentTypesInScope rdf:type rdf:Property ;
    rdfs:label 'Document Types In Scope' ;
    rdfs:comment 'Comma-separated or structured list of document types and ESI categories included in the preservation scope, such as emails, contracts, spreadsheets, presentations, instant messages, voicemails, databases, and physical files.' ;
    rdfs:domain ind:LegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediscoveryCollectionInitiatedFlag rdf:type rdf:Property ;
    rdfs:label 'Ediscovery Collection Initiated Flag' ;
    rdfs:comment 'Indicates whether forensic or eDiscovery collection of ESI has been initiated for custodians under this legal hold. True means collection has started; False means preservation only.' ;
    rdfs:domain ind:LegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalationCount rdf:type rdf:Property ;
    rdfs:label 'Escalation Count' ;
    rdfs:comment 'Number of times the legal hold notice has been escalated or re-sent to non-responsive custodians or management for enforcement.' ;
    rdfs:domain ind:LegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:holdName rdf:type rdf:Property ;
    rdfs:label 'Hold Name' ;
    rdfs:comment 'Descriptive name or title of the legal hold, typically referencing the matter name or subject of the litigation or investigation.' ;
    rdfs:domain ind:LegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdNumber rdf:type rdf:Property ;
    rdfs:label 'Hold Number' ;
    rdfs:comment 'Business-facing unique identifier or reference number for the legal hold notice, often used in communications with custodians and counsel.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdStatus rdf:type rdf:Property ;
    rdfs:label 'Hold Status' ;
    rdfs:comment 'Current lifecycle status of the legal hold. Draft indicates preparation; Active indicates custodians are under preservation obligation; Suspended indicates temporary pause; Released indicates hold has been lifted; Expired indicates hold ended by time limit.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReminderSentDate rdf:type rdf:Property ;
    rdfs:label 'Last Reminder Sent Date' ;
    rdfs:comment 'Date on which the most recent reminder notice was sent to custodians under this legal hold.' ;
    rdfs:domain ind:LegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preservationEndDate rdf:type rdf:Property ;
    rdfs:label 'Preservation End Date' ;
    rdfs:comment 'Latest date through which documents and ESI must be preserved under the legal hold. Defines the end of the temporal scope of preservation. Nullable for ongoing matters.' ;
    rdfs:domain ind:LegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preservationStartDate rdf:type rdf:Property ;
    rdfs:label 'Preservation Start Date' ;
    rdfs:comment 'Earliest date from which documents and ESI must be preserved under the legal hold. Defines the beginning of the temporal scope of preservation.' ;
    rdfs:domain ind:LegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:privilegeDesignationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Privilege Designation Required Flag' ;
    rdfs:comment 'Indicates whether documents preserved under this legal hold must be reviewed and designated for legal professional privilege (LPP) or attorney-client privilege before production. True means privilege review is required; False means no privilege review needed.' ;
    rdfs:domain ind:LegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:releaseDate rdf:type rdf:Property ;
    rdfs:label 'Release Date' ;
    rdfs:comment 'Date on which the legal hold was formally released and custodians were notified that preservation obligations have ended. Nullable if hold is still active.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:releaseReason rdf:type rdf:Property ;
    rdfs:label 'Release Reason' ;
    rdfs:comment 'Explanation or justification for releasing the legal hold, such as matter settlement, case dismissal, statute of limitations expiration, or completion of regulatory investigation.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reminderFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Reminder Frequency Days' ;
    rdfs:comment 'Number of days between automated reminder notices sent to custodians to reinforce their ongoing preservation obligations under the legal hold.' ;
    rdfs:domain ind:LegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:spoliationRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Spoliation Risk Level' ;
    rdfs:comment 'Assessment of the risk that relevant ESI or documents may be destroyed, altered, or lost in violation of the legal hold, potentially resulting in sanctions or adverse inference. Low indicates strong compliance; Critical indicates imminent risk of spoliation.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suspensionOfDestructionFlag rdf:type rdf:Property ;
    rdfs:label 'Suspension Of Destruction Flag' ;
    rdfs:comment 'Indicates whether routine document destruction and retention policies have been suspended for the scope of this legal hold. True means destruction is suspended; False means normal retention applies outside hold scope.' ;
    rdfs:domain ind:LegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:triggerDate rdf:type rdf:Property ;
    rdfs:label 'Trigger Date' ;
    rdfs:comment 'Date on which the triggering event occurred that gave rise to the duty to preserve electronically stored information (ESI) and physical documents.' ;
    rdfs:domain ind:LegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:triggerEvent rdf:type rdf:Property ;
    rdfs:label 'Trigger Event' ;
    rdfs:comment 'Description of the event or circumstance that triggered the issuance of the legal hold, such as receipt of complaint, regulatory inquiry, internal investigation initiation, or reasonably anticipated litigation.' ;
    rdfs:domain ind:LegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:docProductionId rdf:type rdf:Property ;
    rdfs:label 'Doc Production Id' ;
    rdfs:comment 'Unique identifier for the eDiscovery production set. Primary key for the document production record.' ;
    rdfs:domain ind:DocProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryDocEsiCollectionId rdf:type rdf:Property ;
    rdfs:label 'Primary Doc Esi Collection Id' ;
    rdfs:comment 'FK to document.esi_collection.esi_collection_id — Productions are derived from collected ESI. This link provides the chain-of-custody from collection through production that is legally required for defensible eDiscovery.' ;
    rdfs:domain ind:DocProduction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EsiCollection .

ind:acknowledgmentReceived rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Received' ;
    rdfs:comment 'Indicates whether the receiving party has acknowledged receipt of the production.' ;
    rdfs:domain ind:DocProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:batesEndNumber rdf:type rdf:Property ;
    rdfs:label 'Bates End Number' ;
    rdfs:comment 'Last Bates number in the production range (e.g., DEF00012500). Marks the end of the sequential numbering for this production.' ;
    rdfs:domain ind:DocProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batesPrefix rdf:type rdf:Property ;
    rdfs:label 'Bates Prefix' ;
    rdfs:comment 'Prefix applied to Bates numbering for this production set (e.g., DEF, PROD, ABC). Used to uniquely identify the producing party and production set.' ;
    rdfs:domain ind:DocProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batesStartNumber rdf:type rdf:Property ;
    rdfs:label 'Bates Start Number' ;
    rdfs:comment 'First Bates number in the production range (e.g., DEF00000001). Marks the beginning of the sequential numbering for this production.' ;
    rdfs:domain ind:DocProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clawbackInvoked rdf:type rdf:Property ;
    rdfs:label 'Clawback Invoked' ;
    rdfs:comment 'Indicates whether the producing party has invoked clawback provisions to retrieve inadvertently produced privileged documents.' ;
    rdfs:domain ind:DocProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryLocation rdf:type rdf:Property ;
    rdfs:label 'Delivery Location' ;
    rdfs:comment 'Physical or digital location where the production was delivered (e.g., FTP URL, workspace name, physical address).' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Delivery Method' ;
    rdfs:comment 'Method by which the production was delivered to the receiving party (e.g., secure FTP, encrypted hard drive, Relativity workspace transfer).' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeRaised rdf:type rdf:Property ;
    rdfs:label 'Dispute Raised' ;
    rdfs:comment 'Indicates whether the receiving party has raised any disputes or objections regarding this production (e.g., incomplete production, technical issues, privilege claims).' ;
    rdfs:domain ind:DocProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hashVerificationMethod rdf:type rdf:Property ;
    rdfs:label 'Hash Verification Method' ;
    rdfs:comment 'Cryptographic hash algorithm used to verify integrity of produced files (e.g., MD5, SHA-256). Ensures chain of custody.' ;
    rdfs:domain ind:DocProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadFileFormat rdf:type rdf:Property ;
    rdfs:label 'Load File Format' ;
    rdfs:comment 'Format of the metadata load file accompanying the production (e.g., Concordance DAT, Relativity Load File, IPRO LFP). [ENUM-REF-CANDIDATE: dat|opt|lfp|csv|concordance|ipro|relativity — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metadataFieldsIncluded rdf:type rdf:Property ;
    rdfs:label 'Metadata Fields Included' ;
    rdfs:comment 'Comma-separated list or description of metadata fields included in the production load file (e.g., Author, Date Created, Subject, Custodian).' ;
    rdfs:domain ind:DocProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nativeFileCount rdf:type rdf:Property ;
    rdfs:label 'Native File Count' ;
    rdfs:comment 'Number of documents produced in native format (original application format such as .docx, .xlsx, .msg).' ;
    rdfs:domain ind:DocProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:privilegeLogIncluded rdf:type rdf:Property ;
    rdfs:label 'Privilege Log Included' ;
    rdfs:comment 'Indicates whether a privilege log was included with this production to identify withheld documents and the basis for withholding.' ;
    rdfs:domain ind:DocProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:producingCounselName rdf:type rdf:Property ;
    rdfs:label 'Producing Counsel Name' ;
    rdfs:comment 'Name of the law firm or attorney responsible for preparing and delivering this production.' ;
    rdfs:domain ind:DocProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:producingPartyName rdf:type rdf:Property ;
    rdfs:label 'Producing Party Name' ;
    rdfs:comment 'Name of the party or organization producing the documents (typically the client or the law firm on behalf of the client).' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionFormat rdf:type rdf:Property ;
    rdfs:label 'Production Format' ;
    rdfs:comment 'Format in which documents were produced (native files, TIFF images with load files, searchable PDFs, or mixed formats).' ;
    rdfs:domain ind:DocProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionName rdf:type rdf:Property ;
    rdfs:label 'Production Name' ;
    rdfs:comment 'Descriptive name for the production set to aid identification and tracking (e.g., Initial Production - Custodian Smith, Supplemental Production Q2 2024).' ;
    rdfs:domain ind:DocProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionNotes rdf:type rdf:Property ;
    rdfs:label 'Production Notes' ;
    rdfs:comment 'Free-text notes regarding special circumstances, technical issues, or other relevant information about this production.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionNumber rdf:type rdf:Property ;
    rdfs:label 'Production Number' ;
    rdfs:comment 'Business identifier for the production set, typically assigned by the producing party or agreed upon by counsel (e.g., PROD001, DEF-PROD-2024-01).' ;
    rdfs:domain ind:DocProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionType rdf:type rdf:Property ;
    rdfs:label 'Production Type' ;
    rdfs:comment 'Classification of the production based on its purpose and timing within the discovery process.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protectiveOrderReference rdf:type rdf:Property ;
    rdfs:label 'Protective Order Reference' ;
    rdfs:comment 'Reference to the court order or agreement governing confidentiality and use restrictions for this production.' ;
    rdfs:domain ind:DocProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingPartyContact rdf:type rdf:Property ;
    rdfs:label 'Receiving Party Contact' ;
    rdfs:comment 'Primary contact person and email address at the receiving party for production-related communications.' ;
    rdfs:domain ind:DocProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingPartyName rdf:type rdf:Property ;
    rdfs:label 'Receiving Party Name' ;
    rdfs:comment 'Name of the party or organization receiving this production (e.g., opposing counsel, regulatory agency, co-defendant).' ;
    rdfs:domain ind:DocProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redactionApplied rdf:type rdf:Property ;
    rdfs:label 'Redaction Applied' ;
    rdfs:comment 'Indicates whether redactions were applied to any documents in this production to protect privileged, confidential, or sensitive information.' ;
    rdfs:domain ind:DocProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supersededByScheduleRetentionScheduleId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Schedule Retention Schedule Id' ;
    rdfs:comment 'Reference to the retention_schedule_id of the newer rule that replaces this one, if this schedule has been superseded. Null if still active or archived without replacement.' ;
    rdfs:domain ind:RetentionSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RetentionSchedule .

ind:auditTrailRetentionYears rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Retention Years' ;
    rdfs:comment 'Number of years that audit logs and metadata tracking document access, modifications, and destruction events must be retained, often longer than the document itself.' ;
    rdfs:domain ind:RetentionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificateOfDestructionRequired rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Destruction Required' ;
    rdfs:comment 'Indicates whether a formal Certificate of Destruction must be generated and retained as proof of compliant document destruction (True/False).' ;
    rdfs:domain ind:RetentionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clientSpecificOverride rdf:type rdf:Property ;
    rdfs:label 'Client Specific Override' ;
    rdfs:comment 'Indicates whether this retention schedule is a client-specific override of the firms standard retention policy, typically due to contractual obligations or client requests (True/False).' ;
    rdfs:domain ind:RetentionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crossBorderTransferRestriction rdf:type rdf:Property ;
    rdfs:label 'Cross Border Transfer Restriction' ;
    rdfs:comment 'Indicates whether documents under this retention schedule are subject to cross-border data transfer restrictions under GDPR, CCPA, or other data protection regulations (True/False).' ;
    rdfs:domain ind:RetentionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:destructionAuthorizationRequired rdf:type rdf:Property ;
    rdfs:label 'Destruction Authorization Required' ;
    rdfs:comment 'Indicates whether formal authorization from a records manager, partner, or compliance officer is required before destruction can proceed (True/False).' ;
    rdfs:domain ind:RetentionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:destructionMethod rdf:type rdf:Property ;
    rdfs:label 'Destruction Method' ;
    rdfs:comment 'Approved method for destroying documents at end of retention period (e.g., secure deletion for electronic records, shredding for paper, degaussing for magnetic media, cryptographic erasure, incineration, pulping, overwriting). [ENUM-REF-CANDIDATE: secure_deletion|shredding|degaussing|incineration|pulping|overwriting|crypto_erasure — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RetentionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dmsSystemEnforcement rdf:type rdf:Property ;
    rdfs:label 'Dms System Enforcement' ;
    rdfs:comment 'Indicates which Document Management System (DMS) automatically enforces this retention schedule (iManage Work Records Management, NetDocuments Governance, both, manual enforcement, or none).' ;
    rdfs:domain ind:RetentionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediscoveryRelevanceFlag rdf:type rdf:Property ;
    rdfs:label 'Ediscovery Relevance Flag' ;
    rdfs:comment 'Indicates whether documents under this retention schedule are typically relevant for eDiscovery and Electronic Case Filing (ECF) purposes, affecting preservation obligations during litigation (True/False).' ;
    rdfs:domain ind:RetentionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalHoldExemption rdf:type rdf:Property ;
    rdfs:label 'Legal Hold Exemption' ;
    rdfs:comment 'Indicates whether documents subject to this retention schedule are exempt from automatic destruction when a legal hold or litigation hold is in place (True/False). True means destruction is suspended during holds.' ;
    rdfs:domain ind:RetentionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maximumRetentionPeriodYears rdf:type rdf:Property ;
    rdfs:label 'Maximum Retention Period Years' ;
    rdfs:comment 'Maximum number of years the document should be retained from the trigger date before mandatory destruction, if applicable. Null if no maximum limit. Supports fractional years.' ;
    rdfs:domain ind:RetentionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumRetentionPeriodYears rdf:type rdf:Property ;
    rdfs:label 'Minimum Retention Period Years' ;
    rdfs:comment 'Minimum number of years the document must be retained from the trigger date before destruction is permitted. Supports fractional years (e.g., 6.5 years).' ;
    rdfs:domain ind:RetentionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:privacyImpactClassification rdf:type rdf:Property ;
    rdfs:label 'Privacy Impact Classification' ;
    rdfs:comment 'Assessment of the privacy risk associated with documents under this retention schedule (high for documents containing extensive Personally Identifiable Information (PII), medium for limited PII, low for minimal PII, none for non-personal data).' ;
    rdfs:domain ind:RetentionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordsClassificationCode rdf:type rdf:Property ;
    rdfs:label 'Records Classification Code' ;
    rdfs:comment 'Internal or industry-standard records classification code used for filing and retrieval (e.g., based on firm taxonomy or legal records classification schemes).' ;
    rdfs:domain ind:RetentionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleRecordsManager rdf:type rdf:Property ;
    rdfs:label 'Responsible Records Manager' ;
    rdfs:comment 'Name or role of the individual or department responsible for enforcing this retention schedule and authorizing destruction (e.g., Records Manager, Compliance Officer, Knowledge Management team).' ;
    rdfs:domain ind:RetentionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionBasis rdf:type rdf:Property ;
    rdfs:label 'Retention Basis' ;
    rdfs:comment 'Legal or business justification for the retention period (e.g., statute of limitations, regulatory requirement, contractual obligation, business need, client request, professional conduct rules).' ;
    rdfs:domain ind:RetentionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionReviewFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Retention Review Frequency Months' ;
    rdfs:comment 'Frequency in months at which this retention schedule rule should be reviewed and updated to reflect changes in law, regulation, or business practice (e.g., 12 for annual review, 24 for biennial).' ;
    rdfs:domain ind:RetentionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:retentionScheduleStatus rdf:type rdf:Property ;
    rdfs:label 'Retention Schedule Status' ;
    rdfs:comment 'Current lifecycle status of this retention schedule rule (active and enforced, draft pending approval, superseded by newer rule, archived for historical reference, under review for updates).' ;
    rdfs:domain ind:RetentionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionTriggerEvent rdf:type rdf:Property ;
    rdfs:label 'Retention Trigger Event' ;
    rdfs:comment 'The business event that starts the retention clock (e.g., matter closure, document creation date, last access date, final billing, statute of limitations expiry, regulatory hold release, client relationship termination). [ENUM-REF-CANDIDATE: matter_closure|document_creation|last_access|final_billing|statute_of_limitations_expiry|regulatory_hold_release|client_termination|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RetentionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionControlPolicy rdf:type rdf:Property ;
    rdfs:label 'Version Control Policy' ;
    rdfs:comment 'Policy for retaining document versions under this schedule (retain all versions, retain final executed version only, retain major versions only, retain last N versions).' ;
    rdfs:domain ind:RetentionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boardResolutionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Board Resolution Required Flag' ;
    rdfs:comment 'Indicates whether a board resolution or similar corporate authorization is required for valid execution of this document.' ;
    rdfs:domain ind:DocExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceReviewCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Review Completed Flag' ;
    rdfs:comment 'Indicates whether required compliance review (Anti-Money Laundering (AML), Know Your Client (KYC), sanctions checks) has been completed prior to execution.' ;
    rdfs:domain ind:DocExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:counterpartCount rdf:type rdf:Property ;
    rdfs:label 'Counterpart Count' ;
    rdfs:comment 'Number of counterpart copies executed if counterpart execution was used. Null if not executed in counterparts.' ;
    rdfs:domain ind:DocExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:counterpartIndicator rdf:type rdf:Property ;
    rdfs:label 'Counterpart Indicator' ;
    rdfs:comment 'Indicates whether this document was executed in counterparts, allowing multiple identical copies to be signed separately by different parties.' ;
    rdfs:domain ind:DocExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:executedDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Executed Document Reference' ;
    rdfs:comment 'Reference or file path to the fully executed document stored in the Document Management System (DMS). Links to iManage Work or NetDocuments storage location.' ;
    rdfs:domain ind:DocExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionLanguage rdf:type rdf:Property ;
    rdfs:label 'Execution Language' ;
    rdfs:comment 'Primary language in which the executed document is written. ISO 639-1 two-letter language code.' ;
    rdfs:domain ind:DocExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notarizationCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Notarization Completed Flag' ;
    rdfs:comment 'Indicates whether required notarization has been completed for this document execution.' ;
    rdfs:domain ind:DocExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notarizationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Notarization Required Flag' ;
    rdfs:comment 'Indicates whether notarization is required for this document execution to be legally valid.' ;
    rdfs:domain ind:DocExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:powerOfAttorneyUsedFlag rdf:type rdf:Property ;
    rdfs:label 'Power Of Attorney Used Flag' ;
    rdfs:comment 'Indicates whether any signatory executed the document under a Power of Attorney (POA) rather than in their own capacity.' ;
    rdfs:domain ind:DocExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sealAppliedFlag rdf:type rdf:Property ;
    rdfs:label 'Seal Applied Flag' ;
    rdfs:comment 'Indicates whether the required corporate or official seal has been applied to the executed document.' ;
    rdfs:domain ind:DocExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sealRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Seal Required Flag' ;
    rdfs:comment 'Indicates whether a corporate seal or official seal is required for valid execution of this document.' ;
    rdfs:domain ind:DocExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:signaturesCompletedCount rdf:type rdf:Property ;
    rdfs:label 'Signatures Completed Count' ;
    rdfs:comment 'Number of parties who have completed their signature to date. Used to track execution progress.' ;
    rdfs:domain ind:DocExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:signingPartyCount rdf:type rdf:Property ;
    rdfs:label 'Signing Party Count' ;
    rdfs:comment 'Total number of parties required to sign this document for full execution.' ;
    rdfs:domain ind:DocExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:witnessCountObtained rdf:type rdf:Property ;
    rdfs:label 'Witness Count Obtained' ;
    rdfs:comment 'Number of witness signatures obtained to date. Used to track completion of witnessing requirements.' ;
    rdfs:domain ind:DocExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:witnessCountRequired rdf:type rdf:Property ;
    rdfs:label 'Witness Count Required' ;
    rdfs:comment 'Number of witnesses required for valid execution, if witnessing is required. Null if no witnesses required.' ;
    rdfs:domain ind:DocExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:witnessRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Witness Required Flag' ;
    rdfs:comment 'Indicates whether witness signatures are required for this document execution to be legally valid.' ;
    rdfs:domain ind:DocExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:accessLevel rdf:type rdf:Property ;
    rdfs:label 'Access Level' ;
    rdfs:comment 'Security classification determining which users and groups can view and use this template. Enforces information barriers and protects sensitive or strategic template content.' ;
    rdfs:domain ind:DocTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:automationPlatform rdf:type rdf:Property ;
    rdfs:label 'Automation Platform' ;
    rdfs:comment 'The document automation or assembly platform for which this template is configured (e.g., HotDocs, Contract Express, Smokeball). Null if no automation is present.' ;
    rdfs:domain ind:DocTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containsAutomation rdf:type rdf:Property ;
    rdfs:label 'Contains Automation' ;
    rdfs:comment 'Indicates whether the template includes document automation features such as conditional logic, field merges, or calculation formulas. True if automation is present, False otherwise.' ;
    rdfs:domain ind:DocTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:documentType rdf:type rdf:Property ;
    rdfs:label 'Document Type' ;
    rdfs:comment 'Classification of the document template by legal document category. Determines workflow, review requirements, and retention policies. [ENUM-REF-CANDIDATE: contract|agreement|memorandum|brief|motion|pleading|opinion_letter|advice_memo|disclosure_schedule|board_resolution|shareholder_resolution|notice|demand_letter|settlement_agreement|nda|engagement_letter — 16 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DocTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isClientFacing rdf:type rdf:Property ;
    rdfs:label 'Is Client Facing' ;
    rdfs:comment 'Indicates whether documents generated from this template are typically shared with or delivered to clients. True if client-facing, False if internal work product. Affects quality assurance and review requirements.' ;
    rdfs:domain ind:DocTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:language rdf:type rdf:Property ;
    rdfs:label 'Language' ;
    rdfs:comment 'The primary language in which the template is drafted. Critical for multi-jurisdictional firms serving clients across language boundaries.' ;
    rdfs:domain ind:DocTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerPracticeGroup rdf:type rdf:Property ;
    rdfs:label 'Owner Practice Group' ;
    rdfs:comment 'The practice group or department responsible for maintaining, updating, and governing this template. Determines accountability for template quality and currency.' ;
    rdfs:domain ind:DocTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:precedentReferences rdf:type rdf:Property ;
    rdfs:label 'Precedent References' ;
    rdfs:comment 'References to related precedent documents, prior transactions, or exemplar work product that informed the development of this template. Supports knowledge reuse and maintains institutional memory.' ;
    rdfs:domain ind:DocTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryComplianceNotes rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Notes' ;
    rdfs:comment 'Notes on specific regulatory requirements, court rules, or compliance frameworks that this template addresses (e.g., GDPR (General Data Protection Regulation), SOX (Sarbanes-Oxley Act), FRAND (Fair Reasonable and Non-Discriminatory) terms). Critical for risk management and audit trails.' ;
    rdfs:domain ind:DocTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresPartnerReview rdf:type rdf:Property ;
    rdfs:label 'Requires Partner Review' ;
    rdfs:comment 'Indicates whether documents generated from this template must be reviewed by a partner before finalization or delivery. True if partner review is mandatory, False otherwise. Enforces quality control and risk management protocols.' ;
    rdfs:domain ind:DocTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tags rdf:type rdf:Property ;
    rdfs:label 'Tags' ;
    rdfs:comment 'Comma-separated list of keywords and tags for search, filtering, and categorization within the knowledge management system. Enhances template discoverability.' ;
    rdfs:domain ind:DocTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateVersion rdf:type rdf:Property ;
    rdfs:label 'Template Version' ;
    rdfs:comment 'Version identifier for the template following the firm\'s version control standards. Incremented with each substantive revision to track template evolution and ensure users access current forms.' ;
    rdfs:domain ind:DocTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Amount' ;
    rdfs:comment 'Total approved budget for the matter in the firm\'s base currency. Used for budget tracking, variance analysis, and client communications. Confidential financial information.' ;
    rdfs:domain ind:Matter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:closeDate rdf:type rdf:Property ;
    rdfs:label 'Close Date' ;
    rdfs:comment 'Date the matter was officially closed. Nullable for active matters. Once closed, no further time or disbursements may be posted without reopening.' ;
    rdfs:domain ind:Matter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conflictClearanceDate rdf:type rdf:Property ;
    rdfs:label 'Conflict Clearance Date' ;
    rdfs:comment 'Date the matter received conflict clearance approval. Required for regulatory compliance and audit trails.' ;
    rdfs:domain ind:Matter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conflictClearedFlag rdf:type rdf:Property ;
    rdfs:label 'Conflict Cleared Flag' ;
    rdfs:comment 'Indicates whether the matter has passed conflict checking and been approved for engagement. Must be true before work can commence.' ;
    rdfs:domain ind:Matter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:engagementLetterSentDate rdf:type rdf:Property ;
    rdfs:label 'Engagement Letter Sent Date' ;
    rdfs:comment 'Date the formal engagement letter (LOE) was sent to the client. Required for professional indemnity insurance and regulatory compliance.' ;
    rdfs:domain ind:Matter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:engagementLetterSignedDate rdf:type rdf:Property ;
    rdfs:label 'Engagement Letter Signed Date' ;
    rdfs:comment 'Date the client signed and returned the engagement letter, formalizing the attorney-client relationship and scope of work.' ;
    rdfs:domain ind:Matter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:estimatedHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Hours' ;
    rdfs:comment 'Total estimated billable hours required to complete the matter. Used for resource planning and Legal Project Management (LPM) tracking.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ledesMatterCategory rdf:type rdf:Property ;
    rdfs:label 'Ledes Matter Category' ;
    rdfs:comment 'Standardized LEDES billing code category for the matter type (e.g., L01 for Litigation, L02 for Corporate). Enables electronic billing submission to corporate clients.' ;
    rdfs:domain ind:Matter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matterNumber rdf:type rdf:Property ;
    rdfs:label 'Matter Number' ;
    rdfs:comment 'Externally-known unique business identifier for the matter, typically formatted as client code plus sequential number (e.g., CLI001-00123). Used in all client communications, invoices, and internal references.' ;
    rdfs:domain ind:Matter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openDate rdf:type rdf:Property ;
    rdfs:label 'Open Date' ;
    rdfs:comment 'Date the matter was officially opened and approved for work to commence. Marks the start of the matter lifecycle and billing eligibility.' ;
    rdfs:domain ind:Matter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:opposingPartyName rdf:type rdf:Property ;
    rdfs:label 'Opposing Party Name' ;
    rdfs:comment 'Name of the opposing party or counterparty in litigation or transactional matters. Used for conflict checking and matter identification. Confidential.' ;
    rdfs:domain ind:Matter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phase rdf:type rdf:Property ;
    rdfs:label 'Phase' ;
    rdfs:comment 'Current phase or stage in the matter lifecycle. Used for Legal Project Management (LPM) tracking and resource forecasting. Phases vary by matter type. [ENUM-REF-CANDIDATE: intake|discovery|motion_practice|trial|appeal|settlement|closing|post_closing — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Matter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statuteOfLimitationsDate rdf:type rdf:Property ;
    rdfs:label 'Statute Of Limitations Date' ;
    rdfs:comment 'Critical deadline by which legal action must be filed or rights will be forfeited. Used for docket management and malpractice risk mitigation.' ;
    rdfs:domain ind:Matter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualDisbursementsToDate rdf:type rdf:Property ;
    rdfs:label 'Actual Disbursements To Date' ;
    rdfs:comment 'Cumulative total of actual disbursements (expenses) recorded against this phase to date. Used for budget vs. actual variance analysis.' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualEndDate rdf:type rdf:Property ;
    rdfs:label 'Actual End Date' ;
    rdfs:comment 'Actual date on which this phase was completed or closed. Null if phase is still in progress. Used for schedule variance analysis and audit trail.' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualFeesToDate rdf:type rdf:Property ;
    rdfs:label 'Actual Fees To Date' ;
    rdfs:comment 'Cumulative total of actual professional fees (time charges) recorded against this phase to date. Calculated from time entries at applicable rates. Used for budget vs. actual variance analysis.' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualHoursToDate rdf:type rdf:Property ;
    rdfs:label 'Actual Hours To Date' ;
    rdfs:comment 'Cumulative total of actual hours recorded against this phase to date. Sourced from time entry records. Used for budget vs. actual variance analysis.' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualStartDate rdf:type rdf:Property ;
    rdfs:label 'Actual Start Date' ;
    rdfs:comment 'Actual date on which work on this phase commenced. Used for schedule variance analysis and audit trail.' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:budgetedDisbursements rdf:type rdf:Property ;
    rdfs:label 'Budgeted Disbursements' ;
    rdfs:comment 'Estimated total disbursements (out-of-pocket expenses such as court fees, expert witness fees, travel, filing fees) allocated for this phase.' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetedFees rdf:type rdf:Property ;
    rdfs:label 'Budgeted Fees' ;
    rdfs:comment 'Estimated total professional fees (in the matter currency) allocated for this phase. Includes attorney and paralegal time at standard or negotiated rates. Excludes disbursements.' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetedHours rdf:type rdf:Property ;
    rdfs:label 'Budgeted Hours' ;
    rdfs:comment 'Estimated total hours allocated for this phase as part of the matter budget. Used for LPM planning and AFA (Alternative Fee Arrangement) scoping.' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isContingent rdf:type rdf:Property ;
    rdfs:label 'Is Contingent' ;
    rdfs:comment 'Flag indicating whether this phase is subject to a contingent fee arrangement (fees payable only upon successful outcome). Common in litigation and personal injury matters.' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:milestoneDueDate rdf:type rdf:Property ;
    rdfs:label 'Milestone Due Date' ;
    rdfs:comment 'Target due date for the key milestone or deliverable associated with this phase. Used for critical path tracking and client SLA management.' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:phaseDescription rdf:type rdf:Property ;
    rdfs:label 'Phase Description' ;
    rdfs:comment 'Detailed description of the scope, objectives, and deliverables for this phase. Used for LPM (Legal Project Management) planning and client communication.' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phaseName rdf:type rdf:Property ;
    rdfs:label 'Phase Name' ;
    rdfs:comment 'Human-readable name of the phase (e.g., Pleadings, Discovery, Motion Practice, Trial, Appeal, Due Diligence, Negotiation, Closing). Describes the stage of work within the matter lifecycle.' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phaseStatus rdf:type rdf:Property ;
    rdfs:label 'Phase Status' ;
    rdfs:comment 'Current lifecycle status of the phase. Indicates whether the phase has not started, is actively in progress, is on hold pending external events, has been completed, was cancelled, or deferred to a later date.' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phaseType rdf:type rdf:Property ;
    rdfs:label 'Phase Type' ;
    rdfs:comment 'Categorical classification of the phase based on the nature of legal work: litigation (court-based dispute), transactional (M&A, corporate deals), advisory (counseling), compliance (regulatory adherence), IP prosecution (patent/trademark filing), dispute resolution (ADR, arbitration), regulatory (agency proceedings), or other. [ENUM-REF-CANDIDATE: litigation|transactional|advisory|compliance|ip_prosecution|dispute_resolution|regulatory|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedEndDate rdf:type rdf:Property ;
    rdfs:label 'Planned End Date' ;
    rdfs:comment 'Target date by which this phase is planned to be completed. Used for LPM scheduling, milestone tracking, and client SLA (Service Level Agreement) management.' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedStartDate rdf:type rdf:Property ;
    rdfs:label 'Planned Start Date' ;
    rdfs:comment 'Target date on which this phase is planned to commence. Used for LPM scheduling and milestone tracking.' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sequenceOrder rdf:type rdf:Property ;
    rdfs:label 'Sequence Order' ;
    rdfs:comment 'Numeric ordering of the phase within the matter lifecycle. Used to display phases in chronological or logical sequence (e.g., 1=Intake, 2=Pleadings, 3=Discovery, 4=Trial).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:taskId rdf:type rdf:Property ;
    rdfs:label 'Task Id' ;
    rdfs:comment 'Unique identifier for the matter task record. Primary key.' ;
    rdfs:domain ind:Task ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:predecessorTaskId rdf:type rdf:Property ;
    rdfs:label 'Predecessor Task Id' ;
    rdfs:comment 'Reference to a prior task that must be completed before this task can begin. Supports task dependency modeling and critical path analysis in LPM workflows.' ;
    rdfs:domain ind:Task ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Task .

ind:actualHours rdf:type rdf:Property ;
    rdfs:label 'Actual Hours' ;
    rdfs:comment 'Total hours recorded against this task by all timekeepers. Aggregated from time entry records for budget variance analysis and billing.' ;
    rdfs:domain ind:Task ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:blockingReason rdf:type rdf:Property ;
    rdfs:label 'Blocking Reason' ;
    rdfs:comment 'Free-text explanation of why the task is on hold or deferred. Captures dependencies, client delays, or external blockers.' ;
    rdfs:domain ind:Task ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetVarianceCost rdf:type rdf:Property ;
    rdfs:label 'Budget Variance Cost' ;
    rdfs:comment 'Difference between estimated cost and actual cost (actual minus estimated). Positive values indicate over-budget, negative values indicate under-budget. Supports financial performance tracking.' ;
    rdfs:domain ind:Task ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetVarianceHours rdf:type rdf:Property ;
    rdfs:label 'Budget Variance Hours' ;
    rdfs:comment 'Difference between estimated hours and actual hours (actual minus estimated). Positive values indicate over-budget, negative values indicate under-budget. Supports budget performance analysis.' ;
    rdfs:domain ind:Task ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clientVisibleFlag rdf:type rdf:Property ;
    rdfs:label 'Client Visible Flag' ;
    rdfs:comment 'Indicates whether this task is visible to the client in client portal or matter status reports. False for internal administrative or strategy tasks.' ;
    rdfs:domain ind:Task ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliverableDescription rdf:type rdf:Property ;
    rdfs:label 'Deliverable Description' ;
    rdfs:comment 'Description of the expected output or work product from this task (e.g., motion document, research memo, contract redline). Supports quality review and client communication.' ;
    rdfs:domain ind:Task ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalTaskReference rdf:type rdf:Property ;
    rdfs:label 'External Task Reference' ;
    rdfs:comment 'External identifier or reference number for the task in integrated systems (e.g., project management tool, client portal, court ECF system). Supports cross-system reconciliation.' ;
    rdfs:domain ind:Task ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isMilestoneFlag rdf:type rdf:Property ;
    rdfs:label 'Is Milestone Flag' ;
    rdfs:comment 'Indicates whether this task represents a key milestone in the matter lifecycle (e.g., complaint filed, discovery complete, trial date). Used for high-level matter status reporting and client communication.' ;
    rdfs:domain ind:Task ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:startDate rdf:type rdf:Property ;
    rdfs:label 'Start Date' ;
    rdfs:comment 'Date the task was initiated or moved to in-progress status. Supports task duration and throughput analysis.' ;
    rdfs:domain ind:Matter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:taskCategory rdf:type rdf:Property ;
    rdfs:label 'Task Category' ;
    rdfs:comment 'High-level classification of the task type for reporting and workload analysis. Complements UTBMS task code with firm-specific categorization. [ENUM-REF-CANDIDATE: legal_research|document_drafting|client_communication|court_filing|discovery|negotiation|administrative — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Task ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskName rdf:type rdf:Property ;
    rdfs:label 'Task Name' ;
    rdfs:comment 'Short descriptive name of the task (e.g., Draft Motion to Dismiss, Review Contract Terms, Conduct Client Interview).' ;
    rdfs:domain ind:Task ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskStatus rdf:type rdf:Property ;
    rdfs:label 'Task Status' ;
    rdfs:comment 'Current lifecycle status of the task. Tracks progression from assignment through completion or deferral.' ;
    rdfs:domain ind:Task ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teamId rdf:type rdf:Property ;
    rdfs:label 'Team Id' ;
    rdfs:comment 'Unique identifier for the matter team assignment record. Primary key for the matter team association entity.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:conflictClearanceId rdf:type rdf:Property ;
    rdfs:label 'Conflict Clearance Id' ;
    rdfs:comment 'Reference to the conflict clearance record that authorized this timekeeper\'s assignment to the matter. Links to Intapp Conflicts clearance record.' ;
    rdfs:domain ind:Matter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Clearance .

ind:allocationPercentage rdf:type rdf:Property ;
    rdfs:label 'Allocation Percentage' ;
    rdfs:comment 'Percentage of the timekeeper\'s capacity allocated to this matter. Used for workload planning and resource management. Value between 0.00 and 100.00.' ;
    rdfs:domain ind:Matter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignmentSourceReference rdf:type rdf:Property ;
    rdfs:label 'Assignment Source Reference' ;
    rdfs:comment 'Unique identifier of this assignment record in the source system (Elite 3E or Aderant Expert). Used for data lineage and reconciliation.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Assignment Source System' ;
    rdfs:comment 'System from which the matter team assignment record originated. Values: elite_3e (Elite 3E Practice Management), aderant_expert (Aderant Expert Time and Billing), manual (manually entered), import (bulk import).' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingRateCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Billing Rate Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the billing rate override (e.g., USD, GBP, EUR). Aligns with the matter\'s billing currency.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingRateOverride rdf:type rdf:Property ;
    rdfs:label 'Billing Rate Override' ;
    rdfs:comment 'Matter-specific billing rate override for this timekeeper, expressed in the matter\'s billing currency. Overrides the timekeeper\'s standard rate for this matter only. Used for Alternative Fee Arrangements (AFA) or negotiated rates.' ;
    rdfs:domain ind:Matter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feeBudgetCap rdf:type rdf:Property ;
    rdfs:label 'Fee Budget Cap' ;
    rdfs:comment 'Maximum fee amount this timekeeper is authorized to bill to the matter, expressed in the matter\'s billing currency. Used for Alternative Fee Arrangement (AFA) and budget governance. Null if no cap applies.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hoursBudgetCap rdf:type rdf:Property ;
    rdfs:label 'Hours Budget Cap' ;
    rdfs:comment 'Maximum number of hours this timekeeper is authorized to bill to the matter. Used for budget control and Alternative Fee Arrangement (AFA) compliance. Null if no cap applies.' ;
    rdfs:domain ind:Matter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isBillingTimekeeper rdf:type rdf:Property ;
    rdfs:label 'Is Billing Timekeeper' ;
    rdfs:comment 'Indicates whether this timekeeper is authorized to approve billing and invoices for the matter. True if billing authority, False otherwise.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOriginatingTimekeeper rdf:type rdf:Property ;
    rdfs:label 'Is Originating Timekeeper' ;
    rdfs:comment 'Indicates whether this timekeeper originated the client relationship and matter. True if originating attorney, False otherwise. Used for credit allocation and Revenue Per Equity Partner (RPE) calculations.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:roleCode rdf:type rdf:Property ;
    rdfs:label 'Role Code' ;
    rdfs:comment 'Code representing the timekeeper\'s role on the matter. Values: RESP_ATT (Responsible Attorney), SUPV_PRTNR (Supervising Partner), ASSOC (Associate), PARA (Paralegal), BILL_ATT (Billing Attorney), ORIG_ATT (Originating Attorney - client relationship owner), CO_COUNSEL (Co-Counsel), CONSULT (Consultant), EXPERT (Expert Witness), ADMIN (Administrative Support). [ENUM-REF-CANDIDATE: RESP_ATT|SUPV_PRTNR|ASSOC|PARA|BILL_ATT|ORIG_ATT|CO_COUNSEL|CONSULT|EXPERT|ADMIN — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Matter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleDescription rdf:type rdf:Property ;
    rdfs:label 'Role Description' ;
    rdfs:comment 'Full text description of the timekeeper\'s role and responsibilities on the matter. Provides additional context beyond the role code.' ;
    rdfs:domain ind:Matter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetId rdf:type rdf:Property ;
    rdfs:label 'Budget Id' ;
    rdfs:comment 'Unique identifier for the matter budget record. Primary key.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:budgetNumber rdf:type rdf:Property ;
    rdfs:label 'Budget Number' ;
    rdfs:comment 'Business identifier for the matter budget, typically used in engagement letters and client communications.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetSource rdf:type rdf:Property ;
    rdfs:label 'Budget Source' ;
    rdfs:comment 'Origin of the budget: engagement letter, LOE (Letter of Engagement), RFP (Request for Proposal) response, court order (fee cap), client guideline (outside counsel guideline), or internal estimate.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetStatus rdf:type rdf:Property ;
    rdfs:label 'Budget Status' ;
    rdfs:comment 'Current lifecycle status of the budget: draft (under preparation), approved (client-accepted), revised (amended post-approval), closed (matter concluded), suspended (on hold), or exceeded (over budget threshold).' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetType rdf:type rdf:Property ;
    rdfs:label 'Budget Type' ;
    rdfs:comment 'Classification of the budget scope: total fees (all professional fees), phase fees (by litigation or transaction phase), disbursements (out-of-pocket costs), total matter (fees plus disbursements), task-based (UTBMS task codes), or milestone-based (deliverable-driven).' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientAgreedFlag rdf:type rdf:Property ;
    rdfs:label 'Client Agreed Flag' ;
    rdfs:comment 'Indicates whether the client has formally agreed to this budget in writing (engagement letter, LOE, or budget approval email).' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currency rdf:type rdf:Property ;
    rdfs:label 'Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the budget amount (e.g., USD, GBP, EUR).' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hourlyRateAmount rdf:type rdf:Property ;
    rdfs:label 'Hourly Rate Amount' ;
    rdfs:comment 'Hourly billing rate for the timekeeper or role, expressed in the rate currency. Null for non-hourly AFA arrangements.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Rate Approval Status' ;
    rdfs:comment 'Approval status of the rate: draft (under negotiation), approved (finalized), pending_client_approval (awaiting client sign-off), rejected (client declined), or superseded (replaced by newer rate).' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCurrency rdf:type rdf:Property ;
    rdfs:label 'Rate Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the hourly rate amount (e.g., USD, GBP, EUR).' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Rate Effective Date' ;
    rdfs:comment 'Date from which this rate becomes effective for time entry valuation and billing.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rateExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Rate Expiry Date' ;
    rdfs:comment 'Date on which this rate expires or is superseded. Null for open-ended rate agreements.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rateScheduleName rdf:type rdf:Property ;
    rdfs:label 'Rate Schedule Name' ;
    rdfs:comment 'Name of the rate schedule or rate card associated with this budget (e.g., Standard 2024, Client ABC Preferred Rates, AFA Blended Rate).' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateSource rdf:type rdf:Property ;
    rdfs:label 'Rate Source' ;
    rdfs:comment 'Origin of the rate: engagement letter (LOE-specified rate), rate_schedule (firm rate card), court_order (court-imposed fee cap or rate), client_guideline (outside counsel guideline rate), or firm_standard (default firm rate).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateVersion rdf:type rdf:Property ;
    rdfs:label 'Rate Version' ;
    rdfs:comment 'Version number of the rate to track rate changes and amendments over the matter lifecycle.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:timekeeperRole rdf:type rdf:Property ;
    rdfs:label 'Timekeeper Role' ;
    rdfs:comment 'Role or level of the timekeeper for rate governance (e.g., Equity Partner, Non-Equity Partner, Senior Associate, Associate, Paralegal, Legal Assistant). Used for role-based rate schedules.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceThresholdPercentage rdf:type rdf:Property ;
    rdfs:label 'Variance Threshold Percentage' ;
    rdfs:comment 'Percentage threshold above which budget variance triggers client notification or approval requirement (e.g., 10.00 means notify at 10% over budget).' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:version rdf:type rdf:Property ;
    rdfs:label 'Version' ;
    rdfs:comment 'Version number of the budget to track revisions and amendments over the matter lifecycle.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:matterPartyId rdf:type rdf:Property ;
    rdfs:label 'Matter Party Id' ;
    rdfs:comment 'Unique identifier for the matter party record. Primary key for the matter party entity.' ;
    rdfs:domain ind:MatterParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clientIndividualId rdf:type rdf:Property ;
    rdfs:label 'Client Individual Id' ;
    rdfs:comment 'Foreign key linking to client.individual. Business justification: Individual parties in matters may be existing individual clients. Critical for conflict checking, KYC compliance (reusing existing verification), and relationship tracking. Prevents duplicate client r' ;
    rdfs:domain ind:MatterParty ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Individual .

ind:clientOrganisationId rdf:type rdf:Property ;
    rdfs:label 'Client Organisation Id' ;
    rdfs:comment 'Foreign key linking to client.organisation. Business justification: Matter parties are frequently existing client organisations. This link enables conflict checking (identifying when a party in litigation is also a client), consolidated client relationship views, and ' ;
    rdfs:domain ind:MatterParty ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Organisation .

ind:primaryMatterId rdf:type rdf:Property ;
    rdfs:label 'Primary Matter Id' ;
    rdfs:comment 'Reference to the legal matter to which this party is associated. Links the party to the specific case or transaction.' ;
    rdfs:domain ind:MatterParty ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Matter .

ind:tertiaryMatterId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Matter Id' ;
    rdfs:comment 'FK to matter.matter.matter_id — Parties are associated with a specific matter. Required for conflict checking and litigation/transaction party management.' ;
    rdfs:domain ind:MatterParty ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Matter .

ind:toMatterId rdf:type rdf:Property ;
    rdfs:label 'To Matter Id' ;
    rdfs:comment 'FK to matter.matter.matter_id — Parties are associated with a specific matter. Essential for conflict checking, litigation management, and corporate transaction party tracking.' ;
    rdfs:domain ind:MatterParty ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Matter .

ind:adversePartyFlag rdf:type rdf:Property ;
    rdfs:label 'Adverse Party Flag' ;
    rdfs:comment 'Boolean indicator identifying whether this party is adverse to the primary client. Critical for conflict checking and ethical wall management.' ;
    rdfs:domain ind:MatterParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:beneficialOwnerFlag rdf:type rdf:Property ;
    rdfs:label 'Beneficial Owner Flag' ;
    rdfs:comment 'Indicates whether this party is identified as a beneficial owner in the matter. Critical for corporate transaction advisory and regulatory compliance.' ;
    rdfs:domain ind:MatterParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conflictCheckClearedFlag rdf:type rdf:Property ;
    rdfs:label 'Conflict Check Cleared Flag' ;
    rdfs:comment 'Indicates whether conflict checking has been completed and cleared for this party. Critical for ethical compliance and new business intake.' ;
    rdfs:domain ind:MatterParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insuranceCoverageAmount rdf:type rdf:Property ;
    rdfs:label 'Insurance Coverage Amount' ;
    rdfs:comment 'Total insurance coverage amount applicable to this party in the matter. Relevant for litigation matters involving insurance claims or coverage disputes.' ;
    rdfs:domain ind:MatterParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:representationStatus rdf:type rdf:Property ;
    rdfs:label 'Representation Status' ;
    rdfs:comment 'Indicates whether the party is represented by legal counsel, unrepresented, self-represented, or representation status is pending determination.' ;
    rdfs:domain ind:MatterParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:representingCounselName rdf:type rdf:Property ;
    rdfs:label 'Representing Counsel Name' ;
    rdfs:comment 'Name of the primary attorney or counsel representing this party. Null if party is unrepresented.' ;
    rdfs:domain ind:MatterParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:representingFirmName rdf:type rdf:Property ;
    rdfs:label 'Representing Firm Name' ;
    rdfs:comment 'Name of the law firm or legal organization representing this party in the matter. Null if party is unrepresented.' ;
    rdfs:domain ind:MatterParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Role Effective Date' ;
    rdfs:comment 'Date when the party\'s role in the matter became effective. Marks the beginning of the party\'s involvement in the legal matter.' ;
    rdfs:domain ind:MatterParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:roleEndDate rdf:type rdf:Property ;
    rdfs:label 'Role End Date' ;
    rdfs:comment 'Date when the party\'s role in the matter ended. Null for parties still actively involved. Populated when party is dismissed, settled, or withdrawn.' ;
    rdfs:domain ind:MatterParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sanctionsCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Sanctions Check Status' ;
    rdfs:comment 'Result of sanctions list screening for this party. Indicates whether party appears on government sanctions lists or watchlists.' ;
    rdfs:domain ind:MatterParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementAuthorityAmount rdf:type rdf:Property ;
    rdfs:label 'Settlement Authority Amount' ;
    rdfs:comment 'Maximum settlement amount authorized for this party. Used in litigation and dispute resolution to track negotiation parameters.' ;
    rdfs:domain ind:MatterParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acknowledgementDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Deadline Date' ;
    rdfs:comment 'Date by which all custodians are required to acknowledge the hold notice.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dataCategoriesInScope rdf:type rdf:Property ;
    rdfs:label 'Data Categories In Scope' ;
    rdfs:comment 'Comma-separated or structured list of data categories subject to the hold, such as email, instant messages, documents, databases, social media, mobile device data, and cloud storage.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediscoveryVendorName rdf:type rdf:Property ;
    rdfs:label 'Ediscovery Vendor Name' ;
    rdfs:comment 'Name of the third-party eDiscovery vendor or ALSP (Alternative Legal Service Provider) engaged to support collection, processing, and review.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediscoveryVendorReference rdf:type rdf:Property ;
    rdfs:label 'Ediscovery Vendor Reference' ;
    rdfs:comment 'Vendor-assigned project or matter reference number for tracking and billing purposes.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedDataVolumeGb rdf:type rdf:Property ;
    rdfs:label 'Estimated Data Volume Gb' ;
    rdfs:comment 'Estimated volume of ESI subject to the hold, measured in gigabytes, used for proportionality assessment and eDiscovery planning.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedDocumentCount rdf:type rdf:Property ;
    rdfs:label 'Estimated Document Count' ;
    rdfs:comment 'Estimated number of documents or files subject to the hold, used for scoping and cost estimation.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:holdType rdf:type rdf:Property ;
    rdfs:label 'Hold Type' ;
    rdfs:comment 'Classification of the hold based on its legal or regulatory purpose.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuanceDate rdf:type rdf:Property ;
    rdfs:label 'Issuance Date' ;
    rdfs:comment 'Date on which the litigation hold or preservation notice was formally issued to custodians.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:issuingAttorneyName rdf:type rdf:Property ;
    rdfs:label 'Issuing Attorney Name' ;
    rdfs:comment 'Full name of the attorney who issued the hold, captured for audit and accountability purposes.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:malpracticeInsuranceNotifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Malpractice Insurance Notified Flag' ;
    rdfs:comment 'Indicates whether the firms malpractice insurance carrier was notified of the hold due to high spoliation risk or potential exposure.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:modificationHistory rdf:type rdf:Property ;
    rdfs:label 'Modification History' ;
    rdfs:comment 'Structured log or narrative of all modifications made to the hold scope, custodians, or status over its lifecycle.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proportionalityAssessment rdf:type rdf:Property ;
    rdfs:label 'Proportionality Assessment' ;
    rdfs:comment 'Narrative assessment of the proportionality of the hold scope relative to the needs of the case, considering factors such as cost, burden, and relevance.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relativityWorkspaceName rdf:type rdf:Property ;
    rdfs:label 'Relativity Workspace Name' ;
    rdfs:comment 'Human-readable name of the Relativity workspace associated with this hold.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reminderCadenceDays rdf:type rdf:Property ;
    rdfs:label 'Reminder Cadence Days' ;
    rdfs:comment 'Frequency in days at which reminder notices are sent to custodians who have not yet acknowledged the hold.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentPracticeAreaId rdf:type rdf:Property ;
    rdfs:label 'Parent Practice Area Id' ;
    rdfs:comment 'Reference to the parent practice area in the hierarchical taxonomy, enabling roll-up reporting from sub-specializations to broader practice groups. Null for top-level practice areas.' ;
    rdfs:domain ind:PracticeArea ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PracticeArea .

ind:averageMatterValue rdf:type rdf:Property ;
    rdfs:label 'Average Matter Value' ;
    rdfs:comment 'Historical average total billed value for matters in this practice area, used for pipeline valuation, revenue forecasting, and business development targeting. Expressed in firm base currency.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:classificationType rdf:type rdf:Property ;
    rdfs:label 'Classification Type' ;
    rdfs:comment 'High-level classification of the practice area by the nature of legal work performed. Transactional covers M&A (Mergers and Acquisitions), corporate deals; Advisory covers counseling and opinions; Litigation covers dispute resolution; Regulatory covers compliance and government relations; Hybrid covers mixed-mode practices; Specialized covers niche areas like IP (Intellectual Property) prosecution.' ;
    rdfs:domain ind:PracticeArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpdRequirementHours rdf:type rdf:Property ;
    rdfs:label 'Cpd Requirement Hours' ;
    rdfs:comment 'Annual CPD (Continuing Professional Development) or CLE (Continuing Legal Education) hours required for timekeepers practicing in this area, as mandated by the governing regulatory body. Used for compliance tracking and training program planning.' ;
    rdfs:domain ind:PracticeArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:defaultBillingArrangement rdf:type rdf:Property ;
    rdfs:label 'Default Billing Arrangement' ;
    rdfs:comment 'The most common fee arrangement type for matters in this practice area. Hourly for traditional time-based billing; Fixed Fee for scoped project work; Contingency for plaintiff litigation; AFA (Alternative Fee Arrangement) for value-based or risk-sharing models; Retainer for ongoing advisory; Capped Fee for budget-certainty arrangements; Blended Rate for team-based pricing; Success Fee for outcome-based compensation. [ENUM-REF-CANDIDATE: hourly|fixed_fee|contingency|afa|retainer|capped_fee|blended_rate|success_fee — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PracticeArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceCoverageRequirement rdf:type rdf:Property ;
    rdfs:label 'Insurance Coverage Requirement' ;
    rdfs:comment 'Specific professional indemnity or malpractice insurance coverage requirements for this practice area, including minimum coverage amounts and specialized endorsements. Critical for high-risk areas like securities litigation, M&A (Mergers and Acquisitions), or medical malpractice defense.' ;
    rdfs:domain ind:PracticeArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionScope rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Scope' ;
    rdfs:comment 'Geographic or legal jurisdiction scope for this practice area. May be a single jurisdiction (e.g., New York, England and Wales), multi-jurisdictional (e.g., US Federal, EU), or global. Critical for conflict checking, regulatory compliance, and timekeeper licensing requirements.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:knowledgeManagementCategory rdf:type rdf:Property ;
    rdfs:label 'Knowledge Management Category' ;
    rdfs:comment 'Classification used by the firms knowledge management system to organize precedents, practice notes, standard documents, and checklists for this practice area. Maps to DMS (Document Management System) taxonomy and knowledge repository structure.' ;
    rdfs:domain ind:PracticeArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:practiceAreaCode rdf:type rdf:Property ;
    rdfs:label 'Practice Area Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the practice area across all firm systems. Used in matter coding, timekeeper assignments, and rate card structures.' ;
    rdfs:domain ind:PracticeArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:practiceAreaDescription rdf:type rdf:Property ;
    rdfs:label 'Practice Area Description' ;
    rdfs:comment 'Detailed narrative describing the scope, services, and typical matters handled within this practice area. Used for RFP (Request for Proposal) responses, business development materials, and knowledge management.' ;
    rdfs:domain ind:PracticeArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:practiceAreaName rdf:type rdf:Property ;
    rdfs:label 'Practice Area Name' ;
    rdfs:comment 'Full business name of the practice area as recognized by clients and used in marketing materials, engagement letters, and matter classifications.' ;
    rdfs:domain ind:PracticeArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:practiceAreaStatus rdf:type rdf:Property ;
    rdfs:label 'Practice Area Status' ;
    rdfs:comment 'Current lifecycle status of the practice area. Active areas are available for new matter intake and timekeeper assignment. Inactive areas are no longer offered but may have legacy matters. Suspended areas are temporarily unavailable. Archived areas are historical records only.' ;
    rdfs:domain ind:PracticeArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:practiceGroup rdf:type rdf:Property ;
    rdfs:label 'Practice Group' ;
    rdfs:comment 'Broader practice group or department to which this practice area belongs, enabling organizational roll-up and resource allocation reporting.' ;
    rdfs:domain ind:PracticeArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryServiceLine rdf:type rdf:Property ;
    rdfs:label 'Primary Service Line' ;
    rdfs:comment 'The primary revenue-generating service line or business unit to which this practice area contributes. Used for P&L (Profit and Loss) allocation, partner compensation, and strategic planning.' ;
    rdfs:domain ind:PracticeArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proBonoEligible rdf:type rdf:Property ;
    rdfs:label 'Pro Bono Eligible' ;
    rdfs:comment 'Indicates whether this practice area is commonly used for pro bono matters. True for areas like immigration, civil rights, family law; False for highly specialized commercial areas. Used for pro bono reporting and CLE (Continuing Legal Education) credit tracking.' ;
    rdfs:domain ind:PracticeArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryBodyAlignment rdf:type rdf:Property ;
    rdfs:label 'Regulatory Body Alignment' ;
    rdfs:comment 'Primary regulatory or professional body whose standards, ethics rules, and CPD (Continuing Professional Development) requirements govern this practice area. Examples include ABA (American Bar Association), SRA (Solicitors Regulation Authority), IBA (International Bar Association), state bar associations, or specialized bodies like USPTO for IP (Intellectual Property) practice.' ;
    rdfs:domain ind:PracticeArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresSecurityClearance rdf:type rdf:Property ;
    rdfs:label 'Requires Security Clearance' ;
    rdfs:comment 'Indicates whether timekeepers working in this practice area typically require government or client security clearance due to the nature of matters (e.g., defense contracting, national security, classified government work).' ;
    rdfs:domain ind:PracticeArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresSpecialization rdf:type rdf:Property ;
    rdfs:label 'Requires Specialization' ;
    rdfs:comment 'Indicates whether this practice area requires specialized certification, licensing, or accreditation beyond general legal practice admission. True for areas like patent prosecution (USPTO registration), tax law (CPA or LLM), or admiralty law (specialized bar admission).' ;
    rdfs:domain ind:PracticeArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shortName rdf:type rdf:Property ;
    rdfs:label 'Short Name' ;
    rdfs:comment 'Abbreviated name or acronym for the practice area used in internal reporting, dashboards, and space-constrained displays.' ;
    rdfs:domain ind:PracticeArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technologyPlatformRequirement rdf:type rdf:Property ;
    rdfs:label 'Technology Platform Requirement' ;
    rdfs:comment 'Specialized technology platforms or tools typically required for matters in this practice area. Examples: Relativity for eDiscovery (Electronic Discovery) in litigation; LexisNexis for legal research; CLM (Contract Lifecycle Management) systems for transactional work; IP (Intellectual Property) docketing systems for patent prosecution.' ;
    rdfs:domain ind:PracticeArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typicalMatterDurationDays rdf:type rdf:Property ;
    rdfs:label 'Typical Matter Duration Days' ;
    rdfs:comment 'Average or median duration in days for matters in this practice area, from matter opening to closure. Used for resource planning, pipeline forecasting, and WIP (Work in Progress) aging analysis. Null for ongoing advisory relationships without defined end dates.' ;
    rdfs:domain ind:PracticeArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:utbmsActivityCodePrefix rdf:type rdf:Property ;
    rdfs:label 'Utbms Activity Code Prefix' ;
    rdfs:comment 'Standard UTBMS (Uniform Task-Based Management System) activity code prefix applicable to this practice area, providing granular activity-level coding for time entries and expense tracking in client billing.' ;
    rdfs:domain ind:PracticeArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utbmsTaskCodePrefix rdf:type rdf:Property ;
    rdfs:label 'Utbms Task Code Prefix' ;
    rdfs:comment 'Standard UTBMS (Uniform Task-Based Management System) task code prefix applicable to this practice area, enabling standardized time entry coding and client billing compliance. Examples: L for Litigation, C for Case Management, A for ADR (Alternative Dispute Resolution), T for Transactional.' ;
    rdfs:domain ind:PracticeArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryLegalPracticeAreaId rdf:type rdf:Property ;
    rdfs:label 'Primary Legal Practice Area Id' ;
    rdfs:comment 'Foreign key linking to service.practice_area. Business justification: Each legal service belongs to a practice area. Normalize by linking to practice_area master taxonomy. The practice_area STRING column is a code/name reference.' ;
    rdfs:domain ind:LegalService ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PracticeArea .

ind:allowsAfa rdf:type rdf:Property ;
    rdfs:label 'Allows Afa' ;
    rdfs:comment 'Indicates whether this service offering is eligible for Alternative Fee Arrangement (AFA) pricing models including fixed fees, capped fees, success fees, or blended rates.' ;
    rdfs:domain ind:LegalService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvalRequired rdf:type rdf:Property ;
    rdfs:label 'Approval Required' ;
    rdfs:comment 'Indicates whether engagement for this service requires formal approval from practice group leadership, risk committee, or conflicts committee before client commitment.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crossSellServices rdf:type rdf:Property ;
    rdfs:label 'Cross Sell Services' ;
    rdfs:comment 'Comma-separated list of related service codes that are commonly cross-sold or bundled with this offering. Used in business development, client relationship management, and revenue optimization.' ;
    rdfs:domain ind:LegalService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverableTypes rdf:type rdf:Property ;
    rdfs:label 'Deliverable Types' ;
    rdfs:comment 'Comma-separated list of typical deliverable types produced by this service. Examples include legal opinions, contracts, court filings, compliance reports, due diligence memoranda, or advisory presentations.' ;
    rdfs:domain ind:LegalService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedDurationHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Duration Hours' ;
    rdfs:comment 'Typical or average duration in hours required to deliver this service. Used for resource planning, capacity management, and client expectation setting in engagement letters.' ;
    rdfs:domain ind:LegalService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceCoverageRequired rdf:type rdf:Property ;
    rdfs:label 'Insurance Coverage Required' ;
    rdfs:comment 'Indicates whether specialized professional indemnity insurance coverage is required for this service offering beyond standard firm coverage. Relevant for high-risk or specialized services.' ;
    rdfs:domain ind:LegalService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jurisdictionCoverage rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Coverage' ;
    rdfs:comment 'Comma-separated list of legal jurisdictions or geographic regions where the firm is qualified and authorized to deliver this service. Critical for regulatory compliance and engagement eligibility.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:knowledgeAssets rdf:type rdf:Property ;
    rdfs:label 'Knowledge Assets' ;
    rdfs:comment 'Comma-separated list of knowledge management asset identifiers (practice notes, precedent documents, checklists, templates) from the knowledge management system that support delivery of this service.' ;
    rdfs:domain ind:LegalService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matterTypeMapping rdf:type rdf:Property ;
    rdfs:label 'Matter Type Mapping' ;
    rdfs:comment 'Comma-separated list of matter types in the practice management system that typically utilize this service offering. Enables service-to-matter linkage for analytics and cross-selling.' ;
    rdfs:domain ind:LegalService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredExpertiseLevel rdf:type rdf:Property ;
    rdfs:label 'Required Expertise Level' ;
    rdfs:comment 'Minimum attorney seniority or expertise level required to lead delivery of this service. Used for resource allocation, staffing decisions, and quality assurance.' ;
    rdfs:domain ind:LegalService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresKyc rdf:type rdf:Property ;
    rdfs:label 'Requires Kyc' ;
    rdfs:comment 'Indicates whether this service offering requires Know Your Client (KYC) and Anti-Money Laundering (AML) verification before engagement. Ensures compliance with Financial Action Task Force (FATF) standards.' ;
    rdfs:domain ind:LegalService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceCategory rdf:type rdf:Property ;
    rdfs:label 'Service Category' ;
    rdfs:comment 'Commercial category of the service offering indicating complexity, customization level, and typical engagement model. Used for pricing strategy and client segmentation.' ;
    rdfs:domain ind:LegalService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceCode rdf:type rdf:Property ;
    rdfs:label 'Service Code' ;
    rdfs:comment 'Unique alphanumeric code identifying the service offering in business development systems, Request for Proposal (RFP) responses, and Letter of Engagement (LOE) documents. Used as the external business identifier.' ;
    rdfs:domain ind:LegalService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceDescription rdf:type rdf:Property ;
    rdfs:label 'Service Description' ;
    rdfs:comment 'Detailed description of the legal service offering, including scope, deliverables, typical activities, and value proposition. Used in RFP responses and client presentations.' ;
    rdfs:domain ind:LegalService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceName rdf:type rdf:Property ;
    rdfs:label 'Service Name' ;
    rdfs:comment 'Full business name of the legal service offering as presented to clients and used in marketing materials, RFP responses, and engagement letters.' ;
    rdfs:domain ind:LegalService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceStatus rdf:type rdf:Property ;
    rdfs:label 'Service Status' ;
    rdfs:comment 'Current lifecycle status of the service offering. Controls visibility in business development systems, RFP response tools, and client-facing service catalogs.' ;
    rdfs:domain ind:LegalService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceType rdf:type rdf:Property ;
    rdfs:label 'Service Type' ;
    rdfs:comment 'Classification of the service by delivery model and nature of legal work performed. Distinguishes between advisory, transactional, contentious, and support services.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaDeliveryTimeDays rdf:type rdf:Property ;
    rdfs:label 'Sla Delivery Time Days' ;
    rdfs:comment 'Committed delivery timeframe in business days from engagement to completion, as defined in Service Level Agreement (SLA) terms. Used in client commitments and matter planning.' ;
    rdfs:domain ind:LegalService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:technologyRequirements rdf:type rdf:Property ;
    rdfs:label 'Technology Requirements' ;
    rdfs:comment 'Comma-separated list of specialized technology platforms or tools required to deliver this service. Examples include eDiscovery platforms, contract lifecycle management systems, legal research databases, or document automation tools.' ;
    rdfs:domain ind:LegalService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utbmsTaskCodes rdf:type rdf:Property ;
    rdfs:label 'Utbms Task Codes' ;
    rdfs:comment 'Comma-separated list of Uniform Task-Based Management System (UTBMS) task codes associated with this service offering. Used for time entry classification, billing, and client reporting in LEDES format.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:afaModelsSupported rdf:type rdf:Property ;
    rdfs:label 'Afa Models Supported' ;
    rdfs:comment 'Comma-separated list of AFA models supported for this tier (e.g., Fixed Fee, Capped Fee, Blended Rate, Success Fee, Retainer). Used in pricing discussions and engagement structuring.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedByPartner rdf:type rdf:Property ;
    rdfs:label 'Approved By Partner' ;
    rdfs:comment 'Name or identifier of the partner who approved this service tier configuration. Used for governance and accountability.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseHourlyRate rdf:type rdf:Property ;
    rdfs:label 'Base Hourly Rate' ;
    rdfs:comment 'Standard hourly billing rate for this tier in the firm\'s base currency. Used as the starting point for rate negotiations and engagement pricing. May vary by timekeeper seniority within the tier.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conflictCheckLevel rdf:type rdf:Property ;
    rdfs:label 'Conflict Check Level' ;
    rdfs:comment 'Level of conflict checking required for engagements under this tier (standard, enhanced, comprehensive). Higher tiers may require more rigorous conflict analysis and ethical wall procedures.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentRetentionYears rdf:type rdf:Property ;
    rdfs:label 'Document Retention Years' ;
    rdfs:comment 'Minimum document retention period in years for matters under this tier, as required by regulatory obligations and professional standards. Used in records management and DMS configuration.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:includedDeliverables rdf:type rdf:Property ;
    rdfs:label 'Included Deliverables' ;
    rdfs:comment 'Comma-separated or structured list of standard deliverables included in the tier (e.g., legal opinions, memoranda, contract drafts, compliance checklists). Used in RFP responses and engagement scoping.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceCoverageRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Insurance Coverage Required Flag' ;
    rdfs:comment 'Indicates whether specific professional indemnity insurance coverage or coverage limits are required for engagements under this tier. True if additional coverage is mandatory; False otherwise.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kycAmlLevel rdf:type rdf:Property ;
    rdfs:label 'Kyc Aml Level' ;
    rdfs:comment 'Level of KYC and AML due diligence required for clients engaging under this tier (basic, standard, enhanced, high_risk). Higher tiers or higher-risk practice areas may require enhanced due diligence.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User' ;
    rdfs:comment 'Username or identifier of the user who last modified this service tier record. Used for audit trail and accountability.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumEngagementValue rdf:type rdf:Property ;
    rdfs:label 'Maximum Engagement Value' ;
    rdfs:comment 'Maximum total engagement value or cap applicable to this tier (if any). Null for uncapped tiers. Used in pricing and risk management.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumEngagementValue rdf:type rdf:Property ;
    rdfs:label 'Minimum Engagement Value' ;
    rdfs:comment 'Minimum total engagement value or retainer amount required to qualify for this tier. Used in client segmentation and engagement acceptance decisions.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partnerApprovalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Partner Approval Required Flag' ;
    rdfs:comment 'Indicates whether partner-level approval is required to assign a matter to this tier. True if approval is mandatory; False if associates or practice managers can assign. Used in engagement workflow and governance.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responseTimeCommitmentHours rdf:type rdf:Property ;
    rdfs:label 'Response Time Commitment Hours' ;
    rdfs:comment 'Maximum response time commitment in hours for initial client inquiries or urgent requests under this tier. Forms part of the Service Level Agreement (SLA) terms.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scopeOfCoverage rdf:type rdf:Property ;
    rdfs:label 'Scope Of Coverage' ;
    rdfs:comment 'Detailed definition of the legal services and deliverables included in this tier (e.g., advisory opinions, document review, representation in proceedings, regulatory filings). Used to set client expectations and scope engagement letters (LOE).' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTerms rdf:type rdf:Property ;
    rdfs:label 'Sla Terms' ;
    rdfs:comment 'Full text or reference to the Service Level Agreement (SLA) terms applicable to this tier, including response times, escalation procedures, and performance guarantees. Used in engagement letters (LOE) and client contracts.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierCode rdf:type rdf:Property ;
    rdfs:label 'Tier Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the service tier (e.g., STD, PREM, ENT, BESPOKE). Used in system integrations and billing configurations.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierDescription rdf:type rdf:Property ;
    rdfs:label 'Tier Description' ;
    rdfs:comment 'Detailed description of the service tier, including scope of coverage, key differentiators, and target client segments. Used in business development materials and RFP responses.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierLevel rdf:type rdf:Property ;
    rdfs:label 'Tier Level' ;
    rdfs:comment 'Numeric ranking of the tier within the service hierarchy (e.g., 1=Standard, 2=Premium, 3=Enterprise, 4=Bespoke). Used for sorting and eligibility logic.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tierName rdf:type rdf:Property ;
    rdfs:label 'Tier Name' ;
    rdfs:comment 'Full business name of the service tier (e.g., Standard, Premium, Enterprise, Bespoke). Used in client-facing documents, RFPs, and engagement letters (LOE).' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierStatus rdf:type rdf:Property ;
    rdfs:label 'Tier Status' ;
    rdfs:comment 'Current lifecycle status of the service tier. Active tiers are available for new engagements; deprecated tiers are honored for existing matters but not offered to new clients.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:advancePaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Advance Payment Amount' ;
    rdfs:comment 'Required advance payment or retainer deposit amount. Null if no advance payment is required.' ;
    rdfs:domain ind:PricingModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:advancePaymentRequired rdf:type rdf:Property ;
    rdfs:label 'Advance Payment Required' ;
    rdfs:comment 'Flag indicating whether an advance payment or retainer deposit is required before work commences under this pricing model. True = advance required; False = no advance.' ;
    rdfs:domain ind:PricingModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:afaIndicator rdf:type rdf:Property ;
    rdfs:label 'Afa Indicator' ;
    rdfs:comment 'Flag indicating whether this pricing model represents an Alternative Fee Arrangement (non-traditional hourly billing). True = AFA; False = traditional hourly.' ;
    rdfs:domain ind:PricingModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:baseRateAmount rdf:type rdf:Property ;
    rdfs:label 'Base Rate Amount' ;
    rdfs:comment 'The standard rate amount for this pricing model. For hourly models, this is the hourly rate; for fixed fee, this is the base fee amount. Null if rate varies by timekeeper or matter.' ;
    rdfs:domain ind:PricingModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingIncrementMinutes rdf:type rdf:Property ;
    rdfs:label 'Billing Increment Minutes' ;
    rdfs:comment 'Time increment used for rounding billable time entries (e.g., 6 minutes = 0.1 hour, 15 minutes = 0.25 hour). Common values: 6, 10, 15.' ;
    rdfs:domain ind:PricingModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:blendedRateAmount rdf:type rdf:Property ;
    rdfs:label 'Blended Rate Amount' ;
    rdfs:comment 'Single averaged hourly rate applied across all timekeepers on a matter, regardless of individual seniority. Used in blended rate pricing models.' ;
    rdfs:domain ind:PricingModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calculationBasis rdf:type rdf:Property ;
    rdfs:label 'Calculation Basis' ;
    rdfs:comment 'The foundational method used to calculate fees under this model. Time-based = hours worked; Matter-based = per matter/case; Transaction Value = percentage of deal value; Outcome-based = tied to result; Hybrid = combination of methods.' ;
    rdfs:domain ind:PricingModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contingencyPercentage rdf:type rdf:Property ;
    rdfs:label 'Contingency Percentage' ;
    rdfs:comment 'The percentage of recovery or transaction value that constitutes the fee for contingency-based pricing models. Null for non-contingency models.' ;
    rdfs:domain ind:PricingModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discountPercentage rdf:type rdf:Property ;
    rdfs:label 'Discount Percentage' ;
    rdfs:comment 'Standard discount percentage applied to standard rates under this pricing model. Null if no discount applies.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expenseMarkupPercentage rdf:type rdf:Property ;
    rdfs:label 'Expense Markup Percentage' ;
    rdfs:comment 'Percentage markup applied to reimbursable expenses (e.g., 10% administrative fee on disbursements). Null if no markup applies.' ;
    rdfs:domain ind:PricingModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expenseReimbursementPolicy rdf:type rdf:Property ;
    rdfs:label 'Expense Reimbursement Policy' ;
    rdfs:comment 'Policy governing how disbursements and expenses are handled under this pricing model. Full = all expenses billed separately; Capped = expenses up to limit; Included = expenses absorbed in fee; No Reimbursement = client pays directly.' ;
    rdfs:domain ind:PricingModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:latePaymentInterestRate rdf:type rdf:Property ;
    rdfs:label 'Late Payment Interest Rate' ;
    rdfs:comment 'Annual interest rate applied to overdue invoices under this pricing model. Null if no late payment interest applies.' ;
    rdfs:domain ind:PricingModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Fee Amount' ;
    rdfs:comment 'The maximum fee cap for capped fee arrangements. Fees will not exceed this amount regardless of time spent. Null if no cap applies.' ;
    rdfs:domain ind:PricingModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Fee Amount' ;
    rdfs:comment 'The minimum fee that will be charged under this pricing model, regardless of time or effort expended. Null if no minimum applies.' ;
    rdfs:domain ind:PricingModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modelCode rdf:type rdf:Property ;
    rdfs:label 'Model Code' ;
    rdfs:comment 'Business identifier code for the pricing model, used in billing systems and client communications.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelName rdf:type rdf:Property ;
    rdfs:label 'Model Name' ;
    rdfs:comment 'Human-readable name of the pricing model (e.g., \'Standard Hourly Billing\', \'Fixed Fee M&A Advisory\', \'Blended Rate Litigation\').' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelType rdf:type rdf:Property ;
    rdfs:label 'Model Type' ;
    rdfs:comment 'Classification of the fee structure type. Hourly = time-based billing; Fixed Fee = predetermined amount; Capped Fee = hourly with maximum limit; Blended Rate = averaged rate across timekeepers; Retainer = recurring periodic fee; Contingency = success-based percentage.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingModelDescription rdf:type rdf:Property ;
    rdfs:label 'Pricing Model Description' ;
    rdfs:comment 'Detailed description of the pricing model, including its intended use cases, calculation methodology, and any special terms or conditions.' ;
    rdfs:domain ind:PricingModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingModelStatus rdf:type rdf:Property ;
    rdfs:label 'Pricing Model Status' ;
    rdfs:comment 'Current lifecycle status of the pricing model. Active = in use; Inactive = not available for new matters; Draft = under development; Archived = historical; Under Review = pending approval; Approved = ready for activation.' ;
    rdfs:domain ind:PricingModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Rate Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the rate amount (e.g., USD, GBP, EUR).' ;
    rdfs:domain ind:PricingModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retainerFrequency rdf:type rdf:Property ;
    rdfs:label 'Retainer Frequency' ;
    rdfs:comment 'Billing frequency for retainer-based pricing models. Indicates how often the retainer fee is charged.' ;
    rdfs:domain ind:PricingModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaResolutionTimeDays rdf:type rdf:Property ;
    rdfs:label 'Sla Resolution Time Days' ;
    rdfs:comment 'Target resolution or delivery time in days for matters under this pricing model. Part of service level commitments.' ;
    rdfs:domain ind:PricingModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryRatePracticeAreaId rdf:type rdf:Property ;
    rdfs:label 'Primary Rate Practice Area Id' ;
    rdfs:comment 'Foreign key linking to service.practice_area. Business justification: Rate cards are scoped by practice area. Normalize by linking to practice_area master. Remove practice_area_name as it can be retrieved via JOIN to practice_area.name.' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PracticeArea .

ind:ratePracticeAreaId rdf:type rdf:Property ;
    rdfs:label 'Rate Practice Area Id' ;
    rdfs:comment 'FK to service.practice_area.practice_area_id — Rate cards are structured by practice area (litigation rates differ from corporate rates). This is a fundamental billing configuration relationship.' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PracticeArea .

ind:supersededByRateCardId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Rate Card Id' ;
    rdfs:comment 'Reference to the rate card that supersedes this one. Null if this is the current active rate card.' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RateCard .

ind:clientSegment rdf:type rdf:Property ;
    rdfs:label 'Client Segment' ;
    rdfs:comment 'Classification of the client segment to which this rate applies (e.g., Fortune 500, mid-market, small business, government, non-profit, individual).' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDefaultRate rdf:type rdf:Property ;
    rdfs:label 'Is Default Rate' ;
    rdfs:comment 'Boolean flag indicating whether this is the default rate to be applied when no client-specific or matter-specific rate is defined (True = default, False = not default).' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minimumChargeIncrementMinutes rdf:type rdf:Property ;
    rdfs:label 'Minimum Charge Increment Minutes' ;
    rdfs:comment 'Minimum time increment for billing purposes (e.g., 6 minutes for 0.1 hour increments, 15 minutes for 0.25 hour increments). Used in time entry rounding.' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rateCardDescription rdf:type rdf:Property ;
    rdfs:label 'Rate Card Description' ;
    rdfs:comment 'Detailed description of the rate card, including its purpose, scope, and any special terms or conditions.' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCardName rdf:type rdf:Property ;
    rdfs:label 'Rate Card Name' ;
    rdfs:comment 'Descriptive name or label for this rate card (e.g., \'2024 Standard Corporate Rates\', \'Client XYZ Preferred Rates\', \'Litigation Blended Rate\').' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seniorityLevel rdf:type rdf:Property ;
    rdfs:label 'Seniority Level' ;
    rdfs:comment 'Seniority classification of the timekeeper (e.g., equity partner, non-equity partner, of counsel, senior associate, mid-level associate, junior associate, paralegal, legal assistant, contract attorney). [ENUM-REF-CANDIDATE: equity_partner|non_equity_partner|of_counsel|senior_associate|mid_level_associate|junior_associate|paralegal|legal_assistant|contract_attorney — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availabilityCommitment rdf:type rdf:Property ;
    rdfs:label 'Availability Commitment' ;
    rdfs:comment 'Timekeeper availability commitment specified in the SLA (e.g., 24/7 emergency access, business hours only, named partner availability).' ;
    rdfs:domain ind:SlaTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachCount rdf:type rdf:Property ;
    rdfs:label 'Breach Count' ;
    rdfs:comment 'Historical count of SLA breaches across all matters using this template, used for template refinement and risk assessment.' ;
    rdfs:domain ind:SlaTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:breachThresholdPercentage rdf:type rdf:Property ;
    rdfs:label 'Breach Threshold Percentage' ;
    rdfs:comment 'Percentage threshold over target time that constitutes an SLA breach (e.g., 110.00 means 10% over target triggers breach).' ;
    rdfs:domain ind:SlaTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:communicationProtocol rdf:type rdf:Property ;
    rdfs:label 'Communication Protocol' ;
    rdfs:comment 'Specified communication channels and protocols for SLA-governed matters (e.g., email, secure portal, phone, video conference, encrypted messaging).' ;
    rdfs:domain ind:SlaTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationThreshold rdf:type rdf:Property ;
    rdfs:label 'Escalation Threshold' ;
    rdfs:comment 'Threshold value (in same unit as response/turnaround time) at which SLA breach triggers escalation to senior counsel or practice group leader.' ;
    rdfs:domain ind:SlaTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:escalationUnit rdf:type rdf:Property ;
    rdfs:label 'Escalation Unit' ;
    rdfs:comment 'Unit of measure for escalation threshold: hours, business days, or calendar days.' ;
    rdfs:domain ind:SlaTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matterComplexity rdf:type rdf:Property ;
    rdfs:label 'Matter Complexity' ;
    rdfs:comment 'Target matter complexity level for which this SLA template is appropriate, enabling proper SLA-to-matter matching.' ;
    rdfs:domain ind:SlaTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityStandard rdf:type rdf:Property ;
    rdfs:label 'Quality Standard' ;
    rdfs:comment 'Description of the quality standards and deliverable expectations associated with this SLA template (e.g., peer review required, cite-checking standards, document formatting requirements).' ;
    rdfs:domain ind:SlaTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Flag' ;
    rdfs:comment 'Indicates whether this SLA template includes specific regulatory compliance commitments (e.g., GDPR response times, SOX filing deadlines, CCPA data subject request turnaround).' ;
    rdfs:domain ind:SlaTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remediationTerms rdf:type rdf:Property ;
    rdfs:label 'Remediation Terms' ;
    rdfs:comment 'Contractual remediation terms and client remedies in the event of SLA breach (e.g., fee reduction, credit, expedited service on next matter).' ;
    rdfs:domain ind:SlaTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseTimeTarget rdf:type rdf:Property ;
    rdfs:label 'Response Time Target' ;
    rdfs:comment 'Target response time commitment in the unit specified by response_time_unit (e.g., 24 hours for initial client inquiry response).' ;
    rdfs:domain ind:SlaTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responseTimeUnit rdf:type rdf:Property ;
    rdfs:label 'Response Time Unit' ;
    rdfs:comment 'Unit of measure for response time target: hours, business days, or calendar days.' ;
    rdfs:domain ind:SlaTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaType rdf:type rdf:Property ;
    rdfs:label 'Sla Type' ;
    rdfs:comment 'Classification of the SLA template by commitment category: matter response time, document turnaround, court filing deadline adherence, regulatory submission timeliness, client communication response, or legal research delivery.' ;
    rdfs:domain ind:SlaTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:turnaroundTimeTarget rdf:type rdf:Property ;
    rdfs:label 'Turnaround Time Target' ;
    rdfs:comment 'Target turnaround time for deliverable completion in the unit specified by turnaround_time_unit (e.g., 5 business days for contract review).' ;
    rdfs:domain ind:SlaTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:turnaroundTimeUnit rdf:type rdf:Property ;
    rdfs:label 'Turnaround Time Unit' ;
    rdfs:comment 'Unit of measure for turnaround time target: hours, business days, calendar days, or weeks.' ;
    rdfs:domain ind:SlaTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primarySupersededByPackageId rdf:type rdf:Property ;
    rdfs:label 'Primary Superseded By Package Id' ;
    rdfs:comment 'Reference to the newer service package that replaces this one, enabling version lineage tracking and client migration paths.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Package .

ind:averageEngagementValue rdf:type rdf:Property ;
    rdfs:label 'Average Engagement Value' ;
    rdfs:comment 'Average revenue per engagement for this service package calculated from historical billing data. Used for forecasting and business development.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:basePriceAmount rdf:type rdf:Property ;
    rdfs:label 'Base Price Amount' ;
    rdfs:comment 'Standard base price for the service package before any client-specific adjustments or discounts. Used as starting point for pricing negotiations.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:crossSellEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Cross Sell Eligible Flag' ;
    rdfs:comment 'Indicates whether this package is eligible for cross-selling to existing clients with other active engagements. True = eligible for cross-sell campaigns.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:documentManagementRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Document Management Required Flag' ;
    rdfs:comment 'Indicates whether this package requires use of firm DMS (iManage Work or NetDocuments) for document storage, version control, and collaboration.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:includesEdiscoveryFlag rdf:type rdf:Property ;
    rdfs:label 'Includes Ediscovery Flag' ;
    rdfs:comment 'Indicates whether the package includes electronic discovery services using platforms such as Relativity for document review and production.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:includesLegalResearchFlag rdf:type rdf:Property ;
    rdfs:label 'Includes Legal Research Flag' ;
    rdfs:comment 'Indicates whether the package includes access to legal research platforms such as LexisNexis or Thomson Reuters Practical Law.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketingCollateralUrl rdf:type rdf:Property ;
    rdfs:label 'Marketing Collateral Url' ;
    rdfs:comment 'URL or document path to client-facing marketing materials, brochures, or pitch decks for this service package.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumEngagementTermMonths rdf:type rdf:Property ;
    rdfs:label 'Minimum Engagement Term Months' ;
    rdfs:comment 'Minimum commitment period in months required for this package. Null indicates no minimum term requirement.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:packageCode rdf:type rdf:Property ;
    rdfs:label 'Package Code' ;
    rdfs:comment 'Externally-known unique business identifier for the service package used in RFP responses, client proposals, and billing systems.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageDescription rdf:type rdf:Property ;
    rdfs:label 'Package Description' ;
    rdfs:comment 'Detailed description of the service package scope, objectives, and value proposition for client-facing materials and internal knowledge management.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageName rdf:type rdf:Property ;
    rdfs:label 'Package Name' ;
    rdfs:comment 'Human-readable name of the service package (e.g., Corporate Governance Bundle, M&A Full-Service Package, IP Portfolio Management Suite).' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageType rdf:type rdf:Property ;
    rdfs:label 'Package Type' ;
    rdfs:comment 'Classification of the service package structure determining engagement model and delivery approach.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingBasis rdf:type rdf:Property ;
    rdfs:label 'Pricing Basis' ;
    rdfs:comment 'Pricing model for the package. AFA = Alternative Fee Arrangement. Determines how the package is billed to clients.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresConflictCheckFlag rdf:type rdf:Property ;
    rdfs:label 'Requires Conflict Check Flag' ;
    rdfs:comment 'Indicates whether engagement under this package mandates formal conflict checking through Intapp Conflicts or equivalent system before matter intake.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresKycFlag rdf:type rdf:Property ;
    rdfs:label 'Requires Kyc Flag' ;
    rdfs:comment 'Indicates whether this package requires formal KYC and AML compliance checks before engagement commencement per regulatory obligations.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalEngagementsCount rdf:type rdf:Property ;
    rdfs:label 'Total Engagements Count' ;
    rdfs:comment 'Cumulative count of client engagements or matters that have utilized this service package since inception. Used for performance tracking.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryJurisdictionLegalServiceId rdf:type rdf:Property ;
    rdfs:label 'Primary Jurisdiction Legal Service Id' ;
    rdfs:comment 'Reference to the legal service offering for which this jurisdiction coverage applies.' ;
    rdfs:domain ind:JurisdictionCoverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalService .

ind:admissionRequired rdf:type rdf:Property ;
    rdfs:label 'Admission Required' ;
    rdfs:comment 'Indicates whether formal admission or bar membership is required to practice in this jurisdiction.' ;
    rdfs:domain ind:JurisdictionCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:admissionRequirements rdf:type rdf:Property ;
    rdfs:label 'Admission Requirements' ;
    rdfs:comment 'Detailed description of admission or licensing requirements for practicing in this jurisdiction (e.g., bar exam, character and fitness review, Continuing Legal Education requirements).' ;
    rdfs:domain ind:JurisdictionCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amlKycComplianceAvailable rdf:type rdf:Property ;
    rdfs:label 'Aml Kyc Compliance Available' ;
    rdfs:comment 'Indicates whether AML and KYC compliance counseling services are available in this jurisdiction.' ;
    rdfs:domain ind:JurisdictionCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:courtAccessLevel rdf:type rdf:Property ;
    rdfs:label 'Court Access Level' ;
    rdfs:comment 'Level of court access available in this jurisdiction: full (can appear in all courts), limited (specific courts only), none (no court appearances), advisory_only (counsel only, no litigation).' ;
    rdfs:domain ind:JurisdictionCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageNotes rdf:type rdf:Property ;
    rdfs:label 'Coverage Notes' ;
    rdfs:comment 'Additional notes, comments, or guidance regarding service coverage in this jurisdiction, including special considerations, recent regulatory changes, or operational caveats.' ;
    rdfs:domain ind:JurisdictionCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageStatus rdf:type rdf:Property ;
    rdfs:label 'Coverage Status' ;
    rdfs:comment 'Current status of service coverage in this jurisdiction. Active indicates full service availability; restricted indicates limited scope; suspended indicates temporary unavailability.' ;
    rdfs:domain ind:JurisdictionCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataPrivacyComplianceScope rdf:type rdf:Property ;
    rdfs:label 'Data Privacy Compliance Scope' ;
    rdfs:comment 'Description of data privacy and protection compliance counseling available in this jurisdiction (e.g., GDPR, CCPA, DPA, sector-specific privacy laws).' ;
    rdfs:domain ind:JurisdictionCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ecfAccess rdf:type rdf:Property ;
    rdfs:label 'Ecf Access' ;
    rdfs:comment 'Indicates whether the firm has Electronic Case Filing access in this jurisdiction for federal or state court filings.' ;
    rdfs:domain ind:JurisdictionCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:internationalArbitrationVenue rdf:type rdf:Property ;
    rdfs:label 'International Arbitration Venue' ;
    rdfs:comment 'Indicates whether this jurisdiction is recognized as an international arbitration venue under ICC, LCIA, or other international arbitration frameworks.' ;
    rdfs:domain ind:JurisdictionCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ipPortfolioManagementAvailable rdf:type rdf:Property ;
    rdfs:label 'Ip Portfolio Management Available' ;
    rdfs:comment 'Indicates whether IP portfolio management services (patent, trademark, copyright prosecution and maintenance) are available in this jurisdiction.' ;
    rdfs:domain ind:JurisdictionCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jurisdictionalRestrictions rdf:type rdf:Property ;
    rdfs:label 'Jurisdictional Restrictions' ;
    rdfs:comment 'Detailed description of any restrictions, caveats, or limitations on service delivery in this jurisdiction (e.g., cannot appear in court, advisory only, regulatory compliance counseling excluded).' ;
    rdfs:domain ind:JurisdictionCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageRequirements rdf:type rdf:Property ;
    rdfs:label 'Language Requirements' ;
    rdfs:comment 'Languages in which legal services must or can be delivered in this jurisdiction (e.g., English, French, Spanish). Relevant for multi-lingual jurisdictions or international matters.' ;
    rdfs:domain ind:JurisdictionCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localCounselNotes rdf:type rdf:Property ;
    rdfs:label 'Local Counsel Notes' ;
    rdfs:comment 'Additional notes or guidance on local counsel requirements, including circumstances when local counsel may be waived or specific qualifications needed.' ;
    rdfs:domain ind:JurisdictionCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localCounselRequired rdf:type rdf:Property ;
    rdfs:label 'Local Counsel Required' ;
    rdfs:comment 'Indicates whether local counsel must be engaged for matters in this jurisdiction when the primary attorney is not admitted.' ;
    rdfs:domain ind:JurisdictionCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:matterStaffingPriority rdf:type rdf:Property ;
    rdfs:label 'Matter Staffing Priority' ;
    rdfs:comment 'Priority ranking for staffing matters in this jurisdiction (1 = highest priority, higher numbers = lower priority). Used for multi-jurisdictional matter staffing decisions.' ;
    rdfs:domain ind:JurisdictionCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:multiJurisdictionalFlag rdf:type rdf:Property ;
    rdfs:label 'Multi Jurisdictional Flag' ;
    rdfs:comment 'Indicates whether this coverage is part of a multi-jurisdictional service offering spanning multiple states, provinces, or countries.' ;
    rdfs:domain ind:JurisdictionCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pacerAccess rdf:type rdf:Property ;
    rdfs:label 'Pacer Access' ;
    rdfs:comment 'Indicates whether the firm has PACER access for retrieving court records in this jurisdiction.' ;
    rdfs:domain ind:JurisdictionCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:patentBarRequired rdf:type rdf:Property ;
    rdfs:label 'Patent Bar Required' ;
    rdfs:comment 'Indicates whether patent bar admission (USPTO registration for patent prosecution) is required for IP services in this jurisdiction.' ;
    rdfs:domain ind:JurisdictionCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:proHacViceAvailable rdf:type rdf:Property ;
    rdfs:label 'Pro Hac Vice Available' ;
    rdfs:comment 'Indicates whether pro hac vice admission (temporary admission for a specific case) is available in this jurisdiction for attorneys not admitted to the local bar.' ;
    rdfs:domain ind:JurisdictionCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:proHacViceRequirements rdf:type rdf:Property ;
    rdfs:label 'Pro Hac Vice Requirements' ;
    rdfs:comment 'Description of requirements and procedures for obtaining pro hac vice admission in this jurisdiction (e.g., motion filing, local counsel sponsorship, fee payment).' ;
    rdfs:domain ind:JurisdictionCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryComplianceScope rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Scope' ;
    rdfs:comment 'Description of the regulatory compliance counseling scope available in this jurisdiction (e.g., GDPR compliance, SOX advisory, AML counseling, sector-specific regulations).' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfpEligible rdf:type rdf:Property ;
    rdfs:label 'Rfp Eligible' ;
    rdfs:comment 'Indicates whether this jurisdiction coverage qualifies the firm to respond to RFPs requiring service delivery in this jurisdiction.' ;
    rdfs:domain ind:JurisdictionCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:updatedBy rdf:type rdf:Property ;
    rdfs:label 'Updated By' ;
    rdfs:comment 'Identifier of the user or system that last updated this jurisdiction coverage record.' ;
    rdfs:domain ind:JurisdictionCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableServiceTypes rdf:type rdf:Property ;
    rdfs:label 'Applicable Service Types' ;
    rdfs:comment 'Comma-separated list of service type codes or names that can be delivered using this model (e.g., advisory, transactional, dispute_resolution, compliance_counseling).' ;
    rdfs:domain ind:DeliveryModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityUtilizationTargetPct rdf:type rdf:Property ;
    rdfs:label 'Capacity Utilization Target Pct' ;
    rdfs:comment 'Target utilization rate (percentage of billable hours to total available hours) for resources operating under this delivery model, used for capacity planning and profitability analysis.' ;
    rdfs:domain ind:DeliveryModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clientInteractionModel rdf:type rdf:Property ;
    rdfs:label 'Client Interaction Model' ;
    rdfs:comment 'Level and frequency of direct client engagement: high_touch (frequent partner/senior attorney interaction), medium_touch (periodic check-ins), low_touch (minimal direct contact), self_service (client portal-driven), or hybrid (varies by phase).' ;
    rdfs:domain ind:DeliveryModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costStructureBasis rdf:type rdf:Property ;
    rdfs:label 'Cost Structure Basis' ;
    rdfs:comment 'Primary pricing and cost structure associated with this delivery model: hourly_rate (traditional billable hour), fixed_fee (project-based), capped_fee (not-to-exceed), contingency (success-based), retainer (ongoing access), subscription (periodic flat fee), outcome_based (performance-linked), or blended_rate (averaged hourly rate across team). [ENUM-REF-CANDIDATE: hourly_rate|fixed_fee|capped_fee|contingency|retainer|subscription|outcome_based|blended_rate — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DeliveryModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSecurityTier rdf:type rdf:Property ;
    rdfs:label 'Data Security Tier' ;
    rdfs:comment 'Level of data security and confidentiality controls applied to this delivery model: standard (baseline firm security), enhanced (additional encryption and access controls), maximum (air-gapped or highly restricted), client_specific (bespoke security per client requirements).' ;
    rdfs:domain ind:DeliveryModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryModelDescription rdf:type rdf:Property ;
    rdfs:label 'Delivery Model Description' ;
    rdfs:comment 'Detailed narrative description of the delivery model, including operational characteristics, typical use cases, and distinguishing features.' ;
    rdfs:domain ind:DeliveryModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryModelStatus rdf:type rdf:Property ;
    rdfs:label 'Delivery Model Status' ;
    rdfs:comment 'Current lifecycle status of the delivery model: active (in production use), inactive (temporarily suspended), pilot (under trial), deprecated (phasing out), retired (no longer offered).' ;
    rdfs:domain ind:DeliveryModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ethicalWallSupport rdf:type rdf:Property ;
    rdfs:label 'Ethical Wall Support' ;
    rdfs:comment 'Indicates whether this delivery model supports the establishment of ethical walls (information barriers) to manage conflicts of interest (True for models with segregated teams, False for fully integrated teams).' ;
    rdfs:domain ind:DeliveryModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fteRequirementMax rdf:type rdf:Property ;
    rdfs:label 'Fte Requirement Max' ;
    rdfs:comment 'Maximum number of full-time equivalent staff typically allocated to this delivery model for scalability planning.' ;
    rdfs:domain ind:DeliveryModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fteRequirementMin rdf:type rdf:Property ;
    rdfs:label 'Fte Requirement Min' ;
    rdfs:comment 'Minimum number of full-time equivalent staff required to operate this delivery model effectively for a typical engagement.' ;
    rdfs:domain ind:DeliveryModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:innovationMaturity rdf:type rdf:Property ;
    rdfs:label 'Innovation Maturity' ;
    rdfs:comment 'Maturity level of innovation and technology adoption in this delivery model: traditional (established methods), emerging (adopting new tools), innovative (leading-edge practices), cutting_edge (experimental or pioneering approaches).' ;
    rdfs:domain ind:DeliveryModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredMatterSize rdf:type rdf:Property ;
    rdfs:label 'Preferred Matter Size' ;
    rdfs:comment 'Optimal matter or engagement size for which this delivery model is best suited: small (low-value, short-duration), medium (moderate complexity and duration), large (high-value, extended engagement), enterprise (multi-year, strategic), or any (flexible across all sizes).' ;
    rdfs:domain ind:DeliveryModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryDeliveryGeography rdf:type rdf:Property ;
    rdfs:label 'Primary Delivery Geography' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the primary geographic location from which services are delivered (e.g., USA, GBR, IND for offshore centers).' ;
    rdfs:domain ind:DeliveryModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityAssuranceApproach rdf:type rdf:Property ;
    rdfs:label 'Quality Assurance Approach' ;
    rdfs:comment 'Primary quality control mechanism for work delivered under this model: partner_review (senior attorney sign-off), peer_review (colleague validation), automated_qa (technology-driven checks), external_audit (third-party review), iso_certified (ISO 9001 quality management), or none (no formal QA).' ;
    rdfs:domain ind:DeliveryModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resourceComposition rdf:type rdf:Property ;
    rdfs:label 'Resource Composition' ;
    rdfs:comment 'Textual description of the typical team composition, including ratios of partners, associates, paralegals, legal technologists, and support staff (e.g., 1 partner : 3 associates : 2 paralegals).' ;
    rdfs:domain ind:DeliveryModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scalabilityRating rdf:type rdf:Property ;
    rdfs:label 'Scalability Rating' ;
    rdfs:comment 'Assessment of how easily this delivery model can scale up or down to meet fluctuating demand: low (fixed team, limited flexibility), medium (moderate scaling with lead time), high (rapid scaling capability), elastic (on-demand scaling with minimal lead time).' ;
    rdfs:domain ind:DeliveryModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTurnaroundTimeDays rdf:type rdf:Property ;
    rdfs:label 'Sla Turnaround Time Days' ;
    rdfs:comment 'Standard turnaround time commitment in business days for deliverable completion under this delivery model, as defined in typical Service Level Agreements (SLAs).' ;
    rdfs:domain ind:DeliveryModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:staffingModel rdf:type rdf:Property ;
    rdfs:label 'Staffing Model' ;
    rdfs:comment 'Defines the primary resource composition and leadership structure: partner-led (senior attorney oversight), associate-led (mid-level attorney execution), paralegal-led (support-staff driven), mixed-tier (blended seniority), offshore/nearshore/onshore (geographic staffing), or client-site (embedded at client location). [ENUM-REF-CANDIDATE: partner_led|associate_led|paralegal_led|mixed_tier|offshore|nearshore|onshore|client_site — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DeliveryModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technologyEnablement rdf:type rdf:Property ;
    rdfs:label 'Technology Enablement' ;
    rdfs:comment 'Degree of technology integration in the delivery model: manual (minimal tech), standard_tools (DMS and research platforms), advanced_automation (workflow automation and RPA), ai_assisted (AI/ML for document review, contract analysis), or full_digital (end-to-end digital delivery).' ;
    rdfs:domain ind:DeliveryModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientTypeFilter rdf:type rdf:Property ;
    rdfs:label 'Client Type Filter' ;
    rdfs:comment 'Pipe-separated list of client types to which this rule applies (e.g., \'corporate|government\', \'individual\', \'nonprofit\'). Empty if rule applies to all client types. [ENUM-REF-CANDIDATE: corporate|government|individual|nonprofit|partnership|trust|estate|public_sector|private_sector — promote to reference product]' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enforcementLevel rdf:type rdf:Property ;
    rdfs:label 'Enforcement Level' ;
    rdfs:comment 'Severity of the rule enforcement: hard block (prevents engagement from proceeding without exception), advisory warning (requires partner override to proceed), or soft warning (informational only, does not block).' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationLogic rdf:type rdf:Property ;
    rdfs:label 'Evaluation Logic' ;
    rdfs:comment 'Structured expression or pseudo-code defining how the rule is evaluated during intake workflow. May reference client attributes, matter attributes, clearance outcomes, or external data sources.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industrySectorExclusion rdf:type rdf:Property ;
    rdfs:label 'Industry Sector Exclusion' ;
    rdfs:comment 'Pipe-separated list of industry sectors (e.g., NAICS or SIC codes) that are excluded from eligibility for this legal service. Empty if no sector exclusions apply.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matterValueThreshold rdf:type rdf:Property ;
    rdfs:label 'Matter Value Threshold' ;
    rdfs:comment 'Minimum estimated matter value (in base currency) required for the client or matter to qualify for the legal service. Null if no value threshold applies.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overrideAuthorityLevel rdf:type rdf:Property ;
    rdfs:label 'Override Authority Level' ;
    rdfs:comment 'The minimum authority level required to override this rule when enforcement level is advisory warning (e.g., partner, managing partner, practice group leader, general counsel). Null if rule cannot be overridden.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prerequisiteClearanceStatusRequired rdf:type rdf:Property ;
    rdfs:label 'Prerequisite Clearance Status Required' ;
    rdfs:comment 'The clearance status outcome required from the prerequisite clearance process for the rule to pass (e.g., \'approved\', \'cleared\', \'passed\'). Null if no prerequisite applies.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prerequisiteClearanceType rdf:type rdf:Property ;
    rdfs:label 'Prerequisite Clearance Type' ;
    rdfs:comment 'Type of prerequisite clearance required before the legal service can be offered: conflict check (from conflict domain), KYC (Know Your Client), AML (Anti-Money Laundering), sanctions screening, or none if no prerequisite applies.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rulePriority rdf:type rdf:Property ;
    rdfs:label 'Rule Priority' ;
    rdfs:comment 'Numeric priority for rule evaluation order when multiple rules apply to the same service. Lower numbers indicate higher priority. Used by intake workflow engine to sequence rule checks.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ruleVersion rdf:type rdf:Property ;
    rdfs:label 'Rule Version' ;
    rdfs:comment 'Version number of this eligibility rule, incremented with each substantive change to evaluation logic or enforcement parameters. Supports rule change tracking and audit.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:thresholdCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Threshold Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the matter value threshold (e.g., USD, GBP, EUR). Null if no value threshold applies.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lpmLegalServiceId rdf:type rdf:Property ;
    rdfs:label 'Lpm Legal Service Id' ;
    rdfs:comment 'FK to service.legal_service.legal_service_id — LPM templates are created for specific service types. A litigation LPM template differs fundamentally from a transactional one. This link enables correct template selection at matter opening.' ;
    rdfs:domain ind:LpmTemplate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalService .

ind:primaryLpmLegalServiceId rdf:type rdf:Property ;
    rdfs:label 'Primary Lpm Legal Service Id' ;
    rdfs:comment 'Reference to the legal service offering (e.g., M&A advisory, litigation, IP counsel) that this LPM template is designed for.' ;
    rdfs:domain ind:LpmTemplate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalService .

ind:budgetCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Budget Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the estimated budget amount (e.g., USD, GBP, EUR).' ;
    rdfs:domain ind:LpmTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientReportingFrequency rdf:type rdf:Property ;
    rdfs:label 'Client Reporting Frequency' ;
    rdfs:comment 'Standard frequency for client progress reporting defined in this template (Weekly, Bi-Weekly, Monthly, Quarterly, Milestone-Based, Ad-Hoc).' ;
    rdfs:domain ind:LpmTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complexityLevel rdf:type rdf:Property ;
    rdfs:label 'Complexity Level' ;
    rdfs:comment 'Complexity classification of matters that should use this template, indicating resource requirements and risk profile (Low, Medium, High, Very High).' ;
    rdfs:domain ind:LpmTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverableCount rdf:type rdf:Property ;
    rdfs:label 'Deliverable Count' ;
    rdfs:comment 'Total number of standard deliverables (documents, reports, opinions) defined in this template.' ;
    rdfs:domain ind:LpmTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Budget Amount' ;
    rdfs:comment 'Standard estimated budget amount for matters using this template, used for initial scoping and client proposals.' ;
    rdfs:domain ind:LpmTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedDurationDays rdf:type rdf:Property ;
    rdfs:label 'Estimated Duration Days' ;
    rdfs:comment 'Standard estimated duration in calendar days for matters following this template, from matter opening to closure.' ;
    rdfs:domain ind:LpmTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fteRequirement rdf:type rdf:Property ;
    rdfs:label 'Fte Requirement' ;
    rdfs:comment 'Estimated total Full-Time Equivalent (FTE) resource requirement for the duration of a matter using this template.' ;
    rdfs:domain ind:LpmTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:knowledgeArticleReferences rdf:type rdf:Property ;
    rdfs:label 'Knowledge Article References' ;
    rdfs:comment 'Comma-separated list of knowledge management article IDs or practice notes that support this template.' ;
    rdfs:domain ind:LpmTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneCount rdf:type rdf:Property ;
    rdfs:label 'Milestone Count' ;
    rdfs:comment 'Total number of key milestones defined across all phases in this template.' ;
    rdfs:domain ind:LpmTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:phaseCount rdf:type rdf:Property ;
    rdfs:label 'Phase Count' ;
    rdfs:comment 'Total number of project phases defined in this template (e.g., Intake, Planning, Execution, Review, Closure).' ;
    rdfs:domain ind:LpmTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:resourceRoleRequirements rdf:type rdf:Property ;
    rdfs:label 'Resource Role Requirements' ;
    rdfs:comment 'Comma-separated list of required resource roles for this template (e.g., Partner, Senior Associate, Junior Associate, Paralegal, Legal Secretary).' ;
    rdfs:domain ind:LpmTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskCheckpointCount rdf:type rdf:Property ;
    rdfs:label 'Risk Checkpoint Count' ;
    rdfs:comment 'Number of formal risk assessment checkpoints defined in the template for matter governance and quality control.' ;
    rdfs:domain ind:LpmTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:taskCount rdf:type rdf:Property ;
    rdfs:label 'Task Count' ;
    rdfs:comment 'Total number of standard tasks defined in the template task sequence.' ;
    rdfs:domain ind:LpmTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentLineId rdf:type rdf:Property ;
    rdfs:label 'Parent Line Id' ;
    rdfs:comment 'Self-referencing FK on line (parent_line_id)' ;
    rdfs:domain ind:Line ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Line .

ind:parentServiceLineId rdf:type rdf:Property ;
    rdfs:label 'Parent Service Line Id' ;
    rdfs:comment 'Identifier of the parent service line if this service line is a sub-line within a larger business unit. Null for top-level service lines. Enables hierarchical P&L roll-up and strategic planning.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Line .

ind:averageMatterDurationDays rdf:type rdf:Property ;
    rdfs:label 'Average Matter Duration Days' ;
    rdfs:comment 'The typical duration in days from matter opening to closure for matters in this service line. Used for resource planning, WIP forecasting, and client expectation management.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billingModelDefault rdf:type rdf:Property ;
    rdfs:label 'Billing Model Default' ;
    rdfs:comment 'The predominant billing model used by this service line. Hourly = traditional time-based billing. Fixed Fee = flat fee per matter. Contingency = success-based fee. AFA (Alternative Fee Arrangement) = value-based or outcome-based pricing. Hybrid = combination. Retainer = ongoing monthly/quarterly fee.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conflictSensitivityLevel rdf:type rdf:Property ;
    rdfs:label 'Conflict Sensitivity Level' ;
    rdfs:comment 'The typical conflict-of-interest sensitivity for matters in this service line. High = frequent conflicts requiring ethical walls (e.g., M&A, litigation). Medium = occasional conflicts. Low = rare conflicts. Used to inform conflict checking protocols.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossSellingAffinityScore rdf:type rdf:Property ;
    rdfs:label 'Cross Selling Affinity Score' ;
    rdfs:comment 'A calculated score (0-100) representing the likelihood of cross-selling opportunities between this service line and other service lines. Based on historical client engagement patterns. Used for business development targeting.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:diversityTargetPercentage rdf:type rdf:Property ;
    rdfs:label 'Diversity Target Percentage' ;
    rdfs:comment 'The firm\'s diversity representation target (as a percentage) for this service line\'s attorney population. Used for DEI reporting, lateral hiring decisions, and client diversity scorecard requirements.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fteCountCurrent rdf:type rdf:Property ;
    rdfs:label 'Fte Count Current' ;
    rdfs:comment 'The current total FTE headcount (partners, associates, paralegals, and support staff) allocated to this service line. Used for utilization analysis, capacity planning, and revenue per FTE calculations.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geographicScope rdf:type rdf:Property ;
    rdfs:label 'Geographic Scope' ;
    rdfs:comment 'The geographic market scope of this service line\'s operations and client base. Local = single city/metro. Regional = multi-city within region. National = country-wide. International = multi-country. Global = worldwide presence.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:knowledgeManagementRepository rdf:type rdf:Property ;
    rdfs:label 'Knowledge Management Repository' ;
    rdfs:comment 'The primary knowledge management system or repository used by this service line for precedent documents, practice notes, and matter templates (e.g., Thomson Reuters Practical Law, iManage Work, internal KM system).' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineCode rdf:type rdf:Property ;
    rdfs:label 'Line Code' ;
    rdfs:comment 'Short alphanumeric code used internally for financial reporting, practice management systems, and partner compensation allocation (e.g., CORP, DISP, REG, TRANS, IP, EMP).' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineDescription rdf:type rdf:Property ;
    rdfs:label 'Line Description' ;
    rdfs:comment 'Detailed description of the service line\'s scope, including the types of legal services, practice areas, and client matters it encompasses. Used for business development, RFP responses, and strategic planning.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineName rdf:type rdf:Property ;
    rdfs:label 'Line Name' ;
    rdfs:comment 'The official name of the service line as used in firm communications, financial reporting, and client-facing materials (e.g., Corporate Advisory, Disputes & Investigations, Regulatory & Government Affairs, Transactional, Intellectual Property, Employment & Labor).' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketPositioning rdf:type rdf:Property ;
    rdfs:label 'Market Positioning' ;
    rdfs:comment 'The firm\'s market positioning and competitive differentiation statement for this service line. Used in business development, RFP responses, and lateral partner recruitment.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerCount rdf:type rdf:Property ;
    rdfs:label 'Partner Count' ;
    rdfs:comment 'The number of equity and non-equity partners primarily assigned to this service line. Used for RPE (Revenue Per Equity Partner) and PPP (Profit Per Partner) calculations.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:proBonoAllocationPercentage rdf:type rdf:Property ;
    rdfs:label 'Pro Bono Allocation Percentage' ;
    rdfs:comment 'The target percentage of this service line\'s total hours to be allocated to pro bono work. Used for ABA pro bono reporting and associate development planning.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:realizationRateTarget rdf:type rdf:Property ;
    rdfs:label 'Realization Rate Target' ;
    rdfs:comment 'The target realization rate (percentage of standard rates actually collected) for this service line. Expressed as a percentage (e.g., 92.50 for 92.5%). Used for pricing strategy and partner performance evaluation.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryOversightBody rdf:type rdf:Property ;
    rdfs:label 'Regulatory Oversight Body' ;
    rdfs:comment 'Primary regulatory or professional body governing the legal services provided by this service line (e.g., SEC for securities practice, USPTO for patent prosecution, State Bar for general practice). Used for compliance tracking and CPD planning.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueTargetAnnual rdf:type rdf:Property ;
    rdfs:label 'Revenue Target Annual' ;
    rdfs:comment 'The annual revenue target (in firm base currency) set for this service line during strategic planning. Used for partner compensation, performance evaluation, and resource allocation decisions.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:strategicPriorityLevel rdf:type rdf:Property ;
    rdfs:label 'Strategic Priority Level' ;
    rdfs:comment 'The firm\'s strategic investment priority for this service line. Tier 1 = high growth investment. Tier 2 = selective growth. Tier 3 = maintain current scale. Maintain = stable revenue focus. Divest = planned wind-down or sale.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technologyPlatformPrimary rdf:type rdf:Property ;
    rdfs:label 'Technology Platform Primary' ;
    rdfs:comment 'The primary technology platform or specialized software used by this service line (e.g., Relativity for eDiscovery, LexisNexis for legal research, Thomson Reuters for transactional work). Used for IT budgeting and training planning.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outcomeId rdf:type rdf:Property ;
    rdfs:label 'Outcome Id' ;
    rdfs:comment 'Unique identifier for the matter outcome record. Primary key.' ;
    rdfs:domain ind:Outcome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:appealedOutcomeId rdf:type rdf:Property ;
    rdfs:label 'Appealed Outcome Id' ;
    rdfs:comment 'Self-referencing FK on outcome (appealed_outcome_id)' ;
    rdfs:domain ind:Outcome ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Outcome .

ind:triggeredInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Triggered Invoice Id' ;
    rdfs:comment 'Foreign key linking to billing.invoice. Business justification: Matter outcomes with contingent_fee_triggered_flag=true generate a specific contingency fee invoice. Legal billing requires linking the outcome event to the triggered invoice for contingency fee audit' ;
    rdfs:domain ind:Outcome ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:appealFiledByParty rdf:type rdf:Property ;
    rdfs:label 'Appeal Filed By Party' ;
    rdfs:comment 'Identifies which party filed the appeal: client, opposing party, third party, or not applicable.' ;
    rdfs:domain ind:Outcome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appealFiledFlag rdf:type rdf:Property ;
    rdfs:label 'Appeal Filed Flag' ;
    rdfs:comment 'Indicates whether an appeal has been filed against this outcome. True if appeal filed, False otherwise.' ;
    rdfs:domain ind:Outcome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billingImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Billing Impact Flag' ;
    rdfs:comment 'Indicates whether this outcome has billing implications (e.g., contingent fee trigger, success fee, AFA milestone). True if billing impact exists, False otherwise.' ;
    rdfs:domain ind:Outcome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clientSatisfactionRating rdf:type rdf:Property ;
    rdfs:label 'Client Satisfaction Rating' ;
    rdfs:comment 'Client satisfaction rating for the outcome on a scale of 1-5, where 5 is highly satisfied. Null if not collected.' ;
    rdfs:domain ind:Outcome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contingentFeeTriggeredFlag rdf:type rdf:Property ;
    rdfs:label 'Contingent Fee Triggered Flag' ;
    rdfs:comment 'Indicates whether this outcome triggered a contingent fee arrangement. True if triggered, False otherwise.' ;
    rdfs:domain ind:Outcome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:damagesAwardedAmount rdf:type rdf:Property ;
    rdfs:label 'Damages Awarded Amount' ;
    rdfs:comment 'Amount of damages awarded by court or tribunal. Applicable to litigation outcomes. Null if not applicable.' ;
    rdfs:domain ind:Outcome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enforcementActionDate rdf:type rdf:Property ;
    rdfs:label 'Enforcement Action Date' ;
    rdfs:comment 'Date on which enforcement action was initiated. Null if no enforcement action taken.' ;
    rdfs:domain ind:Outcome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enforcementActionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Enforcement Action Required Flag' ;
    rdfs:comment 'Indicates whether enforcement action is required to compel compliance with the outcome. True if enforcement needed, False otherwise.' ;
    rdfs:domain ind:Outcome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:favorableOutcomeFlag rdf:type rdf:Property ;
    rdfs:label 'Favorable Outcome Flag' ;
    rdfs:comment 'Indicates whether the outcome was favorable to the client. True if favorable, False if unfavorable.' ;
    rdfs:domain ind:Outcome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lessonsLearnedReference rdf:type rdf:Property ;
    rdfs:label 'Lessons Learned Reference' ;
    rdfs:comment 'Reference to knowledge management system entry or document capturing lessons learned from this matter outcome.' ;
    rdfs:domain ind:Outcome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matterClosureTriggeredFlag rdf:type rdf:Property ;
    rdfs:label 'Matter Closure Triggered Flag' ;
    rdfs:comment 'Indicates whether this outcome triggered the closure of the parent matter. True if closure triggered, False otherwise.' ;
    rdfs:domain ind:Outcome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:opposingLawFirmName rdf:type rdf:Property ;
    rdfs:label 'Opposing Law Firm Name' ;
    rdfs:comment 'Name of the law firm representing the opposing party.' ;
    rdfs:domain ind:Outcome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outcomeCategory rdf:type rdf:Property ;
    rdfs:label 'Outcome Category' ;
    rdfs:comment 'High-level categorization of the outcome aligned with practice area: litigation, transaction, advisory, regulatory, IP prosecution, compliance. [ENUM-REF-CANDIDATE: litigation|transaction|advisory|regulatory|ip_prosecution|compliance|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Outcome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outcomeDescription rdf:type rdf:Property ;
    rdfs:label 'Outcome Description' ;
    rdfs:comment 'Detailed narrative description of the outcome, including key terms, conditions, and context.' ;
    rdfs:domain ind:Outcome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outcomeStatus rdf:type rdf:Property ;
    rdfs:label 'Outcome Status' ;
    rdfs:comment 'Current status of the outcome: preliminary, final, appealed, vacated, modified, enforced, satisfied, pending approval, draft. [ENUM-REF-CANDIDATE: preliminary|final|appealed|vacated|modified|enforced|satisfied|pending_approval|draft — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Outcome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outcomeType rdf:type rdf:Property ;
    rdfs:label 'Outcome Type' ;
    rdfs:comment 'Classification of the matter outcome. For litigation: judgment, settlement, dismissal, verdict, consent order. For transactions: signing, closing, abandonment. For advisory: opinion delivered, memo issued. For regulatory: approval, denial, conditional approval. [ENUM-REF-CANDIDATE: judgment|settlement|dismissal|verdict|consent_order|signing|closing|abandonment|opinion_delivered|memo_issued|approval|denial|conditional_approval|withdrawal|arbitration_award|mediation_settlement|default_judgment|summary_judgment|mistrial|acquittal|conviction|other — 22 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Outcome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:presidingJudgeName rdf:type rdf:Property ;
    rdfs:label 'Presiding Judge Name' ;
    rdfs:comment 'Name of the judge, arbitrator, or decision-maker who presided over the matter outcome. Applicable to litigation and arbitration.' ;
    rdfs:domain ind:Outcome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionValueAmount rdf:type rdf:Property ;
    rdfs:label 'Transaction Value Amount' ;
    rdfs:comment 'Total value of the transaction for M&A, corporate transaction, or deal closure outcomes. Null if not applicable.' ;
    rdfs:domain ind:Outcome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:winLossClassification rdf:type rdf:Property ;
    rdfs:label 'Win Loss Classification' ;
    rdfs:comment 'Classification of the outcome for win/loss analytics: win, loss, partial win, neutral, or not applicable.' ;
    rdfs:domain ind:Outcome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentId rdf:type rdf:Property ;
    rdfs:label 'Assignment Id' ;
    rdfs:comment 'Unique identifier for this matter-timekeeper assignment record. Primary key.' ;
    rdfs:domain ind:Assignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastModifiedDate rdf:type rdf:Property ;
    rdfs:label 'Last Modified Date' ;
    rdfs:comment 'Timestamp of the most recent modification to this assignment record. Used for change tracking and audit trail.' ;
    rdfs:domain ind:Assignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:parentProductionSetId rdf:type rdf:Property ;
    rdfs:label 'Parent Production Set Id' ;
    rdfs:comment 'Self-referencing FK on production_set (parent_production_set_id)' ;
    rdfs:domain ind:ProductionSet ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductionSet .

ind:approvingAttorneyName rdf:type rdf:Property ;
    rdfs:label 'Approving Attorney Name' ;
    rdfs:comment 'Name of the attorney who approved the production set for delivery.' ;
    rdfs:domain ind:ProductionSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batesRangeEnd rdf:type rdf:Property ;
    rdfs:label 'Bates Range End' ;
    rdfs:comment 'Ending Bates number for the production set.' ;
    rdfs:domain ind:ProductionSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batesRangeStart rdf:type rdf:Property ;
    rdfs:label 'Bates Range Start' ;
    rdfs:comment 'Starting Bates number for the production set, used for document identification and tracking.' ;
    rdfs:domain ind:ProductionSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSourceCount rdf:type rdf:Property ;
    rdfs:label 'Data Source Count' ;
    rdfs:comment 'Number of distinct data sources from which documents in this production set were collected.' ;
    rdfs:domain ind:ProductionSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hash rdf:type rdf:Property ;
    rdfs:label 'Hash' ;
    rdfs:comment 'Cryptographic hash value for the entire production set, ensuring integrity and chain of custody.' ;
    rdfs:domain ind:ProductionSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metadataFieldsProduced rdf:type rdf:Property ;
    rdfs:label 'Metadata Fields Produced' ;
    rdfs:comment 'Comma-separated list of metadata fields included in the production load file.' ;
    rdfs:domain ind:ProductionSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nativeFilesIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Native Files Included Flag' ;
    rdfs:comment 'Indicates whether native file formats are included in the production.' ;
    rdfs:domain ind:ProductionSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:privilegeLogRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Privilege Log Required Flag' ;
    rdfs:comment 'Indicates whether a privilege log must accompany this production set for withheld documents.' ;
    rdfs:domain ind:ProductionSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productionDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Production Deadline Date' ;
    rdfs:comment 'Court-ordered or agreed-upon deadline for delivering this production set.' ;
    rdfs:domain ind:ProductionSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:productionProtocolVersion rdf:type rdf:Property ;
    rdfs:label 'Production Protocol Version' ;
    rdfs:comment 'Version identifier of the production protocol or agreement governing this production set.' ;
    rdfs:domain ind:ProductionSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionSetName rdf:type rdf:Property ;
    rdfs:label 'Production Set Name' ;
    rdfs:comment 'Descriptive name for the production set, typically reflecting the production phase, recipient, or content scope.' ;
    rdfs:domain ind:ProductionSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionSetNumber rdf:type rdf:Property ;
    rdfs:label 'Production Set Number' ;
    rdfs:comment 'Business identifier for the production set, typically assigned by the eDiscovery platform or case management system. Externally visible reference number.' ;
    rdfs:domain ind:ProductionSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionVolumeNumber rdf:type rdf:Property ;
    rdfs:label 'Production Volume Number' ;
    rdfs:comment 'Sequential volume number if the production is split across multiple deliveries.' ;
    rdfs:domain ind:ProductionSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualityControlCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Quality Control Completed Date' ;
    rdfs:comment 'Date on which quality control review was completed.' ;
    rdfs:domain ind:ProductionSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualityControlReviewerName rdf:type rdf:Property ;
    rdfs:label 'Quality Control Reviewer Name' ;
    rdfs:comment 'Name of the individual who performed the quality control review.' ;
    rdfs:domain ind:ProductionSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityControlStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Control Status' ;
    rdfs:comment 'Status of quality control review for the production set.' ;
    rdfs:domain ind:ProductionSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientPartyName rdf:type rdf:Property ;
    rdfs:label 'Recipient Party Name' ;
    rdfs:comment 'Name of the party or organization receiving the production set.' ;
    rdfs:domain ind:ProductionSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redactionAppliedFlag rdf:type rdf:Property ;
    rdfs:label 'Redaction Applied Flag' ;
    rdfs:comment 'Indicates whether redactions have been applied to documents in this production set.' ;
    rdfs:domain ind:ProductionSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalFileSizeGb rdf:type rdf:Property ;
    rdfs:label 'Total File Size Gb' ;
    rdfs:comment 'Total file size of the production set in gigabytes.' ;
    rdfs:domain ind:ProductionSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalProductionVolumes rdf:type rdf:Property ;
    rdfs:label 'Total Production Volumes' ;
    rdfs:comment 'Total number of volumes planned for this production set.' ;
    rdfs:domain ind:ProductionSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:templateClauseAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Template Clause Assignment Id' ;
    rdfs:comment 'Primary key for the template_clause_assignment association' ;
    rdfs:domain ind:TemplateClauseAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clausePosition rdf:type rdf:Property ;
    rdfs:label 'Clause Position' ;
    rdfs:comment 'Structural placement descriptor for the clause within the template (e.g., \'Section 4\', \'Schedule 2\', \'Recital C\'). Provides human-readable positional context beyond numeric sort order.' ;
    rdfs:domain ind:TemplateClauseAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isMandatory rdf:type rdf:Property ;
    rdfs:label 'Is Mandatory' ;
    rdfs:comment 'Indicates whether this clause is mandatory within this specific template. A clause may be mandatory in one template (e.g., confidentiality in an NDA) but optional in another (e.g., confidentiality in an MSA). Cannot live on either parent entity alone.' ;
    rdfs:domain ind:TemplateClauseAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overrideAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Override Allowed Flag' ;
    rdfs:comment 'Indicates whether negotiators are permitted to deviate from or modify this clause when using this template. Override permissions may differ per template — a clause may be locked in a high-risk template but negotiable in a standard commercial template.' ;
    rdfs:domain ind:TemplateClauseAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:templateIntegrationFlag rdf:type rdf:Property ;
    rdfs:label 'Template Integration Flag' ;
    rdfs:comment 'Indicates whether this clause is integrated into automated contract templates within the Contract Lifecycle Management (CLM) or Document Management System (DMS) for automated document assembly. [Moved from clause_library: This boolean on clause_library indicates whether a clause is integrated into automated templates, but this is a derived/aggregate property. The ground truth is captured at the assignment level — if any active template_clause_assignment record exists for a clause, it is template-integrated. The flag on clause_library becomes redundant and potentially stale once the association table exists. Consider deprecating it in favour of a computed view over the association table.]' ;
    rdfs:domain ind:TemplateClauseAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:packageServiceInclusionId rdf:type rdf:Property ;
    rdfs:label 'Package Service Inclusion Id' ;
    rdfs:comment 'Primary key for the package_service_inclusion association' ;
    rdfs:domain ind:PackageServiceInclusion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:includedQuantity rdf:type rdf:Property ;
    rdfs:label 'Included Quantity' ;
    rdfs:comment 'Scope allocation or quantity of this legal service included within the package (e.g., number of matters, hours, or units). Varies per package-service combination and cannot reside on either parent entity.' ;
    rdfs:domain ind:PackageServiceInclusion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isCoreServiceFlag rdf:type rdf:Property ;
    rdfs:label 'Is Core Service Flag' ;
    rdfs:comment 'Indicates whether this legal service is a mandatory (core) component of the package or an elective (optional) add-on. This designation belongs to the inclusion relationship — the same service may be core in one package and elective in another.' ;
    rdfs:domain ind:PackageServiceInclusion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceDiscountPercentage rdf:type rdf:Property ;
    rdfs:label 'Service Discount Percentage' ;
    rdfs:comment 'Component-level pricing discount applied to this legal service when delivered as part of this specific package. Distinct from the package base price and the service standard rate — it is a property of the inclusion relationship itself.' ;
    rdfs:domain ind:PackageServiceInclusion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .
