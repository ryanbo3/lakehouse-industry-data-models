    rdfs:range xsd:decimal .

ind:costCenter rdf:type rdf:Property ;
    rdfs:label 'Cost Center' ;
    rdfs:comment 'Financial cost center code for budgeting and expense allocation purposes.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fullTimeEquivalent rdf:type rdf:Property ;
    rdfs:label 'Full Time Equivalent' ;
    rdfs:comment 'Full-time equivalent percentage representing the user\'s work commitment. 1.00 for full-time, 0.50 for half-time, etc. Used for capacity planning and resource allocation.' ;
    rdfs:domain ind:User ;
