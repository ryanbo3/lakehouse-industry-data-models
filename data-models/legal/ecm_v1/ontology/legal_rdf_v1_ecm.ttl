    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workflowName rdf:type rdf:Property ;
    rdfs:label 'Workflow Name' ;
    rdfs:comment 'Human-readable name or title of the execution workflow (e.g., \'Contract Execution - Standard\', \'NDA Signature Flow\').' ;
    rdfs:domain ind:ExecutionWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workflowStatus rdf:type rdf:Property ;
    rdfs:label 'Workflow Status' ;
    rdfs:comment 'Current lifecycle status of the execution workflow indicating whether it is available for use.' ;
    rdfs:domain ind:ExecutionWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workflowType rdf:type rdf:Property ;
    rdfs:label 'Workflow Type' ;
    rdfs:comment 'Classification of the execution workflow by its primary purpose (signature, approval, review, attestation, notarization, filing).' ;
    rdfs:domain ind:ExecutionWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessControlModel rdf:type rdf:Property ;
    rdfs:label 'Access Control Model' ;
    rdfs:comment 'Security model governing how user permissions and access rights are assigned and enforced for this workspace.' ;
    rdfs:domain ind:Workspace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCode rdf:type rdf:Property ;
    rdfs:label 'Billing Code' ;
    rdfs:comment 'Code used to associate workspace activity and storage costs with client billing and matter accounting.' ;
    rdfs:domain ind:Workspace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destructionEligibleDate rdf:type rdf:Property ;
    rdfs:label 'Destruction Eligible Date' ;
    rdfs:comment 'Calculated date when workspace contents become eligible for destruction per retention policy, subject to litigation hold overrides.' ;
    rdfs:domain ind:Workspace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentManagementSystem rdf:type rdf:Property ;
    rdfs:label 'Document Management System' ;
    rdfs:comment 'Source document management system platform where this workspace is hosted or synchronized from.' ;
    rdfs:domain ind:Workspace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalCollaborationEnabled rdf:type rdf:Property ;
    rdfs:label 'External Collaboration Enabled' ;
    rdfs:comment 'Indicator whether external parties (clients, co-counsel, experts) are permitted to access and collaborate within this workspace.' ;
