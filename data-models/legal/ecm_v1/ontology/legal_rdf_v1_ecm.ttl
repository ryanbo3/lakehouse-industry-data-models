    rdfs:domain ind:ReviewSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Start Timestamp' ;
    rdfs:comment 'Actual date and time when the review session commenced, capturing the real-world event time.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:averageReviewTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Average Review Time Seconds' ;
    rdfs:comment 'Mean time in seconds spent reviewing each document during this session, used for productivity and cost analysis.' ;
    rdfs:domain ind:ReviewSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:codingLayoutName rdf:type rdf:Property ;
    rdfs:label 'Coding Layout Name' ;
    rdfs:comment 'Name of the coding layout or form template used by reviewers to code documents during this session.' ;
    rdfs:domain ind:ReviewSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:custodianFilter rdf:type rdf:Property ;
    rdfs:label 'Custodian Filter' ;
    rdfs:comment 'Custodian or data source filter applied to scope the documents included in this review session.' ;
    rdfs:domain ind:ReviewSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dateRangeFilterEnd rdf:type rdf:Property ;
    rdfs:label 'Date Range Filter End' ;
    rdfs:comment 'End date of the date range filter applied to documents in this review session.' ;
    rdfs:domain ind:ReviewSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dateRangeFilterStart rdf:type rdf:Property ;
    rdfs:label 'Date Range Filter Start' ;
    rdfs:comment 'Start date of the date range filter applied to documents in this review session.' ;
    rdfs:domain ind:ReviewSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentsPending rdf:type rdf:Property ;
    rdfs:label 'Documents Pending' ;
    rdfs:comment 'Count of documents remaining to be reviewed in this session.' ;
    rdfs:domain ind:ReviewSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:documentsReviewed rdf:type rdf:Property ;
    rdfs:label 'Documents Reviewed' ;
    rdfs:comment 'Count of documents that have been reviewed and coded during this session.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hotDocumentCount rdf:type rdf:Property ;
    rdfs:label 'Hot Document Count' ;
    rdfs:comment 'Count of documents flagged as hot or key documents requiring special attention or escalation during this session.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nonResponsiveDocumentCount rdf:type rdf:Property ;
    rdfs:label 'Non Responsive Document Count' ;
    rdfs:comment 'Count of documents coded as non-responsive during this review session.' ;
    rdfs:domain ind:ReviewSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:privilegeDesignationCount rdf:type rdf:Property ;
    rdfs:label 'Privilege Designation Count' ;
    rdfs:comment 'Count of documents designated as privileged during this review session.' ;
    rdfs:domain ind:ReviewSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualityControlErrorRate rdf:type rdf:Property ;
    rdfs:label 'Quality Control Error Rate' ;
    rdfs:comment 'Percentage of documents in the QC sample that were found to have coding errors or inconsistencies.' ;
    rdfs:domain ind:ReviewSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:redactionRequiredCount rdf:type rdf:Property ;
    rdfs:label 'Redaction Required Count' ;
    rdfs:comment 'Count of documents identified as requiring redaction for privileged or confidential information during this session.' ;
    rdfs:domain ind:ReviewSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewCompletionPercentage rdf:type rdf:Property ;
    rdfs:label 'Review Completion Percentage' ;
    rdfs:comment 'Percentage of assigned documents that have been reviewed, calculated as (documents_reviewed / total_documents_assigned) * 100.' ;
    rdfs:domain ind:ReviewSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reviewProtocol rdf:type rdf:Property ;
    rdfs:label 'Review Protocol' ;
    rdfs:comment 'The methodology or protocol applied during this review session, such as Technology Assisted Review (TAR), Continuous Active Learning (CAL), or traditional linear review.' ;
    rdfs:domain ind:ReviewSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Timestamp' ;
    rdfs:comment 'Planned date and time when the review session is scheduled to conclude.' ;
    rdfs:domain ind:ReviewSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Timestamp' ;
    rdfs:comment 'Planned date and time when the review session is scheduled to begin.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sessionNotes rdf:type rdf:Property ;
    rdfs:label 'Session Notes' ;
    rdfs:comment 'Free-text notes or comments recorded by the lead reviewer or supervising attorney regarding this review session.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionNumber rdf:type rdf:Property ;
    rdfs:label 'Session Number' ;
    rdfs:comment 'Business-facing unique identifier for the review session, typically formatted as RS-YYYYMMDD-XXXXXX for external reference and tracking.' ;
    rdfs:domain ind:ReviewSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalDocumentsAssigned rdf:type rdf:Property ;
    rdfs:label 'Total Documents Assigned' ;
    rdfs:comment 'Total count of documents allocated to this review session for review.' ;
    rdfs:domain ind:ReviewSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalReviewHours rdf:type rdf:Property ;
    rdfs:label 'Total Review Hours' ;
    rdfs:comment 'Cumulative hours spent by all reviewers during this review session.' ;
    rdfs:domain ind:ReviewSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:documentTypeId rdf:type rdf:Property ;
    rdfs:label 'Document Type Id' ;
    rdfs:comment 'Reference to the type of legal document this workflow is designed for (e.g., contract, agreement, pleading, motion).' ;
    rdfs:domain ind:ExecutionWorkflow ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DocType .

ind:ownerUserId rdf:type rdf:Property ;
    rdfs:label 'Owner User Id' ;
    rdfs:comment 'Reference to the user or attorney who owns and maintains this workflow definition.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:User .

ind:supersededByWorkflowId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Workflow Id' ;
    rdfs:comment 'Reference to the newer workflow version that supersedes this one, if applicable.' ;
    rdfs:domain ind:ExecutionWorkflow ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ExecutionWorkflow .

ind:approvalAuthorityLevel rdf:type rdf:Property ;
    rdfs:label 'Approval Authority Level' ;
    rdfs:comment 'Level of authority required for approval (e.g., Partner, Senior Associate, General Counsel, Board).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditTrailRequired rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Required' ;
    rdfs:comment 'Indicates whether a complete audit trail of all execution activities must be maintained for compliance.' ;
    rdfs:domain ind:ExecutionWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:businessUnit rdf:type rdf:Property ;
    rdfs:label 'Business Unit' ;
    rdfs:comment 'Business unit or department that primarily uses this execution workflow.' ;
    rdfs:domain ind:ExecutionWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chainOfCustodyRequired rdf:type rdf:Property ;
    rdfs:label 'Chain Of Custody Required' ;
    rdfs:comment 'Indicates whether chain of custody documentation is required for evidentiary purposes.' ;
    rdfs:domain ind:ExecutionWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDefaultWorkflow rdf:type rdf:Property ;
    rdfs:label 'Is Default Workflow' ;
    rdfs:comment 'Indicates whether this is the default workflow for its document type and jurisdiction.' ;
    rdfs:domain ind:ExecutionWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastUsedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Used Timestamp' ;
    rdfs:comment 'Timestamp when this workflow was last used for a document execution.' ;
    rdfs:domain ind:ExecutionWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:maximumSignatories rdf:type rdf:Property ;
    rdfs:label 'Maximum Signatories' ;
    rdfs:comment 'Maximum number of signatories allowed in this execution workflow.' ;
    rdfs:domain ind:ExecutionWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumSignatories rdf:type rdf:Property ;
    rdfs:label 'Minimum Signatories' ;
    rdfs:comment 'Minimum number of signatories required to complete this execution workflow.' ;
    rdfs:domain ind:ExecutionWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sequenceType rdf:type rdf:Property ;
    rdfs:label 'Sequence Type' ;
    rdfs:comment 'Defines how signatories are sequenced in the workflow (sequential order, parallel/simultaneous, hybrid, conditional routing).' ;
    rdfs:domain ind:ExecutionWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signaturePlatform rdf:type rdf:Property ;
    rdfs:label 'Signature Platform' ;
    rdfs:comment 'Electronic signature platform or system used for this workflow (e.g., DocuSign, Adobe Sign, HelloSign, internal system).' ;
    rdfs:domain ind:ExecutionWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialInstructions rdf:type rdf:Property ;
    rdfs:label 'Special Instructions' ;
    rdfs:comment 'Additional instructions or notes for users executing documents through this workflow.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardTurnaroundDays rdf:type rdf:Property ;
    rdfs:label 'Standard Turnaround Days' ;
    rdfs:comment 'Expected number of business days for completion of this execution workflow under normal circumstances.' ;
    rdfs:domain ind:ExecutionWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:workflowCode rdf:type rdf:Property ;
    rdfs:label 'Workflow Code' ;
    rdfs:comment 'Externally-known unique business identifier or code for the workflow (e.g., \'EXEC-STD-001\', \'NDA-SIG-V2\').' ;
    rdfs:domain ind:ExecutionWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workflowDescription rdf:type rdf:Property ;
    rdfs:label 'Workflow Description' ;
    rdfs:comment 'Detailed description of the workflow purpose, steps, and business context.' ;
