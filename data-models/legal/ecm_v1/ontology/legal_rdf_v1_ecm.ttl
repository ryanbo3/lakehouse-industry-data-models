ind:targetControlFrameworkId rdf:type rdf:Property ;
    rdfs:label 'Target Control Framework Id' ;
    rdfs:comment 'Foreign key linking to compliance.control_framework. Business justification: Audit programs are often designed to test compliance with specific control frameworks (e.g., \'ISO 27001 Annual Audit Program\', \'SOX Controls Testing Program\'). The audit_program table has compliance_f' ;
    rdfs:domain ind:AuditProgram ;
