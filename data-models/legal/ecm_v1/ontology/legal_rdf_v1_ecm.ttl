ind:litigationHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Litigation Hold Flag' ;
    rdfs:comment 'Indicator that workspace contents are subject to litigation hold, suspending normal retention and destruction processes.' ;
    rdfs:domain ind:Workspace ;
    rdf:type owl:DatatypeProperty ;
