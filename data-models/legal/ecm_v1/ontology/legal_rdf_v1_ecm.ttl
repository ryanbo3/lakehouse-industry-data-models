    rdfs:range xsd:string .

ind:totalDocumentCount rdf:type rdf:Property ;
    rdfs:label 'Total Document Count' ;
    rdfs:comment 'Current count of documents contained within this workspace, used for capacity planning and billing purposes.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
