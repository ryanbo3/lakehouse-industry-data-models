    rdfs:comment 'Minimum percentage of affirmative votes required from present members to approve a transaction (e.g., 50.00 for simple majority, 66.67 for supermajority).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amortizationSchedule rdf:type rdf:Property ;
