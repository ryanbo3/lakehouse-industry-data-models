    rdfs:range xsd:string .

ind:committeeType rdf:type rdf:Property ;
    rdfs:label 'Committee Type' ;
    rdfs:comment 'Classification of the committee based on its primary approval authority and decision-making scope within investment banking operations.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conflictOfInterestPolicy rdf:type rdf:Property ;
    rdfs:label 'Conflict Of Interest Policy' ;
    rdfs:comment 'Description of the conflict of interest policy governing committee member participation and recusal requirements.' ;
    rdfs:domain ind:ApprovalCommittee ;
