# --- Attribute Properties ---
ind:balanceId rdf:type rdf:Property ;
    rdfs:label 'Balance Id' ;
    rdfs:comment 'Unique identifier for the account balance snapshot record. Primary key for the account balance data product.' ;
    rdfs:domain ind:Balance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountingPeriodId rdf:type rdf:Property ;
    rdfs:label 'Accounting Period Id' ;
    rdfs:comment 'Foreign key linking to ledger.accounting_period. Business justification: Account balances are period-end snapshots required for regulatory call reports, balance sheet preparation, and financial close. This links operational balances to the fiscal calendar for reporting.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccountingPeriod .

ind:currencyId rdf:type rdf:Property ;
    rdfs:label 'Currency Id' ;
    rdfs:comment 'The three-letter ISO 4217 currency code in which the account balance is denominated (e.g., USD, EUR, GBP, JPY).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:depositAccountId rdf:type rdf:Property ;
    rdfs:label 'Deposit Account Id' ;
    rdfs:comment 'Reference to the deposit or transactional account for which this balance snapshot is recorded. Links to the authoritative account registry.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DepositAccount .

ind:accruedInterest rdf:type rdf:Property ;
    rdfs:label 'Accrued Interest' ;
    rdfs:comment 'The cumulative interest earned but not yet credited to the account as of the balance date. Calculated based on the interest rate, balance tier, and accrual method defined in the account terms.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:availableBalance rdf:type rdf:Property ;
    rdfs:label 'Available Balance' ;
    rdfs:comment 'The balance available for withdrawal or use by the account holder. Calculated as ledger balance minus holds, pending debits, and uncollected funds, plus any available overdraft or credit line.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:availableOverdraft rdf:type rdf:Property ;
    rdfs:label 'Available Overdraft' ;
    rdfs:comment 'The remaining overdraft capacity available to the account holder, calculated as overdraft limit minus current overdraft balance utilized.' ;
    rdfs:domain ind:Balance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageDailyBalance rdf:type rdf:Property ;
    rdfs:label 'Average Daily Balance' ;
    rdfs:comment 'The average ledger balance for the statement period or month-to-date, calculated by summing daily balances and dividing by the number of days. Used for interest calculation and Net Interest Margin (NIM) analysis.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:balanceDate rdf:type rdf:Property ;
    rdfs:label 'Balance Date' ;
    rdfs:comment 'The business date for which this balance snapshot is recorded. Represents the end-of-day position for the specified date.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:balanceStatus rdf:type rdf:Property ;
    rdfs:label 'Balance Status' ;
    rdfs:comment 'The operational status of the account balance. Active indicates normal operations; frozen indicates temporary suspension; dormant indicates no activity for an extended period; closed indicates account closure; restricted indicates limited transaction capability.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collateralPledgedAmount rdf:type rdf:Property ;
    rdfs:label 'Collateral Pledged Amount' ;
    rdfs:comment 'The portion of the account balance that has been pledged as collateral for loans, letters of credit, or other obligations, reducing the available balance for withdrawal.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collectedBalance rdf:type rdf:Property ;
    rdfs:label 'Collected Balance' ;
    rdfs:comment 'The portion of the ledger balance that has cleared and is available for reserve requirement calculation. Excludes float and uncollected funds from deposited checks or transfers still in clearing.' ;
    rdfs:domain ind:Balance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:createdTimestamp rdf:type rdf:Property ;
    rdfs:label 'Created Timestamp' ;
    rdfs:comment 'The timestamp when this balance snapshot record was first created in the data lakehouse silver layer. Used for data lineage and audit trail purposes.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dataQualityScore rdf:type rdf:Property ;
    rdfs:label 'Data Quality Score' ;
    rdfs:comment 'A calculated score (0-100) representing the completeness, accuracy, and consistency of the balance record based on automated data quality rules. Used for data governance and issue identification.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daysInPeriod rdf:type rdf:Property ;
    rdfs:label 'Days In Period' ;
    rdfs:comment 'The number of calendar days in the current statement period, used as the denominator for average daily balance calculation.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:escheatmentEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Escheatment Eligible Flag' ;
    rdfs:comment 'Boolean indicator that is true if the account balance is eligible for escheatment to the state due to dormancy or abandonment under applicable unclaimed property laws.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fdicInsuredAmount rdf:type rdf:Property ;
    rdfs:label 'Fdic Insured Amount' ;
    rdfs:comment 'The portion of the account balance that is covered by FDIC deposit insurance, up to the standard maximum deposit insurance amount per depositor, per insured bank, for each account ownership category.' ;
    rdfs:domain ind:Balance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:floatBalance rdf:type rdf:Property ;
    rdfs:label 'Float Balance' ;
    rdfs:comment 'The amount of funds in transit or pending collection, representing deposits that have been credited to the ledger balance but have not yet cleared through the payment system.' ;
    rdfs:domain ind:Balance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holdBalance rdf:type rdf:Property ;
    rdfs:label 'Hold Balance' ;
    rdfs:comment 'The total amount of funds subject to holds, restrictions, or encumbrances that reduce the available balance. Includes administrative holds, legal holds, and collateral pledges.' ;
    rdfs:domain ind:Balance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interestBearingBalance rdf:type rdf:Property ;
    rdfs:label 'Interest Bearing Balance' ;
    rdfs:comment 'The portion of the account balance that is eligible for interest accrual based on the account type and interest calculation method. May differ from ledger balance due to minimum balance requirements or tiered rate structures.' ;
    rdfs:domain ind:Balance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastTransactionDate rdf:type rdf:Property ;
    rdfs:label 'Last Transaction Date' ;
    rdfs:comment 'The date of the most recent customer-initiated transaction on the account. Used to determine dormancy status and escheatment eligibility.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ledgerBalance rdf:type rdf:Property ;
    rdfs:label 'Ledger Balance' ;
    rdfs:comment 'The book balance of the account including all posted transactions as of the balance date. Represents the official accounting balance before adjustments for holds, floats, or uncollected funds.' ;
    rdfs:domain ind:Balance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumBalance rdf:type rdf:Property ;
    rdfs:label 'Maximum Balance' ;
    rdfs:comment 'The highest ledger balance recorded during the statement period or month-to-date. Used for FDIC insurance limit monitoring and liquidity analysis.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumBalance rdf:type rdf:Property ;
    rdfs:label 'Minimum Balance' ;
    rdfs:comment 'The lowest ledger balance recorded during the statement period or month-to-date. Used to determine minimum balance threshold breach and fee assessment.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumBalanceThresholdBreachFlag rdf:type rdf:Property ;
    rdfs:label 'Minimum Balance Threshold Breach Flag' ;
    rdfs:comment 'Boolean indicator that is true if the account balance fell below the contractual minimum balance threshold during the period, triggering potential fee assessment or service charge.' ;
    rdfs:domain ind:Balance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overdraftBalance rdf:type rdf:Property ;
    rdfs:label 'Overdraft Balance' ;
    rdfs:comment 'The amount by which the account is overdrawn if the ledger balance is negative. Zero if the account has a positive balance. Used for overdraft fee calculation and credit risk monitoring.' ;
    rdfs:domain ind:Balance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overdraftLimit rdf:type rdf:Property ;
    rdfs:label 'Overdraft Limit' ;
    rdfs:comment 'The maximum negative balance allowed for the account under the overdraft protection program or line of credit. Zero if no overdraft facility is available.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pendingCredits rdf:type rdf:Property ;
    rdfs:label 'Pending Credits' ;
    rdfs:comment 'The total amount of incoming transactions that have been authorized but not yet posted to the ledger balance. Includes pending deposits, transfers, and reversals.' ;
    rdfs:domain ind:Balance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pendingDebits rdf:type rdf:Property ;
    rdfs:label 'Pending Debits' ;
    rdfs:comment 'The total amount of outgoing transactions that have been authorized but not yet posted to the ledger balance. Includes pending withdrawals, payments, and fees.' ;
    rdfs:domain ind:Balance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reconciliationStatus rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Status' ;
    rdfs:comment 'The status of the balance reconciliation process between the core banking system and the general ledger. Reconciled indicates successful matching; pending indicates awaiting reconciliation; exception indicates discrepancy requiring investigation; override indicates manual adjustment applied.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reserveRequirementBalance rdf:type rdf:Property ;
    rdfs:label 'Reserve Requirement Balance' ;
    rdfs:comment 'The portion of the account balance subject to Federal Reserve reserve requirements under Regulation D. Used for Asset-Liability Management (ALM) and reserve calculation.' ;
    rdfs:domain ind:Balance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:snapshotTimestamp rdf:type rdf:Property ;
    rdfs:label 'Snapshot Timestamp' ;
    rdfs:comment 'The exact date and time when this balance snapshot was captured from the core banking system, typically during the end-of-day batch processing cycle.' ;
    rdfs:domain ind:Balance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sourceSystem rdf:type rdf:Property ;
    rdfs:label 'Source System' ;
    rdfs:comment 'The core banking system from which this balance snapshot was extracted. Identifies the system of record for data lineage and reconciliation purposes.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statementCycleEndDate rdf:type rdf:Property ;
    rdfs:label 'Statement Cycle End Date' ;
    rdfs:comment 'The last date of the current statement period for which average daily balance and other period-based metrics are calculated.' ;
    rdfs:domain ind:Balance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:statementCycleStartDate rdf:type rdf:Property ;
    rdfs:label 'Statement Cycle Start Date' ;
    rdfs:comment 'The first date of the current statement period for which average daily balance and other period-based metrics are calculated.' ;
    rdfs:domain ind:Balance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:uninsuredAmount rdf:type rdf:Property ;
    rdfs:label 'Uninsured Amount' ;
    rdfs:comment 'The portion of the account balance that exceeds FDIC insurance limits and is therefore at risk in the event of bank failure. Used for depositor risk disclosure and liquidity stress testing.' ;
    rdfs:domain ind:Balance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:updatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Updated Timestamp' ;
    rdfs:comment 'The timestamp when this balance snapshot record was last modified in the data lakehouse silver layer. Used for change tracking and audit trail purposes.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:documentId rdf:type rdf:Property ;
    rdfs:label 'Document Id' ;
    rdfs:comment 'Unique identifier for the account document record. Primary key.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:amlCaseId rdf:type rdf:Property ;
    rdfs:label 'Aml Case Id' ;
    rdfs:comment 'Foreign key linking to compliance.aml_case. Business justification: AML investigations require access to account opening documents, KYC documentation, and transaction supporting documents as evidence. Links case files to evidentiary documents for investigator review, ' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AmlCase .

ind:documentAmlReviewerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Document Aml Reviewer Employee Id' ;
    rdfs:comment 'Identifier of the AML compliance officer who reviewed this document.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:documentEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Document Employee Id' ;
    rdfs:comment 'Identifier of the bank officer or employee who verified the document authenticity and completeness.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:documentVerifyingOfficerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Document Verifying Officer Employee Id' ;
    rdfs:comment 'FK to hr.employee' ;
    rdfs:domain ind:Document ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:uploadChannelId rdf:type rdf:Property ;
    rdfs:label 'Upload Channel Id' ;
    rdfs:comment 'Foreign key linking to channel.channel. Business justification: KYC/CDD document submission channel is tracked for regulatory compliance (CIP requirements), customer service quality monitoring, and fraud prevention. Required for BSA/AML examinations and customer a' ;
    rdfs:domain ind:Document ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:amlReviewDate rdf:type rdf:Property ;
    rdfs:label 'Aml Review Date' ;
    rdfs:comment 'Date when the Anti-Money Laundering (AML) review of this document was completed.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:amlReviewRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Aml Review Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether this document requires review by the Anti-Money Laundering (AML) compliance team.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cddVerificationFlag rdf:type rdf:Property ;
    rdfs:label 'Cdd Verification Flag' ;
    rdfs:comment 'Boolean flag indicating whether this document is part of the Customer Due Diligence (CDD) verification process.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:comments rdf:type rdf:Property ;
    rdfs:label 'Comments' ;
    rdfs:comment 'Free-text comments or notes added by officers or system users regarding the document, its verification, or any special handling instructions.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerNotificationSentFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Sent Flag' ;
    rdfs:comment 'Boolean flag indicating whether the customer was notified about the document upload, verification, or status change.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:destructionAuthorizedBy rdf:type rdf:Property ;
    rdfs:label 'Destruction Authorized By' ;
    rdfs:comment 'Name or identifier of the officer who authorized the document destruction.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destructionDate rdf:type rdf:Property ;
    rdfs:label 'Destruction Date' ;
    rdfs:comment 'Date when the document was destroyed or permanently deleted from the system after retention period expiry.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentDescription rdf:type rdf:Property ;
    rdfs:label 'Document Description' ;
    rdfs:comment 'Detailed description of the document content, purpose, or context for business users and auditors.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentName rdf:type rdf:Property ;
    rdfs:label 'Document Name' ;
    rdfs:comment 'Human-readable name or title of the document as provided during upload or generation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentStatus rdf:type rdf:Property ;
    rdfs:label 'Document Status' ;
    rdfs:comment 'Current lifecycle status of the document. Values include pending (awaiting review), verified (authenticity confirmed), approved (accepted for account purposes), rejected (not accepted), expired (validity period lapsed), and archived (retained for historical purposes).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveDate rdf:type rdf:Property ;
    rdfs:label 'Effective Date' ;
    rdfs:comment 'Date from which the document becomes legally or operationally effective for the account.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expiryDate rdf:type rdf:Property ;
    rdfs:label 'Expiry Date' ;
    rdfs:comment 'Date when the document validity expires and renewal or replacement is required. Nullable for documents without expiration.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fileFormat rdf:type rdf:Property ;
    rdfs:label 'File Format' ;
    rdfs:comment 'Format of the stored document file. Common formats include PDF, JPEG, PNG, TIFF, DOCX, and XML.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileSizeBytes rdf:type rdf:Property ;
    rdfs:label 'File Size Bytes' ;
    rdfs:comment 'Size of the document file in bytes, used for storage management and validation purposes.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hash rdf:type rdf:Property ;
    rdfs:label 'Hash' ;
    rdfs:comment 'Cryptographic hash (e.g., SHA-256) of the document content, used to ensure integrity and detect tampering.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingAuthority rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority' ;
    rdfs:comment 'Name of the external authority, government agency, or institution that issued the document (e.g., IRS for tax forms, court for court orders).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Issuing Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code representing the country where the document was issued.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kycVerificationFlag rdf:type rdf:Property ;
    rdfs:label 'Kyc Verification Flag' ;
    rdfs:comment 'Boolean flag indicating whether this document is part of the Know Your Customer (KYC) verification process.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationChannel rdf:type rdf:Property ;
    rdfs:label 'Notification Channel' ;
    rdfs:comment 'Channel through which the customer was notified about the document. Values include email, SMS, postal mail, online portal, mobile app, and phone.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Notification Timestamp' ;
    rdfs:comment 'Timestamp when the customer notification was sent regarding this document.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:referenceNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Number' ;
    rdfs:comment 'Business-assigned unique reference number for the document, used for tracking and retrieval purposes.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryMandateCode rdf:type rdf:Property ;
    rdfs:label 'Regulatory Mandate Code' ;
    rdfs:comment 'Code identifying the specific regulatory requirement or mandate that necessitates this document (e.g., BSA, FATCA, CRS, KYC, CDD).' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason Code' ;
    rdfs:comment 'Code indicating the reason for document rejection if the document status is rejected.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason Description' ;
    rdfs:comment 'Detailed description of the reason for document rejection, providing context for business users and customers.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Retention Expiry Date' ;
    rdfs:comment 'Date when the document retention period expires and the document becomes eligible for destruction or archival.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:retentionPeriodYears rdf:type rdf:Property ;
    rdfs:label 'Retention Period Years' ;
    rdfs:comment 'Number of years the document must be retained per regulatory or internal policy requirements before eligible for destruction.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceSystemCode rdf:type rdf:Property ;
    rdfs:label 'Source System Code' ;
    rdfs:comment 'Code identifying the source system or channel from which the document was received (e.g., core banking system, online portal, branch system, mobile app).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageReferenceUri rdf:type rdf:Property ;
    rdfs:label 'Storage Reference Uri' ;
    rdfs:comment 'Uniform Resource Identifier (URI) or path reference to the physical or digital storage location of the document in the document management system or cloud storage.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typeCode rdf:type rdf:Property ;
    rdfs:label 'Type Code' ;
    rdfs:comment 'Classification code indicating the type of document. Examples include signature card, account agreement, beneficial ownership certification (FinCEN Form 314), W-9 tax form, W-8BEN tax form, power of attorney, court order, death certificate, Know Your Customer (KYC) document, Customer Due Diligence (CDD) document, identity verification, and address proof. [ENUM-REF-CANDIDATE: signature_card|account_agreement|beneficial_ownership_cert|w9_tax_form|w8ben_tax_form|power_of_attorney|court_order|death_certificate|kyc_document|cdd_document|identity_verification|address_proof — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uploadDate rdf:type rdf:Property ;
    rdfs:label 'Upload Date' ;
    rdfs:comment 'Date when the document was uploaded or received into the system.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:uploadTimestamp rdf:type rdf:Property ;
    rdfs:label 'Upload Timestamp' ;
    rdfs:comment 'Precise timestamp when the document was uploaded or received into the system, including time zone information.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:verificationDate rdf:type rdf:Property ;
    rdfs:label 'Verification Date' ;
    rdfs:comment 'Date when the document was verified for authenticity and completeness by an authorized officer.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Verification Timestamp' ;
    rdfs:comment 'Precise timestamp when the document verification was completed, including time zone information.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:version rdf:type rdf:Property ;
    rdfs:label 'Version' ;
    rdfs:comment 'Version identifier for the document, used to track revisions and updates over time.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountFeeId rdf:type rdf:Property ;
    rdfs:label 'Account Fee Id' ;
    rdfs:comment 'Unique identifier for the account fee record. Primary key for the account fee entity.' ;
    rdfs:domain ind:AccountFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceBreachId rdf:type rdf:Property ;
    rdfs:label 'Compliance Breach Id' ;
    rdfs:comment 'Foreign key linking to compliance.breach. Business justification: Fee assessment errors (unauthorized fees, incorrect disclosures, Reg E violations) constitute compliance breaches requiring tracking for regulatory reporting, restitution programs, consent order compl' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Breach .

ind:disputeCaseId rdf:type rdf:Property ;
    rdfs:label 'Dispute Case Id' ;
    rdfs:comment 'Reference to the customer dispute case or complaint ticket associated with this fee, if applicable. Used for tracking dispute resolution.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Case .

ind:employeeId rdf:type rdf:Property ;
    rdfs:label 'Employee Id' ;
    rdfs:comment 'Employee identifier or system identifier of the person or automated process that authorized the fee waiver. Used for accountability and audit trail.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:journalEntryId rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Id' ;
    rdfs:comment 'Foreign key linking to ledger.journal_entry. Business justification: Fee assessments generate journal entries for revenue recognition (DR Fee Receivable/Account, CR Fee Revenue). This links the fee subledger to GL for financial reporting and revenue accounting.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntry .

ind:waiverChannelId rdf:type rdf:Property ;
    rdfs:label 'Waiver Channel Id' ;
    rdfs:comment 'Foreign key linking to channel.channel. Business justification: Fee waiver requests are processed through specific channels for audit trails, customer service quality monitoring, and fraud prevention. Required for compliance reviews and dispute resolution. No exis' ;
    rdfs:domain ind:AccountFee ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:assessedAmount rdf:type rdf:Property ;
    rdfs:label 'Assessed Amount' ;
    rdfs:comment 'The gross amount of the fee assessed against the account before any waivers or adjustments, denominated in the account\'s base currency (typically USD for US operations).' ;
    rdfs:domain ind:AccountFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assessmentDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Date' ;
    rdfs:comment 'The business date on which the fee was assessed and posted to the account. This is the effective date for accounting and regulatory reporting purposes.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assessment Timestamp' ;
    rdfs:comment 'The precise date and time when the fee was assessed and recorded in the core banking system. Used for audit trail and transaction sequencing.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:billingCycle rdf:type rdf:Property ;
    rdfs:label 'Billing Cycle' ;
    rdfs:comment 'The billing cycle or statement period during which the fee was assessed. Typically formatted as YYYYMM or a cycle sequence number.' ;
    rdfs:domain ind:AccountFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:branchCode rdf:type rdf:Property ;
    rdfs:label 'Branch Code' ;
    rdfs:comment 'The branch or service center code where the account is domiciled or where the fee-triggering transaction occurred. Used for profitability analysis and branch performance reporting.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerNotificationFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Flag' ;
    rdfs:comment 'Boolean indicator of whether the customer was notified of this fee assessment through statement, email, SMS, or other communication channel.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disclosureStatementText rdf:type rdf:Property ;
    rdfs:label 'Disclosure Statement Text' ;
    rdfs:comment 'The standardized disclosure text that must be provided to the customer for this fee type, as required by CFPB Regulation DD or other applicable regulations.' ;
    rdfs:domain ind:AccountFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeFlag rdf:type rdf:Property ;
    rdfs:label 'Dispute Flag' ;
    rdfs:comment 'Boolean indicator of whether the customer has disputed this fee charge. True if a dispute case has been opened, False otherwise.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:feeDescription rdf:type rdf:Property ;
    rdfs:label 'Fee Description' ;
    rdfs:comment 'Detailed textual description of the fee assessed, including the reason and context for the charge. Used for customer statement generation and dispute resolution.' ;
    rdfs:domain ind:AccountFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccountCode rdf:type rdf:Property ;
    rdfs:label 'Gl Account Code' ;
    rdfs:comment 'The general ledger account code to which the fee income is posted. Used for financial accounting and revenue recognition.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineOfBusiness rdf:type rdf:Property ;
    rdfs:label 'Line Of Business' ;
    rdfs:comment 'The business segment or line of business to which this fee is attributed. RETAIL=Retail Banking, COMMERCIAL=Commercial Banking, WEALTH=Wealth Management, PRIVATE=Private Banking.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Net Fee Amount' ;
    rdfs:comment 'The net fee amount charged to the account after waivers and adjustments (assessed_amount minus waived_amount). This is the amount that impacts the account balance and fee income.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productCode rdf:type rdf:Property ;
    rdfs:label 'Product Code' ;
    rdfs:comment 'The product code or account type code of the deposit account against which the fee was assessed. Used for product profitability analysis.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryDisclosureRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Disclosure Required Flag' ;
    rdfs:comment 'Boolean indicator of whether this fee type requires specific regulatory disclosure to the customer under CFPB Regulation DD or other consumer protection regulations.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revenueRecognitionDate rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Date' ;
    rdfs:comment 'The accounting date on which the fee revenue is recognized in the general ledger. May differ from assessment_date due to revenue recognition policies.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reversalDate rdf:type rdf:Property ;
    rdfs:label 'Reversal Date' ;
    rdfs:comment 'The business date on which the fee was reversed and credited back to the account. Null if no reversal has occurred.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reversalFlag rdf:type rdf:Property ;
    rdfs:label 'Reversal Flag' ;
    rdfs:comment 'Boolean indicator of whether this fee has been fully reversed. True if the entire net_fee_amount has been credited back to the account.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reversalReasonCode rdf:type rdf:Property ;
    rdfs:label 'Reversal Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for fee reversal. ERROR=System or Processing Error, DISPUTE=Customer Dispute Resolution, GOODWILL=Customer Service Goodwill, REGULATORY=Regulatory Compliance Requirement, FRAUD=Fraudulent Activity. Null if no reversal occurred.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Transaction Reference Number' ;
    rdfs:comment 'The unique transaction identifier from the core banking system that triggered the fee assessment (e.g., the overdraft transaction ID, wire transfer ID, or ATM transaction ID). Used for reconciliation and dispute resolution.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waivedAmount rdf:type rdf:Property ;
    rdfs:label 'Waived Amount' ;
    rdfs:comment 'The portion of the assessed fee that was waived or reversed, denominated in the account\'s base currency. Zero if no waiver was applied.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waiverFlag rdf:type rdf:Property ;
    rdfs:label 'Waiver Flag' ;
    rdfs:comment 'Boolean indicator of whether any portion of the fee was waived. True if waived_amount is greater than zero, False otherwise.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waiverReasonCode rdf:type rdf:Property ;
    rdfs:label 'Waiver Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for fee waiver. CUST_REQ=Customer Request/Goodwill, SVC_FAIL=Service Failure, PROMO=Promotional Waiver, REL_MGMT=Relationship Management, REG_COMP=Regulatory Compliance, ERROR=System or Processing Error. Null if no waiver applied.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Waiver Reason Description' ;
    rdfs:comment 'Free-text explanation providing additional context for the fee waiver decision. Used for audit and customer service documentation.' ;
    rdfs:domain ind:AccountFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverTimestamp rdf:type rdf:Property ;
    rdfs:label 'Waiver Timestamp' ;
    rdfs:comment 'The date and time when the fee waiver was authorized and processed. Null if no waiver was applied.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:holdId rdf:type rdf:Property ;
    rdfs:label 'Hold Id' ;
    rdfs:comment 'Unique identifier for the account hold record. Primary key.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:holdEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Hold Employee Id' ;
    rdfs:comment 'System user ID or employee identifier of the individual who placed the hold. Null for automated system-generated holds. Used for audit and accountability.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:holdLastModifiedUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Hold Last Modified User Employee Id' ;
    rdfs:comment 'System user ID or employee identifier of the individual who last modified the hold record. Null for automated system updates. Used for audit and accountability.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:placingChannelId rdf:type rdf:Property ;
    rdfs:label 'Placing Channel Id' ;
    rdfs:comment 'Foreign key linking to channel.channel. Business justification: Legal and regulatory holds are placed through specific channels for compliance audit trails, dispute resolution, and fraud investigation documentation. Required for regulatory examinations and litigat' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:actualReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Actual Release Date' ;
    rdfs:comment 'The business date on which the hold was actually released or cancelled. Null for active holds. May differ from expected release date if manually released early or extended.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualReleaseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Release Timestamp' ;
    rdfs:comment 'Precise date and time when the hold was released, including timezone offset. Used for audit and compliance reporting.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:amount rdf:type rdf:Property ;
    rdfs:label 'Amount' ;
    rdfs:comment 'Monetary value of funds restricted by this hold, denominated in the account currency. This amount is unavailable for withdrawal or payment processing.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:beneficiaryName rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Name' ;
    rdfs:comment 'The name of the party entitled to receive the held funds, if applicable. Used for garnishments (e.g., creditor name), levies (e.g., IRS), or child support orders. Null for holds without a designated beneficiary.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficiaryReference rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Reference' ;
    rdfs:comment 'External reference number or account identifier for the beneficiary, such as a creditor account number or tax identification number. Null if not applicable.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkAmount rdf:type rdf:Property ;
    rdfs:label 'Check Amount' ;
    rdfs:comment 'The face value of the check that triggered the hold, if applicable. May differ from hold_amount if only a portion of the check is held. Null for non-check holds.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:checkSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Check Serial Number' ;
    rdfs:comment 'The serial number of the deposited check that triggered the hold, if applicable. Used for Reg CC check holds and exception case tracking. Null for non-check holds.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courtCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Court Case Number' ;
    rdfs:comment 'The docket or case number from the court order authorizing the hold, if applicable. Used for garnishments, levies, and legal holds. Null for non-legal holds.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courtJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Court Jurisdiction' ;
    rdfs:comment 'The name of the court or legal jurisdiction that issued the order, if applicable. Examples: \'Superior Court of California, County of Los Angeles\', \'U.S. District Court, Southern District of New York\'. Null for non-legal holds.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerNotificationSent rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Sent' ;
    rdfs:comment 'Indicates whether the account holder has been notified of the hold placement, as required by Reg CC for check holds and consumer protection regulations for other hold types.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disputeDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Date' ;
    rdfs:comment 'The date on which the customer filed a dispute regarding this hold. Null if no dispute has been filed.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disputeResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Date' ;
    rdfs:comment 'The date on which the dispute was resolved. Null if the dispute is still open or no dispute was filed.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expectedReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Expected Release Date' ;
    rdfs:comment 'The anticipated business date on which the hold will be automatically released, based on regulatory timelines (e.g., Reg CC hold periods) or court order expiration. Nullable for indefinite holds.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expirationAction rdf:type rdf:Property ;
    rdfs:label 'Expiration Action' ;
    rdfs:comment 'The action to be taken when the hold reaches its expected release date. Auto-release holds are lifted automatically; manual review holds require operations approval; extend holds are renewed for another period; escalate holds trigger compliance or legal review.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdStatus rdf:type rdf:Property ;
    rdfs:label 'Hold Status' ;
    rdfs:comment 'Current lifecycle status of the hold. Active holds reduce available balance; released holds have been lifted; expired holds passed their release date; cancelled holds were removed before maturity; partial release indicates a portion of the hold amount has been freed.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdType rdf:type rdf:Property ;
    rdfs:label 'Hold Type' ;
    rdfs:comment 'Classification of the hold based on its origin and purpose. Check holds are governed by Reg CC; legal holds include garnishments, levies, and court orders; fraud holds are placed by compliance or fraud teams; administrative holds are internal operational restrictions. [ENUM-REF-CANDIDATE: check_hold|legal_hold|administrative_hold|garnishment|levy|fraud_hold|regulatory_hold|collateral_hold — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalNotes rdf:type rdf:Property ;
    rdfs:label 'Internal Notes' ;
    rdfs:comment 'Free-text field for internal operational notes, case management updates, and audit trail commentary. Not visible to customers. Used by operations, compliance, and legal teams for case tracking.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCurrentRecord rdf:type rdf:Property ;
    rdfs:label 'Is Current Record' ;
    rdfs:comment 'Indicates whether this is the current active version of the hold record. True for the latest version; false for historical versions. Used for SCD Type 2 queries.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Modified Timestamp' ;
    rdfs:comment 'The date and time when this hold record was last updated in the source system or lakehouse. Used for incremental data processing and audit trails.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:notificationDate rdf:type rdf:Property ;
    rdfs:label 'Notification Date' ;
    rdfs:comment 'The date on which the customer notification was sent or delivered. Null if no notification has been sent. Used for regulatory compliance tracking.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notificationMethod rdf:type rdf:Property ;
    rdfs:label 'Notification Method' ;
    rdfs:comment 'The channel through which the customer was notified of the hold. Null if no notification has been sent. [ENUM-REF-CANDIDATE: mail|email|sms|phone|in_person|online_banking|mobile_app — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partialReleaseAllowed rdf:type rdf:Property ;
    rdfs:label 'Partial Release Allowed' ;
    rdfs:comment 'Indicates whether the hold can be partially released before full maturity. True for holds that support incremental release (e.g., large check holds under Reg CC); false for all-or-nothing holds (e.g., fraud holds, court orders).' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:placementDate rdf:type rdf:Property ;
    rdfs:label 'Placement Date' ;
    rdfs:comment 'The business date on which the hold was placed on the account. This is the effective date from which the funds became unavailable.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:placementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Placement Timestamp' ;
    rdfs:comment 'Precise date and time when the hold was created in the system, including timezone offset. Used for audit trails and sequence resolution.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:placingAuthority rdf:type rdf:Property ;
    rdfs:label 'Placing Authority' ;
    rdfs:comment 'The organizational unit or external entity that initiated the hold. Court orders and external agencies (e.g., IRS, child support enforcement) are captured separately from internal departments. [ENUM-REF-CANDIDATE: branch|legal_department|compliance|court_order|fraud_team|operations|automated_system|external_agency — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priority rdf:type rdf:Property ;
    rdfs:label 'Priority' ;
    rdfs:comment 'Numeric priority ranking for this hold when multiple holds exist on the same account. Lower numbers indicate higher priority. Used to determine order of fund allocation when account balance is insufficient to cover all holds. Legal holds typically have higher priority than administrative holds.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonCode rdf:type rdf:Property ;
    rdfs:label 'Reason Code' ;
    rdfs:comment 'Standardized internal code representing the specific reason for the hold. Maps to regulatory categories (e.g., Reg CC exception holds) and internal operational codes.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonNarrative rdf:type rdf:Property ;
    rdfs:label 'Reason Narrative' ;
    rdfs:comment 'Free-text description providing additional context for the hold. May include check number, court case number, fraud case ID, or other supporting details for operational and customer service use.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Record Effective Date' ;
    rdfs:comment 'The business date from which this version of the hold record is effective. Used for slowly changing dimension (SCD) Type 2 historization in the lakehouse.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recordEndDate rdf:type rdf:Property ;
    rdfs:label 'Record End Date' ;
    rdfs:comment 'The business date on which this version of the hold record ceased to be effective. Null for the current active version. Used for slowly changing dimension (SCD) Type 2 historization.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryBasis rdf:type rdf:Property ;
    rdfs:label 'Regulatory Basis' ;
    rdfs:comment 'The primary regulatory or legal framework under which the hold is placed. Reg CC governs check holds; BSA/AML/OFAC govern compliance holds; court orders and tax levies are legal holds. \'None\' indicates an internal administrative hold. [ENUM-REF-CANDIDATE: reg_cc|bsa|aml|ofac|court_order|garnishment_order|tax_levy|none — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releasedAmount rdf:type rdf:Property ;
    rdfs:label 'Released Amount' ;
    rdfs:comment 'The cumulative amount of funds that have been released from this hold through partial releases. Zero for holds that have not been partially released. Equals hold_amount when the hold is fully released.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remainingHoldAmount rdf:type rdf:Property ;
    rdfs:label 'Remaining Hold Amount' ;
    rdfs:comment 'The current amount still held after any partial releases. Calculated as hold_amount minus released_amount. Used for real-time available balance calculation.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holderId rdf:type rdf:Property ;
    rdfs:label 'Holder Id' ;
    rdfs:comment 'Unique identifier for the account holder association record. Primary key.' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:collateralPledgeId rdf:type rdf:Property ;
    rdfs:label 'Collateral Pledge Id' ;
    rdfs:comment 'Foreign key linking to collateral.pledge. Business justification: Account holders pledge their deposit accounts or account-held assets as collateral for credit facilities. Banks track which account holder executed the pledge for legal enforceability, signature autho' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CollateralPledge .

ind:holderEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Holder Employee Id' ;
    rdfs:comment 'The system user ID or employee ID of the person who created this account holder record. Audit trail field for accountability and compliance.' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:holderLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Holder Last Modified By User Employee Id' ;
    rdfs:comment 'The system user ID or employee ID of the person who last modified this account holder record. Audit trail field for accountability and compliance.' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:partyId rdf:type rdf:Property ;
    rdfs:label 'Party Id' ;
    rdfs:comment 'Reference to the individual or legal entity (from customer domain) who holds rights or interests in the account. Links to the customer master.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:amlRiskRating rdf:type rdf:Property ;
    rdfs:label 'Aml Risk Rating' ;
    rdfs:comment 'The Anti-Money Laundering (AML) risk rating assigned to this account holder based on customer profile, transaction patterns, geographic risk, and other factors. Determines monitoring intensity and reporting requirements.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amlRiskRatingDate rdf:type rdf:Property ;
    rdfs:label 'Aml Risk Rating Date' ;
    rdfs:comment 'The date on which the current AML risk rating was assigned or last reviewed. Used to track compliance with periodic risk assessment requirements.' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:beneficiaryAllocationPercentage rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Allocation Percentage' ;
    rdfs:comment 'The percentage of account proceeds allocated to this beneficiary upon the death of the account owner. Must sum to 100.00 across all beneficiaries of the same account. Null for non-beneficiary roles.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:beneficiaryDesignationDate rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Designation Date' ;
    rdfs:comment 'The date on which the beneficiary designation was made by the account owner. Null if this holder is not a beneficiary.' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:beneficiaryRelationship rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Relationship' ;
    rdfs:comment 'The relationship of the beneficiary to the account owner. Used for estate planning, probate processing, and FDIC insurance coverage calculation. None if this holder is not a beneficiary. [ENUM-REF-CANDIDATE: spouse|child|parent|sibling|other_relative|friend|organization|none — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficiaryRevocationDate rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Revocation Date' ;
    rdfs:comment 'The date on which the beneficiary designation was revoked by the account owner. Null if the beneficiary designation is still active or was never revoked.' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:beneficiaryType rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Type' ;
    rdfs:comment 'The type of beneficiary designation for payable-on-death (POD) or transfer-on-death (TOD) roles. Individual for natural persons; trust for revocable or irrevocable trusts; estate for estate of deceased; charity for non-profit organizations. None if this holder is not a beneficiary.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designationDate rdf:type rdf:Property ;
    rdfs:label 'Designation Date' ;
    rdfs:comment 'The date on which the customer was formally designated or added to the account in this role. May differ from effective_date if there is a lag between designation and activation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fdicInsuranceCategory rdf:type rdf:Property ;
    rdfs:label 'Fdic Insurance Category' ;
    rdfs:comment 'The FDIC insurance ownership category applicable to this account holder relationship. Determines insurance coverage limits and aggregation rules. Single for individual ownership; joint for joint ownership; revocable_trust for living trusts; irrevocable_trust for irrevocable trusts; employee_benefit for retirement accounts; corporation for business entities; government for public funds. [ENUM-REF-CANDIDATE: single|joint|revocable_trust|irrevocable_trust|employee_benefit|corporation|government — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kycNextReviewDate rdf:type rdf:Property ;
    rdfs:label 'Kyc Next Review Date' ;
    rdfs:comment 'The date on which the next periodic KYC review is due for this account holder. Determined by risk rating and regulatory requirements.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:kycVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Kyc Verification Date' ;
    rdfs:comment 'The date on which KYC verification was completed for this account holder. Used to track compliance with periodic re-verification requirements.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:kycVerificationStatus rdf:type rdf:Property ;
    rdfs:label 'Kyc Verification Status' ;
    rdfs:comment 'The status of Know Your Customer (KYC) verification for this account holder. Verified indicates successful identity verification; pending indicates verification in progress; failed indicates verification could not be completed; expired indicates verification needs renewal.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationPreference rdf:type rdf:Property ;
    rdfs:label 'Notification Preference' ;
    rdfs:comment 'The preferred communication channel for account notifications and alerts for this holder. Email for electronic mail; SMS for text messages; phone for voice calls; mail for postal mail; none if notifications are suppressed.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipPercentage rdf:type rdf:Property ;
    rdfs:label 'Ownership Percentage' ;
    rdfs:comment 'The percentage of ownership interest held by this customer in the account. Applicable for joint accounts where ownership is divided. Must sum to 100.00 across all owners of the same account. Null for non-ownership roles (authorized signer, power of attorney).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ownershipRole rdf:type rdf:Property ;
    rdfs:label 'Ownership Role' ;
    rdfs:comment 'The role or capacity in which the customer holds rights to the account. Determines access rights, signing authority, and legal standing. Primary owner has full control; joint owner shares ownership; authorized signer can transact but does not own; power of attorney acts on behalf of owner; trustee manages for beneficiaries; custodian holds for minors or incapacitated persons.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pepStatus rdf:type rdf:Property ;
    rdfs:label 'Pep Status' ;
    rdfs:comment 'Indicates whether this account holder is identified as a Politically Exposed Person (PEP) - an individual who holds or has held a prominent public position. True if PEP; False if not. PEP status triggers enhanced due diligence requirements.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipStatus rdf:type rdf:Property ;
    rdfs:label 'Relationship Status' ;
    rdfs:comment 'The current lifecycle status of this account holder relationship. Active indicates the relationship is in effect and the holder has the specified rights; inactive indicates temporary suspension; suspended indicates regulatory or compliance hold; terminated indicates the relationship has ended.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revocationDate rdf:type rdf:Property ;
    rdfs:label 'Revocation Date' ;
    rdfs:comment 'The date on which the account holder designation was revoked or terminated by the account owner or by operation of law. Null if the relationship is still active or was never revoked.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sanctionsScreeningDate rdf:type rdf:Property ;
    rdfs:label 'Sanctions Screening Date' ;
    rdfs:comment 'The date on which the most recent sanctions screening was performed for this account holder. Screening is typically performed at onboarding and periodically thereafter.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sanctionsScreeningStatus rdf:type rdf:Property ;
    rdfs:label 'Sanctions Screening Status' ;
    rdfs:comment 'The result of sanctions screening against OFAC, UN, EU, and other sanctions lists. Clear indicates no match; match indicates potential match requiring review; pending_review indicates screening in progress; blocked indicates confirmed match and account restrictions applied.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signingAuthorityLevel rdf:type rdf:Property ;
    rdfs:label 'Signing Authority Level' ;
    rdfs:comment 'The level of transaction authority granted to this holder. Full authority allows all transactions without limits; limited authority is subject to transaction amount thresholds or approval requirements; none indicates no transactional rights (e.g., beneficiary-only role).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signingAuthorityLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Signing Authority Limit Amount' ;
    rdfs:comment 'The maximum transaction amount (in account currency) that this holder can authorize without additional approval. Applicable when signing_authority_level is limited. Null for full or none authority levels.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceSystemRecordReference rdf:type rdf:Property ;
    rdfs:label 'Source System Record Reference' ;
    rdfs:comment 'The unique identifier of this account holder record in the source system. Used for traceability and reconciliation back to the operational system of record.' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statementDeliveryPreference rdf:type rdf:Property ;
    rdfs:label 'Statement Delivery Preference' ;
    rdfs:comment 'The account holders preference for receiving account statements. Electronic for online/email delivery; paper for postal mail; both for dual delivery; none if statements are suppressed (e.g., for non-primary holders).' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportingDocumentationReference rdf:type rdf:Property ;
    rdfs:label 'Supporting Documentation Reference' ;
    rdfs:comment 'Reference identifier or file path to supporting legal documentation for this holder relationship. Examples include power of attorney documents, trust agreements, custodial orders, beneficiary designation forms, or court orders.' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxIdNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Id Number' ;
    rdfs:comment 'The tax identification number (TIN) for this account holder. Social Security Number (SSN) for US individuals; Employer Identification Number (EIN) for US entities; foreign tax ID for non-US persons. Used for tax reporting and compliance.' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxIdType rdf:type rdf:Property ;
    rdfs:label 'Tax Id Type' ;
    rdfs:comment 'The type of tax identification number provided. SSN for Social Security Number; EIN for Employer Identification Number; ITIN for Individual Taxpayer Identification Number; foreign_tin for non-US tax ID; none if not provided or not applicable.' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxReportingStatus rdf:type rdf:Property ;
    rdfs:label 'Tax Reporting Status' ;
    rdfs:comment 'The tax reporting status for interest and other income attributable to this account holder. Reportable indicates 1099-INT reporting required; exempt indicates tax-exempt entity; foreign indicates FATCA or CRS reporting required; pending indicates status determination in progress.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationReason rdf:type rdf:Property ;
    rdfs:label 'Termination Reason' ;
    rdfs:comment 'The reason for termination of this account holder relationship. Examples include account closure, holder removal by owner, death of holder, expiration of power of attorney, or regulatory action. Null if relationship is still active.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:w9W8FormReceivedDate rdf:type rdf:Property ;
    rdfs:label 'W9 W8 Form Received Date' ;
    rdfs:comment 'The date on which the IRS Form W-9 (for US persons) or Form W-8 (for foreign persons) was received from this account holder. Required for tax reporting compliance.' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:interestAccrualId rdf:type rdf:Property ;
    rdfs:label 'Interest Accrual Id' ;
    rdfs:comment 'Unique identifier for the daily interest accrual record. Primary key for the account interest accrual entity.' ;
    rdfs:domain ind:InterestAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accrualBasisCode rdf:type rdf:Property ;
    rdfs:label 'Accrual Basis Code' ;
    rdfs:comment 'Day count convention used to calculate interest accrual. Determines how days are counted in the numerator and denominator of the interest calculation formula. ACT/360 is common for money market accounts, ACT/365 for savings, 30/360 for certain time deposits.' ;
    rdfs:domain ind:InterestAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accrualDate rdf:type rdf:Property ;
    rdfs:label 'Accrual Date' ;
    rdfs:comment 'The business date on which this interest accrual calculation was performed. Represents the principal business event timestamp for this daily accrual record.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accrualMethod rdf:type rdf:Property ;
    rdfs:label 'Accrual Method' ;
    rdfs:comment 'The mathematical method used to calculate interest accrual. Simple interest is calculated on principal only; compound interest includes previously accrued interest in the calculation base; continuous uses exponential compounding.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accrualReversalReason rdf:type rdf:Property ;
    rdfs:label 'Accrual Reversal Reason' ;
    rdfs:comment 'Code or description explaining why this accrual was reversed, if applicable. Common reasons include account closure, rate correction, system error, or NPL (Non-Performing Loan) classification requiring accrual suspension.' ;
    rdfs:domain ind:InterestAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accrualStatus rdf:type rdf:Property ;
    rdfs:label 'Accrual Status' ;
    rdfs:comment 'Current lifecycle status of this accrual record. Calculated indicates daily accrual computed but not yet posted; posted indicates interest has been capitalized to account; reversed indicates accrual was backed out; suspended indicates accrual is on hold (e.g., for NPL accounts).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accruedInterestAmount rdf:type rdf:Property ;
    rdfs:label 'Accrued Interest Amount' ;
    rdfs:comment 'The interest amount accrued for this specific accrual date, calculated as (principal_balance × applicable_interest_rate × days) / day_count_basis. This is the daily interest increment.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:applicableInterestRate rdf:type rdf:Property ;
    rdfs:label 'Applicable Interest Rate' ;
    rdfs:comment 'The annualized interest rate applied to calculate this accrual, expressed as a decimal (e.g., 0.025000000 for 2.5% per annum). May reflect tiered rate, promotional rate, or base rate depending on account balance and product terms.' ;
    rdfs:domain ind:InterestAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calculationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Calculation Timestamp' ;
    rdfs:comment 'The system timestamp when this interest accrual calculation was performed. Used for audit trail and to distinguish between batch calculation runs.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cumulativeAccruedInterest rdf:type rdf:Property ;
    rdfs:label 'Cumulative Accrued Interest' ;
    rdfs:comment 'The total interest accrued from the last interest posting date through the current accrual date. Represents the running total of unpaid accrued interest for the current interest period.' ;
    rdfs:domain ind:InterestAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interestIncomeGlAccount rdf:type rdf:Property ;
    rdfs:label 'Interest Income Gl Account' ;
    rdfs:comment 'The general ledger account code to which this interest expense (from the bank\'s perspective) is posted. Used for financial accounting and NII (Net Interest Income) reporting.' ;
    rdfs:domain ind:InterestAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interestPayableGlAccount rdf:type rdf:Property ;
    rdfs:label 'Interest Payable Gl Account' ;
    rdfs:comment 'The general ledger account code for the accrued interest payable liability. Represents the contra-account for the interest expense accrual until interest is posted to the customer account.' ;
    rdfs:domain ind:InterestAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interestPostingFrequency rdf:type rdf:Property ;
    rdfs:label 'Interest Posting Frequency' ;
    rdfs:comment 'The frequency at which accrued interest is capitalized and posted to the account balance. Defines the cadence of interest payment or compounding per the account product terms. [ENUM-REF-CANDIDATE: daily|weekly|monthly|quarterly|semi-annually|annually|at_maturity — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InterestAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interestRateTierCode rdf:type rdf:Property ;
    rdfs:label 'Interest Rate Tier Code' ;
    rdfs:comment 'Code identifying the balance tier or rate band applied for this accrual. Used when accounts have tiered interest structures where different balance ranges earn different rates.' ;
    rdfs:domain ind:InterestAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastInterestPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Last Interest Payment Date' ;
    rdfs:comment 'The most recent date on which interest was posted or paid to the account. Marks the beginning of the current accrual period.' ;
    rdfs:domain ind:InterestAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:modifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Modified Timestamp' ;
    rdfs:comment 'The timestamp when this accrual record was last updated. Used for audit trail and change tracking.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:netInterestAmount rdf:type rdf:Property ;
    rdfs:label 'Net Interest Amount' ;
    rdfs:comment 'The net interest amount after withholding tax deduction, calculated as accrued_interest_amount minus withholding_tax_amount. Represents the interest amount that will be credited to the customer.' ;
    rdfs:domain ind:InterestAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextInterestPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Next Interest Payment Date' ;
    rdfs:comment 'The scheduled date on which the cumulative accrued interest will be posted to the account or paid to the customer. Used for interest payment planning and customer disclosure.' ;
    rdfs:domain ind:InterestAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:postedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Posted Timestamp' ;
    rdfs:comment 'The system timestamp when the accrued interest was posted to the customer account or general ledger. Null if accrual status is calculated or pending_review.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:principalBalance rdf:type rdf:Property ;
    rdfs:label 'Principal Balance' ;
    rdfs:comment 'The account balance amount on which interest is calculated for this accrual date. Represents the principal subject to interest computation, typically the end-of-day ledger balance.' ;
    rdfs:domain ind:InterestAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Flag' ;
    rdfs:comment 'Indicates whether this accrual must be included in regulatory capital or liquidity reporting (e.g., Basel III LCR, NSFR calculations). True if regulatory reporting is required, False otherwise.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Reporting Flag' ;
    rdfs:comment 'Indicates whether this interest accrual must be included in tax reporting (e.g., 1099-INT for US customers, FATCA/CRS reporting for foreign accounts). True if tax reporting is required, False otherwise.' ;
    rdfs:domain ind:InterestAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:withholdingTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Amount' ;
    rdfs:comment 'The tax amount withheld from the accrued interest for this accrual date, calculated as accrued_interest_amount × withholding_tax_rate. Represents the portion of interest income remitted to tax authorities.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:withholdingTaxRate rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Rate' ;
    rdfs:comment 'The tax rate applied to withhold tax on interest income for applicable accounts, expressed as a decimal (e.g., 0.300000 for 30%). Applies to accounts subject to FATCA, CRS, or domestic tax withholding requirements.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yearBasisDays rdf:type rdf:Property ;
    rdfs:label 'Year Basis Days' ;
    rdfs:comment 'The number of days used in the denominator of the interest calculation (e.g., 360, 365, or actual days in year). Determined by the accrual_basis_code and used to annualize the interest rate.' ;
    rdfs:domain ind:InterestAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:interestRateId rdf:type rdf:Property ;
    rdfs:label 'Interest Rate Id' ;
    rdfs:comment 'Unique identifier for the account interest rate configuration record.' ;
    rdfs:domain ind:InterestRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Approved By Employee Id' ;
    rdfs:comment 'Foreign key linking to hr.employee. Business justification: Interest rate changes and exceptions require documented approval by ALCO members, pricing committee, or relationship managers per pricing governance and margin management policies. Real business proce' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:rateBenchmarkId rdf:type rdf:Property ;
    rdfs:label 'Rate Benchmark Id' ;
    rdfs:comment 'The market benchmark index to which variable rates are tied. SOFR (Secured Overnight Financing Rate), FED_FUNDS (Federal Funds Rate), PRIME (Prime Rate), LIBOR (London Interbank Offered Rate - legacy), TREASURY (US Treasury Rate), or NONE for fixed rates.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RateBenchmark .

ind:supersededByRateInterestRateId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Rate Interest Rate Id' ;
    rdfs:comment 'Reference to the account_interest_rate_id that supersedes this rate configuration. Used to maintain rate change history and audit trail.' ;
    rdfs:domain ind:InterestRate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InterestRate .

ind:baseRate rdf:type rdf:Property ;
    rdfs:label 'Base Rate' ;
    rdfs:comment 'The base annual interest rate expressed as a decimal (e.g., 0.025000 for 2.5%). For fixed rates, this is the final rate. For variable rates, this is the starting point before spread adjustment.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compoundingFrequency rdf:type rdf:Property ;
    rdfs:label 'Compounding Frequency' ;
    rdfs:comment 'The frequency at which interest is compounded and added to the principal balance. Daily compounding is most common for deposit accounts.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdByUser rdf:type rdf:Property ;
    rdfs:label 'Created By User' ;
    rdfs:comment 'The user ID or system identifier of the person or process that created this interest rate configuration record. Used for audit trail and accountability.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ftpRate rdf:type rdf:Property ;
    rdfs:label 'Ftp Rate' ;
    rdfs:comment 'The internal Funds Transfer Pricing rate used to allocate funding costs or credits between business lines. Expressed as a decimal. Used for management accounting and profitability attribution.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interestPaymentFrequency rdf:type rdf:Property ;
    rdfs:label 'Interest Payment Frequency' ;
    rdfs:comment 'The frequency at which accrued interest is credited to the customer\'s account or paid out. Most deposit accounts credit interest monthly.' ;
    rdfs:domain ind:InterestRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPromotional rdf:type rdf:Property ;
    rdfs:label 'Is Promotional' ;
    rdfs:comment 'Indicates whether this is a promotional interest rate offered as part of a marketing campaign or customer acquisition strategy. True if promotional, False if standard rate.' ;
    rdfs:domain ind:InterestRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTaxAdvantaged rdf:type rdf:Property ;
    rdfs:label 'Is Tax Advantaged' ;
    rdfs:comment 'Indicates whether this rate applies to a tax-advantaged account type (e.g., IRA, HSA, 529 plan) where interest may be tax-deferred or tax-exempt. True if tax-advantaged, False otherwise.' ;
    rdfs:domain ind:InterestRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maximumBalanceCap rdf:type rdf:Property ;
    rdfs:label 'Maximum Balance Cap' ;
    rdfs:comment 'The maximum account balance on which interest is paid at this rate. Balances exceeding this cap may earn a different rate or no additional interest.' ;
    rdfs:domain ind:InterestRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumBalanceRequirement rdf:type rdf:Property ;
    rdfs:label 'Minimum Balance Requirement' ;
    rdfs:comment 'The minimum account balance required to earn the stated interest rate. Balances below this threshold may earn a lower rate or no interest.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nimContributionBps rdf:type rdf:Property ;
    rdfs:label 'Nim Contribution Bps' ;
    rdfs:comment 'The estimated contribution of this rate configuration to the bank\'s Net Interest Margin (NIM), expressed in basis points. Used for profitability analysis and ALCO reporting.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionalExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Promotional Expiry Date' ;
    rdfs:comment 'The date on which the promotional rate expires and reverts to the standard rate. Only applicable when is_promotional is True.' ;
    rdfs:domain ind:InterestRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rateApprovalAuthority rdf:type rdf:Property ;
    rdfs:label 'Rate Approval Authority' ;
    rdfs:comment 'The governance body or role that approved this interest rate configuration. ALCO (Asset-Liability Committee), TREASURY, PRODUCT_MANAGEMENT, BRANCH_MANAGER, or EXECUTIVE_COMMITTEE.' ;
    rdfs:domain ind:InterestRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Rate Approval Date' ;
    rdfs:comment 'The date on which this interest rate configuration was formally approved by the designated approval authority.' ;
    rdfs:domain ind:InterestRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rateCeiling rdf:type rdf:Property ;
    rdfs:label 'Rate Ceiling' ;
    rdfs:comment 'The maximum interest rate that can be applied regardless of benchmark index movements. Caps the bank\'s interest expense exposure. Expressed as a decimal.' ;
    rdfs:domain ind:InterestRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateChangeFrequency rdf:type rdf:Property ;
    rdfs:label 'Rate Change Frequency' ;
    rdfs:comment 'The frequency at which variable interest rates are reviewed and potentially adjusted based on benchmark index movements. Fixed rates use \'at_maturity\' or \'as_needed\'. [ENUM-REF-CANDIDATE: daily|weekly|monthly|quarterly|annually|at_maturity|as_needed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateChangeReason rdf:type rdf:Property ;
    rdfs:label 'Rate Change Reason' ;
    rdfs:comment 'Business justification or reason for this rate configuration or rate change. Examples: \'Benchmark index adjustment\', \'Competitive positioning\', \'Promotional campaign Q4 2024\', \'ALCO directive\'.' ;
    rdfs:domain ind:InterestRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateFloor rdf:type rdf:Property ;
    rdfs:label 'Rate Floor' ;
    rdfs:comment 'The minimum interest rate that can be applied regardless of benchmark index movements. Protects the bank from negative or excessively low rates. Expressed as a decimal.' ;
    rdfs:domain ind:InterestRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateStatus rdf:type rdf:Property ;
    rdfs:label 'Rate Status' ;
    rdfs:comment 'The current lifecycle status of this interest rate configuration. Active (currently in effect), Pending (approved but not yet effective), Expired (past expiry date), Superseded (replaced by newer rate), or Suspended (temporarily inactive).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateType rdf:type rdf:Property ;
    rdfs:label 'Rate Type' ;
    rdfs:comment 'Classification of the interest rate structure: fixed (constant rate), variable (indexed to benchmark), tiered (rate varies by balance threshold), or promotional (temporary marketing rate).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryDisclosureText rdf:type rdf:Property ;
    rdfs:label 'Regulatory Disclosure Text' ;
    rdfs:comment 'The standardized disclosure text required by Regulation DD for customer communication regarding this interest rate, including APY calculation methodology and any conditions or limitations.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipBonusBps rdf:type rdf:Property ;
    rdfs:label 'Relationship Bonus Bps' ;
    rdfs:comment 'Additional basis points added to the base rate for customers meeting relationship pricing criteria. For example, 25 BPS = 0.25% rate bonus.' ;
    rdfs:domain ind:InterestRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:relationshipPricingEligible rdf:type rdf:Property ;
    rdfs:label 'Relationship Pricing Eligible' ;
    rdfs:comment 'Indicates whether this rate is eligible for relationship pricing adjustments based on the customer\'s total Assets Under Management (AUM) or product holdings with the bank. True if eligible, False otherwise.' ;
    rdfs:domain ind:InterestRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:spreadBps rdf:type rdf:Property ;
    rdfs:label 'Spread Bps' ;
    rdfs:comment 'The spread over the benchmark index expressed in basis points (BPS). One basis point equals 0.01%. For example, 50 BPS = 0.50%. Applied to variable rates only.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxWithholdingRate rdf:type rdf:Property ;
    rdfs:label 'Tax Withholding Rate' ;
    rdfs:comment 'The percentage of interest income subject to tax withholding, expressed as a decimal (e.g., 0.2400 for 24%). Applicable for certain account types and jurisdictions.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tierApr rdf:type rdf:Property ;
    rdfs:label 'Tier Apr' ;
    rdfs:comment 'The Annual Percentage Rate for this balance tier, expressed as a decimal (e.g., 0.024693 for 2.4693% APR). APR is the simple interest rate before compounding effects.' ;
    rdfs:domain ind:InterestRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tierApy rdf:type rdf:Property ;
    rdfs:label 'Tier Apy' ;
    rdfs:comment 'The Annual Percentage Yield for this balance tier, expressed as a decimal (e.g., 0.025000 for 2.5% APY). APY reflects the effect of compounding and is the rate disclosed to customers per Regulation DD.' ;
    rdfs:domain ind:InterestRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tierMaximumBalance rdf:type rdf:Property ;
    rdfs:label 'Tier Maximum Balance' ;
    rdfs:comment 'The maximum balance threshold for this rate tier. Balances above this amount move to the next tier. Null for the highest tier indicating no upper limit.' ;
    rdfs:domain ind:InterestRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tierMinimumBalance rdf:type rdf:Property ;
    rdfs:label 'Tier Minimum Balance' ;
    rdfs:comment 'The minimum balance threshold for this rate tier. Balances at or above this amount and below the tier maximum earn this tier\'s rate. Part of tiered rate structure.' ;
    rdfs:domain ind:InterestRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tierSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Tier Sequence Number' ;
    rdfs:comment 'The ordinal position of this rate tier within a tiered rate structure. Tier 1 is the lowest balance tier, incrementing for higher balance tiers. Null for non-tiered rates.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:updatedByUser rdf:type rdf:Property ;
    rdfs:label 'Updated By User' ;
    rdfs:comment 'The user ID or system identifier of the person or process that last modified this interest rate configuration record. Used for audit trail and accountability.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountLimitId rdf:type rdf:Property ;
    rdfs:label 'Account Limit Id' ;
    rdfs:comment 'Unique identifier for the account limit record. Primary key for the account limit entity.' ;
    rdfs:domain ind:AccountLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:amlThresholdFlag rdf:type rdf:Property ;
    rdfs:label 'Aml Threshold Flag' ;
    rdfs:comment 'Indicates whether this limit is configured to support Anti-Money Laundering (AML) monitoring and Currency Transaction Report (CTR) thresholds. True if AML-related, False otherwise.' ;
    rdfs:domain ind:AccountLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvalAuthority rdf:type rdf:Property ;
    rdfs:label 'Approval Authority' ;
    rdfs:comment 'The role, department, or individual authorized to approve this limit configuration. May reference a user ID, role code, or department name.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approval Timestamp' ;
    rdfs:comment 'Date and time when this limit was approved. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:breachActionCode rdf:type rdf:Property ;
    rdfs:label 'Breach Action Code' ;
    rdfs:comment 'Action to be taken when a transaction would breach this limit. Values: BLOCK (reject transaction), WARN (alert but allow), ALLOW_WITH_FEE (permit with penalty charge), ESCALATE (require manual approval).' ;
    rdfs:domain ind:AccountLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerRequestedFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Requested Flag' ;
    rdfs:comment 'Indicates whether this limit was requested by the customer (e.g., self-imposed spending limit) rather than being bank-mandated. True if customer-initiated, False if bank-imposed.' ;
    rdfs:domain ind:AccountLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fraudPreventionFlag rdf:type rdf:Property ;
    rdfs:label 'Fraud Prevention Flag' ;
    rdfs:comment 'Indicates whether this limit is primarily configured for fraud prevention purposes. True if the limit is part of fraud controls, False otherwise.' ;
    rdfs:domain ind:AccountLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastResetTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Reset Timestamp' ;
    rdfs:comment 'Date and time when the utilization counters were last reset. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:AccountLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastUtilizationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Utilization Timestamp' ;
    rdfs:comment 'Date and time of the most recent transaction that utilized this limit. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:AccountLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:limitDescription rdf:type rdf:Property ;
    rdfs:label 'Limit Description' ;
    rdfs:comment 'Free-text description providing additional context or business rationale for this limit configuration.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limitStatus rdf:type rdf:Property ;
    rdfs:label 'Limit Status' ;
    rdfs:comment 'Current lifecycle status of the account limit. Values: ACTIVE (limit is currently enforced), SUSPENDED (temporarily not enforced), EXPIRED (past expiry date), PENDING (awaiting approval or activation), CANCELLED (permanently deactivated).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedBy rdf:type rdf:Property ;
    rdfs:label 'Modified By' ;
    rdfs:comment 'Identifier of the user or system that last modified this limit record. May be a user ID, employee number, or system identifier.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Notification Threshold Amount' ;
    rdfs:comment 'The utilization amount at which the customer or bank should be notified (e.g., alert when 80% of limit is reached). Nullable if no notification threshold is configured.' ;
    rdfs:domain ind:AccountLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overrideFlag rdf:type rdf:Property ;
    rdfs:label 'Override Flag' ;
    rdfs:comment 'Indicates whether this limit can be overridden by authorized personnel during transaction processing. True if override is permitted, False otherwise.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overrideReason rdf:type rdf:Property ;
    rdfs:label 'Override Reason' ;
    rdfs:comment 'Business justification or reason code for allowing limit overrides. Populated when override_flag is True.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resetFrequencyCode rdf:type rdf:Property ;
    rdfs:label 'Reset Frequency Code' ;
    rdfs:comment 'Frequency at which the utilization counters are reset to zero. Values: DAILY (reset at start of each day), WEEKLY (reset weekly), MONTHLY (reset monthly), QUARTERLY (reset quarterly), ANNUAL (reset annually), NONE (no automatic reset).' ;
    rdfs:domain ind:AccountLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskCategory rdf:type rdf:Property ;
    rdfs:label 'Risk Category' ;
    rdfs:comment 'Risk classification of the account or customer for which this limit is configured. Used to determine appropriate limit thresholds. Values: LOW (minimal risk), MEDIUM (moderate risk), HIGH (elevated risk), CRITICAL (highest risk requiring strictest controls).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utilizationAmount rdf:type rdf:Property ;
    rdfs:label 'Utilization Amount' ;
    rdfs:comment 'Current cumulative amount utilized against this limit within the applicable time period (e.g., daily, monthly). Reset frequency depends on limit type.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:utilizationCount rdf:type rdf:Property ;
    rdfs:label 'Utilization Count' ;
    rdfs:comment 'Number of transactions that have been applied against this limit within the current period. Used for frequency-based limits.' ;
    rdfs:domain ind:AccountLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:versionNumber rdf:type rdf:Property ;
    rdfs:label 'Version Number' ;
    rdfs:comment 'Version number of this limit record, incremented with each modification. Used for optimistic locking and audit trail.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdBy rdf:type rdf:Property ;
    rdfs:label 'Created By' ;
    rdfs:comment 'Identifier of the user or system that created this limit record. May be a user ID, employee number, or system identifier.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountProductId rdf:type rdf:Property ;
    rdfs:label 'Account Product Id' ;
    rdfs:comment 'Unique identifier for the account product. Primary key for the account product catalog.' ;
    rdfs:domain ind:AccountProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reportingCodeId rdf:type rdf:Property ;
    rdfs:label 'Reporting Code Id' ;
    rdfs:comment 'FFIEC Call Report schedule and line item code for regulatory reporting. Maps to specific lines in FFIEC 031/041 Consolidated Reports of Condition and Income.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReportingCode .

ind:accountTypeCode rdf:type rdf:Property ;
    rdfs:label 'Account Type Code' ;
    rdfs:comment 'Granular account type classification code used for operational processing and system routing within the core banking platform.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:achTransferAllowed rdf:type rdf:Property ;
    rdfs:label 'Ach Transfer Allowed' ;
    rdfs:comment 'Indicates whether ACH transfers (both incoming and outgoing) are permitted for accounts under this product. True = ACH allowed, False = ACH restricted.' ;
    rdfs:domain ind:AccountProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ageRestrictionMaximum rdf:type rdf:Property ;
    rdfs:label 'Age Restriction Maximum' ;
    rdfs:comment 'Maximum age limit for opening an account under this product (e.g., student accounts). Null if no maximum age restriction applies.' ;
    rdfs:domain ind:AccountProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ageRestrictionMinimum rdf:type rdf:Property ;
    rdfs:label 'Age Restriction Minimum' ;
    rdfs:comment 'Minimum age requirement for primary account holder to open an account under this product. Null if no age restriction applies.' ;
    rdfs:domain ind:AccountProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bicCode rdf:type rdf:Property ;
    rdfs:label 'Bic Code' ;
    rdfs:comment 'Bank Identifier Code (also known as SWIFT code) associated with this product for international wire transfers and SWIFT messaging. Format: 8 or 11 alphanumeric characters.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkWritingAllowed rdf:type rdf:Property ;
    rdfs:label 'Check Writing Allowed' ;
    rdfs:comment 'Indicates whether check writing privileges are permitted for accounts under this product. True = checks allowed, False = no check writing.' ;
    rdfs:domain ind:AccountProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crsReportable rdf:type rdf:Property ;
    rdfs:label 'Crs Reportable' ;
    rdfs:comment 'Indicates whether accounts under this product are subject to OECD Common Reporting Standard for automatic exchange of financial account information. True = CRS reportable, False = exempt.' ;
    rdfs:domain ind:AccountProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:debitCardEligible rdf:type rdf:Property ;
    rdfs:label 'Debit Card Eligible' ;
    rdfs:comment 'Indicates whether accounts under this product are eligible for debit card issuance. True = debit card can be issued, False = not eligible.' ;
    rdfs:domain ind:AccountProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discontinuationDate rdf:type rdf:Property ;
    rdfs:label 'Discontinuation Date' ;
    rdfs:comment 'Date on which this product was discontinued and closed to new accounts. Null if product is still active or pending.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eligibleCustomerSegments rdf:type rdf:Property ;
    rdfs:label 'Eligible Customer Segments' ;
    rdfs:comment 'Comma-separated list of customer segments eligible to open accounts under this product (e.g., retail, small_business, corporate, private_banking, student, senior). [ENUM-REF-CANDIDATE: retail|small_business|corporate|private_banking|institutional|government|non_profit|student|senior — promote to reference product]' ;
    rdfs:domain ind:AccountProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fatcaReportable rdf:type rdf:Property ;
    rdfs:label 'Fatca Reportable' ;
    rdfs:comment 'Indicates whether accounts under this product are subject to FATCA reporting requirements for US tax purposes. True = FATCA reportable, False = exempt.' ;
    rdfs:domain ind:AccountProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:feeScheduleReference rdf:type rdf:Property ;
    rdfs:label 'Fee Schedule Reference' ;
    rdfs:comment 'Reference code linking to the fee schedule document or system record that defines all fees applicable to this product (monthly maintenance, overdraft, transaction fees, etc.).' ;
    rdfs:domain ind:AccountProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glMappingCode rdf:type rdf:Property ;
    rdfs:label 'Gl Mapping Code' ;
    rdfs:comment 'General ledger account code to which balances and transactions for this product are posted in the financial accounting system.' ;
    rdfs:domain ind:AccountProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ibanAssignmentRequired rdf:type rdf:Property ;
    rdfs:label 'Iban Assignment Required' ;
    rdfs:comment 'Indicates whether accounts under this product must be assigned an IBAN for international payment processing. True = IBAN required, False = not required.' ;
    rdfs:domain ind:AccountProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interestBearingFlag rdf:type rdf:Property ;
    rdfs:label 'Interest Bearing Flag' ;
    rdfs:comment 'Indicates whether the account product accrues interest on deposited balances. True = interest-bearing, False = non-interest-bearing.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interestCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Interest Calculation Method' ;
    rdfs:comment 'Method used to calculate interest accrual on account balances. Daily balance = interest on end-of-day balance, average daily balance = interest on average balance over period, minimum balance = interest on lowest balance in period, tiered = different rates for different balance tiers.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interestCompoundingFrequency rdf:type rdf:Property ;
    rdfs:label 'Interest Compounding Frequency' ;
    rdfs:comment 'Frequency at which accrued interest is capitalized and added to the principal balance for subsequent interest calculations.' ;
    rdfs:domain ind:AccountProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interestRateScheduleReference rdf:type rdf:Property ;
    rdfs:label 'Interest Rate Schedule Reference' ;
    rdfs:comment 'Reference code linking to the interest rate schedule that defines current and historical interest rates for this product, including tiered rate structures.' ;
    rdfs:domain ind:AccountProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kycTierRequired rdf:type rdf:Property ;
    rdfs:label 'Kyc Tier Required' ;
    rdfs:comment 'Level of KYC due diligence required to open an account under this product, aligned with AML and customer identification program requirements.' ;
    rdfs:domain ind:AccountProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lifecycleStatus rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Status' ;
    rdfs:comment 'Current lifecycle status of the account product. Active = available for new accounts, discontinued = no longer offered but existing accounts remain, grandfathered = closed to new customers but existing accounts retain terms, pending_approval = awaiting regulatory or internal approval, suspended = temporarily unavailable.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumBalanceLimit rdf:type rdf:Property ;
    rdfs:label 'Maximum Balance Limit' ;
    rdfs:comment 'Maximum balance allowed in accounts under this product, typically for regulatory or insurance reasons. Null if no maximum limit applies.' ;
    rdfs:domain ind:AccountProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumOpeningDeposit rdf:type rdf:Property ;
    rdfs:label 'Minimum Opening Deposit' ;
    rdfs:comment 'Minimum initial deposit amount required to open an account under this product, in the bank\'s functional currency (typically USD).' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mobileBankingEnabled rdf:type rdf:Property ;
    rdfs:label 'Mobile Banking Enabled' ;
    rdfs:comment 'Indicates whether accounts under this product have access to mobile banking applications. True = mobile banking available, False = not available.' ;
    rdfs:domain ind:AccountProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:onlineBankingEnabled rdf:type rdf:Property ;
    rdfs:label 'Online Banking Enabled' ;
    rdfs:comment 'Indicates whether accounts under this product have access to online banking services. True = online banking available, False = not available.' ;
    rdfs:domain ind:AccountProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overdraftProtectionAvailable rdf:type rdf:Property ;
    rdfs:label 'Overdraft Protection Available' ;
    rdfs:comment 'Indicates whether overdraft protection services are available for accounts under this product. True = overdraft protection can be enabled, False = not available.' ;
    rdfs:domain ind:AccountProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productCategory rdf:type rdf:Property ;
    rdfs:label 'Product Category' ;
    rdfs:comment 'High-level classification of the account product type. DDA = Demand Deposit Account (checking), savings = savings account, money_market = money market account, certificate_of_deposit = time deposit, custodial = custodial/trust account.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productDescription rdf:type rdf:Property ;
    rdfs:label 'Product Description' ;
    rdfs:comment 'Detailed description of the account product features, benefits, and intended use case for internal reference and customer communication.' ;
    rdfs:domain ind:AccountProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productName rdf:type rdf:Property ;
    rdfs:label 'Product Name' ;
    rdfs:comment 'Full business name of the account product as marketed to customers and displayed in customer-facing channels.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryClassification rdf:type rdf:Property ;
    rdfs:label 'Regulatory Classification' ;
    rdfs:comment 'Federal Reserve Regulation D classification determining reserve requirements and transaction limitations. Reg D savings accounts are subject to six-transaction monthly limits; transaction accounts include DDA and NOW accounts.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reserveRequirementApplicable rdf:type rdf:Property ;
    rdfs:label 'Reserve Requirement Applicable' ;
    rdfs:comment 'Indicates whether deposits in this product are subject to Federal Reserve reserve requirements under Regulation D. True = subject to reserve requirements, False = exempt.' ;
    rdfs:domain ind:AccountProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reserveRequirementRatio rdf:type rdf:Property ;
    rdfs:label 'Reserve Requirement Ratio' ;
    rdfs:comment 'Percentage of deposits that must be held in reserve with the Federal Reserve, expressed as a decimal (e.g., 0.1000 = 10%). Null if reserve requirements do not apply.' ;
    rdfs:domain ind:AccountProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:statementFrequency rdf:type rdf:Property ;
    rdfs:label 'Statement Frequency' ;
    rdfs:comment 'Frequency at which account statements are generated and delivered to customers for accounts under this product.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wireTransferAllowed rdf:type rdf:Property ;
    rdfs:label 'Wire Transfer Allowed' ;
    rdfs:comment 'Indicates whether domestic and international wire transfers are permitted for accounts under this product. True = wire transfers allowed, False = not permitted.' ;
    rdfs:domain ind:AccountProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:statementId rdf:type rdf:Property ;
    rdfs:label 'Statement Id' ;
    rdfs:comment 'Unique identifier for the account statement record. Primary key for the account statement entity.' ;
    rdfs:domain ind:Statement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryChannelId rdf:type rdf:Property ;
    rdfs:label 'Delivery Channel Id' ;
    rdfs:comment 'Foreign key linking to channel.channel. Business justification: Statement delivery channel tracking is required for regulatory proof of delivery (Reg E, Reg DD), customer preference management, and cost optimization. Links to channel for delivery method analytics ' ;
    rdfs:domain ind:Statement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:annualPercentageYield rdf:type rdf:Property ;
    rdfs:label 'Annual Percentage Yield' ;
    rdfs:comment 'The annualized rate of return on the account, expressed as a percentage, reflecting the effect of compounding interest. Disclosed per Regulation DD requirements.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:archivalDate rdf:type rdf:Property ;
    rdfs:label 'Archival Date' ;
    rdfs:comment 'The date when the statement was moved to archival storage or purged, if applicable. Used for compliance with record retention policies.' ;
    rdfs:domain ind:Statement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:archivalStatus rdf:type rdf:Property ;
    rdfs:label 'Archival Status' ;
    rdfs:comment 'Indicates the current archival state of the statement record. Active statements are readily accessible; archived statements are moved to long-term storage; purged statements have been deleted per retention policy.' ;
    rdfs:domain ind:Statement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bic rdf:type rdf:Property ;
    rdfs:label 'Bic' ;
    rdfs:comment 'The Bank Identifier Code (also known as SWIFT code) for the financial institution holding the account. Used for international wire transfers and SWIFT messaging.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closingBalance rdf:type rdf:Property ;
    rdfs:label 'Closing Balance' ;
    rdfs:comment 'The account balance at the end of the statement period (as of statement_period_end_date). Represents the final ledger balance after all transactions in this cycle.' ;
    rdfs:domain ind:Statement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cycleCode rdf:type rdf:Property ;
    rdfs:label 'Cycle Code' ;
    rdfs:comment 'Internal code representing the statement cycle configuration (e.g., monthly on the 1st, quarterly on the 15th). Used for batch processing and scheduling.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryStatus rdf:type rdf:Property ;
    rdfs:label 'Delivery Status' ;
    rdfs:comment 'Current status of the statement delivery process. Tracks whether the statement has been successfully delivered to the customer and, for electronic statements, whether it has been accessed.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Delivery Timestamp' ;
    rdfs:comment 'The date and time when the statement was successfully delivered or made available to the account holder through the specified delivery channel.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:escheatmentWarningFlag rdf:type rdf:Property ;
    rdfs:label 'Escheatment Warning Flag' ;
    rdfs:comment 'Indicates whether this statement includes a warning that the account is approaching dormancy and may be subject to escheatment (transfer to state unclaimed property). Required in certain jurisdictions.' ;
    rdfs:domain ind:Statement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:feesCharged rdf:type rdf:Property ;
    rdfs:label 'Fees Charged' ;
    rdfs:comment 'The total fees and service charges assessed against the account during the statement period, including maintenance fees, overdraft fees, and transaction fees.' ;
    rdfs:domain ind:Statement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:format rdf:type rdf:Property ;
    rdfs:label 'Format' ;
    rdfs:comment 'The file format or medium in which the statement is generated and delivered. PDF is standard for electronic statements; paper indicates physical print.' ;
    rdfs:domain ind:Statement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generatedBySystem rdf:type rdf:Property ;
    rdfs:label 'Generated By System' ;
    rdfs:comment 'The name or identifier of the core banking system or statement generation platform that produced this statement (e.g., Temenos T24, FIS Profile).' ;
    rdfs:domain ind:Statement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Generated Timestamp' ;
    rdfs:comment 'The date and time when the statement record was generated by the core banking system. Represents the system event time for audit and reconciliation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:iban rdf:type rdf:Property ;
    rdfs:label 'Iban' ;
    rdfs:comment 'The International Bank Account Number for the account, if applicable. Used for international transactions and regulatory reporting in jurisdictions that require IBAN.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interestEarned rdf:type rdf:Property ;
    rdfs:label 'Interest Earned' ;
    rdfs:comment 'The total interest accrued and credited to the account during the statement period. Calculated based on the account\'s interest rate and daily balance.' ;
    rdfs:domain ind:Statement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interestRate rdf:type rdf:Property ;
    rdfs:label 'Interest Rate' ;
    rdfs:comment 'The nominal annual interest rate applied to the account during the statement period, expressed as a percentage. May be tiered based on balance.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:language rdf:type rdf:Property ;
    rdfs:label 'Language' ;
    rdfs:comment 'Two-letter ISO 639-1 language code indicating the language in which the statement is generated (e.g., en for English, es for Spanish, fr for French).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noticeOfChangeFlag rdf:type rdf:Property ;
    rdfs:label 'Notice Of Change Flag' ;
    rdfs:comment 'Indicates whether this statement includes a notice of change to account terms, fees, or interest rates. Required for regulatory compliance and customer notification.' ;
    rdfs:domain ind:Statement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:openingBalance rdf:type rdf:Property ;
    rdfs:label 'Opening Balance' ;
    rdfs:comment 'The account balance at the beginning of the statement period (as of statement_period_start_date). Represents the starting ledger balance before any transactions in this cycle.' ;
    rdfs:domain ind:Statement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overdraftCount rdf:type rdf:Property ;
    rdfs:label 'Overdraft Count' ;
    rdfs:comment 'The number of times the account balance went negative (overdraft) during the statement period. Used for fee assessment and risk monitoring.' ;
    rdfs:domain ind:Statement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overdraftFees rdf:type rdf:Property ;
    rdfs:label 'Overdraft Fees' ;
    rdfs:comment 'The total overdraft and non-sufficient funds (NSF) fees charged during the statement period. Subset of total fees_charged, broken out for regulatory disclosure.' ;
    rdfs:domain ind:Statement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:periodEndDate rdf:type rdf:Property ;
    rdfs:label 'Period End Date' ;
    rdfs:comment 'The last date of the statement cycle period. Represents the end of the transaction window covered by this statement.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodStartDate rdf:type rdf:Property ;
    rdfs:label 'Period Start Date' ;
    rdfs:comment 'The first date of the statement cycle period. Represents the beginning of the transaction window covered by this statement.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regDdDisclosureFlag rdf:type rdf:Property ;
    rdfs:label 'Reg Dd Disclosure Flag' ;
    rdfs:comment 'Indicates whether Regulation DD disclosures (Truth in Savings Act - interest rates, fees, terms) are included on this statement. Required for deposit accounts.' ;
    rdfs:domain ind:Statement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regEDisclosureFlag rdf:type rdf:Property ;
    rdfs:label 'Reg E Disclosure Flag' ;
    rdfs:comment 'Indicates whether Regulation E disclosures (electronic fund transfer rights and liabilities) are included on this statement. Required for accounts with EFT activity.' ;
    rdfs:domain ind:Statement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:statementDate rdf:type rdf:Property ;
    rdfs:label 'Statement Date' ;
    rdfs:comment 'The official date on which the statement was generated and made available to the account holder. This is the date printed on the statement document.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:statementNumber rdf:type rdf:Property ;
    rdfs:label 'Statement Number' ;
    rdfs:comment 'Externally visible unique statement number assigned by the core banking system for customer reference and audit purposes. Typically follows a sequential or date-based numbering scheme.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statementType rdf:type rdf:Property ;
    rdfs:label 'Statement Type' ;
    rdfs:comment 'Classification of the statement based on its frequency or purpose. Monthly and quarterly are standard cycles; interim may be generated on demand; final indicates account closure.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suppressionFlag rdf:type rdf:Property ;
    rdfs:label 'Suppression Flag' ;
    rdfs:comment 'Indicates whether statement generation was suppressed for this cycle due to customer preference, account inactivity, or regulatory exemption.' ;
    rdfs:domain ind:Statement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:suppressionReason rdf:type rdf:Property ;
    rdfs:label 'Suppression Reason' ;
    rdfs:comment 'The reason why statement generation was suppressed, if suppression_flag is true. Provides audit trail for non-delivery.' ;
    rdfs:domain ind:Statement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCredits rdf:type rdf:Property ;
    rdfs:label 'Total Credits' ;
    rdfs:comment 'The sum of all credit transactions (deposits, interest credits, reversals) posted to the account during the statement period.' ;
    rdfs:domain ind:Statement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDebits rdf:type rdf:Property ;
    rdfs:label 'Total Debits' ;
    rdfs:comment 'The sum of all debit transactions (withdrawals, fees, charges, payments) posted to the account during the statement period.' ;
    rdfs:domain ind:Statement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionCount rdf:type rdf:Property ;
    rdfs:label 'Transaction Count' ;
    rdfs:comment 'The total number of transactions (both credits and debits) posted to the account during the statement period. Used for summary reporting and fee calculation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:viewedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Viewed Timestamp' ;
    rdfs:comment 'The date and time when the account holder first accessed or viewed the electronic statement. Null for paper statements or if not yet viewed.' ;
    rdfs:domain ind:Statement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:statusHistoryId rdf:type rdf:Property ;
    rdfs:label 'Status History Id' ;
    rdfs:comment 'Unique identifier for each account status transition record. Primary key for the immutable audit log of account lifecycle events.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:batchId rdf:type rdf:Property ;
    rdfs:label 'Batch Id' ;
    rdfs:comment 'Identifier of the batch process that created this status history record, if applicable. Null for real-time transactions. Used for batch reconciliation and operational monitoring.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Batch .

ind:authorizingOfficerName rdf:type rdf:Property ;
    rdfs:label 'Authorizing Officer Name' ;
    rdfs:comment 'Full name of the bank officer who authorized the status change. Provides human-readable audit trail for regulatory examination.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:balanceAtTransition rdf:type rdf:Property ;
    rdfs:label 'Balance At Transition' ;
    rdfs:comment 'The account balance at the moment of status transition. Critical for FDIC insurance claim processing, escheatment reporting, and write-off calculations. Expressed in the account currency.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Hold Flag' ;
    rdfs:comment 'Indicates whether the status change was driven by a compliance or regulatory hold (e.g., OFAC match, court order, regulatory investigation). True if compliance-driven, False otherwise.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currencyCode rdf:type rdf:Property ;
    rdfs:label 'Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the balance at transition. Ensures accurate multi-currency reporting and regulatory compliance.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dormancyPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Dormancy Period Days' ;
    rdfs:comment 'Number of days the account remained inactive before transitioning to dormant status. Populated only for transitions to dormant status. Used for escheatment timeline calculations and regulatory dormancy reporting.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:effectiveTimestamp rdf:type rdf:Property ;
    rdfs:label 'Effective Timestamp' ;
    rdfs:comment 'The precise date and time when the new status became effective for the account. This is the business event timestamp, distinct from the record creation timestamp. Critical for regulatory timeline reconstruction and FDIC insurance claim processing.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:holdAuthority rdf:type rdf:Property ;
    rdfs:label 'Hold Authority' ;
    rdfs:comment 'Name of the regulatory authority or legal entity that mandated the hold or status change (e.g., OFAC, FBI, court name, state regulator). Populated only when compliance_hold_flag is True.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Hold Reference Number' ;
    rdfs:comment 'Official reference number or case identifier from the regulatory authority or court that issued the hold. Populated only when compliance_hold_flag is True.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiatingChannel rdf:type rdf:Property ;
    rdfs:label 'Initiating Channel' ;
    rdfs:comment 'The channel or interface through which the status change was initiated. Distinguishes customer-initiated changes from system-automated or regulatory-driven transitions. [ENUM-REF-CANDIDATE: branch|online_banking|mobile_app|call_center|atm|back_office|system_automated|regulatory_authority|third_party — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newStatus rdf:type rdf:Property ;
    rdfs:label 'New Status' ;
    rdfs:comment 'The account lifecycle status after this transition was applied. Captures the to-state in the status change event. Required for regulatory examination and AML dormancy monitoring. [ENUM-REF-CANDIDATE: pending_activation|active|dormant|inactive|frozen|blocked|closed|written_off|reactivated — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousStatus rdf:type rdf:Property ;
    rdfs:label 'Previous Status' ;
    rdfs:comment 'The account lifecycle status immediately before this transition occurred. Captures the from-state in the status change event. [ENUM-REF-CANDIDATE: pending_activation|active|dormant|inactive|frozen|blocked|closed|written_off — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonDescription rdf:type rdf:Property ;
    rdfs:label 'Reason Description' ;
    rdfs:comment 'Free-text narrative providing additional context and details about the reason for the status change. Supplements the reason code with case-specific information.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Reversal Reference Code' ;
    rdfs:comment 'Reference to the account_status_history_id of the reversing entry if this transition was reversed. Null if not reversed. Maintains bidirectional audit trail for corrections.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supportingDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Supporting Document Reference' ;
    rdfs:comment 'Reference identifier or URI to supporting documentation that justifies the status change (e.g., court order number, customer request ticket, AML case ID, death certificate reference). Critical for regulatory examination and dispute resolution.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:systemSource rdf:type rdf:Property ;
    rdfs:label 'System Source' ;
    rdfs:comment 'Identifier of the source system or application that recorded the status transition (e.g., Temenos T24, FIS Profile, batch job name, API service). Used for data lineage and troubleshooting.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sweepId rdf:type rdf:Property ;
    rdfs:label 'Sweep Id' ;
    rdfs:comment 'Unique identifier for the account sweep arrangement record. Primary key.' ;
    rdfs:domain ind:Sweep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:collateralAssetId rdf:type rdf:Property ;
    rdfs:label 'Collateral Asset Id' ;
    rdfs:comment 'Foreign key linking to collateral.collateral_asset. Business justification: Sweep arrangements move excess cash into collateralized investment vehicles (repos, money market funds backed by securities). Banks track which collateral assets back sweep investments for liquidity r' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CollateralAsset .

ind:destinationAccountDepositAccountId rdf:type rdf:Property ;
    rdfs:label 'Destination Account Deposit Account Id' ;
    rdfs:comment 'Reference to the deposit account or investment vehicle to which funds are swept. The target account in the sweep arrangement. Nullable for external investment vehicles tracked separately.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DepositAccount .

ind:fundId rdf:type rdf:Property ;
    rdfs:label 'Fund Id' ;
    rdfs:comment 'External reference identifier for the investment vehicle (e.g., fund CUSIP, brokerage account number). Nullable for internal sweeps.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fund .

ind:setupChannelId rdf:type rdf:Property ;
    rdfs:label 'Setup Channel Id' ;
    rdfs:comment 'Foreign key linking to channel.channel. Business justification: Investment sweep arrangement setup channel is tracked for suitability review compliance, customer service attribution, and regulatory documentation. Required for SEC/FINRA examinations of investment p' ;
    rdfs:domain ind:Account ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:sweepDepositAccountId rdf:type rdf:Property ;
    rdfs:label 'Sweep Deposit Account Id' ;
    rdfs:comment 'Reference to the deposit account from which funds are swept. The originating account in the sweep arrangement.' ;
    rdfs:domain ind:Sweep ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DepositAccount .

ind:approvalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Approval Required Flag' ;
    rdfs:comment 'Indicates whether each sweep execution requires manual approval before processing. Used for high-value or sensitive arrangements.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:arrangementNumber rdf:type rdf:Property ;
    rdfs:label 'Arrangement Number' ;
    rdfs:comment 'Business identifier for the sweep arrangement, used for customer communication and operational reference.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoReplenishmentEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Replenishment Enabled' ;
    rdfs:comment 'Indicates whether automatic replenishment from destination to source is enabled when source account falls below target balance. Applicable for two-way sweep arrangements.' ;
    rdfs:domain ind:Sweep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:businessDayConvention rdf:type rdf:Property ;
    rdfs:label 'Business Day Convention' ;
    rdfs:comment 'Rule for adjusting sweep execution dates that fall on non-business days. Following moves to next business day; preceding moves to prior business day; modified following moves forward unless it crosses month boundary.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerNotificationEnabled rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Enabled' ;
    rdfs:comment 'Indicates whether customer receives notifications for each sweep execution.' ;
    rdfs:domain ind:Sweep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:direction rdf:type rdf:Property ;
    rdfs:label 'Direction' ;
    rdfs:comment 'Directionality of the sweep arrangement. One-way sweeps only move funds from source to destination; two-way or bidirectional sweeps can return funds to source when destination balance exceeds thresholds.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frequency rdf:type rdf:Property ;
    rdfs:label 'Frequency' ;
    rdfs:comment 'Frequency at which the sweep arrangement is evaluated and executed. Daily sweeps occur once per business day; end-of-day sweeps execute after final posting; intraday sweeps may execute multiple times; on-demand sweeps are manually triggered.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ftpRateCode rdf:type rdf:Property ;
    rdfs:label 'Ftp Rate Code' ;
    rdfs:comment 'Reference to the FTP rate curve or code used for internal profitability allocation of swept funds. Used for management accounting and ALCO reporting.' ;
    rdfs:domain ind:Sweep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holidayCalendarCode rdf:type rdf:Property ;
    rdfs:label 'Holiday Calendar Code' ;
    rdfs:comment 'Reference to the holiday calendar used to determine business days for sweep execution scheduling (e.g., US Federal Reserve, TARGET2, local jurisdiction).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investmentVehicleType rdf:type rdf:Property ;
    rdfs:label 'Investment Vehicle Type' ;
    rdfs:comment 'Type of external investment vehicle for investment sweep arrangements. None indicates internal account-to-account sweep.' ;
    rdfs:domain ind:Sweep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastSweepAmount rdf:type rdf:Property ;
    rdfs:label 'Last Sweep Amount' ;
    rdfs:comment 'Amount transferred in the most recent sweep execution. Used for operational reporting and pattern analysis.' ;
    rdfs:domain ind:Sweep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastSweepExecutionDate rdf:type rdf:Property ;
    rdfs:label 'Last Sweep Execution Date' ;
    rdfs:comment 'Date of the most recent successful sweep execution. Used for operational monitoring and next-execution scheduling.' ;
    rdfs:domain ind:Sweep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lifetimeSweepCount rdf:type rdf:Property ;
    rdfs:label 'Lifetime Sweep Count' ;
    rdfs:comment 'Total number of sweep executions since arrangement inception. Used for usage analytics and fee calculation.' ;
    rdfs:domain ind:Sweep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lifetimeSweepTotalAmount rdf:type rdf:Property ;
    rdfs:label 'Lifetime Sweep Total Amount' ;
    rdfs:comment 'Cumulative total amount swept since arrangement inception. Used for customer reporting and funds transfer pricing (FTP) analytics.' ;
    rdfs:domain ind:Sweep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumSweepAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Sweep Amount' ;
    rdfs:comment 'Maximum amount that can be transferred in a single sweep execution. Used for risk management and liquidity control. Nullable for unlimited sweeps.' ;
    rdfs:domain ind:Sweep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumSweepAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Sweep Amount' ;
    rdfs:comment 'Minimum amount that must be transferred for a sweep to execute. Prevents small, uneconomical transfers.' ;
    rdfs:domain ind:Sweep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextScheduledSweepDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Sweep Date' ;
    rdfs:comment 'Date when the next sweep execution is scheduled to occur, based on frequency and business calendar.' ;
    rdfs:domain ind:Sweep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priorityRank rdf:type rdf:Property ;
    rdfs:label 'Priority Rank' ;
    rdfs:comment 'Execution priority when multiple sweep arrangements exist on the same source account. Lower numbers execute first. Used for cash concentration hierarchies.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:replenishmentThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Replenishment Threshold Amount' ;
    rdfs:comment 'Source account balance threshold below which auto-replenishment is triggered. Applicable when auto_replenishment_enabled is true.' ;
    rdfs:domain ind:Sweep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sweepStatus rdf:type rdf:Property ;
    rdfs:label 'Sweep Status' ;
    rdfs:comment 'Current operational status of the sweep arrangement. Active arrangements execute per schedule; suspended arrangements are temporarily halted; terminated arrangements are closed; pending activation awaits approval; under review indicates compliance or risk review in progress.' ;
    rdfs:domain ind:Sweep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sweepType rdf:type rdf:Property ;
    rdfs:label 'Sweep Type' ;
    rdfs:comment 'Classification of the sweep arrangement. Zero-balance sweep transfers all excess funds; target-balance sweep maintains a specified balance; threshold sweep triggers when balance exceeds a limit; investment sweep moves funds to money market or investment vehicle; hybrid combines multiple rules.' ;
    rdfs:domain ind:Sweep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Target Balance Amount' ;
    rdfs:comment 'Desired balance to maintain in the source account after sweep execution. Applicable for target-balance sweep types. Nullable for zero-balance sweeps.' ;
    rdfs:domain ind:Sweep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:terminationDate rdf:type rdf:Property ;
    rdfs:label 'Termination Date' ;
    rdfs:comment 'Date when the sweep arrangement is terminated or expires. Nullable for open-ended arrangements.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:thresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Threshold Amount' ;
    rdfs:comment 'Minimum balance threshold that triggers a sweep execution. When source account balance exceeds this amount, sweep is initiated. Nullable for zero-balance sweep types.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accountTransactionId rdf:type rdf:Property ;
    rdfs:label 'Account Transaction Id' ;
    rdfs:comment 'Unique identifier for the account transaction record. Primary key for the account transaction entity.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccountTransaction .

ind:channelId rdf:type rdf:Property ;
    rdfs:label 'Channel Id' ;
    rdfs:comment 'Foreign key linking to channel.channel. Business justification: Every transaction occurs through a specific channel for fraud detection, AML monitoring (CTR/SAR reporting), channel analytics, and customer behavior analysis. Essential for BSA/AML compliance and ope' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:counterpartyPartyId rdf:type rdf:Property ;
    rdfs:label 'Counterparty Party Id' ;
    rdfs:comment 'Foreign key linking to customer.party. Business justification: Internal transfers between customer accounts require counterparty identification for AML transaction monitoring, related-party transaction detection, and regulatory reporting (CTR, SAR). When counterp' ;
    rdfs:domain ind:AccountTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:reversedTransactionAccountTransactionId rdf:type rdf:Property ;
    rdfs:label 'Reversed Transaction Account Transaction Id' ;
    rdfs:comment 'Reference to the original account transaction ID that this transaction reverses. Null if this is not a reversal transaction.' ;
    rdfs:domain ind:AccountTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccountTransaction .

ind:achTraceNumber rdf:type rdf:Property ;
    rdfs:label 'Ach Trace Number' ;
    rdfs:comment '15-digit trace number assigned to ACH transactions for tracking and reconciliation purposes. Null for non-ACH transactions.' ;
    rdfs:domain ind:AccountTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amlAlertFlag rdf:type rdf:Property ;
    rdfs:label 'Aml Alert Flag' ;
    rdfs:comment 'Boolean indicator specifying whether this transaction triggered an AML alert requiring investigation. True if alert generated, False otherwise.' ;
    rdfs:domain ind:AccountTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:amlRiskScore rdf:type rdf:Property ;
    rdfs:label 'Aml Risk Score' ;
    rdfs:comment 'Numeric risk score assigned by the AML transaction monitoring system indicating the likelihood of money laundering or suspicious activity. Higher scores trigger enhanced review.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:balanceAfterTransaction rdf:type rdf:Property ;
    rdfs:label 'Balance After Transaction' ;
    rdfs:comment 'The running account balance immediately after this transaction was posted. Used for statement generation and overdraft detection.' ;
    rdfs:domain ind:AccountTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cardAuthorizationCode rdf:type rdf:Property ;
    rdfs:label 'Card Authorization Code' ;
    rdfs:comment 'Authorization code returned by the card network for approved card transactions. Null for non-card transactions.' ;
    rdfs:domain ind:AccountTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterpartyAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Counterparty Account Number' ;
    rdfs:comment 'The account number of the counterparty (originator or beneficiary) involved in the transaction. May be an internal account, external IBAN, or card number depending on transaction type.' ;
    rdfs:domain ind:AccountTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterpartyBankBic rdf:type rdf:Property ;
    rdfs:label 'Counterparty Bank Bic' ;
    rdfs:comment 'The SWIFT BIC (Bank Identifier Code) of the counterparty\'s financial institution for wire transfers and cross-border payments.' ;
    rdfs:domain ind:AccountTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctrReportableFlag rdf:type rdf:Property ;
    rdfs:label 'Ctr Reportable Flag' ;
    rdfs:comment 'Boolean indicator specifying whether this transaction meets the threshold for Currency Transaction Report filing with FinCEN (typically cash transactions over $10,000).' ;
    rdfs:domain ind:AccountTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exchangeRate rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate' ;
    rdfs:comment 'The exchange rate applied for currency conversion if the transaction involved foreign exchange. Null for single-currency transactions.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feeAmount rdf:type rdf:Property ;
    rdfs:label 'Fee Amount' ;
    rdfs:comment 'The amount of any fee charged in association with this transaction (e.g., overdraft fee, wire transfer fee, ATM surcharge). Zero if no fee applies.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holdAmount rdf:type rdf:Property ;
    rdfs:label 'Hold Amount' ;
    rdfs:comment 'The amount of funds placed on hold or reserved as a result of this transaction (e.g., check hold, card authorization hold). Null if no hold applies.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holdReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Hold Release Date' ;
    rdfs:comment 'The date on which any hold placed by this transaction will be released and funds will become available. Null if no hold applies.' ;
    rdfs:domain ind:AccountTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:interestAmount rdf:type rdf:Property ;
    rdfs:label 'Interest Amount' ;
    rdfs:comment 'The amount of interest credited or debited as part of this transaction. Applicable for interest accrual postings on deposit accounts. Zero if not an interest transaction.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:merchantCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Merchant Category Code' ;
    rdfs:comment 'Four-digit ISO 18245 code classifying the type of merchant or service provider for card transactions. Used for spend analytics and rewards program eligibility.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:narrative rdf:type rdf:Property ;
    rdfs:label 'Narrative' ;
    rdfs:comment 'Free-text description or memo field providing additional context about the transaction purpose, merchant name, or customer-entered notes. Appears on account statements.' ;
    rdfs:domain ind:AccountTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Original Currency Amount' ;
    rdfs:comment 'The transaction amount in the original currency before conversion to the account base currency. Null if no conversion occurred.' ;
    rdfs:domain ind:AccountTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Original Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code of the original transaction currency before conversion to the account base currency. Null if no conversion occurred.' ;
    rdfs:domain ind:AccountTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentSystemReference rdf:type rdf:Property ;
    rdfs:label 'Payment System Reference' ;
    rdfs:comment 'Unique identifier assigned by the originating payment system or network (ACH trace number, wire IMAD/OMAD, SWIFT UETR, card authorization code). Used for end-to-end traceability and dispute resolution.' ;
    rdfs:domain ind:AccountTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingDate rdf:type rdf:Property ;
    rdfs:label 'Posting Date' ;
    rdfs:comment 'The date on which the transaction was actually posted to the account ledger in the core banking system. Used for GL reconciliation and regulatory reporting cutoff.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:postingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Posting Timestamp' ;
    rdfs:comment 'Precise timestamp when the transaction was committed to the account ledger, including time zone. Critical for intraday liquidity monitoring and real-time balance calculations.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:settlementDate rdf:type rdf:Property ;
    rdfs:label 'Settlement Date' ;
    rdfs:comment 'The date on which the transaction settled through the payment system or clearing house. May differ from posting date for multi-day clearing cycles.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transactionDate rdf:type rdf:Property ;
    rdfs:label 'Transaction Date' ;
    rdfs:comment 'The business date on which the transaction was initiated or authorized by the customer or originating system. This is the date visible to the customer on statements.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transactionStatus rdf:type rdf:Property ;
    rdfs:label 'Transaction Status' ;
    rdfs:comment 'Current lifecycle status of the transaction indicating whether it is pending settlement, successfully posted to the ledger, reversed, failed, or cancelled.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valueDate rdf:type rdf:Property ;
    rdfs:label 'Value Date' ;
    rdfs:comment 'The date on which funds become available or are debited for interest calculation purposes. May differ from transaction date due to clearing cycles or holds.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:wireImad rdf:type rdf:Property ;
    rdfs:label 'Wire Imad' ;
    rdfs:comment 'Input Message Accountability Data assigned to incoming wire transfers by the Federal Reserve or CHIPS. Null for non-wire transactions.' ;
    rdfs:domain ind:AccountTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wireOmad rdf:type rdf:Property ;
    rdfs:label 'Wire Omad' ;
    rdfs:comment 'Output Message Accountability Data assigned to outgoing wire transfers by the Federal Reserve or CHIPS. Null for non-wire transactions.' ;
    rdfs:domain ind:AccountTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typeId rdf:type rdf:Property ;
    rdfs:label 'Type Id' ;
    rdfs:comment 'Unique identifier for the account type. Primary key for the account type reference table.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountTypeDescription rdf:type rdf:Property ;
    rdfs:label 'Account Type Description' ;
    rdfs:comment 'Detailed business description of the account type, including its purpose, features, and typical use cases. Provides context for product management, compliance, and customer service teams.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountTypeName rdf:type rdf:Property ;
    rdfs:label 'Account Type Name' ;
    rdfs:comment 'Full descriptive name of the account type (e.g., Demand Deposit Account, Savings Account, Money Market Account, Certificate of Deposit, Custodial Account). Human-readable label used in customer-facing applications and internal reporting.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:achTransferAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Ach Transfer Allowed Flag' ;
    rdfs:comment 'Indicates whether ACH debits and credits are permitted for this account type. Determines eligibility for direct deposit, bill payment, and electronic funds transfer services.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:atmAccessFlag rdf:type rdf:Property ;
    rdfs:label 'Atm Access Flag' ;
    rdfs:comment 'Indicates whether accounts of this type support ATM withdrawals and balance inquiries. Affects card issuance and channel access controls.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:callReportSchedule rdf:type rdf:Property ;
    rdfs:label 'Call Report Schedule' ;
    rdfs:comment 'FFIEC Call Report schedule code (e.g., RC-E for deposit liabilities) where this account type must be reported. Ensures accurate quarterly regulatory filings to the Federal Reserve, FDIC, and OCC.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkWritingAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Check Writing Allowed Flag' ;
    rdfs:comment 'Indicates whether customers can write checks against this account type. Determines check order eligibility and payment processing rules.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cipExemptionFlag rdf:type rdf:Property ;
    rdfs:label 'Cip Exemption Flag' ;
    rdfs:comment 'Indicates whether this account type qualifies for an exemption from standard Customer Identification Program requirements under USA PATRIOT Act Section 326. Typically false for most retail and commercial accounts.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crsReportableFlag rdf:type rdf:Property ;
    rdfs:label 'Crs Reportable Flag' ;
    rdfs:comment 'Indicates whether this account type is subject to OECD Common Reporting Standard automatic exchange of financial account information. Applies to accounts held by tax residents of participating jurisdictions.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerSegment rdf:type rdf:Property ;
    rdfs:label 'Customer Segment' ;
    rdfs:comment 'Target customer segment for this account type. Supports marketing strategy, pricing decisions, and customer relationship management (CRM) analytics.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:debitCardEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Debit Card Eligible Flag' ;
    rdfs:comment 'Indicates whether a debit card can be issued and linked to this account type. Determines card product offerings and payment channel availability.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escheatmentPeriodYears rdf:type rdf:Property ;
    rdfs:label 'Escheatment Period Years' ;
    rdfs:comment 'Number of years of account dormancy after which funds must be escheated (transferred) to the state unclaimed property authority. Varies by state jurisdiction and account type.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fatcaReportableFlag rdf:type rdf:Property ;
    rdfs:label 'Fatca Reportable Flag' ;
    rdfs:comment 'Indicates whether this account type is subject to FATCA reporting requirements for U.S. persons holding foreign financial accounts or foreign entities with U.S. ownership. Affects IRS Form 8938 and FBAR filing obligations.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fdicInsuredFlag rdf:type rdf:Property ;
    rdfs:label 'Fdic Insured Flag' ;
    rdfs:comment 'Indicates whether deposits in this account type are eligible for FDIC insurance coverage. True for most deposit accounts; false for non-deposit products or uninsured investment accounts.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:glLiabilityCategory rdf:type rdf:Property ;
    rdfs:label 'Gl Liability Category' ;
    rdfs:comment 'Balance sheet liability classification for this account type. Used in financial statement preparation, liquidity reporting, and Asset-Liability Management (ALM) analysis.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kycVerificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Kyc Verification Required Flag' ;
    rdfs:comment 'Indicates whether enhanced Know Your Customer due diligence is required at account opening for this account type. Affects onboarding workflows and compliance checks.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:liquidityCoverageRatioCategory rdf:type rdf:Property ;
    rdfs:label 'Liquidity Coverage Ratio Category' ;
    rdfs:comment 'Basel III Liquidity Coverage Ratio classification that determines the assumed outflow rate for this account type during a 30-day stress scenario. Critical for liquidity risk management and regulatory compliance.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumOpeningBalance rdf:type rdf:Property ;
    rdfs:label 'Minimum Opening Balance' ;
    rdfs:comment 'Minimum initial deposit required to open an account of this type. Enforced during account origination and disclosed in product terms and conditions.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:monthlyServiceFee rdf:type rdf:Property ;
    rdfs:label 'Monthly Service Fee' ;
    rdfs:comment 'Standard monthly maintenance fee charged for this account type if balance or activity requirements are not met. Subject to fee waiver rules and regulatory disclosure requirements.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nsfrCategory rdf:type rdf:Property ;
    rdfs:label 'Nsfr Category' ;
    rdfs:comment 'Basel III Net Stable Funding Ratio classification that determines the required stable funding factor for this account type. Used in long-term liquidity planning and regulatory capital calculations.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onlineBankingEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Online Banking Enabled Flag' ;
    rdfs:comment 'Indicates whether this account type is accessible through online banking and mobile banking channels. Affects digital channel entitlements and customer self-service capabilities.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overdraftAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Overdraft Allowed Flag' ;
    rdfs:comment 'Indicates whether overdraft protection or overdraft privilege is available for this account type. Determines eligibility for overdraft facilities and fee structures.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productLine rdf:type rdf:Property ;
    rdfs:label 'Product Line' ;
    rdfs:comment 'Business line or division that offers this account type. Enables product profitability analysis, customer segmentation, and line-of-business reporting.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reserveRequirementApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Reserve Requirement Applicable Flag' ;
    rdfs:comment 'Indicates whether this account type is subject to Federal Reserve reserve requirements under Regulation D. Affects bank liquidity management and Asset-Liability Committee (ALCO) calculations.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxReportingForm rdf:type rdf:Property ;
    rdfs:label 'Tax Reporting Form' ;
    rdfs:comment 'IRS form code used for tax reporting of interest income or other taxable events for this account type (e.g., 1099-INT for interest income, 1099-MISC for other income). Drives year-end tax document generation.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionLimitApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Transaction Limit Applicable Flag' ;
    rdfs:comment 'Indicates whether this account type is subject to monthly transaction limits under Regulation D (historically 6 withdrawals/transfers per statement cycle for savings accounts). Determines system controls and customer notifications.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:typeStatus rdf:type rdf:Property ;
    rdfs:label 'Type Status' ;
    rdfs:comment 'Current lifecycle status of this account type in the product catalog. Active types are available for new account openings; deprecated types are closed to new business but support existing accounts.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wireTransferAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Wire Transfer Allowed Flag' ;
    rdfs:comment 'Indicates whether domestic and international wire transfers can be initiated from this account type. Affects payment hub routing and Anti-Money Laundering (AML) screening requirements.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:beneficiaryDesignationId rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Designation Id' ;
    rdfs:comment 'Unique identifier for the beneficiary designation record. Primary key for the beneficiary designation entity.' ;
    rdfs:domain ind:BeneficiaryDesignation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:beneficiaryPartyId rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Party Id' ;
    rdfs:comment 'Foreign key linking to customer.party. Business justification: Estate planning and beneficiary designation require proper KYC when beneficiary is an existing customer. Links to party master for identity verification, tax reporting (estate/inheritance), and remove' ;
    rdfs:domain ind:Account ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:primaryBeneficiaryEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Beneficiary Employee Id' ;
    rdfs:comment 'User identifier of the bank employee or system user who created this beneficiary designation record. Required for audit trail and accountability.' ;
    rdfs:domain ind:BeneficiaryDesignation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:allocationPercentage rdf:type rdf:Property ;
    rdfs:label 'Allocation Percentage' ;
    rdfs:comment 'Percentage of account proceeds allocated to this beneficiary upon account holder death. Must sum to 100.00 across all active beneficiaries on the same account. Expressed as a decimal value between 0.00 and 100.00.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amlScreeningDate rdf:type rdf:Property ;
    rdfs:label 'Aml Screening Date' ;
    rdfs:comment 'Date on which the beneficiary was screened against AML sanctions lists. Required for regulatory compliance and audit trail.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:amlScreeningStatus rdf:type rdf:Property ;
    rdfs:label 'Aml Screening Status' ;
    rdfs:comment 'Result of AML sanctions screening for the beneficiary against OFAC and other watchlists. Cleared status is required before distribution can occur.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficiaryAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Address Line1' ;
    rdfs:comment 'Primary street address line for the beneficiary. Required for mailing distribution checks and legal notices upon account holder death.' ;
    rdfs:domain ind:BeneficiaryDesignation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficiaryAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Address Line2' ;
    rdfs:comment 'Secondary address line for apartment, suite, or unit number. Optional field for additional address detail.' ;
    rdfs:domain ind:BeneficiaryDesignation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficiaryCity rdf:type rdf:Property ;
    rdfs:label 'Beneficiary City' ;
    rdfs:comment 'City or municipality of the beneficiary address. Required for legal notices and distribution processing.' ;
    rdfs:domain ind:BeneficiaryDesignation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficiaryCountryCode rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code for the beneficiary address. Determines cross-border reporting requirements and distribution processing rules.' ;
    rdfs:domain ind:BeneficiaryDesignation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficiaryDateOfBirth rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Date Of Birth' ;
    rdfs:comment 'Date of birth of the beneficiary if the beneficiary is an individual. Used for identity verification and to determine if special handling is required for minor beneficiaries.' ;
    rdfs:domain ind:BeneficiaryDesignation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:beneficiaryEmailAddress rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Email Address' ;
    rdfs:comment 'Email address for the beneficiary. Used for electronic communication regarding designation status and distribution processing.' ;
    rdfs:domain ind:BeneficiaryDesignation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficiaryPhoneNumber rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Phone Number' ;
    rdfs:comment 'Primary contact phone number for the beneficiary. Used to notify beneficiary of account holder death and coordinate distribution.' ;
    rdfs:domain ind:BeneficiaryDesignation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficiaryPostalCode rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the beneficiary address. Required for mailing and address validation.' ;
    rdfs:domain ind:BeneficiaryDesignation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficiaryPriority rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Priority' ;
    rdfs:comment 'Priority tier of the beneficiary designation. Primary beneficiaries receive proceeds first; contingent beneficiaries receive proceeds only if all primary beneficiaries predecease the account holder.' ;
    rdfs:domain ind:BeneficiaryDesignation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficiaryStateProvince rdf:type rdf:Property ;
    rdfs:label 'Beneficiary State Province' ;
    rdfs:comment 'State, province, or region of the beneficiary address. Determines applicable state probate law and escheatment jurisdiction.' ;
    rdfs:domain ind:BeneficiaryDesignation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designationNumber rdf:type rdf:Property ;
    rdfs:label 'Designation Number' ;
    rdfs:comment 'Externally-known unique business identifier for this beneficiary designation. Used for customer communication and legal documentation reference.' ;
    rdfs:domain ind:BeneficiaryDesignation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designationStatus rdf:type rdf:Property ;
    rdfs:label 'Designation Status' ;
    rdfs:comment 'Current lifecycle status of the beneficiary designation. Active designations are legally binding; revoked or superseded designations have no legal effect.' ;
    rdfs:domain ind:BeneficiaryDesignation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minorCustodianName rdf:type rdf:Property ;
    rdfs:label 'Minor Custodian Name' ;
    rdfs:comment 'Full legal name of the custodian designated to manage proceeds on behalf of a minor beneficiary under the Uniform Transfers to Minors Act (UTMA). Required when beneficiary is under age of majority.' ;
    rdfs:domain ind:BeneficiaryDesignation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notarizationDate rdf:type rdf:Property ;
    rdfs:label 'Notarization Date' ;
    rdfs:comment 'Date on which the beneficiary designation form was notarized. Required when notarization_required_flag is true.' ;
    rdfs:domain ind:BeneficiaryDesignation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notarizationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Notarization Required Flag' ;
    rdfs:comment 'Indicates whether state law or bank policy requires notarization of the beneficiary designation form. Varies by jurisdiction and account type.' ;
    rdfs:domain ind:BeneficiaryDesignation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:perStirpesFlag rdf:type rdf:Property ;
    rdfs:label 'Per Stirpes Flag' ;
    rdfs:comment 'Indicates whether the beneficiary designation includes per stirpes distribution. If true and the beneficiary predeceases the account holder, the beneficiary\'s share passes to their descendants rather than to other named beneficiaries.' ;
    rdfs:domain ind:BeneficiaryDesignation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:relationshipToAccountHolder rdf:type rdf:Property ;
    rdfs:label 'Relationship To Account Holder' ;
    rdfs:comment 'Nature of the personal or business relationship between the beneficiary and the account holder. Used for compliance review and fraud detection. [ENUM-REF-CANDIDATE: spouse|child|parent|sibling|other_relative|friend|business_partner|unrelated — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BeneficiaryDesignation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revocationReason rdf:type rdf:Property ;
    rdfs:label 'Revocation Reason' ;
    rdfs:comment 'Free-text explanation for why the beneficiary designation was revoked. Common reasons include divorce, death of beneficiary, change in estate planning strategy, or account holder request.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trustDate rdf:type rdf:Property ;
    rdfs:label 'Trust Date' ;
    rdfs:comment 'Date on which the trust was legally established. Used to verify trust validity and identify the correct trust instrument when multiple trusts exist with similar names.' ;
    rdfs:domain ind:BeneficiaryDesignation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trustName rdf:type rdf:Property ;
    rdfs:label 'Trust Name' ;
    rdfs:comment 'Full legal name of the trust if the beneficiary type is trust. Must match the trust instrument exactly for legal distribution.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trusteeName rdf:type rdf:Property ;
    rdfs:label 'Trustee Name' ;
    rdfs:comment 'Full legal name of the trustee authorized to receive and manage proceeds on behalf of the trust. Required for trust beneficiary designations.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:witnessCount rdf:type rdf:Property ;
    rdfs:label 'Witness Count' ;
    rdfs:comment 'Number of witnesses who signed the beneficiary designation form. Some jurisdictions require one or more witnesses for legal validity.' ;
    rdfs:domain ind:BeneficiaryDesignation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certificateOfDepositId rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Deposit Id' ;
    rdfs:comment 'Unique system identifier for the certificate of deposit instrument. Primary key for the CD master record.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CertificateOfDeposit .

ind:channelRelationshipManagerId rdf:type rdf:Property ;
    rdfs:label 'Channel Relationship Manager Id' ;
    rdfs:comment 'Reference to the bank employee responsible for managing the customer relationship and CD product. Used for sales attribution and client servicing.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ChannelRelationshipManager .

ind:glAccountId rdf:type rdf:Property ;
    rdfs:label 'Gl Account Id' ;
    rdfs:comment 'Foreign key linking to ledger.gl_account. Business justification: CDs are time deposits requiring GL mapping for balance sheet classification, interest expense accrual, and regulatory capital calculations. Essential for financial reporting and FDIC insurance trackin' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:instrumentId rdf:type rdf:Property ;
    rdfs:label 'Instrument Id' ;
    rdfs:comment 'Foreign key linking to security.instrument. Business justification: CDs are debt securities with ISINs/CUSIPs traded in secondary markets. Banks must link CD accounts to security master for mark-to-market valuation, regulatory capital calculations (HQLA classification' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Instrument .

ind:apy rdf:type rdf:Property ;
    rdfs:label 'Apy' ;
    rdfs:comment 'Effective annual rate of return accounting for compounding effects. Disclosed to customers per Regulation DD Truth in Savings requirements. Expressed as decimal (e.g., 0.0330 for 3.30%).' ;
    rdfs:domain ind:CertificateOfDeposit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:autoRenewalFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Flag' ;
    rdfs:comment 'Indicates whether the CD automatically rolls over into a new term at maturity if no customer instruction is received. True: auto-renew enabled; False: manual renewal required.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:callDate rdf:type rdf:Property ;
    rdfs:label 'Call Date' ;
    rdfs:comment 'Earliest date on which the issuing bank may exercise the call option to redeem the CD. Null for non-callable CDs.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:callPremiumAmount rdf:type rdf:Property ;
    rdfs:label 'Call Premium Amount' ;
    rdfs:comment 'Additional amount paid to the CD holder if the bank exercises the call option, compensating for early redemption. Null for non-callable CDs.' ;
    rdfs:domain ind:CertificateOfDeposit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:callableFlag rdf:type rdf:Property ;
    rdfs:label 'Callable Flag' ;
    rdfs:comment 'Indicates whether the issuing bank has the right to redeem the CD before maturity. True: callable CD with issuer redemption option; False: non-callable, customer holds to maturity.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cdNumber rdf:type rdf:Property ;
    rdfs:label 'Cd Number' ;
    rdfs:comment 'Externally visible certificate number assigned to this CD instrument. Used for customer statements, regulatory reporting, and inter-bank communication.' ;
    rdfs:domain ind:CertificateOfDeposit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdStatus rdf:type rdf:Property ;
    rdfs:label 'Cd Status' ;
    rdfs:comment 'Current lifecycle state of the CD instrument. Active: accruing interest; Matured: reached term end; Redeemed: early withdrawal executed; Rolled-over: renewed into new term; Closed: final settlement completed.' ;
    rdfs:domain ind:CertificateOfDeposit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdType rdf:type rdf:Property ;
    rdfs:label 'Cd Type' ;
    rdfs:comment 'Classification of the CD product structure. Traditional: standard fixed-rate; Jumbo: high-value institutional; Brokered: issued through intermediary; Callable: issuer redemption option; Bump-up: rate adjustment option; Variable-rate: floating coupon.' ;
    rdfs:domain ind:CertificateOfDeposit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dayCountConvention rdf:type rdf:Property ;
    rdfs:label 'Day Count Convention' ;
    rdfs:comment 'Method for calculating the fraction of a year for interest accrual. ACT/360: actual days over 360-day year; ACT/365: actual days over 365-day year; ACT/ACT: actual days over actual year; 30/360: assumes 30-day months.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:earlyWithdrawalPenaltyFlag rdf:type rdf:Property ;
    rdfs:label 'Early Withdrawal Penalty Flag' ;
    rdfs:comment 'Indicates whether a penalty applies if the CD is redeemed before maturity. True: penalty schedule in effect; False: penalty-free early withdrawal permitted (rare, typically for death/disability exceptions).' ;
    rdfs:domain ind:CertificateOfDeposit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:faceValueAmount rdf:type rdf:Property ;
    rdfs:label 'Face Value Amount' ;
    rdfs:comment 'Principal amount deposited at CD origination. This is the base amount on which interest accrues over the term.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gracePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Grace Period Days' ;
    rdfs:comment 'Number of days after maturity during which the customer may withdraw funds or change renewal instructions without penalty. Typical range: 7-10 days.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:issueDate rdf:type rdf:Property ;
    rdfs:label 'Issue Date' ;
    rdfs:comment 'Date on which the CD was issued and the deposit was accepted. Marks the start of the interest accrual period.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maturityDate rdf:type rdf:Property ;
    rdfs:label 'Maturity Date' ;
    rdfs:comment 'Date on which the CD term ends and principal plus accrued interest becomes payable to the holder. Calculated from issue date plus term in days.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maturityValueAmount rdf:type rdf:Property ;
    rdfs:label 'Maturity Value Amount' ;
    rdfs:comment 'Total amount payable at maturity, including principal and all accrued interest. Calculated at issue and updated if rate changes (variable-rate CDs).' ;
    rdfs:domain ind:CertificateOfDeposit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:negotiableFlag rdf:type rdf:Property ;
    rdfs:label 'Negotiable Flag' ;
    rdfs:comment 'Indicates whether the CD is a negotiable instrument that can be traded in secondary markets. True: negotiable CD with CUSIP/ISIN; False: non-negotiable retail CD held to maturity.' ;
    rdfs:domain ind:CertificateOfDeposit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:penaltyCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Penalty Calculation Method' ;
    rdfs:comment 'Method used to compute the early withdrawal penalty amount. Simple_interest: penalty based on simple interest; Compound_interest: penalty includes compounding; Flat_fee: fixed dollar amount; Percentage_of_principal: percentage of face value.' ;
    rdfs:domain ind:CertificateOfDeposit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyMonthsInterest rdf:type rdf:Property ;
    rdfs:label 'Penalty Months Interest' ;
    rdfs:comment 'Number of months of interest forfeited as penalty for early withdrawal. Common values: 3, 6, 12 months. Null if no penalty applies.' ;
    rdfs:domain ind:CertificateOfDeposit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rateSpreadBps rdf:type rdf:Property ;
    rdfs:label 'Rate Spread Bps' ;
    rdfs:comment 'Margin added to the benchmark rate for variable-rate CDs, expressed in basis points (1 BPS = 0.01%). Example: SOFR + 50 BPS. Null for fixed-rate CDs.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryReserveClassification rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reserve Classification' ;
    rdfs:comment 'Federal Reserve classification for reserve requirement purposes. Time_deposit: CDs with original maturity > 7 days (typically exempt from reserve requirements under Regulation D). Savings_deposit: CDs with < 7 days. Transaction_account: rare for CDs.' ;
    rdfs:domain ind:CertificateOfDeposit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalInstruction rdf:type rdf:Property ;
    rdfs:label 'Renewal Instruction' ;
    rdfs:comment 'Customer directive for funds disposition at maturity. Principal_only: renew principal, disburse interest; Principal_plus_interest: renew both; Transfer_to_dda: move to demand deposit account; Hold_for_instruction: await customer decision.' ;
    rdfs:domain ind:CertificateOfDeposit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalTermDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Term Days' ;
    rdfs:comment 'Term length in days for the new CD if auto-renewal is executed. May differ from original term. Null if auto-renewal is disabled.' ;
    rdfs:domain ind:CertificateOfDeposit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:termDays rdf:type rdf:Property ;
    rdfs:label 'Term Days' ;
    rdfs:comment 'Total number of calendar days from issue to maturity. Common terms: 30, 60, 90, 180, 365, 730 days. Drives interest calculation and regulatory reserve classification.' ;
    rdfs:domain ind:CertificateOfDeposit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:custodialAccountId rdf:type rdf:Property ;
    rdfs:label 'Custodial Account Id' ;
    rdfs:comment 'Unique identifier for the custodial account. Primary key for this entity.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustodialAccount .

ind:branchId rdf:type rdf:Property ;
    rdfs:label 'Branch Id' ;
    rdfs:comment 'Identifier of the bank branch or trust office where the custodial account is domiciled and administered.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Branch .

ind:investorAccountId rdf:type rdf:Property ;
    rdfs:label 'Investor Account Id' ;
    rdfs:comment 'Foreign key linking to asset.investor_account. Business justification: Custodial accounts (529 plans, UGMA/UTMA, trust accounts) are paired with investor accounts for securities/fund holdings. Custodial_account tracks fiduciary relationship and cash; investor_account tra' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InvestorAccount .

ind:legalEntityId rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Id' ;
    rdfs:comment 'Identifier of the bank entity or trust department acting as custodian and fiduciary for this account.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:loanFeeScheduleId rdf:type rdf:Property ;
    rdfs:label 'Loan Fee Schedule Id' ;
    rdfs:comment 'Identifier of the fee schedule governing custodial and fiduciary fees charged to this account, including management fees, transaction fees, and administrative charges.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LoanFeeSchedule .

ind:settlementAccountDepositAccountId rdf:type rdf:Property ;
    rdfs:label 'Settlement Account Deposit Account Id' ;
    rdfs:comment 'Foreign key linking to account.deposit_account. Business justification: Custodial accounts require linked deposit accounts for trade settlement, custody fee debits, corporate action cash proceeds, and securities lending collateral. Core operational requirement for custody' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DepositAccount .

ind:accountName rdf:type rdf:Property ;
    rdfs:label 'Account Name' ;
    rdfs:comment 'Legal name or title of the custodial account as it appears on statements and regulatory filings.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountNumber rdf:type rdf:Property ;
    rdfs:label 'Account Number' ;
    rdfs:comment 'Externally-visible unique account number assigned to the custodial account. May conform to IBAN format for international accounts or internal bank numbering scheme.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountStatus rdf:type rdf:Property ;
    rdfs:label 'Account Status' ;
    rdfs:comment 'Current lifecycle status of the custodial account. Active accounts are operational; dormant accounts have no recent activity; suspended accounts have temporary restrictions; closed accounts are terminated; pending approval accounts await regulatory or internal approval; restricted accounts have limited transaction capabilities due to legal or compliance holds.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualManagementFeeRate rdf:type rdf:Property ;
    rdfs:label 'Annual Management Fee Rate' ;
    rdfs:comment 'Annual management fee rate charged for custodial and fiduciary services, expressed as a percentage of assets under management (e.g., 0.0100 for 1.00% annual fee).' ;
    rdfs:domain ind:CustodialAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cashBalance rdf:type rdf:Property ;
    rdfs:label 'Cash Balance' ;
    rdfs:comment 'Current cash balance held in the custodial account, excluding securities and other non-cash assets.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:closingDate rdf:type rdf:Property ;
    rdfs:label 'Closing Date' ;
    rdfs:comment 'Date when the custodial account was closed or terminated. Null for active accounts.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:currentBalance rdf:type rdf:Property ;
    rdfs:label 'Current Balance' ;
    rdfs:comment 'Current total balance of all assets held in the custodial account, expressed in the account base currency. Includes cash, securities at market value, and other assets.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:distributionFrequency rdf:type rdf:Property ;
    rdfs:label 'Distribution Frequency' ;
    rdfs:comment 'Scheduled frequency for distributions from the custodial account. Monthly, quarterly, and annual distributions follow regular schedules; on-demand distributions occur at beneficiary request; event-triggered distributions occur upon specific conditions; none indicates no regular distributions.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionInstruction rdf:type rdf:Property ;
    rdfs:label 'Distribution Instruction' ;
    rdfs:comment 'Instructions governing distributions from the custodial account to beneficiaries, including frequency, amount, conditions, and triggering events as specified in the governing instrument.' ;
    rdfs:domain ind:CustodialAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fatcaStatus rdf:type rdf:Property ;
    rdfs:label 'Fatca Status' ;
    rdfs:comment 'Compliance status of the custodial account with FATCA reporting requirements. Compliant accounts have completed required reporting; non-compliant accounts have outstanding FATCA obligations; exempt accounts are not subject to FATCA; not applicable for domestic-only accounts.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiduciaryRelationshipType rdf:type rdf:Property ;
    rdfs:label 'Fiduciary Relationship Type' ;
    rdfs:comment 'Classification of the fiduciary relationship governing the custodial account. Trust accounts hold assets under trust agreement; escrow accounts hold funds pending transaction completion; IOLTA (Interest on Lawyers Trust Accounts) hold client funds for attorneys; guardian accounts hold assets for minors or incapacitated persons; conservator accounts manage financial affairs under court order; executor accounts manage estate assets.' ;
    rdfs:domain ind:CustodialAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingInstrumentDate rdf:type rdf:Property ;
    rdfs:label 'Governing Instrument Date' ;
    rdfs:comment 'Effective date of the governing legal instrument (trust agreement, court order, escrow agreement) that establishes the fiduciary relationship.' ;
    rdfs:domain ind:CustodialAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:governingInstrumentReference rdf:type rdf:Property ;
    rdfs:label 'Governing Instrument Reference' ;
    rdfs:comment 'Reference number or identifier of the legal document governing the custodial relationship, such as trust agreement number, court order number, escrow agreement reference, or will reference.' ;
    rdfs:domain ind:CustodialAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantorName rdf:type rdf:Property ;
    rdfs:label 'Grantor Name' ;
    rdfs:comment 'Full legal name of the grantor, settlor, or person who established the custodial account and transferred assets into fiduciary custody.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interestAccrualMethod rdf:type rdf:Property ;
    rdfs:label 'Interest Accrual Method' ;
    rdfs:comment 'Method used to calculate and accrue interest on the custodial account cash balance. Daily accrual calculates interest each day; monthly and quarterly accrue at period end; simple interest does not compound; compound interest includes interest-on-interest.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investmentRestrictionDescription rdf:type rdf:Property ;
    rdfs:label 'Investment Restriction Description' ;
    rdfs:comment 'Detailed description of any investment restrictions, limitations, or guidelines applicable to the custodial account assets, such as prohibited asset classes, concentration limits, or risk parameters.' ;
    rdfs:domain ind:CustodialAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investmentRestrictionFlag rdf:type rdf:Property ;
    rdfs:label 'Investment Restriction Flag' ;
    rdfs:comment 'Indicates whether the custodial account is subject to investment restrictions defined in the governing instrument or by applicable law (e.g., prudent investor rule, prohibited investments).' ;
    rdfs:domain ind:CustodialAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jurisdictionState rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction State' ;
    rdfs:comment 'Two-letter US state code indicating the legal jurisdiction governing the custodial account, particularly relevant for state trust law and probate matters.' ;
    rdfs:domain ind:CustodialAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kycReviewDate rdf:type rdf:Property ;
    rdfs:label 'Kyc Review Date' ;
    rdfs:comment 'Date when the most recent KYC review was completed for this custodial account.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:kycStatus rdf:type rdf:Property ;
    rdfs:label 'Kyc Status' ;
    rdfs:comment 'Status of Know Your Customer due diligence for the custodial account, including verification of beneficiary and grantor identities. Verified accounts have completed KYC; pending accounts are under review; expired accounts require re-verification; failed accounts did not pass KYC checks.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastStatementDate rdf:type rdf:Property ;
    rdfs:label 'Last Statement Date' ;
    rdfs:comment 'Date when the most recent account statement was generated and issued.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastValuationDate rdf:type rdf:Property ;
    rdfs:label 'Last Valuation Date' ;
    rdfs:comment 'Date when the custodial account assets were last valued and marked-to-market for reporting purposes.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextStatementDate rdf:type rdf:Property ;
    rdfs:label 'Next Statement Date' ;
    rdfs:comment 'Scheduled date for the next account statement generation.' ;
    rdfs:domain ind:CustodialAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:openingDate rdf:type rdf:Property ;
    rdfs:label 'Opening Date' ;
    rdfs:comment 'Date when the custodial account was officially opened and became operational.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryRegime rdf:type rdf:Property ;
    rdfs:label 'Regulatory Regime' ;
    rdfs:comment 'Primary regulatory framework governing the custodial account. OCC federal regulations apply to national bank trust departments; state trust law applies to state-chartered institutions; ERISA governs employee benefit plan accounts; Uniform Trust Code applies in adopting states; probate court governs estate and guardianship accounts.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securitiesMarketValue rdf:type rdf:Property ;
    rdfs:label 'Securities Market Value' ;
    rdfs:comment 'Current market value of all securities held in the custodial account, marked-to-market as of the last valuation date.' ;
    rdfs:domain ind:CustodialAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accountType rdf:type rdf:Property ;
    rdfs:label 'Account Type' ;
    rdfs:comment 'Classification of the deposit account product type. DDA = Demand Deposit Account (checking), NOW = Negotiable Order of Withdrawal.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amountEscheated rdf:type rdf:Property ;
    rdfs:label 'Amount Escheated' ;
    rdfs:comment 'Total amount remitted to the state as unclaimed property. Null if not yet escheated.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:atmWithdrawalLimit rdf:type rdf:Property ;
    rdfs:label 'Atm Withdrawal Limit' ;
    rdfs:comment 'Maximum amount that can be withdrawn via ATM in a single transaction or calendar day.' ;
    rdfs:domain ind:DepositAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dailyTransferLimit rdf:type rdf:Property ;
    rdfs:label 'Daily Transfer Limit' ;
    rdfs:comment 'Maximum amount that can be transferred out of the account in a single calendar day.' ;
    rdfs:domain ind:DepositAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dailyWithdrawalLimit rdf:type rdf:Property ;
    rdfs:label 'Daily Withdrawal Limit' ;
    rdfs:comment 'Maximum amount that can be withdrawn from the account in a single calendar day across all channels.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dormancyClassificationDate rdf:type rdf:Property ;
    rdfs:label 'Dormancy Classification Date' ;
    rdfs:comment 'Date the account was classified as dormant due to lack of customer-initiated activity for the defined dormancy period.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dormancyPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Dormancy Period Months' ;
    rdfs:comment 'Number of months of inactivity required before the account is classified as dormant, per state or regulatory requirements.' ;
    rdfs:domain ind:DepositAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:escheatmentFilingDate rdf:type rdf:Property ;
    rdfs:label 'Escheatment Filing Date' ;
    rdfs:comment 'Date the account balance was reported and remitted to the state as unclaimed property. Null if not yet escheated.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:escheatmentJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Escheatment Jurisdiction' ;
    rdfs:comment 'Two-letter US state code or jurisdiction to which unclaimed funds must be escheated.' ;
    rdfs:domain ind:DepositAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fdicCoverageCategory rdf:type rdf:Property ;
    rdfs:label 'Fdic Coverage Category' ;
    rdfs:comment 'FDIC insurance coverage category determining the insurance limit applicable to this account. [ENUM-REF-CANDIDATE: single|joint|revocable_trust|irrevocable_trust|employee_benefit|corporation|government — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DepositAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastActivityDate rdf:type rdf:Property ;
    rdfs:label 'Last Activity Date' ;
    rdfs:comment 'Date of the most recent customer-initiated transaction or activity on the account. Used for dormancy tracking.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:overdraftOptInStatus rdf:type rdf:Property ;
    rdfs:label 'Overdraft Opt In Status' ;
    rdfs:comment 'Customer election status for overdraft coverage on ATM and one-time debit card transactions, as required by Regulation E.' ;
    rdfs:domain ind:DepositAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overdraftProtectionSource rdf:type rdf:Property ;
    rdfs:label 'Overdraft Protection Source' ;
    rdfs:comment 'Source of funds for overdraft protection, if configured. Indicates the linked account or credit facility used to cover overdrafts.' ;
    rdfs:domain ind:DepositAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipType rdf:type rdf:Property ;
    rdfs:label 'Ownership Type' ;
    rdfs:comment 'Legal ownership structure of the deposit account. [ENUM-REF-CANDIDATE: individual|joint|corporate|trust|estate|custodial|government — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DepositAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statementCycle rdf:type rdf:Property ;
    rdfs:label 'Statement Cycle' ;
    rdfs:comment 'Frequency at which account statements are generated and delivered to the account holder.' ;
    rdfs:domain ind:DepositAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:directDebitMandateId rdf:type rdf:Property ;
    rdfs:label 'Direct Debit Mandate Id' ;
    rdfs:comment 'Unique identifier for the direct debit mandate authorization record.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DirectDebitMandate .

ind:authorizationChannelId rdf:type rdf:Property ;
    rdfs:label 'Authorization Channel Id' ;
    rdfs:comment 'Foreign key linking to channel.channel. Business justification: NACHA and Reg E require tracking the channel through which direct debit mandates are authorized for dispute resolution and compliance audits. Essential for unauthorized debit claim investigations. Rem' ;
    rdfs:domain ind:DirectDebitMandate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:sanctionsScreeningEventId rdf:type rdf:Property ;
    rdfs:label 'Sanctions Screening Event Id' ;
    rdfs:comment 'Foreign key linking to compliance.sanctions_screening_event. Business justification: Direct debit mandates require OFAC screening of originators/creditors at setup and periodic refresh per sanctions compliance requirements. Links mandate to screening results for blocking decisions, re' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SanctionsScreeningEvent .

ind:verifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Verified By Employee Id' ;
    rdfs:comment 'Foreign key linking to hr.employee. Business justification: Direct debit mandate authorization requires banker verification of customer identity and authorization per CIP/BSA requirements and fraud prevention. Real business process: mandate verification workfl' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:authorizationDate rdf:type rdf:Property ;
    rdfs:label 'Authorization Date' ;
    rdfs:comment 'Date on which the account holder authorized the direct debit mandate.' ;
    rdfs:domain ind:DirectDebitMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authorizationMethod rdf:type rdf:Property ;
    rdfs:label 'Authorization Method' ;
    rdfs:comment 'Method by which the authorization was obtained from the account holder.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Authorization Timestamp' ;
    rdfs:comment 'Precise timestamp when the mandate authorization was captured in the system.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:authorizedAmount rdf:type rdf:Property ;
    rdfs:label 'Authorized Amount' ;
    rdfs:comment 'Maximum amount authorized per debit transaction. Null for variable amount mandates.' ;
    rdfs:domain ind:DirectDebitMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collectionCount rdf:type rdf:Property ;
    rdfs:label 'Collection Count' ;
    rdfs:comment 'Total number of debit collections executed under this mandate to date.' ;
    rdfs:domain ind:DirectDebitMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:creditorIdentifier rdf:type rdf:Property ;
    rdfs:label 'Creditor Identifier' ;
    rdfs:comment 'ISO 13616 compliant creditor identifier used in SEPA direct debit schemes to uniquely identify the creditor.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstCollectionDate rdf:type rdf:Property ;
    rdfs:label 'First Collection Date' ;
    rdfs:comment 'Date of the first debit collection under this mandate.' ;
    rdfs:domain ind:DirectDebitMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:frequencyCode rdf:type rdf:Property ;
    rdfs:label 'Frequency Code' ;
    rdfs:comment 'Expected frequency at which debits will be initiated under this mandate. [ENUM-REF-CANDIDATE: daily|weekly|biweekly|monthly|quarterly|annual|on_demand — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastCollectionDate rdf:type rdf:Property ;
    rdfs:label 'Last Collection Date' ;
    rdfs:comment 'Date of the most recent debit collection executed under this mandate.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mandateReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Mandate Reference Number' ;
    rdfs:comment 'Unique external reference number assigned to this mandate for identification in ACH and SEPA transactions.' ;
    rdfs:domain ind:DirectDebitMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mandateStatus rdf:type rdf:Property ;
    rdfs:label 'Mandate Status' ;
    rdfs:comment 'Current lifecycle status of the direct debit mandate.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mandateType rdf:type rdf:Property ;
    rdfs:label 'Mandate Type' ;
    rdfs:comment 'Classification of the mandate indicating whether it authorizes recurring debits, a single one-off debit, or variable amount debits.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originatorName rdf:type rdf:Property ;
    rdfs:label 'Originator Name' ;
    rdfs:comment 'Legal name of the company or entity authorized to originate ACH debit entries against the account.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preNotificationDays rdf:type rdf:Property ;
    rdfs:label 'Pre Notification Days' ;
    rdfs:comment 'Number of days advance notice required before each debit is executed.' ;
    rdfs:domain ind:DirectDebitMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:returnCount rdf:type rdf:Property ;
    rdfs:label 'Return Count' ;
    rdfs:comment 'Total number of ACH returns received for debits initiated under this mandate.' ;
    rdfs:domain ind:DirectDebitMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revocationChannel rdf:type rdf:Property ;
    rdfs:label 'Revocation Channel' ;
    rdfs:comment 'Channel through which the customer revoked the mandate.' ;
    rdfs:domain ind:DirectDebitMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revocationReasonCode rdf:type rdf:Property ;
    rdfs:label 'Revocation Reason Code' ;
    rdfs:comment 'Coded reason for mandate revocation.' ;
    rdfs:domain ind:DirectDebitMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secCode rdf:type rdf:Property ;
    rdfs:label 'Sec Code' ;
    rdfs:comment 'NACHA Standard Entry Class code indicating the type of ACH transaction authorized (PPD=Prearranged Payment and Deposit, CCD=Corporate Credit or Debit, WEB=Internet-Initiated, TEL=Telephone-Initiated). [ENUM-REF-CANDIDATE: PPD|CCD|WEB|TEL|POP|ARC|BOC|RCK — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DirectDebitMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatureDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Signature Document Reference' ;
    rdfs:comment 'Reference identifier to the stored authorization document or signature image.' ;
    rdfs:domain ind:DirectDebitMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatureOnFileFlag rdf:type rdf:Property ;
    rdfs:label 'Signature On File Flag' ;
    rdfs:comment 'Indicates whether a physical or digital signature authorizing the mandate is retained on file.' ;
    rdfs:domain ind:DirectDebitMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dormancyReviewId rdf:type rdf:Property ;
    rdfs:label 'Dormancy Review Id' ;
    rdfs:comment 'Unique identifier for the dormancy review record. Primary key for the dormancy review operational tracking entity.' ;
    rdfs:domain ind:DormancyReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:outreachChannelId rdf:type rdf:Property ;
    rdfs:label 'Outreach Channel Id' ;
    rdfs:comment 'Foreign key linking to channel.channel. Business justification: State escheatment laws require documented outreach attempts through specific channels before remitting dormant account funds to state authorities. Required for compliance with unclaimed property regul' ;
    rdfs:domain ind:DormancyReview ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:primaryDormancyEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Dormancy Employee Id' ;
    rdfs:comment 'Employee identifier of the compliance officer assigned to manage this dormancy review case.' ;
    rdfs:domain ind:DormancyReview ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accountBalanceAtReview rdf:type rdf:Property ;
    rdfs:label 'Account Balance At Review' ;
    rdfs:comment 'Current balance of the deposit account at the time the dormancy review was initiated. Used to determine materiality and escheatment amount.' ;
    rdfs:domain ind:DormancyReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:closureReasonCode rdf:type rdf:Property ;
    rdfs:label 'Closure Reason Code' ;
    rdfs:comment 'Code indicating the reason for closing the dormancy review case. Null if review still open.' ;
    rdfs:domain ind:DormancyReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerResponseChannel rdf:type rdf:Property ;
    rdfs:label 'Customer Response Channel' ;
    rdfs:comment 'Channel through which the customer responded to dormancy notification. Null if no response received.' ;
    rdfs:domain ind:DormancyReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerResponseDate rdf:type rdf:Property ;
    rdfs:label 'Customer Response Date' ;
    rdfs:comment 'Date when the customer responded to dormancy outreach. Null if no response received.' ;
    rdfs:domain ind:DormancyReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customerResponseFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Response Flag' ;
    rdfs:comment 'Indicates whether the customer responded to any outreach attempt. True if customer responded, False if no response received.' ;
    rdfs:domain ind:DormancyReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dueDiligenceCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Due Diligence Completion Date' ;
    rdfs:comment 'Date when all required due diligence efforts to locate and contact the customer were completed prior to escheatment.' ;
    rdfs:domain ind:DormancyReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:escheatmentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Escheatment Reference Number' ;
    rdfs:comment 'Reference number assigned by the state unclaimed property office for the escheatment filing. Null if not yet escheated.' ;
    rdfs:domain ind:DormancyReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escheatmentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Escheatment Required Flag' ;
    rdfs:comment 'Indicates whether the account balance must be escheated to the state based on dormancy period exceeding state threshold and lack of customer response.' ;
    rdfs:domain ind:DormancyReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:firstOutreachDate rdf:type rdf:Property ;
    rdfs:label 'First Outreach Date' ;
    rdfs:comment 'Date of the first outreach attempt to notify the customer of dormancy status and request account reactivation.' ;
    rdfs:domain ind:DormancyReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastCustomerActivityDate rdf:type rdf:Property ;
    rdfs:label 'Last Customer Activity Date' ;
    rdfs:comment 'Date of the most recent customer-initiated transaction or contact on the account. Used to determine dormancy period calculation start date.' ;
    rdfs:domain ind:DormancyReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastOutreachDate rdf:type rdf:Property ;
    rdfs:label 'Last Outreach Date' ;
    rdfs:comment 'Date of the most recent outreach attempt to contact the customer regarding the dormant account.' ;
    rdfs:domain ind:DormancyReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent update to this dormancy review record. Used for change tracking and audit trail.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:notes rdf:type rdf:Property ;
    rdfs:label 'Notes' ;
    rdfs:comment 'Free-text field for compliance officers to document case-specific details, customer interactions, special circumstances, or resolution notes.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outreachAttemptCount rdf:type rdf:Property ;
    rdfs:label 'Outreach Attempt Count' ;
    rdfs:comment 'Total number of outreach attempts made to contact the customer regarding the dormant account. Includes letters, emails, phone calls, and other communication methods.' ;
    rdfs:domain ind:DormancyReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:outreachMethodLog rdf:type rdf:Property ;
    rdfs:label 'Outreach Method Log' ;
    rdfs:comment 'Comma-separated log of outreach methods used in chronological order. Examples: mail, email, phone, certified_mail, sms.' ;
    rdfs:domain ind:DormancyReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reactivationDate rdf:type rdf:Property ;
    rdfs:label 'Reactivation Date' ;
    rdfs:comment 'Date when the dormant account was reactivated to active status following customer engagement. Null if not reactivated.' ;
    rdfs:domain ind:DormancyReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reactivationFlag rdf:type rdf:Property ;
    rdfs:label 'Reactivation Flag' ;
    rdfs:comment 'Indicates whether the account was successfully reactivated following customer response. True if reactivated, False otherwise.' ;
    rdfs:domain ind:DormancyReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewClosedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Review Closed Timestamp' ;
    rdfs:comment 'Timestamp when the dormancy review was closed, either due to account reactivation, escheatment completion, or other resolution. Null if review still open.' ;
    rdfs:domain ind:DormancyReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reviewInitiatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Review Initiated Timestamp' ;
    rdfs:comment 'Timestamp when the dormancy review record was created and the review workflow was initiated.' ;
    rdfs:domain ind:DormancyReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reviewPriorityLevel rdf:type rdf:Property ;
    rdfs:label 'Review Priority Level' ;
    rdfs:comment 'Priority classification for the dormancy review based on account balance, customer relationship value, and time to escheatment deadline.' ;
    rdfs:domain ind:DormancyReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Review Reference Number' ;
    rdfs:comment 'Externally visible unique reference number for the dormancy review case. Format: DR-XXXXXXXXXX.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewStatus rdf:type rdf:Property ;
    rdfs:label 'Review Status' ;
    rdfs:comment 'Current status of the dormancy review workflow. Tracks progression from initiation through customer outreach to final disposition. [ENUM-REF-CANDIDATE: initiated|outreach_in_progress|customer_responded|no_response|escalated|escheated|closed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateEscheatmentThresholdDays rdf:type rdf:Property ;
    rdfs:label 'State Escheatment Threshold Days' ;
    rdfs:comment 'Number of days of inactivity required before escheatment is mandated under the applicable state jurisdiction. Varies by state, typically ranging from 3 to 5 years.' ;
    rdfs:domain ind:DormancyReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stateJurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'State Jurisdiction Code' ;
    rdfs:comment 'Two-letter US state code identifying the jurisdiction governing escheatment for this account. Determines applicable dormancy threshold and reporting requirements.' ;
    rdfs:domain ind:DormancyReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overdraftFacilityId rdf:type rdf:Property ;
    rdfs:label 'Overdraft Facility Id' ;
    rdfs:comment 'Unique identifier for the overdraft facility arrangement. Primary key for the overdraft facility record.' ;
    rdfs:domain ind:OverdraftFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryOverdraftDepositAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Overdraft Deposit Account Id' ;
    rdfs:comment 'Reference to the deposit account (DDA, savings, money market) to which this overdraft facility is attached.' ;
    rdfs:domain ind:OverdraftFacility ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DepositAccount .

ind:approvalDate rdf:type rdf:Property ;
    rdfs:label 'Approval Date' ;
    rdfs:comment 'Date the overdraft facility was approved by the bank. Used for audit trail and compliance reporting.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvedLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Approved Limit Amount' ;
    rdfs:comment 'Maximum overdraft amount approved by the bank for this facility. Represents the ceiling for negative balance coverage.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:autoRepaymentEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Repayment Enabled' ;
    rdfs:comment 'Indicates whether automatic repayment of overdraft balance is enabled. True if incoming deposits automatically reduce the overdraft balance. False if manual repayment is required.' ;
    rdfs:domain ind:OverdraftFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cancellationDate rdf:type rdf:Property ;
    rdfs:label 'Cancellation Date' ;
    rdfs:comment 'Date the overdraft facility was cancelled and ceased to be available. Null if facility is not cancelled.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cancellationReason rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason' ;
    rdfs:comment 'Reason the overdraft facility was cancelled: customer request, account closure, adverse credit review, regulatory requirement, fraud detection, or other. Null if facility is not cancelled.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentUtilizationAmount rdf:type rdf:Property ;
    rdfs:label 'Current Utilization Amount' ;
    rdfs:comment 'Current outstanding overdraft balance being utilized by the customer. Represents the negative balance covered by the facility. Zero if account is not overdrawn.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dailyFeeCapAmount rdf:type rdf:Property ;
    rdfs:label 'Daily Fee Cap Amount' ;
    rdfs:comment 'Maximum total overdraft fees that can be charged in a single day. Used to limit customer exposure to excessive fees. Null if no daily cap applies.' ;
    rdfs:domain ind:OverdraftFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:facilityNumber rdf:type rdf:Property ;
    rdfs:label 'Facility Number' ;
    rdfs:comment 'Externally visible business identifier for the overdraft facility, used in customer communications and statements.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityType rdf:type rdf:Property ;
    rdfs:label 'Facility Type' ;
    rdfs:comment 'Classification of the overdraft protection arrangement: standard (bank covers overdraft with fee), premium (enhanced coverage), linked to savings account, linked to line of credit, or linked to credit card.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastUsageDate rdf:type rdf:Property ;
    rdfs:label 'Last Usage Date' ;
    rdfs:comment 'Most recent date the overdraft facility was used (account balance went negative). Null if facility has never been used.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lifetimeUsageCount rdf:type rdf:Property ;
    rdfs:label 'Lifetime Usage Count' ;
    rdfs:comment 'Total number of times the overdraft facility has been used (account went into negative balance) since facility inception. Used for customer behavior analysis.' ;
    rdfs:domain ind:OverdraftFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumTransferAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Transfer Amount' ;
    rdfs:comment 'Minimum amount that must be transferred from the linked protection source to cover an overdraft. Used to avoid multiple small transfers. Zero if no minimum applies.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:monthlyFeeCapAmount rdf:type rdf:Property ;
    rdfs:label 'Monthly Fee Cap Amount' ;
    rdfs:comment 'Maximum total overdraft fees that can be charged in a calendar month. Used to limit customer exposure to excessive fees. Null if no monthly cap applies.' ;
    rdfs:domain ind:OverdraftFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:optInDate rdf:type rdf:Property ;
    rdfs:label 'Opt In Date' ;
    rdfs:comment 'Date the customer provided opt-in consent for overdraft coverage per Regulation E. Null if customer has not opted in or opt-in is not applicable.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:optInStatus rdf:type rdf:Property ;
    rdfs:label 'Opt In Status' ;
    rdfs:comment 'Customer opt-in status for overdraft coverage on ATM and one-time debit card transactions per Federal Reserve Regulation E. Opted in indicates customer consented. Opted out indicates customer declined. Pending indicates awaiting customer decision. Not applicable for non-Reg E overdraft types.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optOutDate rdf:type rdf:Property ;
    rdfs:label 'Opt Out Date' ;
    rdfs:comment 'Date the customer revoked opt-in consent and opted out of overdraft coverage. Null if customer has not opted out.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:overdraftFacilityStatus rdf:type rdf:Property ;
    rdfs:label 'Overdraft Facility Status' ;
    rdfs:comment 'Current lifecycle state of the overdraft facility. Active indicates the facility is operational and available for use. Suspended indicates temporary hold. Cancelled indicates customer or bank terminated the arrangement. Expired indicates the facility reached its end date. Pending activation indicates awaiting customer opt-in or bank approval.' ;
    rdfs:domain ind:OverdraftFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overdraftFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Overdraft Fee Amount' ;
    rdfs:comment 'Standard fee charged per overdraft occurrence when the account balance goes negative and bank coverage is used. Zero if no overdraft fee applies.' ;
    rdfs:domain ind:OverdraftFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:protectionSourceType rdf:type rdf:Property ;
    rdfs:label 'Protection Source Type' ;
    rdfs:comment 'Identifies the source of funds used to cover overdrafts: bank coverage (bank absorbs with fee), linked savings account, linked line of credit, linked credit card, or none (no protection).' ;
    rdfs:domain ind:OverdraftFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewDate rdf:type rdf:Property ;
    rdfs:label 'Review Date' ;
    rdfs:comment 'Next scheduled date for bank review of the overdraft facility terms, limit, and customer eligibility. Used for periodic reassessment.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:riskRating rdf:type rdf:Property ;
    rdfs:label 'Risk Rating' ;
    rdfs:comment 'Bank internal risk assessment of the overdraft facility based on customer credit profile, usage patterns, and repayment history. Used for credit risk management and limit adjustments.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Transfer Fee Amount' ;
    rdfs:comment 'Fee charged per overdraft transfer event when funds are moved from the linked protection source to cover a negative balance. Zero if no per-transfer fee applies.' ;
    rdfs:domain ind:OverdraftFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transferIncrementAmount rdf:type rdf:Property ;
    rdfs:label 'Transfer Increment Amount' ;
    rdfs:comment 'Fixed increment amount for transfers from linked protection source (e.g., transfers occur in multiples of 50.00). Null if transfers match exact overdraft amount.' ;
    rdfs:domain ind:OverdraftFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:utilizationPercentage rdf:type rdf:Property ;
    rdfs:label 'Utilization Percentage' ;
    rdfs:comment 'Percentage of the approved limit currently utilized, calculated as (current_utilization_amount / approved_limit_amount) * 100. Used for credit risk monitoring.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateTierId rdf:type rdf:Property ;
    rdfs:label 'Rate Tier Id' ;
    rdfs:comment 'Unique identifier for the rate tier record. Primary key.' ;
    rdfs:domain ind:RateTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:annualPercentageRate rdf:type rdf:Property ;
    rdfs:label 'Annual Percentage Rate' ;
    rdfs:comment 'The nominal annual interest rate for this tier, expressed as a decimal (e.g., 0.02500 for 2.5%). Used for interest accrual calculations.' ;
    rdfs:domain ind:RateTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fdicInsuranceApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Fdic Insurance Applicable Flag' ;
    rdfs:comment 'Indicates whether deposits in accounts using this rate tier are eligible for FDIC insurance coverage (True for most deposit products, False for certain investment or sweep accounts).' ;
    rdfs:domain ind:RateTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geographicRestriction rdf:type rdf:Property ;
    rdfs:label 'Geographic Restriction' ;
    rdfs:comment 'Geographic limitation for rate tier availability, specified as comma-separated list of state/province codes or country codes. NULL indicates no geographic restriction.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedBy rdf:type rdf:Property ;
    rdfs:label 'Last Modified By' ;
    rdfs:comment 'User ID or system identifier of the person or process that last modified this rate tier record.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumBalanceThreshold rdf:type rdf:Property ;
    rdfs:label 'Maximum Balance Threshold' ;
    rdfs:comment 'The maximum account balance for which this tier\'s interest rate applies. Inclusive upper bound of the tier range. NULL indicates no upper limit for the highest tier.' ;
    rdfs:domain ind:RateTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumBalanceThreshold rdf:type rdf:Property ;
    rdfs:label 'Minimum Balance Threshold' ;
    rdfs:comment 'The minimum account balance required to qualify for this tier\'s interest rate. Inclusive lower bound of the tier range.' ;
    rdfs:domain ind:RateTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nimImpactBasisPoints rdf:type rdf:Property ;
    rdfs:label 'Nim Impact Basis Points' ;
    rdfs:comment 'Estimated impact of this rate tier on the bank\'s Net Interest Margin, expressed in basis points. Used for profitability analysis and Asset-Liability Management (ALM). Negative values indicate margin compression.' ;
    rdfs:domain ind:RateTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:promotionalDescription rdf:type rdf:Property ;
    rdfs:label 'Promotional Description' ;
    rdfs:comment 'Marketing description of the promotional rate offer, including any special terms or conditions. NULL for non-promotional tiers.' ;
    rdfs:domain ind:RateTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionalFlag rdf:type rdf:Property ;
    rdfs:label 'Promotional Flag' ;
    rdfs:comment 'Indicates whether this rate tier is part of a promotional offering (True) or standard product pricing (False). Promotional rates typically have limited duration.' ;
    rdfs:domain ind:RateTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rateIndexCode rdf:type rdf:Property ;
    rdfs:label 'Rate Index Code' ;
    rdfs:comment 'Code identifying the external rate index to which this tier is linked (e.g., SOFR, EFFR, LIBOR). NULL for fixed or non-indexed rates.' ;
    rdfs:domain ind:RateTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateMarginBasisPoints rdf:type rdf:Property ;
    rdfs:label 'Rate Margin Basis Points' ;
    rdfs:comment 'Margin in basis points added to or subtracted from the rate index to determine the tier\'s APR. One basis point equals 0.01%. NULL for non-indexed rates.' ;
    rdfs:domain ind:RateTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rateTierStatus rdf:type rdf:Property ;
    rdfs:label 'Rate Tier Status' ;
    rdfs:comment 'Current lifecycle status of the rate tier: active (currently in use), inactive (temporarily disabled), pending (scheduled for future activation), expired (past expiry date), or superseded (replaced by newer tier structure).' ;
    rdfs:domain ind:RateTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipCriteriaDescription rdf:type rdf:Property ;
    rdfs:label 'Relationship Criteria Description' ;
    rdfs:comment 'Detailed description of the relationship requirements needed to qualify for this rate tier (e.g., maintain $25,000 combined balance across all accounts, or set up recurring direct deposit of $1,000+). NULL if relationship_pricing_flag is False.' ;
    rdfs:domain ind:RateTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipPricingFlag rdf:type rdf:Property ;
    rdfs:label 'Relationship Pricing Flag' ;
    rdfs:comment 'Indicates whether this rate tier requires the customer to maintain additional qualifying relationships with the bank (True), such as direct deposit, minimum combined balances, or linked loan products. False for standalone pricing.' ;
    rdfs:domain ind:RateTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:standingOrderId rdf:type rdf:Property ;
    rdfs:label 'Standing Order Id' ;
    rdfs:comment 'Unique identifier for the standing order. Primary key for the standing order entity.' ;
    rdfs:domain ind:StandingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:amlScreeningTimestamp rdf:type rdf:Property ;
    rdfs:label 'Aml Screening Timestamp' ;
    rdfs:comment 'Date and time of the most recent AML and sanctions screening for this standing order. Screening is typically performed at setup and periodically thereafter.' ;
    rdfs:domain ind:StandingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:beneficiaryAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Account Number' ;
    rdfs:comment 'Account number of the beneficiary receiving the funds. May be internal account number, IBAN, or domestic account format depending on payment channel.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficiaryBankCode rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Bank Code' ;
    rdfs:comment 'Bank Identifier Code (BIC) or SWIFT code of the beneficiary financial institution. Required for international transfers and interbank payments.' ;
    rdfs:domain ind:StandingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficiaryBankName rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Bank Name' ;
    rdfs:comment 'Name of the financial institution where the beneficiary account is held. Used for payment routing and customer reference.' ;
    rdfs:domain ind:StandingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessDayAdjustment rdf:type rdf:Property ;
    rdfs:label 'Business Day Adjustment' ;
    rdfs:comment 'Rule for adjusting execution date when scheduled date falls on a non-business day. Following moves to next business day; preceding moves to prior business day; modified following moves forward unless crossing month boundary.' ;
    rdfs:domain ind:StandingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationReasonCode rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for standing order cancellation. Used for operational reporting and customer service.' ;
    rdfs:domain ind:StandingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cancellation Timestamp' ;
    rdfs:comment 'Date and time when the standing order was cancelled. Null for active or suspended orders.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:chargeBearer rdf:type rdf:Property ;
    rdfs:label 'Charge Bearer' ;
    rdfs:comment 'Party responsible for payment of transaction charges and fees. Debtor bears all charges; creditor receives net amount; shared splits charges between parties.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endDate rdf:type rdf:Property ;
    rdfs:label 'End Date' ;
    rdfs:comment 'Date on which the standing order expires and ceases execution. Nullable for open-ended standing orders with no predetermined termination.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:executionCount rdf:type rdf:Property ;
    rdfs:label 'Execution Count' ;
    rdfs:comment 'Cumulative number of successful executions of the standing order since inception. Incremented after each successful payment.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:executionDay rdf:type rdf:Property ;
    rdfs:label 'Execution Day' ;
    rdfs:comment 'Day of the period on which the standing order should execute. For monthly frequency, represents day of month (1-31); for weekly, day of week (1-7). Adjusted for non-business days per bank policy.' ;
    rdfs:domain ind:StandingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:failedExecutionCount rdf:type rdf:Property ;
    rdfs:label 'Failed Execution Count' ;
    rdfs:comment 'Cumulative number of failed execution attempts due to insufficient funds, account restrictions, or system errors. Used for risk monitoring and customer notification.' ;
    rdfs:domain ind:StandingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:instructionReference rdf:type rdf:Property ;
    rdfs:label 'Instruction Reference' ;
    rdfs:comment 'Externally visible unique reference number assigned to the standing order instruction by the customer or bank. Used for customer inquiries and statement reconciliation.' ;
    rdfs:domain ind:StandingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instructionStatus rdf:type rdf:Property ;
    rdfs:label 'Instruction Status' ;
    rdfs:comment 'Current lifecycle status of the standing order instruction. Active orders execute on schedule; suspended orders are temporarily halted; cancelled orders are terminated; pending activation orders await start date; expired orders have passed their end date.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastExecutionDate rdf:type rdf:Property ;
    rdfs:label 'Last Execution Date' ;
    rdfs:comment 'Date of the most recent successful execution of the standing order. Null if the standing order has never executed.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextExecutionDate rdf:type rdf:Property ;
    rdfs:label 'Next Execution Date' ;
    rdfs:comment 'Next calendar date on which the standing order is scheduled to execute. Updated after each successful execution or when schedule is modified.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentChannel rdf:type rdf:Property ;
    rdfs:label 'Payment Channel' ;
    rdfs:comment 'Payment rail or clearing channel through which the standing order executes. Determines routing, settlement speed, and applicable fees.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentReference rdf:type rdf:Property ;
    rdfs:label 'Payment Reference' ;
    rdfs:comment 'Free-text reference or remittance information included with each payment execution. Appears on beneficiary statement for payment identification and reconciliation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityCode rdf:type rdf:Property ;
    rdfs:label 'Priority Code' ;
    rdfs:comment 'Execution priority level for the standing order. High and urgent priorities may incur premium fees but ensure faster processing.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:setupTimestamp rdf:type rdf:Property ;
    rdfs:label 'Setup Timestamp' ;
    rdfs:comment 'Date and time when the standing order instruction was originally created in the system. Immutable audit field.' ;
    rdfs:domain ind:StandingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:startDate rdf:type rdf:Property ;
    rdfs:label 'Start Date' ;
    rdfs:comment 'Date on which the standing order becomes active and eligible for first execution. Standing order will not execute before this date.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transferAmount rdf:type rdf:Property ;
    rdfs:label 'Transfer Amount' ;
    rdfs:comment 'Fixed monetary amount to be transferred with each execution of the standing order. Amount remains constant unless modified by customer instruction.' ;
    rdfs:domain ind:StandingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:distributionEventId rdf:type rdf:Property ;
    rdfs:label 'Distribution Event Id' ;
    rdfs:comment 'Unique identifier for the fund distribution event record.' ;
    rdfs:domain ind:DistributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fundClassId rdf:type rdf:Property ;
    rdfs:label 'Fund Class Id' ;
    rdfs:comment 'Reference to the specific fund share class for which the distribution is declared.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FundClass .

ind:paymentHolidayCalendarId rdf:type rdf:Property ;
    rdfs:label 'Payment Holiday Calendar Id' ;
    rdfs:comment 'Foreign key linking to reference.holiday_calendar. Business justification: Distribution payments made on valid business days per fund calendar. Required for payment scheduling, cash management, and investor servicing.' ;
    rdfs:domain ind:DistributionEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HolidayCalendar .

ind:accrualEndDate rdf:type rdf:Property ;
    rdfs:label 'Accrual End Date' ;
    rdfs:comment 'End date of the period during which the income or capital gains distributed were earned or realized by the fund. Used for fund accounting and performance attribution.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accrualStartDate rdf:type rdf:Property ;
    rdfs:label 'Accrual Start Date' ;
    rdfs:comment 'Start date of the period during which the income or capital gains distributed were earned or realized by the fund. Used for fund accounting and performance attribution.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvedBy rdf:type rdf:Property ;
    rdfs:label 'Approved By' ;
    rdfs:comment 'Name or identifier of the individual or committee that approved the distribution, such as the board of trustees, investment committee, or authorized officer.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declarationDate rdf:type rdf:Property ;
    rdfs:label 'Declaration Date' ;
    rdfs:comment 'Date on which the fund\'s board of directors or trustees formally declares the distribution.' ;
    rdfs:domain ind:DistributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:distributionApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Distribution Approval Date' ;
    rdfs:comment 'Date on which the distribution was formally approved by the fund\'s board of directors or trustees, or by authorized fund management under delegated authority.' ;
    rdfs:domain ind:DistributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:distributionCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Distribution Calculation Method' ;
    rdfs:comment 'Description of the methodology used to calculate the distribution amount, such as percentage of Net Asset Value (NAV), fixed rate, or based on net investment income and realized gains.' ;
    rdfs:domain ind:DistributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionNoticeDate rdf:type rdf:Property ;
    rdfs:label 'Distribution Notice Date' ;
    rdfs:comment 'Date on which the distribution notice was sent to shareholders, intermediaries, and regulatory authorities. Used to track compliance with notice requirements.' ;
    rdfs:domain ind:DistributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:distributionNumber rdf:type rdf:Property ;
    rdfs:label 'Distribution Number' ;
    rdfs:comment 'Business identifier for the distribution event, typically assigned by the fund administrator or transfer agent.' ;
    rdfs:domain ind:DistributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionRatePerUnit rdf:type rdf:Property ;
    rdfs:label 'Distribution Rate Per Unit' ;
    rdfs:comment 'Gross distribution amount per fund share or unit before any withholding taxes or adjustments.' ;
    rdfs:domain ind:DistributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:distributionSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Distribution Sequence Number' ;
    rdfs:comment 'Sequential number of the distribution within the tax year or fund fiscal year, used to track and order multiple distributions for the same fund class.' ;
    rdfs:domain ind:DistributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:distributionSourceDescription rdf:type rdf:Property ;
    rdfs:label 'Distribution Source Description' ;
    rdfs:comment 'Narrative description of the source of the distribution, such as net investment income, realized capital gains, or return of capital. Provides additional context for investor communications and regulatory disclosures.' ;
    rdfs:domain ind:DistributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionStatus rdf:type rdf:Property ;
    rdfs:label 'Distribution Status' ;
    rdfs:comment 'Current lifecycle status of the distribution event. Declared indicates the distribution has been announced. Pending approval indicates awaiting regulatory or board approval. Approved indicates ready for payment processing. Paid indicates distribution has been processed and paid to shareholders. Cancelled indicates the distribution was revoked before payment.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionType rdf:type rdf:Property ;
    rdfs:label 'Distribution Type' ;
    rdfs:comment 'Classification of the distribution for tax and accounting purposes. Income dividend represents ordinary income distributions from interest and dividends earned by the fund. Short-term capital gain represents gains from securities held one year or less. Long-term capital gain represents gains from securities held more than one year. Return of capital represents distributions that exceed the fund\'s earnings and profits. Qualified dividend represents dividends eligible for preferential tax treatment. Non-qualified dividend represents ordinary income dividends taxed at regular rates.' ;
    rdfs:domain ind:DistributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exDividendDate rdf:type rdf:Property ;
    rdfs:label 'Ex Dividend Date' ;
    rdfs:comment 'Date on which the fund begins trading without the distribution value. Investors purchasing shares on or after this date are not entitled to the declared distribution.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:foreignTaxCreditPercentage rdf:type rdf:Property ;
    rdfs:label 'Foreign Tax Credit Percentage' ;
    rdfs:comment 'Percentage of the distribution eligible for foreign tax credit pass-through to U.S. shareholders, representing foreign taxes paid by the fund on foreign-source income. Expressed as a decimal.' ;
    rdfs:domain ind:DistributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:form1099DivReportable rdf:type rdf:Property ;
    rdfs:label 'Form 1099 Div Reportable' ;
    rdfs:comment 'Indicates whether the distribution must be reported to the Internal Revenue Service (IRS) on Form 1099-DIV for U.S. tax purposes. True for most distributions to U.S. taxable investors.' ;
    rdfs:domain ind:DistributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netDistributionPerUnit rdf:type rdf:Property ;
    rdfs:label 'Net Distribution Per Unit' ;
    rdfs:comment 'Net distribution amount per share after applying default withholding tax rate. Represents the cash amount paid to investors subject to standard withholding.' ;
    rdfs:domain ind:DistributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentDate rdf:type rdf:Property ;
    rdfs:label 'Payment Date' ;
    rdfs:comment 'Date on which the distribution is paid to eligible shareholders or reinvested in additional fund shares.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentMethod rdf:type rdf:Property ;
    rdfs:label 'Payment Method' ;
    rdfs:comment 'Default payment method for the distribution. Cash indicates distribution paid in cash to investor accounts. Reinvestment indicates automatic reinvestment in additional fund shares at the reinvestment NAV. Mixed indicates the fund supports both options based on individual investor elections.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualifiedDividendPercentage rdf:type rdf:Property ;
    rdfs:label 'Qualified Dividend Percentage' ;
    rdfs:comment 'Percentage of the distribution that qualifies for preferential tax treatment as qualified dividends under Internal Revenue Code Section 1(h)(11). Expressed as a decimal (e.g., 0.85 for 85%).' ;
    rdfs:domain ind:DistributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recordDate rdf:type rdf:Property ;
    rdfs:label 'Record Date' ;
    rdfs:comment 'Date on which the fund determines which shareholders are entitled to receive the distribution. Only shareholders of record as of this date will receive the payment.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryFilingReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Reference' ;
    rdfs:comment 'Reference number or identifier for the regulatory filing associated with the distribution, such as Securities and Exchange Commission (SEC) Form N-CSR or Form N-PORT filing number.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reinvestmentNav rdf:type rdf:Property ;
    rdfs:label 'Reinvestment Nav' ;
    rdfs:comment 'Net Asset Value per share used to calculate the number of additional shares issued to investors who elect to reinvest their distribution. Typically the NAV as of the ex-dividend date or payment date per fund prospectus.' ;
    rdfs:domain ind:DistributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:section199aDividendPercentage rdf:type rdf:Property ;
    rdfs:label 'Section 199a Dividend Percentage' ;
    rdfs:comment 'Percentage of the distribution that qualifies as Section 199A dividends eligible for the qualified business income deduction. Expressed as a decimal. Applicable to Real Estate Investment Trust (REIT) and certain other fund distributions.' ;
    rdfs:domain ind:DistributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sharesOutstandingAtRecord rdf:type rdf:Property ;
    rdfs:label 'Shares Outstanding At Record' ;
    rdfs:comment 'Total number of fund shares outstanding as of the record date, used to calculate the total distribution amount and determine eligible shareholders.' ;
    rdfs:domain ind:DistributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxYear rdf:type rdf:Property ;
    rdfs:label 'Tax Year' ;
    rdfs:comment 'Calendar or fiscal tax year to which the distribution is attributed for tax reporting purposes. Typically the year in which the distribution is paid, but may differ for distributions declared in December and paid in January.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalDistributionAmount rdf:type rdf:Property ;
    rdfs:label 'Total Distribution Amount' ;
    rdfs:comment 'Total gross distribution amount declared for all eligible shares of the fund class, calculated as distribution rate per unit multiplied by total shares outstanding as of record date.' ;
    rdfs:domain ind:DistributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditorPartyId rdf:type rdf:Property ;
    rdfs:label 'Auditor Party Id' ;
    rdfs:comment 'Unique identifier for the external auditor responsible for auditing the fund\'s financial statements.' ;
    rdfs:domain ind:Fund ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:baseCurrencyId rdf:type rdf:Property ;
    rdfs:label 'Base Currency Id' ;
    rdfs:comment 'Foreign key linking to reference.currency. Business justification: Fund base currency is fundamental to NAV calculation, performance reporting, and investor statements. Every fund must have a base currency for accounting consolidation and regulatory reporting (UCITS,' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:domicileJurisdictionId rdf:type rdf:Property ;
    rdfs:label 'Domicile Jurisdiction Id' ;
    rdfs:comment 'Foreign key linking to reference.jurisdiction. Business justification: Fund domicile determines regulatory framework (Luxembourg UCITS, Irish QIF, Cayman SPC), tax treatment, and supervisory authority. Critical for compliance, licensing, and legal structure.' ;
    rdfs:domain ind:Fund ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Jurisdiction .

ind:fundPartyId rdf:type rdf:Property ;
    rdfs:label 'Fund Party Id' ;
    rdfs:comment 'Unique identifier for the custodian bank responsible for safekeeping the fund\'s assets.' ;
    rdfs:domain ind:Fund ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:fundTransferAgentPartyId rdf:type rdf:Property ;
    rdfs:label 'Fund Transfer Agent Party Id' ;
    rdfs:comment 'Unique identifier for the transfer agent responsible for maintaining shareholder records and processing subscriptions and redemptions.' ;
    rdfs:domain ind:Fund ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:stressScenarioId rdf:type rdf:Property ;
    rdfs:label 'Stress Scenario Id' ;
    rdfs:comment 'Foreign key linking to risk.stress_scenario. Business justification: Funds undergo regulatory stress testing (CCAR for bank-owned funds, AIFMD Article 15 stress tests, UCITS stress testing guidelines). Links fund to applicable stress scenarios. Real process: fund-level' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StressScenario .

ind:umbrellaFundId rdf:type rdf:Property ;
    rdfs:label 'Umbrella Fund Id' ;
    rdfs:comment 'Unique identifier for the parent umbrella fund structure if this fund is a sub-fund within a larger umbrella arrangement. Null if the fund is standalone.' ;
    rdfs:domain ind:Fund ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fund .

ind:administratorId rdf:type rdf:Property ;
    rdfs:label 'Administrator Id' ;
    rdfs:comment 'Unique identifier for the third-party administrator responsible for fund accounting, NAV calculation, and investor servicing.' ;
    rdfs:domain ind:Fund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assetClass rdf:type rdf:Property ;
    rdfs:label 'Asset Class' ;
    rdfs:comment 'The primary asset class in which the fund invests: equity, fixed income, money market, multi-asset, alternative investments, or real estate.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benchmarkIndex rdf:type rdf:Property ;
    rdfs:label 'Benchmark Index' ;
    rdfs:comment 'The name of the market index or composite benchmark against which the fund\'s performance is measured.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cusip rdf:type rdf:Property ;
    rdfs:label 'Cusip' ;
    rdfs:comment 'Nine-character alphanumeric code identifying North American securities.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealingFrequency rdf:type rdf:Property ;
    rdfs:label 'Dealing Frequency' ;
    rdfs:comment 'The frequency at which investors can subscribe to or redeem shares from the fund: daily, weekly, monthly, or quarterly.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionPolicy rdf:type rdf:Property ;
    rdfs:label 'Distribution Policy' ;
    rdfs:comment 'The fund\'s policy regarding income and capital gains: accumulating (reinvested), distributing (paid out to investors), or mixed.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYearEnd rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year End' ;
    rdfs:comment 'The month and day (MM-DD format) marking the end of the fund\'s fiscal year for accounting and regulatory reporting purposes.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundName rdf:type rdf:Property ;
    rdfs:label 'Fund Name' ;
    rdfs:comment 'The full legal name of the investment fund as registered with regulatory authorities.' ;
    rdfs:domain ind:Fund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundStatus rdf:type rdf:Property ;
    rdfs:label 'Fund Status' ;
    rdfs:comment 'The current operational status of the fund: active (accepting subscriptions), soft-closed (limited new subscriptions), hard-closed (no new subscriptions), liquidating (winding down), terminated (closed), or suspended (temporarily halted).' ;
    rdfs:domain ind:Fund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundType rdf:type rdf:Property ;
    rdfs:label 'Fund Type' ;
    rdfs:comment 'The primary classification of the fund structure: mutual fund, exchange-traded fund (ETF), hedge fund, pension fund, UCITS (Undertakings for Collective Investment in Transferable Securities), or SICAV (Société d\'Investissement à Capital Variable).' ;
    rdfs:domain ind:Fund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inceptionDate rdf:type rdf:Property ;
    rdfs:label 'Inception Date' ;
    rdfs:comment 'The date on which the fund was legally established and began operations.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:investmentObjective rdf:type rdf:Property ;
    rdfs:label 'Investment Objective' ;
    rdfs:comment 'A detailed description of the fund\'s investment goals, strategy, and target outcomes as disclosed in the prospectus.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investmentStrategy rdf:type rdf:Property ;
    rdfs:label 'Investment Strategy' ;
    rdfs:comment 'The primary investment strategy employed by the fund: growth, value, income, balanced, index-tracking, quantitative, or alternative strategies. [ENUM-REF-CANDIDATE: growth|value|income|balanced|index|quantitative|alternative — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isin rdf:type rdf:Property ;
    rdfs:label 'Isin' ;
    rdfs:comment 'The globally unique 12-character alphanumeric code identifying the fund as a security.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:launchDate rdf:type rdf:Property ;
    rdfs:label 'Launch Date' ;
    rdfs:comment 'The date on which the fund was first made available for investor subscriptions.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalStructure rdf:type rdf:Property ;
    rdfs:label 'Legal Structure' ;
    rdfs:comment 'The legal structure of the fund: open-ended (continuous issuance/redemption), closed-ended (fixed shares), unit trust, investment trust, or limited partnership.' ;
    rdfs:domain ind:Fund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leiCode rdf:type rdf:Property ;
    rdfs:label 'Lei Code' ;
    rdfs:comment 'The 20-character alphanumeric Legal Entity Identifier (LEI) uniquely identifying the fund as a legal entity for regulatory reporting.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managementFeeRate rdf:type rdf:Property ;
    rdfs:label 'Management Fee Rate' ;
    rdfs:comment 'The annual management fee charged by the fund manager, expressed as a decimal percentage of Assets Under Management (AUM). For example, 0.0075 represents 0.75%.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumInvestment rdf:type rdf:Property ;
    rdfs:label 'Minimum Investment' ;
    rdfs:comment 'The minimum amount required for an initial investment in the fund, expressed in the base currency.' ;
    rdfs:domain ind:Fund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumSubsequentInvestment rdf:type rdf:Property ;
    rdfs:label 'Minimum Subsequent Investment' ;
    rdfs:comment 'The minimum amount required for subsequent investments after the initial subscription, expressed in the base currency.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:navFrequency rdf:type rdf:Property ;
    rdfs:label 'Nav Frequency' ;
    rdfs:comment 'The frequency at which the fund\'s Net Asset Value (NAV) is calculated and published: daily, weekly, monthly, quarterly, or annually.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceFeeRate rdf:type rdf:Property ;
    rdfs:label 'Performance Fee Rate' ;
    rdfs:comment 'The performance or incentive fee charged based on fund returns exceeding a specified hurdle rate, expressed as a decimal percentage. For example, 0.2000 represents 20%.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prospectusDate rdf:type rdf:Property ;
    rdfs:label 'Prospectus Date' ;
    rdfs:comment 'The effective date of the current fund prospectus or offering document.' ;
    rdfs:domain ind:Fund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:redemptionNoticePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Redemption Notice Period Days' ;
    rdfs:comment 'The number of days advance notice required by investors to redeem shares from the fund.' ;
    rdfs:domain ind:Fund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sedol rdf:type rdf:Property ;
    rdfs:label 'Sedol' ;
    rdfs:comment 'Seven-character alphanumeric code identifying securities traded in the United Kingdom and Ireland.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Settlement Period Days' ;
    rdfs:comment 'The number of days after a subscription or redemption transaction date (T) by which settlement must occur (e.g., T+3).' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shortName rdf:type rdf:Property ;
    rdfs:label 'Short Name' ;
    rdfs:comment 'Abbreviated or marketing name of the fund used for display and reporting purposes.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetAum rdf:type rdf:Property ;
    rdfs:label 'Target Aum' ;
    rdfs:comment 'The target or maximum Assets Under Management (AUM) amount the fund aims to reach or maintain, expressed in the base currency.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalExpenseRatio rdf:type rdf:Property ;
    rdfs:label 'Total Expense Ratio' ;
    rdfs:comment 'The total annual operating expenses of the fund expressed as a percentage of average net assets, including management fees, administrative costs, and other operational expenses.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fundAdministratorId rdf:type rdf:Property ;
    rdfs:label 'Fund Administrator Id' ;
    rdfs:comment 'Unique identifier for the fund administrator service provider relationship. Primary key for the fund administrator entity.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FundAdministrator .

ind:administratorRelationshipManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Administrator Relationship Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to hr.employee. Business justification: Fund administrator relationships require dedicated bank employee oversight for SLA monitoring, regulatory compliance, escalation management, and contract renewal. Banking operations assign relationshi' ;
    rdfs:domain ind:FundAdministrator ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:bicDirectoryId rdf:type rdf:Property ;
    rdfs:label 'Bic Directory Id' ;
    rdfs:comment 'Foreign key linking to reference.bic_directory. Business justification: Administrator BIC for payment instructions, SWIFT messaging, and cash management. Critical for subscription/redemption settlement and expense payments.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BicDirectory .

ind:businessCountryId rdf:type rdf:Property ;
    rdfs:label 'Business Country Id' ;
    rdfs:comment 'Foreign key linking to reference.country. Business justification: Administrator domicile affects regulatory oversight, service provider due diligence, and operational risk assessment. Required for vendor management and audit.' ;
    rdfs:domain ind:FundAdministrator ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:leiRegistryId rdf:type rdf:Property ;
    rdfs:label 'Lei Registry Id' ;
    rdfs:comment 'Foreign key linking to reference.lei_registry. Business justification: Administrator LEI for regulatory reporting (SFTR, MiFID II), service provider identification, and legal entity verification. Regulatory mandate for counterparty identification.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LeiRegistry .

ind:administratorName rdf:type rdf:Property ;
    rdfs:label 'Administrator Name' ;
    rdfs:comment 'The full legal name of the fund administration service provider organization.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:administratorType rdf:type rdf:Property ;
    rdfs:label 'Administrator Type' ;
    rdfs:comment 'Classification of the service provider role in the fund\'s operational infrastructure.' ;
    rdfs:domain ind:FundAdministrator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Fee Amount' ;
    rdfs:comment 'The annual base fee charged by the administrator for fund administration services.' ;
    rdfs:domain ind:FundAdministrator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditOpinion rdf:type rdf:Property ;
    rdfs:label 'Audit Opinion' ;
    rdfs:comment 'The opinion issued in the most recent operational audit report of the administrator.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aumFeeBasisPoints rdf:type rdf:Property ;
    rdfs:label 'Aum Fee Basis Points' ;
    rdfs:comment 'The fee rate expressed in basis points charged as a percentage of fund assets under management.' ;
    rdfs:domain ind:FundAdministrator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:businessAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Business Address Line1' ;
    rdfs:comment 'The first line of the administrator\'s primary business address.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Business Address Line2' ;
    rdfs:comment 'The second line of the administrator\'s primary business address (suite, floor, building).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessCity rdf:type rdf:Property ;
    rdfs:label 'Business City' ;
    rdfs:comment 'The city where the administrator\'s primary business office is located.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessPostalCode rdf:type rdf:Property ;
    rdfs:label 'Business Postal Code' ;
    rdfs:comment 'The postal or ZIP code of the administrator\'s primary business address.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessStateProvince rdf:type rdf:Property ;
    rdfs:label 'Business State Province' ;
    rdfs:comment 'The state or province where the administrator\'s primary business office is located.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractEndDate rdf:type rdf:Property ;
    rdfs:label 'Contract End Date' ;
    rdfs:comment 'The date when the fund administration service contract expires or terminates. Null for open-ended contracts.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractStartDate rdf:type rdf:Property ;
    rdfs:label 'Contract Start Date' ;
    rdfs:comment 'The date when the fund administration service contract becomes effective.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractStatus rdf:type rdf:Property ;
    rdfs:label 'Contract Status' ;
    rdfs:comment 'Current lifecycle status of the fund administration service contract.' ;
    rdfs:domain ind:FundAdministrator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationContactEmail rdf:type rdf:Property ;
    rdfs:label 'Escalation Contact Email' ;
    rdfs:comment 'The email address of the escalation contact person at the administrator.' ;
    rdfs:domain ind:FundAdministrator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationContactName rdf:type rdf:Property ;
    rdfs:label 'Escalation Contact Name' ;
    rdfs:comment 'The name of the senior contact person at the administrator for escalation of critical issues or service failures.' ;
    rdfs:domain ind:FundAdministrator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Fee Calculation Method' ;
    rdfs:comment 'Description of how administrator fees are calculated (e.g., percentage of AUM, fixed annual fee, per-transaction pricing, tiered structure).' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Fee Currency Code' ;
    rdfs:comment 'The currency in which administrator fees are denominated and paid, using ISO 4217 three-letter currency code.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceCoverageAmount rdf:type rdf:Property ;
    rdfs:label 'Insurance Coverage Amount' ;
    rdfs:comment 'The amount of professional indemnity or errors and omissions insurance coverage maintained by the administrator.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Insurance Currency Code' ;
    rdfs:comment 'The currency in which the administrator\'s insurance coverage is denominated, using ISO 4217 three-letter currency code.' ;
    rdfs:domain ind:FundAdministrator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdiction rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction' ;
    rdfs:comment 'The primary legal jurisdiction where the administrator is domiciled and regulated, using ISO 3166-1 alpha-3 country code.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAuditDate rdf:type rdf:Property ;
    rdfs:label 'Last Audit Date' ;
    rdfs:comment 'The date of the most recent SOC 1 Type II or equivalent operational audit of the administrator\'s controls and processes.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastPerformanceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Performance Review Date' ;
    rdfs:comment 'The date of the most recent formal performance review of the administrator\'s service delivery.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:navCalculationDeadlineTime rdf:type rdf:Property ;
    rdfs:label 'Nav Calculation Deadline Time' ;
    rdfs:comment 'The contractual time by which the administrator must complete daily NAV calculation and reporting.' ;
    rdfs:domain ind:FundAdministrator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:paymentFrequency rdf:type rdf:Property ;
    rdfs:label 'Payment Frequency' ;
    rdfs:comment 'The frequency at which administrator fees are invoiced and paid.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceRating rdf:type rdf:Property ;
    rdfs:label 'Performance Rating' ;
    rdfs:comment 'Internal performance rating of the administrator based on service quality, timeliness, accuracy, and responsiveness.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Email' ;
    rdfs:comment 'The email address of the primary contact person at the administrator for operational communications.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactName rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Name' ;
    rdfs:comment 'The full name of the primary relationship manager or contact person at the administrator for operational matters.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Phone' ;
    rdfs:comment 'The telephone number of the primary contact person at the administrator for urgent operational matters.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAuthority rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority' ;
    rdfs:comment 'The name of the regulatory body that oversees and licenses the fund administrator (e.g., SEC, FCA, FINMA, MAS).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAuthorizationNumber rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authorization Number' ;
    rdfs:comment 'The license or registration number issued by the relevant regulatory authority authorizing the administrator to provide fund services.' ;
    rdfs:domain ind:FundAdministrator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceScope rdf:type rdf:Property ;
    rdfs:label 'Service Scope' ;
    rdfs:comment 'Detailed description of the services provided by the administrator, including NAV calculation, fund accounting, investor servicing, regulatory reporting, and other operational functions.' ;
    rdfs:domain ind:FundAdministrator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTerms rdf:type rdf:Property ;
    rdfs:label 'Sla Terms' ;
    rdfs:comment 'Detailed service level agreement terms including NAV calculation deadlines, reporting timelines, error resolution commitments, and performance guarantees.' ;
    rdfs:domain ind:FundAdministrator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:socReportType rdf:type rdf:Property ;
    rdfs:label 'Soc Report Type' ;
    rdfs:comment 'The type of service organization control report provided by the administrator to evidence operational controls.' ;
    rdfs:domain ind:FundAdministrator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Termination Notice Days' ;
    rdfs:comment 'The number of days advance notice required by either party to terminate the fund administration service contract.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fundAuditId rdf:type rdf:Property ;
    rdfs:label 'Fund Audit Id' ;
    rdfs:comment 'Unique identifier for the fund audit engagement record. Primary key for the fund audit entity.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FundAudit .

ind:auditFeeCurrencyId rdf:type rdf:Property ;
    rdfs:label 'Audit Fee Currency Id' ;
    rdfs:comment 'Foreign key linking to reference.currency. Business justification: Audit fee currency for expense accounting, vendor payment, and TER calculation. Required for multi-currency audit engagement management.' ;
    rdfs:domain ind:FundAudit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:auditLiaisonEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Audit Liaison Employee Id' ;
    rdfs:comment 'Foreign key linking to hr.employee. Business justification: Fund audits require internal bank employee coordination for audit committee reporting, regulatory filing oversight, management letter response, and remediation tracking. Controllers or compliance offi' ;
    rdfs:domain ind:FundAudit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:auditCommitteeApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Audit Committee Approval Date' ;
    rdfs:comment 'Date when the fund\'s audit committee reviewed and approved the audit report and financial statements.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditDocumentationRetentionDate rdf:type rdf:Property ;
    rdfs:label 'Audit Documentation Retention Date' ;
    rdfs:comment 'Date through which audit documentation and working papers must be retained per regulatory requirements (typically 7 years from report date).' ;
    rdfs:domain ind:FundAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditEngagementNumber rdf:type rdf:Property ;
    rdfs:label 'Audit Engagement Number' ;
    rdfs:comment 'External reference number assigned by the audit firm to this engagement. Used for tracking and correspondence with the auditor.' ;
    rdfs:domain ind:FundAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Audit Fee Amount' ;
    rdfs:comment 'Total fee charged by the audit firm for the engagement, including all professional services rendered.' ;
    rdfs:domain ind:FundAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditFirmName rdf:type rdf:Property ;
    rdfs:label 'Audit Firm Name' ;
    rdfs:comment 'Name of the external audit firm conducting the fund audit. Must be a registered public accounting firm.' ;
    rdfs:domain ind:FundAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditFirmRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Audit Firm Registration Number' ;
    rdfs:comment 'Registration or license number of the audit firm with the relevant regulatory authority (e.g., PCAOB registration number).' ;
    rdfs:domain ind:FundAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditOpinionType rdf:type rdf:Property ;
    rdfs:label 'Audit Opinion Type' ;
    rdfs:comment 'The type of opinion issued by the auditor. Unqualified (clean) opinion indicates financial statements are fairly presented; qualified opinion indicates exceptions; adverse opinion indicates material misstatements; disclaimer indicates inability to form an opinion.' ;
    rdfs:domain ind:FundAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Audit Period End Date' ;
    rdfs:comment 'The ending date of the period covered by this audit engagement.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Audit Period Start Date' ;
    rdfs:comment 'The beginning date of the period covered by this audit engagement.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditReportDate rdf:type rdf:Property ;
    rdfs:label 'Audit Report Date' ;
    rdfs:comment 'Date when the auditor\'s report was signed and issued. This is the date through which the auditor has responsibility for subsequent events.' ;
    rdfs:domain ind:FundAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditScope rdf:type rdf:Property ;
    rdfs:label 'Audit Scope' ;
    rdfs:comment 'Description of the scope and boundaries of the audit engagement, including what financial statements, periods, and areas are covered.' ;
    rdfs:domain ind:FundAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditStatus rdf:type rdf:Property ;
    rdfs:label 'Audit Status' ;
    rdfs:comment 'Current status of the audit engagement in its lifecycle. Tracks progression from planning through final filing.' ;
    rdfs:domain ind:FundAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditType rdf:type rdf:Property ;
    rdfs:label 'Audit Type' ;
    rdfs:comment 'Classification of the audit engagement. Annual statutory audits are required by regulation; interim reviews provide limited assurance; special purpose audits address specific matters; agreed-upon procedures perform specific tests; compliance audits verify regulatory adherence.' ;
    rdfs:domain ind:FundAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boardApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Board Approval Date' ;
    rdfs:comment 'Date when the fund\'s board of directors formally approved the audited financial statements for publication and filing.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:engagementPartnerLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Engagement Partner License Number' ;
    rdfs:comment 'Professional license or certification number of the engagement partner (e.g., CPA license number).' ;
    rdfs:domain ind:FundAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementPartnerName rdf:type rdf:Property ;
    rdfs:label 'Engagement Partner Name' ;
    rdfs:comment 'Name of the lead audit partner responsible for the engagement. The partner signs the audit opinion.' ;
    rdfs:domain ind:FundAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fieldworkCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Fieldwork Completion Date' ;
    rdfs:comment 'Date when the audit fieldwork and testing procedures were completed.' ;
    rdfs:domain ind:FundAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fieldworkStartDate rdf:type rdf:Property ;
    rdfs:label 'Fieldwork Start Date' ;
    rdfs:comment 'Date when the audit fieldwork and testing procedures commenced.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fiscalYearEndDate rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year End Date' ;
    rdfs:comment 'The fiscal year end date for which this audit is being conducted. Typically aligns with the fund\'s fiscal year end.' ;
    rdfs:domain ind:FundAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:goingConcernFlag rdf:type rdf:Property ;
    rdfs:label 'Going Concern Flag' ;
    rdfs:comment 'Indicates whether the auditor identified substantial doubt about the fund\'s ability to continue as a going concern.' ;
    rdfs:domain ind:FundAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:keyAuditMatters rdf:type rdf:Property ;
    rdfs:label 'Key Audit Matters' ;
    rdfs:comment 'Description of the key audit matters identified during the engagement. These are matters that required significant auditor attention and judgment.' ;
    rdfs:domain ind:FundAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managementLetterIssuedFlag rdf:type rdf:Property ;
    rdfs:label 'Management Letter Issued Flag' ;
    rdfs:comment 'Indicates whether the auditor issued a management letter with recommendations for operational improvements or control enhancements.' ;
    rdfs:domain ind:FundAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:managementLetterPoints rdf:type rdf:Property ;
    rdfs:label 'Management Letter Points' ;
    rdfs:comment 'Summary of key points and recommendations included in the management letter, covering operational improvements, control enhancements, and best practice suggestions.' ;
    rdfs:domain ind:FundAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialWeaknessDescription rdf:type rdf:Property ;
    rdfs:label 'Material Weakness Description' ;
    rdfs:comment 'Detailed description of any material weaknesses identified in internal controls, including the nature and potential impact.' ;
    rdfs:domain ind:FundAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialWeaknessIdentifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Material Weakness Identified Flag' ;
    rdfs:comment 'Indicates whether the auditor identified any material weaknesses in internal controls over financial reporting.' ;
    rdfs:domain ind:FundAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:opinionBasis rdf:type rdf:Property ;
    rdfs:label 'Opinion Basis' ;
    rdfs:comment 'Detailed explanation of the basis for the auditor\'s opinion, including any qualifications, limitations, or emphasis of matter paragraphs.' ;
    rdfs:domain ind:FundAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryFilingDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Date' ;
    rdfs:comment 'Date when the audited financial statements and audit report were filed with the regulatory authority.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryFilingDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Deadline Date' ;
    rdfs:comment 'Regulatory deadline by which the audited financial statements must be filed to maintain compliance.' ;
    rdfs:domain ind:FundAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryFilingFormType rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Form Type' ;
    rdfs:comment 'Type of regulatory form used for filing the audit report (e.g., Form N-CSR for certified shareholder reports, Form 10-K for annual reports).' ;
    rdfs:domain ind:FundAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryFilingReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Reference Number' ;
    rdfs:comment 'Reference or accession number assigned by the regulatory authority upon successful filing (e.g., SEC accession number).' ;
    rdfs:domain ind:FundAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryFilingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Required Flag' ;
    rdfs:comment 'Indicates whether the audit report must be filed with regulatory authorities such as the Securities and Exchange Commission (SEC).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:restatementDescription rdf:type rdf:Property ;
    rdfs:label 'Restatement Description' ;
    rdfs:comment 'Description of the nature and impact of any financial statement restatements required as a result of the audit findings.' ;
    rdfs:domain ind:FundAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restatementRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Restatement Required Flag' ;
    rdfs:comment 'Indicates whether the audit identified errors requiring restatement of previously issued financial statements.' ;
    rdfs:domain ind:FundAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:significantDeficiencyCount rdf:type rdf:Property ;
    rdfs:label 'Significant Deficiency Count' ;
    rdfs:comment 'Number of significant deficiencies in internal controls identified during the audit that are less severe than material weaknesses but still warrant attention.' ;
    rdfs:domain ind:FundAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subsequentEventsReviewDate rdf:type rdf:Property ;
    rdfs:label 'Subsequent Events Review Date' ;
    rdfs:comment 'Date through which the auditor reviewed subsequent events that may require adjustment or disclosure in the financial statements.' ;
    rdfs:domain ind:FundAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fundBenchmarkId rdf:type rdf:Property ;
    rdfs:label 'Fund Benchmark Id' ;
    rdfs:comment 'Unique identifier for the fund benchmark association record.' ;
    rdfs:domain ind:FundBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:benchmarkId rdf:type rdf:Property ;
    rdfs:label 'Benchmark Id' ;
    rdfs:comment 'Foreign key linking to security.benchmark. Business justification: Fund benchmarks must reference the master benchmark definition for return calculation, performance attribution, and hurdle rate determination. Direct lookup relationship required for accurate performa' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Benchmark .

ind:supersededByBenchmarkFundBenchmarkId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Benchmark Fund Benchmark Id' ;
    rdfs:comment 'Reference to the fund_benchmark_id that replaces this benchmark assignment. Populated when benchmark_status is superseded. Enables tracking of benchmark change history.' ;
    rdfs:domain ind:FundBenchmark ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FundBenchmark .

ind:assignmentReason rdf:type rdf:Property ;
    rdfs:label 'Assignment Reason' ;
    rdfs:comment 'Business rationale for assigning this benchmark to the fund or fund class (e.g., investment strategy alignment, investor request, regulatory requirement, board decision, benchmark change due to index discontinuation).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benchmarkCurrency rdf:type rdf:Property ;
    rdfs:label 'Benchmark Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code in which the benchmark is denominated (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:FundBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benchmarkMethodologyDescription rdf:type rdf:Property ;
    rdfs:label 'Benchmark Methodology Description' ;
    rdfs:comment 'Brief description of the benchmark construction methodology, including weighting scheme (market-cap weighted, equal-weighted, factor-based), rebalancing frequency, and constituent selection criteria.' ;
    rdfs:domain ind:FundBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benchmarkProvider rdf:type rdf:Property ;
    rdfs:label 'Benchmark Provider' ;
    rdfs:comment 'Name of the organization that publishes and maintains the benchmark index (e.g., S&P Dow Jones Indices, MSCI Inc., FTSE Russell, Bloomberg).' ;
    rdfs:domain ind:FundBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benchmarkStatus rdf:type rdf:Property ;
    rdfs:label 'Benchmark Status' ;
    rdfs:comment 'Current lifecycle status of the benchmark assignment: active (currently in use), inactive (temporarily suspended), pending (approved but not yet effective), superseded (replaced by a newer benchmark), or discontinued (permanently retired).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benchmarkType rdf:type rdf:Property ;
    rdfs:label 'Benchmark Type' ;
    rdfs:comment 'Classification of the benchmark role: primary (main performance comparison), secondary (supplemental comparison), absolute return hurdle (minimum return threshold for performance fees), composite (blended benchmark), custom (client-specific), or peer group (universe comparison).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSource rdf:type rdf:Property ;
    rdfs:label 'Data Source' ;
    rdfs:comment 'System or vendor from which benchmark return data is sourced (e.g., Bloomberg, FactSet, MSCI Direct, internal calculation). Critical for data lineage and reconciliation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:highWaterMarkFlag rdf:type rdf:Property ;
    rdfs:label 'High Water Mark Flag' ;
    rdfs:comment 'Indicates whether performance fees are subject to a high water mark provision, meaning fees are only charged on net new profits above the highest previous Net Asset Value (NAV). Applicable when performance_fee_applicable_flag is true.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hurdleRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Hurdle Rate Percentage' ;
    rdfs:comment 'Minimum return threshold (expressed as annualized percentage) that the fund must exceed before performance fees are charged. Applicable only when benchmark_type is absolute_return_hurdle. Null for market index benchmarks.' ;
    rdfs:domain ind:FundBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Review Date' ;
    rdfs:comment 'Date of the most recent periodic review of the benchmark appropriateness by the investment committee or board. Regulatory best practice requires annual benchmark reviews.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Review Date' ;
    rdfs:comment 'Scheduled date for the next periodic review of benchmark appropriateness. Typically annual or as specified in fund governance policies.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:performanceFeeApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Performance Fee Applicable Flag' ;
    rdfs:comment 'Indicates whether this benchmark is used to calculate performance-based fees (incentive fees, carried interest). True if the fund charges performance fees based on outperformance versus this benchmark.' ;
    rdfs:domain ind:FundBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:prospectusDisclosureFlag rdf:type rdf:Property ;
    rdfs:label 'Prospectus Disclosure Flag' ;
    rdfs:comment 'Indicates whether this benchmark is disclosed in the fund prospectus or offering documents as the primary or supplemental performance comparison index.' ;
    rdfs:domain ind:FundBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rebalancingFrequency rdf:type rdf:Property ;
    rdfs:label 'Rebalancing Frequency' ;
    rdfs:comment 'Frequency at which the benchmark index is reconstituted or rebalanced (e.g., quarterly for most equity indices, monthly for some bond indices).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Required Flag' ;
    rdfs:comment 'Indicates whether performance relative to this benchmark must be reported to regulatory authorities (e.g., SEC Form N-PORT, UCITS KIID).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:returnCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Return Calculation Method' ;
    rdfs:comment 'Method by which benchmark returns are calculated: total return (includes dividends reinvested), price return (capital appreciation only), net return (after withholding taxes), or gross return (before taxes).' ;
    rdfs:domain ind:FundBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trackingErrorToleranceBps rdf:type rdf:Property ;
    rdfs:label 'Tracking Error Tolerance Bps' ;
    rdfs:comment 'Maximum acceptable tracking error (standard deviation of the difference between fund returns and benchmark returns) expressed in basis points. Used for index funds and passive strategies to monitor replication quality.' ;
    rdfs:domain ind:FundBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:usageContext rdf:type rdf:Property ;
    rdfs:label 'Usage Context' ;
    rdfs:comment 'Primary purpose for which this benchmark is used: performance fee calculation (determines incentive fees), IPS mandate (Investment Policy Statement compliance), investor reporting (client communications), regulatory filing (Form N-1A, UCITS KIID), marketing material (prospectus, factsheets), or risk attribution (portfolio analytics).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightingPercentage rdf:type rdf:Property ;
    rdfs:label 'Weighting Percentage' ;
    rdfs:comment 'Percentage weight of this benchmark in a composite or blended benchmark structure. For single benchmarks, this is 100.00. For composite benchmarks, the sum of all benchmark weights for a given fund/class should equal 100.00.' ;
    rdfs:domain ind:FundBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:domicileCountryId rdf:type rdf:Property ;
    rdfs:label 'Domicile Country Id' ;
    rdfs:comment 'Foreign key linking to reference.country. Business justification: Share class domicile may differ from umbrella fund (e.g., Irish umbrella with Luxembourg share class). Determines tax treatment, withholding obligations, and regulatory reporting requirements.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:bloombergTicker rdf:type rdf:Property ;
    rdfs:label 'Bloomberg Ticker' ;
    rdfs:comment 'Bloomberg-assigned ticker symbol for the fund class. Used for market data retrieval, pricing, and analytics on Bloomberg Terminal.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classCode rdf:type rdf:Property ;
    rdfs:label 'Class Code' ;
    rdfs:comment 'Short alphanumeric code identifying the share class within the fund (e.g., A, B, I, R, Institutional). Used for internal classification and operational processing.' ;
    rdfs:domain ind:FundClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:className rdf:type rdf:Property ;
    rdfs:label 'Class Name' ;
    rdfs:comment 'Full descriptive name of the share class (e.g., Institutional Class, Retail Class A, Hedged EUR Class). Human-readable identifier used in client reporting and marketing materials.' ;
    rdfs:domain ind:FundClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Data Source System' ;
    rdfs:comment 'Name of the upstream operational system from which this fund class record originated (e.g., SimCorp Dimension, BlackRock Aladdin, proprietary fund accounting system). Used for data lineage and reconciliation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealingCutoffTime rdf:type rdf:Property ;
    rdfs:label 'Dealing Cutoff Time' ;
    rdfs:comment 'Time of day (HH:MM format) by which subscription and redemption orders must be received to be processed at the next available NAV. Orders received after this time are processed at the subsequent NAV.' ;
    rdfs:domain ind:FundClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:entryLoadRate rdf:type rdf:Property ;
    rdfs:label 'Entry Load Rate' ;
    rdfs:comment 'Front-end sales charge or entry fee applied when an investor subscribes to the fund class, expressed as a decimal percentage of the subscription amount. May be waived for institutional investors.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exitLoadRate rdf:type rdf:Property ;
    rdfs:label 'Exit Load Rate' ;
    rdfs:comment 'Back-end sales charge or exit fee applied when an investor redeems shares from the fund class, expressed as a decimal percentage of the redemption amount. Often used to discourage short-term trading.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fundClassStatus rdf:type rdf:Property ;
    rdfs:label 'Fund Class Status' ;
    rdfs:comment 'Current operational status of the fund class. Active classes accept subscriptions and redemptions; suspended classes are temporarily closed; closed classes no longer accept new investors; liquidated classes have been wound down.' ;
    rdfs:domain ind:FundClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hedgedFlag rdf:type rdf:Property ;
    rdfs:label 'Hedged Flag' ;
    rdfs:comment 'Indicates whether the fund class employs currency hedging to mitigate foreign exchange risk for investors. True if hedged, False if unhedged.' ;
    rdfs:domain ind:FundClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:investorEligibility rdf:type rdf:Property ;
    rdfs:label 'Investor Eligibility' ;
    rdfs:comment 'Classification of investor types eligible to invest in this share class. Determines minimum investment thresholds, fee structures, and regulatory treatment.' ;
    rdfs:domain ind:FundClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kiidUrl rdf:type rdf:Property ;
    rdfs:label 'Kiid Url' ;
    rdfs:comment 'Web address (URL) where the Key Investor Information Document (KIID) or Key Information Document (KID) can be accessed. Mandatory pre-contractual disclosure document for UCITS and PRIIPs.' ;
    rdfs:domain ind:FundClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumInitialInvestment rdf:type rdf:Property ;
    rdfs:label 'Minimum Initial Investment' ;
    rdfs:comment 'Minimum amount required for an investor to make an initial subscription into the fund class, expressed in the class currency. Used to enforce eligibility and operational thresholds.' ;
    rdfs:domain ind:FundClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ongoingChargesFigure rdf:type rdf:Property ;
    rdfs:label 'Ongoing Charges Figure' ;
    rdfs:comment 'Annual charges taken from the fund class excluding transaction costs and performance fees, expressed as a decimal percentage of AUM. Required disclosure metric under UCITS regulations.' ;
    rdfs:domain ind:FundClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prospectusUrl rdf:type rdf:Property ;
    rdfs:label 'Prospectus Url' ;
    rdfs:comment 'Web address (URL) where the current prospectus or offering document for the fund class can be accessed. Required for investor disclosure and regulatory compliance.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sfdrClassification rdf:type rdf:Property ;
    rdfs:label 'Sfdr Classification' ;
    rdfs:comment 'Classification under EU SFDR indicating the fund class sustainability profile. Article 8 funds promote environmental or social characteristics; Article 9 funds have sustainable investment as their objective; Article 6 funds do not integrate sustainability.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundDistributionChannelId rdf:type rdf:Property ;
    rdfs:label 'Fund Distribution Channel Id' ;
    rdfs:comment 'Unique identifier for the fund distribution channel relationship record. Primary key for this entity.' ;
    rdfs:domain ind:FundDistributionChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:distributorPartyId rdf:type rdf:Property ;
    rdfs:label 'Distributor Party Id' ;
    rdfs:comment 'Foreign key linking to customer.party. Business justification: Distributors are legal entities (parties) requiring KYC/AML screening, regulatory approval tracking, commission payment processing, and relationship management. Links distribution agreements to corpor' ;
    rdfs:domain ind:FundDistributionChannel ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:relationshipManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Relationship Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to hr.employee. Business justification: Distribution channels require dedicated relationship managers (bank employees) for sales target monitoring, commission reconciliation, regulatory compliance oversight, and distributor performance mana' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:agreementEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Agreement Effective Date' ;
    rdfs:comment 'The date when the distribution agreement becomes legally effective and the distributor is authorized to sell fund units.' ;
    rdfs:domain ind:FundDistributionChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:agreementExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Agreement Expiry Date' ;
    rdfs:comment 'The date when the distribution agreement expires or terminates. Null for open-ended agreements.' ;
    rdfs:domain ind:FundDistributionChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:amlResponsibility rdf:type rdf:Property ;
    rdfs:label 'Aml Responsibility' ;
    rdfs:comment 'Indicates which party is responsible for Anti-Money Laundering (AML) monitoring and compliance for transactions through this channel.' ;
    rdfs:domain ind:FundDistributionChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionAgreementReference rdf:type rdf:Property ;
    rdfs:label 'Distribution Agreement Reference' ;
    rdfs:comment 'Reference number or identifier for the legal distribution agreement governing this channel relationship.' ;
    rdfs:domain ind:FundDistributionChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributorIdentifier rdf:type rdf:Property ;
    rdfs:label 'Distributor Identifier' ;
    rdfs:comment 'Unique business identifier for the distributor, such as Legal Entity Identifier (LEI), FINRA CRD number, or internal distributor code.' ;
    rdfs:domain ind:FundDistributionChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributorType rdf:type rdf:Property ;
    rdfs:label 'Distributor Type' ;
    rdfs:comment 'Classification of the distributor channel type. IFA = Independent Financial Advisor, RIA = Registered Investment Advisor. [ENUM-REF-CANDIDATE: IFA|bank|platform|insurance_wrapper|direct|broker_dealer|RIA — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FundDistributionChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivityFlag rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Flag' ;
    rdfs:comment 'Indicates whether this distributor has exclusive distribution rights for the fund in the specified geographic scope or investor segment.' ;
    rdfs:domain ind:FundDistributionChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geographicScope rdf:type rdf:Property ;
    rdfs:label 'Geographic Scope' ;
    rdfs:comment 'The geographic regions or countries where this distributor is authorized to sell the fund. Comma-separated list of ISO 3166-1 alpha-3 country codes or regional descriptors.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investorSegmentServed rdf:type rdf:Property ;
    rdfs:label 'Investor Segment Served' ;
    rdfs:comment 'The target investor segment that this distribution channel serves. HNWI = High Net Worth Individual.' ;
    rdfs:domain ind:FundDistributionChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kycResponsibility rdf:type rdf:Property ;
    rdfs:label 'Kyc Responsibility' ;
    rdfs:comment 'Indicates which party is responsible for conducting Know Your Customer (KYC) due diligence on end investors in this distribution channel.' ;
    rdfs:domain ind:FundDistributionChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingSupportProvided rdf:type rdf:Property ;
    rdfs:label 'Marketing Support Provided' ;
    rdfs:comment 'The level of marketing and promotional support provided by the fund manager to this distribution channel.' ;
    rdfs:domain ind:FundDistributionChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumInvestmentAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Investment Amount' ;
    rdfs:comment 'The minimum initial investment amount required for subscriptions through this distribution channel, in the fund base currency.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:omnibusAccountFlag rdf:type rdf:Property ;
    rdfs:label 'Omnibus Account Flag' ;
    rdfs:comment 'Indicates whether this distributor uses an omnibus account structure where the distributor holds fund units on behalf of multiple underlying investors.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:platformCode rdf:type rdf:Property ;
    rdfs:label 'Platform Code' ;
    rdfs:comment 'The platform or system code used by the distributor for fund identification and transaction processing. May include multiple codes separated by semicolons.' ;
    rdfs:domain ind:FundDistributionChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Date' ;
    rdfs:comment 'The date when regulatory approval was granted for this distribution channel arrangement, if applicable.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryApprovalRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Required' ;
    rdfs:comment 'Indicates whether regulatory approval is required for this distribution arrangement in the applicable jurisdiction.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryFramework rdf:type rdf:Property ;
    rdfs:label 'Regulatory Framework' ;
    rdfs:comment 'The regulatory framework or jurisdiction governing this distribution arrangement, such as SEC, FCA, ESMA, or specific country regulators.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retrocessionArrangement rdf:type rdf:Property ;
    rdfs:label 'Retrocession Arrangement' ;
    rdfs:comment 'The type of retrocession or fee-sharing arrangement in place. Describes how distribution fees are paid back to the intermediary.' ;
    rdfs:domain ind:FundDistributionChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesVolumeTarget rdf:type rdf:Property ;
    rdfs:label 'Sales Volume Target' ;
    rdfs:comment 'The target sales volume or Assets Under Management (AUM) goal for this distribution channel, in the fund base currency.' ;
    rdfs:domain ind:FundDistributionChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:subAccountingAgreementFlag rdf:type rdf:Property ;
    rdfs:label 'Sub Accounting Agreement Flag' ;
    rdfs:comment 'Indicates whether a sub-accounting agreement is in place where the distributor maintains detailed investor records on behalf of the fund.' ;
    rdfs:domain ind:FundDistributionChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:terminationNoticePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Termination Notice Period Days' ;
    rdfs:comment 'The number of days advance notice required by either party to terminate the distribution agreement.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trailerFeeRate rdf:type rdf:Property ;
    rdfs:label 'Trailer Fee Rate' ;
    rdfs:comment 'The ongoing annual trailer fee or commission rate paid to the distributor, expressed as a percentage of Assets Under Management (AUM). Also known as 12b-1 fee in US context.' ;
    rdfs:domain ind:FundDistributionChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:upfrontCommissionRate rdf:type rdf:Property ;
    rdfs:label 'Upfront Commission Rate' ;
    rdfs:comment 'The initial sales commission rate paid to the distributor at the point of sale, expressed as a percentage of the subscription amount.' ;
    rdfs:domain ind:FundDistributionChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fundExpenseId rdf:type rdf:Property ;
    rdfs:label 'Fund Expense Id' ;
    rdfs:comment 'Unique identifier for the fund expense record. Primary key.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FundExpense .

ind:exchangeRateId rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate Id' ;
    rdfs:comment 'Foreign key linking to reference.exchange_rate. Business justification: FX rate for expense currency conversion to fund base currency. Required for accurate NAV calculation and audit trail.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ExchangeRate .

ind:originalExpenseFundExpenseId rdf:type rdf:Property ;
    rdfs:label 'Original Expense Fund Expense Id' ;
    rdfs:comment 'Reference to the original fund_expense_id if this record is a reversal or adjustment. Null for original entries.' ;
    rdfs:domain ind:FundExpense ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FundExpense .

ind:accrualBasis rdf:type rdf:Property ;
    rdfs:label 'Accrual Basis' ;
    rdfs:comment 'Frequency or method by which the expense is accrued for Net Asset Value (NAV) calculation purposes.' ;
    rdfs:domain ind:FundExpense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualizedRate rdf:type rdf:Property ;
    rdfs:label 'Annualized Rate' ;
    rdfs:comment 'Annualized percentage rate of the expense relative to fund assets, expressed as a decimal (e.g., 0.015 for 1.5%). Used for management fees and other recurring expenses.' ;
    rdfs:domain ind:FundExpense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Base Currency Amount' ;
    rdfs:comment 'Expense amount converted to the fund\'s base reporting currency for consolidated financial reporting.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calculationMethodology rdf:type rdf:Property ;
    rdfs:label 'Calculation Methodology' ;
    rdfs:comment 'Description of the method used to calculate the expense amount, including any formulas, tiered structures, or performance hurdles.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenter rdf:type rdf:Property ;
    rdfs:label 'Cost Center' ;
    rdfs:comment 'Cost center or business unit to which the expense is allocated for internal management reporting.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expenseAmount rdf:type rdf:Property ;
    rdfs:label 'Expense Amount' ;
    rdfs:comment 'Monetary value of the expense in the specified currency. Represents the total cost incurred.' ;
    rdfs:domain ind:FundExpense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expenseCategory rdf:type rdf:Property ;
    rdfs:label 'Expense Category' ;
    rdfs:comment 'High-level categorization of the expense for financial reporting and analysis purposes.' ;
    rdfs:domain ind:FundExpense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expenseDescription rdf:type rdf:Property ;
    rdfs:label 'Expense Description' ;
    rdfs:comment 'Detailed textual description of the expense, including the nature of services or goods provided.' ;
    rdfs:domain ind:FundExpense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expenseRatioContribution rdf:type rdf:Property ;
    rdfs:label 'Expense Ratio Contribution' ;
    rdfs:comment 'Contribution of this expense to the fund\'s overall expense ratio, expressed as a percentage of average net assets.' ;
    rdfs:domain ind:FundExpense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expenseReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Expense Reference Number' ;
    rdfs:comment 'External reference number or invoice number for the expense transaction.' ;
    rdfs:domain ind:FundExpense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expenseStatus rdf:type rdf:Property ;
    rdfs:label 'Expense Status' ;
    rdfs:comment 'Current lifecycle status of the expense record indicating its processing state.' ;
    rdfs:domain ind:FundExpense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expenseType rdf:type rdf:Property ;
    rdfs:label 'Expense Type' ;
    rdfs:comment 'Classification of the fund expense by type. Determines the nature of the cost incurred by the fund. [ENUM-REF-CANDIDATE: management_fee|performance_fee|administration_fee|custodian_fee|audit_fee|legal_fee|regulatory_filing_fee|transfer_agent_fee|distribution_fee|trustee_fee|compliance_fee|insurance_fee|other_operating_expense — 13 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FundExpense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceDate rdf:type rdf:Property ;
    rdfs:label 'Invoice Date' ;
    rdfs:comment 'Date on the invoice issued by the payee for this expense.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:invoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Invoice Number' ;
    rdfs:comment 'Invoice number provided by the payee for this expense. Used for accounts payable reconciliation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:navImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Nav Impact Amount' ;
    rdfs:comment 'The amount by which this expense reduces the fund\'s Net Asset Value (NAV). Used in daily NAV calculation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payeeIdentifier rdf:type rdf:Property ;
    rdfs:label 'Payee Identifier' ;
    rdfs:comment 'Unique identifier for the payee in the vendor or counterparty master system.' ;
    rdfs:domain ind:FundExpense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payeeName rdf:type rdf:Property ;
    rdfs:label 'Payee Name' ;
    rdfs:comment 'Name of the entity or individual to whom the expense is paid (e.g., fund administrator, custodian, auditor).' ;
    rdfs:domain ind:FundExpense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recoupmentEligibleIndicator rdf:type rdf:Property ;
    rdfs:label 'Recoupment Eligible Indicator' ;
    rdfs:comment 'Flag indicating whether the waived expense is eligible for future recoupment by the fund manager under the expense limitation agreement.' ;
    rdfs:domain ind:FundExpense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recoupmentExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Recoupment Expiration Date' ;
    rdfs:comment 'Date by which the fund manager must recoup the waived expense, after which the recoupment right expires.' ;
    rdfs:domain ind:FundExpense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryReportingCategory rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Category' ;
    rdfs:comment 'Category code used for regulatory reporting purposes (e.g., SEC Form N-1A, N-CSR expense classifications).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalIndicator rdf:type rdf:Property ;
    rdfs:label 'Reversal Indicator' ;
    rdfs:comment 'Flag indicating whether this expense record represents a reversal or correction of a previously recorded expense.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxDeductibleIndicator rdf:type rdf:Property ;
    rdfs:label 'Tax Deductible Indicator' ;
    rdfs:comment 'Flag indicating whether the expense is tax-deductible for the fund under applicable tax regulations.' ;
    rdfs:domain ind:FundExpense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waiverAmount rdf:type rdf:Property ;
    rdfs:label 'Waiver Amount' ;
    rdfs:comment 'Amount of the expense that was waived or reimbursed, reducing the net expense borne by the fund.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waiverIndicator rdf:type rdf:Property ;
    rdfs:label 'Waiver Indicator' ;
    rdfs:comment 'Flag indicating whether the expense was waived or reimbursed by the fund manager or sponsor.' ;
    rdfs:domain ind:FundExpense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fundFeeScheduleId rdf:type rdf:Property ;
    rdfs:label 'Fund Fee Schedule Id' ;
    rdfs:comment 'Unique identifier for the fund fee schedule record. Primary key for this entity.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FundFeeSchedule .

ind:feeCurrencyId rdf:type rdf:Property ;
    rdfs:label 'Fee Currency Id' ;
    rdfs:comment 'Foreign key linking to reference.currency. Business justification: Fee calculation currency for management fees, performance fees, and expense accruals. Required for multi-currency fee billing and TER calculation.' ;
    rdfs:domain ind:FundFeeSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:supersededByScheduleFundFeeScheduleId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Schedule Fund Fee Schedule Id' ;
    rdfs:comment 'Reference to the fee schedule that supersedes this one. Null if this is the current active schedule.' ;
    rdfs:domain ind:FundFeeSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FundFeeSchedule .

ind:crystallizationFrequency rdf:type rdf:Property ;
    rdfs:label 'Crystallization Frequency' ;
    rdfs:comment 'Frequency at which performance fees are calculated and locked in (crystallized). Determines when performance fee liability becomes payable.' ;
    rdfs:domain ind:FundFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryLoadType rdf:type rdf:Property ;
    rdfs:label 'Entry Load Type' ;
    rdfs:comment 'Structure of the entry load fee. Flat: single rate for all subscriptions. Tiered: rate varies by subscription amount. Waived: no entry load charged.' ;
    rdfs:domain ind:FundFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exitLoadHoldingPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Exit Load Holding Period Days' ;
    rdfs:comment 'Number of days an investor must hold the investment before the exit load is reduced or waived. Used to determine applicable exit load tier.' ;
    rdfs:domain ind:FundFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:feePaymentFrequency rdf:type rdf:Property ;
    rdfs:label 'Fee Payment Frequency' ;
    rdfs:comment 'Frequency at which accrued fees are paid to the fund manager or service provider.' ;
    rdfs:domain ind:FundFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeScheduleCode rdf:type rdf:Property ;
    rdfs:label 'Fee Schedule Code' ;
    rdfs:comment 'Business identifier code for this fee schedule, used for operational reference and reporting.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeScheduleName rdf:type rdf:Property ;
    rdfs:label 'Fee Schedule Name' ;
    rdfs:comment 'Descriptive name of the fee schedule, typically indicating the share class and fee structure type.' ;
    rdfs:domain ind:FundFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeScheduleStatus rdf:type rdf:Property ;
    rdfs:label 'Fee Schedule Status' ;
    rdfs:comment 'Current lifecycle status of the fee schedule indicating whether it is currently in use, pending activation, or has been superseded.' ;
    rdfs:domain ind:FundFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hurdleRate rdf:type rdf:Property ;
    rdfs:label 'Hurdle Rate' ;
    rdfs:comment 'Minimum rate of return that must be achieved before performance fees are charged. Expressed as an annual percentage rate.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hurdleType rdf:type rdf:Property ;
    rdfs:label 'Hurdle Type' ;
    rdfs:comment 'Type of hurdle rate application. Hard hurdle: performance fee applies only to returns above the hurdle. Soft hurdle: performance fee applies to all returns once hurdle is exceeded.' ;
    rdfs:domain ind:FundFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managementFeeBasis rdf:type rdf:Property ;
    rdfs:label 'Management Fee Basis' ;
    rdfs:comment 'The base amount on which the management fee is calculated, such as total Assets Under Management (AUM), Net Asset Value (NAV), committed capital, or invested capital.' ;
    rdfs:domain ind:FundFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prospectusReference rdf:type rdf:Property ;
    rdfs:label 'Prospectus Reference' ;
    rdfs:comment 'Reference to the section or page in the fund prospectus where this fee schedule is disclosed to investors.' ;
    rdfs:domain ind:FundFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recoupmentEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Recoupment Eligible Flag' ;
    rdfs:comment 'Indicates whether waived fees are eligible for recoupment (recovery) by the fund manager in future periods when expenses fall below the cap.' ;
    rdfs:domain ind:FundFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recoupmentPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Recoupment Period Months' ;
    rdfs:comment 'Number of months during which waived fees remain eligible for recoupment by the fund manager.' ;
    rdfs:domain ind:FundFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:redemptionFeeRate rdf:type rdf:Property ;
    rdfs:label 'Redemption Fee Rate' ;
    rdfs:comment 'Fee charged on redemptions to discourage short-term trading and protect long-term investors. Typically retained by the fund rather than paid to the manager. Expressed as a percentage of redemption amount.' ;
    rdfs:domain ind:FundFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:switchingFeeRate rdf:type rdf:Property ;
    rdfs:label 'Switching Fee Rate' ;
    rdfs:comment 'Fee charged when an investor switches between different funds or share classes within the same fund family. Expressed as a percentage of the switched amount.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:terCap rdf:type rdf:Property ;
    rdfs:label 'Ter Cap' ;
    rdfs:comment 'Maximum Total Expense Ratio (TER) that can be charged to investors, expressed as an annual percentage. Any expenses above this cap are absorbed by the fund manager.' ;
    rdfs:domain ind:FundFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waiverExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Waiver Expiry Date' ;
    rdfs:comment 'Date on which the fee waiver expires and full fees resume. Null if no waiver is in effect or waiver is indefinite.' ;
    rdfs:domain ind:FundFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fundHoldingId rdf:type rdf:Property ;
    rdfs:label 'Fund Holding Id' ;
    rdfs:comment 'Unique identifier for the fund holding record. Primary key for the fund holding entity.' ;
    rdfs:domain ind:FundHolding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:corporateActionId rdf:type rdf:Property ;
    rdfs:label 'Corporate Action Id' ;
    rdfs:comment 'Foreign key linking to security.corporate_action. Business justification: Holdings affected by corporate actions (dividends, splits, mergers) require direct linkage for entitlement calculation, position adjustment, and income accrual. Essential for accurate NAV and investor' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CorporateAction .

ind:counterpartyRatingId rdf:type rdf:Property ;
    rdfs:label 'Counterparty Rating Id' ;
    rdfs:comment 'Foreign key linking to risk.counterparty_rating. Business justification: Fund holdings of debt instruments require counterparty credit ratings for risk monitoring and regulatory reporting (UCITS 5/10/40 rules, AIFMD risk management). Real process: credit risk assessment of' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CounterpartyRating .

ind:countryId rdf:type rdf:Property ;
    rdfs:label 'Country Id' ;
    rdfs:comment 'Foreign key linking to reference.country. Business justification: Geographic risk exposure reporting for UCITS 5/10/40 rules, concentration limits, and country risk monitoring. Regulatory requirement for diversification compliance and risk management.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:creditExposureId rdf:type rdf:Property ;
    rdfs:label 'Credit Exposure Id' ;
    rdfs:comment 'Foreign key linking to risk.credit_exposure. Business justification: Fund holdings of loans, bonds, and credit derivatives represent credit exposures requiring EAD, RWA, and ECL calculation for consolidated risk reporting. Real process: aggregating fund credit exposure' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CreditExposure .

ind:derivativeId rdf:type rdf:Property ;
    rdfs:label 'Derivative Id' ;
    rdfs:comment 'Foreign key linking to security.derivative. Business justification: When holding is derivative, direct link enables margin calculation, counterparty exposure aggregation, regulatory reporting (EMIR, Dodd-Frank), and derivatives usage compliance (UCITS commitment appro' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Derivative .

ind:equityId rdf:type rdf:Property ;
    rdfs:label 'Equity Id' ;
    rdfs:comment 'Foreign key linking to security.equity. Business justification: When holding is equity, direct link enables dividend entitlement calculation, corporate action processing (splits, rights issues), voting rights management, and equity-specific risk analytics (beta, m' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Equity .

ind:factorId rdf:type rdf:Property ;
    rdfs:label 'Factor Id' ;
    rdfs:comment 'Foreign key linking to risk.risk_factor. Business justification: Market risk positions in funds are decomposed into risk factors (equity indices, interest rate curves, FX rates) for VaR calculation, stress testing, and FRTB compliance. Real process: market risk fac' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Factor .

ind:fixedIncomeId rdf:type rdf:Property ;
    rdfs:label 'Fixed Income Id' ;
    rdfs:comment 'Foreign key linking to security.fixed_income. Business justification: When holding is fixed income, direct link enables coupon accrual calculation, credit rating monitoring, duration/convexity analytics, and yield-to-maturity tracking. Essential for bond portfolio manag' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FixedIncome .

ind:issuerId rdf:type rdf:Property ;
    rdfs:label 'Issuer Id' ;
    rdfs:comment 'Foreign key linking to security.issuer. Business justification: Holdings require issuer reference for concentration risk monitoring (UCITS 5/10/40 rules), credit risk aggregation, sector exposure analysis, and regulatory reporting. Critical for investment complian' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Issuer .

ind:issuerLeiRegistryId rdf:type rdf:Property ;
    rdfs:label 'Issuer Lei Registry Id' ;
    rdfs:comment 'Foreign key linking to reference.lei_registry. Business justification: Issuer LEI for concentration limits (UCITS 5% single issuer rule), counterparty risk aggregation, and regulatory reporting (SFTR, EMIR). Critical for issuer-level risk management.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LeiRegistry .

ind:listingId rdf:type rdf:Property ;
    rdfs:label 'Listing Id' ;
    rdfs:comment 'Foreign key linking to security.listing. Business justification: Holdings track specific exchange listings for liquidity classification (MiFID II liquid/illiquid), trading venue selection, best execution compliance, and swing pricing threshold determination.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Listing .

ind:marketPriceCurrencyId rdf:type rdf:Property ;
    rdfs:label 'Market Price Currency Id' ;
    rdfs:comment 'Foreign key linking to reference.currency. Business justification: Holdings priced in local currencies (JPY equity, EUR bond) require FX conversion to fund base currency. Fundamental to portfolio valuation and NAV calculation.' ;
    rdfs:domain ind:FundHolding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:priceId rdf:type rdf:Property ;
    rdfs:label 'Price Id' ;
    rdfs:comment 'Foreign key linking to security.price. Business justification: Holdings require specific price record reference for NAV calculation audit trail, pricing source verification, fair value hierarchy compliance (IFRS 13), and pricing challenge resolution.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Price .

ind:referenceInstrumentIdentifierId rdf:type rdf:Property ;
    rdfs:label 'Reference Instrument Identifier Id' ;
    rdfs:comment 'Foreign key linking to reference.instrument_identifier. Business justification: Holdings identified by ISIN/CUSIP for position keeping, corporate actions, pricing, and regulatory reporting (SFTR, MiFID II). Core portfolio management requirement linking holdings to master security' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InstrumentIdentifier .

ind:sectorIndustryCodeId rdf:type rdf:Property ;
    rdfs:label 'Sector Industry Code Id' ;
    rdfs:comment 'Foreign key linking to reference.industry_code. Business justification: Sector exposure reporting (GICS, ICB) for risk analytics, concentration monitoring, and investment mandate compliance. Essential for sector allocation analysis and style drift detection.' ;
    rdfs:domain ind:FundHolding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IndustryCode .

ind:securityCreditRatingId rdf:type rdf:Property ;
    rdfs:label 'Security Credit Rating Id' ;
    rdfs:comment 'Foreign key linking to security.credit_rating. Business justification: Holdings require credit rating reference for investment mandate compliance (investment-grade only), UCITS eligibility (rated debt), risk weighting, and credit risk reporting. Essential for fixed incom' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CreditRating .

ind:structuredProductId rdf:type rdf:Property ;
    rdfs:label 'Structured Product Id' ;
    rdfs:comment 'Foreign key linking to security.structured_product. Business justification: When holding is structured product (CLO, MBS, ABS), direct link enables waterfall modeling, prepayment analysis, credit enhancement tracking, and regulatory capital calculation (CRR securitization fra' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StructuredProduct .

ind:yieldCurveId rdf:type rdf:Property ;
    rdfs:label 'Yield Curve Id' ;
    rdfs:comment 'Foreign key linking to security.yield_curve. Business justification: Fixed income holdings require yield curve reference for mark-to-market valuation, duration calculation, scenario analysis, and interest rate risk reporting. Essential for bond portfolio analytics.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:YieldCurve .

ind:accruedIncome rdf:type rdf:Property ;
    rdfs:label 'Accrued Income' ;
    rdfs:comment 'The amount of income (interest, dividends, or other distributions) that has been earned but not yet received on this holding as of the valuation date, expressed in base currency.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acquisitionDate rdf:type rdf:Property ;
    rdfs:label 'Acquisition Date' ;
    rdfs:comment 'The date on which the fund first acquired this holding. Used for holding period analysis and tax reporting.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:baseCurrency rdf:type rdf:Property ;
    rdfs:label 'Base Currency' ;
    rdfs:comment 'The three-letter ISO 4217 currency code representing the fund base currency in which NAV is calculated (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costBasis rdf:type rdf:Property ;
    rdfs:label 'Cost Basis' ;
    rdfs:comment 'The original acquisition cost of the holding in the fund base currency. Used to calculate unrealized gain or loss. May be calculated using FIFO, LIFO, or average cost method.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:counterpartyLei rdf:type rdf:Property ;
    rdfs:label 'Counterparty Lei' ;
    rdfs:comment 'The 20-character ISO 17442 Legal Entity Identifier of the counterparty for derivative or collateralized transactions. Required for regulatory reporting under EMIR and Dodd-Frank.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterpartyName rdf:type rdf:Property ;
    rdfs:label 'Counterparty Name' ;
    rdfs:comment 'The name of the counterparty for derivative instruments or securities lending transactions. Applicable to OTC derivatives, swaps, and collateralized positions.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:custodianAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Custodian Account Number' ;
    rdfs:comment 'The account number or identifier at the custodian institution where this holding is held. Used for reconciliation and settlement.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:custodianName rdf:type rdf:Property ;
    rdfs:label 'Custodian Name' ;
    rdfs:comment 'The name of the custodian bank or depository institution holding the physical or electronic custody of the asset on behalf of the fund.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationYears rdf:type rdf:Property ;
    rdfs:label 'Duration Years' ;
    rdfs:comment 'The modified duration or effective duration of the fixed income instrument, expressed in years. Measures the sensitivity of the instrument price to changes in interest rates. Applicable to bonds and other fixed income securities.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fairValueLevel rdf:type rdf:Property ;
    rdfs:label 'Fair Value Level' ;
    rdfs:comment 'The IFRS 13 fair value hierarchy level used to determine the market price: Level 1 (quoted prices in active markets), Level 2 (observable inputs other than quoted prices), or Level 3 (unobservable inputs).' ;
    rdfs:domain ind:FundHolding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdingStatus rdf:type rdf:Property ;
    rdfs:label 'Holding Status' ;
    rdfs:comment 'The current lifecycle status of the holding. Indicates whether the position is active, pending settlement, restricted from trading, pledged as collateral, or liquidated.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liquidityClassification rdf:type rdf:Property ;
    rdfs:label 'Liquidity Classification' ;
    rdfs:comment 'Classification of the holding based on its liquidity profile and the ease with which it can be converted to cash without significant price impact. Used for liquidity risk management and regulatory reporting under UCITS and AIFMD.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketValueBase rdf:type rdf:Property ;
    rdfs:label 'Market Value Base' ;
    rdfs:comment 'The total market value of the holding converted to the fund base currency using the FX rate at the valuation date. This is the value used in NAV calculation.' ;
    rdfs:domain ind:FundHolding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketValueLocal rdf:type rdf:Property ;
    rdfs:label 'Market Value Local' ;
    rdfs:comment 'The total market value of the holding in the local currency of the instrument, calculated as quantity held multiplied by market price.' ;
    rdfs:domain ind:FundHolding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:percentageOfNav rdf:type rdf:Property ;
    rdfs:label 'Percentage Of Nav' ;
    rdfs:comment 'The market value of this holding expressed as a percentage of the total fund NAV at the valuation date. Used for concentration risk analysis and regulatory reporting.' ;
    rdfs:domain ind:FundHolding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricingSource rdf:type rdf:Property ;
    rdfs:label 'Pricing Source' ;
    rdfs:comment 'The source or vendor from which the market price was obtained (e.g., Bloomberg, Reuters, IDC, internal valuation model). Used for audit trail and price verification.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityHeld rdf:type rdf:Property ;
    rdfs:label 'Quantity Held' ;
    rdfs:comment 'The number of units, shares, or nominal amount of the instrument held in the fund at the valuation date. For bonds, this may represent face value; for equities, share count.' ;
    rdfs:domain ind:FundHolding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unrealizedGainLoss rdf:type rdf:Property ;
    rdfs:label 'Unrealized Gain Loss' ;
    rdfs:comment 'The difference between the current market value in base currency and the cost basis, representing the unrealized profit or loss on the holding. Positive values indicate gains, negative values indicate losses.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valuationDate rdf:type rdf:Property ;
    rdfs:label 'Valuation Date' ;
    rdfs:comment 'The specific date on which this holding position and valuation are recorded. Critical for point-in-time portfolio snapshots and NAV calculation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fundLifecycleEventId rdf:type rdf:Property ;
    rdfs:label 'Fund Lifecycle Event Id' ;
    rdfs:comment 'Unique identifier for the fund lifecycle event record. Primary key for the fund lifecycle event entity.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FundLifecycleEvent .

ind:primaryFundId rdf:type rdf:Property ;
    rdfs:label 'Primary Fund Id' ;
    rdfs:comment 'Identifier of the fund to which this lifecycle event applies. Links to the master fund entity.' ;
    rdfs:domain ind:FundLifecycleEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fund .

ind:supersededByEventFundLifecycleEventId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Event Fund Lifecycle Event Id' ;
    rdfs:comment 'Identifier of the subsequent lifecycle event that supersedes or replaces this event.' ;
    rdfs:domain ind:FundLifecycleEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FundLifecycleEvent .

ind:auditorFirm rdf:type rdf:Property ;
    rdfs:label 'Auditor Firm' ;
    rdfs:comment 'Name of the external auditor firm providing audit or assurance services related to this lifecycle event.' ;
    rdfs:domain ind:FundLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aumAtEvent rdf:type rdf:Property ;
    rdfs:label 'Aum At Event' ;
    rdfs:comment 'Total assets under management of the fund at the time of the lifecycle event. Provides context for the scale and impact of the event.' ;
    rdfs:domain ind:FundLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:aumCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Aum Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the AUM at event amount.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boardResolutionReference rdf:type rdf:Property ;
    rdfs:label 'Board Resolution Reference' ;
    rdfs:comment 'Reference number or identifier of the board of directors resolution authorizing this lifecycle event.' ;
    rdfs:domain ind:FundLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionDate rdf:type rdf:Property ;
    rdfs:label 'Completion Date' ;
    rdfs:comment 'Date on which the lifecycle event was fully completed and all associated actions were finalized.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eventCategory rdf:type rdf:Property ;
    rdfs:label 'Event Category' ;
    rdfs:comment 'High-level categorization of the lifecycle event for reporting and analysis purposes.' ;
    rdfs:domain ind:FundLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventDate rdf:type rdf:Property ;
    rdfs:label 'Event Date' ;
    rdfs:comment 'The date on which the lifecycle event was formally recorded or announced. This is the principal business event timestamp for the lifecycle event.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eventDescription rdf:type rdf:Property ;
    rdfs:label 'Event Description' ;
    rdfs:comment 'Detailed narrative description of the lifecycle event, including business rationale, impact on investors, and any special conditions or considerations.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventReason rdf:type rdf:Property ;
    rdfs:label 'Event Reason' ;
    rdfs:comment 'Business rationale or justification for the lifecycle event. Explains why the event was initiated.' ;
    rdfs:domain ind:FundLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Event Reference Number' ;
    rdfs:comment 'Externally-known unique reference number assigned to this lifecycle event for tracking and audit purposes.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventStatus rdf:type rdf:Property ;
    rdfs:label 'Event Status' ;
    rdfs:comment 'Current status of the lifecycle event in its approval and execution workflow. [ENUM-REF-CANDIDATE: proposed|pending_approval|approved|effective|completed|cancelled|superseded — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventType rdf:type rdf:Property ;
    rdfs:label 'Event Type' ;
    rdfs:comment 'Classification of the lifecycle event. Defines the nature of the event in the fund\'s operational lifecycle. [ENUM-REF-CANDIDATE: fund_launch|soft_close|hard_close|reopening|merger|restructuring|share_class_launch|share_class_termination|fund_liquidation|fund_suspension|fund_deregistration|name_change|domicile_change|strategy_change — promote to reference product]' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiatedBy rdf:type rdf:Property ;
    rdfs:label 'Initiated By' ;
    rdfs:comment 'Name or identifier of the individual, department, or entity that initiated this lifecycle event.' ;
    rdfs:domain ind:FundLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investorCountAtEvent rdf:type rdf:Property ;
    rdfs:label 'Investor Count At Event' ;
    rdfs:comment 'Total number of investors holding positions in the fund at the time of the lifecycle event.' ;
    rdfs:domain ind:FundLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:investorNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Investor Notification Date' ;
    rdfs:comment 'Date on which investors were formally notified of this lifecycle event. Critical for compliance with disclosure requirements.' ;
    rdfs:domain ind:FundLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:investorNotificationMethod rdf:type rdf:Property ;
    rdfs:label 'Investor Notification Method' ;
    rdfs:comment 'Method or channel used to notify investors of this lifecycle event.' ;
    rdfs:domain ind:FundLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalCounselFirm rdf:type rdf:Property ;
    rdfs:label 'Legal Counsel Firm' ;
    rdfs:comment 'Name of the external legal counsel firm advising on this lifecycle event.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mergerExchangeRatio rdf:type rdf:Property ;
    rdfs:label 'Merger Exchange Ratio' ;
    rdfs:comment 'Exchange ratio applied in fund merger events, representing the number of successor fund shares received per share of the merging fund.' ;
    rdfs:domain ind:FundLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pressReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Press Release Date' ;
    rdfs:comment 'Date on which the press release announcing this lifecycle event was issued.' ;
    rdfs:domain ind:FundLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pressReleaseIssuedFlag rdf:type rdf:Property ;
    rdfs:label 'Press Release Issued Flag' ;
    rdfs:comment 'Indicates whether a public press release was issued to announce this lifecycle event.' ;
    rdfs:domain ind:FundLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:prospectusSupplementFlag rdf:type rdf:Property ;
    rdfs:label 'Prospectus Supplement Flag' ;
    rdfs:comment 'Indicates whether a prospectus supplement was issued to investors in connection with this lifecycle event.' ;
    rdfs:domain ind:FundLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryApprovalReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Reference' ;
    rdfs:comment 'Reference number or identifier of the regulatory approval granted for this lifecycle event. Populated when regulatory approval is obtained.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryApprovalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Required Flag' ;
    rdfs:comment 'Indicates whether this lifecycle event requires formal regulatory approval before it can become effective.' ;
    rdfs:domain ind:FundLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shareholderApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Shareholder Approval Date' ;
    rdfs:comment 'Date on which shareholders approved this lifecycle event through formal vote.' ;
    rdfs:domain ind:FundLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shareholderApprovalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Shareholder Approval Required Flag' ;
    rdfs:comment 'Indicates whether this lifecycle event requires formal shareholder approval before it can become effective.' ;
    rdfs:domain ind:FundLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fundMandateId rdf:type rdf:Property ;
    rdfs:label 'Fund Mandate Id' ;
    rdfs:comment 'Unique identifier for the fund mandate record. Primary key.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FundMandate .

ind:appetiteId rdf:type rdf:Property ;
    rdfs:label 'Appetite Id' ;
    rdfs:comment 'Foreign key linking to risk.risk_appetite. Business justification: Fund investment mandates must align with sponsor\'s risk appetite framework, especially for bank-owned funds and pension funds. Required for governance and risk appetite cascading. Real process: ensuri' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Appetite .

ind:primaryFundPartyId rdf:type rdf:Property ;
    rdfs:label 'Primary Fund Party Id' ;
    rdfs:comment 'Reference to the investment manager or portfolio manager responsible for executing the mandate.' ;
    rdfs:domain ind:FundMandate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:breachTolerancePolicy rdf:type rdf:Property ;
    rdfs:label 'Breach Tolerance Policy' ;
    rdfs:comment 'Policy describing acceptable tolerance levels for temporary breaches of mandate restrictions and required remediation actions.' ;
    rdfs:domain ind:FundMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceMonitoringFrequency rdf:type rdf:Property ;
    rdfs:label 'Compliance Monitoring Frequency' ;
    rdfs:comment 'Frequency at which portfolio holdings are monitored for compliance with mandate restrictions.' ;
    rdfs:domain ind:FundMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditQualityMinimum rdf:type rdf:Property ;
    rdfs:label 'Credit Quality Minimum' ;
    rdfs:comment 'Minimum credit rating required for fixed income investments (e.g., investment grade, BBB- or higher). [ENUM-REF-CANDIDATE: AAA|AA|A|BBB|BB|B|CCC|investment_grade|non_investment_grade — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FundMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currencyHedgingPolicy rdf:type rdf:Property ;
    rdfs:label 'Currency Hedging Policy' ;
    rdfs:comment 'Policy regarding foreign exchange risk management (e.g., fully hedged, partially hedged, unhedged, discretionary).' ;
    rdfs:domain ind:FundMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:derivativeUsagePolicy rdf:type rdf:Property ;
    rdfs:label 'Derivative Usage Policy' ;
    rdfs:comment 'Policy governing the use of derivative instruments (e.g., prohibited, hedging only, efficient portfolio management, speculative trading allowed).' ;
    rdfs:domain ind:FundMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentReference rdf:type rdf:Property ;
    rdfs:label 'Document Reference' ;
    rdfs:comment 'Reference identifier or file path to the formal mandate document or Investment Policy Statement (IPS).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationRangeMaxYears rdf:type rdf:Property ;
    rdfs:label 'Duration Range Max Years' ;
    rdfs:comment 'Maximum portfolio duration in years for fixed income holdings to manage interest rate risk.' ;
    rdfs:domain ind:FundMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:durationRangeMinYears rdf:type rdf:Property ;
    rdfs:label 'Duration Range Min Years' ;
    rdfs:comment 'Minimum portfolio duration in years for fixed income holdings to manage interest rate risk.' ;
    rdfs:domain ind:FundMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:esgConstraints rdf:type rdf:Property ;
    rdfs:label 'Esg Constraints' ;
    rdfs:comment 'Environmental, Social, and Governance criteria or exclusions applied to the investment universe (e.g., exclude tobacco, weapons, fossil fuels; require minimum ESG rating).' ;
    rdfs:domain ind:FundMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicRestrictions rdf:type rdf:Property ;
    rdfs:label 'Geographic Restrictions' ;
    rdfs:comment 'Geographic regions or countries where investments are permitted or restricted (e.g., developed markets only, exclude sanctioned countries).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:highWaterMarkApplicable rdf:type rdf:Property ;
    rdfs:label 'High Water Mark Applicable' ;
    rdfs:comment 'Indicates whether a high water mark mechanism is used for performance fee calculation to ensure fees are only charged on net new profits.' ;
    rdfs:domain ind:FundMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuerConcentrationLimitPct rdf:type rdf:Property ;
    rdfs:label 'Issuer Concentration Limit Pct' ;
    rdfs:comment 'Maximum percentage of fund assets that can be invested in securities of a single issuer to mitigate concentration risk.' ;
    rdfs:domain ind:FundMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leverageLimitPct rdf:type rdf:Property ;
    rdfs:label 'Leverage Limit Pct' ;
    rdfs:comment 'Maximum leverage ratio expressed as a percentage of Net Asset Value (NAV) that the fund is permitted to employ.' ;
    rdfs:domain ind:FundMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:liquidityRequirementPct rdf:type rdf:Property ;
    rdfs:label 'Liquidity Requirement Pct' ;
    rdfs:comment 'Minimum percentage of fund assets that must be held in liquid instruments to meet redemption requests and operational needs.' ;
    rdfs:domain ind:FundMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mandateCode rdf:type rdf:Property ;
    rdfs:label 'Mandate Code' ;
    rdfs:comment 'Unique business identifier or code for the mandate used in operational systems and regulatory reporting.' ;
    rdfs:domain ind:FundMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mandateName rdf:type rdf:Property ;
    rdfs:label 'Mandate Name' ;
    rdfs:comment 'Business name or title of the investment mandate.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Modified By User' ;
    rdfs:comment 'User identifier or name of the person who last modified the mandate record.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceFeeApplicable rdf:type rdf:Property ;
    rdfs:label 'Performance Fee Applicable' ;
    rdfs:comment 'Indicates whether a performance-based fee structure is applicable to this mandate.' ;
    rdfs:domain ind:FundMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:permittedAssetClasses rdf:type rdf:Property ;
    rdfs:label 'Permitted Asset Classes' ;
    rdfs:comment 'Comma-separated list of asset classes the fund is authorized to invest in (e.g., equities, fixed income, commodities, real estate, derivatives, cash equivalents).' ;
    rdfs:domain ind:FundMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prohibitedAssetClasses rdf:type rdf:Property ;
    rdfs:label 'Prohibited Asset Classes' ;
    rdfs:comment 'Comma-separated list of asset classes explicitly excluded from the investment universe.' ;
    rdfs:domain ind:FundMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sectorLimits rdf:type rdf:Property ;
    rdfs:label 'Sector Limits' ;
    rdfs:comment 'Maximum exposure limits by industry sector (e.g., technology max 25%, financials max 20%) to ensure diversification.' ;
    rdfs:domain ind:FundMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sriConstraints rdf:type rdf:Property ;
    rdfs:label 'Sri Constraints' ;
    rdfs:comment 'Socially responsible investment criteria or ethical screening rules applied to portfolio construction.' ;
    rdfs:domain ind:FundMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundPerformanceId rdf:type rdf:Property ;
    rdfs:label 'Fund Performance Id' ;
    rdfs:comment 'Unique identifier for the fund performance record.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FundPerformance .

ind:navCurrencyId rdf:type rdf:Property ;
    rdfs:label 'Nav Currency Id' ;
    rdfs:comment 'Foreign key linking to reference.currency. Business justification: Performance metrics currency denomination for return calculation and peer comparison. Essential for GIPS compliance and performance attribution.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:primaryFundEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Fund Employee Id' ;
    rdfs:comment 'Identifier of the user or system process that performed the performance calculation.' ;
    rdfs:domain ind:FundPerformance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:activeReturnPct rdf:type rdf:Property ;
    rdfs:label 'Active Return Pct' ;
    rdfs:comment 'Excess return of the fund relative to the benchmark (fund return minus benchmark return), also known as alpha. Measures the value added by active management.' ;
    rdfs:domain ind:FundPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageAum rdf:type rdf:Property ;
    rdfs:label 'Average Aum' ;
    rdfs:comment 'Average total net assets of the fund during the performance period, used for expense ratio and turnover calculations.' ;
    rdfs:domain ind:FundPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:beginningNav rdf:type rdf:Property ;
    rdfs:label 'Beginning Nav' ;
    rdfs:comment 'Net Asset Value per share at the start of the performance period.' ;
    rdfs:domain ind:FundPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:benchmarkReturnPct rdf:type rdf:Property ;
    rdfs:label 'Benchmark Return Pct' ;
    rdfs:comment 'Return of the benchmark index over the same performance period, expressed as a percentage.' ;
    rdfs:domain ind:FundPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:beta rdf:type rdf:Property ;
    rdfs:label 'Beta' ;
    rdfs:comment 'Measure of the fund\'s sensitivity to benchmark movements. Beta of 1.0 indicates the fund moves in line with the benchmark; >1.0 indicates higher volatility; <1.0 indicates lower volatility.' ;
    rdfs:domain ind:FundPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calculationDate rdf:type rdf:Property ;
    rdfs:label 'Calculation Date' ;
    rdfs:comment 'Date on which the performance metrics were calculated.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capitalAppreciationPct rdf:type rdf:Property ;
    rdfs:label 'Capital Appreciation Pct' ;
    rdfs:comment 'Portion of total return attributable to capital gains (price appreciation), expressed as a percentage.' ;
    rdfs:domain ind:FundPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:endingNav rdf:type rdf:Property ;
    rdfs:label 'Ending Nav' ;
    rdfs:comment 'Net Asset Value per share at the end of the performance period.' ;
    rdfs:domain ind:FundPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expenseRatioPct rdf:type rdf:Property ;
    rdfs:label 'Expense Ratio Pct' ;
    rdfs:comment 'Total annual operating expenses as a percentage of average net assets during the performance period. Includes management fees, administrative costs, and other fund expenses.' ;
    rdfs:domain ind:FundPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gipsCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Gips Compliant Flag' ;
    rdfs:comment 'Indicates whether the performance calculation and presentation comply with Global Investment Performance Standards established by CFA Institute.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incomeReturnPct rdf:type rdf:Property ;
    rdfs:label 'Income Return Pct' ;
    rdfs:comment 'Portion of total return attributable to income (dividends, interest, distributions), expressed as a percentage.' ;
    rdfs:domain ind:FundPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:informationRatio rdf:type rdf:Property ;
    rdfs:label 'Information Ratio' ;
    rdfs:comment 'Risk-adjusted active return metric calculated as active return / tracking error. Measures excess return per unit of active risk.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumDrawdownPct rdf:type rdf:Property ;
    rdfs:label 'Maximum Drawdown Pct' ;
    rdfs:comment 'Largest peak-to-trough decline in fund value during the performance period, expressed as a percentage. Measures downside risk and worst-case loss scenario.' ;
    rdfs:domain ind:FundPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mwrReturnPct rdf:type rdf:Property ;
    rdfs:label 'Mwr Return Pct' ;
    rdfs:comment 'Money-weighted return (also known as Internal Rate of Return or IRR) that accounts for the timing and magnitude of cash flows. Reflects the actual investor experience including contribution and withdrawal timing effects.' ;
    rdfs:domain ind:FundPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:numberOfHoldings rdf:type rdf:Property ;
    rdfs:label 'Number Of Holdings' ;
    rdfs:comment 'Total count of distinct securities held in the fund portfolio at the end of the performance period.' ;
    rdfs:domain ind:FundPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:performanceAttributionAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Performance Attribution Available Flag' ;
    rdfs:comment 'Indicates whether detailed performance attribution analysis (sector allocation, security selection effects) is available for this performance record.' ;
    rdfs:domain ind:FundPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:performanceEndDate rdf:type rdf:Property ;
    rdfs:label 'Performance End Date' ;
    rdfs:comment 'End date of the performance measurement period.' ;
    rdfs:domain ind:FundPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:performancePeriodType rdf:type rdf:Property ;
    rdfs:label 'Performance Period Type' ;
    rdfs:comment 'Standard reporting period for the performance calculation. ITD = Inception-to-Date (since inception). [ENUM-REF-CANDIDATE: 1M|3M|6M|YTD|1Y|3Y|5Y|ITD — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FundPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceStartDate rdf:type rdf:Property ;
    rdfs:label 'Performance Start Date' ;
    rdfs:comment 'Start date of the performance measurement period.' ;
    rdfs:domain ind:FundPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:performanceStatus rdf:type rdf:Property ;
    rdfs:label 'Performance Status' ;
    rdfs:comment 'Current status of the performance record in its lifecycle: preliminary (initial calculation), final (confirmed), restated (corrected after finalization), audited (verified by external auditor).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rSquared rdf:type rdf:Property ;
    rdfs:label 'R Squared' ;
    rdfs:comment 'Statistical measure (0 to 1) indicating how much of the fund\'s movements can be explained by benchmark movements. Higher values indicate greater correlation with the benchmark.' ;
    rdfs:domain ind:FundPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportingCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Reporting Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code in which performance metrics are reported to investors. May differ from base fund currency for multi-currency share classes.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskFreeRatePct rdf:type rdf:Property ;
    rdfs:label 'Risk Free Rate Pct' ;
    rdfs:comment 'Risk-free rate of return used in risk-adjusted performance calculations (Sharpe ratio, Sortino ratio). Typically based on government treasury securities of comparable duration.' ;
    rdfs:domain ind:FundPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sharpeRatio rdf:type rdf:Property ;
    rdfs:label 'Sharpe Ratio' ;
    rdfs:comment 'Risk-adjusted return metric calculated as (fund return - risk-free rate) / standard deviation of returns. Measures excess return per unit of total risk.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sortinoRatio rdf:type rdf:Property ;
    rdfs:label 'Sortino Ratio' ;
    rdfs:comment 'Risk-adjusted return metric similar to Sharpe ratio but using downside deviation instead of total standard deviation. Focuses on downside risk only.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalReturnAmount rdf:type rdf:Property ;
    rdfs:label 'Total Return Amount' ;
    rdfs:comment 'Absolute dollar amount of return generated during the performance period, calculated as ending NAV minus beginning NAV plus distributions.' ;
    rdfs:domain ind:FundPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trackingErrorPct rdf:type rdf:Property ;
    rdfs:label 'Tracking Error Pct' ;
    rdfs:comment 'Standard deviation of the difference between fund returns and benchmark returns, expressed as a percentage. Measures the consistency of active return.' ;
    rdfs:domain ind:FundPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:turnoverRatioPct rdf:type rdf:Property ;
    rdfs:label 'Turnover Ratio Pct' ;
    rdfs:comment 'Measure of how frequently assets within the fund are bought and sold, expressed as a percentage of average net assets. Higher turnover may indicate more active trading.' ;
    rdfs:domain ind:FundPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:twrGrossReturnPct rdf:type rdf:Property ;
    rdfs:label 'Twr Gross Return Pct' ;
    rdfs:comment 'Time-weighted return before deduction of fees, expressed as a percentage. TWR eliminates the effect of cash flows and measures the compound growth rate of the portfolio.' ;
    rdfs:domain ind:FundPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:twrNetReturnPct rdf:type rdf:Property ;
    rdfs:label 'Twr Net Return Pct' ;
    rdfs:comment 'Time-weighted return after deduction of all fees and expenses, expressed as a percentage. This is the return actually realized by investors.' ;
    rdfs:domain ind:FundPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volatilityPct rdf:type rdf:Property ;
    rdfs:label 'Volatility Pct' ;
    rdfs:comment 'Annualized standard deviation of fund returns over the performance period, expressed as a percentage. Measures total risk and return variability.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fundRegulatoryReportId rdf:type rdf:Property ;
    rdfs:label 'Fund Regulatory Report Id' ;
    rdfs:comment 'Unique identifier for the fund regulatory report record.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FundRegulatoryReport .

ind:jurisdictionId rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Id' ;
    rdfs:comment 'Foreign key linking to reference.jurisdiction. Business justification: Regulatory filing jurisdiction (SEC, FCA, ESMA, CIMA) for submission routing, deadline tracking, and compliance monitoring. Critical for multi-jurisdiction regulatory reporting.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Jurisdiction .

ind:riskReportId rdf:type rdf:Property ;
    rdfs:label 'Risk Report Id' ;
    rdfs:comment 'Foreign key linking to risk.risk_report. Business justification: Fund regulatory reports (AIFMD, UCITS KIID, Form PF) feed into consolidated risk reports for board and regulators. Required for enterprise-wide risk reporting aggregation. Real process: consolidating ' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RiskReport .

ind:acceptanceDate rdf:type rdf:Property ;
    rdfs:label 'Acceptance Date' ;
    rdfs:comment 'Date on which the regulator formally accepted the report submission as complete and compliant.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:amendmentReason rdf:type rdf:Property ;
    rdfs:label 'Amendment Reason' ;
    rdfs:comment 'Explanation of why the report was amended or resubmitted, including nature of corrections made.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditTrailReference rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Reference' ;
    rdfs:comment 'Reference identifier linking this report to internal audit logs and compliance tracking systems.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityLevel rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Level' ;
    rdfs:comment 'Classification level indicating the sensitivity and access restrictions for this regulatory report.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Confirmation Number' ;
    rdfs:comment 'Confirmation or acknowledgment number issued by the regulator upon successful receipt of the report.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingFrequency rdf:type rdf:Property ;
    rdfs:label 'Filing Frequency' ;
    rdfs:comment 'Required frequency at which this type of regulatory report must be filed. [ENUM-REF-CANDIDATE: daily|weekly|monthly|quarterly|semi_annual|annual|ad_hoc — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lateFilingFlag rdf:type rdf:Property ;
    rdfs:label 'Late Filing Flag' ;
    rdfs:comment 'Indicates whether the report was submitted after the regulatory deadline.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lateFilingReason rdf:type rdf:Property ;
    rdfs:label 'Late Filing Reason' ;
    rdfs:comment 'Explanation for why the report was filed after the regulatory deadline.' ;
    rdfs:domain ind:FundRegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalSubmissionReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Original Submission Reference Number' ;
    rdfs:comment 'Reference number of the original report submission if this is a resubmission or amendment.' ;
    rdfs:domain ind:FundRegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Penalty Amount' ;
    rdfs:comment 'Monetary penalty assessed by the regulator for late filing, errors, or non-compliance.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Penalty Currency Code' ;
    rdfs:comment 'Three-letter ISO currency code for the penalty amount.' ;
    rdfs:domain ind:FundRegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicDisclosureFlag rdf:type rdf:Property ;
    rdfs:label 'Public Disclosure Flag' ;
    rdfs:comment 'Indicates whether this regulatory report is subject to public disclosure or remains confidential.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatorCode rdf:type rdf:Property ;
    rdfs:label 'Regulator Code' ;
    rdfs:comment 'Code identifying the regulatory body or governing authority to which this report is submitted. [ENUM-REF-CANDIDATE: SEC|FINRA|CFTC|FCA|ESMA|EBA|BaFin|AMF|CSSF|MAS — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorName rdf:type rdf:Property ;
    rdfs:label 'Regulator Name' ;
    rdfs:comment 'Full name of the regulatory body or governing authority receiving this report.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionDate rdf:type rdf:Property ;
    rdfs:label 'Rejection Date' ;
    rdfs:comment 'Date on which the regulator rejected the report submission due to errors or non-compliance.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rejectionReason rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason' ;
    rdfs:comment 'Detailed explanation provided by the regulator for rejecting the report submission.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Report Approval Date' ;
    rdfs:comment 'Date on which the regulatory report was internally approved for submission.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportChecksum rdf:type rdf:Property ;
    rdfs:label 'Report Checksum' ;
    rdfs:comment 'Cryptographic hash or checksum of the report file to ensure data integrity and detect tampering.' ;
    rdfs:domain ind:FundRegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportFileFormat rdf:type rdf:Property ;
    rdfs:label 'Report File Format' ;
    rdfs:comment 'Technical file format in which the regulatory report was submitted.' ;
    rdfs:domain ind:FundRegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportFileName rdf:type rdf:Property ;
    rdfs:label 'Report File Name' ;
    rdfs:comment 'Name of the file containing the regulatory report submission, typically in XML, XBRL, or PDF format.' ;
    rdfs:domain ind:FundRegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportFileSizeBytes rdf:type rdf:Property ;
    rdfs:label 'Report File Size Bytes' ;
    rdfs:comment 'Size of the submitted report file in bytes.' ;
    rdfs:domain ind:FundRegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reportPreparerEmail rdf:type rdf:Property ;
    rdfs:label 'Report Preparer Email' ;
    rdfs:comment 'Email address of the individual responsible for preparing the regulatory report.' ;
    rdfs:domain ind:FundRegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportPreparerName rdf:type rdf:Property ;
    rdfs:label 'Report Preparer Name' ;
    rdfs:comment 'Name of the individual or team responsible for preparing the regulatory report.' ;
    rdfs:domain ind:FundRegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Report Reference Number' ;
    rdfs:comment 'Externally-known unique reference number assigned to this regulatory report submission by the reporting system or regulator.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportReviewerName rdf:type rdf:Property ;
    rdfs:label 'Report Reviewer Name' ;
    rdfs:comment 'Name of the individual who reviewed and approved the regulatory report before submission.' ;
    rdfs:domain ind:FundRegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportStatus rdf:type rdf:Property ;
    rdfs:label 'Report Status' ;
    rdfs:comment 'Current lifecycle status of the regulatory report submission.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportType rdf:type rdf:Property ;
    rdfs:label 'Report Type' ;
    rdfs:comment 'Type of regulatory report being filed. Indicates the specific regulatory framework and form template. [ENUM-REF-CANDIDATE: AIFMD_ANNEX_IV|UCITS_KIID|UCITS_KID|FORM_PF|CPO_PQR|FATCA|CRS|EMIR|SOLVENCY_II — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportVersionNumber rdf:type rdf:Property ;
    rdfs:label 'Report Version Number' ;
    rdfs:comment 'Version number of this report submission, incremented for each amendment or resubmission.' ;
    rdfs:domain ind:FundRegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reportingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Reporting Period End Date' ;
    rdfs:comment 'End date of the period covered by this regulatory report.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Start Date' ;
    rdfs:comment 'Start date of the period covered by this regulatory report.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:resubmissionFlag rdf:type rdf:Property ;
    rdfs:label 'Resubmission Flag' ;
    rdfs:comment 'Indicates whether this report is a resubmission or amendment of a previously filed report.' ;
    rdfs:domain ind:FundRegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:submissionDate rdf:type rdf:Property ;
    rdfs:label 'Submission Date' ;
    rdfs:comment 'Date on which the regulatory report was submitted to the regulator or governing body.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:submissionDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Submission Deadline Date' ;
    rdfs:comment 'Regulatory deadline date by which the report must be submitted to remain compliant.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:submissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submission Timestamp' ;
    rdfs:comment 'Precise timestamp when the regulatory report was submitted to the regulator, including time zone information.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fundSwitchId rdf:type rdf:Property ;
    rdfs:label 'Fund Switch Id' ;
    rdfs:comment 'Unique identifier for the fund switch transaction. Primary key for the fund switch record.' ;
    rdfs:domain ind:FundSwitch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:settlementHolidayCalendarId rdf:type rdf:Property ;
    rdfs:label 'Settlement Holiday Calendar Id' ;
    rdfs:comment 'Foreign key linking to reference.holiday_calendar. Business justification: Switch settlement on valid business days per fund calendar. Critical for dealing deadline enforcement and transfer agency SLA compliance.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HolidayCalendar .

ind:sourceFundClassId rdf:type rdf:Property ;
    rdfs:label 'Source Fund Class Id' ;
    rdfs:comment 'Reference to the specific fund class from which units are being redeemed in the switch transaction.' ;
    rdfs:domain ind:FundSwitch ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FundClass .

ind:sourceFundId rdf:type rdf:Property ;
    rdfs:label 'Source Fund Id' ;
    rdfs:comment 'Reference to the fund from which units are being redeemed as part of the switch transaction.' ;
    rdfs:domain ind:FundSwitch ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fund .

ind:targetFundClassId rdf:type rdf:Property ;
    rdfs:label 'Target Fund Class Id' ;
    rdfs:comment 'Reference to the specific fund class into which proceeds are being reinvested in the switch transaction.' ;
    rdfs:domain ind:FundSwitch ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FundClass .

ind:targetFundId rdf:type rdf:Property ;
    rdfs:label 'Target Fund Id' ;
    rdfs:comment 'Reference to the fund into which proceeds are being reinvested as part of the switch transaction.' ;
    rdfs:domain ind:FundSwitch ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fund .

ind:transferAgentPartyId rdf:type rdf:Property ;
    rdfs:label 'Transfer Agent Party Id' ;
    rdfs:comment 'Reference to the transfer agent responsible for processing the fund switch transaction.' ;
    rdfs:domain ind:FundSwitch ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:amlCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Aml Check Status' ;
    rdfs:comment 'Status of the Anti-Money Laundering compliance check performed on the fund switch transaction.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmationSentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Confirmation Sent Timestamp' ;
    rdfs:comment 'Timestamp when the fund switch confirmation was sent to the investor.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:entryLoadAmount rdf:type rdf:Property ;
    rdfs:label 'Entry Load Amount' ;
    rdfs:comment 'Entry load or subscription fee charged on the target fund class as part of the switch transaction.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exitLoadAmount rdf:type rdf:Property ;
    rdfs:label 'Exit Load Amount' ;
    rdfs:comment 'Exit load or redemption fee charged on the source fund class if the switch occurs before the lock-in period expires.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossRedemptionProceeds rdf:type rdf:Property ;
    rdfs:label 'Gross Redemption Proceeds' ;
    rdfs:comment 'Total proceeds from the redemption of units from the source fund class before deducting any fees or charges.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lockInComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Lock In Compliance Flag' ;
    rdfs:comment 'Indicator of whether the fund switch transaction complies with any lock-in period restrictions on the source fund class.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netSwitchProceeds rdf:type rdf:Property ;
    rdfs:label 'Net Switch Proceeds' ;
    rdfs:comment 'Net proceeds available for reinvestment into the target fund class after deducting switching fees, exit loads, and any applicable taxes.' ;
    rdfs:domain ind:FundSwitch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderDate rdf:type rdf:Property ;
    rdfs:label 'Order Date' ;
    rdfs:comment 'Date on which the investor submitted the fund switch order instruction.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:orderTimestamp rdf:type rdf:Property ;
    rdfs:label 'Order Timestamp' ;
    rdfs:comment 'Precise timestamp when the fund switch order was received and recorded by the transfer agent or fund administrator.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:realizedGainLoss rdf:type rdf:Property ;
    rdfs:label 'Realized Gain Loss' ;
    rdfs:comment 'Realized capital gain or loss resulting from the redemption leg of the fund switch transaction, calculated as the difference between redemption proceeds and cost basis.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:redemptionNav rdf:type rdf:Property ;
    rdfs:label 'Redemption Nav' ;
    rdfs:comment 'Net Asset Value per unit of the source fund class applied to calculate the redemption proceeds.' ;
    rdfs:domain ind:FundSwitch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:redemptionUnits rdf:type rdf:Property ;
    rdfs:label 'Redemption Units' ;
    rdfs:comment 'Number of units redeemed from the source fund class as part of the switch transaction.' ;
    rdfs:domain ind:FundSwitch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:subscriptionNav rdf:type rdf:Property ;
    rdfs:label 'Subscription Nav' ;
    rdfs:comment 'Net Asset Value per unit of the target fund class applied to calculate the number of units subscribed.' ;
    rdfs:domain ind:FundSwitch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:subscriptionUnits rdf:type rdf:Property ;
    rdfs:label 'Subscription Units' ;
    rdfs:comment 'Number of units subscribed in the target fund class using the net switch proceeds.' ;
    rdfs:domain ind:FundSwitch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:switchOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Switch Order Number' ;
    rdfs:comment 'Externally-known unique reference number assigned to the fund switch order for tracking and confirmation purposes.' ;
    rdfs:domain ind:FundSwitch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:switchStatus rdf:type rdf:Property ;
    rdfs:label 'Switch Status' ;
    rdfs:comment 'Current lifecycle status of the fund switch transaction indicating its processing stage.' ;
    rdfs:domain ind:FundSwitch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:switchType rdf:type rdf:Property ;
    rdfs:label 'Switch Type' ;
    rdfs:comment 'Classification of the switch transaction indicating whether it is a full redemption and reinvestment, partial switch, or part of a systematic switch plan.' ;
    rdfs:domain ind:FundSwitch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:switchingFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Switching Fee Amount' ;
    rdfs:comment 'Fee charged by the fund administrator or transfer agent for processing the fund switch transaction.' ;
    rdfs:domain ind:FundSwitch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxEventFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Event Flag' ;
    rdfs:comment 'Indicator of whether the fund switch transaction triggers a taxable event for the investor under applicable tax regulations.' ;
    rdfs:domain ind:FundSwitch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxWithheldAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Withheld Amount' ;
    rdfs:comment 'Total tax amount withheld from the redemption proceeds as required by applicable tax regulations.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tradeDate rdf:type rdf:Property ;
    rdfs:label 'Trade Date' ;
    rdfs:comment 'Date on which the fund switch transaction is executed and the Net Asset Value (NAV) is applied for both redemption and subscription legs.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fundTransactionId rdf:type rdf:Property ;
    rdfs:label 'Fund Transaction Id' ;
    rdfs:comment 'Unique identifier for the fund transaction record. Primary key for the fund transaction entity.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FundTransaction .

ind:brokerBicDirectoryId rdf:type rdf:Property ;
    rdfs:label 'Broker Bic Directory Id' ;
    rdfs:comment 'Foreign key linking to reference.bic_directory. Business justification: Broker BIC for settlement instructions, SWIFT messaging, and trade confirmation matching. Critical for straight-through processing and payment routing.' ;
    rdfs:domain ind:FundTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BicDirectory .

ind:brokerId rdf:type rdf:Property ;
    rdfs:label 'Broker Id' ;
    rdfs:comment 'Identifier of the broker or counterparty through which the transaction was executed. Links to broker master entity.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Broker .

ind:portfolioId rdf:type rdf:Property ;
    rdfs:label 'Portfolio Id' ;
    rdfs:comment 'Identifier of the portfolio within the fund where this transaction occurred. Links to portfolio master entity.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ManagedPortfolio .

ind:transactionCurrencyId rdf:type rdf:Property ;
    rdfs:label 'Transaction Currency Id' ;
    rdfs:comment 'Foreign key linking to reference.currency. Business justification: Trade execution currency for settlement, broker confirmation matching, and cash management. Essential for multi-currency trading and FX exposure tracking.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:accountingDate rdf:type rdf:Property ;
    rdfs:label 'Accounting Date' ;
    rdfs:comment 'Date on which the transaction is recorded in the fund accounting books. May differ from trade date for certain adjustments.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accountingTreatment rdf:type rdf:Property ;
    rdfs:label 'Accounting Treatment' ;
    rdfs:comment 'Classification of how the transaction is treated in fund accounting books for financial reporting purposes.' ;
    rdfs:domain ind:FundTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseCurrencyGrossAmount rdf:type rdf:Property ;
    rdfs:label 'Base Currency Gross Amount' ;
    rdfs:comment 'Gross transaction amount converted to the funds base currency using the FX rate.' ;
    rdfs:domain ind:FundTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseCurrencyNetAmount rdf:type rdf:Property ;
    rdfs:label 'Base Currency Net Amount' ;
    rdfs:comment 'Net transaction amount converted to the funds base currency using the FX rate. Used for NAV calculation.' ;
    rdfs:domain ind:FundTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commissionAmount rdf:type rdf:Property ;
    rdfs:label 'Commission Amount' ;
    rdfs:comment 'Brokerage commission or transaction fee charged for executing the trade.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:generalLedgerAccountCode rdf:type rdf:Property ;
    rdfs:label 'General Ledger Account Code' ;
    rdfs:comment 'General ledger account code to which this transaction is posted in the fund accounting subledger.' ;
    rdfs:domain ind:FundTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Amount' ;
    rdfs:comment 'Total transaction value before fees, commissions, and taxes. Calculated as quantity multiplied by unit price.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:instrumentCusip rdf:type rdf:Property ;
    rdfs:label 'Instrument Cusip' ;
    rdfs:comment 'CUSIP identifier for North American securities involved in the transaction.' ;
    rdfs:domain ind:FundTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instrumentIsin rdf:type rdf:Property ;
    rdfs:label 'Instrument Isin' ;
    rdfs:comment 'International Securities Identification Number uniquely identifying the financial instrument traded in this transaction.' ;
    rdfs:domain ind:FundTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instrumentSedol rdf:type rdf:Property ;
    rdfs:label 'Instrument Sedol' ;
    rdfs:comment 'SEDOL identifier for securities traded on UK and Irish exchanges.' ;
    rdfs:domain ind:FundTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:navDate rdf:type rdf:Property ;
    rdfs:label 'Nav Date' ;
    rdfs:comment 'NAV calculation date to which this transaction contributes. Critical for daily NAV computation and investor pricing.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:netAmount rdf:type rdf:Property ;
    rdfs:label 'Net Amount' ;
    rdfs:comment 'Net transaction value after deducting all commissions, fees, and taxes. This is the amount that impacts fund cash position.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantity rdf:type rdf:Property ;
    rdfs:label 'Quantity' ;
    rdfs:comment 'Number of units or shares of the instrument involved in the transaction. Positive for purchases/receipts, negative for sales/payments.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementMethod rdf:type rdf:Property ;
    rdfs:label 'Settlement Method' ;
    rdfs:comment 'Method used for settling the transaction: Delivery versus Payment (DVP), Receive versus Payment (RVP), Free of Payment (FOP), or Cash.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementStatus rdf:type rdf:Property ;
    rdfs:label 'Settlement Status' ;
    rdfs:comment 'Status indicating whether cash and securities have been exchanged and the transaction has settled with the counterparty.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Amount' ;
    rdfs:comment 'Total tax amount associated with the transaction, including withholding tax, stamp duty, or transaction tax.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tradeConfirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Trade Confirmation Number' ;
    rdfs:comment 'Confirmation number received from the broker or exchange confirming the trade execution.' ;
    rdfs:domain ind:FundTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionNotes rdf:type rdf:Property ;
    rdfs:label 'Transaction Notes' ;
    rdfs:comment 'Free-text notes or comments providing additional context or explanation for the transaction.' ;
    rdfs:domain ind:FundTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionType rdf:type rdf:Property ;
    rdfs:label 'Transaction Type' ;
    rdfs:comment 'Classification of the fund transaction indicating the nature of the accounting entry or portfolio activity. [ENUM-REF-CANDIDATE: purchase|sale|maturity|dividend_income|interest_income|expense_payment|corporate_action|fx_transaction|subscription|redemption|transfer_in|transfer_out|capital_call|distribution — 14 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundValuationAdjustmentId rdf:type rdf:Property ;
    rdfs:label 'Fund Valuation Adjustment Id' ;
    rdfs:comment 'Unique identifier for the fund valuation adjustment record. Primary key for this entity.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FundValuationAdjustment .

ind:navRecordId rdf:type rdf:Property ;
    rdfs:label 'Nav Record Id' ;
    rdfs:comment 'Reference to the NAV calculation record to which this adjustment was applied. Links to the specific NAV calculation event.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NavRecord .

ind:originalAdjustmentFundValuationAdjustmentId rdf:type rdf:Property ;
    rdfs:label 'Original Adjustment Fund Valuation Adjustment Id' ;
    rdfs:comment 'Reference to the original adjustment record that this entry reverses. Populated only when reversal_flag is true. Maintains audit trail for adjustment corrections.' ;
    rdfs:domain ind:FundValuationAdjustment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FundValuationAdjustment .

ind:adjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Adjustment Amount' ;
    rdfs:comment 'The absolute monetary amount of the adjustment applied to the NAV calculation. Positive values increase NAV; negative values decrease NAV. Expressed in the fund base currency.' ;
    rdfs:domain ind:FundValuationAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adjustmentBasis rdf:type rdf:Property ;
    rdfs:label 'Adjustment Basis' ;
    rdfs:comment 'The calculation basis or methodology used to determine the adjustment amount. Net flow threshold triggers adjustment when net flows exceed a percentage of AUM; gross subscription/redemption bases adjustment on absolute flow amounts; asset illiquidity bases adjustment on portfolio liquidity profile; market volatility uses market conditions; trading cost estimate uses expected transaction costs.' ;
    rdfs:domain ind:FundValuationAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentCategory rdf:type rdf:Property ;
    rdfs:label 'Adjustment Category' ;
    rdfs:comment 'Business category indicating the trigger or reason for the adjustment. Subscription-driven adjustments protect against inflows; redemption-driven protect against outflows; market event adjustments respond to extraordinary market conditions; illiquid asset adjustments address valuation uncertainty; regulatory required adjustments comply with mandates; discretionary adjustments are management decisions.' ;
    rdfs:domain ind:FundValuationAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentDate rdf:type rdf:Property ;
    rdfs:label 'Adjustment Date' ;
    rdfs:comment 'The valuation date on which this adjustment was applied to the fund NAV calculation. This is the business event date for the adjustment.' ;
    rdfs:domain ind:FundValuationAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:adjustmentPerUnit rdf:type rdf:Property ;
    rdfs:label 'Adjustment Per Unit' ;
    rdfs:comment 'The adjustment amount expressed per fund unit or share. This is the impact on the dealing NAV per unit for investors transacting on this valuation date.' ;
    rdfs:domain ind:FundValuationAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adjustmentPercentage rdf:type rdf:Property ;
    rdfs:label 'Adjustment Percentage' ;
    rdfs:comment 'The adjustment expressed as a percentage of NAV or transaction value. Used for swing pricing and dilution levy calculations. Positive percentages increase dealing NAV for subscriptions or decrease for redemptions.' ;
    rdfs:domain ind:FundValuationAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adjustmentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Adjustment Reference Number' ;
    rdfs:comment 'Business-assigned unique reference number for this valuation adjustment. Used for audit trail and external reporting.' ;
    rdfs:domain ind:FundValuationAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentStatus rdf:type rdf:Property ;
    rdfs:label 'Adjustment Status' ;
    rdfs:comment 'Current lifecycle status of the adjustment. Pending adjustments await approval; approved adjustments are authorized but not yet applied; applied adjustments are reflected in NAV; reversed adjustments have been unwound; rejected adjustments were not approved.' ;
    rdfs:domain ind:FundValuationAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Adjustment Timestamp' ;
    rdfs:comment 'Precise date and time when the adjustment calculation was executed and applied to the NAV. Used for audit trail and sequencing of adjustments.' ;
    rdfs:domain ind:FundValuationAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:adjustmentType rdf:type rdf:Property ;
    rdfs:label 'Adjustment Type' ;
    rdfs:comment 'Classification of the valuation adjustment mechanism applied. Swing pricing adjusts NAV based on net flows; dilution levy charges incoming/outgoing investors; fair value adjustment corrects stale prices; side pocket segregates illiquid assets; liquidity adjustment reflects market liquidity conditions; anti-dilution levy protects existing investors from trading costs.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealingNavImpact rdf:type rdf:Property ;
    rdfs:label 'Dealing Nav Impact' ;
    rdfs:comment 'The impact of this adjustment on the dealing NAV per unit used for investor subscriptions and redemptions. This is the NAV that transacting investors receive after adjustment application.' ;
    rdfs:domain ind:FundValuationAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disclosureText rdf:type rdf:Property ;
    rdfs:label 'Disclosure Text' ;
    rdfs:comment 'Standardized disclosure text describing the adjustment for inclusion in investor communications, fund fact sheets, and regulatory filings. Explains the adjustment mechanism and investor impact in plain language.' ;
    rdfs:domain ind:FundValuationAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedTradingCostBps rdf:type rdf:Property ;
    rdfs:label 'Estimated Trading Cost Bps' ;
    rdfs:comment 'Estimated trading costs in basis points used to calculate the adjustment amount. Represents expected bid-ask spreads, market impact, and transaction fees for portfolio rebalancing.' ;
    rdfs:domain ind:FundValuationAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossRedemptionAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Redemption Amount' ;
    rdfs:comment 'Total gross redemption amount on the adjustment date. Used to calculate dilution impact and determine adjustment magnitude for redemption-driven adjustments.' ;
    rdfs:domain ind:FundValuationAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossSubscriptionAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Subscription Amount' ;
    rdfs:comment 'Total gross subscription amount on the adjustment date. Used to calculate dilution impact and determine adjustment magnitude for subscription-driven adjustments.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:illiquidAssetPercentage rdf:type rdf:Property ;
    rdfs:label 'Illiquid Asset Percentage' ;
    rdfs:comment 'Percentage of fund portfolio classified as illiquid assets at the time of adjustment. Used to determine fair value adjustment magnitude and side pocket requirements.' ;
    rdfs:domain ind:FundValuationAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:investorProtectionFlag rdf:type rdf:Property ;
    rdfs:label 'Investor Protection Flag' ;
    rdfs:comment 'Indicates whether this adjustment was applied specifically to protect existing investors from dilution caused by large subscriptions or redemptions. True for anti-dilution mechanisms; false for other adjustment types.' ;
    rdfs:domain ind:FundValuationAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netFlowAmount rdf:type rdf:Property ;
    rdfs:label 'Net Flow Amount' ;
    rdfs:comment 'The actual net flow amount (subscriptions minus redemptions) on the adjustment date that contributed to triggering the adjustment. Expressed in fund base currency.' ;
    rdfs:domain ind:FundValuationAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netFlowThresholdPercentage rdf:type rdf:Property ;
    rdfs:label 'Net Flow Threshold Percentage' ;
    rdfs:comment 'The net flow threshold percentage of Assets Under Management (AUM) that triggered the adjustment. Used in swing pricing mechanisms where adjustments activate when net flows exceed a defined percentage.' ;
    rdfs:domain ind:FundValuationAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:publishedNavImpact rdf:type rdf:Property ;
    rdfs:label 'Published Nav Impact' ;
    rdfs:comment 'The impact of this adjustment on the published NAV per unit used for performance reporting and regulatory filings. May differ from dealing NAV if swing pricing is applied asymmetrically.' ;
    rdfs:domain ind:FundValuationAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reversalReason rdf:type rdf:Property ;
    rdfs:label 'Reversal Reason' ;
    rdfs:comment 'Detailed explanation of why the original adjustment was reversed. Required for audit trail and regulatory compliance when adjustments are unwound.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggeringCondition rdf:type rdf:Property ;
    rdfs:label 'Triggering Condition' ;
    rdfs:comment 'Detailed description of the specific condition or threshold that triggered this adjustment. Examples: net redemptions exceeded 2% of AUM; illiquid asset position exceeded 15% of portfolio; market bid-ask spreads widened beyond 50 basis points.' ;
    rdfs:domain ind:FundValuationAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investmentRestrictionId rdf:type rdf:Property ;
    rdfs:label 'Investment Restriction Id' ;
    rdfs:comment 'Unique identifier for the investment restriction rule record.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InvestmentRestriction .

ind:primaryInvestmentEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Investment Employee Id' ;
    rdfs:comment 'Identifier of the portfolio manager responsible for monitoring and remediating this restriction.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:regulatoryTaxonomyId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Taxonomy Id' ;
    rdfs:comment 'Foreign key linking to reference.regulatory_taxonomy. Business justification: Investment restrictions derived from regulatory taxonomy (UCITS diversification, 40 Act concentration limits). Links compliance rules to regulatory framework for automated monitoring.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryTaxonomy .

ind:riskLimitId rdf:type rdf:Property ;
    rdfs:label 'Risk Limit Id' ;
    rdfs:comment 'Foreign key linking to risk.risk_limit. Business justification: Investment restrictions operationalize risk limits at fund level (concentration limits, VaR limits, leverage limits). Required for limit monitoring and breach management. Real process: translating ent' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RiskLimit .

ind:supersededByRestrictionInvestmentRestrictionId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Restriction Investment Restriction Id' ;
    rdfs:comment 'Identifier of the restriction rule that supersedes this one. Null if this is the current version.' ;
    rdfs:domain ind:InvestmentRestriction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InvestmentRestriction .

ind:approvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approved Timestamp' ;
    rdfs:comment 'Timestamp when the restriction rule was approved for activation. Null if still in draft or pending approval.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:breachDate rdf:type rdf:Property ;
    rdfs:label 'Breach Date' ;
    rdfs:comment 'Date on which the restriction was breached. Null if no breach has occurred.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:breachMagnitude rdf:type rdf:Property ;
    rdfs:label 'Breach Magnitude' ;
    rdfs:comment 'Magnitude of the breach expressed in the same unit as the threshold (e.g., 2.50 for 2.5% over limit). Null if compliant.' ;
    rdfs:domain ind:InvestmentRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:breachStatus rdf:type rdf:Property ;
    rdfs:label 'Breach Status' ;
    rdfs:comment 'Current compliance status of the restriction: compliant, breached, warning (approaching threshold), remediated, waived (approved exception), or under review.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachTimestamp rdf:type rdf:Property ;
    rdfs:label 'Breach Timestamp' ;
    rdfs:comment 'Precise timestamp when the breach was detected, supporting intraday and real-time monitoring.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:breachTolerance rdf:type rdf:Property ;
    rdfs:label 'Breach Tolerance' ;
    rdfs:comment 'Allowable tolerance or buffer before a breach is triggered (e.g., 0.50 for 0.5% tolerance above threshold).' ;
    rdfs:domain ind:InvestmentRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:checkTiming rdf:type rdf:Property ;
    rdfs:label 'Check Timing' ;
    rdfs:comment 'Indicates whether the restriction is enforced pre-trade (before execution), post-trade (after settlement), or both.' ;
    rdfs:domain ind:InvestmentRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentExposure rdf:type rdf:Property ;
    rdfs:label 'Current Exposure' ;
    rdfs:comment 'Current measured exposure or utilization against the restriction threshold, expressed in the same unit as the threshold.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enforcementAction rdf:type rdf:Property ;
    rdfs:label 'Enforcement Action' ;
    rdfs:comment 'Action taken when a breach is detected: block (prevent trade), alert (notify), escalate (senior approval), override required, or auto-remediate.' ;
    rdfs:domain ind:InvestmentRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastCheckTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Check Timestamp' ;
    rdfs:comment 'Timestamp of the most recent compliance check performed for this restriction.' ;
    rdfs:domain ind:InvestmentRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:monitoringFrequency rdf:type rdf:Property ;
    rdfs:label 'Monitoring Frequency' ;
    rdfs:comment 'Frequency at which the restriction is monitored and compliance is checked: real-time, intraday, daily, weekly, monthly, quarterly, or on-demand. [ENUM-REF-CANDIDATE: real_time|intraday|daily|weekly|monthly|quarterly|on_demand — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextCheckTimestamp rdf:type rdf:Property ;
    rdfs:label 'Next Check Timestamp' ;
    rdfs:comment 'Scheduled timestamp for the next compliance check based on monitoring frequency.' ;
    rdfs:domain ind:InvestmentRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:overrideAllowed rdf:type rdf:Property ;
    rdfs:label 'Override Allowed' ;
    rdfs:comment 'Indicates whether manual override of the restriction is permitted under defined circumstances (true/false).' ;
    rdfs:domain ind:InvestmentRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overrideAuthorityLevel rdf:type rdf:Property ;
    rdfs:label 'Override Authority Level' ;
    rdfs:comment 'Minimum authority level required to approve an override: none, portfolio manager, head of risk, CIO (Chief Investment Officer), board, or regulator.' ;
    rdfs:domain ind:InvestmentRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationDeadline rdf:type rdf:Property ;
    rdfs:label 'Remediation Deadline' ;
    rdfs:comment 'Date by which a breach must be remediated to restore compliance. Null if no breach or no deadline applies.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remediationPlan rdf:type rdf:Property ;
    rdfs:label 'Remediation Plan' ;
    rdfs:comment 'Description of the remediation plan or actions taken to address the breach.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictionCategory rdf:type rdf:Property ;
    rdfs:label 'Restriction Category' ;
    rdfs:comment 'Business category of the restriction: concentration, liquidity, leverage, counterparty exposure, asset class, geography, sector, issuer, credit rating, or maturity. [ENUM-REF-CANDIDATE: concentration|liquidity|leverage|counterparty|asset_class|geography|sector|issuer|rating|maturity — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InvestmentRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictionCode rdf:type rdf:Property ;
    rdfs:label 'Restriction Code' ;
    rdfs:comment 'Unique business code identifying the restriction rule within the compliance framework.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictionName rdf:type rdf:Property ;
    rdfs:label 'Restriction Name' ;
    rdfs:comment 'Human-readable name of the investment restriction rule.' ;
    rdfs:domain ind:InvestmentRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictionStatus rdf:type rdf:Property ;
    rdfs:label 'Restriction Status' ;
    rdfs:comment 'Lifecycle status of the restriction rule: active (in force), suspended (temporarily inactive), expired, superseded (replaced by newer rule), or draft (not yet effective).' ;
    rdfs:domain ind:InvestmentRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictionType rdf:type rdf:Property ;
    rdfs:label 'Restriction Type' ;
    rdfs:comment 'Classification of the restriction source: regulatory (UCITS, AIFMD), mandate (prospectus), internal (risk policy), contractual (IMA), statutory (local law), or risk limit (VaR, concentration).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleDescription rdf:type rdf:Property ;
    rdfs:label 'Rule Description' ;
    rdfs:comment 'Detailed textual description of the investment restriction rule, including conditions and applicability.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdCurrency rdf:type rdf:Property ;
    rdfs:label 'Threshold Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for absolute amount thresholds (e.g., USD, EUR, GBP). Null for percentage or ratio thresholds.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdUnit rdf:type rdf:Property ;
    rdfs:label 'Threshold Unit' ;
    rdfs:comment 'Unit of measure for the threshold value: percentage (%), absolute amount (currency), basis points (bps), ratio, or count.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdValue rdf:type rdf:Property ;
    rdfs:label 'Threshold Value' ;
    rdfs:comment 'Numeric threshold or limit value for the restriction (e.g., 10.00 for 10% concentration limit).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxResidencyCountryId rdf:type rdf:Property ;
    rdfs:label 'Tax Residency Country Id' ;
    rdfs:comment 'Foreign key linking to reference.country. Business justification: Tax residency determines FATCA, CRS reporting obligations, withholding tax rates, and treaty benefits. Regulatory mandate for tax compliance and investor classification.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:accountClosureDate rdf:type rdf:Property ;
    rdfs:label 'Account Closure Date' ;
    rdfs:comment 'Date when the account was formally closed. Null for active accounts. Closed accounts retain historical data for regulatory retention periods.' ;
    rdfs:domain ind:InvestorAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accountOpeningDate rdf:type rdf:Property ;
    rdfs:label 'Account Opening Date' ;
    rdfs:comment 'Date when the investor account was first opened and activated in the transfer agency system. Marks the start of the account lifecycle.' ;
    rdfs:domain ind:InvestorAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:beneficialOwnerCount rdf:type rdf:Property ;
    rdfs:label 'Beneficial Owner Count' ;
    rdfs:comment 'Number of underlying beneficial owners represented by this account. Applicable for omnibus and nominee accounts. Null for direct retail accounts.' ;
    rdfs:domain ind:InvestorAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:closureReason rdf:type rdf:Property ;
    rdfs:label 'Closure Reason' ;
    rdfs:comment 'Reason code for account closure. Used for operational analytics and regulatory reporting.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionBankAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Distribution Bank Account Number' ;
    rdfs:comment 'Bank account number for cash distribution payments. Required when distribution preference is cash or partial reinvest.' ;
    rdfs:domain ind:InvestorAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionBankAccountType rdf:type rdf:Property ;
    rdfs:label 'Distribution Bank Account Type' ;
    rdfs:comment 'Type of bank account designated for cash distributions. Determines ACH transaction code.' ;
    rdfs:domain ind:InvestorAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionBankRoutingNumber rdf:type rdf:Property ;
    rdfs:label 'Distribution Bank Routing Number' ;
    rdfs:comment 'ABA routing number for the bank receiving cash distributions. Nine-digit code identifying the financial institution.' ;
    rdfs:domain ind:InvestorAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionPreference rdf:type rdf:Property ;
    rdfs:label 'Distribution Preference' ;
    rdfs:comment 'Investor election for handling fund distributions (dividends, capital gains). Reinvest purchases additional shares; cash pays to bank account.' ;
    rdfs:domain ind:InvestorAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dormancyFlag rdf:type rdf:Property ;
    rdfs:label 'Dormancy Flag' ;
    rdfs:comment 'Indicates whether the account has been classified as dormant due to prolonged inactivity. Triggers escheatment and outreach processes.' ;
    rdfs:domain ind:InvestorAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:investorType rdf:type rdf:Property ;
    rdfs:label 'Investor Type' ;
    rdfs:comment 'Classification of the investor account holder. Determines servicing model, fee structure, and regulatory treatment.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Mailing Address Line1' ;
    rdfs:comment 'First line of the postal mailing address for account correspondence and statements.' ;
    rdfs:domain ind:InvestorAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Mailing Address Line2' ;
    rdfs:comment 'Second line of the postal mailing address (apartment, suite, building number). Optional field.' ;
    rdfs:domain ind:InvestorAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingCity rdf:type rdf:Property ;
    rdfs:label 'Mailing City' ;
    rdfs:comment 'City or municipality component of the mailing address.' ;
    rdfs:domain ind:InvestorAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingCountry rdf:type rdf:Property ;
    rdfs:label 'Mailing Country' ;
    rdfs:comment 'Three-letter ISO country code for the mailing address. Determines postal routing and regulatory jurisdiction.' ;
    rdfs:domain ind:InvestorAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingPostalCode rdf:type rdf:Property ;
    rdfs:label 'Mailing Postal Code' ;
    rdfs:comment 'Postal or ZIP code component of the mailing address. Format varies by country.' ;
    rdfs:domain ind:InvestorAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingStateProvince rdf:type rdf:Property ;
    rdfs:label 'Mailing State Province' ;
    rdfs:comment 'State, province, or region component of the mailing address. Format varies by country.' ;
    rdfs:domain ind:InvestorAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredCurrency rdf:type rdf:Property ;
    rdfs:label 'Preferred Currency' ;
    rdfs:comment 'Three-letter ISO currency code for account statements, distributions, and client communications. May differ from fund base currency.' ;
    rdfs:domain ind:InvestorAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationType rdf:type rdf:Property ;
    rdfs:label 'Registration Type' ;
    rdfs:comment 'Legal structure of the account registration. Determines ownership rights, tax treatment, and beneficiary rules. [ENUM-REF-CANDIDATE: individual|joint_tenants|tenants_in_common|trust|corporate|partnership|ira|401k|ugma|utma — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictedTradingFlag rdf:type rdf:Property ;
    rdfs:label 'Restricted Trading Flag' ;
    rdfs:comment 'Indicates whether trading restrictions are in place on this account. True if the account is subject to market timing controls, redemption fees, or regulatory holds.' ;
    rdfs:domain ind:InvestorAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:restrictedTradingReason rdf:type rdf:Property ;
    rdfs:label 'Restricted Trading Reason' ;
    rdfs:comment 'Explanation for trading restrictions. Examples include excessive trading pattern detection, regulatory hold, or pending investigation.' ;
    rdfs:domain ind:InvestorAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statementDeliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Statement Delivery Method' ;
    rdfs:comment 'Investor preference for receiving account statements and confirmations. Electronic delivery reduces costs and environmental impact.' ;
    rdfs:domain ind:InvestorAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investorStatementId rdf:type rdf:Property ;
    rdfs:label 'Investor Statement Id' ;
    rdfs:comment 'Unique identifier for the investor statement record. Primary key.' ;
    rdfs:domain ind:InvestorStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capitalGainsLongTerm rdf:type rdf:Property ;
    rdfs:label 'Capital Gains Long Term' ;
    rdfs:comment 'Long-term capital gains distributed to the investor during the statement period.' ;
    rdfs:domain ind:InvestorStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capitalGainsShortTerm rdf:type rdf:Property ;
    rdfs:label 'Capital Gains Short Term' ;
    rdfs:comment 'Short-term capital gains distributed to the investor during the statement period.' ;
    rdfs:domain ind:InvestorStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:closingNavPerUnit rdf:type rdf:Property ;
    rdfs:label 'Closing Nav Per Unit' ;
    rdfs:comment 'Net Asset Value per unit at the end of the statement period.' ;
    rdfs:domain ind:InvestorStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:closingUnitBalance rdf:type rdf:Property ;
    rdfs:label 'Closing Unit Balance' ;
    rdfs:comment 'Number of fund units or shares held by the investor at the end of the statement period.' ;
    rdfs:domain ind:InvestorStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:closingValue rdf:type rdf:Property ;
    rdfs:label 'Closing Value' ;
    rdfs:comment 'Total market value of the investor\'s holdings at the end of the statement period (closing units × closing NAV).' ;
    rdfs:domain ind:InvestorStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryAddress rdf:type rdf:Property ;
    rdfs:label 'Delivery Address' ;
    rdfs:comment 'Email address or postal address to which the statement was delivered.' ;
    rdfs:domain ind:InvestorStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Delivery Method' ;
    rdfs:comment 'Method by which the statement was delivered to the investor.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feesDeducted rdf:type rdf:Property ;
    rdfs:label 'Fees Deducted' ;
    rdfs:comment 'Total fees charged to the investor account during the statement period, including management fees, performance fees, and administrative charges.' ;
    rdfs:domain ind:InvestorStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incomeReceived rdf:type rdf:Property ;
    rdfs:label 'Income Received' ;
    rdfs:comment 'Total income allocated to the investor account during the statement period, including dividends and interest.' ;
    rdfs:domain ind:InvestorStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:openingNavPerUnit rdf:type rdf:Property ;
    rdfs:label 'Opening Nav Per Unit' ;
    rdfs:comment 'Net Asset Value per unit at the beginning of the statement period.' ;
    rdfs:domain ind:InvestorStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:openingUnitBalance rdf:type rdf:Property ;
    rdfs:label 'Opening Unit Balance' ;
    rdfs:comment 'Number of fund units or shares held by the investor at the beginning of the statement period.' ;
    rdfs:domain ind:InvestorStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:openingValue rdf:type rdf:Property ;
    rdfs:label 'Opening Value' ;
    rdfs:comment 'Total market value of the investor\'s holdings at the beginning of the statement period (opening units × opening NAV).' ;
    rdfs:domain ind:InvestorStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ordinaryDividendAmount rdf:type rdf:Property ;
    rdfs:label 'Ordinary Dividend Amount' ;
    rdfs:comment 'Portion of distributions classified as ordinary dividends for tax reporting purposes.' ;
    rdfs:domain ind:InvestorStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualifiedDividendAmount rdf:type rdf:Property ;
    rdfs:label 'Qualified Dividend Amount' ;
    rdfs:comment 'Portion of distributions that qualify for preferential tax treatment as qualified dividends.' ;
    rdfs:domain ind:InvestorStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:statementFormat rdf:type rdf:Property ;
    rdfs:label 'Statement Format' ;
    rdfs:comment 'File format in which the statement was generated and delivered.' ;
    rdfs:domain ind:InvestorStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statementPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Statement Period End Date' ;
    rdfs:comment 'The last date of the reporting period covered by this statement.' ;
    rdfs:domain ind:InvestorStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:statementPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Statement Period Start Date' ;
    rdfs:comment 'The first date of the reporting period covered by this statement.' ;
    rdfs:domain ind:InvestorStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:statementStatus rdf:type rdf:Property ;
    rdfs:label 'Statement Status' ;
    rdfs:comment 'Current lifecycle status of the investor statement.' ;
    rdfs:domain ind:InvestorStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxFormReference rdf:type rdf:Property ;
    rdfs:label 'Tax Form Reference' ;
    rdfs:comment 'Reference to associated tax forms such as Form 1099-DIV, 1099-B, or equivalent international tax documents.' ;
    rdfs:domain ind:InvestorStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalDistributionsAmount rdf:type rdf:Property ;
    rdfs:label 'Total Distributions Amount' ;
    rdfs:comment 'Total monetary value of all distributions paid or reinvested during the statement period.' ;
    rdfs:domain ind:InvestorStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDistributionsUnits rdf:type rdf:Property ;
    rdfs:label 'Total Distributions Units' ;
    rdfs:comment 'Total number of fund units issued as distributions (reinvestments) during the statement period.' ;
    rdfs:domain ind:InvestorStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalRedemptionsAmount rdf:type rdf:Property ;
    rdfs:label 'Total Redemptions Amount' ;
    rdfs:comment 'Total monetary value of all redemption transactions during the statement period.' ;
    rdfs:domain ind:InvestorStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalRedemptionsUnits rdf:type rdf:Property ;
    rdfs:label 'Total Redemptions Units' ;
    rdfs:comment 'Total number of fund units redeemed by the investor during the statement period.' ;
    rdfs:domain ind:InvestorStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalSubscriptionsAmount rdf:type rdf:Property ;
    rdfs:label 'Total Subscriptions Amount' ;
    rdfs:comment 'Total monetary value of all subscription transactions during the statement period.' ;
    rdfs:domain ind:InvestorStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalSubscriptionsUnits rdf:type rdf:Property ;
    rdfs:label 'Total Subscriptions Units' ;
    rdfs:comment 'Total number of fund units purchased by the investor during the statement period.' ;
    rdfs:domain ind:InvestorStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holidayCalendarId rdf:type rdf:Property ;
    rdfs:label 'Holiday Calendar Id' ;
    rdfs:comment 'Foreign key linking to reference.holiday_calendar. Business justification: NAV calculation occurs only on valid dealing days per fund calendar. Business day validation is critical for pricing accuracy, investor dealing, and regulatory compliance (UCITS dealing frequency rule' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HolidayCalendar .

ind:previousNavRecordId rdf:type rdf:Property ;
    rdfs:label 'Previous Nav Record Id' ;
    rdfs:comment 'Reference to the prior NAV record for this fund class, enabling time-series analysis and change tracking. Null for the first NAV record.' ;
    rdfs:domain ind:NavRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NavRecord .

ind:accruedExpenses rdf:type rdf:Property ;
    rdfs:label 'Accrued Expenses' ;
    rdfs:comment 'Expenses incurred but not yet paid by the fund, including accrued management fees, performance fees, custody fees, audit fees, and other operating expenses as of the valuation date.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calculationMethod rdf:type rdf:Property ;
    rdfs:label 'Calculation Method' ;
    rdfs:comment 'The valuation methodology used for calculating NAV. Amortized cost is used for money market funds; mark-to-market uses current market prices; fair value uses estimated values when market prices unavailable.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionPerUnit rdf:type rdf:Property ;
    rdfs:label 'Distribution Per Unit' ;
    rdfs:comment 'The amount of income or capital distribution declared per unit/share on this valuation date, if any. Zero if no distribution declared.' ;
    rdfs:domain ind:NavRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exDistributionDate rdf:type rdf:Property ;
    rdfs:label 'Ex Distribution Date' ;
    rdfs:comment 'The date on which the fund begins trading without the value of its next distribution payment. Investors purchasing on or after this date are not entitled to the declared distribution.' ;
    rdfs:domain ind:NavRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:grossAssetValue rdf:type rdf:Property ;
    rdfs:label 'Gross Asset Value' ;
    rdfs:comment 'Total market value of all fund assets before deducting liabilities. Represents the sum of all portfolio holdings valued at market prices as of the valuation date.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isAudited rdf:type rdf:Property ;
    rdfs:label 'Is Audited' ;
    rdfs:comment 'Indicates whether this NAV calculation has been subject to external audit verification. True if audited, false otherwise.' ;
    rdfs:domain ind:NavRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:managementFeeAccrual rdf:type rdf:Property ;
    rdfs:label 'Management Fee Accrual' ;
    rdfs:comment 'Accrued management fee owed to the fund manager for the period up to and including the valuation date, calculated based on the management fee rate and fund assets.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:navCalculationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Nav Calculation Timestamp' ;
    rdfs:comment 'The precise date and time when the NAV calculation was completed and finalized.' ;
    rdfs:domain ind:NavRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:navChangeAmount rdf:type rdf:Property ;
    rdfs:label 'Nav Change Amount' ;
    rdfs:comment 'The absolute change in NAV per unit compared to the previous valuation date, expressed in currency units.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:navChangePercentage rdf:type rdf:Property ;
    rdfs:label 'Nav Change Percentage' ;
    rdfs:comment 'The percentage change in NAV per unit compared to the previous valuation date. Expressed as a percentage (e.g., 2.5000 represents 2.50%).' ;
    rdfs:domain ind:NavRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:navPerUnit rdf:type rdf:Property ;
    rdfs:label 'Nav Per Unit' ;
    rdfs:comment 'The NAV divided by the number of units outstanding. This is the price at which investors buy and sell fund units. Also known as NAV per share for share-based funds.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:navPublicationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Nav Publication Timestamp' ;
    rdfs:comment 'The date and time when the NAV was officially published and made available to investors and distribution channels.' ;
    rdfs:domain ind:NavRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:navStatus rdf:type rdf:Property ;
    rdfs:label 'Nav Status' ;
    rdfs:comment 'Current lifecycle status of this NAV calculation. Preliminary indicates initial calculation pending review; final indicates approved and published; restated indicates correction of previously published NAV; suspended indicates NAV calculation halted.' ;
    rdfs:domain ind:NavRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netAssetValue rdf:type rdf:Property ;
    rdfs:label 'Net Asset Value' ;
    rdfs:comment 'The net value of the fund calculated as gross asset value minus total liabilities. This is the authoritative NAV figure used for all investor transactions and regulatory reporting.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceFeeAccrual rdf:type rdf:Property ;
    rdfs:label 'Performance Fee Accrual' ;
    rdfs:comment 'Accrued performance fee or incentive fee owed to the fund manager based on fund performance relative to benchmark or high-water mark as of the valuation date.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricingBasis rdf:type rdf:Property ;
    rdfs:label 'Pricing Basis' ;
    rdfs:comment 'The pricing methodology used for investor transactions. Forward pricing uses the next calculated NAV after order receipt; historic pricing uses the most recent NAV; swing pricing adjusts NAV for dilution.' ;
    rdfs:domain ind:NavRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Created Timestamp' ;
    rdfs:comment 'The date and time when this NAV record was first created in the system.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Updated Timestamp' ;
    rdfs:comment 'The date and time when this NAV record was last modified in the system.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:restatementReason rdf:type rdf:Property ;
    rdfs:label 'Restatement Reason' ;
    rdfs:comment 'Explanation for why this NAV was restated, if applicable. Null for original NAV calculations. Populated when nav_status is restated.' ;
    rdfs:domain ind:NavRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalLiabilities rdf:type rdf:Property ;
    rdfs:label 'Total Liabilities' ;
    rdfs:comment 'Sum of all fund liabilities including accrued expenses, payables, borrowings, and other obligations as of the valuation date.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalRedemptions rdf:type rdf:Property ;
    rdfs:label 'Total Redemptions' ;
    rdfs:comment 'Total monetary value of investor redemptions (sales) processed and settled on this valuation date.' ;
    rdfs:domain ind:NavRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalSubscriptions rdf:type rdf:Property ;
    rdfs:label 'Total Subscriptions' ;
    rdfs:comment 'Total monetary value of new investor subscriptions (purchases) processed and settled on this valuation date.' ;
    rdfs:domain ind:NavRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitsOutstanding rdf:type rdf:Property ;
    rdfs:label 'Units Outstanding' ;
    rdfs:comment 'Total number of fund units or shares currently issued and held by investors as of the valuation date.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valuationFrequency rdf:type rdf:Property ;
    rdfs:label 'Valuation Frequency' ;
    rdfs:comment 'The regular schedule on which NAV is calculated for this fund class (daily, weekly, monthly, quarterly, or annual).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionId rdf:type rdf:Property ;
    rdfs:label 'Redemption Id' ;
    rdfs:comment 'Unique identifier for the redemption transaction. Primary key for the redemption record.' ;
    rdfs:domain ind:Redemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paymentTransactionId rdf:type rdf:Property ;
    rdfs:label 'Payment Transaction Id' ;
    rdfs:comment 'Foreign key linking to payment.payment_transaction. Business justification: Redemption settlement tracking requires linking the redemption order to the outbound payment to the investor. Transfer agents must confirm payment execution before finalizing unit cancellation. The ex' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentTransaction .

ind:amountRequested rdf:type rdf:Property ;
    rdfs:label 'Amount Requested' ;
    rdfs:comment 'Monetary amount requested for redemption when the investor specifies a dollar amount rather than units.' ;
    rdfs:domain ind:Redemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dealingNav rdf:type rdf:Property ;
    rdfs:label 'Dealing Nav' ;
    rdfs:comment 'The Net Asset Value per unit or share applied to calculate the redemption proceeds, typically the NAV as of the trade date.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gatePercentageApplied rdf:type rdf:Property ;
    rdfs:label 'Gate Percentage Applied' ;
    rdfs:comment 'Percentage of the requested redemption that is fulfilled when a gate restriction is in effect, with the remainder deferred.' ;
    rdfs:domain ind:Redemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gateRestrictionFlag rdf:type rdf:Property ;
    rdfs:label 'Gate Restriction Flag' ;
    rdfs:comment 'Indicates whether the redemption is subject to fund-level gate restrictions limiting total redemptions in a period (True = gate applied, False = no gate).' ;
    rdfs:domain ind:Redemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lockInPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Lock In Period End Date' ;
    rdfs:comment 'Date on which any mandatory lock-in or holding period for the redeemed units expires, used to validate early redemption restrictions.' ;
    rdfs:domain ind:Redemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:netRedemptionProceeds rdf:type rdf:Property ;
    rdfs:label 'Net Redemption Proceeds' ;
    rdfs:comment 'Final amount payable to the investor after deducting exit load, fees, and taxes from gross proceeds.' ;
    rdfs:domain ind:Redemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderNumber rdf:type rdf:Property ;
    rdfs:label 'Order Number' ;
    rdfs:comment 'Externally visible business identifier for the redemption order, used for investor communication and reconciliation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Account Number' ;
    rdfs:comment 'Bank account number or International Bank Account Number (IBAN) to which redemption proceeds are transferred.' ;
    rdfs:domain ind:Redemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentRoutingNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Routing Number' ;
    rdfs:comment 'Bank routing number, SWIFT Bank Identifier Code (BIC), or other routing identifier for the payment destination.' ;
    rdfs:domain ind:Redemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentSentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Payment Sent Timestamp' ;
    rdfs:comment 'Date and time when the redemption proceeds payment was initiated to the investor account.' ;
    rdfs:domain ind:Redemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:redemptionStatus rdf:type rdf:Property ;
    rdfs:label 'Redemption Status' ;
    rdfs:comment 'Current lifecycle status of the redemption order (pending, confirmed, settled, cancelled, rejected, suspended).' ;
    rdfs:domain ind:Redemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionType rdf:type rdf:Property ;
    rdfs:label 'Redemption Type' ;
    rdfs:comment 'Indicates whether the redemption is a full liquidation of the investor position or a partial withdrawal.' ;
    rdfs:domain ind:Redemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:units rdf:type rdf:Property ;
    rdfs:label 'Units' ;
    rdfs:comment 'Number of fund units or shares requested for redemption by the investor.' ;
    rdfs:domain ind:Redemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:restrictionBreachId rdf:type rdf:Property ;
    rdfs:label 'Restriction Breach Id' ;
    rdfs:comment 'Unique identifier for the restriction breach record. Primary key.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RestrictionBreach .

ind:captureId rdf:type rdf:Property ;
    rdfs:label 'Capture Id' ;
    rdfs:comment 'Identifier of the trade transaction that triggered the breach, if applicable.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Capture .

ind:primaryRestrictionEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Restriction Employee Id' ;
    rdfs:comment 'Identifier of the portfolio manager responsible for the fund at the time of breach.' ;
    rdfs:domain ind:RestrictionBreach ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:securityReferenceInstrumentIdentifierId rdf:type rdf:Property ;
    rdfs:label 'Security Reference Instrument Identifier Id' ;
    rdfs:comment 'Foreign key linking to reference.instrument_identifier. Business justification: Breach tied to specific security for root cause analysis, position monitoring, and compliance reporting. Links breach to master security data.' ;
    rdfs:domain ind:RestrictionBreach ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InstrumentIdentifier .

ind:tertiaryRestrictionWaiverGrantedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Restriction Waiver Granted By Employee Id' ;
    rdfs:comment 'Identifier of the authorized individual who granted the waiver.' ;
    rdfs:domain ind:RestrictionBreach ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualValue rdf:type rdf:Property ;
    rdfs:label 'Actual Value' ;
    rdfs:comment 'The actual value of the metric at the time of breach detection.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:breachCategory rdf:type rdf:Property ;
    rdfs:label 'Breach Category' ;
    rdfs:comment 'Category of investment restriction breached: concentration limits, liquidity requirements, leverage constraints, exposure limits, diversification rules, or asset eligibility criteria.' ;
    rdfs:domain ind:RestrictionBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Breach Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for monetary breach values.' ;
    rdfs:domain ind:RestrictionBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachDetectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Breach Detection Timestamp' ;
    rdfs:comment 'Date and time when the restriction breach was detected by the compliance monitoring system.' ;
    rdfs:domain ind:RestrictionBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:breachDisposition rdf:type rdf:Property ;
    rdfs:label 'Breach Disposition' ;
    rdfs:comment 'Final disposition of the breach: resolved (corrected and closed), waived (approved exception granted), escalated (elevated for senior decision), pending (awaiting action), or withdrawn (breach determination reversed).' ;
    rdfs:domain ind:RestrictionBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachMagnitudeUnit rdf:type rdf:Property ;
    rdfs:label 'Breach Magnitude Unit' ;
    rdfs:comment 'Unit of measure for the breach magnitude: percentage, basis points (BPS), currency amount, number of units, or ratio.' ;
    rdfs:domain ind:RestrictionBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachMagnitudeValue rdf:type rdf:Property ;
    rdfs:label 'Breach Magnitude Value' ;
    rdfs:comment 'Quantitative measure of the breach magnitude, expressed in the unit of measure specified (e.g., percentage points over limit, absolute amount over threshold).' ;
    rdfs:domain ind:RestrictionBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:breachNotes rdf:type rdf:Property ;
    rdfs:label 'Breach Notes' ;
    rdfs:comment 'Free-text notes and comments regarding the breach, remediation, and resolution process.' ;
    rdfs:domain ind:RestrictionBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachOccurrenceDate rdf:type rdf:Property ;
    rdfs:label 'Breach Occurrence Date' ;
    rdfs:comment 'Business date on which the breach actually occurred or was effective.' ;
    rdfs:domain ind:RestrictionBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:breachReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Breach Reference Number' ;
    rdfs:comment 'External reference number assigned to this breach for tracking and reporting purposes.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachSeverityScore rdf:type rdf:Property ;
    rdfs:label 'Breach Severity Score' ;
    rdfs:comment 'Numerical severity score assigned to the breach based on magnitude, duration, and regulatory impact (typically 1-10 scale).' ;
    rdfs:domain ind:RestrictionBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:breachType rdf:type rdf:Property ;
    rdfs:label 'Breach Type' ;
    rdfs:comment 'Classification of the breach severity: hard limit (absolute prohibition), soft limit (guideline with tolerance), warning (approaching limit), or threshold (monitoring trigger).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringStage rdf:type rdf:Property ;
    rdfs:label 'Monitoring Stage' ;
    rdfs:comment 'Stage at which the breach was detected: pre-trade compliance check, post-trade validation, end-of-day reconciliation, or intraday monitoring.' ;
    rdfs:domain ind:RestrictionBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portfolioManagerNotifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Portfolio Manager Notified Flag' ;
    rdfs:comment 'Indicates whether the portfolio manager has been notified of the breach.' ;
    rdfs:domain ind:RestrictionBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:portfolioManagerNotifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Portfolio Manager Notified Timestamp' ;
    rdfs:comment 'Date and time when the portfolio manager was notified of the breach.' ;
    rdfs:domain ind:RestrictionBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:regulatoryReportSubmittedFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Submitted Flag' ;
    rdfs:comment 'Indicates whether the required regulatory report has been submitted.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryReportSubmittedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Submitted Timestamp' ;
    rdfs:comment 'Date and time when the regulatory report was submitted.' ;
    rdfs:domain ind:RestrictionBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:regulatoryReportingDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Deadline Date' ;
    rdfs:comment 'Deadline date by which the breach must be reported to the regulator, if reporting is required.' ;
    rdfs:domain ind:RestrictionBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remediationActionType rdf:type rdf:Property ;
    rdfs:label 'Remediation Action Type' ;
    rdfs:comment 'Type of remediation action taken to address the breach: trade reversal, position reduction, portfolio rebalancing, waiver granted by authorized party, no action required, or manual override.' ;
    rdfs:domain ind:RestrictionBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationDescription rdf:type rdf:Property ;
    rdfs:label 'Remediation Description' ;
    rdfs:comment 'Detailed description of the remediation actions taken or planned to resolve the breach.' ;
    rdfs:domain ind:RestrictionBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationInitiatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Remediation Initiated Timestamp' ;
    rdfs:comment 'Date and time when remediation actions were initiated.' ;
    rdfs:domain ind:RestrictionBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:resolutionDate rdf:type rdf:Property ;
    rdfs:label 'Resolution Date' ;
    rdfs:comment 'Date on which the breach was fully resolved and the portfolio returned to compliance.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:resolutionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Resolution Timestamp' ;
    rdfs:comment 'Precise date and time when the breach was resolved.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:thresholdLimitValue rdf:type rdf:Property ;
    rdfs:label 'Threshold Limit Value' ;
    rdfs:comment 'The regulatory or policy threshold limit that was breached.' ;
    rdfs:domain ind:RestrictionBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waiverGrantedFlag rdf:type rdf:Property ;
    rdfs:label 'Waiver Granted Flag' ;
    rdfs:comment 'Indicates whether a formal waiver was granted for this breach by authorized personnel.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waiverGrantedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Waiver Granted Timestamp' ;
    rdfs:comment 'Date and time when the waiver was formally granted.' ;
    rdfs:domain ind:RestrictionBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:waiverJustification rdf:type rdf:Property ;
    rdfs:label 'Waiver Justification' ;
    rdfs:comment 'Business justification and rationale for granting the waiver.' ;
    rdfs:domain ind:RestrictionBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriptionId rdf:type rdf:Property ;
    rdfs:label 'Subscription Id' ;
    rdfs:comment 'Unique identifier for the subscription transaction record. Primary key for the subscription entity.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:amlClearanceDate rdf:type rdf:Property ;
    rdfs:label 'Aml Clearance Date' ;
    rdfs:comment 'Date when the subscription transaction received Anti-Money Laundering (AML) clearance and was approved to proceed.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:amlClearanceStatus rdf:type rdf:Property ;
    rdfs:label 'Aml Clearance Status' ;
    rdfs:comment 'Status of Anti-Money Laundering (AML) screening and clearance for this subscription transaction. Pending = screening in progress, Cleared = passed AML checks, Flagged = requires manual review, Rejected = failed AML checks and transaction blocked.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionRate rdf:type rdf:Property ;
    rdfs:label 'Commission Rate' ;
    rdfs:comment 'Percentage rate of commission payable to the intermediary or advisor on this subscription. Expressed as a decimal. May be zero for direct orders or fee-based accounts.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confirmationSentDate rdf:type rdf:Property ;
    rdfs:label 'Confirmation Sent Date' ;
    rdfs:comment 'Date when the trade confirmation was sent to the investor. Required by SEC regulations to be sent promptly after settlement.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:costBasisPerUnit rdf:type rdf:Property ;
    rdfs:label 'Cost Basis Per Unit' ;
    rdfs:comment 'Tax cost basis per unit for this subscription lot. Calculated as net_investment_amount / units_allotted. Used for future capital gains/loss calculations upon redemption.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumInvestmentWaived rdf:type rdf:Property ;
    rdfs:label 'Minimum Investment Waived' ;
    rdfs:comment 'Indicates whether the fund minimum investment requirement was waived for this subscription (e.g., for systematic investment plans, employer-sponsored plans, or discretionary waivers).' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netInvestmentAmount rdf:type rdf:Property ;
    rdfs:label 'Net Investment Amount' ;
    rdfs:comment 'Net dollar amount actually invested in the fund after deducting entry loads and fees. Calculated as gross_subscription_amount - entry_load_amount. This is the amount used to calculate units allotted.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderMethod rdf:type rdf:Property ;
    rdfs:label 'Order Method' ;
    rdfs:comment 'Indicates whether the investor specified a dollar amount to invest or a specific number of units/shares to purchase.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Payment Received Date' ;
    rdfs:comment 'Date when the subscription payment was received by the transfer agent or fund custodian. Critical for determining good order status and settlement timing.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Status' ;
    rdfs:comment 'Current status of the payment for this subscription. Pending = awaiting receipt, Received = payment received but not cleared, Cleared = payment fully cleared and available, Failed = payment failed or rejected, Reversed = payment reversed or returned.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedAmount rdf:type rdf:Property ;
    rdfs:label 'Requested Amount' ;
    rdfs:comment 'Gross dollar amount the investor intends to invest before any fees or loads are applied. Populated when order_method is amount.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requestedUnits rdf:type rdf:Property ;
    rdfs:label 'Requested Units' ;
    rdfs:comment 'Number of fund units or shares the investor requests to purchase. Populated when order_method is units.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceOfFunds rdf:type rdf:Property ;
    rdfs:label 'Source Of Funds' ;
    rdfs:comment 'Investor declaration or classification of the source of funds for this subscription (e.g., salary, savings, inheritance, business income, investment proceeds). Required for Anti-Money Laundering (AML) compliance and Know Your Customer (KYC) due diligence.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriptionNumber rdf:type rdf:Property ;
    rdfs:label 'Subscription Number' ;
    rdfs:comment 'Business-facing unique order number for the subscription transaction. Used for investor communication and operational tracking.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriptionStatus rdf:type rdf:Property ;
    rdfs:label 'Subscription Status' ;
    rdfs:comment 'Current lifecycle status of the subscription order. Pending = order received awaiting validation, Accepted = order validated and accepted, Processing = order being processed for settlement, Settled = units allotted and transaction complete, Cancelled = order cancelled by investor or system, Rejected = order rejected due to validation failure or compliance issue.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriptionType rdf:type rdf:Property ;
    rdfs:label 'Subscription Type' ;
    rdfs:comment 'Classification of the subscription order type. Initial = first investment in fund, Additional = subsequent investment, Systematic = recurring automatic investment, Reinvestment = dividend/capital gain reinvestment, Exchange_in = transfer from another fund.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxLotMethod rdf:type rdf:Property ;
    rdfs:label 'Tax Lot Method' ;
    rdfs:comment 'Cost basis accounting method elected by the investor for this subscription and future redemptions. FIFO = First In First Out, LIFO = Last In First Out, Average_cost = average cost basis, Specific_identification = investor specifies lots to redeem.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitsAllotted rdf:type rdf:Property ;
    rdfs:label 'Units Allotted' ;
    rdfs:comment 'Number of fund units or shares allotted to the investor account as a result of this subscription. Calculated as net_investment_amount / dealing_nav.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waiverReason rdf:type rdf:Property ;
    rdfs:label 'Waiver Reason' ;
    rdfs:comment 'Business reason or code explaining why minimum investment or other requirements were waived for this subscription (e.g., systematic plan, employer plan, relationship pricing).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferAgencyEventId rdf:type rdf:Property ;
    rdfs:label 'Transfer Agency Event Id' ;
    rdfs:comment 'Unique identifier for the transfer agency event record. Primary key for the transfer agency event log.' ;
    rdfs:domain ind:TransferAgencyEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:orderId rdf:type rdf:Property ;
    rdfs:label 'Order Id' ;
    rdfs:comment 'Identifier of the investor order that triggered this transfer agency event, if applicable.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:parentEventTransferAgencyEventId rdf:type rdf:Property ;
    rdfs:label 'Parent Event Transfer Agency Event Id' ;
    rdfs:comment 'Identifier of the parent transfer agency event if this event is part of a multi-step process.' ;
    rdfs:domain ind:TransferAgencyEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TransferAgencyEvent .

ind:primaryOriginalEventTransferAgencyEventId rdf:type rdf:Property ;
    rdfs:label 'Primary Original Event Transfer Agency Event Id' ;
    rdfs:comment 'Identifier of the original transfer agency event that is being reversed or corrected by this event.' ;
    rdfs:domain ind:TransferAgencyEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TransferAgencyEvent .

ind:amlClearanceTimestamp rdf:type rdf:Property ;
    rdfs:label 'Aml Clearance Timestamp' ;
    rdfs:comment 'Date and time when AML clearance was completed for this transfer agency event.' ;
    rdfs:domain ind:TransferAgencyEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eventNotes rdf:type rdf:Property ;
    rdfs:label 'Event Notes' ;
    rdfs:comment 'Free-text notes or comments recorded by transfer agency operators regarding this event.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Event Sequence Number' ;
    rdfs:comment 'Sequential number indicating the order of this event within a related series of transfer agency events.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eventTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event Timestamp' ;
    rdfs:comment 'Precise date and time when the transfer agency event occurred in the processing workflow.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:exceptionCode rdf:type rdf:Property ;
    rdfs:label 'Exception Code' ;
    rdfs:comment 'Standardized code identifying the type of exception encountered during processing.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionFlag rdf:type rdf:Property ;
    rdfs:label 'Exception Flag' ;
    rdfs:comment 'Indicator of whether an exception occurred during the processing of this transfer agency event.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exceptionReason rdf:type rdf:Property ;
    rdfs:label 'Exception Reason' ;
    rdfs:comment 'Detailed description of the exception or error that occurred during transfer agency event processing.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderType rdf:type rdf:Property ;
    rdfs:label 'Order Type' ;
    rdfs:comment 'Type of investor order being processed in this transfer agency event. [ENUM-REF-CANDIDATE: subscription|redemption|exchange|transfer|dividend_reinvestment|systematic_investment|systematic_withdrawal — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingDate rdf:type rdf:Property ;
    rdfs:label 'Processing Date' ;
    rdfs:comment 'Business date on which the transfer agency event was processed, used for NAV application and accounting purposes.' ;
    rdfs:domain ind:TransferAgencyEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:processingPriority rdf:type rdf:Property ;
    rdfs:label 'Processing Priority' ;
    rdfs:comment 'Priority level assigned to this transfer agency event for processing queue management.' ;
    rdfs:domain ind:TransferAgencyEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingStatus rdf:type rdf:Property ;
    rdfs:label 'Processing Status' ;
    rdfs:comment 'Current status of the transfer agency event in the processing lifecycle. [ENUM-REF-CANDIDATE: initiated|pending|in_progress|completed|failed|cancelled|suspended|rejected — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registerUpdateTimestamp rdf:type rdf:Property ;
    rdfs:label 'Register Update Timestamp' ;
    rdfs:comment 'Date and time when the fund register was updated as a result of this transfer agency event.' ;
    rdfs:domain ind:TransferAgencyEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:statementGenerationFlag rdf:type rdf:Property ;
    rdfs:label 'Statement Generation Flag' ;
    rdfs:comment 'Indicator of whether an investor statement was generated as a result of this transfer agency event.' ;
    rdfs:domain ind:TransferAgencyEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:statementGenerationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Statement Generation Timestamp' ;
    rdfs:comment 'Date and time when the investor statement was generated for this transfer agency event.' ;
    rdfs:domain ind:TransferAgencyEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:stpIndicator rdf:type rdf:Property ;
    rdfs:label 'Stp Indicator' ;
    rdfs:comment 'Flag indicating whether the transfer agency event was processed automatically without manual intervention.' ;
    rdfs:domain ind:TransferAgencyEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transactionAmount rdf:type rdf:Property ;
    rdfs:label 'Transaction Amount' ;
    rdfs:comment 'Monetary amount of the transaction being processed in the transfer agency event.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionCurrency rdf:type rdf:Property ;
    rdfs:label 'Transaction Currency' ;
    rdfs:comment 'Three-letter ISO currency code for the transaction amount.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitQuantity rdf:type rdf:Property ;
    rdfs:label 'Unit Quantity' ;
    rdfs:comment 'Number of fund units or shares involved in the transfer agency event.' ;
    rdfs:domain ind:TransferAgencyEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assetUnitRegisterId rdf:type rdf:Property ;
    rdfs:label 'Asset Unit Register Id' ;
    rdfs:comment 'Unique identifier for the unit register record. Primary key for the authoritative unit/share register.' ;
    rdfs:domain ind:AssetUnitRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:averageCostPerUnit rdf:type rdf:Property ;
    rdfs:label 'Average Cost Per Unit' ;
    rdfs:comment 'Weighted average cost basis per unit calculated across all purchase transactions. Used for tax reporting and capital gains calculations.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:beneficialOwnerFlag rdf:type rdf:Property ;
    rdfs:label 'Beneficial Owner Flag' ;
    rdfs:comment 'Indicates whether the registered account holder is the beneficial owner of the units. False indicates the account is held by a nominee or intermediary on behalf of underlying beneficial owners.' ;
    rdfs:domain ind:AssetUnitRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currentMarketValue rdf:type rdf:Property ;
    rdfs:label 'Current Market Value' ;
    rdfs:comment 'Current market value of the investor\'s holdings calculated as units held multiplied by current NAV per unit. Represents the liquidation value at current market prices.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentNavPerUnit rdf:type rdf:Property ;
    rdfs:label 'Current Nav Per Unit' ;
    rdfs:comment 'Most recent Net Asset Value per unit for the fund class. Used to calculate current market value of the investor\'s holdings.' ;
    rdfs:domain ind:AssetUnitRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:distributionOption rdf:type rdf:Property ;
    rdfs:label 'Distribution Option' ;
    rdfs:comment 'Investor\'s election for handling fund distributions and dividends. Reinvest automatically purchases additional units, cash pays distributions to the investor\'s bank account, partial reinvest applies a percentage to each option.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escheatmentDueDate rdf:type rdf:Property ;
    rdfs:label 'Escheatment Due Date' ;
    rdfs:comment 'Date by which the position must be escheated to the appropriate state authority if the investor cannot be located. Calculated based on dormancy period and state-specific regulations.' ;
    rdfs:domain ind:AssetUnitRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:firstInvestmentDate rdf:type rdf:Property ;
    rdfs:label 'First Investment Date' ;
    rdfs:comment 'Date of the investor\'s first purchase transaction in this fund class. Used for holding period calculations and investor tenure analysis.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:holdingPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Holding Period Days' ;
    rdfs:comment 'Number of days since the first investment date. Used for long-term vs short-term capital gains classification and investor tenure analysis.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastTransactionType rdf:type rdf:Property ;
    rdfs:label 'Last Transaction Type' ;
    rdfs:comment 'Type of the most recent transaction that affected this position. Used for operational tracking and investor behavior analysis.' ;
    rdfs:domain ind:AssetUnitRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordClosedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Closed Timestamp' ;
    rdfs:comment 'Timestamp when this unit register position was closed due to full redemption or account closure. Null for active positions.' ;
    rdfs:domain ind:AssetUnitRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:registerStatus rdf:type rdf:Property ;
    rdfs:label 'Register Status' ;
    rdfs:comment 'Current status of the unit register position. Active indicates normal holdings, closed indicates fully redeemed, suspended indicates temporary restrictions, pending closure indicates redemption in progress, restricted indicates regulatory or compliance holds.' ;
    rdfs:domain ind:AssetUnitRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictionExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Restriction Expiry Date' ;
    rdfs:comment 'Date when the current restriction will automatically expire and normal transaction processing will resume. Null if restriction is indefinite or no restriction applies.' ;
    rdfs:domain ind:AssetUnitRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:restrictionReason rdf:type rdf:Property ;
    rdfs:label 'Restriction Reason' ;
    rdfs:comment 'Detailed explanation of why the position is restricted, if applicable. Provides context for operational staff and compliance teams.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemRecordCode rdf:type rdf:Property ;
    rdfs:label 'Source System Record Code' ;
    rdfs:comment 'Unique identifier for this unit register record in the source transfer agency system. Used for reconciliation and audit trail back to the operational system of record.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCostBasis rdf:type rdf:Property ;
    rdfs:label 'Total Cost Basis' ;
    rdfs:comment 'Total amount invested by the investor in this fund class, calculated as units held multiplied by average cost per unit. Represents the investor\'s original investment value for tax purposes.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDistributionsReceived rdf:type rdf:Property ;
    rdfs:label 'Total Distributions Received' ;
    rdfs:comment 'Cumulative amount of all distributions (dividends, capital gains, return of capital) received by the investor since first investment. Used for tax reporting and investor statements.' ;
    rdfs:domain ind:AssetUnitRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDistributionsReinvested rdf:type rdf:Property ;
    rdfs:label 'Total Distributions Reinvested' ;
    rdfs:comment 'Cumulative amount of distributions that were reinvested to purchase additional units. Subset of total distributions received.' ;
    rdfs:domain ind:AssetUnitRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitsHeld rdf:type rdf:Property ;
    rdfs:label 'Units Held' ;
    rdfs:comment 'Current number of fund units or shares held by the investor in this fund class. Represents the investor\'s ownership stake and is used to calculate distributions and redemption proceeds.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unrealizedGainLossPercentage rdf:type rdf:Property ;
    rdfs:label 'Unrealized Gain Loss Percentage' ;
    rdfs:comment 'Unrealized gain or loss expressed as a percentage of the total cost basis. Calculated as (unrealized gain/loss / total cost basis) * 100.' ;
    rdfs:domain ind:AssetUnitRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditBudgetId rdf:type rdf:Property ;
    rdfs:label 'Audit Budget Id' ;
    rdfs:comment 'Unique identifier for the audit budget record.' ;
    rdfs:domain ind:AuditBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:planId rdf:type rdf:Property ;
    rdfs:label 'Plan Id' ;
    rdfs:comment 'Reference to the annual audit plan this budget supports.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Plan .

ind:advisoryHoursActual rdf:type rdf:Property ;
    rdfs:label 'Advisory Hours Actual' ;
    rdfs:comment 'Actual hours consumed on advisory and consulting activities.' ;
    rdfs:domain ind:AuditBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:advisoryHoursPlanned rdf:type rdf:Property ;
    rdfs:label 'Advisory Hours Planned' ;
    rdfs:comment 'Planned hours allocated to advisory and consulting activities.' ;
    rdfs:domain ind:AuditBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvalStatus rdf:type rdf:Property ;
    rdfs:label 'Approval Status' ;
    rdfs:comment 'Approval status of the budget by the Audit Committee or Chief Audit Executive (CAE).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedByName rdf:type rdf:Property ;
    rdfs:label 'Approved By Name' ;
    rdfs:comment 'Name of the executive or committee that approved the budget (typically Chief Audit Executive or Audit Committee Chair).' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assuranceHoursActual rdf:type rdf:Property ;
    rdfs:label 'Assurance Hours Actual' ;
    rdfs:comment 'Actual hours consumed on assurance audit engagements.' ;
    rdfs:domain ind:AuditBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assuranceHoursPlanned rdf:type rdf:Property ;
    rdfs:label 'Assurance Hours Planned' ;
    rdfs:comment 'Planned hours allocated to assurance audit engagements.' ;
    rdfs:domain ind:AuditBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditCommitteePresentationDate rdf:type rdf:Property ;
    rdfs:label 'Audit Committee Presentation Date' ;
    rdfs:comment 'Date when the budget was presented to the Audit Committee for review and approval.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:budgetStatus rdf:type rdf:Property ;
    rdfs:label 'Budget Status' ;
    rdfs:comment 'Current approval and execution status of the budget.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coSourcingActual rdf:type rdf:Property ;
    rdfs:label 'Co Sourcing Actual' ;
    rdfs:comment 'Actual expenditure on third-party audit support and co-sourcing services during the period.' ;
    rdfs:domain ind:AuditBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coSourcingBudget rdf:type rdf:Property ;
    rdfs:label 'Co Sourcing Budget' ;
    rdfs:comment 'Budget allocated for third-party audit support and co-sourcing services.' ;
    rdfs:domain ind:AuditBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coSourcingHoursActual rdf:type rdf:Property ;
    rdfs:label 'Co Sourcing Hours Actual' ;
    rdfs:comment 'Actual hours delivered by third-party audit support providers.' ;
    rdfs:domain ind:AuditBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coSourcingHoursPlanned rdf:type rdf:Property ;
    rdfs:label 'Co Sourcing Hours Planned' ;
    rdfs:comment 'Planned hours to be delivered by third-party audit support providers (co-sourcing partners).' ;
    rdfs:domain ind:AuditBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contingencyHoursActual rdf:type rdf:Property ;
    rdfs:label 'Contingency Hours Actual' ;
    rdfs:comment 'Actual hours consumed from the contingency reserve.' ;
    rdfs:domain ind:AuditBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contingencyHoursPlanned rdf:type rdf:Property ;
    rdfs:label 'Contingency Hours Planned' ;
    rdfs:comment 'Planned hours reserved for unplanned audits, special investigations, and emerging risks.' ;
    rdfs:domain ind:AuditBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costPerAuditDay rdf:type rdf:Property ;
    rdfs:label 'Cost Per Audit Day' ;
    rdfs:comment 'Average cost per audit day, calculated as total expenditure divided by total hours (converted to days). Used for benchmarking against industry peers.' ;
    rdfs:domain ind:AuditBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cycleType rdf:type rdf:Property ;
    rdfs:label 'Cycle Type' ;
    rdfs:comment 'The planning cycle granularity for this budget record (annual plan, quarterly allocation, monthly tracking, or engagement-specific).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resourceAdequacyAssessment rdf:type rdf:Property ;
    rdfs:label 'Resource Adequacy Assessment' ;
    rdfs:comment 'Chief Audit Executive assessment of whether the budget provides adequate resources to fulfill the audit mandate and cover the audit universe.' ;
    rdfs:domain ind:AuditBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technologyActual rdf:type rdf:Property ;
    rdfs:label 'Technology Actual' ;
    rdfs:comment 'Actual expenditure on audit technology and tools during the period.' ;
    rdfs:domain ind:AuditBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:technologyBudget rdf:type rdf:Property ;
    rdfs:label 'Technology Budget' ;
    rdfs:comment 'Budget allocated for audit technology tools, software licenses, data analytics platforms, and IT infrastructure.' ;
    rdfs:domain ind:AuditBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalActualExpenditure rdf:type rdf:Property ;
    rdfs:label 'Total Actual Expenditure' ;
    rdfs:comment 'Total actual financial expenditure incurred during the budget period.' ;
    rdfs:domain ind:AuditBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalActualHours rdf:type rdf:Property ;
    rdfs:label 'Total Actual Hours' ;
    rdfs:comment 'Total audit hours actually consumed during the budget period.' ;
    rdfs:domain ind:AuditBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Total Budget Amount' ;
    rdfs:comment 'Total financial budget allocated for the audit function during this period, including salaries, travel, technology, and training.' ;
    rdfs:domain ind:AuditBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPlannedHours rdf:type rdf:Property ;
    rdfs:label 'Total Planned Hours' ;
    rdfs:comment 'Total audit hours planned for the budget period across all engagements and activities.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingActual rdf:type rdf:Property ;
    rdfs:label 'Training Actual' ;
    rdfs:comment 'Actual expenditure on audit staff training and professional development during the period.' ;
    rdfs:domain ind:AuditBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingBudget rdf:type rdf:Property ;
    rdfs:label 'Training Budget' ;
    rdfs:comment 'Budget allocated for audit staff training, professional development, certifications, and continuing education.' ;
    rdfs:domain ind:AuditBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:travelExpenseActual rdf:type rdf:Property ;
    rdfs:label 'Travel Expense Actual' ;
    rdfs:comment 'Actual expenditure on audit team travel and expenses during the period.' ;
    rdfs:domain ind:AuditBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:travelExpenseBudget rdf:type rdf:Property ;
    rdfs:label 'Travel Expense Budget' ;
    rdfs:comment 'Budget allocated for audit team travel, lodging, meals, and related expenses.' ;
    rdfs:domain ind:AuditBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceHours rdf:type rdf:Property ;
    rdfs:label 'Variance Hours' ;
    rdfs:comment 'Variance between planned and actual hours (actual minus planned). Positive indicates over-budget, negative indicates under-budget.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:variancePercentage rdf:type rdf:Property ;
    rdfs:label 'Variance Percentage' ;
    rdfs:comment 'Percentage variance between planned and actual hours, calculated as (actual - planned) / planned * 100.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:committeeReportId rdf:type rdf:Property ;
    rdfs:label 'Committee Report Id' ;
    rdfs:comment 'Unique identifier for the audit committee report record.' ;
    rdfs:domain ind:CommitteeReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:committeeApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Committee Approved By Employee Id' ;
    rdfs:comment 'Identifier of the individual who approved this report for submission to the audit committee.' ;
    rdfs:domain ind:CommitteeReport ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:committeePreparedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Committee Prepared By Employee Id' ;
    rdfs:comment 'Identifier of the internal audit staff member who prepared this report.' ;
    rdfs:domain ind:CommitteeReport ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryCommitteeEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Committee Employee Id' ;
    rdfs:comment 'Identifier of the audit committee chair to whom this report was presented.' ;
    rdfs:domain ind:CommitteeReport ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualHours rdf:type rdf:Property ;
    rdfs:label 'Actual Hours' ;
    rdfs:comment 'Total actual audit hours consumed during the reporting period.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amlBsaAuditStatus rdf:type rdf:Property ;
    rdfs:label 'Aml Bsa Audit Status' ;
    rdfs:comment 'Status of audit activities related to Anti-Money Laundering and Bank Secrecy Act compliance programs.' ;
    rdfs:domain ind:CommitteeReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetedHours rdf:type rdf:Property ;
    rdfs:label 'Budgeted Hours' ;
    rdfs:comment 'Total budgeted audit hours for the reporting period.' ;
    rdfs:domain ind:CommitteeReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:caeIndependenceAttestation rdf:type rdf:Property ;
    rdfs:label 'Cae Independence Attestation' ;
    rdfs:comment 'Boolean flag indicating whether the Chief Audit Executive has attested to organizational independence and objectivity for the reporting period.' ;
    rdfs:domain ind:CommitteeReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ccarDfastAuditStatus rdf:type rdf:Property ;
    rdfs:label 'Ccar Dfast Audit Status' ;
    rdfs:comment 'Status of audit activities related to CCAR and DFAST stress testing processes and capital planning.' ;
    rdfs:domain ind:CommitteeReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:committeeFeedback rdf:type rdf:Property ;
    rdfs:label 'Committee Feedback' ;
    rdfs:comment 'Feedback, questions, or directives provided by the audit committee in response to this report.' ;
    rdfs:domain ind:CommitteeReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:committeeMeetingDate rdf:type rdf:Property ;
    rdfs:label 'Committee Meeting Date' ;
    rdfs:comment 'The date on which the audit committee meeting was held to review this report.' ;
    rdfs:domain ind:CommitteeReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:continuousMonitoringSummary rdf:type rdf:Property ;
    rdfs:label 'Continuous Monitoring Summary' ;
    rdfs:comment 'Summary of continuous monitoring activities, including automated control testing and real-time risk indicators.' ;
    rdfs:domain ind:CommitteeReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalAuditorCoordination rdf:type rdf:Property ;
    rdfs:label 'External Auditor Coordination' ;
    rdfs:comment 'Summary of coordination activities with external auditors, including reliance on internal audit work and joint planning efforts.' ;
    rdfs:domain ind:CommitteeReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalQuarter rdf:type rdf:Property ;
    rdfs:label 'Fiscal Quarter' ;
    rdfs:comment 'The fiscal quarter (1-4) to which this audit committee report pertains, if applicable.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fiscalYear rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year' ;
    rdfs:comment 'The fiscal year to which this audit committee report pertains.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:highRiskFindingsCount rdf:type rdf:Property ;
    rdfs:label 'High Risk Findings Count' ;
    rdfs:comment 'Number of open audit findings rated as high risk or critical.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:keyRiskIndicatorsSummary rdf:type rdf:Property ;
    rdfs:label 'Key Risk Indicators Summary' ;
    rdfs:comment 'Summary of key risk indicators monitored during the reporting period and any threshold breaches or trends.' ;
    rdfs:domain ind:CommitteeReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lowRiskFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Low Risk Findings Count' ;
    rdfs:comment 'Number of open audit findings rated as low risk.' ;
    rdfs:domain ind:CommitteeReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mediumRiskFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Medium Risk Findings Count' ;
    rdfs:comment 'Number of open audit findings rated as medium risk.' ;
    rdfs:domain ind:CommitteeReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextReportDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Report Due Date' ;
    rdfs:comment 'The scheduled due date for the next audit committee report.' ;
    rdfs:domain ind:CommitteeReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:openFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Open Findings Count' ;
    rdfs:comment 'Total number of audit findings that remain open as of the report date.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overdueActionsCount rdf:type rdf:Property ;
    rdfs:label 'Overdue Actions Count' ;
    rdfs:comment 'Number of remediation actions that are past their target completion date.' ;
    rdfs:domain ind:CommitteeReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:planCompletionPercentage rdf:type rdf:Property ;
    rdfs:label 'Plan Completion Percentage' ;
    rdfs:comment 'Percentage of the annual audit plan completed as of the report date, expressed as a decimal (e.g., 75.50 for 75.5%).' ;
    rdfs:domain ind:CommitteeReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityAssuranceResults rdf:type rdf:Property ;
    rdfs:label 'Quality Assurance Results' ;
    rdfs:comment 'Results of internal quality assurance reviews or external quality assessments of the internal audit function, including ratings and improvement recommendations.' ;
    rdfs:domain ind:CommitteeReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryExaminationStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Examination Status' ;
    rdfs:comment 'Current status of regulatory examinations by bodies such as Federal Reserve, OCC, FDIC, or SEC.' ;
    rdfs:domain ind:CommitteeReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryExaminationSummary rdf:type rdf:Property ;
    rdfs:label 'Regulatory Examination Summary' ;
    rdfs:comment 'Summary of findings, observations, and action items from recent regulatory examinations.' ;
    rdfs:domain ind:CommitteeReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Report Document Reference' ;
    rdfs:comment 'Reference identifier or file path to the formal audit committee report document stored in the document management system.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Report Period End Date' ;
    rdfs:comment 'The ending date of the reporting period covered by this audit committee report.' ;
    rdfs:domain ind:CommitteeReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Report Period Start Date' ;
    rdfs:comment 'The beginning date of the reporting period covered by this audit committee report.' ;
    rdfs:domain ind:CommitteeReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportPresentationDate rdf:type rdf:Property ;
    rdfs:label 'Report Presentation Date' ;
    rdfs:comment 'The date on which this report was presented to the audit committee during the meeting.' ;
    rdfs:domain ind:CommitteeReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Report Submission Date' ;
    rdfs:comment 'The date on which this report was formally submitted to the audit committee.' ;
    rdfs:domain ind:CommitteeReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:significantFindingsSummary rdf:type rdf:Property ;
    rdfs:label 'Significant Findings Summary' ;
    rdfs:comment 'Executive summary of the most significant audit findings identified during the reporting period, including key risks and control deficiencies.' ;
    rdfs:domain ind:CommitteeReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Sox Compliance Status' ;
    rdfs:comment 'Status of Sarbanes-Oxley Act compliance activities and internal control over financial reporting (ICFR) testing.' ;
    rdfs:domain ind:CommitteeReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:threeLinesModelAssessment rdf:type rdf:Property ;
    rdfs:label 'Three Lines Model Assessment' ;
    rdfs:comment 'Assessment of the effectiveness of the three lines of defense model (business line controls, risk management and compliance, internal audit) during the reporting period.' ;
    rdfs:domain ind:CommitteeReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issueTrackerId rdf:type rdf:Property ;
    rdfs:label 'Issue Tracker Id' ;
    rdfs:comment 'Unique identifier for the audit issue tracking record. Primary key for the audit issue tracker.' ;
    rdfs:domain ind:IssueTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditEngagementId rdf:type rdf:Property ;
    rdfs:label 'Audit Engagement Id' ;
    rdfs:comment 'Reference to the audit engagement that identified this issue. Applicable when issue_source_type is internal_audit. Links to the engagement table for full audit context.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Engagement .

ind:findingId rdf:type rdf:Property ;
    rdfs:label 'Finding Id' ;
    rdfs:comment 'Reference to the detailed audit finding record that describes the control deficiency or observation. Provides linkage to the full finding documentation including root cause analysis and detailed testing results.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Finding .

ind:loanAccountId rdf:type rdf:Property ;
    rdfs:label 'Loan Account Id' ;
    rdfs:comment 'Foreign key linking to loan.loan_account. Business justification: Issue tracker consolidates findings from audits, regulatory exams, and continuous monitoring; issues often relate to specific loan accounts (e.g., ECL error on loan #12345). Linking issues to loan acc' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LoanAccount .

ind:operationalRiskEventId rdf:type rdf:Property ;
    rdfs:label 'Operational Risk Event Id' ;
    rdfs:comment 'Foreign key linking to risk.operational_risk_event. Business justification: Issue tracker consolidates audit findings and operational risk events for integrated remediation tracking. Links issue to event, supporting root cause analysis, corrective action planning, and regulat' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OperationalRiskEvent .

ind:primaryIssueOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Issue Owner Employee Id' ;
    rdfs:comment 'Identifier of the individual assigned day-to-day responsibility for coordinating remediation activities and providing status updates. Typically a manager or director within the business unit.' ;
    rdfs:domain ind:IssueTracker ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:priorIssueIssueTrackerId rdf:type rdf:Property ;
    rdfs:label 'Prior Issue Issue Tracker Id' ;
    rdfs:comment 'Reference to the previous audit issue tracker record if this is a repeat finding. Enables tracking of recurring issues and remediation effectiveness over time.' ;
    rdfs:domain ind:IssueTracker ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IssueTracker .

ind:responsibleCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Responsible Cost Center Id' ;
    rdfs:comment 'Foreign key linking to ledger.cost_center. Business justification: Issues are assigned to cost centers for remediation accountability, budget allocation, and organizational performance tracking. Cost center linkage replaces denormalized business_unit_owner with prope' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:tertiaryIssueValidatedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Issue Validated By Employee Id' ;
    rdfs:comment 'Identifier of the auditor who performed the validation testing. Links to employee or auditor table for contact information and credentials.' ;
    rdfs:domain ind:IssueTracker ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:agingBucket rdf:type rdf:Property ;
    rdfs:label 'Aging Bucket' ;
    rdfs:comment 'Categorization of issue age based on days since identification. Used for aging analysis and audit committee reporting. Buckets typically align with escalation thresholds.' ;
    rdfs:domain ind:IssueTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditCommitteeReportDate rdf:type rdf:Property ;
    rdfs:label 'Audit Committee Report Date' ;
    rdfs:comment 'Date when the issue was presented to the Audit Committee. Null if not yet reported or if audit_committee_reported_flag is false.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditCommitteeReportedFlag rdf:type rdf:Property ;
    rdfs:label 'Audit Committee Reported Flag' ;
    rdfs:comment 'Indicates whether this issue has been reported to the Audit Committee of the Board of Directors. True for high-risk issues, material weaknesses, significant deficiencies, and regulatory findings that require board-level awareness.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:closureDate rdf:type rdf:Property ;
    rdfs:label 'Closure Date' ;
    rdfs:comment 'Date when the issue was officially closed after successful validation. Used to calculate time-to-remediate metrics and track closure rates.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:controlFramework rdf:type rdf:Property ;
    rdfs:label 'Control Framework' ;
    rdfs:comment 'The control or regulatory framework that the issue relates to. Examples include COSO Internal Control, SOX Section 404, Basel III, AML/BSA, CCAR, DFAST, IFRS 9, CECL.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentDueDate rdf:type rdf:Property ;
    rdfs:label 'Current Due Date' ;
    rdfs:comment 'Current target date for completing remediation after any approved extensions. This is the active due date used for overdue calculations and escalation triggers.' ;
    rdfs:domain ind:IssueTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:daysOverdue rdf:type rdf:Property ;
    rdfs:label 'Days Overdue' ;
    rdfs:comment 'Number of calendar days the issue is past the current due date. Calculated as current date minus current_due_date when status is overdue. Zero or null when not overdue.' ;
    rdfs:domain ind:IssueTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:escalationDate rdf:type rdf:Property ;
    rdfs:label 'Escalation Date' ;
    rdfs:comment 'Date when the issue was escalated to a higher level of management or governance. Null if no escalation has occurred.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:escalationStatus rdf:type rdf:Property ;
    rdfs:label 'Escalation Status' ;
    rdfs:comment 'Current escalation level based on overdue status, risk rating, and extension count. None indicates no escalation. Higher levels indicate increasing senior management and governance body involvement.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:extensionCount rdf:type rdf:Property ;
    rdfs:label 'Extension Count' ;
    rdfs:comment 'Number of times the due date has been extended since the issue was opened. High extension counts trigger escalation and audit committee attention.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:externalAuditorCoordinationFlag rdf:type rdf:Property ;
    rdfs:label 'External Auditor Coordination Flag' ;
    rdfs:comment 'Indicates whether the issue has been shared with or identified by the external auditor. True for SOX-relevant issues and material weaknesses that impact the financial statement audit.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:identificationDate rdf:type rdf:Property ;
    rdfs:label 'Identification Date' ;
    rdfs:comment 'Date when the issue was first identified or reported. Used to calculate aging metrics and track time from identification to closure.' ;
    rdfs:domain ind:IssueTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:issueDescription rdf:type rdf:Property ;
    rdfs:label 'Issue Description' ;
    rdfs:comment 'Detailed description of the audit issue, control deficiency, or regulatory finding. Includes the condition observed, the criteria or standard that was not met, and the context of the deficiency.' ;
    rdfs:domain ind:IssueTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issueReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Issue Reference Number' ;
    rdfs:comment 'Business-facing unique reference number assigned to the issue for tracking and communication purposes. Used in audit committee reports and management communications.' ;
    rdfs:domain ind:IssueTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issueSourceType rdf:type rdf:Property ;
    rdfs:label 'Issue Source Type' ;
    rdfs:comment 'The origin or source that identified the issue. Distinguishes between internal audit findings, regulatory examination findings, external audit observations, self-identified issues by business units, management reviews, and continuous monitoring alerts.' ;
    rdfs:domain ind:IssueTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issueStatus rdf:type rdf:Property ;
    rdfs:label 'Issue Status' ;
    rdfs:comment 'Current lifecycle status of the issue. Open indicates newly identified and not yet started. In_progress indicates remediation activities underway. Pending_validation indicates remediation complete and awaiting audit validation. Closed indicates validated and closed. Overdue indicates past due date.' ;
    rdfs:domain ind:IssueTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issueTitle rdf:type rdf:Property ;
    rdfs:label 'Issue Title' ;
    rdfs:comment 'Concise title or summary of the audit issue or finding. Used in executive dashboards and audit committee reporting for quick identification.' ;
    rdfs:domain ind:IssueTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lob rdf:type rdf:Property ;
    rdfs:label 'Lob' ;
    rdfs:comment 'Specific Line of Business (LOB) code or name where the issue was identified. Examples include Commercial Lending, Investment Banking, Wealth Management, Retail Banking, Treasury, Risk Management.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managementActionPlan rdf:type rdf:Property ;
    rdfs:label 'Management Action Plan' ;
    rdfs:comment 'Detailed description of the corrective actions management has committed to implement to remediate the issue. Includes specific steps, milestones, and resource commitments.' ;
    rdfs:domain ind:IssueTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialWeaknessFlag rdf:type rdf:Property ;
    rdfs:label 'Material Weakness Flag' ;
    rdfs:comment 'Indicates whether the issue constitutes a material weakness in internal control over financial reporting as defined by SOX and PCAOB standards. Material weaknesses must be disclosed in the annual 10-K filing.' ;
    rdfs:domain ind:IssueTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originalDueDate rdf:type rdf:Property ;
    rdfs:label 'Original Due Date' ;
    rdfs:comment 'Initial target date agreed upon for completing remediation when the issue was first opened. Serves as baseline for tracking extensions and delays.' ;
    rdfs:domain ind:IssueTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryBody rdf:type rdf:Property ;
    rdfs:label 'Regulatory Body' ;
    rdfs:comment 'Name of the regulatory authority that issued the finding when issue_source_type is regulatory_exam. Examples include Federal Reserve (Fed), Office of the Comptroller of the Currency (OCC), Federal Deposit Insurance Corporation (FDIC), Securities and Exchange Commission (SEC), Financial Industry Regulatory Authority (FINRA), Consumer Financial Protection Bureau (CFPB).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryExamReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Exam Reference' ;
    rdfs:comment 'Official examination reference number or Matter Requiring Attention (MRA) number assigned by the regulatory body. Used for tracking and correspondence with regulators.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationApproach rdf:type rdf:Property ;
    rdfs:label 'Remediation Approach' ;
    rdfs:comment 'High-level category describing the primary remediation strategy. Process redesign for fundamental process changes, control enhancement for strengthening existing controls, system implementation for technology solutions, policy update for governance changes, training for capability building, resource addition for staffing or budget increases.' ;
    rdfs:domain ind:IssueTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationProgressPercentage rdf:type rdf:Property ;
    rdfs:label 'Remediation Progress Percentage' ;
    rdfs:comment 'Estimated percentage completion of the management action plan. Ranges from 0.00 to 100.00. Used for tracking progress and identifying stalled remediation efforts.' ;
    rdfs:domain ind:IssueTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:repeatFindingFlag rdf:type rdf:Property ;
    rdfs:label 'Repeat Finding Flag' ;
    rdfs:comment 'Indicates whether this issue is a repeat of a previously identified and closed finding. Repeat findings indicate ineffective remediation or control sustainability issues and trigger heightened scrutiny.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:significantDeficiencyFlag rdf:type rdf:Property ;
    rdfs:label 'Significant Deficiency Flag' ;
    rdfs:comment 'Indicates whether the issue constitutes a significant deficiency in internal control over financial reporting. Less severe than a material weakness but important enough to merit attention by those charged with governance.' ;
    rdfs:domain ind:IssueTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:soxRelevantFlag rdf:type rdf:Property ;
    rdfs:label 'Sox Relevant Flag' ;
    rdfs:comment 'Indicates whether the issue impacts a SOX-relevant control over financial reporting. True if the issue affects a key control supporting financial statement assertions under SOX Section 404.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:threeLinesPosition rdf:type rdf:Property ;
    rdfs:label 'Three Lines Position' ;
    rdfs:comment 'Indicates which line of defense in the Three Lines Model is responsible for remediation. First line (business operations), second line (risk and compliance oversight), or third line (internal audit).' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationDate rdf:type rdf:Property ;
    rdfs:label 'Validation Date' ;
    rdfs:comment 'Date when audit validation testing was completed. Null if validation has not yet occurred.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validationStatus rdf:type rdf:Property ;
    rdfs:label 'Validation Status' ;
    rdfs:comment 'Status of audit validation testing to confirm remediation effectiveness. Not_started indicates remediation not yet complete. In_progress indicates validation testing underway. Passed indicates successful validation. Failed indicates remediation did not address the issue. Deferred indicates validation postponed.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationId rdf:type rdf:Property ;
    rdfs:label 'Notification Id' ;
    rdfs:comment 'Unique identifier for the audit notification record. Primary key.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:notificationRecipientEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Notification Recipient Employee Id' ;
    rdfs:comment 'Employee identifier of the primary recipient.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:notificationSenderEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Notification Sender Employee Id' ;
    rdfs:comment 'Employee identifier of the individual issuing the notification.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:acknowledgementDate rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Date' ;
    rdfs:comment 'Date on which the recipient formally acknowledged receipt of the notification.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:acknowledgementReceivedFlag rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Received Flag' ;
    rdfs:comment 'Indicator of whether acknowledgement of receipt has been received from the recipient.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:acknowledgementRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Required Flag' ;
    rdfs:comment 'Indicator of whether formal acknowledgement of receipt is required from the recipient.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:attachmentCount rdf:type rdf:Property ;
    rdfs:label 'Attachment Count' ;
    rdfs:comment 'Number of attachments or supporting documents included with the notification.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:body rdf:type rdf:Property ;
    rdfs:label 'Body' ;
    rdfs:comment 'Full text content of the audit notification message or letter body.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessUnitNotified rdf:type rdf:Property ;
    rdfs:label 'Business Unit Notified' ;
    rdfs:comment 'Name of the business unit, department, or division that is the subject of the audit notification.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ccRecipients rdf:type rdf:Property ;
    rdfs:label 'Cc Recipients' ;
    rdfs:comment 'Comma-separated list of additional recipients copied on the notification, including names and email addresses.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationChannel rdf:type rdf:Property ;
    rdfs:label 'Communication Channel' ;
    rdfs:comment 'Channel or medium through which the notification was delivered: email, postal mail, secure portal, hand delivery, registered mail, or electronic signature platform.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryCode rdf:type rdf:Property ;
    rdfs:label 'Country Code' ;
    rdfs:comment 'Three-letter ISO country code for the jurisdiction relevant to the notification.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysToRespond rdf:type rdf:Property ;
    rdfs:label 'Days To Respond' ;
    rdfs:comment 'Number of calendar days between notification issuance and response receipt, used for performance tracking.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryConfirmationDate rdf:type rdf:Property ;
    rdfs:label 'Delivery Confirmation Date' ;
    rdfs:comment 'Date on which delivery confirmation was received.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deliveryConfirmationFlag rdf:type rdf:Property ;
    rdfs:label 'Delivery Confirmation Flag' ;
    rdfs:comment 'Indicator of whether delivery confirmation was received for the notification.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geographicRegion rdf:type rdf:Property ;
    rdfs:label 'Geographic Region' ;
    rdfs:comment 'Geographic region or jurisdiction relevant to the notification, such as North America, EMEA, APAC.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalEntityName rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Name' ;
    rdfs:comment 'Legal entity name to which the notification applies, relevant for multi-entity banking organizations.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationNumber rdf:type rdf:Property ;
    rdfs:label 'Notification Number' ;
    rdfs:comment 'Business-facing unique reference number for the audit notification, used for tracking and correspondence.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationStatus rdf:type rdf:Property ;
    rdfs:label 'Notification Status' ;
    rdfs:comment 'Current lifecycle status of the notification: draft, pending approval, approved, issued, acknowledged by recipient, overdue response, or cancelled. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|issued|acknowledged|overdue|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationType rdf:type rdf:Property ;
    rdfs:label 'Notification Type' ;
    rdfs:comment 'Type of audit communication being issued: engagement announcement letter, information request list (IRL), draft report issuance, management response request, final report distribution, or follow-up notice.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overdueFlag rdf:type rdf:Property ;
    rdfs:label 'Overdue Flag' ;
    rdfs:comment 'Indicator of whether the response is overdue based on the response due date.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorityLevel rdf:type rdf:Property ;
    rdfs:label 'Priority Level' ;
    rdfs:comment 'Priority classification of the notification based on urgency and business impact.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientEmail rdf:type rdf:Property ;
    rdfs:label 'Recipient Email' ;
    rdfs:comment 'Email address of the primary recipient.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientName rdf:type rdf:Property ;
    rdfs:label 'Recipient Name' ;
    rdfs:comment 'Name of the primary recipient of the audit notification, typically the business unit head or process owner.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientTitle rdf:type rdf:Property ;
    rdfs:label 'Recipient Title' ;
    rdfs:comment 'Job title or role of the primary recipient.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryExaminationFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Examination Flag' ;
    rdfs:comment 'Indicator of whether this notification is related to a regulatory examination or external audit coordination.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responseDueDate rdf:type rdf:Property ;
    rdfs:label 'Response Due Date' ;
    rdfs:comment 'Date by which the recipient is required to respond to the notification, applicable for information requests and management response requests.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responseReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Response Received Date' ;
    rdfs:comment 'Date on which the response to the notification was received from the recipient.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responseReceivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Response Received Timestamp' ;
    rdfs:comment 'Precise timestamp when the response was received, supporting Service Level Agreement (SLA) tracking.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:senderEmail rdf:type rdf:Property ;
    rdfs:label 'Sender Email' ;
    rdfs:comment 'Email address of the notification sender for correspondence and replies.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:senderName rdf:type rdf:Property ;
    rdfs:label 'Sender Name' ;
    rdfs:comment 'Name of the individual or role issuing the notification, typically the lead auditor or Chief Audit Executive (CAE).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:senderTitle rdf:type rdf:Property ;
    rdfs:label 'Sender Title' ;
    rdfs:comment 'Job title or role of the individual issuing the notification.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectLine rdf:type rdf:Property ;
    rdfs:label 'Subject Line' ;
    rdfs:comment 'Subject line or title of the audit notification communication.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:threeLinesOfDefenseLevel rdf:type rdf:Property ;
    rdfs:label 'Three Lines Of Defense Level' ;
    rdfs:comment 'The line of defense within the three lines model that this notification pertains to: first line (business operations), second line (risk and compliance), or third line (internal audit).' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorPlanId rdf:type rdf:Property ;
    rdfs:label 'Prior Plan Id' ;
    rdfs:comment 'Reference to the previous audit plan that this plan supersedes or follows. Enables year-over-year comparison and continuity tracking.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Plan .

ind:regulatoryCalendarId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Calendar Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_calendar. Business justification: Audit plans must coordinate with regulatory filing deadlines to ensure pre-submission validation. Auditors schedule engagements around critical filings (Call Reports, CCAR, AML certifications) to prov' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryCalendar .

ind:advisoryHours rdf:type rdf:Property ;
    rdfs:label 'Advisory Hours' ;
    rdfs:comment 'The number of hours allocated to advisory and consulting services. Represents non-assurance activities where internal audit provides guidance on risk, control, and governance matters.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvalCommittee rdf:type rdf:Property ;
    rdfs:label 'Approval Committee' ;
    rdfs:comment 'The name of the committee or board that approved the audit plan, typically the Audit Committee of the Board of Directors. Documents governance oversight.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assuranceHours rdf:type rdf:Property ;
    rdfs:label 'Assurance Hours' ;
    rdfs:comment 'The number of hours allocated to assurance engagements. Represents traditional audit activities that provide independent assessment of risk management, control, and governance processes.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditUniverseCount rdf:type rdf:Property ;
    rdfs:label 'Audit Universe Count' ;
    rdfs:comment 'The total number of auditable entities in the audit universe for this plan. Represents the complete population of business units, processes, systems, and functions that could be audited.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:combinedAssuranceApproach rdf:type rdf:Property ;
    rdfs:label 'Combined Assurance Approach' ;
    rdfs:comment 'Indicates whether the audit plan incorporates a combined assurance approach that integrates assurance activities across all three lines of defense to optimize coverage and reduce duplication.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contingencyHours rdf:type rdf:Property ;
    rdfs:label 'Contingency Hours' ;
    rdfs:comment 'The number of audit hours reserved for unplanned or emerging risk audits. Provides flexibility to respond to unexpected events, regulatory requests, or management concerns during the plan period.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coveragePercentage rdf:type rdf:Property ;
    rdfs:label 'Coverage Percentage' ;
    rdfs:comment 'The percentage of the audit universe covered by planned audits, calculated as (planned_audit_count / audit_universe_count) * 100. Key metric for assessing adequacy of audit coverage.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:externalAuditCoordination rdf:type rdf:Property ;
    rdfs:label 'External Audit Coordination' ;
    rdfs:comment 'Indicates whether the audit plan includes coordination with external auditors to leverage their work and avoid duplication of effort.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:financialCoveragePercentage rdf:type rdf:Property ;
    rdfs:label 'Financial Coverage Percentage' ;
    rdfs:comment 'The percentage of planned audit hours allocated to financial and accounting audits. Supports financial statement audit coordination and SOX compliance.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:itCoveragePercentage rdf:type rdf:Property ;
    rdfs:label 'It Coverage Percentage' ;
    rdfs:comment 'The percentage of planned audit hours allocated to information technology and cybersecurity audits. Critical for digital banking risk management.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:keyRiskThemes rdf:type rdf:Property ;
    rdfs:label 'Key Risk Themes' ;
    rdfs:comment 'Summary of the primary risk themes driving audit plan prioritization, such as cybersecurity, regulatory change, credit risk, operational resilience, or digital transformation. Communicates risk focus to the Audit Committee.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastRevisionDate rdf:type rdf:Property ;
    rdfs:label 'Last Revision Date' ;
    rdfs:comment 'The date when the audit plan was last revised or updated. Material changes to the approved plan require Audit Committee notification or re-approval.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operationalCoveragePercentage rdf:type rdf:Property ;
    rdfs:label 'Operational Coverage Percentage' ;
    rdfs:comment 'The percentage of planned audit hours allocated to operational and process audits. Balances regulatory focus with operational effectiveness and efficiency objectives.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planDescription rdf:type rdf:Property ;
    rdfs:label 'Plan Description' ;
    rdfs:comment 'Detailed narrative description of the audit plan scope, objectives, key focus areas, and strategic alignment. Provides context for stakeholders reviewing the plan.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planName rdf:type rdf:Property ;
    rdfs:label 'Plan Name' ;
    rdfs:comment 'The formal name or title of the audit plan, typically including the year and scope (e.g., \'FY2024 Enterprise Internal Audit Plan\').' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planStatus rdf:type rdf:Property ;
    rdfs:label 'Plan Status' ;
    rdfs:comment 'Current lifecycle status of the audit plan. Draft indicates initial development, submitted means awaiting approval, approved indicates board/committee endorsement, active means currently in execution, completed means all planned audits finished, superseded means replaced by a newer plan, and cancelled means plan was terminated. [ENUM-REF-CANDIDATE: draft|submitted|approved|active|completed|superseded|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planType rdf:type rdf:Property ;
    rdfs:label 'Plan Type' ;
    rdfs:comment 'The type or duration scope of the audit plan. Annual plans cover a single fiscal year, multi-year plans span multiple years, quarterly plans are short-term tactical plans, ad-hoc plans address emerging risks, and continuous plans support ongoing monitoring programs.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedAuditCount rdf:type rdf:Property ;
    rdfs:label 'Planned Audit Count' ;
    rdfs:comment 'The number of individual audit engagements planned for execution during this plan period. Subset of the audit universe selected based on risk assessment and resource availability.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:planningMethodology rdf:type rdf:Property ;
    rdfs:label 'Planning Methodology' ;
    rdfs:comment 'The methodology used to develop the audit plan. Risk-based prioritizes high-risk areas, cyclical ensures periodic coverage of all areas, regulatory-driven focuses on compliance requirements, hybrid combines multiple approaches, continuous monitoring emphasizes real-time assurance, and combined assurance integrates three lines of defense.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryCoveragePercentage rdf:type rdf:Property ;
    rdfs:label 'Regulatory Coverage Percentage' ;
    rdfs:comment 'The percentage of planned audit hours allocated to regulatory and compliance audits. Key metric for demonstrating adequate coverage of regulatory obligations to supervisory authorities.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryExamCoordination rdf:type rdf:Property ;
    rdfs:label 'Regulatory Exam Coordination' ;
    rdfs:comment 'Indicates whether the audit plan considers timing and scope of regulatory examinations to support preparation and follow-up activities.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resourceConstraintNotes rdf:type rdf:Property ;
    rdfs:label 'Resource Constraint Notes' ;
    rdfs:comment 'Documentation of any resource constraints or limitations that affected plan development, such as staffing shortages, budget limitations, or skill gaps. Important for managing stakeholder expectations.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Date' ;
    rdfs:comment 'The date when the enterprise risk assessment was completed to inform audit plan prioritization. Critical input for risk-based audit planning.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:strategicAlignmentNotes rdf:type rdf:Property ;
    rdfs:label 'Strategic Alignment Notes' ;
    rdfs:comment 'Explanation of how the audit plan aligns with the organizations strategic objectives and priorities. Demonstrates value-add of internal audit to enterprise strategy execution.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submittedDate rdf:type rdf:Property ;
    rdfs:label 'Submitted Date' ;
    rdfs:comment 'The date when the audit plan was formally submitted to the Audit Committee or Board for approval. Tracks governance process timeline.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:threeLinesModelAlignment rdf:type rdf:Property ;
    rdfs:label 'Three Lines Model Alignment' ;
    rdfs:comment 'Indicates whether the audit plan is aligned with the three lines of defense governance model. Aligned means plan coordinates with first line (business) and second line (risk/compliance) activities, partial means some coordination, not aligned means independent planning.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:year rdf:type rdf:Property ;
    rdfs:label 'Year' ;
    rdfs:comment 'The fiscal or calendar year for which this audit plan is defined. Represents the primary planning horizon for internal audit activities.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:programId rdf:type rdf:Property ;
    rdfs:label 'Program Id' ;
    rdfs:comment 'Unique identifier for the audit program. Primary key for the audit program entity.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceSoxControlId rdf:type rdf:Property ;
    rdfs:label 'Compliance Sox Control Id' ;
    rdfs:comment 'Foreign key linking to compliance.sox_control. Business justification: Audit programs test specific SOX controls for design and operating effectiveness. This is the fundamental link between control documentation (compliance) and control testing (audit), required for SOX ' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ComplianceSoxControl .

ind:programApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Program Approved By Employee Id' ;
    rdfs:comment 'Reference to the audit manager or director who approved this audit program for execution. Establishes accountability for program design.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:programEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Program Employee Id' ;
    rdfs:comment 'Reference to the staff member assigned as lead auditor responsible for executing this audit program and coordinating fieldwork.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:reviewerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Reviewer Employee Id' ;
    rdfs:comment 'Reference to the senior auditor or manager assigned to review the work performed under this audit program for quality assurance.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:auditCommitteeReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Audit Committee Reporting Flag' ;
    rdfs:comment 'Indicates whether results from this audit program will be reported to the Audit Committee of the Board of Directors. True for high-risk or material programs.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:automatedControlFlag rdf:type rdf:Property ;
    rdfs:label 'Automated Control Flag' ;
    rdfs:comment 'Indicates whether this audit program tests automated controls (system-enforced controls). True if program includes testing of IT general controls or application controls.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:completionPercentage rdf:type rdf:Property ;
    rdfs:label 'Completion Percentage' ;
    rdfs:comment 'Percentage of audit program steps completed (0.00 to 100.00). Calculated as (completed steps / total steps) * 100. Used for progress tracking and reporting.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:controlObjective rdf:type rdf:Property ;
    rdfs:label 'Control Objective' ;
    rdfs:comment 'High-level control objective that the audit program is designed to test (e.g., Ensure all loan disbursements are properly authorized and recorded). Aligns with COSO framework control objectives.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cosoComponent rdf:type rdf:Property ;
    rdfs:label 'Coso Component' ;
    rdfs:comment 'COSO Internal Control Framework component addressed by this program: control_environment (tone at the top), risk_assessment (risk identification), control_activities (policies and procedures), information_communication (data flow), or monitoring (ongoing evaluation).' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataAnalyticsFlag rdf:type rdf:Property ;
    rdfs:label 'Data Analytics Flag' ;
    rdfs:comment 'Indicates whether this audit program employs data analytics techniques (e.g., full population testing, trend analysis, anomaly detection). True if program uses advanced analytical methods.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Hours' ;
    rdfs:comment 'Planned number of audit hours required to complete this program. Used for resource planning and budget tracking.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedEvidenceType rdf:type rdf:Property ;
    rdfs:label 'Expected Evidence Type' ;
    rdfs:comment 'Description of the evidence expected to be collected during program execution (e.g., signed approval forms, system reports, reconciliation worksheets, email confirmations). Guides auditor documentation requirements.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalAuditorRelianceFlag rdf:type rdf:Property ;
    rdfs:label 'External Auditor Reliance Flag' ;
    rdfs:comment 'Indicates whether external auditors plan to rely on the work performed under this audit program for their financial statement audit. True if program meets external audit standards.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:findingsCount rdf:type rdf:Property ;
    rdfs:label 'Findings Count' ;
    rdfs:comment 'Number of audit findings (control deficiencies, exceptions, observations) identified during execution of this audit program. Updated as testing progresses.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:keyControlFlag rdf:type rdf:Property ;
    rdfs:label 'Key Control Flag' ;
    rdfs:comment 'Indicates whether this audit program tests key controls (controls that are critical to mitigating significant risks). True if program focuses on key controls per risk assessment.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:populationSize rdf:type rdf:Property ;
    rdfs:label 'Population Size' ;
    rdfs:comment 'Total number of items or transactions in the population from which the sample is drawn. Used to calculate sampling risk and extrapolate findings.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:programCode rdf:type rdf:Property ;
    rdfs:label 'Program Code' ;
    rdfs:comment 'Standardized code for the audit program following organizational taxonomy (e.g., CR-2024, TRS-1001). Used for tracking and reporting.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programName rdf:type rdf:Property ;
    rdfs:label 'Program Name' ;
    rdfs:comment 'Descriptive name of the audit program identifying the area or process being tested (e.g., Loan Origination Controls Testing, Treasury Operations Review).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programStatus rdf:type rdf:Property ;
    rdfs:label 'Program Status' ;
    rdfs:comment 'Current lifecycle status of the audit program: draft (under development), approved (ready for execution), in_progress (fieldwork underway), completed (testing finished), on_hold (temporarily suspended), or cancelled (discontinued).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programType rdf:type rdf:Property ;
    rdfs:label 'Program Type' ;
    rdfs:comment 'Classification of the audit program by focus area: operational (process efficiency), financial (accounting controls), compliance (regulatory adherence), IT (technology controls), fraud (investigative), or regulatory (external examination support).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskArea rdf:type rdf:Property ;
    rdfs:label 'Risk Area' ;
    rdfs:comment 'Primary risk category addressed by this audit program per Basel III risk taxonomy: credit risk, market risk, operational risk, liquidity risk, compliance risk, or reputational risk.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleSize rdf:type rdf:Property ;
    rdfs:label 'Sample Size' ;
    rdfs:comment 'Number of items or transactions selected for testing in this audit program. Determined based on risk assessment, population size, and desired confidence level.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:samplingMethod rdf:type rdf:Property ;
    rdfs:label 'Sampling Method' ;
    rdfs:comment 'Sampling approach used for test selection: judgmental (risk-based selection), statistical (probability-based), random (unbiased selection), stratified (segmented population), monetary_unit (dollar-weighted), or full_population (100% testing).' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeDescription rdf:type rdf:Property ;
    rdfs:label 'Scope Description' ;
    rdfs:comment 'Detailed description of the audit program scope including processes, systems, business units, and time periods covered. Defines boundaries of the testing effort.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testApproach rdf:type rdf:Property ;
    rdfs:label 'Test Approach' ;
    rdfs:comment 'Primary testing methodology employed in this program: walkthrough (process understanding), substantive (transaction testing), controls_testing (design and operating effectiveness), data_analytics (population analysis), inquiry (interviews), observation (process witnessing), inspection (document review), or reperformance (independent execution). [ENUM-REF-CANDIDATE: walkthrough|substantive|controls_testing|data_analytics|inquiry|observation|inspection|reperformance — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Test Period End Date' ;
    rdfs:comment 'Ending date of the period covered by this audit program testing (e.g., 2024-12-31). Defines the temporal scope of audit procedures.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:testPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Test Period Start Date' ;
    rdfs:comment 'Beginning date of the period covered by this audit program testing (e.g., 2024-01-01). Defines the temporal scope of audit procedures.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:threeLinesModelLine rdf:type rdf:Property ;
    rdfs:label 'Three Lines Model Line' ;
    rdfs:comment 'Identifies which line of defense this audit program evaluates per the IIA Three Lines Model: first_line (operational management), second_line (risk and compliance oversight), or third_line (internal audit).' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workpaperReference rdf:type rdf:Property ;
    rdfs:label 'Workpaper Reference' ;
    rdfs:comment 'Reference code or identifier linking this audit program to the corresponding audit workpapers and documentation repository (e.g., WP-CR-2024-001). Supports audit trail and evidence management.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditReportId rdf:type rdf:Property ;
    rdfs:label 'Audit Report Id' ;
    rdfs:comment 'Unique identifier for the audit report record. Primary key for the audit report entity.' ;
    rdfs:domain ind:AuditReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditDirectorName rdf:type rdf:Property ;
    rdfs:label 'Audit Director Name' ;
    rdfs:comment 'Name of the audit director or Chief Audit Executive (CAE) who reviewed and approved the audit report. Accountable for audit quality and independence.' ;
    rdfs:domain ind:AuditReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditObjective rdf:type rdf:Property ;
    rdfs:label 'Audit Objective' ;
    rdfs:comment 'Statement of the specific goals and intended outcomes of the audit engagement. Defines what the audit was designed to accomplish and the questions it sought to answer.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backgroundContext rdf:type rdf:Property ;
    rdfs:label 'Background Context' ;
    rdfs:comment 'Descriptive information about the audited area including business processes, organizational structure, regulatory environment, and prior audit history. Provides context for understanding the audit scope and findings.' ;
    rdfs:domain ind:AuditReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Critical Findings Count' ;
    rdfs:comment 'Number of critical-severity findings identified in the audit. Critical findings represent significant control deficiencies with high likelihood and impact that require immediate management attention and Board notification.' ;
    rdfs:domain ind:AuditReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:distributionList rdf:type rdf:Property ;
    rdfs:label 'Distribution List' ;
    rdfs:comment 'List of individuals and roles who received the audit report including business unit management, executive leadership, Audit Committee members, and regulatory examiners. Documents report dissemination for governance and compliance purposes.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executiveSummary rdf:type rdf:Property ;
    rdfs:label 'Executive Summary' ;
    rdfs:comment 'High-level overview of the audit objectives, scope, key findings, and conclusions. Provides senior management and the Audit Committee with a concise understanding of the engagement results without requiring detailed review.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpDueDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Due Date' ;
    rdfs:comment 'Target date for conducting follow-up audit procedures to verify remediation of findings. Typically set based on management\'s committed action plan completion dates.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:followUpRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Follow Up Required Flag' ;
    rdfs:comment 'Indicator of whether this audit report requires formal follow-up audit work to validate implementation of management action plans. True indicates follow-up audit is scheduled.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:highFindingsCount rdf:type rdf:Property ;
    rdfs:label 'High Findings Count' ;
    rdfs:comment 'Number of high-severity findings identified in the audit. High findings represent material control weaknesses that could result in significant financial, operational, or reputational impact.' ;
    rdfs:domain ind:AuditReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:issuanceDate rdf:type rdf:Property ;
    rdfs:label 'Issuance Date' ;
    rdfs:comment 'Official date the audit report was formally issued to management and the Audit Committee. Marks the beginning of management response and remediation tracking timelines.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leadAuditorName rdf:type rdf:Property ;
    rdfs:label 'Lead Auditor Name' ;
    rdfs:comment 'Name of the senior auditor who led the engagement and is responsible for the report content and conclusions. Primary point of contact for questions and follow-up.' ;
    rdfs:domain ind:AuditReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lowFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Low Findings Count' ;
    rdfs:comment 'Number of low-severity findings identified in the audit. Low findings represent minor control weaknesses or opportunities for process improvement.' ;
    rdfs:domain ind:AuditReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:managementAgreementFlag rdf:type rdf:Property ;
    rdfs:label 'Management Agreement Flag' ;
    rdfs:comment 'Indicator of whether management agrees with the audit findings and conclusions. True indicates full agreement, false indicates disagreement requiring escalation and documentation of differing views.' ;
    rdfs:domain ind:AuditReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:managementResponseSummary rdf:type rdf:Property ;
    rdfs:label 'Management Response Summary' ;
    rdfs:comment 'Consolidated summary of management\'s formal responses to audit findings including agreement or disagreement with findings, planned corrective actions, responsible parties, and target completion dates.' ;
    rdfs:domain ind:AuditReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediumFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Medium Findings Count' ;
    rdfs:comment 'Number of medium-severity findings identified in the audit. Medium findings represent control weaknesses that should be addressed but do not pose immediate significant risk.' ;
    rdfs:domain ind:AuditReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:methodologyDescription rdf:type rdf:Property ;
    rdfs:label 'Methodology Description' ;
    rdfs:comment 'Explanation of the audit approach, techniques, and procedures employed including interviews, walkthroughs, testing, data analytics, and sampling methods. Documents how the audit work was performed.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallAuditOpinion rdf:type rdf:Property ;
    rdfs:label 'Overall Audit Opinion' ;
    rdfs:comment 'Summary assessment of the adequacy and effectiveness of governance, risk management, and control processes within the audited area. Satisfactory indicates effective controls, needs improvement indicates control weaknesses requiring attention, unsatisfactory indicates significant deficiencies, and no opinion indicates scope limitations prevented a conclusion.' ;
    rdfs:domain ind:AuditReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positiveObservations rdf:type rdf:Property ;
    rdfs:label 'Positive Observations' ;
    rdfs:comment 'Documentation of effective controls, best practices, and areas of strong performance identified during the audit. Provides balanced reporting and recognizes effective risk management.' ;
    rdfs:domain ind:AuditReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityAssuranceReviewFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Assurance Review Flag' ;
    rdfs:comment 'Indicator of whether this audit report underwent independent quality assurance review by a senior auditor not involved in the engagement. True indicates QA review was performed per IIA standards.' ;
    rdfs:domain ind:AuditReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportNumber rdf:type rdf:Property ;
    rdfs:label 'Report Number' ;
    rdfs:comment 'Business identifier for the audit report, typically following organizational numbering conventions (e.g., IA-2024-001). Used for external reference and tracking.' ;
    rdfs:domain ind:AuditReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxScopeFlag rdf:type rdf:Property ;
    rdfs:label 'Sox Scope Flag' ;
    rdfs:comment 'Indicator of whether this audit report covers controls within the scope of Sarbanes-Oxley Act Section 404 internal control over financial reporting requirements. True indicates SOX-relevant controls were examined.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:title rdf:type rdf:Property ;
    rdfs:label 'Title' ;
    rdfs:comment 'Formal title of the audit report that describes the subject matter and scope of the engagement (e.g., \'Commercial Lending Credit Underwriting Process Audit\').' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Total Findings Count' ;
    rdfs:comment 'Total number of audit findings across all severity levels. Provides an aggregate measure of control deficiencies identified during the engagement.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:resourceId rdf:type rdf:Property ;
    rdfs:label 'Resource Id' ;
    rdfs:comment 'Unique identifier for the audit resource record. Primary key for the audit resource master data.' ;
    rdfs:domain ind:Resource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:currentEngagementId rdf:type rdf:Property ;
    rdfs:label 'Current Engagement Id' ;
    rdfs:comment 'Foreign key reference to the current active audit engagement the resource is assigned to. Null if the resource is currently unassigned or on administrative leave.' ;
    rdfs:domain ind:Resource ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Engagement .

ind:resourceEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Resource Employee Id' ;
    rdfs:comment 'Foreign key reference to the employee master record in the Human Resources (HR) domain. Links the audit resource to their core HR profile for payroll, benefits, and organizational hierarchy.' ;
    rdfs:domain ind:Resource ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:resourceReportingLineManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Resource Reporting Line Manager Employee Id' ;
    rdfs:comment 'Foreign key reference to the employee ID of the auditors direct line manager within the internal audit function. Used for performance management and organizational hierarchy reporting.' ;
    rdfs:domain ind:Resource ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:auditGrade rdf:type rdf:Property ;
    rdfs:label 'Audit Grade' ;
    rdfs:comment 'Hierarchical grade or level of the auditor within the internal audit organization. Used for resource planning, assignment complexity matching, and career progression tracking.' ;
    rdfs:domain ind:Resource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditorName rdf:type rdf:Property ;
    rdfs:label 'Auditor Name' ;
    rdfs:comment 'Full legal name of the internal auditor. Used for audit report attribution, engagement assignment, and audit committee reporting.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Availability Status' ;
    rdfs:comment 'Current availability status of the audit resource for new engagement assignments. Critical for real-time resource planning and audit plan execution.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availableCapacityPercentage rdf:type rdf:Property ;
    rdfs:label 'Available Capacity Percentage' ;
    rdfs:comment 'Percentage of the auditors time currently available for new audit assignments (0-100). Calculated based on current engagement workload, administrative duties, and planned time off.' ;
    rdfs:domain ind:Resource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:backgroundCheckDate rdf:type rdf:Property ;
    rdfs:label 'Background Check Date' ;
    rdfs:comment 'Date of the most recent background check performed on the auditor. Required for regulatory compliance and audit committee reporting. Typically refreshed every 3-5 years.' ;
    rdfs:domain ind:Resource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cfeCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Cfe Certified Flag' ;
    rdfs:comment 'Indicates whether the auditor holds the Certified Fraud Examiner (CFE) professional certification from the Association of Certified Fraud Examiners (ACFE). Critical for fraud investigation, Anti-Money Laundering (AML) audit, and forensic audit assignments.' ;
    rdfs:domain ind:Resource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ciaCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Cia Certified Flag' ;
    rdfs:comment 'Indicates whether the auditor holds the Certified Internal Auditor (CIA) professional certification from the Institute of Internal Auditors (IIA). Critical for regulatory audit assignments and audit committee credibility.' ;
    rdfs:domain ind:Resource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cisaCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Cisa Certified Flag' ;
    rdfs:comment 'Indicates whether the auditor holds the Certified Information Systems Auditor (CISA) professional certification from ISACA. Essential for IT audit, cybersecurity audit, and technology risk assessment engagements.' ;
    rdfs:domain ind:Resource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:continuousProfessionalEducationHours rdf:type rdf:Property ;
    rdfs:label 'Continuous Professional Education Hours' ;
    rdfs:comment 'Total number of Continuous Professional Education (CPE) hours completed by the auditor in the current reporting period. Required for maintaining professional certifications (CIA, CPA, CISA) and regulatory compliance.' ;
    rdfs:domain ind:Resource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cpaCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Cpa Certified Flag' ;
    rdfs:comment 'Indicates whether the auditor holds the Certified Public Accountant (CPA) professional certification. Relevant for financial statement audits, Sarbanes-Oxley Act (SOX) compliance, and General Ledger (GL) audits.' ;
    rdfs:domain ind:Resource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currentEngagementRole rdf:type rdf:Property ;
    rdfs:label 'Current Engagement Role' ;
    rdfs:comment 'Role the auditor is performing on their current engagement (e.g., Lead Auditor, Team Member, Subject Matter Expert). Used for workload balancing and engagement oversight.' ;
    rdfs:domain ind:Resource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frmCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Frm Certified Flag' ;
    rdfs:comment 'Indicates whether the auditor holds the Financial Risk Manager (FRM) professional certification from the Global Association of Risk Professionals (GARP). Relevant for market risk, credit risk, operational risk, and Basel III compliance audit engagements.' ;
    rdfs:domain ind:Resource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hireDate rdf:type rdf:Property ;
    rdfs:label 'Hire Date' ;
    rdfs:comment 'Date the auditor was hired into the internal audit function at the institution. Used for tenure calculations, anniversary recognition, and retention analytics.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:homeOfficeLocation rdf:type rdf:Property ;
    rdfs:label 'Home Office Location' ;
    rdfs:comment 'Primary office location or city where the auditor is based. Used for travel planning, regional audit coverage, and cost center allocation.' ;
    rdfs:domain ind:Resource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:independenceAttestationDate rdf:type rdf:Property ;
    rdfs:label 'Independence Attestation Date' ;
    rdfs:comment 'Date of the most recent independence attestation signed by the auditor. Required annually per Institute of Internal Auditors (IIA) Standards to confirm the auditor has no conflicts of interest with audit subjects.' ;
    rdfs:domain ind:Resource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:jobTitle rdf:type rdf:Property ;
    rdfs:label 'Job Title' ;
    rdfs:comment 'Official job title of the audit resource within the internal audit function (e.g., Senior Auditor, Audit Manager, Chief Audit Executive, IT Audit Specialist).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageCapabilities rdf:type rdf:Property ;
    rdfs:label 'Language Capabilities' ;
    rdfs:comment 'Comma-separated list of languages the auditor is proficient in (e.g., English, Spanish, Mandarin, French). Critical for international audit assignments and cross-border regulatory examinations.' ;
    rdfs:domain ind:Resource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otherCertifications rdf:type rdf:Property ;
    rdfs:label 'Other Certifications' ;
    rdfs:comment 'Comma-separated list of additional professional certifications held by the auditor (e.g., CISM, CRISC, CFE, CFA, PMP). Supports specialized audit assignment matching and continuous professional development tracking.' ;
    rdfs:domain ind:Resource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryExpertiseArea rdf:type rdf:Property ;
    rdfs:label 'Primary Expertise Area' ;
    rdfs:comment 'Primary domain of audit expertise for the resource. Used for skills-based engagement assignment and capacity planning. Aligns with the banks Lines of Business (LOB) and risk taxonomy. [ENUM-REF-CANDIDATE: credit_risk|market_risk|operational_risk|aml|kyc|it_audit|cybersecurity|trading|regulatory_compliance|sox|basel|ifrs|treasury|wealth_management|retail_banking|investment_banking|payments|fraud|data_privacy|model_validation — 20 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Resource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resourceStatus rdf:type rdf:Property ;
    rdfs:label 'Resource Status' ;
    rdfs:comment 'Current employment status of the audit resource. Active resources are available for engagement assignment; terminated/retired resources are retained for historical audit trail purposes.' ;
    rdfs:domain ind:Resource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryExpertiseAreas rdf:type rdf:Property ;
    rdfs:label 'Secondary Expertise Areas' ;
    rdfs:comment 'Comma-separated list of secondary or supporting areas of audit expertise. Enables cross-functional audit assignments and resource flexibility during peak audit periods.' ;
    rdfs:domain ind:Resource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityClearanceLevel rdf:type rdf:Property ;
    rdfs:label 'Security Clearance Level' ;
    rdfs:comment 'Level of security clearance granted to the auditor for accessing sensitive systems, data, and facilities. Determines which audit engagements the resource is eligible for (e.g., board-level audits, cybersecurity audits).' ;
    rdfs:domain ind:Resource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yearsAtInstitution rdf:type rdf:Property ;
    rdfs:label 'Years At Institution' ;
    rdfs:comment 'Number of years the auditor has been employed at the current banking institution. Reflects institutional knowledge and familiarity with internal controls, systems, and culture.' ;
    rdfs:domain ind:Resource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yearsOfExperience rdf:type rdf:Property ;
    rdfs:label 'Years Of Experience' ;
    rdfs:comment 'Total years of professional audit experience, including both internal audit and external audit roles. Used for engagement complexity matching and mentorship program assignment.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Id' ;
    rdfs:comment 'Unique identifier for the audit risk assessment record.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryRiskEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Risk Employee Id' ;
    rdfs:comment 'Reference to the internal auditor or risk analyst who performed this risk assessment.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:universeId rdf:type rdf:Property ;
    rdfs:label 'Universe Id' ;
    rdfs:comment 'Reference to the auditable entity in the audit universe being assessed.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Universe .

ind:amlBsaScopeFlag rdf:type rdf:Property ;
    rdfs:label 'Aml Bsa Scope Flag' ;
    rdfs:comment 'Indicates whether this auditable entity is within the scope of AML/BSA compliance and monitoring programs.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assessmentCycle rdf:type rdf:Property ;
    rdfs:label 'Assessment Cycle' ;
    rdfs:comment 'The frequency or trigger for this risk assessment (annual, semi-annual, quarterly, event-driven, ad-hoc, continuous).' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentMethodology rdf:type rdf:Property ;
    rdfs:label 'Assessment Methodology' ;
    rdfs:comment 'The methodology used to perform this risk assessment (quantitative scoring, qualitative judgment, hybrid, scenario-based, heat-map).' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentNotes rdf:type rdf:Property ;
    rdfs:label 'Assessment Notes' ;
    rdfs:comment 'Free-text notes capturing additional context, rationale, or observations from the risk assessment process.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Period End Date' ;
    rdfs:comment 'The end date of the period covered by this risk assessment.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessmentPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Period Start Date' ;
    rdfs:comment 'The start date of the period covered by this risk assessment.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assessment Status' ;
    rdfs:comment 'Current lifecycle status of this risk assessment record (draft, in-review, approved, superseded, archived).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ccarDfastScopeFlag rdf:type rdf:Property ;
    rdfs:label 'Ccar Dfast Scope Flag' ;
    rdfs:comment 'Indicates whether this auditable entity is within the scope of CCAR or DFAST stress testing and capital planning processes.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ceclIfrs9ScopeFlag rdf:type rdf:Property ;
    rdfs:label 'Cecl Ifrs9 Scope Flag' ;
    rdfs:comment 'Indicates whether this auditable entity is within the scope of CECL or IFRS 9 expected credit loss modeling and reporting.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:changeActivityScore rdf:type rdf:Property ;
    rdfs:label 'Change Activity Score' ;
    rdfs:comment 'Risk score component reflecting the volume and significance of recent changes (system upgrades, process redesigns, organizational restructuring) affecting the entity.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complexityFactorScore rdf:type rdf:Property ;
    rdfs:label 'Complexity Factor Score' ;
    rdfs:comment 'Risk score component reflecting the operational and organizational complexity of the auditable entity.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:continuousMonitoringFlag rdf:type rdf:Property ;
    rdfs:label 'Continuous Monitoring Flag' ;
    rdfs:comment 'Indicates whether this auditable entity is subject to continuous monitoring or continuous auditing processes rather than periodic audits.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:controlEnvironmentRating rdf:type rdf:Property ;
    rdfs:label 'Control Environment Rating' ;
    rdfs:comment 'Qualitative assessment of the strength and maturity of the control environment for this auditable entity.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalAuditCoordinationFlag rdf:type rdf:Property ;
    rdfs:label 'External Audit Coordination Flag' ;
    rdfs:comment 'Indicates whether this auditable entity requires coordination with external auditors for reliance or joint testing.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:financialMaterialityScore rdf:type rdf:Property ;
    rdfs:label 'Financial Materiality Score' ;
    rdfs:comment 'Risk score component reflecting the financial significance of the entity in terms of revenue, assets, or risk-weighted assets (RWA).' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inherentRiskScore rdf:type rdf:Property ;
    rdfs:label 'Inherent Risk Score' ;
    rdfs:comment 'The calculated inherent risk score before considering controls, typically on a scale of 0-100 or 1-5.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:keyRiskIndicators rdf:type rdf:Property ;
    rdfs:label 'Key Risk Indicators' ;
    rdfs:comment 'Comma-separated list or description of key risk indicators monitored for this auditable entity to track risk trends.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextAssessmentDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Assessment Due Date' ;
    rdfs:comment 'The scheduled date for the next risk assessment of this auditable entity based on the assessment cycle.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priorFindingsScore rdf:type rdf:Property ;
    rdfs:label 'Prior Findings Score' ;
    rdfs:comment 'Risk score component reflecting the severity and volume of findings from prior audits, regulatory examinations, or continuous monitoring.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recommendedAuditFrequency rdf:type rdf:Property ;
    rdfs:label 'Recommended Audit Frequency' ;
    rdfs:comment 'The recommended frequency for auditing this entity based on the risk assessment results.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendedAuditScope rdf:type rdf:Property ;
    rdfs:label 'Recommended Audit Scope' ;
    rdfs:comment 'The recommended scope or depth of audit coverage for this entity based on risk assessment.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryExposureScore rdf:type rdf:Property ;
    rdfs:label 'Regulatory Exposure Score' ;
    rdfs:comment 'Risk score component reflecting the degree of regulatory scrutiny and compliance requirements applicable to the entity.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:residualRiskScore rdf:type rdf:Property ;
    rdfs:label 'Residual Risk Score' ;
    rdfs:comment 'The calculated residual risk score after considering the control environment, used for audit prioritization.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:riskAppetiteAlignment rdf:type rdf:Property ;
    rdfs:label 'Risk Appetite Alignment' ;
    rdfs:comment 'Indicates whether the residual risk for this entity is within the organizations stated risk appetite or tolerance levels.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskRanking rdf:type rdf:Property ;
    rdfs:label 'Risk Ranking' ;
    rdfs:comment 'The ordinal ranking of this auditable entity within the audit universe based on residual risk score, used for audit plan prioritization.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:riskTrend rdf:type rdf:Property ;
    rdfs:label 'Risk Trend' ;
    rdfs:comment 'The observed trend in risk level for this auditable entity compared to prior assessments (increasing, stable, decreasing, new-risk, emerging).' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceObligationId rdf:type rdf:Property ;
    rdfs:label 'Compliance Obligation Id' ;
    rdfs:comment 'Foreign key linking to compliance.obligation. Business justification: Compliance obligations define mandatory audit coverage. Audit universe entities must be mapped to obligations they satisfy (SOX, BSA/AML, CCAR) to determine audit frequency, scope, and methodology. Fu' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Obligation .

ind:geographicRegionId rdf:type rdf:Property ;
    rdfs:label 'Geographic Region Id' ;
    rdfs:comment 'Foreign key linking to reference.geographic_region. Business justification: Audit universe entities are organized by geographic regions for risk assessment, resource allocation, and regulatory coordination. Fundamental dimension for banking audit planning. Replaces text geogr' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GeographicRegion .

ind:industryCodeId rdf:type rdf:Property ;
    rdfs:label 'Industry Code Id' ;
    rdfs:comment 'Foreign key linking to reference.industry_code. Business justification: Audit universe includes counterparties and clients classified by industry for concentration risk assessment and industry-specific audit procedures. Required for credit risk audits and regulatory stres' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IndustryCode .

ind:referenceProductTypeId rdf:type rdf:Property ;
    rdfs:label 'Reference Product Type Id' ;
    rdfs:comment 'Foreign key linking to reference.product_type. Business justification: Audit universe includes banking product lines (loans, deposits, derivatives, securities) requiring product-specific risk assessment and audit procedures. Banking audits are fundamentally organized by ' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductType .

ind:regulatoryChangeId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Change Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_change. Business justification: Regulatory changes trigger risk reassessment of audit universe entities. Audit planning must document which regulatory changes necessitate coverage of specific entities, driving audit frequency, scope' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryChange .

ind:annualRevenueImpact rdf:type rdf:Property ;
    rdfs:label 'Annual Revenue Impact' ;
    rdfs:comment 'Estimated annual revenue in USD associated with or generated by this auditable entity, used for risk prioritization.' ;
    rdfs:domain ind:Universe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assetValue rdf:type rdf:Property ;
    rdfs:label 'Asset Value' ;
    rdfs:comment 'Total asset value in USD under management or control of this auditable entity, relevant for risk assessment.' ;
    rdfs:domain ind:Universe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditCoverageStatus rdf:type rdf:Property ;
    rdfs:label 'Audit Coverage Status' ;
    rdfs:comment 'Current status of audit coverage for this entity indicating whether it is current, overdue for audit, upcoming, or not yet scheduled.' ;
    rdfs:domain ind:Universe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Audit Frequency Months' ;
    rdfs:comment 'The standard audit cycle frequency in months for this entity based on its risk rating (e.g., 12, 24, 36 months).' ;
    rdfs:domain ind:Universe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:entityCode rdf:type rdf:Property ;
    rdfs:label 'Entity Code' ;
    rdfs:comment 'Standardized code or identifier used to reference the auditable entity across audit documentation and systems.' ;
    rdfs:domain ind:Universe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entityDescription rdf:type rdf:Property ;
    rdfs:label 'Entity Description' ;
    rdfs:comment 'Detailed description of the auditable entity including its scope, purpose, and key characteristics relevant to audit planning.' ;
    rdfs:domain ind:Universe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entityName rdf:type rdf:Property ;
    rdfs:label 'Entity Name' ;
    rdfs:comment 'The official name or title of the auditable entity (business unit, process, system, legal entity, or product line).' ;
    rdfs:domain ind:Universe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entityStatus rdf:type rdf:Property ;
    rdfs:label 'Entity Status' ;
    rdfs:comment 'Current operational status of the auditable entity within the organization (active, inactive, merged, divested, under review).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entityType rdf:type rdf:Property ;
    rdfs:label 'Entity Type' ;
    rdfs:comment 'Classification of the auditable entity indicating whether it is a business process, IT system, legal entity, product line, business unit, or control framework.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:highPriorityFindingsCount rdf:type rdf:Property ;
    rdfs:label 'High Priority Findings Count' ;
    rdfs:comment 'The current number of high-priority or critical audit findings associated with this entity requiring immediate management attention.' ;
    rdfs:domain ind:Universe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastAuditRating rdf:type rdf:Property ;
    rdfs:label 'Last Audit Rating' ;
    rdfs:comment 'The overall audit rating or opinion issued in the most recent audit (satisfactory, needs improvement, unsatisfactory, not rated).' ;
    rdfs:domain ind:Universe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAuditType rdf:type rdf:Property ;
    rdfs:label 'Last Audit Type' ;
    rdfs:comment 'The type or scope of the most recent audit conducted (comprehensive, focused, follow-up, advisory, continuous monitoring).' ;
    rdfs:domain ind:Universe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastRiskAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Risk Assessment Date' ;
    rdfs:comment 'The date when the most recent risk assessment was performed for this auditable entity.' ;
    rdfs:domain ind:Universe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:materialityThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Materiality Threshold Amount' ;
    rdfs:comment 'The financial materiality threshold in USD used to assess the significance of findings and risks for this auditable entity.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextRiskAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Next Risk Assessment Date' ;
    rdfs:comment 'The scheduled date for the next risk assessment of this auditable entity.' ;
    rdfs:domain ind:Universe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextScheduledAuditDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Audit Date' ;
    rdfs:comment 'The planned date for the next scheduled audit of this entity based on the risk-based audit plan.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:overdueFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Overdue Findings Count' ;
    rdfs:comment 'The current number of audit findings for this entity where the agreed remediation date has passed without closure.' ;
    rdfs:domain ind:Universe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:owningDivision rdf:type rdf:Property ;
    rdfs:label 'Owning Division' ;
    rdfs:comment 'The business division, department, or organizational unit that owns and is accountable for the auditable entity.' ;
    rdfs:domain ind:Universe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryRelevanceFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Relevance Flag' ;
    rdfs:comment 'Indicator of whether the auditable entity is subject to specific regulatory oversight or compliance requirements (True/False).' ;
    rdfs:domain ind:Universe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rwaAllocation rdf:type rdf:Property ;
    rdfs:label 'Rwa Allocation' ;
    rdfs:comment 'The amount of risk-weighted assets in USD allocated to this auditable entity under Basel III capital adequacy framework.' ;
    rdfs:domain ind:Universe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:updatedBy rdf:type rdf:Property ;
    rdfs:label 'Updated By' ;
    rdfs:comment 'The user ID or system identifier of the person or process that last updated this audit universe record.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caeCharterId rdf:type rdf:Property ;
    rdfs:label 'Cae Charter Id' ;
    rdfs:comment 'Unique identifier for the Chief Audit Executive charter record. Primary key for the charter governance document.' ;
    rdfs:domain ind:CaeCharter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supersededCharterCaeCharterId rdf:type rdf:Property ;
    rdfs:label 'Superseded Charter Cae Charter Id' ;
    rdfs:comment 'Reference to the previous charter version that this charter supersedes, maintaining version lineage and governance history.' ;
    rdfs:domain ind:CaeCharter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CaeCharter .

ind:administrativeReportingLine rdf:type rdf:Property ;
    rdfs:label 'Administrative Reporting Line' ;
    rdfs:comment 'Defines the administrative reporting relationship of the Chief Audit Executive, typically to the Chief Executive Officer (CEO) or Chief Financial Officer (CFO), for day-to-day operational matters.' ;
    rdfs:domain ind:CaeCharter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualReviewRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Annual Review Requirement Flag' ;
    rdfs:comment 'Indicates whether the charter requires annual review and reaffirmation by the Audit Committee and Board, per IIA Standards and regulatory guidance.' ;
    rdfs:domain ind:CaeCharter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvingBody rdf:type rdf:Property ;
    rdfs:label 'Approving Body' ;
    rdfs:comment 'Name of the governing body that approved the charter, typically the Audit Committee of the Board of Directors, establishing the independence and authority of the internal audit function.' ;
    rdfs:domain ind:CaeCharter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assuranceServicesScope rdf:type rdf:Property ;
    rdfs:label 'Assurance Services Scope' ;
    rdfs:comment 'Description of the scope of assurance services the internal audit function is authorized to provide, including risk management, control, and governance processes.' ;
    rdfs:domain ind:CaeCharter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditCommitteeChairName rdf:type rdf:Property ;
    rdfs:label 'Audit Committee Chair Name' ;
    rdfs:comment 'Name of the Audit Committee Chair who signed or approved the charter on behalf of the Board, establishing accountability for oversight.' ;
    rdfs:domain ind:CaeCharter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditCommitteeReportingFrequency rdf:type rdf:Property ;
    rdfs:label 'Audit Committee Reporting Frequency' ;
    rdfs:comment 'Defines the frequency and nature of reporting by the Chief Audit Executive to the Audit Committee, typically quarterly or as needed for significant matters.' ;
    rdfs:domain ind:CaeCharter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditUniverseCoverage rdf:type rdf:Property ;
    rdfs:label 'Audit Universe Coverage' ;
    rdfs:comment 'Defines the comprehensive audit universe that falls within the scope of the internal audit function, including all entities, operations, functions, and processes subject to audit.' ;
    rdfs:domain ind:CaeCharter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boardApprovalResolutionNumber rdf:type rdf:Property ;
    rdfs:label 'Board Approval Resolution Number' ;
    rdfs:comment 'Board resolution or meeting minute reference number documenting the formal approval of the charter by the Board of Directors.' ;
    rdfs:domain ind:CaeCharter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetAuthority rdf:type rdf:Property ;
    rdfs:label 'Budget Authority' ;
    rdfs:comment 'Defines the Chief Audit Executive\'s authority over the internal audit budget, staffing, and resource allocation, ensuring adequate resources to fulfill the audit mandate.' ;
    rdfs:domain ind:CaeCharter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:charterNumber rdf:type rdf:Property ;
    rdfs:label 'Charter Number' ;
    rdfs:comment 'Business identifier for the charter document, typically assigned by the Audit Committee or Board for tracking and reference purposes.' ;
    rdfs:domain ind:CaeCharter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:charterStatus rdf:type rdf:Property ;
    rdfs:label 'Charter Status' ;
    rdfs:comment 'Current lifecycle status of the charter document indicating its approval and operational state within the governance framework.' ;
    rdfs:domain ind:CaeCharter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:charterTitle rdf:type rdf:Property ;
    rdfs:label 'Charter Title' ;
    rdfs:comment 'Official title of the charter document as approved by the Audit Committee and Board, typically \'Internal Audit Charter\' or \'Chief Audit Executive Charter\'.' ;
    rdfs:domain ind:CaeCharter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:charterVersion rdf:type rdf:Property ;
    rdfs:label 'Charter Version' ;
    rdfs:comment 'Version identifier for the charter document, incremented with each revision or amendment approved by the Audit Committee or Board.' ;
    rdfs:domain ind:CaeCharter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consultingServicesScope rdf:type rdf:Property ;
    rdfs:label 'Consulting Services Scope' ;
    rdfs:comment 'Description of the scope of consulting and advisory services the internal audit function is authorized to provide to management, with appropriate safeguards to independence.' ;
    rdfs:domain ind:CaeCharter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentStorageLocation rdf:type rdf:Property ;
    rdfs:label 'Document Storage Location' ;
    rdfs:comment 'Physical or electronic storage location of the official signed charter document, ensuring accessibility for reference and regulatory examination.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expirationDate rdf:type rdf:Property ;
    rdfs:label 'Expiration Date' ;
    rdfs:comment 'Date on which the charter expires or is scheduled for mandatory review, typically set annually per IIA Standards requiring annual review and reaffirmation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:externalAssessmentFrequencyYears rdf:type rdf:Property ;
    rdfs:label 'External Assessment Frequency Years' ;
    rdfs:comment 'Frequency in years for external quality assessments of the internal audit function, typically every five years per IIA Standards.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fraudInvestigationAuthority rdf:type rdf:Property ;
    rdfs:label 'Fraud Investigation Authority' ;
    rdfs:comment 'Authority granted to the internal audit function to investigate suspected fraud, misconduct, and violations of laws, regulations, or policies, including coordination with legal and compliance functions.' ;
    rdfs:domain ind:CaeCharter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalReportingLine rdf:type rdf:Property ;
    rdfs:label 'Functional Reporting Line' ;
    rdfs:comment 'Defines the functional reporting relationship of the Chief Audit Executive, typically to the Audit Committee of the Board, ensuring organizational independence.' ;
    rdfs:domain ind:CaeCharter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:independenceProvisions rdf:type rdf:Property ;
    rdfs:label 'Independence Provisions' ;
    rdfs:comment 'Detailed provisions ensuring the independence and objectivity of the internal audit function, including safeguards against conflicts of interest and impairments to independence.' ;
    rdfs:domain ind:CaeCharter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:privateSessionRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Private Session Requirement Flag' ;
    rdfs:comment 'Indicates whether the charter mandates private sessions between the Chief Audit Executive and the Audit Committee without management present, a key independence safeguard.' ;
    rdfs:domain ind:CaeCharter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:purposeStatement rdf:type rdf:Property ;
    rdfs:label 'Purpose Statement' ;
    rdfs:comment 'Formal statement defining the purpose of the internal audit function, typically to provide independent, objective assurance and consulting services designed to add value and improve operations.' ;
    rdfs:domain ind:CaeCharter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityAssuranceRequirement rdf:type rdf:Property ;
    rdfs:label 'Quality Assurance Requirement' ;
    rdfs:comment 'Requirement for the internal audit function to develop and maintain a Quality Assurance and Improvement Program (QAIP) including internal and external assessments.' ;
    rdfs:domain ind:CaeCharter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryCoordinationAuthority rdf:type rdf:Property ;
    rdfs:label 'Regulatory Coordination Authority' ;
    rdfs:comment 'Authority granted to the internal audit function to coordinate with external auditors and regulatory examiners, including the Federal Reserve, Office of the Comptroller of the Currency (OCC), and other banking regulators.' ;
    rdfs:domain ind:CaeCharter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryFilingFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Flag' ;
    rdfs:comment 'Indicates whether the charter or its key provisions must be filed with banking regulators such as the Federal Reserve or Office of the Comptroller of the Currency (OCC).' ;
    rdfs:domain ind:CaeCharter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revisionHistory rdf:type rdf:Property ;
    rdfs:label 'Revision History' ;
    rdfs:comment 'Summary of significant revisions and amendments made to the charter over time, providing audit trail of governance evolution.' ;
    rdfs:domain ind:CaeCharter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskAssessmentMethodology rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Methodology' ;
    rdfs:comment 'Approved methodology for conducting risk assessments to develop the annual audit plan, ensuring audit resources are allocated to highest-risk areas.' ;
    rdfs:domain ind:CaeCharter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeOfAuthority rdf:type rdf:Property ;
    rdfs:label 'Scope Of Authority' ;
    rdfs:comment 'Comprehensive description of the scope and boundaries of the internal audit function\'s authority, including access rights, audit universe coverage, and limitations.' ;
    rdfs:domain ind:CaeCharter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:staffingAuthority rdf:type rdf:Property ;
    rdfs:label 'Staffing Authority' ;
    rdfs:comment 'Authority granted to the Chief Audit Executive to hire, terminate, and manage internal audit staff, ensuring the function has appropriate skills and competencies.' ;
    rdfs:domain ind:CaeCharter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardsConformanceRequirement rdf:type rdf:Property ;
    rdfs:label 'Standards Conformance Requirement' ;
    rdfs:comment 'Requirement for the internal audit function to conform to the Institute of Internal Auditors (IIA) International Standards for the Professional Practice of Internal Auditing and Code of Ethics.' ;
    rdfs:domain ind:CaeCharter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:threeLinesModelPosition rdf:type rdf:Property ;
    rdfs:label 'Three Lines Model Position' ;
    rdfs:comment 'Position of the internal audit function within the Three Lines of Defense governance model, typically designated as the third line providing independent assurance.' ;
    rdfs:domain ind:CaeCharter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unrestrictedAccessFlag rdf:type rdf:Property ;
    rdfs:label 'Unrestricted Access Flag' ;
    rdfs:comment 'Indicates whether the charter grants unrestricted access to all records, personnel, and physical properties relevant to the performance of audit engagements, a key independence provision.' ;
    rdfs:domain ind:CaeCharter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:whistleblowerCoordinationFlag rdf:type rdf:Property ;
    rdfs:label 'Whistleblower Coordination Flag' ;
    rdfs:comment 'Indicates whether the internal audit function has a role in coordinating or overseeing the organization\'s whistleblower and ethics hotline programs.' ;
    rdfs:domain ind:CaeCharter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:continuousMonitoringId rdf:type rdf:Property ;
    rdfs:label 'Continuous Monitoring Id' ;
    rdfs:comment 'Unique identifier for the continuous monitoring program record.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContinuousMonitoring .

ind:monitoredControlId rdf:type rdf:Property ;
    rdfs:label 'Monitored Control Id' ;
    rdfs:comment 'Identifier of the specific control or process being monitored by this program.' ;
    rdfs:domain ind:ContinuousMonitoring ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ComplianceSoxControl .

ind:monitoredGlAccountId rdf:type rdf:Property ;
    rdfs:label 'Monitored Gl Account Id' ;
    rdfs:comment 'Foreign key linking to ledger.gl_account. Business justification: Continuous monitoring programs target specific GL accounts for automated control testing, threshold monitoring, and exception detection. Account linkage is fundamental for continuous auditing and real' ;
    rdfs:domain ind:ContinuousMonitoring ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:automationLevel rdf:type rdf:Property ;
    rdfs:label 'Automation Level' ;
    rdfs:comment 'Degree of automation in the continuous monitoring program (e.g., Fully Automated, Semi-Automated, Manual).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSourceTable rdf:type rdf:Property ;
    rdfs:label 'Data Source Table' ;
    rdfs:comment 'Specific table, view, or data object within the source system used for monitoring.' ;
    rdfs:domain ind:ContinuousMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationRule rdf:type rdf:Property ;
    rdfs:label 'Escalation Rule' ;
    rdfs:comment 'Business rule defining when and to whom exceptions are escalated (e.g., escalate to senior management if exception count exceeds 10).' ;
    rdfs:domain ind:ContinuousMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationThreshold rdf:type rdf:Property ;
    rdfs:label 'Escalation Threshold' ;
    rdfs:comment 'Numeric threshold for exception count or severity that triggers escalation to higher management or audit committee.' ;
    rdfs:domain ind:ContinuousMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exceptionCountLastRun rdf:type rdf:Property ;
    rdfs:label 'Exception Count Last Run' ;
    rdfs:comment 'Number of exceptions or control breaches detected during the most recent execution of the monitoring program.' ;
    rdfs:domain ind:ContinuousMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exceptionCriteria rdf:type rdf:Property ;
    rdfs:label 'Exception Criteria' ;
    rdfs:comment 'Detailed business rules or conditions that define when an exception is raised by the monitoring program.' ;
    rdfs:domain ind:ContinuousMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionSeverity rdf:type rdf:Property ;
    rdfs:label 'Exception Severity' ;
    rdfs:comment 'Severity classification of exceptions raised by this monitoring program (e.g., Critical, High, Medium, Low).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastExecutionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Execution Timestamp' ;
    rdfs:comment 'Precise timestamp when the continuous monitoring routine was last executed.' ;
    rdfs:domain ind:ContinuousMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:monitoredControlName rdf:type rdf:Property ;
    rdfs:label 'Monitored Control Name' ;
    rdfs:comment 'Name or description of the control or business process under continuous monitoring.' ;
    rdfs:domain ind:ContinuousMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringTool rdf:type rdf:Property ;
    rdfs:label 'Monitoring Tool' ;
    rdfs:comment 'Name of the software tool or platform used to execute the continuous monitoring routine (e.g., ACL, IDEA, Tableau, custom script).' ;
    rdfs:domain ind:ContinuousMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextScheduledExecutionDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Execution Date' ;
    rdfs:comment 'Date when the continuous monitoring routine is next scheduled to run.' ;
    rdfs:domain ind:ContinuousMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:programEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Program Effective Date' ;
    rdfs:comment 'Date when the continuous monitoring program became effective and operational.' ;
    rdfs:domain ind:ContinuousMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:programEndDate rdf:type rdf:Property ;
    rdfs:label 'Program End Date' ;
    rdfs:comment 'Date when the continuous monitoring program is scheduled to end or was retired (nullable for ongoing programs).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:programNotes rdf:type rdf:Property ;
    rdfs:label 'Program Notes' ;
    rdfs:comment 'Free-text notes or comments about the continuous monitoring program, including special considerations, recent changes, or known issues.' ;
    rdfs:domain ind:ContinuousMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programOwnerEmail rdf:type rdf:Property ;
    rdfs:label 'Program Owner Email' ;
    rdfs:comment 'Email address of the continuous monitoring program owner for notifications and escalations.' ;
    rdfs:domain ind:ContinuousMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programOwnerName rdf:type rdf:Property ;
    rdfs:label 'Program Owner Name' ;
    rdfs:comment 'Name of the individual or role responsible for the continuous monitoring program.' ;
    rdfs:domain ind:ContinuousMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryDriver rdf:type rdf:Property ;
    rdfs:label 'Regulatory Driver' ;
    rdfs:comment 'Regulatory requirement or compliance mandate driving the need for continuous monitoring (e.g., SOX Section 404, Basel III, CCAR, AML/BSA).' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdOperator rdf:type rdf:Property ;
    rdfs:label 'Threshold Operator' ;
    rdfs:comment 'Comparison operator applied to the threshold (e.g., Greater Than, Less Than, Equal To, Between).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdType rdf:type rdf:Property ;
    rdfs:label 'Threshold Type' ;
    rdfs:comment 'Type of threshold used to define exceptions (e.g., Absolute value, Percentage, Rate, Count, Variance from baseline).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cosourcingArrangementId rdf:type rdf:Property ;
    rdfs:label 'Cosourcing Arrangement Id' ;
    rdfs:comment 'Unique identifier for the co-sourcing arrangement record. Primary key for tracking third-party audit support engagements.' ;
    rdfs:domain ind:CosourcingArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:engagementId rdf:type rdf:Property ;
    rdfs:label 'Engagement Id' ;
    rdfs:comment 'Foreign key linking to audit.engagement. Business justification: cosourcing_arrangement captures engagements where external audit firms or specialists are brought in. These arrangements are FOR specific audit engagements. Currently no FK exists from cosourcing_arra' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Engagement .

ind:supervisingStaffEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Supervising Staff Employee Id' ;
    rdfs:comment 'Employee identifier for the supervising CAE staff member, linking to the human resources system for organizational hierarchy and accountability tracking.' ;
    rdfs:domain ind:CosourcingArrangement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:arrangementStatus rdf:type rdf:Property ;
    rdfs:label 'Arrangement Status' ;
    rdfs:comment 'Current lifecycle status of the co-sourcing arrangement, tracking progression from planning through completion or termination. [ENUM-REF-CANDIDATE: draft|approved|active|completed|suspended|terminated|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingMethod rdf:type rdf:Property ;
    rdfs:label 'Billing Method' ;
    rdfs:comment 'Contractual billing structure defining how the external service provider charges for co-sourcing services.' ;
    rdfs:domain ind:CosourcingArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Reference Number' ;
    rdfs:comment 'Reference identifier linking this co-sourcing arrangement to the master services agreement or statement of work in the procurement system.' ;
    rdfs:domain ind:CosourcingArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cosourcingType rdf:type rdf:Property ;
    rdfs:label 'Cosourcing Type' ;
    rdfs:comment 'Category of co-sourcing engagement defining the scope and nature of external support provided to the internal audit function. [ENUM-REF-CANDIDATE: full_cosource|specialist_support|it_audit|regulatory_specialist|sox_compliance|model_validation|cybersecurity — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CosourcingArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementEndDate rdf:type rdf:Property ;
    rdfs:label 'Engagement End Date' ;
    rdfs:comment 'Planned or actual completion date for the co-sourcing arrangement, marking the end of the external provider\'s active involvement.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:engagementScope rdf:type rdf:Property ;
    rdfs:label 'Engagement Scope' ;
    rdfs:comment 'Detailed description of the work scope, deliverables, and areas of responsibility assigned to the external service provider within the audit engagement.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementStartDate rdf:type rdf:Property ;
    rdfs:label 'Engagement Start Date' ;
    rdfs:comment 'Date when the co-sourcing arrangement becomes effective and the external provider begins work on the audit engagement.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:feeCurrency rdf:type rdf:Property ;
    rdfs:label 'Fee Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the fee amount, supporting multi-currency co-sourcing arrangements across global operations.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:independenceConfirmationDate rdf:type rdf:Property ;
    rdfs:label 'Independence Confirmation Date' ;
    rdfs:comment 'Date when the external service provider submitted their independence attestation and conflict of interest disclosure.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:independenceConfirmationFlag rdf:type rdf:Property ;
    rdfs:label 'Independence Confirmation Flag' ;
    rdfs:comment 'Indicator confirming that the external service provider has provided written attestation of independence and absence of conflicts of interest per IIA standards and regulatory requirements.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:performanceEvaluationDate rdf:type rdf:Property ;
    rdfs:label 'Performance Evaluation Date' ;
    rdfs:comment 'Date when the formal performance evaluation of the external service provider was completed by the supervising internal audit staff.' ;
    rdfs:domain ind:CosourcingArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedHours rdf:type rdf:Property ;
    rdfs:label 'Planned Hours' ;
    rdfs:comment 'Estimated total hours allocated for the external service provider to complete the co-sourcing engagement scope, used for budget planning and resource allocation.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityOversightProcedures rdf:type rdf:Property ;
    rdfs:label 'Quality Oversight Procedures' ;
    rdfs:comment 'Description of the quality assurance and oversight controls implemented by internal audit to monitor the external provider\'s work quality, methodology adherence, and deliverable standards.' ;
    rdfs:domain ind:CosourcingArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalFlag rdf:type rdf:Property ;
    rdfs:label 'Renewal Flag' ;
    rdfs:comment 'Indicator showing whether this co-sourcing arrangement is eligible for or planned for renewal in the next audit planning cycle.' ;
    rdfs:domain ind:CosourcingArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceProviderName rdf:type rdf:Property ;
    rdfs:label 'Service Provider Name' ;
    rdfs:comment 'Legal name of the external audit firm, specialist consultant, or third-party provider engaged to supplement internal audit capacity.' ;
    rdfs:domain ind:CosourcingArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceProviderType rdf:type rdf:Property ;
    rdfs:label 'Service Provider Type' ;
    rdfs:comment 'Classification of the external service provider based on firm size, specialization, and market positioning.' ;
    rdfs:domain ind:CosourcingArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorDueDiligenceDate rdf:type rdf:Property ;
    rdfs:label 'Vendor Due Diligence Date' ;
    rdfs:comment 'Date when vendor due diligence assessment was completed for the external service provider, including background checks, financial stability review, and capability validation.' ;
    rdfs:domain ind:CosourcingArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:alcoMeetingId rdf:type rdf:Property ;
    rdfs:label 'Alco Meeting Id' ;
    rdfs:comment 'Foreign key linking to treasury.alco_meeting. Business justification: Audit engagements are triggered by ALCO resolutions (e.g., FTP methodology review, hedge effectiveness audit). Auditors reference the specific ALCO meeting that mandated the engagement.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AlcoMeeting .

ind:assessmentId rdf:type rdf:Property ;
    rdfs:label 'Assessment Id' ;
    rdfs:comment 'Foreign key linking to risk.risk_assessment. Business justification: Audit engagements frequently scope and test risk assessments performed by first/second lines. Links engagement to the specific risk assessment under audit review, supporting audit planning and workpap' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Assessment .

ind:auditedPartyId rdf:type rdf:Property ;
    rdfs:label 'Audited Party Id' ;
    rdfs:comment 'Foreign key linking to customer.party. Business justification: Audit engagements examine specific customers/legal entities for AML, KYC, credit risk, or operational reviews. Tracks which customer is the subject of the audit for regulatory reporting, risk assessme' ;
    rdfs:domain ind:Engagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:capitalPlanId rdf:type rdf:Property ;
    rdfs:label 'Capital Plan Id' ;
    rdfs:comment 'Foreign key linking to treasury.capital_plan. Business justification: Capital planning (CCAR/DFAST) is a mandatory audit area. Audit engagements directly audit specific capital plan submissions for methodology, assumptions, stress testing, and regulatory compliance.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CapitalPlan .

ind:capitalRatioId rdf:type rdf:Property ;
    rdfs:label 'Capital Ratio Id' ;
    rdfs:comment 'Foreign key linking to treasury.capital_ratio. Business justification: Capital ratio calculation, RWA methodology, and regulatory reporting are mandatory audit subjects. Engagements audit specific ratio calculation periods for Basel III compliance and regulatory submissi' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CapitalRatio .

ind:cashFlowForecastId rdf:type rdf:Property ;
    rdfs:label 'Cash Flow Forecast Id' ;
    rdfs:comment 'Foreign key linking to treasury.cash_flow_forecast. Business justification: Cash flow forecasting models, assumptions, and CCAR/DFAST projections are audit engagement subjects. Auditors audit specific forecast versions for model risk, assumption reasonableness, and regulatory' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CashFlowForecast .

ind:consentOrderId rdf:type rdf:Property ;
    rdfs:label 'Consent Order Id' ;
    rdfs:comment 'Foreign key linking to compliance.consent_order. Business justification: Consent orders mandate specific audit engagements with defined scope and timelines. Auditors must track which engagements satisfy consent order requirements for regulatory reporting and board oversigh' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConsentOrder .

ind:contingencyFundingPlanId rdf:type rdf:Property ;
    rdfs:label 'Contingency Funding Plan Id' ;
    rdfs:comment 'Foreign key linking to treasury.contingency_funding_plan. Business justification: Contingency funding plan adequacy, testing, and governance are regulatory audit requirements. Engagements audit specific CFP versions for liquidity stress preparedness and regulatory compliance (Basel' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContingencyFundingPlan .

ind:engagementCreatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Engagement Created By User Employee Id' ;
    rdfs:comment 'Identifier of the user or auditor who created the engagement record in the audit management system.' ;
    rdfs:domain ind:Engagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:engagementEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Engagement Employee Id' ;
    rdfs:comment 'Identifier of the senior auditor responsible for leading the engagement, supervising the audit team, and signing off on the audit report. Links to the auditor or employee master.' ;
    rdfs:domain ind:Engagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:engagementManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Engagement Manager Employee Id' ;
    rdfs:comment 'Identifier of the audit manager or director overseeing the engagement, responsible for quality review and stakeholder communication. Links to the auditor or employee master.' ;
    rdfs:domain ind:Engagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:engagementUpdatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Engagement Updated By User Employee Id' ;
    rdfs:comment 'Identifier of the user or auditor who last modified the engagement record, used for accountability and audit trail purposes.' ;
    rdfs:domain ind:Engagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:facilityId rdf:type rdf:Property ;
    rdfs:label 'Facility Id' ;
    rdfs:comment 'Foreign key linking to loan.facility. Business justification: Audit engagements often scope to specific credit facilities (e.g., syndicated loan audits, revolving credit line reviews). Auditors test facility-level controls, covenant compliance, and utilization. ' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:fundingPlanId rdf:type rdf:Property ;
    rdfs:label 'Funding Plan Id' ;
    rdfs:comment 'Foreign key linking to treasury.funding_plan. Business justification: Funding plan execution, ALCO limit compliance, and issuance governance are audit engagement subjects. Auditors audit specific funding plan versions for adherence to approved strategy and risk limits.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FundingPlan .

ind:interestRateRiskPositionId rdf:type rdf:Property ;
    rdfs:label 'Interest Rate Risk Position Id' ;
    rdfs:comment 'Foreign key linking to treasury.interest_rate_risk_position. Business justification: Interest rate risk measurement, EVE/NII sensitivity, and limit compliance are audit engagement subjects. Auditors audit specific IRR position snapshots for model validation and ALCO limit adherence.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InterestRateRiskPosition .

ind:irbModelId rdf:type rdf:Property ;
    rdfs:label 'Irb Model Id' ;
    rdfs:comment 'Foreign key linking to risk.irb_model. Business justification: Model validation audits target specific IRB models for regulatory capital. Links engagement to the model under audit, supporting model risk management, validation tracking, and regulatory approval pro' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IrbModel .

ind:liquidityRatioId rdf:type rdf:Property ;
    rdfs:label 'Liquidity Ratio Id' ;
    rdfs:comment 'Foreign key linking to treasury.liquidity_ratio. Business justification: LCR/NSFR calculation methodology, data quality, and regulatory reporting are mandatory audit subjects. Engagements audit specific ratio calculation periods for Basel III compliance and regulatory subm' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LiquidityRatio .

ind:materialityCurrencyId rdf:type rdf:Property ;
    rdfs:label 'Materiality Currency Id' ;
    rdfs:comment 'Foreign key linking to reference.currency. Business justification: Audit engagements establish materiality thresholds denominated in specific currencies. Essential for international banking audits where materiality must be assessed in local or reporting currency. Sta' ;
    rdfs:domain ind:Engagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:policyId rdf:type rdf:Property ;
    rdfs:label 'Policy Id' ;
    rdfs:comment 'Foreign key linking to compliance.policy. Business justification: Policy compliance testing is a primary audit objective. Engagements must reference specific policies being tested for scope definition, workpaper organization, and audit reporting. Essential for polic' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Policy .

ind:transferPricingCurveId rdf:type rdf:Property ;
    rdfs:label 'Transfer Pricing Curve Id' ;
    rdfs:comment 'Foreign key linking to treasury.transfer_pricing_curve. Business justification: FTP curve methodology, rate-setting governance, and ALCO approval are common audit engagement subjects. Auditors directly audit specific curve versions for model validation and governance compliance.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TransferPricingCurve .

ind:actualEndDate rdf:type rdf:Property ;
    rdfs:label 'Actual End Date' ;
    rdfs:comment 'Actual date when the audit engagement was completed and the final report was issued, used for tracking schedule adherence and cycle time metrics.' ;
    rdfs:domain ind:Engagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualStartDate rdf:type rdf:Property ;
    rdfs:label 'Actual Start Date' ;
    rdfs:comment 'Actual date when fieldwork or engagement execution commenced, used for tracking schedule adherence and resource utilization.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditObjectives rdf:type rdf:Property ;
    rdfs:label 'Audit Objectives' ;
    rdfs:comment 'Specific objectives and goals of the audit engagement, articulating what the audit intends to evaluate, assess, or provide assurance on.' ;
    rdfs:domain ind:Engagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataAnalyticsUsedFlag rdf:type rdf:Property ;
    rdfs:label 'Data Analytics Used Flag' ;
    rdfs:comment 'Indicates whether advanced data analytics, machine learning, or automated testing tools were employed during the engagement (True) or traditional manual audit procedures were used (False).' ;
    rdfs:domain ind:Engagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:engagementNumber rdf:type rdf:Property ;
    rdfs:label 'Engagement Number' ;
    rdfs:comment 'Business-facing unique identifier or reference number for the audit engagement, used in audit committee reporting and external communication.' ;
    rdfs:domain ind:Engagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementStatus rdf:type rdf:Property ;
    rdfs:label 'Engagement Status' ;
    rdfs:comment 'Current lifecycle status of the audit engagement: planning (scoping and preparation), fieldwork (evidence gathering and testing), reporting (draft and final report preparation), management response (awaiting or reviewing management action plans), closed (engagement complete), or cancelled (engagement terminated before completion).' ;
    rdfs:domain ind:Engagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementType rdf:type rdf:Property ;
    rdfs:label 'Engagement Type' ;
    rdfs:comment 'Classification of the audit engagement by its primary purpose: assurance (independent evaluation), advisory (consulting), regulatory (mandated review), SOX compliance (Sarbanes-Oxley Act internal controls), IT audit (technology systems and controls), or AML/BSA review (Anti-Money Laundering/Bank Secrecy Act compliance).' ;
    rdfs:domain ind:Engagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Date' ;
    rdfs:comment 'Scheduled date for follow-up audit procedures to verify implementation of management action plans and closure of findings.' ;
    rdfs:domain ind:Engagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inherentRiskRating rdf:type rdf:Property ;
    rdfs:label 'Inherent Risk Rating' ;
    rdfs:comment 'Risk rating of the auditable entity or process before considering the effectiveness of controls, based on factors such as financial materiality, regulatory exposure, complexity, and change activity.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managementResponseDueDate rdf:type rdf:Property ;
    rdfs:label 'Management Response Due Date' ;
    rdfs:comment 'Date by which management is required to provide formal responses and action plans to address audit findings.' ;
    rdfs:domain ind:Engagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:managementResponseReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Management Response Received Date' ;
    rdfs:comment 'Actual date when management submitted their formal responses and remediation action plans to the audit findings.' ;
    rdfs:domain ind:Engagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:overallRiskRating rdf:type rdf:Property ;
    rdfs:label 'Overall Risk Rating' ;
    rdfs:comment 'Aggregate risk rating assigned to the engagement based on the severity and number of findings, the inherent risk of the audited area, and the residual risk after considering management action plans.' ;
    rdfs:domain ind:Engagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedEndDate rdf:type rdf:Property ;
    rdfs:label 'Planned End Date' ;
    rdfs:comment 'Scheduled completion date for the audit engagement execution as defined in the audit plan or engagement letter.' ;
    rdfs:domain ind:Engagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedStartDate rdf:type rdf:Property ;
    rdfs:label 'Planned Start Date' ;
    rdfs:comment 'Scheduled start date for the audit engagement execution as defined in the audit plan or engagement letter.' ;
    rdfs:domain ind:Engagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryMandateFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Mandate Flag' ;
    rdfs:comment 'Indicates whether the engagement is mandated by a regulatory requirement, consent order, or supervisory agreement (True) or is discretionary based on risk assessment (False).' ;
    rdfs:domain ind:Engagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportDistributionList rdf:type rdf:Property ;
    rdfs:label 'Report Distribution List' ;
    rdfs:comment 'List of stakeholders, executives, and audit committee members to whom the audit report was distributed, typically stored as a delimited list or reference to a distribution group.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportIssueDate rdf:type rdf:Property ;
    rdfs:label 'Report Issue Date' ;
    rdfs:comment 'Date when the final audit report was formally issued to management and the audit committee.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:residualRiskRating rdf:type rdf:Property ;
    rdfs:label 'Residual Risk Rating' ;
    rdfs:comment 'Risk rating after considering the design and operating effectiveness of controls and management action plans to remediate identified findings.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeStatement rdf:type rdf:Property ;
    rdfs:label 'Scope Statement' ;
    rdfs:comment 'Detailed description of the audit scope, including the processes, controls, systems, locations, and time periods covered by the engagement. Defines boundaries and exclusions.' ;
    rdfs:domain ind:Engagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxSection rdf:type rdf:Property ;
    rdfs:label 'Sox Section' ;
    rdfs:comment 'Specific section of the Sarbanes-Oxley Act that this engagement addresses, if the engagement is SOX-related (e.g., Section 302, Section 404, Section 906).' ;
    rdfs:domain ind:Engagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:threeLinesOfDefenseLine rdf:type rdf:Property ;
    rdfs:label 'Three Lines Of Defense Line' ;
    rdfs:comment 'Classification of the engagement within the three lines of defense model: first line (operational management and controls), second line (risk management and compliance oversight), or third line (internal audit providing independent assurance).' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Engagement Assignment Id' ;
    rdfs:comment 'Unique identifier for the engagement assignment record linking an audit resource to a specific audit engagement.' ;
    rdfs:domain ind:EngagementAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Auditor Employee Id' ;
    rdfs:comment 'Reference to the audit staff member or resource assigned to the engagement.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryEngagementEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Engagement Employee Id' ;
    rdfs:comment 'Human resources employee identifier for the assigned auditor, used for cross-referencing with HR systems.' ;
    rdfs:domain ind:EngagementAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assignmentApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Assignment Approved By' ;
    rdfs:comment 'Name or identifier of the audit leader or Chief Audit Executive (CAE) who approved this resource assignment.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentApprovedDate rdf:type rdf:Property ;
    rdfs:label 'Assignment Approved Date' ;
    rdfs:comment 'The date when the assignment was formally approved by audit management.' ;
    rdfs:domain ind:EngagementAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignmentChangeReason rdf:type rdf:Property ;
    rdfs:label 'Assignment Change Reason' ;
    rdfs:comment 'Documentation of the reason for any changes to the assignment, such as scope modifications, resource reallocation, or timeline adjustments.' ;
    rdfs:domain ind:EngagementAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentEndDate rdf:type rdf:Property ;
    rdfs:label 'Assignment End Date' ;
    rdfs:comment 'The date when the auditor completes or is scheduled to complete their work on the engagement.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignmentNotes rdf:type rdf:Property ;
    rdfs:label 'Assignment Notes' ;
    rdfs:comment 'General notes and comments about the assignment, including special instructions, scope clarifications, or coordination requirements.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentPriority rdf:type rdf:Property ;
    rdfs:label 'Assignment Priority' ;
    rdfs:comment 'The priority level of this assignment relative to other work assigned to the auditor, used for workload balancing and resource allocation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentStartDate rdf:type rdf:Property ;
    rdfs:label 'Assignment Start Date' ;
    rdfs:comment 'The date when the auditor begins work on the engagement, marking the start of their assignment period.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assignment Status' ;
    rdfs:comment 'Current lifecycle status of the assignment indicating whether the auditor is actively working on the engagement.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentType rdf:type rdf:Property ;
    rdfs:label 'Assignment Type' ;
    rdfs:comment 'Classification of the assignment indicating whether the auditor is a primary team member, secondary support, advisory consultant, quality reviewer, or trainee.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billableFlag rdf:type rdf:Property ;
    rdfs:label 'Billable Flag' ;
    rdfs:comment 'Indicates whether the hours worked on this assignment are billable to a specific business unit or cost center.' ;
    rdfs:domain ind:EngagementAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificationHeld rdf:type rdf:Property ;
    rdfs:label 'Certification Held' ;
    rdfs:comment 'Professional certifications held by the auditor relevant to this assignment, such as Certified Internal Auditor (CIA), Certified Information Systems Auditor (CISA), Certified Public Accountant (CPA), or Certified Fraud Examiner (CFE).' ;
    rdfs:domain ind:EngagementAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeCode rdf:type rdf:Property ;
    rdfs:label 'Charge Code' ;
    rdfs:comment 'The financial charge code or cost center code to which the auditor\'s time on this engagement is allocated for budgeting and cost tracking.' ;
    rdfs:domain ind:EngagementAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competencyRequirement rdf:type rdf:Property ;
    rdfs:label 'Competency Requirement' ;
    rdfs:comment 'The specific skills, certifications, or competencies required for the auditor to fulfill this assignment effectively.' ;
    rdfs:domain ind:EngagementAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conflictOfInterestNotes rdf:type rdf:Property ;
    rdfs:label 'Conflict Of Interest Notes' ;
    rdfs:comment 'Documentation of any potential or actual conflicts of interest identified and how they are being managed or mitigated.' ;
    rdfs:domain ind:EngagementAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementRole rdf:type rdf:Property ;
    rdfs:label 'Engagement Role' ;
    rdfs:comment 'The specific role the auditor performs within the engagement team, defining responsibilities and authority level.' ;
    rdfs:domain ind:EngagementAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceNotes rdf:type rdf:Property ;
    rdfs:label 'Performance Notes' ;
    rdfs:comment 'Detailed notes and feedback on the auditor\'s performance, contributions, and areas for development during this engagement.' ;
    rdfs:domain ind:EngagementAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remoteWorkFlag rdf:type rdf:Property ;
    rdfs:label 'Remote Work Flag' ;
    rdfs:comment 'Indicates whether the auditor is performing this assignment remotely rather than on-site.' ;
    rdfs:domain ind:EngagementAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trainingHoursEarned rdf:type rdf:Property ;
    rdfs:label 'Training Hours Earned' ;
    rdfs:comment 'The number of Continuing Professional Education (CPE) or training hours earned by the auditor through participation in this engagement.' ;
    rdfs:domain ind:EngagementAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:travelRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Travel Required Flag' ;
    rdfs:comment 'Indicates whether the assignment requires the auditor to travel to remote locations or client sites.' ;
    rdfs:domain ind:EngagementAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workpaperAccessLevel rdf:type rdf:Property ;
    rdfs:label 'Workpaper Access Level' ;
    rdfs:comment 'The level of access the auditor has to engagement workpapers and documentation based on their role and responsibilities.' ;
    rdfs:domain ind:EngagementAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementScopeId rdf:type rdf:Property ;
    rdfs:label 'Engagement Scope Id' ;
    rdfs:comment 'Unique identifier for the audit engagement scope record.' ;
    rdfs:domain ind:EngagementScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:costCenterId rdf:type rdf:Property ;
    rdfs:label 'Cost Center Id' ;
    rdfs:comment 'Foreign key linking to ledger.cost_center. Business justification: Cost center audits assess operational efficiency, budget compliance, and control effectiveness. Cost center scoping enables targeted audit procedures for organizational units.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:inclusionFlag rdf:type rdf:Property ;
    rdfs:label 'Inclusion Flag' ;
    rdfs:comment 'Indicates whether this scope item is included (True) or explicitly excluded (False) from the audit engagement.' ;
    rdfs:domain ind:EngagementScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:materialityThreshold rdf:type rdf:Property ;
    rdfs:label 'Materiality Threshold' ;
    rdfs:comment 'The monetary materiality threshold applied to this scope item for determining audit significance and testing depth.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processName rdf:type rdf:Property ;
    rdfs:label 'Process Name' ;
    rdfs:comment 'The name of the business process included in or excluded from the audit scope (e.g., Loan Origination, Trade Settlement, AML Transaction Monitoring).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskJustification rdf:type rdf:Property ;
    rdfs:label 'Risk Justification' ;
    rdfs:comment 'Risk-based rationale for the scope decision, linking to the risk assessment that drove inclusion or exclusion of this item.' ;
    rdfs:domain ind:EngagementScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplingApproach rdf:type rdf:Property ;
    rdfs:label 'Sampling Approach' ;
    rdfs:comment 'The sampling methodology to be applied to this scope item during audit testing (statistical, judgmental, full population review, or risk-based).' ;
    rdfs:domain ind:EngagementScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeChangeApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Scope Change Approved By' ;
    rdfs:comment 'The name or identifier of the person who approved the scope change (e.g., Chief Audit Executive, Audit Committee Chair).' ;
    rdfs:domain ind:EngagementScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeChangeDate rdf:type rdf:Property ;
    rdfs:label 'Scope Change Date' ;
    rdfs:comment 'The date on which this scope item was added, modified, or removed from the engagement scope.' ;
    rdfs:domain ind:EngagementScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scopeChangeFlag rdf:type rdf:Property ;
    rdfs:label 'Scope Change Flag' ;
    rdfs:comment 'Indicates whether this scope item was added, modified, or removed after the initial scope definition (True if changed, False if original).' ;
    rdfs:domain ind:EngagementScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scopeChangeReason rdf:type rdf:Property ;
    rdfs:label 'Scope Change Reason' ;
    rdfs:comment 'The business or regulatory reason for changing the scope after initial definition (e.g., new risk identified, regulatory request, resource constraint).' ;
    rdfs:domain ind:EngagementScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeItemCode rdf:type rdf:Property ;
    rdfs:label 'Scope Item Code' ;
    rdfs:comment 'The standardized code or identifier for the scope item as used in operational systems (e.g., GL account code, system ID, country code).' ;
    rdfs:domain ind:EngagementScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeItemName rdf:type rdf:Property ;
    rdfs:label 'Scope Item Name' ;
    rdfs:comment 'The name or identifier of the specific process, system, geography, product, legal entity, or business unit included in or excluded from the audit scope.' ;
    rdfs:domain ind:EngagementScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeItemType rdf:type rdf:Property ;
    rdfs:label 'Scope Item Type' ;
    rdfs:comment 'The category of scope item being defined (process, system, geography, product, legal entity, or business unit).' ;
    rdfs:domain ind:EngagementScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeNotes rdf:type rdf:Property ;
    rdfs:label 'Scope Notes' ;
    rdfs:comment 'Additional notes, clarifications, or context regarding this scope item that support audit quality and regulatory examination responses.' ;
    rdfs:domain ind:EngagementScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopePeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Scope Period End Date' ;
    rdfs:comment 'The ending date of the time period covered by this scope item for the audit engagement.' ;
    rdfs:domain ind:EngagementScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scopePeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Scope Period Start Date' ;
    rdfs:comment 'The beginning date of the time period covered by this scope item for the audit engagement.' ;
    rdfs:domain ind:EngagementScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scopeRationale rdf:type rdf:Property ;
    rdfs:label 'Scope Rationale' ;
    rdfs:comment 'Business justification for including or excluding this item from the audit scope, documenting the decision-making process.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeStatus rdf:type rdf:Property ;
    rdfs:label 'Scope Status' ;
    rdfs:comment 'The current lifecycle status of this scope item within the audit engagement (draft, approved, in progress, completed, or superseded).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:systemName rdf:type rdf:Property ;
    rdfs:label 'System Name' ;
    rdfs:comment 'The name of the operational system or application included in or excluded from the audit scope (e.g., Temenos T24, Murex, SAS Risk Management).' ;
    rdfs:domain ind:EngagementScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alcoResolutionId rdf:type rdf:Property ;
    rdfs:label 'Alco Resolution Id' ;
    rdfs:comment 'Foreign key linking to treasury.alco_resolution. Business justification: Audit findings cite ALCO resolutions that established the policy, limit, or control that was breached. Essential for compliance verification and root cause analysis in treasury audits.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AlcoResolution .

ind:counterpartyAgreementId rdf:type rdf:Property ;
    rdfs:label 'Counterparty Agreement Id' ;
    rdfs:comment 'Foreign key linking to trade.counterparty_agreement. Business justification: Findings may reference specific ISDA/CSA agreements with inadequate collateral terms, missing legal opinions, or non-compliant margin calculations. Links finding to specific agreement for remediation ' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CounterpartyAgreement .

ind:findingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Finding Employee Id' ;
    rdfs:comment 'Reference to the business owner or manager responsible for remediating the finding, typically from the Human Resources or Employee master data.' ;
    rdfs:domain ind:Finding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:priorFindingId rdf:type rdf:Property ;
    rdfs:label 'Prior Finding Id' ;
    rdfs:comment 'Reference to the original finding identifier if this is a repeat finding, enabling tracking of recurring issues across audit cycles.' ;
    rdfs:domain ind:Finding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Finding .

ind:relatedAccountDepositAccountId rdf:type rdf:Property ;
    rdfs:label 'Related Account Deposit Account Id' ;
    rdfs:comment 'Foreign key linking to account.deposit_account. Business justification: Audit findings frequently identify issues with specific deposit accounts (dormancy, escheatment, fee assessment errors, interest calculation). Links finding to account enables root cause analysis, rem' ;
    rdfs:domain ind:Finding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DepositAccount .

ind:relatedHoldAccountHoldId rdf:type rdf:Property ;
    rdfs:label 'Related Hold Account Hold Id' ;
    rdfs:comment 'Foreign key linking to account.account_hold. Business justification: Regulatory audits and compliance reviews identify improper holds (incorrect legal authority, expired holds, customer notification failures). Links finding to specific hold enables remediation validati' ;
    rdfs:domain ind:Finding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Hold .

ind:tradingBookId rdf:type rdf:Property ;
    rdfs:label 'Trading Book Id' ;
    rdfs:comment 'Foreign key linking to trade.trading_book. Business justification: Audit findings often cite specific trading books where control deficiencies were identified (e.g., limit breaches, P&L reconciliation failures, Volcker violations). Links finding to audited book for r' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TradingBook .

ind:treasuryNostroReconciliationId rdf:type rdf:Property ;
    rdfs:label 'Treasury Nostro Reconciliation Id' ;
    rdfs:comment 'Foreign key linking to treasury.nostro_reconciliation. Business justification: Unreconciled nostro breaks, aging exceptions, and control failures generate audit findings. Findings reference specific reconciliation records as evidence of operational risk and control deficiencies ' ;
    rdfs:domain ind:Finding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NostroReconciliation .

ind:actualRemediationDate rdf:type rdf:Property ;
    rdfs:label 'Actual Remediation Date' ;
    rdfs:comment 'The date when remediation was actually completed and validated by audit, marking the closure of the finding.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:businessProcess rdf:type rdf:Property ;
    rdfs:label 'Business Process' ;
    rdfs:comment 'The business process or functional area where the finding was identified (e.g., Commercial Lending, Securities Trading, Payment Processing, Risk Management).' ;
    rdfs:domain ind:Finding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cause rdf:type rdf:Property ;
    rdfs:label 'Cause' ;
    rdfs:comment 'Root cause analysis explaining why the condition occurred - the underlying reason for the control deficiency or gap.' ;
    rdfs:domain ind:Finding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:condition rdf:type rdf:Property ;
    rdfs:label 'Condition' ;
    rdfs:comment 'Detailed description of what was found during the audit - the actual state or situation observed that represents a deviation from expected standards.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criteria rdf:type rdf:Property ;
    rdfs:label 'Criteria' ;
    rdfs:comment 'The standard, policy, regulation, or best practice that should have been followed - what the correct state or control should be.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effect rdf:type rdf:Property ;
    rdfs:label 'Effect' ;
    rdfs:comment 'Description of the actual or potential impact and risk to the organization if the finding is not remediated - the business consequence of the control gap.' ;
    rdfs:domain ind:Finding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalAuditorSharedFlag rdf:type rdf:Property ;
    rdfs:label 'External Auditor Shared Flag' ;
    rdfs:comment 'Indicator of whether this finding was shared with external auditors as part of coordination and reliance activities. True indicates it was shared.' ;
    rdfs:domain ind:Finding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:financialImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Amount' ;
    rdfs:comment 'Quantified financial impact of the finding in the organization\'s reporting currency, including actual losses, potential exposure, or remediation costs.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:findingNumber rdf:type rdf:Property ;
    rdfs:label 'Finding Number' ;
    rdfs:comment 'Business-facing unique identifier or reference number for the finding, often used in audit reports and management communications.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingStatus rdf:type rdf:Property ;
    rdfs:label 'Finding Status' ;
    rdfs:comment 'Current lifecycle status of the finding: draft (being documented), open (issued to management), in remediation (action plan underway), pending validation (awaiting audit verification), closed (remediated and validated), reopened (recurred after closure).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingType rdf:type rdf:Property ;
    rdfs:label 'Finding Type' ;
    rdfs:comment 'Classification of the finding severity and nature: control deficiency (minor gap), significant deficiency (important gap requiring attention), material weakness (critical gap with material impact), observation (informational note), or best practice (improvement opportunity).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geography rdf:type rdf:Property ;
    rdfs:label 'Geography' ;
    rdfs:comment 'Geographic region, country, or jurisdiction where the finding was identified, using three-letter ISO country codes where applicable.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identifiedDate rdf:type rdf:Property ;
    rdfs:label 'Identified Date' ;
    rdfs:comment 'The date when the finding was first identified during audit fieldwork.' ;
    rdfs:domain ind:Finding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:impact rdf:type rdf:Property ;
    rdfs:label 'Impact' ;
    rdfs:comment 'Assessment of the magnitude of potential loss or harm if the risk materializes - financial, reputational, regulatory, or operational impact.' ;
    rdfs:domain ind:Finding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuedDate rdf:type rdf:Property ;
    rdfs:label 'Issued Date' ;
    rdfs:comment 'The date when the finding was formally issued to management in the audit report or finding memo.' ;
    rdfs:domain ind:Finding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:likelihood rdf:type rdf:Property ;
    rdfs:label 'Likelihood' ;
    rdfs:comment 'Assessment of the probability that the risk will materialize or the control failure will occur.' ;
    rdfs:domain ind:Finding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managementAgreesFlag rdf:type rdf:Property ;
    rdfs:label 'Management Agrees Flag' ;
    rdfs:comment 'Indicator of whether management agrees with the finding. True indicates agreement, False indicates disagreement or partial agreement.' ;
    rdfs:domain ind:Finding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:managementResponse rdf:type rdf:Property ;
    rdfs:label 'Management Response' ;
    rdfs:comment 'Formal written response from management acknowledging the finding and outlining their agreement, disagreement, or planned corrective actions.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendation rdf:type rdf:Property ;
    rdfs:label 'Recommendation' ;
    rdfs:comment 'Detailed recommendation from internal audit on how to remediate the finding and strengthen controls.' ;
    rdfs:domain ind:Finding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryCitation rdf:type rdf:Property ;
    rdfs:label 'Regulatory Citation' ;
    rdfs:comment 'Reference to the specific regulatory requirement, statute, or rule that was violated or not met (e.g., Basel III Article 123, SOX Section 404, Regulation CC Section 229.10).' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportedFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reported Flag' ;
    rdfs:comment 'Indicator of whether this finding was required to be reported to regulatory authorities (Fed, OCC, SEC, etc.). True indicates regulatory reporting occurred.' ;
    rdfs:domain ind:Finding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remediationCostEstimate rdf:type rdf:Property ;
    rdfs:label 'Remediation Cost Estimate' ;
    rdfs:comment 'Estimated cost to remediate the finding, including technology investments, process redesign, training, and resource allocation.' ;
    rdfs:domain ind:Finding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rootCauseCategory rdf:type rdf:Property ;
    rdfs:label 'Root Cause Category' ;
    rdfs:comment 'High-level categorization of the root cause: process design (flawed procedure), execution failure (not following procedure), resource constraint (insufficient staffing or budget), technology limitation (system gap), training gap (knowledge deficiency), oversight weakness (inadequate supervision).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetRemediationDate rdf:type rdf:Property ;
    rdfs:label 'Target Remediation Date' ;
    rdfs:comment 'The date by which management has committed to complete remediation of the finding, as agreed in the management action plan.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:issueValidationId rdf:type rdf:Property ;
    rdfs:label 'Issue Validation Id' ;
    rdfs:comment 'Unique identifier for the issue validation record.' ;
    rdfs:domain ind:IssueValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditFindingId rdf:type rdf:Property ;
    rdfs:label 'Audit Finding Id' ;
    rdfs:comment 'Reference to the audit finding that is being validated for closure.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Finding .

ind:managementActionId rdf:type rdf:Property ;
    rdfs:label 'Management Action Id' ;
    rdfs:comment 'Reference to the management action plan that was implemented to remediate the finding.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ManagementAction .

ind:validatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Validator Employee Id' ;
    rdfs:comment 'Employee identifier of the auditor who performed the validation.' ;
    rdfs:domain ind:IssueValidation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:controlEffectivenessRating rdf:type rdf:Property ;
    rdfs:label 'Control Effectiveness Rating' ;
    rdfs:comment 'Rating of the effectiveness of the remediated control based on validation testing results.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceLocation rdf:type rdf:Property ;
    rdfs:label 'Evidence Location' ;
    rdfs:comment 'File path, document repository location, or system reference where validation evidence is stored.' ;
    rdfs:domain ind:IssueValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceReviewed rdf:type rdf:Property ;
    rdfs:label 'Evidence Reviewed' ;
    rdfs:comment 'Description of the evidence and documentation reviewed during the validation process to confirm remediation.' ;
    rdfs:domain ind:IssueValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionCount rdf:type rdf:Property ;
    rdfs:label 'Exception Count' ;
    rdfs:comment 'Number of exceptions identified during the validation testing.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exceptionsIdentified rdf:type rdf:Property ;
    rdfs:label 'Exceptions Identified' ;
    rdfs:comment 'Description of any exceptions or deficiencies identified during validation testing that indicate incomplete remediation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reopenDate rdf:type rdf:Property ;
    rdfs:label 'Reopen Date' ;
    rdfs:comment 'Date when the finding was reopened based on validation results.' ;
    rdfs:domain ind:IssueValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reopenFlag rdf:type rdf:Property ;
    rdfs:label 'Reopen Flag' ;
    rdfs:comment 'Indicates whether the finding was reopened due to validation testing revealing incomplete or ineffective remediation.' ;
    rdfs:domain ind:IssueValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reopenReason rdf:type rdf:Property ;
    rdfs:label 'Reopen Reason' ;
    rdfs:comment 'Explanation of why the finding was reopened after validation testing.' ;
    rdfs:domain ind:IssueValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualRiskAcceptedFlag rdf:type rdf:Property ;
    rdfs:label 'Residual Risk Accepted Flag' ;
    rdfs:comment 'Indicates whether management has formally accepted the residual risk.' ;
    rdfs:domain ind:IssueValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:residualRiskAssessment rdf:type rdf:Property ;
    rdfs:label 'Residual Risk Assessment' ;
    rdfs:comment 'Assessment of any remaining risk after the management action has been implemented, including likelihood and impact.' ;
    rdfs:domain ind:IssueValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplePopulation rdf:type rdf:Property ;
    rdfs:label 'Sample Population' ;
    rdfs:comment 'Total population size from which the validation sample was drawn.' ;
    rdfs:domain ind:IssueValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:testingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Testing Period End Date' ;
    rdfs:comment 'End date of the period covered by the validation testing.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:testingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Testing Period Start Date' ;
    rdfs:comment 'Start date of the period covered by the validation testing.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validationConclusion rdf:type rdf:Property ;
    rdfs:label 'Validation Conclusion' ;
    rdfs:comment 'Final conclusion of the validation testing indicating whether the finding has been effectively remediated.' ;
    rdfs:domain ind:IssueValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationMethod rdf:type rdf:Property ;
    rdfs:label 'Validation Method' ;
    rdfs:comment 'Method used to validate the effectiveness of the management action implementation. [ENUM-REF-CANDIDATE: document review|re-testing|walkthrough|data analysis|observation|inquiry|inspection|recalculation — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:IssueValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationNotes rdf:type rdf:Property ;
    rdfs:label 'Validation Notes' ;
    rdfs:comment 'Detailed notes and observations from the validation testing, including any exceptions or concerns identified.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationNumber rdf:type rdf:Property ;
    rdfs:label 'Validation Number' ;
    rdfs:comment 'Business identifier for the validation record, used for tracking and reporting purposes.' ;
    rdfs:domain ind:IssueValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationTeam rdf:type rdf:Property ;
    rdfs:label 'Validation Team' ;
    rdfs:comment 'Name of the audit team or unit responsible for performing the validation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validatorName rdf:type rdf:Property ;
    rdfs:label 'Validator Name' ;
    rdfs:comment 'Name of the internal auditor or audit team member who performed the validation testing.' ;
    rdfs:domain ind:IssueValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Action Owner Employee Id' ;
    rdfs:comment 'Employee identifier for the action owner, linking to the human capital management system for accountability tracking.' ;
    rdfs:domain ind:ManagementAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actionDescription rdf:type rdf:Property ;
    rdfs:label 'Action Description' ;
    rdfs:comment 'Detailed description of the remediation action that management commits to implement in response to the audit finding or recommendation.' ;
    rdfs:domain ind:ManagementAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionNotes rdf:type rdf:Property ;
    rdfs:label 'Action Notes' ;
    rdfs:comment 'Additional notes, comments, or context regarding the management action plan, supporting communication between management and internal audit.' ;
    rdfs:domain ind:ManagementAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionOwnerName rdf:type rdf:Property ;
    rdfs:label 'Action Owner Name' ;
    rdfs:comment 'Full name of the individual accountable for executing and completing the management action plan.' ;
    rdfs:domain ind:ManagementAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionOwnerTitle rdf:type rdf:Property ;
    rdfs:label 'Action Owner Title' ;
    rdfs:comment 'Job title or position of the action owner, establishing their authority and accountability level within the organization.' ;
    rdfs:domain ind:ManagementAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionPriority rdf:type rdf:Property ;
    rdfs:label 'Action Priority' ;
    rdfs:comment 'Priority level assigned to the management action based on the severity and risk rating of the underlying audit finding.' ;
    rdfs:domain ind:ManagementAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionStatus rdf:type rdf:Property ;
    rdfs:label 'Action Status' ;
    rdfs:comment 'Current lifecycle status of the management action plan tracking progress from commitment through validation and closure.' ;
    rdfs:domain ind:ManagementAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionType rdf:type rdf:Property ;
    rdfs:label 'Action Type' ;
    rdfs:comment 'Classification of the type of remediation action being implemented, supporting analysis of remediation patterns and resource planning.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Date' ;
    rdfs:comment 'Date when management reported that the remediation action was fully implemented and ready for internal audit validation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:completionEvidenceDescription rdf:type rdf:Property ;
    rdfs:label 'Completion Evidence Description' ;
    rdfs:comment 'Description of the evidence provided by management to demonstrate that the remediation action has been completed as committed.' ;
    rdfs:domain ind:ManagementAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysOpen rdf:type rdf:Property ;
    rdfs:label 'Days Open' ;
    rdfs:comment 'Number of calendar days the management action has been open, calculated from the action creation date to closure date or current date if still open.' ;
    rdfs:domain ind:ManagementAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost' ;
    rdfs:comment 'Estimated financial cost to implement the management action, including labor, technology, and other resource costs, used for budgeting and prioritization.' ;
    rdfs:domain ind:ManagementAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:extensionApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Extension Approval Date' ;
    rdfs:comment 'Date when the extension to the target completion date was formally approved by the designated authority.' ;
    rdfs:domain ind:ManagementAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:extensionApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Extension Approved By' ;
    rdfs:comment 'Name or identifier of the authority who approved the extension request, typically senior management or audit committee.' ;
    rdfs:domain ind:ManagementAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:extensionReason rdf:type rdf:Property ;
    rdfs:label 'Extension Reason' ;
    rdfs:comment 'Business justification provided by management for requesting an extension to the original target completion date.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mapNumber rdf:type rdf:Property ;
    rdfs:label 'Map Number' ;
    rdfs:comment 'Business-facing unique identifier or reference number for the management action plan, used in audit committee reporting and tracking.' ;
    rdfs:domain ind:ManagementAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalTargetCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Original Target Completion Date' ;
    rdfs:comment 'Initial target date committed by management for completing the remediation action, established at the time of management response.' ;
    rdfs:domain ind:ManagementAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revisedTargetCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Revised Target Completion Date' ;
    rdfs:comment 'Updated target completion date if the original deadline was extended due to legitimate business reasons, requiring approval and justification.' ;
    rdfs:domain ind:ManagementAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validatedBy rdf:type rdf:Property ;
    rdfs:label 'Validated By' ;
    rdfs:comment 'Name or identifier of the internal auditor who performed the validation testing and confirmed action closure.' ;
    rdfs:domain ind:ManagementAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringExceptionId rdf:type rdf:Property ;
    rdfs:label 'Monitoring Exception Id' ;
    rdfs:comment 'Unique identifier for the monitoring exception record. Primary key.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MonitoringException .

ind:escalatedFindingId rdf:type rdf:Property ;
    rdfs:label 'Escalated Finding Id' ;
    rdfs:comment 'Reference to the formal audit finding record if this exception was escalated to a finding, establishing traceability.' ;
    rdfs:domain ind:MonitoringException ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Finding .

ind:executionId rdf:type rdf:Property ;
    rdfs:label 'Execution Id' ;
    rdfs:comment 'Foreign key linking to trade.execution. Business justification: Continuous monitoring detects execution anomalies (price outliers, timing violations, venue selection errors) for trade surveillance. Links exception to flagged execution for investigation and best ex' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Execution .

ind:flaggedJournalEntryId rdf:type rdf:Property ;
    rdfs:label 'Flagged Journal Entry Id' ;
    rdfs:comment 'Foreign key linking to ledger.journal_entry. Business justification: Monitoring exceptions flag specific journal entries that violate thresholds or control rules. Direct JE linkage provides audit trail, enables investigation, and supports exception resolution and contr' ;
    rdfs:domain ind:MonitoringException ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntry .

ind:marketRiskPositionId rdf:type rdf:Property ;
    rdfs:label 'Market Risk Position Id' ;
    rdfs:comment 'Foreign key linking to risk.market_risk_position. Business justification: Monitoring exceptions flag unusual market risk positions for investigation. Links exception to the specific position, supporting trading desk oversight, VaR breach analysis, and FRTB capital charge va' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MarketRiskPosition .

ind:monitoringRuleId rdf:type rdf:Property ;
    rdfs:label 'Monitoring Rule Id' ;
    rdfs:comment 'Identifier of the specific monitoring rule or control test that detected this exception.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MonitoringRule .

ind:assignedInvestigatorName rdf:type rdf:Property ;
    rdfs:label 'Assigned Investigator Name' ;
    rdfs:comment 'Full name of the investigator assigned to this exception for tracking and accountability purposes.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessUnit rdf:type rdf:Property ;
    rdfs:label 'Business Unit' ;
    rdfs:comment 'The business unit or division where the exception occurred, enabling organizational segmentation and accountability.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataRecordReference rdf:type rdf:Property ;
    rdfs:label 'Data Record Reference' ;
    rdfs:comment 'Reference to the specific data record or transaction that triggered the exception (e.g., transaction ID, account ID, GL entry ID, trade ID).' ;
    rdfs:domain ind:MonitoringException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataRecordType rdf:type rdf:Property ;
    rdfs:label 'Data Record Type' ;
    rdfs:comment 'Type of data record referenced (e.g., transaction, account, loan, payment, trade, GL entry) to provide context for the data_record_reference.' ;
    rdfs:domain ind:MonitoringException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposition rdf:type rdf:Property ;
    rdfs:label 'Disposition' ;
    rdfs:comment 'Final disposition or outcome of the exception investigation (escalated to formal audit finding, determined to be false positive, accepted as risk by management, remediated, or pending review).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionDate rdf:type rdf:Property ;
    rdfs:label 'Disposition Date' ;
    rdfs:comment 'The date when the final disposition decision was made for this exception.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dispositionRationale rdf:type rdf:Property ;
    rdfs:label 'Disposition Rationale' ;
    rdfs:comment 'Explanation and business justification for the disposition decision, documenting why the exception was classified as it was.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionCategory rdf:type rdf:Property ;
    rdfs:label 'Exception Category' ;
    rdfs:comment 'High-level category grouping exceptions by business domain (operational, financial, compliance, security, data integrity, fraud indicator).' ;
    rdfs:domain ind:MonitoringException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionDate rdf:type rdf:Property ;
    rdfs:label 'Exception Date' ;
    rdfs:comment 'The date when the exception or anomaly was identified by the continuous monitoring program.' ;
    rdfs:domain ind:MonitoringException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exceptionDescription rdf:type rdf:Property ;
    rdfs:label 'Exception Description' ;
    rdfs:comment 'Detailed narrative description of the exception, including what was detected, the context, and why it was flagged as an anomaly.' ;
    rdfs:domain ind:MonitoringException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionNumber rdf:type rdf:Property ;
    rdfs:label 'Exception Number' ;
    rdfs:comment 'Business identifier for the exception, typically a human-readable reference number used in reporting and tracking.' ;
    rdfs:domain ind:MonitoringException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionStatus rdf:type rdf:Property ;
    rdfs:label 'Exception Status' ;
    rdfs:comment 'Current lifecycle status of the exception (open, under investigation, escalated to finding, closed as false positive, closed as accepted risk, closed as remediated).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Exception Timestamp' ;
    rdfs:comment 'The precise timestamp when the exception was detected by the monitoring system.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:exceptionType rdf:type rdf:Property ;
    rdfs:label 'Exception Type' ;
    rdfs:comment 'Classification of the exception based on the nature of the anomaly detected (e.g., control failure, policy violation, threshold breach, data quality issue, segregation of duties conflict, unauthorized access).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialImpactCurrency rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the financial impact amount.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationNotes rdf:type rdf:Property ;
    rdfs:label 'Investigation Notes' ;
    rdfs:comment 'Detailed notes and findings from the investigation process, documenting analysis, evidence reviewed, and preliminary conclusions.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationStartDate rdf:type rdf:Property ;
    rdfs:label 'Investigation Start Date' ;
    rdfs:comment 'The date when investigation of the exception formally began.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Impact Flag' ;
    rdfs:comment 'Indicates whether this exception has potential regulatory reporting or compliance implications (True/False).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resolutionAction rdf:type rdf:Property ;
    rdfs:label 'Resolution Action' ;
    rdfs:comment 'Description of the corrective or remedial action taken to resolve the exception, if applicable.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemName rdf:type rdf:Property ;
    rdfs:label 'Source System Name' ;
    rdfs:comment 'Name of the operational system from which the exception data originated (e.g., Core Banking System, Trading System, Payment Hub).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceAmount rdf:type rdf:Property ;
    rdfs:label 'Variance Amount' ;
    rdfs:comment 'The calculated difference between the actual value and the threshold value, representing the magnitude of the breach.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityAssuranceReviewId rdf:type rdf:Property ;
    rdfs:label 'Quality Assurance Review Id' ;
    rdfs:comment 'Unique identifier for the quality assurance review record. Primary key for the quality assurance review entity.' ;
    rdfs:domain ind:QualityAssuranceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priorReviewQualityAssuranceReviewId rdf:type rdf:Property ;
    rdfs:label 'Prior Review Quality Assurance Review Id' ;
    rdfs:comment 'Reference to the previous quality assurance review record, enabling tracking of improvement trends and follow-up on prior recommendations.' ;
    rdfs:domain ind:QualityAssuranceReview ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QualityAssuranceReview .

ind:actionPlanDueDate rdf:type rdf:Property ;
    rdfs:label 'Action Plan Due Date' ;
    rdfs:comment 'Target date by which the internal audit function commits to implementing corrective actions and improvements identified in the quality assurance review.' ;
    rdfs:domain ind:QualityAssuranceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditCommitteeApprovalFlag rdf:type rdf:Property ;
    rdfs:label 'Audit Committee Approval Flag' ;
    rdfs:comment 'Indicates whether the Audit Committee formally approved and accepted the quality assurance review findings and the Chief Audit Executives action plan.' ;
    rdfs:domain ind:QualityAssuranceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:caeResponse rdf:type rdf:Property ;
    rdfs:label 'Cae Response' ;
    rdfs:comment 'Formal response from the Chief Audit Executive to the quality assurance review findings and recommendations, including acceptance, planned actions, and implementation timelines for improvement initiatives.' ;
    rdfs:domain ind:QualityAssuranceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caeResponseDate rdf:type rdf:Property ;
    rdfs:label 'Cae Response Date' ;
    rdfs:comment 'Date when the Chief Audit Executive formally responded to the quality assurance review findings and recommendations.' ;
    rdfs:domain ind:QualityAssuranceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conformanceRating rdf:type rdf:Property ;
    rdfs:label 'Conformance Rating' ;
    rdfs:comment 'Overall assessment rating indicating the degree to which the internal audit activity conforms with the IIA Standards and Code of Ethics. Generally Conforms is the top rating indicating the internal audit activity is judged to achieve the fundamental requirements; Partially Conforms indicates deficiencies in practice; Does Not Conform indicates the internal audit activity has not achieved many or all of the fundamental requirements.' ;
    rdfs:domain ind:QualityAssuranceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpReviewDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Review Date' ;
    rdfs:comment 'Scheduled date for follow-up quality assurance review to assess progress on implementing recommendations and corrective actions.' ;
    rdfs:domain ind:QualityAssuranceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:followUpReviewRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Follow Up Review Required Flag' ;
    rdfs:comment 'Indicates whether a follow-up quality assurance review is required to validate implementation of corrective actions and improvements, typically triggered by partially conforms or does not conform ratings.' ;
    rdfs:domain ind:QualityAssuranceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:highPriorityRecommendationsCount rdf:type rdf:Property ;
    rdfs:label 'High Priority Recommendations Count' ;
    rdfs:comment 'Number of high-priority or critical recommendations requiring immediate management attention and remediation to address significant gaps in conformance with IIA Standards.' ;
    rdfs:domain ind:QualityAssuranceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:iiaStandardsScope rdf:type rdf:Property ;
    rdfs:label 'Iia Standards Scope' ;
    rdfs:comment 'Specific IIA Standards and principles evaluated during this quality assurance review, including attribute standards (1000-1300 series) and performance standards (2000-2600 series) assessed for conformance.' ;
    rdfs:domain ind:QualityAssuranceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:improvementOpportunities rdf:type rdf:Property ;
    rdfs:label 'Improvement Opportunities' ;
    rdfs:comment 'Areas identified for enhancement and improvement in the internal audit functions practices, methodologies, or conformance with IIA Standards, including specific recommendations for remediation.' ;
    rdfs:domain ind:QualityAssuranceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyObservations rdf:type rdf:Property ;
    rdfs:label 'Key Observations' ;
    rdfs:comment 'Summary of the principal findings and observations from the quality assurance review, highlighting strengths, areas of conformance, and opportunities for improvement in audit practices and methodologies.' ;
    rdfs:domain ind:QualityAssuranceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadReviewerName rdf:type rdf:Property ;
    rdfs:label 'Lead Reviewer Name' ;
    rdfs:comment 'Full name of the individual leading the quality assurance review, whether internal quality assurance manager or external assessment partner.' ;
    rdfs:domain ind:QualityAssuranceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendationsCount rdf:type rdf:Property ;
    rdfs:label 'Recommendations Count' ;
    rdfs:comment 'Total number of formal recommendations issued as part of the quality assurance review for improving audit practices and conformance with professional standards.' ;
    rdfs:domain ind:QualityAssuranceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Requirement Flag' ;
    rdfs:comment 'Indicates whether this quality assurance review was mandated by regulatory requirements or supervisory expectations (e.g., Federal Reserve, OCC, EBA guidance on internal audit effectiveness).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Review Completion Date' ;
    rdfs:comment 'Date when the quality assurance review fieldwork and assessment activities were completed and final report issued.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewNotes rdf:type rdf:Property ;
    rdfs:label 'Review Notes' ;
    rdfs:comment 'Additional notes, context, or commentary regarding the quality assurance review process, findings, or special circumstances affecting the assessment.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewNumber rdf:type rdf:Property ;
    rdfs:label 'Review Number' ;
    rdfs:comment 'Business identifier for the quality assurance review, typically following organizational numbering conventions (e.g., QA-2024-001).' ;
    rdfs:domain ind:QualityAssuranceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Review Period End Date' ;
    rdfs:comment 'Ending date of the audit activity period being assessed by this quality assurance review. Defines the temporal scope of audit work subject to quality evaluation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Review Period Start Date' ;
    rdfs:comment 'Beginning date of the audit activity period being assessed by this quality assurance review. Defines the temporal scope of audit work subject to quality evaluation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewStartDate rdf:type rdf:Property ;
    rdfs:label 'Review Start Date' ;
    rdfs:comment 'Date when the quality assurance review fieldwork and assessment activities commenced.' ;
    rdfs:domain ind:QualityAssuranceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewType rdf:type rdf:Property ;
    rdfs:label 'Review Type' ;
    rdfs:comment 'Classification of the quality assurance review distinguishing between internal self-assessments conducted by the audit function, external assessments by independent qualified reviewers, regulatory peer reviews mandated by supervisory authorities, ongoing monitoring activities, and periodic internal reviews.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewerOrganizationName rdf:type rdf:Property ;
    rdfs:label 'Reviewer Organization Name' ;
    rdfs:comment 'Name of the organization or firm conducting the external quality assurance review. Populated for external assessments and regulatory peer reviews; null for internal reviews.' ;
    rdfs:domain ind:QualityAssuranceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewerQualifications rdf:type rdf:Property ;
    rdfs:label 'Reviewer Qualifications' ;
    rdfs:comment 'Professional certifications and qualifications of the review team (e.g., CIA, CPA, CRMA) demonstrating competence and independence required for quality assessments.' ;
    rdfs:domain ind:QualityAssuranceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewerType rdf:type rdf:Property ;
    rdfs:label 'Reviewer Type' ;
    rdfs:comment 'Classification of the party conducting the quality assurance review, distinguishing between internal quality assurance teams, external independent assessors, regulatory examiners, and peer reviewers from other institutions.' ;
    rdfs:domain ind:QualityAssuranceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strengthsIdentified rdf:type rdf:Property ;
    rdfs:label 'Strengths Identified' ;
    rdfs:comment 'Specific strengths and best practices identified during the quality assurance review where the internal audit function demonstrates excellence or leading practices in conformance with professional standards.' ;
    rdfs:domain ind:QualityAssuranceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendationId rdf:type rdf:Property ;
    rdfs:label 'Recommendation Id' ;
    rdfs:comment 'Unique identifier for the audit recommendation record. Primary key.' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responsibleOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Responsible Owner Employee Id' ;
    rdfs:comment 'System identifier linking to the employee record of the responsible business owner in the Human Capital Management (HCM) system for accountability tracking and escalation workflows.' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:acceptanceStatus rdf:type rdf:Property ;
    rdfs:label 'Acceptance Status' ;
    rdfs:comment 'Management decision on whether to accept and implement the recommendation as proposed. Rejected recommendations require escalation to audit committee and documentation of risk acceptance.' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualImplementationDate rdf:type rdf:Property ;
    rdfs:label 'Actual Implementation Date' ;
    rdfs:comment 'Date when management completed implementation of the recommendation. Subject to validation testing by internal audit before final closure.' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:alternativeActionProposed rdf:type rdf:Property ;
    rdfs:label 'Alternative Action Proposed' ;
    rdfs:comment 'Description of alternative corrective action proposed by management when the original recommendation is rejected or modified. Subject to audit review and approval.' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlFrameworkReference rdf:type rdf:Property ;
    rdfs:label 'Control Framework Reference' ;
    rdfs:comment 'Reference to the specific control framework component addressed by the recommendation, such as COSO Internal Control Framework principles, Basel III operational risk controls, or ISO 27001 information security controls.' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationFlag rdf:type rdf:Property ;
    rdfs:label 'Escalation Flag' ;
    rdfs:comment 'Indicator whether the recommendation has been escalated to senior management or audit committee due to overdue status, rejection, or critical risk rating. Triggers enhanced monitoring and reporting.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedCostAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost Amount' ;
    rdfs:comment 'Projected financial cost to implement the recommendation, including technology investments, consulting fees, training costs, and ongoing operational expenses. Used for budgeting and cost-benefit analysis.' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedImplementationEffort rdf:type rdf:Property ;
    rdfs:label 'Estimated Implementation Effort' ;
    rdfs:comment 'Assessment of the resources, time, and complexity required to implement the recommendation. Used for prioritization and resource allocation decisions by management.' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implementationProgressPercentage rdf:type rdf:Property ;
    rdfs:label 'Implementation Progress Percentage' ;
    rdfs:comment 'Percentage completion of recommendation implementation as reported by management. Used for continuous monitoring and Key Risk Indicator (KRI) dashboards.' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isActive rdf:type rdf:Property ;
    rdfs:label 'Is Active' ;
    rdfs:comment 'Indicator whether the recommendation record is currently active. False for closed, cancelled, or archived recommendations. Used for filtering active remediation tracking.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:managementResponseDate rdf:type rdf:Property ;
    rdfs:label 'Management Response Date' ;
    rdfs:comment 'Date when management formally responded to the recommendation. Used to track Service Level Agreement (SLA) compliance for audit response timelines.' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originalTargetDate rdf:type rdf:Property ;
    rdfs:label 'Original Target Date' ;
    rdfs:comment 'Initial target remediation date established when the recommendation was first issued. Preserved for audit trail and variance analysis when target dates are extended.' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recommendationNumber rdf:type rdf:Property ;
    rdfs:label 'Recommendation Number' ;
    rdfs:comment 'Business-facing unique identifier for the recommendation, typically formatted as REC-YYYY-#### for external communication and tracking in audit committee reports.' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendationStatus rdf:type rdf:Property ;
    rdfs:label 'Recommendation Status' ;
    rdfs:comment 'Current lifecycle state of the recommendation. Tracks progression from initial issuance through management acceptance, implementation, validation by audit, and final closure. [ENUM-REF-CANDIDATE: draft|issued|accepted|rejected|in_progress|implemented|validated|closed|overdue — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendationText rdf:type rdf:Property ;
    rdfs:label 'Recommendation Text' ;
    rdfs:comment 'Detailed description of the specific corrective action proposed by internal audit to remediate the identified control deficiency. Includes the rationale, expected outcome, and implementation guidance.' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendationType rdf:type rdf:Property ;
    rdfs:label 'Recommendation Type' ;
    rdfs:comment 'Classification of the recommendation based on the nature of corrective action required: process improvement, control enhancement, policy update, system change, training, or organizational change.' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryRequirementReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Requirement Reference' ;
    rdfs:comment 'Citation of specific regulatory requirement, statute, or supervisory guidance that the recommendation addresses. Examples include Basel III capital requirements, Sarbanes-Oxley Act (SOX) controls, Bank Secrecy Act (BSA) compliance, or Dodd-Frank Act Stress Testing (DFAST) requirements.' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionRationale rdf:type rdf:Property ;
    rdfs:label 'Rejection Rationale' ;
    rdfs:comment 'Detailed explanation provided by management when a recommendation is rejected or partially accepted. Must include risk acceptance justification and alternative mitigation strategies if applicable.' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleBusinessOwner rdf:type rdf:Property ;
    rdfs:label 'Responsible Business Owner' ;
    rdfs:comment 'Name and title of the executive or manager accountable for implementing the recommendation. Typically a Line of Business (LOB) leader or control function head within the three lines of defense model.' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxControlFlag rdf:type rdf:Property ;
    rdfs:label 'Sox Control Flag' ;
    rdfs:comment 'Indicator whether the recommendation relates to a Sarbanes-Oxley Act (SOX) internal control over financial reporting. True if the recommendation impacts SOX 302 or SOX 404 compliance.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:threeLinesDefenseLine rdf:type rdf:Property ;
    rdfs:label 'Three Lines Defense Line' ;
    rdfs:comment 'Classification of which defense line the recommendation targets within the three lines of defense model: first line (business operations), second line (risk and compliance), or third line (internal audit).' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationAuditor rdf:type rdf:Property ;
    rdfs:label 'Validation Auditor' ;
    rdfs:comment 'Name of the internal auditor who performed validation testing of the implemented recommendation. Ensures independence and accountability in the validation process.' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAuditId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Audit Id' ;
    rdfs:comment 'Unique identifier for the regulatory audit examination record. Primary key for the regulatory audit entity.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryAudit .

ind:assetQualityRating rdf:type rdf:Property ;
    rdfs:label 'Asset Quality Rating' ;
    rdfs:comment 'CAMELS component rating for asset quality. Evaluates the quality of loan and investment portfolios, credit risk management, and adequacy of loan loss reserves. Ratings range from 1 (strongest) to 5 (weakest).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capitalAdequacyRating rdf:type rdf:Property ;
    rdfs:label 'Capital Adequacy Rating' ;
    rdfs:comment 'CAMELS component rating for capital adequacy. Assesses the quantity and quality of capital relative to the institutions risk profile. Ratings range from 1 (strongest) to 5 (weakest).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compositeRating rdf:type rdf:Property ;
    rdfs:label 'Composite Rating' ;
    rdfs:comment 'Overall composite rating assigned by the regulator based on the CAMELS rating system (Capital adequacy, Asset quality, Management, Earnings, Liquidity, Sensitivity to market risk). Ratings range from 1 (strongest) to 5 (weakest).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:earningsRating rdf:type rdf:Property ;
    rdfs:label 'Earnings Rating' ;
    rdfs:comment 'CAMELS component rating for earnings performance. Evaluates the quality, quantity, and sustainability of earnings. Ratings range from 1 (strongest) to 5 (weakest).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:examinationEndDate rdf:type rdf:Property ;
    rdfs:label 'Examination End Date' ;
    rdfs:comment 'Date when the regulatory examination fieldwork officially concluded. Marks the completion of on-site or remote examination activities by the regulatory team.' ;
    rdfs:domain ind:RegulatoryAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:examinationNotes rdf:type rdf:Property ;
    rdfs:label 'Examination Notes' ;
    rdfs:comment 'Additional notes, observations, or context regarding the regulatory examination. Captures supplementary information not covered in structured fields.' ;
    rdfs:domain ind:RegulatoryAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:examinationNumber rdf:type rdf:Property ;
    rdfs:label 'Examination Number' ;
    rdfs:comment 'Official examination reference number assigned by the regulatory body conducting the examination. This is the externally-known identifier used in all regulatory correspondence and documentation.' ;
    rdfs:domain ind:RegulatoryAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:examinationPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Examination Period End Date' ;
    rdfs:comment 'Ending date of the period under examination. Defines the end of the timeframe for which business activities, transactions, and controls are being reviewed by the regulator.' ;
    rdfs:domain ind:RegulatoryAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:examinationPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Examination Period Start Date' ;
    rdfs:comment 'Beginning date of the period under examination. Defines the start of the timeframe for which business activities, transactions, and controls are being reviewed by the regulator.' ;
    rdfs:domain ind:RegulatoryAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:examinationScopeDescription rdf:type rdf:Property ;
    rdfs:label 'Examination Scope Description' ;
    rdfs:comment 'Comprehensive narrative description of the examination scope including specific business lines, legal entities, geographic regions, systems, processes, and risk areas covered during the regulatory review.' ;
    rdfs:domain ind:RegulatoryAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:examinationStartDate rdf:type rdf:Property ;
    rdfs:label 'Examination Start Date' ;
    rdfs:comment 'Date when the regulatory examination fieldwork officially commenced. Marks the beginning of on-site or remote examination activities by the regulatory team.' ;
    rdfs:domain ind:RegulatoryAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:examinationStatus rdf:type rdf:Property ;
    rdfs:label 'Examination Status' ;
    rdfs:comment 'Current lifecycle status of the regulatory examination. Tracks the examination from initial scheduling through final closure and response submission. [ENUM-REF-CANDIDATE: scheduled|in progress|fieldwork complete|preliminary findings issued|final report issued|response submitted|closed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:examinationType rdf:type rdf:Property ;
    rdfs:label 'Examination Type' ;
    rdfs:comment 'Classification of the regulatory examination based on its primary focus area. Determines the scope and nature of the supervisory review being conducted.' ;
    rdfs:domain ind:RegulatoryAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finalFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Final Findings Count' ;
    rdfs:comment 'Number of final findings, matters requiring attention, or supervisory recommendations documented in the final examination report. Represents confirmed regulatory concerns requiring remediation.' ;
    rdfs:domain ind:RegulatoryAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:finalReportReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Final Report Received Date' ;
    rdfs:comment 'Date when the final examination report was officially received from the regulatory body. Marks the formal conclusion of the examination process.' ;
    rdfs:domain ind:RegulatoryAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:internalAuditLiaisonEmail rdf:type rdf:Property ;
    rdfs:label 'Internal Audit Liaison Email' ;
    rdfs:comment 'Email address of the internal audit liaison coordinating the regulatory examination response. Primary internal contact for examination coordination.' ;
    rdfs:domain ind:RegulatoryAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalAuditLiaisonName rdf:type rdf:Property ;
    rdfs:label 'Internal Audit Liaison Name' ;
    rdfs:comment 'Full name of the internal audit staff member designated as the primary liaison and coordinator for this regulatory examination. Responsible for coordinating internal responses and documentation requests.' ;
    rdfs:domain ind:RegulatoryAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadExaminerEmail rdf:type rdf:Property ;
    rdfs:label 'Lead Examiner Email' ;
    rdfs:comment 'Official email address of the lead examiner from the regulatory body. Used for formal examination correspondence and information requests.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadExaminerName rdf:type rdf:Property ;
    rdfs:label 'Lead Examiner Name' ;
    rdfs:comment 'Full name of the lead examiner from the regulatory body who is responsible for directing the examination. Primary point of contact from the regulatory authority.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadExaminerPhone rdf:type rdf:Property ;
    rdfs:label 'Lead Examiner Phone' ;
    rdfs:comment 'Direct contact phone number for the lead examiner from the regulatory body. Enables direct communication during the examination process.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liquidityRating rdf:type rdf:Property ;
    rdfs:label 'Liquidity Rating' ;
    rdfs:comment 'CAMELS component rating for liquidity position. Assesses the adequacy of liquidity sources relative to present and future needs, and the ability to meet obligations. Ratings range from 1 (strongest) to 5 (weakest).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managementRating rdf:type rdf:Property ;
    rdfs:label 'Management Rating' ;
    rdfs:comment 'CAMELS component rating for management capability. Assesses the competence of management and the board of directors, compliance with laws and regulations, and overall governance. Ratings range from 1 (strongest) to 5 (weakest).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matterRequiringAttentionCount rdf:type rdf:Property ;
    rdfs:label 'Matter Requiring Attention Count' ;
    rdfs:comment 'Number of Matters Requiring Attention (MRA) formally issued by the regulator. MRAs are supervisory concerns that require prompt corrective action and board-level attention.' ;
    rdfs:domain ind:RegulatoryAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:matterRequiringImmediateAttentionCount rdf:type rdf:Property ;
    rdfs:label 'Matter Requiring Immediate Attention Count' ;
    rdfs:comment 'Number of Matters Requiring Immediate Attention (MRIA) formally issued by the regulator. MRIAs are the most severe supervisory concerns requiring urgent corrective action and heightened board oversight.' ;
    rdfs:domain ind:RegulatoryAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preliminaryFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Preliminary Findings Count' ;
    rdfs:comment 'Number of preliminary findings, observations, or matters requiring attention identified by the regulatory examiners during the examination. Indicates the volume of issues discovered.' ;
    rdfs:domain ind:RegulatoryAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responseSubmittedDate rdf:type rdf:Property ;
    rdfs:label 'Response Submitted Date' ;
    rdfs:comment 'Date when the institutions formal written response to the regulatory examination findings was submitted to the regulator. Documents compliance with response deadlines.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scopeAreas rdf:type rdf:Property ;
    rdfs:label 'Scope Areas' ;
    rdfs:comment 'Detailed description of the business areas, processes, systems, and controls included within the scope of the regulatory examination. Defines what will be reviewed during the examination.' ;
    rdfs:domain ind:RegulatoryAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sensitivityToMarketRiskRating rdf:type rdf:Property ;
    rdfs:label 'Sensitivity To Market Risk Rating' ;
    rdfs:comment 'CAMELS component rating for sensitivity to market risk. Evaluates the degree to which changes in interest rates, foreign exchange rates, commodity prices, or equity prices can adversely affect earnings or capital. Ratings range from 1 (strongest) to 5 (weakest).' ;
    rdfs:domain ind:RegulatoryAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryFindingId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Finding Id' ;
    rdfs:comment 'Unique identifier for the regulatory finding record issued by an external regulator during a supervisory examination.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryFinding .

ind:citedPartyId rdf:type rdf:Property ;
    rdfs:label 'Cited Party Id' ;
    rdfs:comment 'Foreign key linking to customer.party. Business justification: Regulatory findings may cite specific customer cases as examples of control failures (AML violations, BSA deficiencies, fair lending issues). Links finding to customer for remediation tracking, relati' ;
    rdfs:domain ind:RegulatoryFinding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:regulatoryExamId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Exam Id' ;
    rdfs:comment 'Reference to the regulatory examination or supervisory review during which this finding was issued.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryExam .

ind:stressTestRunId rdf:type rdf:Property ;
    rdfs:label 'Stress Test Run Id' ;
    rdfs:comment 'Foreign key linking to risk.stress_test_run. Business justification: Regulatory findings from CCAR/DFAST examinations reference specific stress test runs. Links examiner finding to the run under review, supporting regulatory response, remediation tracking, and capital ' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StressTestRun .

ind:boardEscalationFlag rdf:type rdf:Property ;
    rdfs:label 'Board Escalation Flag' ;
    rdfs:comment 'Indicates whether the finding was escalated to the Board of Directors or Audit Committee due to severity, regulatory consequence, or materiality (True/False).' ;
    rdfs:domain ind:RegulatoryFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:boardReportingDate rdf:type rdf:Property ;
    rdfs:label 'Board Reporting Date' ;
    rdfs:comment 'Date on which the finding was reported to the Board of Directors or Audit Committee.' ;
    rdfs:domain ind:RegulatoryFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:businessLine rdf:type rdf:Property ;
    rdfs:label 'Business Line' ;
    rdfs:comment 'Line of business or business unit to which the finding applies (e.g., Retail Banking, Commercial Lending, Investment Banking, Wealth Management, Treasury).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureStatus rdf:type rdf:Property ;
    rdfs:label 'Closure Status' ;
    rdfs:comment 'Current closure status of the regulatory finding (Open, Closed, Pending Validation by regulator, Reopened due to ineffective remediation).' ;
    rdfs:domain ind:RegulatoryFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enforcementActionFlag rdf:type rdf:Property ;
    rdfs:label 'Enforcement Action Flag' ;
    rdfs:comment 'Indicates whether the finding resulted in or is associated with a formal enforcement action by the regulator (e.g., consent order, cease and desist order, civil money penalty) (True/False).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:enforcementActionReference rdf:type rdf:Property ;
    rdfs:label 'Enforcement Action Reference' ;
    rdfs:comment 'Reference number or citation of the formal enforcement action if applicable (e.g., consent order number, docket number).' ;
    rdfs:domain ind:RegulatoryFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingDescription rdf:type rdf:Property ;
    rdfs:label 'Finding Description' ;
    rdfs:comment 'Detailed description of the regulatory finding, including the deficiency identified, the control weakness, and the regulatory concern as documented by the examiner.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingTitle rdf:type rdf:Property ;
    rdfs:label 'Finding Title' ;
    rdfs:comment 'Short title or summary of the regulatory finding as stated in the examination report.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorFindingReference rdf:type rdf:Property ;
    rdfs:label 'Prior Finding Reference' ;
    rdfs:comment 'Reference to the prior regulatory finding or examination number if this is a repeat finding.' ;
    rdfs:domain ind:RegulatoryFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorClosureConfirmationFlag rdf:type rdf:Property ;
    rdfs:label 'Regulator Closure Confirmation Flag' ;
    rdfs:comment 'Indicates whether the regulator has formally confirmed closure of the finding (True) or whether closure is internal only pending regulator review (False).' ;
    rdfs:domain ind:RegulatoryFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatorOffice rdf:type rdf:Property ;
    rdfs:label 'Regulator Office' ;
    rdfs:comment 'Specific office, district, or regional division of the regulator that conducted the examination (e.g., OCC District Office, Federal Reserve Bank of New York).' ;
    rdfs:domain ind:RegulatoryFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationCommitment rdf:type rdf:Property ;
    rdfs:label 'Remediation Commitment' ;
    rdfs:comment 'Summary of the banks committed remediation actions and corrective measures as documented in the formal response to the regulator.' ;
    rdfs:domain ind:RegulatoryFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationDueDate rdf:type rdf:Property ;
    rdfs:label 'Remediation Due Date' ;
    rdfs:comment 'Target date by which the bank has committed to complete all remediation actions and close the finding, as agreed with the regulator.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remediationOwner rdf:type rdf:Property ;
    rdfs:label 'Remediation Owner' ;
    rdfs:comment 'Name or title of the executive, business unit head, or control function owner responsible for executing the remediation plan and closing the finding.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationStatus rdf:type rdf:Property ;
    rdfs:label 'Remediation Status' ;
    rdfs:comment 'Current status of remediation activities (Not Started, In Progress, Completed, Validated by internal audit or compliance, Overdue).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseStatus rdf:type rdf:Property ;
    rdfs:label 'Response Status' ;
    rdfs:comment 'Current status of the banks formal response to the regulator (Not Started, In Progress, Submitted, Accepted by regulator, Rejected by regulator, Resubmitted).' ;
    rdfs:domain ind:RegulatoryFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseAnalysis rdf:type rdf:Property ;
    rdfs:label 'Root Cause Analysis' ;
    rdfs:comment 'Summary of the root cause analysis conducted by the bank to identify the underlying cause of the deficiency (e.g., process gap, control weakness, resource constraint, system limitation).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severityLevel rdf:type rdf:Property ;
    rdfs:label 'Severity Level' ;
    rdfs:comment 'Internal severity classification assigned to the finding based on risk impact, regulatory consequence, and remediation urgency (Critical, High, Moderate, Low).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:threeLinesAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Three Lines Assignment Id' ;
    rdfs:comment 'Unique identifier for the three lines of defense assignment record.' ;
    rdfs:domain ind:ThreeLinesAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountabilityClarityScore rdf:type rdf:Property ;
    rdfs:label 'Accountability Clarity Score' ;
    rdfs:comment 'A score (0-100) representing the clarity and completeness of accountability mapping for this assignment, used to identify gaps or overlaps in the three lines model.' ;
    rdfs:domain ind:ThreeLinesAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignedLineOfDefense rdf:type rdf:Property ;
    rdfs:label 'Assigned Line Of Defense' ;
    rdfs:comment 'The line of defense to which this control activity is assigned: first line (business management and operational controls), second line (risk management and compliance oversight), or third line (internal audit independent assurance).' ;
    rdfs:domain ind:ThreeLinesAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentCode rdf:type rdf:Property ;
    rdfs:label 'Assignment Code' ;
    rdfs:comment 'Business identifier code for the three lines assignment, used for external reference and reporting.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentRationale rdf:type rdf:Property ;
    rdfs:label 'Assignment Rationale' ;
    rdfs:comment 'Business justification and rationale for assigning this control activity to the designated line of defense, including risk considerations and organizational structure.' ;
    rdfs:domain ind:ThreeLinesAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditCoverageResponsibility rdf:type rdf:Property ;
    rdfs:label 'Audit Coverage Responsibility' ;
    rdfs:comment 'The internal audit team or function responsible for providing independent assurance over this control domain (e.g., Financial Audit, Operational Audit, IT Audit, Compliance Audit).' ;
    rdfs:domain ind:ThreeLinesAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditLeadName rdf:type rdf:Property ;
    rdfs:label 'Audit Lead Name' ;
    rdfs:comment 'Name of the audit lead or senior auditor responsible for third line assurance activities related to this assignment.' ;
    rdfs:domain ind:ThreeLinesAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlActivity rdf:type rdf:Property ;
    rdfs:label 'Control Activity' ;
    rdfs:comment 'The specific control activity or control process being assigned to a line of defense (e.g., loan approval process, trade reconciliation, KYC verification).' ;
    rdfs:domain ind:ThreeLinesAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlOwnerEmail rdf:type rdf:Property ;
    rdfs:label 'Control Owner Email' ;
    rdfs:comment 'Email address of the control owner for communication and escalation purposes.' ;
    rdfs:domain ind:ThreeLinesAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlOwnerName rdf:type rdf:Property ;
    rdfs:label 'Control Owner Name' ;
    rdfs:comment 'Name of the individual or role responsible for owning and executing the control activity within the assigned line of defense.' ;
    rdfs:domain ind:ThreeLinesAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlOwnerTitle rdf:type rdf:Property ;
    rdfs:label 'Control Owner Title' ;
    rdfs:comment 'Job title or role designation of the control owner (e.g., Credit Risk Manager, Compliance Officer, Business Unit Head).' ;
    rdfs:domain ind:ThreeLinesAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationProtocol rdf:type rdf:Property ;
    rdfs:label 'Escalation Protocol' ;
    rdfs:comment 'Defined escalation path and protocol for issues or breaches identified within this control domain, specifying communication channels and decision authority.' ;
    rdfs:domain ind:ThreeLinesAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gapFlag rdf:type rdf:Property ;
    rdfs:label 'Gap Flag' ;
    rdfs:comment 'Indicates whether this assignment has identified gaps in coverage where no line of defense has clear accountability.' ;
    rdfs:domain ind:ThreeLinesAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overlapFlag rdf:type rdf:Property ;
    rdfs:label 'Overlap Flag' ;
    rdfs:comment 'Indicates whether this assignment has identified overlaps or conflicts with other three lines assignments, requiring resolution or clarification.' ;
    rdfs:domain ind:ThreeLinesAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:oversightFunction rdf:type rdf:Property ;
    rdfs:label 'Oversight Function' ;
    rdfs:comment 'The second line oversight function responsible for monitoring and challenging the control (e.g., Enterprise Risk Management, Compliance, Legal, Financial Control).' ;
    rdfs:domain ind:ThreeLinesAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oversightOwnerName rdf:type rdf:Property ;
    rdfs:label 'Oversight Owner Name' ;
    rdfs:comment 'Name of the individual or role responsible for second line oversight of this control activity.' ;
    rdfs:domain ind:ThreeLinesAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Review Frequency Months' ;
    rdfs:comment 'The frequency in months at which this assignment should be reviewed (e.g., 6, 12, 24 months).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:riskSubcategory rdf:type rdf:Property ;
    rdfs:label 'Risk Subcategory' ;
    rdfs:comment 'More granular risk subcategory or risk type within the primary risk category (e.g., counterparty credit risk, interest rate risk, fraud risk, AML risk).' ;
    rdfs:domain ind:ThreeLinesAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workpaperId rdf:type rdf:Property ;
    rdfs:label 'Workpaper Id' ;
    rdfs:comment 'Unique identifier for the audit workpaper record. Primary key for the workpaper entity.' ;
    rdfs:domain ind:Workpaper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:almHedgeId rdf:type rdf:Property ;
    rdfs:label 'Alm Hedge Id' ;
    rdfs:comment 'Foreign key linking to treasury.alm_hedge. Business justification: Auditors test hedge designation, effectiveness testing, and hedge accounting treatment. Workpapers reference specific hedge records as audit evidence for ASC 815 compliance and ALM strategy execution.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AlmHedge .

ind:auditProgramStepId rdf:type rdf:Property ;
    rdfs:label 'Audit Program Step Id' ;
    rdfs:comment 'Reference to the specific audit program step that this workpaper documents. Links workpaper to the planned audit procedure.' ;
    rdfs:domain ind:Workpaper ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProgramStep .

ind:businessProcessId rdf:type rdf:Property ;
    rdfs:label 'Business Process Id' ;
    rdfs:comment 'Reference to the business process under audit that this workpaper documents. Links workpaper to the process hierarchy.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BusinessProcess .

ind:debtIssuanceId rdf:type rdf:Property ;
    rdfs:label 'Debt Issuance Id' ;
    rdfs:comment 'Foreign key linking to treasury.debt_issuance. Business justification: Auditors test debt issuance authorization, pricing, use of proceeds, and accounting treatment. Workpapers reference specific issuance records as transaction-level audit evidence for funding and capita' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DebtIssuance .

ind:ftpRateId rdf:type rdf:Property ;
    rdfs:label 'Ftp Rate Id' ;
    rdfs:comment 'Foreign key linking to treasury.ftp_rate. Business justification: Auditors test FTP rate calculations, approval workflows, and rate application accuracy. Workpapers reference specific rate records as audit evidence for transfer pricing governance and NIM allocation ' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FtpRate .

ind:hqlaInventoryId rdf:type rdf:Property ;
    rdfs:label 'Hqla Inventory Id' ;
    rdfs:comment 'Foreign key linking to treasury.hqla_inventory. Business justification: Auditors test HQLA eligibility, valuation, haircut application, and encumbrance status. Workpapers reference specific securities as substantive testing evidence for LCR calculation and liquidity risk ' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HqlaInventory .

ind:lcId rdf:type rdf:Property ;
    rdfs:label 'Lc Id' ;
    rdfs:comment 'Foreign key linking to loan.lc. Business justification: Trade finance audits test specific letters of credit for UCP 600 compliance, document examination accuracy, and sanctions screening. Workpapers must reference the LC tested for audit trail and regulat' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lc .

ind:subjectPartyId rdf:type rdf:Property ;
    rdfs:label 'Subject Party Id' ;
    rdfs:comment 'Foreign key linking to customer.party. Business justification: Workpapers document audit evidence about specific customers (transaction testing, KYC verification, credit file reviews). Links evidence to customer for regulatory exam support, audit trail completene' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:supportingDocumentId rdf:type rdf:Property ;
    rdfs:label 'Supporting Document Id' ;
    rdfs:comment 'Foreign key linking to account.account_document. Business justification: Audit workpapers reference supporting documents as evidence (account opening forms, KYC documents, authorization records). Links workpaper to specific documents reviewed, required for audit trail comp' ;
    rdfs:domain ind:Workpaper ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Document .

ind:testedStandingOrderId rdf:type rdf:Property ;
    rdfs:label 'Tested Standing Order Id' ;
    rdfs:comment 'Foreign key linking to account.standing_order. Business justification: Auditors test standing orders for proper authorization, AML screening, and execution accuracy. Workpapers document sample orders tested and results. Required for operational audit evidence and payment' ;
    rdfs:domain ind:Workpaper ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StandingOrder .

ind:workpaperEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Workpaper Employee Id' ;
    rdfs:comment 'Reference to the auditor or staff member who prepared this workpaper. Establishes accountability for workpaper creation.' ;
    rdfs:domain ind:Workpaper ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:auditConclusion rdf:type rdf:Property ;
    rdfs:label 'Audit Conclusion' ;
    rdfs:comment 'Summary conclusion reached by the auditor based on the evidence documented in this workpaper. Articulates the auditor\'s professional judgment on the control effectiveness, risk level, or compliance status tested.' ;
    rdfs:domain ind:Workpaper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataExtractionDate rdf:type rdf:Property ;
    rdfs:label 'Data Extraction Date' ;
    rdfs:comment 'Date when data was extracted from the source system for analysis in this workpaper. Establishes data currency and as-of date for testing.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dataExtractionQuery rdf:type rdf:Property ;
    rdfs:label 'Data Extraction Query' ;
    rdfs:comment 'SQL query, report parameters, or extraction criteria used to obtain data from the source system. Documents reproducibility of data extraction.' ;
    rdfs:domain ind:Workpaper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentFormat rdf:type rdf:Property ;
    rdfs:label 'Document Format' ;
    rdfs:comment 'File format of the stored workpaper document: pdf (portable document format), excel (spreadsheet), word (text document), powerpoint (presentation), email (email correspondence), image (scanned document or screenshot), video (recorded interview or observation), audio (recorded interview), or other (miscellaneous format). [ENUM-REF-CANDIDATE: pdf|excel|word|powerpoint|email|image|video|audio|other — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentPageCount rdf:type rdf:Property ;
    rdfs:label 'Document Page Count' ;
    rdfs:comment 'Number of pages in the workpaper document. Used for workpaper inventory and completeness verification.' ;
    rdfs:domain ind:Workpaper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:documentStorageReference rdf:type rdf:Property ;
    rdfs:label 'Document Storage Reference' ;
    rdfs:comment 'File path, URL, or document management system reference to the physical workpaper document (e.g., SharePoint URL, network path, document ID in audit management system). Enables retrieval of supporting documentation.' ;
    rdfs:domain ind:Workpaper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Exception Rate Percentage' ;
    rdfs:comment 'Calculated exception rate as a percentage of sample size (exceptions / sample size * 100). Used to assess materiality and control deficiency severity.' ;
    rdfs:domain ind:Workpaper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exceptionsIdentifiedCount rdf:type rdf:Property ;
    rdfs:label 'Exceptions Identified Count' ;
    rdfs:comment 'Number of exceptions or deviations identified during testing documented in this workpaper. Used to assess control reliability and determine if findings should be raised.' ;
    rdfs:domain ind:Workpaper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:findingRaisedFlag rdf:type rdf:Property ;
    rdfs:label 'Finding Raised Flag' ;
    rdfs:comment 'Indicates whether a formal audit finding was raised based on the evidence in this workpaper. True if finding was escalated to audit report, false otherwise.' ;
    rdfs:domain ind:Workpaper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interviewDate rdf:type rdf:Property ;
    rdfs:label 'Interview Date' ;
    rdfs:comment 'Date when the interview was conducted. Applicable for interview notes workpapers.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:intervieweeName rdf:type rdf:Property ;
    rdfs:label 'Interviewee Name' ;
    rdfs:comment 'Name of the individual interviewed for this workpaper. Applicable for interview notes workpapers. Classified as confidential to protect interview participant identity.' ;
    rdfs:domain ind:Workpaper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intervieweeTitle rdf:type rdf:Property ;
    rdfs:label 'Interviewee Title' ;
    rdfs:comment 'Job title or role of the individual interviewed (e.g., \'VP Credit Risk\', \'Senior Loan Officer\'). Provides context for interview responses.' ;
    rdfs:domain ind:Workpaper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preparationDate rdf:type rdf:Property ;
    rdfs:label 'Preparation Date' ;
    rdfs:comment 'Date when the workpaper was prepared or completed by the auditor. Establishes timeline of audit work performed.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryRequirement rdf:type rdf:Property ;
    rdfs:label 'Regulatory Requirement' ;
    rdfs:comment 'Specific regulatory requirement, standard, or compliance obligation that this workpaper addresses (e.g., \'SOX Section 404\', \'Basel III Pillar 1\', \'GDPR Article 32\'). Links audit work to regulatory mandates.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workpaperDescription rdf:type rdf:Property ;
    rdfs:label 'Workpaper Description' ;
    rdfs:comment 'Detailed description of the audit work performed, methodology applied, scope of testing, and any relevant context for understanding the workpaper content.' ;
    rdfs:domain ind:Workpaper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workpaperType rdf:type rdf:Property ;
    rdfs:label 'Workpaper Type' ;
    rdfs:comment 'Classification of the workpaper by its audit purpose: planning memo (audit planning documentation), control walkthrough (process and control documentation), test of controls (control effectiveness testing), substantive test (detailed transaction testing), interview notes (stakeholder interview documentation), or data extract (system data analysis).' ;
    rdfs:domain ind:Workpaper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelAlertId rdf:type rdf:Property ;
    rdfs:label 'Channel Alert Id' ;
    rdfs:comment 'Unique identifier for the channel alert record. Primary key.' ;
    rdfs:domain ind:ChannelAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:campaignId rdf:type rdf:Property ;
    rdfs:label 'Campaign Id' ;
    rdfs:comment 'Reference to the marketing or communication campaign associated with this alert, if applicable, enabling campaign performance tracking.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Campaign .

ind:instructionId rdf:type rdf:Property ;
    rdfs:label 'Instruction Id' ;
    rdfs:comment 'Foreign key linking to payment.payment_instruction. Business justification: Alerts may reference payment instructions for scheduled payment reminders, mandate expiration notices, or instruction-level status updates. Supports proactive customer communication and payment instru' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Instruction .

ind:templateId rdf:type rdf:Property ;
    rdfs:label 'Template Id' ;
    rdfs:comment 'Reference to the message template used to generate this alert, enabling template performance tracking and version control.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:transactionId rdf:type rdf:Property ;
    rdfs:label 'Transaction Id' ;
    rdfs:comment 'Reference to the specific transaction that triggered this alert, if applicable (e.g., for transaction confirmation or fraud alerts).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccountTransaction .

ind:actualSendTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Send Timestamp' ;
    rdfs:comment 'The actual date and time when the alert was sent to the delivery provider, following format yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:ChannelAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:alertCategory rdf:type rdf:Property ;
    rdfs:label 'Alert Category' ;
    rdfs:comment 'High-level categorization of the alert for reporting and analytics: operational (transactional updates), regulatory (compliance-driven notices), marketing (promotional), risk (fraud/security), or service (customer service notifications).' ;
    rdfs:domain ind:ChannelAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertType rdf:type rdf:Property ;
    rdfs:label 'Alert Type' ;
    rdfs:comment 'Classification of the alert based on its business purpose: transaction confirmation, fraud detection, balance threshold breach, payment due reminder, regulatory notice, security notification, promotional message, service update, branch appointment reminder, or statement availability. [ENUM-REF-CANDIDATE: transaction_alert|fraud_alert|balance_threshold|payment_due|regulatory_notice|security_alert|promotional|service_notification|appointment_reminder|statement_ready — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerResponse rdf:type rdf:Property ;
    rdfs:label 'Customer Response' ;
    rdfs:comment 'The customer\'s response or action taken after receiving the alert: acknowledged, dismissed, clicked embedded link, contacted the bank, or no response recorded.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveredTimestamp rdf:type rdf:Property ;
    rdfs:label 'Delivered Timestamp' ;
    rdfs:comment 'The date and time when the alert was successfully delivered to the customer\'s device or inbox, following format yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:ChannelAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deliveryCostAmount rdf:type rdf:Property ;
    rdfs:label 'Delivery Cost Amount' ;
    rdfs:comment 'The cost incurred for delivering this alert through the chosen channel, typically charged by the delivery provider.' ;
    rdfs:domain ind:ChannelAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryCostCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Delivery Cost Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the delivery cost amount.' ;
    rdfs:domain ind:ChannelAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryProvider rdf:type rdf:Property ;
    rdfs:label 'Delivery Provider' ;
    rdfs:comment 'Name of the third-party service provider or platform used to deliver the alert (e.g., Twilio for SMS, SendGrid for email, Firebase for push notifications).' ;
    rdfs:domain ind:ChannelAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureReason rdf:type rdf:Property ;
    rdfs:label 'Failure Reason' ;
    rdfs:comment 'Detailed explanation of why the alert delivery failed, if applicable (e.g., invalid phone number, email bounced, device token expired, customer blocked sender).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageCode rdf:type rdf:Property ;
    rdfs:label 'Language Code' ;
    rdfs:comment 'Two-letter ISO 639-1 language code indicating the language in which the alert was delivered, based on customer preference.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastRetryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Retry Timestamp' ;
    rdfs:comment 'The date and time of the most recent delivery retry attempt, following format yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:ChannelAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:personalizationApplied rdf:type rdf:Property ;
    rdfs:label 'Personalization Applied' ;
    rdfs:comment 'Indicates whether customer-specific personalization (name, account details, transaction amounts) was applied to the alert content (True) or a generic template was used (False).' ;
    rdfs:domain ind:ChannelAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:providerMessageReference rdf:type rdf:Property ;
    rdfs:label 'Provider Message Reference' ;
    rdfs:comment 'Unique message identifier assigned by the delivery provider, used for tracking and troubleshooting delivery issues.' ;
    rdfs:domain ind:ChannelAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readTimestamp rdf:type rdf:Property ;
    rdfs:label 'Read Timestamp' ;
    rdfs:comment 'The date and time when the customer opened or read the alert, if tracking is available, following format yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:ChannelAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recipientAddress rdf:type rdf:Property ;
    rdfs:label 'Recipient Address' ;
    rdfs:comment 'The specific delivery address used for this alert: email address, phone number, device token, or other channel-specific identifier.' ;
    rdfs:domain ind:ChannelAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Flag' ;
    rdfs:comment 'Indicates whether this alert is mandated by regulatory requirements (True) or is discretionary/operational (False).' ;
    rdfs:domain ind:ChannelAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Response Timestamp' ;
    rdfs:comment 'The date and time when the customer responded to or interacted with the alert, following format yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:ChannelAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:retryCount rdf:type rdf:Property ;
    rdfs:label 'Retry Count' ;
    rdfs:comment 'Number of delivery retry attempts made for this alert after initial failure.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scheduledSendTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Send Timestamp' ;
    rdfs:comment 'The date and time when the alert was scheduled to be sent, following format yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:ChannelAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:slaMetFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Met Flag' ;
    rdfs:comment 'Indicates whether the alert was delivered within the defined Service Level Agreement (SLA) target time (True) or exceeded the target (False).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaTargetDeliveryMinutes rdf:type rdf:Property ;
    rdfs:label 'Sla Target Delivery Minutes' ;
    rdfs:comment 'The target number of minutes within which this alert type should be delivered, as defined by internal Service Level Agreement (SLA) standards.' ;
    rdfs:domain ind:ChannelAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subject rdf:type rdf:Property ;
    rdfs:label 'Subject' ;
    rdfs:comment 'Subject line or headline of the alert message, providing a brief summary of the notification content.' ;
    rdfs:domain ind:ChannelAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggeredByEvent rdf:type rdf:Property ;
    rdfs:label 'Triggered By Event' ;
    rdfs:comment 'Description of the business event or condition that triggered the alert generation (e.g., balance below threshold, large withdrawal, suspicious activity detected).' ;
    rdfs:domain ind:ChannelAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apiApplicationId rdf:type rdf:Property ;
    rdfs:label 'Api Application Id' ;
    rdfs:comment 'Unique identifier for the API application registration record. Primary key for the API application entity.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ApiApplication .

ind:accountInformationServiceEnabled rdf:type rdf:Property ;
    rdfs:label 'Account Information Service Enabled' ;
    rdfs:comment 'Boolean flag indicating whether the application is authorized to access account information services under PSD2 or equivalent open banking regulations.' ;
    rdfs:domain ind:ApiApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:activationDate rdf:type rdf:Property ;
    rdfs:label 'Activation Date' ;
    rdfs:comment 'Date on which the API application was activated and granted access to production APIs following successful onboarding and approval.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:apiProductSubscriptions rdf:type rdf:Property ;
    rdfs:label 'Api Product Subscriptions' ;
    rdfs:comment 'Comma-separated list of API product subscriptions granted to the application, such as account information service (AIS), payment initiation service (PIS), funds confirmation service (FCS), and other open banking services.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationCode rdf:type rdf:Property ;
    rdfs:label 'Application Code' ;
    rdfs:comment 'Unique business identifier or code assigned to the API application for external reference and integration purposes.' ;
    rdfs:domain ind:ApiApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationName rdf:type rdf:Property ;
    rdfs:label 'Application Name' ;
    rdfs:comment 'Human-readable name of the third-party provider (TPP) or internal application registered to consume the bank\'s open banking APIs.' ;
    rdfs:domain ind:ApiApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationStatus rdf:type rdf:Property ;
    rdfs:label 'Application Status' ;
    rdfs:comment 'Current lifecycle status of the API application registration indicating whether the application is authorized to consume APIs.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationType rdf:type rdf:Property ;
    rdfs:label 'Application Type' ;
    rdfs:comment 'Classification of the API application based on the nature of the consumer organization (third-party provider, internal application, partner, fintech, aggregator, or merchant service).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callbackUrl rdf:type rdf:Property ;
    rdfs:label 'Callback Url' ;
    rdfs:comment 'Registered callback URL to which the bank\'s API gateway will redirect users after authentication or send asynchronous notifications.' ;
    rdfs:domain ind:ApiApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentDurationDays rdf:type rdf:Property ;
    rdfs:label 'Consent Duration Days' ;
    rdfs:comment 'Maximum number of days for which customer consent remains valid for this application to access their data, as defined by regulatory requirements or bank policy.' ;
    rdfs:domain ind:ApiApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataAccessScope rdf:type rdf:Property ;
    rdfs:label 'Data Access Scope' ;
    rdfs:comment 'Detailed description of the data access permissions and scope granted to the application, including specific account types, transaction history depth, and customer data elements.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deactivationDate rdf:type rdf:Property ;
    rdfs:label 'Deactivation Date' ;
    rdfs:comment 'Date on which the API application was deactivated or revoked, terminating its access to the bank\'s APIs.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:developerContactEmail rdf:type rdf:Property ;
    rdfs:label 'Developer Contact Email' ;
    rdfs:comment 'Primary email address for technical and operational communication with the application developer or organization.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:developerContactPhone rdf:type rdf:Property ;
    rdfs:label 'Developer Contact Phone' ;
    rdfs:comment 'Primary phone number for contacting the application developer or organization for support and incident management.' ;
    rdfs:domain ind:ApiApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:developerOrganizationName rdf:type rdf:Property ;
    rdfs:label 'Developer Organization Name' ;
    rdfs:comment 'Legal name of the organization or entity that developed and owns the API application.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eidasCertificateExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Eidas Certificate Expiry Date' ;
    rdfs:comment 'Expiration date of the eIDAS qualified certificate. The application must renew the certificate before this date to maintain API access.' ;
    rdfs:domain ind:ApiApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eidasCertificateIssuer rdf:type rdf:Property ;
    rdfs:label 'Eidas Certificate Issuer' ;
    rdfs:comment 'Name of the qualified trust service provider (QTSP) that issued the eIDAS certificate for the application.' ;
    rdfs:domain ind:ApiApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eidasCertificateReference rdf:type rdf:Property ;
    rdfs:label 'Eidas Certificate Reference' ;
    rdfs:comment 'Reference identifier for the eIDAS qualified certificate used for secure authentication and digital signatures in PSD2 API transactions.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:encryptionStandard rdf:type rdf:Property ;
    rdfs:label 'Encryption Standard' ;
    rdfs:comment 'Encryption protocol and version required for secure communication between the application and the bank\'s API endpoints (e.g., TLS 1.2, TLS 1.3, mutual TLS).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environment rdf:type rdf:Property ;
    rdfs:label 'Environment' ;
    rdfs:comment 'Deployment environment in which the API application is registered and operates (sandbox for testing, UAT for user acceptance testing, production for live operations).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundsConfirmationServiceEnabled rdf:type rdf:Property ;
    rdfs:label 'Funds Confirmation Service Enabled' ;
    rdfs:comment 'Boolean flag indicating whether the application is authorized to confirm availability of funds for card-based payment transactions under PSD2 or equivalent open banking regulations.' ;
    rdfs:domain ind:ApiApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ipWhitelist rdf:type rdf:Property ;
    rdfs:label 'Ip Whitelist' ;
    rdfs:comment 'Comma-separated list of IP addresses or CIDR ranges from which the application is permitted to make API requests for enhanced security.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oauth2ClientIdentifier rdf:type rdf:Property ;
    rdfs:label 'Oauth2 Client Identifier' ;
    rdfs:comment 'OAuth 2.0 client identifier assigned to the application for authentication and authorization flows in the open banking API ecosystem.' ;
    rdfs:domain ind:ApiApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oauth2ClientSecretHash rdf:type rdf:Property ;
    rdfs:label 'Oauth2 Client Secret Hash' ;
    rdfs:comment 'Hashed representation of the OAuth 2.0 client secret used for secure authentication. The plaintext secret is never stored.' ;
    rdfs:domain ind:ApiApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onboardingApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Onboarding Approval Date' ;
    rdfs:comment 'Date on which the application\'s onboarding request was approved and the application was authorized to access production APIs.' ;
    rdfs:domain ind:ApiApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:onboardingApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Onboarding Approval Status' ;
    rdfs:comment 'Status of the application\'s onboarding approval process indicating whether the bank has authorized the application to access production APIs.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onboardingApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Onboarding Approved By' ;
    rdfs:comment 'Name or identifier of the bank employee or system that approved the application\'s onboarding request.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentInitiationServiceEnabled rdf:type rdf:Property ;
    rdfs:label 'Payment Initiation Service Enabled' ;
    rdfs:comment 'Boolean flag indicating whether the application is authorized to initiate payments on behalf of customers under PSD2 or equivalent open banking regulations.' ;
    rdfs:domain ind:ApiApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rateLimitRequestsPerDay rdf:type rdf:Property ;
    rdfs:label 'Rate Limit Requests Per Day' ;
    rdfs:comment 'Maximum number of API requests the application is permitted to make per day based on its assigned rate limit tier.' ;
    rdfs:domain ind:ApiApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rateLimitRequestsPerMinute rdf:type rdf:Property ;
    rdfs:label 'Rate Limit Requests Per Minute' ;
    rdfs:comment 'Maximum number of API requests the application is permitted to make per minute based on its assigned rate limit tier.' ;
    rdfs:domain ind:ApiApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rateLimitTier rdf:type rdf:Property ;
    rdfs:label 'Rate Limit Tier' ;
    rdfs:comment 'Tier classification that determines the maximum number of API requests the application is allowed to make within a specified time period.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationDate rdf:type rdf:Property ;
    rdfs:label 'Registration Date' ;
    rdfs:comment 'Date on which the API application was initially registered in the bank\'s open banking platform.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryRegistrationStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Registration Status' ;
    rdfs:comment 'Status of the application\'s regulatory registration with competent authorities such as PSD2 TPP license or CFPB 1033 registration.' ;
    rdfs:domain ind:ApiApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaResponseTimeMs rdf:type rdf:Property ;
    rdfs:label 'Sla Response Time Ms' ;
    rdfs:comment 'Maximum API response time in milliseconds guaranteed under the service level agreement for the application\'s rate limit tier.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaUptimePercentage rdf:type rdf:Property ;
    rdfs:label 'Sla Uptime Percentage' ;
    rdfs:comment 'Guaranteed uptime percentage for the API services as defined in the service level agreement with the application developer.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:termsOfServiceAcceptedDate rdf:type rdf:Property ;
    rdfs:label 'Terms Of Service Accepted Date' ;
    rdfs:comment 'Date on which the application developer accepted the current version of the API terms of service.' ;
    rdfs:domain ind:ApiApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:termsOfServiceVersion rdf:type rdf:Property ;
    rdfs:label 'Terms Of Service Version' ;
    rdfs:comment 'Version identifier of the API terms of service that the application developer has accepted and agreed to comply with.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tppCompetentAuthority rdf:type rdf:Property ;
    rdfs:label 'Tpp Competent Authority' ;
    rdfs:comment 'Name of the regulatory authority that issued the TPP license or registration (e.g., Financial Conduct Authority, BaFin, ACPR).' ;
    rdfs:domain ind:ApiApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tppLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Tpp License Number' ;
    rdfs:comment 'License or registration number issued by the competent authority under PSD2 or equivalent regulation authorizing the third-party provider to offer payment services.' ;
    rdfs:domain ind:ApiApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:webhookUrl rdf:type rdf:Property ;
    rdfs:label 'Webhook Url' ;
    rdfs:comment 'Endpoint URL where the bank will send real-time event notifications and webhooks for subscribed events such as payment status updates or account changes.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:atmId rdf:type rdf:Property ;
    rdfs:label 'Atm Id' ;
    rdfs:comment 'Unique identifier for the ATM unit in the bank\'s owned and managed network.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Atm .

ind:adaCompliant rdf:type rdf:Property ;
    rdfs:label 'Ada Compliant' ;
    rdfs:comment 'Indicates whether the ATM meets ADA accessibility requirements (True) or not (False).' ;
    rdfs:domain ind:Atm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line 1' ;
    rdfs:comment 'Primary street address line where the ATM is physically located.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line 2' ;
    rdfs:comment 'Secondary address line for suite, building, or unit number where the ATM is located.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageDailyCashDispensed rdf:type rdf:Property ;
    rdfs:label 'Average Daily Cash Dispensed' ;
    rdfs:comment 'Average amount of cash dispensed by this ATM per day in the local currency, calculated over a rolling period.' ;
    rdfs:domain ind:Atm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageDailyTransactions rdf:type rdf:Property ;
    rdfs:label 'Average Daily Transactions' ;
    rdfs:comment 'Average number of transactions processed by this ATM per day, calculated over a rolling period (e.g., 30 days).' ;
    rdfs:domain ind:Atm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:biometricAuthenticationEnabled rdf:type rdf:Property ;
    rdfs:label 'Biometric Authentication Enabled' ;
    rdfs:comment 'Indicates whether the ATM supports biometric authentication methods such as fingerprint or iris scanning (True) or not (False).' ;
    rdfs:domain ind:Atm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cashCassetteConfiguration rdf:type rdf:Property ;
    rdfs:label 'Cash Cassette Configuration' ;
    rdfs:comment 'Denomination configuration of cash cassettes (e.g., Cassette 1: $20, Cassette 2: $50, Cassette 3: $100, Cassette 4: $20).' ;
    rdfs:domain ind:Atm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cashCassetteCount rdf:type rdf:Property ;
    rdfs:label 'Cash Cassette Count' ;
    rdfs:comment 'Number of cash cassettes installed in the ATM for dispensing currency.' ;
    rdfs:domain ind:Atm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cashReplenishmentSchedule rdf:type rdf:Property ;
    rdfs:label 'Cash Replenishment Schedule' ;
    rdfs:comment 'Frequency at which the ATM is scheduled for cash replenishment: daily, weekly, bi-weekly, monthly, or on-demand based on usage.' ;
    rdfs:domain ind:Atm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkImagingEnabled rdf:type rdf:Property ;
    rdfs:label 'Check Imaging Enabled' ;
    rdfs:comment 'Indicates whether the ATM has check imaging capability for remote deposit capture (True) or not (False).' ;
    rdfs:domain ind:Atm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:city rdf:type rdf:Property ;
    rdfs:label 'City' ;
    rdfs:comment 'City or municipality where the ATM is located.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactlessEnabled rdf:type rdf:Property ;
    rdfs:label 'Contactless Enabled' ;
    rdfs:comment 'Indicates whether the ATM supports contactless card or mobile wallet transactions (True) or not (False).' ;
    rdfs:domain ind:Atm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:depositEnabled rdf:type rdf:Property ;
    rdfs:label 'Deposit Enabled' ;
    rdfs:comment 'Indicates whether the ATM supports cash and/or check deposit functionality (True) or is withdrawal-only (False).' ;
    rdfs:domain ind:Atm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:firmwareVersion rdf:type rdf:Property ;
    rdfs:label 'Firmware Version' ;
    rdfs:comment 'Version number of the firmware currently installed on the ATM.' ;
    rdfs:domain ind:Atm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:installationDate rdf:type rdf:Property ;
    rdfs:label 'Installation Date' ;
    rdfs:comment 'Date when the ATM was first installed and commissioned at its current location.' ;
    rdfs:domain ind:Atm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ipAddress rdf:type rdf:Property ;
    rdfs:label 'Ip Address' ;
    rdfs:comment 'Network IP address assigned to the ATM for communication with the bank\'s transaction processing systems.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastCashReplenishmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Cash Replenishment Date' ;
    rdfs:comment 'Date when the ATM was last replenished with cash.' ;
    rdfs:domain ind:Atm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Last Maintenance Date' ;
    rdfs:comment 'Date of the most recent scheduled or unscheduled maintenance service performed on the ATM.' ;
    rdfs:domain ind:Atm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:latitude rdf:type rdf:Property ;
    rdfs:label 'Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of the ATM location in decimal degrees.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:locationType rdf:type rdf:Property ;
    rdfs:label 'Location Type' ;
    rdfs:comment 'Classification of the ATM placement: branch-attached (within or adjacent to a branch), off-premise (remote location), in-lobby, drive-through, or standalone kiosk.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:longitude rdf:type rdf:Property ;
    rdfs:label 'Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of the ATM location in decimal degrees.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:manufacturer rdf:type rdf:Property ;
    rdfs:label 'Manufacturer' ;
    rdfs:comment 'Name of the company that manufactured the ATM unit.' ;
    rdfs:domain ind:Atm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxWithdrawalAmount rdf:type rdf:Property ;
    rdfs:label 'Max Withdrawal Amount' ;
    rdfs:comment 'Maximum single transaction withdrawal amount allowed at this ATM in the local currency.' ;
    rdfs:domain ind:Atm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:model rdf:type rdf:Property ;
    rdfs:label 'Model' ;
    rdfs:comment 'Model designation of the ATM unit as specified by the manufacturer (e.g., NCR SelfServ 80, Diebold Nixdorf DN Series).' ;
    rdfs:domain ind:Atm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkAffiliations rdf:type rdf:Property ;
    rdfs:label 'Network Affiliations' ;
    rdfs:comment 'Comma-separated list of interbank networks the ATM participates in (e.g., Visa, Mastercard, STAR, Allpoint, NYCE, Cirrus).' ;
    rdfs:domain ind:Atm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Next Maintenance Date' ;
    rdfs:comment 'Date when the next scheduled preventive maintenance is planned for the ATM.' ;
    rdfs:domain ind:Atm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operationalStatus rdf:type rdf:Property ;
    rdfs:label 'Operational Status' ;
    rdfs:comment 'Current operational state of the ATM: active (in service), inactive (temporarily offline), maintenance (scheduled service), out-of-service (unplanned downtime), or decommissioned (permanently removed).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postalCode rdf:type rdf:Property ;
    rdfs:label 'Postal Code' ;
    rdfs:comment 'Postal or ZIP code for the ATM location.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serialNumber rdf:type rdf:Property ;
    rdfs:label 'Serial Number' ;
    rdfs:comment 'Manufacturer-assigned serial number uniquely identifying the physical ATM hardware unit.' ;
    rdfs:domain ind:Atm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceProvider rdf:type rdf:Property ;
    rdfs:label 'Service Provider' ;
    rdfs:comment 'Name of the third-party service provider responsible for ATM maintenance and cash management, if outsourced. Null if managed in-house.' ;
    rdfs:domain ind:Atm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateProvince rdf:type rdf:Property ;
    rdfs:label 'State Province' ;
    rdfs:comment 'State, province, or administrative region where the ATM is located.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportedTransactionTypes rdf:type rdf:Property ;
    rdfs:label 'Supported Transaction Types' ;
    rdfs:comment 'Comma-separated list of transaction types the ATM supports (e.g., withdrawal, deposit, balance inquiry, transfer, bill payment, check cashing).' ;
    rdfs:domain ind:Atm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surchargeAmount rdf:type rdf:Property ;
    rdfs:label 'Surcharge Amount' ;
    rdfs:comment 'Fee charged to non-customer cardholders for using this ATM, in the local currency. Zero if no surcharge applies.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:surchargeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Surcharge Currency Code' ;
    rdfs:comment 'Three-letter ISO currency code for the surcharge amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Atm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:videoBankingEnabled rdf:type rdf:Property ;
    rdfs:label 'Video Banking Enabled' ;
    rdfs:comment 'Indicates whether the ATM supports live video teller assistance (True) or not (False).' ;
    rdfs:domain ind:Atm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:atmTransactionId rdf:type rdf:Property ;
    rdfs:label 'Atm Transaction Id' ;
    rdfs:comment 'Unique identifier for the ATM transaction event. Primary key for the atm_transaction product.' ;
    rdfs:domain ind:AtmTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cardId rdf:type rdf:Property ;
    rdfs:label 'Card Id' ;
    rdfs:comment 'Tokenized reference to the card used for the transaction. Links to the card master record without exposing PAN (Primary Account Number).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Card .

ind:channelSessionId rdf:type rdf:Property ;
    rdfs:label 'Channel Session Id' ;
    rdfs:comment 'Unique identifier for the ATM session during which this transaction occurred, used to group multiple transactions within a single customer session.' ;
    rdfs:domain ind:AtmTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Session .

ind:issuerInstitutionLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Issuer Institution Legal Entity Id' ;
    rdfs:comment 'Bank Identification Number (BIN) or institution code of the issuing bank that issued the card used in the transaction.' ;
    rdfs:domain ind:AtmTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:originalTransactionAtmTransactionId rdf:type rdf:Property ;
    rdfs:label 'Original Transaction Atm Transaction Id' ;
    rdfs:comment 'Reference to the original ATM transaction ID if this record represents a reversal or adjustment. Null for original transactions.' ;
    rdfs:domain ind:AtmTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AtmTransaction .

ind:authorizationCode rdf:type rdf:Property ;
    rdfs:label 'Authorization Code' ;
    rdfs:comment 'Alphanumeric code returned by the issuing bank or card network upon successful authorization of the transaction.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardEntryMode rdf:type rdf:Property ;
    rdfs:label 'Card Entry Mode' ;
    rdfs:comment 'Method by which the card data was captured at the ATM: chip (EMV chip read), magnetic stripe, contactless (NFC/RFID), or manual entry.' ;
    rdfs:domain ind:AtmTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cashDispensedAmount rdf:type rdf:Property ;
    rdfs:label 'Cash Dispensed Amount' ;
    rdfs:comment 'Actual amount of cash dispensed by the ATM, which should match the transaction amount for withdrawal transactions. Null for non-cash transactions.' ;
    rdfs:domain ind:AtmTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cashDispensedFlag rdf:type rdf:Property ;
    rdfs:label 'Cash Dispensed Flag' ;
    rdfs:comment 'Boolean indicator of whether physical cash was successfully dispensed by the ATM for this transaction (True=cash dispensed, False=no cash dispensed).' ;
    rdfs:domain ind:AtmTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fraudFlag rdf:type rdf:Property ;
    rdfs:label 'Fraud Flag' ;
    rdfs:comment 'Boolean indicator of whether this transaction was flagged as potentially fraudulent by the fraud detection system. True=flagged for review, False=not flagged.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fraudScore rdf:type rdf:Property ;
    rdfs:label 'Fraud Score' ;
    rdfs:comment 'Risk score assigned by the fraud detection system indicating the likelihood of fraudulent activity, typically ranging from 0 (low risk) to 100 (high risk).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interchangeFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Interchange Fee Amount' ;
    rdfs:comment 'Fee paid by the acquiring bank to the issuing bank for processing the ATM transaction, typically a percentage of the transaction amount plus a fixed fee.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:networkCode rdf:type rdf:Property ;
    rdfs:label 'Network Code' ;
    rdfs:comment 'Card network or ATM network used to route and authorize the transaction (e.g., Visa, Mastercard, STAR, Cirrus, Plus). [ENUM-REF-CANDIDATE: visa|mastercard|star|pulse|cirrus|plus|interac|maestro — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AtmTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onUsTransactionFlag rdf:type rdf:Property ;
    rdfs:label 'On Us Transaction Flag' ;
    rdfs:comment 'Boolean indicator of whether this is an on-us transaction (customer using their own bank\'s ATM) or an off-us transaction (customer using another bank\'s ATM). True=on-us, False=off-us.' ;
    rdfs:domain ind:AtmTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pinVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Pin Verified Flag' ;
    rdfs:comment 'Boolean indicator of whether the customer\'s PIN was successfully verified during the transaction. True=PIN verified, False=PIN not verified or failed.' ;
    rdfs:domain ind:AtmTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receiptPrintedFlag rdf:type rdf:Property ;
    rdfs:label 'Receipt Printed Flag' ;
    rdfs:comment 'Boolean indicator of whether a paper receipt was printed for the customer (True=receipt printed, False=receipt declined or unavailable).' ;
    rdfs:domain ind:AtmTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responseCode rdf:type rdf:Property ;
    rdfs:label 'Response Code' ;
    rdfs:comment 'Numeric code returned by the issuer or network indicating the outcome of the authorization request (e.g., 00=approved, 51=insufficient funds, 54=expired card).' ;
    rdfs:domain ind:AtmTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseDescription rdf:type rdf:Property ;
    rdfs:label 'Response Description' ;
    rdfs:comment 'Human-readable description of the response code, explaining the reason for approval or decline (e.g., \'Approved\', \'Insufficient Funds\', \'Invalid PIN\').' ;
    rdfs:domain ind:AtmTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementAmount rdf:type rdf:Property ;
    rdfs:label 'Settlement Amount' ;
    rdfs:comment 'Total amount settled for this transaction, including transaction amount, surcharge, and any applicable fees, in the settlement currency.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Settlement Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the settlement amount, which may differ from transaction currency for cross-border transactions.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminalLocationCode rdf:type rdf:Property ;
    rdfs:label 'Terminal Location Code' ;
    rdfs:comment 'Geographic or branch location code where the ATM terminal is physically installed, used for location-based analytics and fraud detection.' ;
    rdfs:domain ind:AtmTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminalType rdf:type rdf:Property ;
    rdfs:label 'Terminal Type' ;
    rdfs:comment 'Classification of the ATM terminal type: branch (inside bank branch), offsite (standalone location), mobile (portable ATM), kiosk (self-service banking kiosk), or drive-through.' ;
    rdfs:domain ind:AtmTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Transaction Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the transaction amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transaction Timestamp' ;
    rdfs:comment 'Date and time when the ATM transaction was initiated by the customer at the terminal, in ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:currentRegulatoryExamId rdf:type rdf:Property ;
    rdfs:label 'Current Regulatory Exam Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_exam. Business justification: Branches are regulatory exam targets (BSA/AML branch exams, CRA performance evaluations, consumer compliance exams). Link enables exam scoping, document request coordination, and findings attribution.' ;
    rdfs:domain ind:Branch ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryExam .

ind:atmCount rdf:type rdf:Property ;
    rdfs:label 'Atm Count' ;
    rdfs:comment 'Number of ATM machines located at or immediately adjacent to the branch. Used for self-service capacity planning and customer convenience analysis.' ;
    rdfs:domain ind:Branch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:branchName rdf:type rdf:Property ;
    rdfs:label 'Branch Name' ;
    rdfs:comment 'Official business name of the branch location as registered with regulatory authorities and displayed to customers.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:branchStatus rdf:type rdf:Property ;
    rdfs:label 'Branch Status' ;
    rdfs:comment 'Current operational status of the branch in its lifecycle. Active branches are fully operational; inactive branches are permanently closed; temporarily closed branches are expected to reopen; pending opening branches are approved but not yet operational; pending closure branches are scheduled for closure; under renovation branches are temporarily closed for facility upgrades.' ;
    rdfs:domain ind:Branch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:branchType rdf:type rdf:Property ;
    rdfs:label 'Branch Type' ;
    rdfs:comment 'Classification of the branch based on service capabilities and operational model. Full-service branches offer complete banking services; limited-service branches offer restricted services; drive-through branches focus on vehicle-accessible transactions; in-store branches are located within retail establishments; mobile branches are temporary or movable units; automated branches are primarily self-service; private banking branches serve high-net-worth clients. [ENUM-REF-CANDIDATE: full_service|limited_service|drive_through|in_store|mobile|automated|private_banking — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Branch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bsaAmlDesignation rdf:type rdf:Property ;
    rdfs:label 'Bsa Aml Designation' ;
    rdfs:comment 'Risk classification of the branch for BSA/AML compliance purposes. Standard designation applies default monitoring; high-risk designation requires enhanced due diligence; enhanced monitoring applies additional transaction surveillance; exempt designation applies to branches with limited transaction capabilities.' ;
    rdfs:domain ind:Branch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:driveThroughLanes rdf:type rdf:Property ;
    rdfs:label 'Drive Through Lanes' ;
    rdfs:comment 'Number of drive-through service lanes available at the branch for vehicle-accessible banking transactions.' ;
    rdfs:domain ind:Branch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:emailAddress rdf:type rdf:Property ;
    rdfs:label 'Email Address' ;
    rdfs:comment 'Official email address for the branch used for customer inquiries, service requests, and business correspondence.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:faxNumber rdf:type rdf:Property ;
    rdfs:label 'Fax Number' ;
    rdfs:comment 'Facsimile number for the branch used for document transmission and formal communications.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fdicCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Fdic Certificate Number' ;
    rdfs:comment 'FDIC certificate number associated with the institution operating this branch. Used for regulatory reporting and deposit insurance identification.' ;
    rdfs:domain ind:Branch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaseExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Lease Expiration Date' ;
    rdfs:comment 'Date when the current lease agreement for the branch facility expires. Null for owned properties. Used for lease renewal planning and real estate strategy.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leaseOrOwned rdf:type rdf:Property ;
    rdfs:label 'Lease Or Owned' ;
    rdfs:comment 'Indicates whether the branch facility is owned by the bank, leased from a third party, or operates under a ground lease arrangement. Used for real estate portfolio management and cost allocation.' ;
    rdfs:domain ind:Branch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketCode rdf:type rdf:Property ;
    rdfs:label 'Market Code' ;
    rdfs:comment 'Code identifying the market or metropolitan statistical area (MSA) in which the branch operates. Used for market share analysis and competitive positioning.' ;
    rdfs:domain ind:Branch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingHoursSaturday rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Saturday' ;
    rdfs:comment 'Operating hours for the branch on Saturdays. May differ from weekday hours or be closed. Format includes opening and closing times.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingHoursSunday rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Sunday' ;
    rdfs:comment 'Operating hours for the branch on Sundays. Many branches are closed on Sundays. Format includes opening and closing times or indication of closure.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingHoursWeekday rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Weekday' ;
    rdfs:comment 'Standard operating hours for the branch on weekdays (Monday through Friday). Format typically includes opening and closing times (e.g., 09:00-17:00).' ;
    rdfs:domain ind:Branch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parkingAvailable rdf:type rdf:Property ;
    rdfs:label 'Parking Available' ;
    rdfs:comment 'Indicates whether dedicated customer parking is available at or near the branch location.' ;
    rdfs:domain ind:Branch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:performanceTier rdf:type rdf:Property ;
    rdfs:label 'Performance Tier' ;
    rdfs:comment 'Internal classification of branch performance based on deposit volume, loan origination, customer acquisition, and profitability metrics. Flagship branches are premier locations; Tier 1 represents highest performance; Tier 4 represents lowest performance. Used for resource allocation and strategic planning.' ;
    rdfs:domain ind:Branch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phoneNumber rdf:type rdf:Property ;
    rdfs:label 'Phone Number' ;
    rdfs:comment 'Primary contact telephone number for the branch. Used by customers and internal staff for inquiries and service requests.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionCode rdf:type rdf:Property ;
    rdfs:label 'Region Code' ;
    rdfs:comment 'Internal code identifying the geographic region or district to which the branch is assigned for management and reporting purposes.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Regulatory Jurisdiction' ;
    rdfs:comment 'Primary regulatory authority or jurisdiction governing the branch operations. May include federal, state, or international regulatory bodies depending on location.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safeDepositBoxCount rdf:type rdf:Property ;
    rdfs:label 'Safe Deposit Box Count' ;
    rdfs:comment 'Total number of safe deposit boxes available for customer rental at the branch. Used for vault capacity management and revenue forecasting.' ;
    rdfs:domain ind:Branch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:squareFootage rdf:type rdf:Property ;
    rdfs:label 'Square Footage' ;
    rdfs:comment 'Total interior floor space of the branch facility measured in square feet. Used for facilities management, lease cost analysis, and space utilization planning.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:staffCapacity rdf:type rdf:Property ;
    rdfs:label 'Staff Capacity' ;
    rdfs:comment 'Maximum number of full-time equivalent staff members the branch is designed to accommodate. Used for workforce planning and capacity management.' ;
    rdfs:domain ind:Branch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:timeZone rdf:type rdf:Property ;
    rdfs:label 'Time Zone' ;
    rdfs:comment 'IANA time zone identifier for the branch location (e.g., America/New_York). Used for scheduling, transaction timestamping, and cross-timezone coordination.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wheelchairAccessible rdf:type rdf:Property ;
    rdfs:label 'Wheelchair Accessible' ;
    rdfs:comment 'Indicates whether the branch facility is fully accessible to customers using wheelchairs, including ramps, elevators, and accessible service counters.' ;
    rdfs:domain ind:Branch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:branchAppointmentId rdf:type rdf:Property ;
    rdfs:label 'Branch Appointment Id' ;
    rdfs:comment 'Unique identifier for the branch appointment record. Primary key.' ;
    rdfs:domain ind:BranchAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rescheduledFromAppointmentId rdf:type rdf:Property ;
    rdfs:label 'Rescheduled From Appointment Id' ;
    rdfs:comment 'Reference to the original appointment identifier if this appointment is a rescheduled version of a prior appointment.' ;
    rdfs:domain ind:BranchAppointment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BranchAppointment .

ind:staffAssignedEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Staff Assigned Employee Id' ;
    rdfs:comment 'Foreign key linking to hr.employee. Business justification: Appointments are staffed by specific employees (advisors, specialists, product experts). Essential for capacity planning, performance tracking, compensation attribution, and customer relationship cont' ;
    rdfs:domain ind:BranchAppointment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualArrivalTime rdf:type rdf:Property ;
    rdfs:label 'Actual Arrival Time' ;
    rdfs:comment 'The actual date and time when the customer arrived for the appointment.' ;
    rdfs:domain ind:BranchAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Actual Duration Minutes' ;
    rdfs:comment 'Actual duration of the appointment in minutes, calculated from start to end time.' ;
    rdfs:domain ind:BranchAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualEndTime rdf:type rdf:Property ;
    rdfs:label 'Actual End Time' ;
    rdfs:comment 'The actual date and time when the appointment service concluded.' ;
    rdfs:domain ind:BranchAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualStartTime rdf:type rdf:Property ;
    rdfs:label 'Actual Start Time' ;
    rdfs:comment 'The actual date and time when the appointment service began.' ;
    rdfs:domain ind:BranchAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:appointmentChannel rdf:type rdf:Property ;
    rdfs:label 'Appointment Channel' ;
    rdfs:comment 'The channel through which the appointment was originally booked.' ;
    rdfs:domain ind:BranchAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appointmentNotes rdf:type rdf:Property ;
    rdfs:label 'Appointment Notes' ;
    rdfs:comment 'Free-text notes or comments recorded by staff during or after the appointment, capturing key discussion points or customer requests.' ;
    rdfs:domain ind:BranchAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appointmentNumber rdf:type rdf:Property ;
    rdfs:label 'Appointment Number' ;
    rdfs:comment 'Business-facing unique identifier or confirmation number for the appointment, used for customer reference and tracking.' ;
    rdfs:domain ind:BranchAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appointmentOutcome rdf:type rdf:Property ;
    rdfs:label 'Appointment Outcome' ;
    rdfs:comment 'The result or outcome of the appointment after completion or cancellation.' ;
    rdfs:domain ind:BranchAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appointmentStatus rdf:type rdf:Property ;
    rdfs:label 'Appointment Status' ;
    rdfs:comment 'Current lifecycle status of the appointment. [ENUM-REF-CANDIDATE: scheduled|confirmed|in_progress|completed|cancelled|no_show|rescheduled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BranchAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appointmentType rdf:type rdf:Property ;
    rdfs:label 'Appointment Type' ;
    rdfs:comment 'Category of service or consultation requested for the appointment. [ENUM-REF-CANDIDATE: account_opening|loan_consultation|investment_review|kyc_refresh|notary_service|wealth_advisory|mortgage_application|safe_deposit_box — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BranchAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmationSentFlag rdf:type rdf:Property ;
    rdfs:label 'Confirmation Sent Flag' ;
    rdfs:comment 'Indicator of whether an appointment confirmation notification was sent to the customer.' ;
    rdfs:domain ind:BranchAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerFeedback rdf:type rdf:Property ;
    rdfs:label 'Customer Feedback' ;
    rdfs:comment 'Free-text feedback or comments provided by the customer regarding their appointment experience.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSatisfactionScore rdf:type rdf:Property ;
    rdfs:label 'Customer Satisfaction Score' ;
    rdfs:comment 'Numeric rating provided by the customer reflecting their satisfaction with the appointment experience, typically on a scale of 1 to 5 or 1 to 10.' ;
    rdfs:domain ind:BranchAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:followUpAction rdf:type rdf:Property ;
    rdfs:label 'Follow Up Action' ;
    rdfs:comment 'Description of the follow-up action or next steps required after the appointment.' ;
    rdfs:domain ind:BranchAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noShowFlag rdf:type rdf:Property ;
    rdfs:label 'No Show Flag' ;
    rdfs:comment 'Indicator of whether the customer failed to attend the scheduled appointment without prior cancellation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productsDiscussed rdf:type rdf:Property ;
    rdfs:label 'Products Discussed' ;
    rdfs:comment 'Comma-separated list or description of banking products or services discussed during the appointment.' ;
    rdfs:domain ind:BranchAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productsSold rdf:type rdf:Property ;
    rdfs:label 'Products Sold' ;
    rdfs:comment 'Comma-separated list or description of banking products or services successfully sold or opened as a result of the appointment.' ;
    rdfs:domain ind:BranchAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reminderSentFlag rdf:type rdf:Property ;
    rdfs:label 'Reminder Sent Flag' ;
    rdfs:comment 'Indicator of whether an appointment reminder notification was sent to the customer.' ;
    rdfs:domain ind:BranchAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reminderSentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reminder Sent Timestamp' ;
    rdfs:comment 'Date and time when the appointment reminder notification was sent to the customer.' ;
    rdfs:domain ind:BranchAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:revenueCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Revenue Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the revenue generated amount.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueGeneratedAmount rdf:type rdf:Property ;
    rdfs:label 'Revenue Generated Amount' ;
    rdfs:comment 'Estimated or actual revenue generated from products sold or services rendered during the appointment.' ;
    rdfs:domain ind:BranchAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduledDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Date' ;
    rdfs:comment 'The date on which the appointment is scheduled to occur.' ;
    rdfs:domain ind:BranchAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Scheduled Duration Minutes' ;
    rdfs:comment 'Planned duration of the appointment in minutes.' ;
    rdfs:domain ind:BranchAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scheduledEndTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Time' ;
    rdfs:comment 'The anticipated date and time when the appointment is scheduled to conclude.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledStartTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Time' ;
    rdfs:comment 'The precise date and time when the appointment is scheduled to begin.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:slaActualWaitTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Sla Actual Wait Time Minutes' ;
    rdfs:comment 'The actual wait time in minutes from scheduled start time to actual start time, used for SLA compliance tracking.' ;
    rdfs:domain ind:BranchAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Compliance Flag' ;
    rdfs:comment 'Indicator of whether the appointment met the defined service level agreement for wait time and service delivery.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaTargetWaitTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Sla Target Wait Time Minutes' ;
    rdfs:comment 'The target maximum wait time in minutes from scheduled start time to actual start time, as defined by branch service level agreements.' ;
    rdfs:domain ind:BranchAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:branchTellerTransactionId rdf:type rdf:Property ;
    rdfs:label 'Branch Teller Transaction Id' ;
    rdfs:comment 'Unique identifier for the branch teller transaction record.' ;
    rdfs:domain ind:BranchTellerTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditWorkpaperId rdf:type rdf:Property ;
    rdfs:label 'Audit Workpaper Id' ;
    rdfs:comment 'Foreign key linking to audit.workpaper. Business justification: Auditors sample teller transactions as evidence when testing cash handling controls, CTR/SAR compliance, dual control procedures, and operational accuracy. Transactions are directly referenced in audi' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Workpaper .

ind:originalTransactionBranchTellerTransactionId rdf:type rdf:Property ;
    rdfs:label 'Original Transaction Branch Teller Transaction Id' ;
    rdfs:comment 'Identifier of the original transaction being reversed, if this is a reversal transaction.' ;
    rdfs:domain ind:BranchTellerTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BranchTellerTransaction .

ind:primaryBranchEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Branch Employee Id' ;
    rdfs:comment 'Identifier of the teller who processed the transaction.' ;
    rdfs:domain ind:BranchTellerTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:sessionId rdf:type rdf:Property ;
    rdfs:label 'Session Id' ;
    rdfs:comment 'Identifier of the teller session during which the transaction was processed, used for session reconciliation and audit.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Session .

ind:checkNumber rdf:type rdf:Property ;
    rdfs:label 'Check Number' ;
    rdfs:comment 'Check number for check deposit or check cashing transactions.' ;
    rdfs:domain ind:BranchTellerTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkRoutingNumber rdf:type rdf:Property ;
    rdfs:label 'Check Routing Number' ;
    rdfs:comment 'Nine-digit ABA routing number for check transactions.' ;
    rdfs:domain ind:BranchTellerTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctrThresholdFlag rdf:type rdf:Property ;
    rdfs:label 'Ctr Threshold Flag' ;
    rdfs:comment 'Indicates whether the transaction meets or exceeds the $10,000 threshold requiring a Currency Transaction Report (CTR) filing under the Bank Secrecy Act (BSA) and FinCEN regulations.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerIdentificationNumber rdf:type rdf:Property ;
    rdfs:label 'Customer Identification Number' ;
    rdfs:comment 'Identification document number presented by the customer, required for high-value transactions and CTR reporting.' ;
    rdfs:domain ind:BranchTellerTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerIdentificationType rdf:type rdf:Property ;
    rdfs:label 'Customer Identification Type' ;
    rdfs:comment 'Type of identification document presented by the customer for the transaction, required for compliance and KYC purposes.' ;
    rdfs:domain ind:BranchTellerTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glPostingDate rdf:type rdf:Property ;
    rdfs:label 'Gl Posting Date' ;
    rdfs:comment 'Date when the transaction was posted to the general ledger for accounting purposes.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:overrideRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Override Required Flag' ;
    rdfs:comment 'Indicates whether the transaction required supervisory or managerial override approval due to policy exceptions or limit breaches.' ;
    rdfs:domain ind:BranchTellerTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:safeDepositBoxNumber rdf:type rdf:Property ;
    rdfs:label 'Safe Deposit Box Number' ;
    rdfs:comment 'Safe deposit box number for safe deposit box access transactions.' ;
    rdfs:domain ind:BranchTellerTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionChannel rdf:type rdf:Property ;
    rdfs:label 'Transaction Channel' ;
    rdfs:comment 'Specific channel within the branch network through which the transaction was initiated.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wireReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Wire Reference Number' ;
    rdfs:comment 'Unique reference number for wire transfer initiation transactions.' ;
    rdfs:domain ind:BranchTellerTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workstationCode rdf:type rdf:Property ;
    rdfs:label 'Workstation Code' ;
    rdfs:comment 'Identifier of the teller workstation or terminal used to process the transaction.' ;
    rdfs:domain ind:BranchTellerTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amlMonitoringEnabled rdf:type rdf:Property ;
    rdfs:label 'Aml Monitoring Enabled' ;
    rdfs:comment 'Indicates whether transactions through this channel are subject to real-time or near-real-time AML transaction monitoring.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:apiEndpointUrl rdf:type rdf:Property ;
    rdfs:label 'Api Endpoint Url' ;
    rdfs:comment 'Base URL for API-based channels (open banking API, BaaS API). Null for non-API channels.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authenticationMethod rdf:type rdf:Property ;
    rdfs:label 'Authentication Method' ;
    rdfs:comment 'Primary authentication method(s) used by the channel (e.g., username/password, biometric, two-factor authentication, certificate-based, in-person verification). [ENUM-REF-CANDIDATE: username_password|biometric|mfa|certificate|oauth|saml|in_person|pin|token — promote to reference product]' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelCode rdf:type rdf:Property ;
    rdfs:label 'Channel Code' ;
    rdfs:comment 'Unique business identifier code for the channel, used for external references and system integration. Follows bank-specific channel coding standards.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelDescription rdf:type rdf:Property ;
    rdfs:label 'Channel Description' ;
    rdfs:comment 'Detailed description of the channel\'s purpose, capabilities, and target customer segments.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelName rdf:type rdf:Property ;
    rdfs:label 'Channel Name' ;
    rdfs:comment 'Human-readable name of the channel (e.g., \'Mobile Banking App\', \'Downtown Branch\', \'Corporate API Gateway\').' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelStatus rdf:type rdf:Property ;
    rdfs:label 'Channel Status' ;
    rdfs:comment 'Current operational status of the channel in its lifecycle.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelType rdf:type rdf:Property ;
    rdfs:label 'Channel Type' ;
    rdfs:comment 'Primary classification of the channel. Aligned with ISO 20022 channel type taxonomy where applicable.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterCode rdf:type rdf:Property ;
    rdfs:label 'Cost Center Code' ;
    rdfs:comment 'General ledger cost center code to which channel operating expenses are allocated.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSegmentRestriction rdf:type rdf:Property ;
    rdfs:label 'Customer Segment Restriction' ;
    rdfs:comment 'Comma-separated list of customer segment codes that are permitted to use this channel. Null if no restriction applies (channel available to all segments).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kycCapability rdf:type rdf:Property ;
    rdfs:label 'Kyc Capability' ;
    rdfs:comment 'Level of KYC and customer due diligence capability available through the channel (full identity verification, partial verification, or none).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:omnichannelOrchestrationEnabled rdf:type rdf:Property ;
    rdfs:label 'Omnichannel Orchestration Enabled' ;
    rdfs:comment 'Indicates whether the channel participates in omnichannel customer journey orchestration and cross-channel session continuity.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operatingHoursDescription rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Description' ;
    rdfs:comment 'Human-readable description of channel operating hours (e.g., \'24/7\', \'Mon-Fri 9AM-5PM EST\', \'Business days excluding bank holidays\').' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productOfferingScope rdf:type rdf:Property ;
    rdfs:label 'Product Offering Scope' ;
    rdfs:comment 'Scope of banking products and services available through this channel (all products, restricted subset, or custom configuration).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaResponseTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Sla Response Time Seconds' ;
    rdfs:comment 'Target response time in seconds for channel interactions as defined in the channel SLA (e.g., page load time for digital, call answer time for contact center).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subtype rdf:type rdf:Property ;
    rdfs:label 'Subtype' ;
    rdfs:comment 'Detailed sub-classification of the channel providing granular segmentation (e.g., mobile app vs web banking under digital; full-service branch vs express branch). [ENUM-REF-CANDIDATE: mobile_app|web_banking|branch_full_service|branch_express|atm_full_service|atm_deposit_only|ivr|live_agent|chatbot|email|rm_dedicated|rm_shared|open_banking_api|baas_api|embedded_finance — 15 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportsAccountOpening rdf:type rdf:Property ;
    rdfs:label 'Supports Account Opening' ;
    rdfs:comment 'Indicates whether the channel supports new account origination and onboarding workflows.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsInvestmentServices rdf:type rdf:Property ;
    rdfs:label 'Supports Investment Services' ;
    rdfs:comment 'Indicates whether the channel provides investment banking, wealth management, or securities trading capabilities.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsLoanOrigination rdf:type rdf:Property ;
    rdfs:label 'Supports Loan Origination' ;
    rdfs:comment 'Indicates whether the channel supports loan application and origination processes.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsTransactions rdf:type rdf:Property ;
    rdfs:label 'Supports Transactions' ;
    rdfs:comment 'Indicates whether the channel supports financial transaction execution (payments, transfers, withdrawals) or is information/inquiry-only.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:swiftBicCode rdf:type rdf:Property ;
    rdfs:label 'Swift Bic Code' ;
    rdfs:comment 'SWIFT BIC code associated with the channel if it represents a branch or location with its own BIC. Null for non-branch channels or branches without unique BIC.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartyProvider rdf:type rdf:Property ;
    rdfs:label 'Third Party Provider' ;
    rdfs:comment 'Name of third-party vendor or technology provider if the channel is operated or enabled by an external partner (e.g., fintech platform, BaaS provider, core banking vendor). Null if operated in-house.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionLimitDaily rdf:type rdf:Property ;
    rdfs:label 'Transaction Limit Daily' ;
    rdfs:comment 'Maximum aggregate transaction amount allowed per customer per day through this channel. Null if no limit applies.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionLimitPerTransaction rdf:type rdf:Property ;
    rdfs:label 'Transaction Limit Per Transaction' ;
    rdfs:comment 'Maximum single transaction amount allowed through this channel. Null if no limit applies.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:channelProductId rdf:type rdf:Property ;
    rdfs:label 'Channel Product Id' ;
    rdfs:comment 'Unique identifier for the channel-product association. Primary key.' ;
    rdfs:domain ind:ChannelProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:disclosureTemplateId rdf:type rdf:Property ;
    rdfs:label 'Disclosure Template Id' ;
    rdfs:comment 'Reference to the regulatory disclosure template that must be presented for this product-channel combination.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DisclosureTemplate .

ind:authenticationMethodRequired rdf:type rdf:Property ;
    rdfs:label 'Authentication Method Required' ;
    rdfs:comment 'Authentication method(s) required for accessing this product through this channel (e.g., password, biometric, two-factor, token, PIN).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Channel Fee Amount' ;
    rdfs:comment 'Channel-specific fee charged for accessing or transacting with this product through this channel (e.g., ATM surcharge, branch service fee).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:channelFeeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Channel Fee Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the channel fee.' ;
    rdfs:domain ind:ChannelProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelSpecificProductCode rdf:type rdf:Property ;
    rdfs:label 'Channel Specific Product Code' ;
    rdfs:comment 'Channel-specific identifier or SKU for the product variant offered through this channel, if different from the standard product code.' ;
    rdfs:domain ind:ChannelProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configurationParameters rdf:type rdf:Property ;
    rdfs:label 'Configuration Parameters' ;
    rdfs:comment 'Channel-specific configuration parameters or feature flags for this product (stored as JSON or key-value pairs).' ;
    rdfs:domain ind:ChannelProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossSellPriority rdf:type rdf:Property ;
    rdfs:label 'Cross Sell Priority' ;
    rdfs:comment 'Priority ranking for cross-selling this product through this channel (lower number = higher priority).' ;
    rdfs:domain ind:ChannelProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:digitalExperienceUrl rdf:type rdf:Property ;
    rdfs:label 'Digital Experience Url' ;
    rdfs:comment 'URL or deep link to the digital experience for this product within this channel (for digital channels).' ;
    rdfs:domain ind:ChannelProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kycRequirementLevel rdf:type rdf:Property ;
    rdfs:label 'Kyc Requirement Level' ;
    rdfs:comment 'Level of KYC verification required when opening or accessing this product through this channel.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingCampaignCode rdf:type rdf:Property ;
    rdfs:label 'Marketing Campaign Code' ;
    rdfs:comment 'Marketing campaign identifier associated with promoting this product through this channel.' ;
    rdfs:domain ind:ChannelProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingTier rdf:type rdf:Property ;
    rdfs:label 'Pricing Tier' ;
    rdfs:comment 'Pricing tier or segment applicable to this product-channel combination (e.g., premium, standard, basic).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryDisclosureRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Disclosure Required' ;
    rdfs:comment 'Indicates whether regulatory disclosures must be presented when offering this product through this channel.' ;
    rdfs:domain ind:ChannelProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsClosure rdf:type rdf:Property ;
    rdfs:label 'Supports Closure' ;
    rdfs:comment 'Indicates whether account or product closure can be initiated through this channel.' ;
    rdfs:domain ind:ChannelProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsServicing rdf:type rdf:Property ;
    rdfs:label 'Supports Servicing' ;
    rdfs:comment 'Indicates whether account servicing activities (balance inquiries, statement requests, profile updates) for this product are supported through this channel.' ;
    rdfs:domain ind:ChannelProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transactionLimitCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Transaction Limit Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the transaction limits (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:ChannelProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactCenterId rdf:type rdf:Property ;
    rdfs:label 'Contact Center Id' ;
    rdfs:comment 'Unique identifier for the contact center operational unit.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContactCenter .

ind:supervisorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Supervisor Employee Id' ;
    rdfs:comment 'Foreign key linking to hr.employee. Business justification: Contact centers require supervisor assignment for operational hierarchy, escalation handling, quality monitoring, workforce management, and SLA accountability. Essential for performance reporting and ' ;
    rdfs:domain ind:ContactCenter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:callRecordingPolicy rdf:type rdf:Property ;
    rdfs:label 'Call Recording Policy' ;
    rdfs:comment 'Recording policy for customer interactions: all calls (100% recording), sample (random subset), none (no recording), or regulatory-only (only calls subject to compliance requirements).' ;
    rdfs:domain ind:ContactCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:centerCode rdf:type rdf:Property ;
    rdfs:label 'Center Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the contact center for operational reporting and routing (e.g., \'NYC-IB-01\', \'MUM-CS-02\').' ;
    rdfs:domain ind:ContactCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:centerName rdf:type rdf:Property ;
    rdfs:label 'Center Name' ;
    rdfs:comment 'Business name of the contact center operational unit (e.g., \'New York Inbound Voice Center\', \'Mumbai Customer Service Hub\').' ;
    rdfs:domain ind:ContactCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:centerType rdf:type rdf:Property ;
    rdfs:label 'Center Type' ;
    rdfs:comment 'Primary operational mode of the contact center: inbound voice (customer-initiated calls), outbound campaigns (proactive outreach), IVR self-service (Interactive Voice Response), live chat, secure email, SMS, or video banking. [ENUM-REF-CANDIDATE: inbound_voice|outbound_campaigns|ivr_self_service|live_chat|secure_email|sms|video_banking — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ContactCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coreBankingIntegrationEndpoint rdf:type rdf:Property ;
    rdfs:label 'Core Banking Integration Endpoint' ;
    rdfs:comment 'API endpoint or system identifier for core banking system integration to access account and transaction data during customer interactions.' ;
    rdfs:domain ind:ContactCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmIntegrationEndpoint rdf:type rdf:Property ;
    rdfs:label 'Crm Integration Endpoint' ;
    rdfs:comment 'API endpoint or system identifier for CRM integration to retrieve customer context and log interactions.' ;
    rdfs:domain ind:ContactCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveFromDate rdf:type rdf:Property ;
    rdfs:label 'Effective From Date' ;
    rdfs:comment 'Date when this contact center configuration became effective and operational.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveToDate rdf:type rdf:Property ;
    rdfs:label 'Effective To Date' ;
    rdfs:comment 'Date when this contact center configuration ceased to be effective. Null for currently active centers.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ivrMenuStructure rdf:type rdf:Property ;
    rdfs:label 'Ivr Menu Structure' ;
    rdfs:comment 'High-level description or reference to the IVR menu flow and options available to callers (e.g., \'Press 1 for Accounts, 2 for Loans, 3 for Cards\').' ;
    rdfs:domain ind:ContactCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ivrTreeVersion rdf:type rdf:Property ;
    rdfs:label 'Ivr Tree Version' ;
    rdfs:comment 'Version identifier of the IVR menu tree configuration currently deployed at this contact center (e.g., \'v3.2.1\').' ;
    rdfs:domain ind:ContactCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingHoursFriday rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Friday' ;
    rdfs:comment 'Operating hours on Friday in HH:MM-HH:MM format. Null if closed.' ;
    rdfs:domain ind:ContactCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingHoursMonday rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Monday' ;
    rdfs:comment 'Operating hours on Monday in HH:MM-HH:MM format (e.g., \'08:00-20:00\'). Null if closed.' ;
    rdfs:domain ind:ContactCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingHoursThursday rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Thursday' ;
    rdfs:comment 'Operating hours on Thursday in HH:MM-HH:MM format. Null if closed.' ;
    rdfs:domain ind:ContactCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingHoursTuesday rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Tuesday' ;
    rdfs:comment 'Operating hours on Tuesday in HH:MM-HH:MM format. Null if closed.' ;
    rdfs:domain ind:ContactCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingHoursWednesday rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Wednesday' ;
    rdfs:comment 'Operating hours on Wednesday in HH:MM-HH:MM format. Null if closed.' ;
    rdfs:domain ind:ContactCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pciDssCompliant rdf:type rdf:Property ;
    rdfs:label 'Pci Dss Compliant' ;
    rdfs:comment 'Indicates whether this contact center is certified compliant with PCI-DSS standards for handling payment card information.' ;
    rdfs:domain ind:ContactCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pciDssScope rdf:type rdf:Property ;
    rdfs:label 'Pci Dss Scope' ;
    rdfs:comment 'Description of PCI-DSS scope for this contact center (e.g., \'Full card data capture\', \'Tokenized payments only\', \'No card handling\').' ;
    rdfs:domain ind:ContactCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:physicalAddress rdf:type rdf:Property ;
    rdfs:label 'Physical Address' ;
    rdfs:comment 'Full street address of the contact center facility if physical or hybrid. Null for fully virtual centers.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityRules rdf:type rdf:Property ;
    rdfs:label 'Priority Rules' ;
    rdfs:comment 'Business rules defining customer prioritization in queue (e.g., \'Private Banking clients priority 1, Retail clients priority 2\').' ;
    rdfs:domain ind:ContactCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityMonitoringEnabled rdf:type rdf:Property ;
    rdfs:label 'Quality Monitoring Enabled' ;
    rdfs:comment 'Indicates whether quality assurance monitoring and scoring is active for this contact center.' ;
    rdfs:domain ind:ContactCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:queueRoutingModel rdf:type rdf:Property ;
    rdfs:label 'Queue Routing Model' ;
    rdfs:comment 'Call distribution strategy: skill-based (route to agents with specific skills), priority-based (VIP customers first), round-robin (sequential distribution), or least-occupied (agent with fewest active calls).' ;
    rdfs:domain ind:ContactCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaAbandonmentRatePercent rdf:type rdf:Property ;
    rdfs:label 'Sla Abandonment Rate Percent' ;
    rdfs:comment 'Target maximum percentage of calls abandoned by customers before reaching an agent, per SLA commitment.' ;
    rdfs:domain ind:ContactCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaAverageHandleTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Sla Average Handle Time Seconds' ;
    rdfs:comment 'Target average duration in seconds for an agent to complete a customer interaction (talk time plus after-call work), per SLA commitment.' ;
    rdfs:domain ind:ContactCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaAverageSpeedOfAnswerSeconds rdf:type rdf:Property ;
    rdfs:label 'Sla Average Speed Of Answer Seconds' ;
    rdfs:comment 'Target average time in seconds for an agent to answer an incoming call, per SLA commitment.' ;
    rdfs:domain ind:ContactCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaFirstCallResolutionPercent rdf:type rdf:Property ;
    rdfs:label 'Sla First Call Resolution Percent' ;
    rdfs:comment 'Target percentage of customer issues resolved on the first contact without requiring follow-up, per SLA commitment.' ;
    rdfs:domain ind:ContactCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:staffingModel rdf:type rdf:Property ;
    rdfs:label 'Staffing Model' ;
    rdfs:comment 'Workforce composition: in-house (bank employees only), outsourced (third-party vendor), or blended (mix of both).' ;
    rdfs:domain ind:ContactCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportedLanguages rdf:type rdf:Property ;
    rdfs:label 'Supported Languages' ;
    rdfs:comment 'Comma-separated list of ISO 639-1 language codes supported by this contact center (e.g., \'en,es,fr,hi\').' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorName rdf:type rdf:Property ;
    rdfs:label 'Vendor Name' ;
    rdfs:comment 'Name of the third-party vendor operating this contact center if staffing model is outsourced or blended. Null for in-house centers.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workforceManagementSystem rdf:type rdf:Property ;
    rdfs:label 'Workforce Management System' ;
    rdfs:comment 'Name or identifier of the workforce management platform used for agent scheduling, forecasting, and capacity planning (e.g., \'Verint WFM\', \'NICE IEX\').' ;
    rdfs:domain ind:ContactCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalChannelId rdf:type rdf:Property ;
    rdfs:label 'Digital Channel Id' ;
    rdfs:comment 'Unique identifier for the digital channel instance, registered API consumer, or third-party provider application.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DigitalChannel .

ind:apiGatewayEndpoint rdf:type rdf:Property ;
    rdfs:label 'Api Gateway Endpoint' ;
    rdfs:comment 'Base URL or endpoint address for the API gateway serving this channel.' ;
    rdfs:domain ind:DigitalChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalChannelStatus rdf:type rdf:Property ;
    rdfs:label 'Digital Channel Status' ;
    rdfs:comment 'Current lifecycle status of the digital channel instance or API consumer registration.' ;
    rdfs:domain ind:DigitalChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:featureFlags rdf:type rdf:Property ;
    rdfs:label 'Feature Flags' ;
    rdfs:comment 'Comma-separated list of enabled feature flags or capabilities for this channel instance (e.g., \'payment_initiation\', \'account_aggregation\', \'funds_confirmation\').' ;
    rdfs:domain ind:DigitalChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBaasEnabled rdf:type rdf:Property ;
    rdfs:label 'Is Baas Enabled' ;
    rdfs:comment 'Indicates whether this channel is configured for Banking-as-a-Service or embedded finance capabilities.' ;
    rdfs:domain ind:DigitalChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastActivityTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Activity Timestamp' ;
    rdfs:comment 'Timestamp of the most recent API call, login, or transaction activity through this channel.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:maxRequestsPerMinute rdf:type rdf:Property ;
    rdfs:label 'Max Requests Per Minute' ;
    rdfs:comment 'Maximum number of API requests allowed per minute for this channel instance.' ;
    rdfs:domain ind:DigitalChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:oauthClientIdentifier rdf:type rdf:Property ;
    rdfs:label 'Oauth Client Identifier' ;
    rdfs:comment 'OAuth2 or OIDC client identifier for API consumer authentication.' ;
    rdfs:domain ind:DigitalChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oauthClientSecretHash rdf:type rdf:Property ;
    rdfs:label 'Oauth Client Secret Hash' ;
    rdfs:comment 'Hashed OAuth2 client secret for secure credential storage.' ;
    rdfs:domain ind:DigitalChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onboardingApprovedDate rdf:type rdf:Property ;
    rdfs:label 'Onboarding Approved Date' ;
    rdfs:comment 'Date when the channel or API consumer registration was approved.' ;
    rdfs:domain ind:DigitalChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:platformVariant rdf:type rdf:Property ;
    rdfs:label 'Platform Variant' ;
    rdfs:comment 'Specific platform or protocol variant for the channel (e.g., iOS, Android, REST API).' ;
    rdfs:domain ind:DigitalChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionTimeoutMinutes rdf:type rdf:Property ;
    rdfs:label 'Session Timeout Minutes' ;
    rdfs:comment 'Idle session timeout duration in minutes before automatic logout or token expiration.' ;
    rdfs:domain ind:DigitalChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:termsAcceptedDate rdf:type rdf:Property ;
    rdfs:label 'Terms Accepted Date' ;
    rdfs:comment 'Date when the current terms of service version was accepted by the developer or TPP.' ;
    rdfs:domain ind:DigitalChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tppRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Tpp Registration Number' ;
    rdfs:comment 'Regulatory registration or license number for third-party provider applications under PSD2 or open banking frameworks.' ;
    rdfs:domain ind:DigitalChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelIncidentId rdf:type rdf:Property ;
    rdfs:label 'Channel Incident Id' ;
    rdfs:comment 'Unique identifier for the channel incident record. Primary key.' ;
    rdfs:domain ind:ChannelIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedEngineerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Assigned Engineer Employee Id' ;
    rdfs:comment 'Foreign key linking to hr.employee. Business justification: Channel incidents require individual engineer assignment for accountability, workload tracking, resolution metrics, and escalation management. Critical for IT operations, SLA compliance, and post-inci' ;
    rdfs:domain ind:ChannelIncident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:acknowledgedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Acknowledged Timestamp' ;
    rdfs:comment 'Date and time when the incident was acknowledged by the support team and assigned for investigation. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:ChannelIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:affectedChannelCount rdf:type rdf:Property ;
    rdfs:label 'Affected Channel Count' ;
    rdfs:comment 'Number of distinct channels impacted by this incident. Used for multi-channel outage scenarios.' ;
    rdfs:domain ind:ChannelIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedLocationCount rdf:type rdf:Property ;
    rdfs:label 'Affected Location Count' ;
    rdfs:comment 'Number of physical locations (branches, ATMs) or logical endpoints affected by the incident.' ;
    rdfs:domain ind:ChannelIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedTeam rdf:type rdf:Property ;
    rdfs:label 'Assigned Team' ;
    rdfs:comment 'Name of the technical support team or group assigned to investigate and resolve the incident.' ;
    rdfs:domain ind:ChannelIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelIncidentStatus rdf:type rdf:Property ;
    rdfs:label 'Channel Incident Status' ;
    rdfs:comment 'Current lifecycle status of the incident. Tracks progression from initial detection through investigation, resolution, and closure. [ENUM-REF-CANDIDATE: new|acknowledged|investigating|identified|resolving|resolved|closed|reopened — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ChannelIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Closed Timestamp' ;
    rdfs:comment 'Date and time when the incident record was formally closed after verification and documentation. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:communicationSentFlag rdf:type rdf:Property ;
    rdfs:label 'Communication Sent Flag' ;
    rdfs:comment 'Indicates whether customer communication was sent regarding the incident. True if customers were notified; False otherwise.' ;
    rdfs:domain ind:ChannelIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerImpactCount rdf:type rdf:Property ;
    rdfs:label 'Customer Impact Count' ;
    rdfs:comment 'Estimated or actual number of customers affected by the incident. Used for impact assessment and regulatory reporting.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:detectedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Detected Timestamp' ;
    rdfs:comment 'Date and time when the incident was first detected by monitoring systems or reported by users. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:durationMinutes rdf:type rdf:Property ;
    rdfs:label 'Duration Minutes' ;
    rdfs:comment 'Total duration of the incident from start to resolution, measured in minutes. Used for Service Level Agreement (SLA) tracking and operational risk reporting.' ;
    rdfs:domain ind:ChannelIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:escalatedFlag rdf:type rdf:Property ;
    rdfs:label 'Escalated Flag' ;
    rdfs:comment 'Indicates whether the incident was escalated beyond initial support tier. True if escalated; False if resolved at first level.' ;
    rdfs:domain ind:ChannelIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalationLevel rdf:type rdf:Property ;
    rdfs:label 'Escalation Level' ;
    rdfs:comment 'Current escalation tier of the incident. Level 1 is first-line support; higher levels indicate escalation to specialized teams or management.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentNumber rdf:type rdf:Property ;
    rdfs:label 'Incident Number' ;
    rdfs:comment 'Business-facing unique incident reference number used for tracking and communication. Format: INC-YYYYMMDD.' ;
    rdfs:domain ind:ChannelIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentType rdf:type rdf:Property ;
    rdfs:label 'Incident Type' ;
    rdfs:comment 'Classification of the incident by operational category: ATM outage, mobile app downtime, web banking downtime, branch closure, contact center system failure, or API gateway disruption.' ;
    rdfs:domain ind:ChannelIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postIncidentReviewDate rdf:type rdf:Property ;
    rdfs:label 'Post Incident Review Date' ;
    rdfs:comment 'Date when the post-incident review was conducted or is scheduled. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:ChannelIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:postIncidentReviewRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Post Incident Review Required Flag' ;
    rdfs:comment 'Indicates whether a formal post-incident review is required based on severity, impact, or regulatory requirements. True if review required; False otherwise.' ;
    rdfs:domain ind:ChannelIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postIncidentReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Post Incident Review Status' ;
    rdfs:comment 'Current status of the post-incident review process. Tracks progression from scheduling through completion of lessons-learned analysis.' ;
    rdfs:domain ind:ChannelIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportableFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reportable Flag' ;
    rdfs:comment 'Indicates whether the incident meets thresholds for mandatory regulatory reporting to authorities such as Federal Reserve, OCC, or CFPB. True if reportable; False otherwise.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resolutionDescription rdf:type rdf:Property ;
    rdfs:label 'Resolution Description' ;
    rdfs:comment 'Detailed narrative of the actions taken to resolve the incident and restore service. Documents the resolution steps for knowledge management.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Resolved Timestamp' ;
    rdfs:comment 'Date and time when the incident was resolved and service was restored. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:ChannelIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rootCauseDescription rdf:type rdf:Property ;
    rdfs:label 'Root Cause Description' ;
    rdfs:comment 'Detailed narrative description of the root cause identified through investigation. Documents the underlying technical or operational failure that triggered the incident.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rpoMetFlag rdf:type rdf:Property ;
    rdfs:label 'Rpo Met Flag' ;
    rdfs:comment 'Indicates whether data recovery met the defined RPO target. True if RPO was met; False if data loss exceeded acceptable threshold.' ;
    rdfs:domain ind:ChannelIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rpoTargetMinutes rdf:type rdf:Property ;
    rdfs:label 'Rpo Target Minutes' ;
    rdfs:comment 'Target Recovery Point Objective for this incident type, measured in minutes. Defines the maximum acceptable data loss window per business continuity plan.' ;
    rdfs:domain ind:ChannelIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rtoMetFlag rdf:type rdf:Property ;
    rdfs:label 'Rto Met Flag' ;
    rdfs:comment 'Indicates whether the incident was resolved within the defined RTO target. True if RTO was met; False if exceeded.' ;
    rdfs:domain ind:ChannelIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rtoTargetMinutes rdf:type rdf:Property ;
    rdfs:label 'Rto Target Minutes' ;
    rdfs:comment 'Target Recovery Time Objective for this incident type, measured in minutes. Defines the maximum acceptable downtime per business continuity plan.' ;
    rdfs:domain ind:ChannelIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaBreachFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Flag' ;
    rdfs:comment 'Indicates whether the incident resulted in a breach of service level agreement commitments. True if SLA was breached; False otherwise.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:startTimestamp rdf:type rdf:Property ;
    rdfs:label 'Start Timestamp' ;
    rdfs:comment 'Date and time when the incident actually began affecting service availability or performance. May differ from detected_timestamp if incident started before detection. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:timeToAcknowledgeMinutes rdf:type rdf:Property ;
    rdfs:label 'Time To Acknowledge Minutes' ;
    rdfs:comment 'Time elapsed between detection and acknowledgment by support team, measured in minutes. Used for response time SLA tracking.' ;
    rdfs:domain ind:ChannelIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:timeToDetectMinutes rdf:type rdf:Property ;
    rdfs:label 'Time To Detect Minutes' ;
    rdfs:comment 'Time elapsed between incident start and detection, measured in minutes. Key metric for monitoring effectiveness.' ;
    rdfs:domain ind:ChannelIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:timeToResolveMinutes rdf:type rdf:Property ;
    rdfs:label 'Time To Resolve Minutes' ;
    rdfs:comment 'Time elapsed between acknowledgment and resolution, measured in minutes. Core metric for incident management performance.' ;
    rdfs:domain ind:ChannelIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transactionImpactCount rdf:type rdf:Property ;
    rdfs:label 'Transaction Impact Count' ;
    rdfs:comment 'Number of customer transactions that failed, were delayed, or were otherwise impacted during the incident window.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:workaroundAppliedFlag rdf:type rdf:Property ;
    rdfs:label 'Workaround Applied Flag' ;
    rdfs:comment 'Indicates whether a temporary workaround was applied to restore service before permanent resolution. True if workaround was used; False if direct resolution.' ;
    rdfs:domain ind:ChannelIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workaroundDescription rdf:type rdf:Property ;
    rdfs:label 'Workaround Description' ;
    rdfs:comment 'Description of the temporary workaround applied to restore service while permanent fix is implemented.' ;
    rdfs:domain ind:ChannelIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionId rdf:type rdf:Property ;
    rdfs:label 'Interaction Id' ;
    rdfs:comment 'Primary key for interaction' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Interaction .

ind:interactionContactCenterAgentEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Interaction Contact Center Agent Employee Id' ;
    rdfs:comment 'The identifier of the contact center agent who handled the interaction. Populated only for contact center channel interactions.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:interactionEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Interaction Employee Id' ;
    rdfs:comment 'The identifier of the teller who processed the branch transaction. Populated only for branch channel interactions.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:overrideApprovalId rdf:type rdf:Property ;
    rdfs:label 'Override Approval Id' ;
    rdfs:comment 'The identifier of the supervisory override or approval granted for exceptions or limit overrides during the transaction. Populated for branch and contact center interactions requiring approval.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OverrideApproval .

ind:apiEndpoint rdf:type rdf:Property ;
    rdfs:label 'Api Endpoint' ;
    rdfs:comment 'The API endpoint URL or path invoked during the interaction. Populated only for API channel interactions.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apiPayloadSizeBytes rdf:type rdf:Property ;
    rdfs:label 'Api Payload Size Bytes' ;
    rdfs:comment 'The size of the API request or response payload in bytes. Populated only for API channel interactions.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:apiResponseCode rdf:type rdf:Property ;
    rdfs:label 'Api Response Code' ;
    rdfs:comment 'The HTTP response code returned by the API endpoint (e.g., 200, 400, 500). Populated only for API channel interactions.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:atmAuthorizationCode rdf:type rdf:Property ;
    rdfs:label 'Atm Authorization Code' ;
    rdfs:comment 'The authorization or approval code returned by the ATM network for the transaction. Populated only for ATM channel interactions.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:atmCashDispensedFlag rdf:type rdf:Property ;
    rdfs:label 'Atm Cash Dispensed Flag' ;
    rdfs:comment 'Indicates whether cash was successfully dispensed during the ATM transaction. Populated only for ATM channel interactions.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:atmResponseCode rdf:type rdf:Property ;
    rdfs:label 'Atm Response Code' ;
    rdfs:comment 'The response code returned by the ATM network indicating success, decline, or error condition. Populated only for ATM channel interactions.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:atmSurchargeAmount rdf:type rdf:Property ;
    rdfs:label 'Atm Surcharge Amount' ;
    rdfs:comment 'The surcharge fee applied to the ATM transaction, if applicable. Populated only for ATM channel interactions.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:branchLocationCode rdf:type rdf:Property ;
    rdfs:label 'Branch Location Code' ;
    rdfs:comment 'The code identifying the branch location where the interaction occurred. Populated only for branch channel interactions.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactCenterCallDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Contact Center Call Duration Seconds' ;
    rdfs:comment 'The total duration of the contact center call in seconds. Populated only for contact center voice interactions.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contactCenterInteractionMode rdf:type rdf:Property ;
    rdfs:label 'Contact Center Interaction Mode' ;
    rdfs:comment 'The mode of contact center interaction (e.g., Interactive Voice Response (IVR), live voice call, chat, email, Short Message Service (SMS)). Populated only for contact center channel interactions.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactCenterIvrPath rdf:type rdf:Property ;
    rdfs:label 'Contact Center Ivr Path' ;
    rdfs:comment 'The sequence of IVR menu selections made by the customer during the interaction. Populated only for contact center IVR interactions.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalDeviceType rdf:type rdf:Property ;
    rdfs:label 'Digital Device Type' ;
    rdfs:comment 'The type of device used for digital banking interactions. Populated only for digital banking channel interactions.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalSessionIpAddress rdf:type rdf:Property ;
    rdfs:label 'Digital Session Ip Address' ;
    rdfs:comment 'The IP address from which the digital banking session originated. Populated only for digital banking channel interactions.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalUserAgent rdf:type rdf:Property ;
    rdfs:label 'Digital User Agent' ;
    rdfs:comment 'The user agent string identifying the browser or application used for the digital banking interaction. Populated only for digital banking channel interactions.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationSeconds rdf:type rdf:Property ;
    rdfs:label 'Duration Seconds' ;
    rdfs:comment 'The duration of the interaction in seconds, from initiation to completion or termination.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:errorCode rdf:type rdf:Property ;
    rdfs:label 'Error Code' ;
    rdfs:comment 'The system error code if the interaction failed or encountered an error condition.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:errorMessage rdf:type rdf:Property ;
    rdfs:label 'Error Message' ;
    rdfs:comment 'The human-readable error message describing the failure or error condition.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geolocationLatitude rdf:type rdf:Property ;
    rdfs:label 'Geolocation Latitude' ;
    rdfs:comment 'The latitude coordinate of the interaction location, if captured (e.g., for mobile banking or ATM transactions).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geolocationLongitude rdf:type rdf:Property ;
    rdfs:label 'Geolocation Longitude' ;
    rdfs:comment 'The longitude coordinate of the interaction location, if captured (e.g., for mobile banking or ATM transactions).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interactionStatus rdf:type rdf:Property ;
    rdfs:label 'Interaction Status' ;
    rdfs:comment 'The outcome or current status of the interaction event.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Interaction Timestamp' ;
    rdfs:comment 'The precise date and time when the interaction event occurred in the channel system.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:interactionType rdf:type rdf:Property ;
    rdfs:label 'Interaction Type' ;
    rdfs:comment 'The specific type of interaction or transaction performed (e.g., withdrawal, deposit, balance inquiry, login, transfer, bill payment, wire initiation, account inquiry, IVR navigation, agent call, API call).' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productServiceCode rdf:type rdf:Property ;
    rdfs:label 'Product Service Code' ;
    rdfs:comment 'The code identifying the product or service associated with this interaction (e.g., checking account, savings account, loan product, investment product).' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionStatus rdf:type rdf:Property ;
    rdfs:label 'Resolution Status' ;
    rdfs:comment 'Indicates whether the customer inquiry or issue was resolved during this interaction.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTargetSeconds rdf:type rdf:Property ;
    rdfs:label 'Sla Target Seconds' ;
    rdfs:comment 'The target service level agreement time for this interaction type, measured in seconds.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:journeyId rdf:type rdf:Property ;
    rdfs:label 'Journey Id' ;
    rdfs:comment 'Primary key for journey' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Journey .

ind:currentChannelId rdf:type rdf:Property ;
    rdfs:label 'Current Channel Id' ;
    rdfs:comment 'Foreign key linking to channel.channel. Business justification: Customer journeys track progression across channels. The current_channel string should be replaced with a FK to the channel master to enable proper omnichannel analytics. This FK uses the label prefix' ;
    rdfs:domain ind:Journey ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:abandonmentFlag rdf:type rdf:Property ;
    rdfs:label 'Abandonment Flag' ;
    rdfs:comment 'Indicates whether the customer abandoned the journey before completion. True if the customer dropped off; false otherwise.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:abandonmentStage rdf:type rdf:Property ;
    rdfs:label 'Abandonment Stage' ;
    rdfs:comment 'The stage at which the customer abandoned the journey. Null if journey was not abandoned. Used to identify friction points.' ;
    rdfs:domain ind:Journey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:abandonmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Abandonment Timestamp' ;
    rdfs:comment 'Date and time when the journey was marked as abandoned. Null if journey was not abandoned.' ;
    rdfs:domain ind:Journey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:activeDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Active Duration Minutes' ;
    rdfs:comment 'Total time the customer was actively engaged in the journey (excluding idle time), measured in minutes. Provides insight into actual effort required.' ;
    rdfs:domain ind:Journey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Timestamp' ;
    rdfs:comment 'Date and time when the journey was successfully completed. Null for in-progress or abandoned journeys.' ;
    rdfs:domain ind:Journey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:applicationReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Application Reference Number' ;
    rdfs:comment 'External reference number for the application or case associated with this journey. Used for cross-system tracking and customer communication.' ;
    rdfs:domain ind:Journey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelScope rdf:type rdf:Property ;
    rdfs:label 'Channel Scope' ;
    rdfs:comment 'Defines which channels are available for this journey. Omnichannel allows seamless switching; restricted scopes limit customer to specific channels.' ;
    rdfs:domain ind:Journey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelSwitchCount rdf:type rdf:Property ;
    rdfs:label 'Channel Switch Count' ;
    rdfs:comment 'Number of times the customer switched channels during this journey. Measures omnichannel behavior and channel orchestration effectiveness.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Flag' ;
    rdfs:comment 'Indicates whether all regulatory requirements were met during the journey. True if compliant; false if any compliance issues were identified.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currentStage rdf:type rdf:Property ;
    rdfs:label 'Current Stage' ;
    rdfs:comment 'The current stage or step the customer is in within the journey (e.g., \'Identity Verification\', \'Document Upload\', \'Credit Review\', \'Final Approval\'). Stage names are journey-specific.' ;
    rdfs:domain ind:Journey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentStageEntryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Current Stage Entry Timestamp' ;
    rdfs:comment 'Date and time when the customer entered the current stage. Used to calculate stage duration and identify bottlenecks.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:currentStageSequence rdf:type rdf:Property ;
    rdfs:label 'Current Stage Sequence' ;
    rdfs:comment 'Ordinal position of the current stage within the journey template. Enables progress tracking and completion percentage calculation.' ;
    rdfs:domain ind:Journey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:escalationReason rdf:type rdf:Property ;
    rdfs:label 'Escalation Reason' ;
    rdfs:comment 'Reason for journey escalation, if applicable. Null if journey has not been escalated.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Expected Completion Date' ;
    rdfs:comment 'Projected date by which the journey should be completed based on template durations and current progress. Used for SLA tracking and customer communication.' ;
    rdfs:domain ind:Journey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:initiatedChannel rdf:type rdf:Property ;
    rdfs:label 'Initiated Channel' ;
    rdfs:comment 'The channel through which the customer originally started this journey. Enables channel attribution and conversion analysis. [ENUM-REF-CANDIDATE: mobile_app|web_portal|branch|atm|contact_center|relationship_manager|api|chatbot — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Journey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:journeyName rdf:type rdf:Property ;
    rdfs:label 'Journey Name' ;
    rdfs:comment 'Business-friendly name of the journey instance, typically derived from the template (e.g., \'Personal Checking Account Opening\', \'Mortgage Loan Application\', \'Annual KYC Refresh\').' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:journeyStatus rdf:type rdf:Property ;
    rdfs:label 'Journey Status' ;
    rdfs:comment 'Current lifecycle status of the journey instance. Tracks whether the customer is actively progressing, has completed, or has dropped off. [ENUM-REF-CANDIDATE: initiated|in_progress|completed|abandoned|suspended|cancelled|failed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:journeyType rdf:type rdf:Property ;
    rdfs:label 'Journey Type' ;
    rdfs:comment 'Classification of the journey by business process type. Determines applicable regulatory requirements, SLA targets, and channel orchestration rules. [ENUM-REF-CANDIDATE: account_opening|loan_application|kyc_refresh|onboarding|product_upgrade|complaint_resolution|service_request|wealth_advisory|investment_onboarding — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Journey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npsCollectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Nps Collection Timestamp' ;
    rdfs:comment 'Date and time when the NPS score was collected from the customer. Null if NPS was not collected.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:npsScore rdf:type rdf:Property ;
    rdfs:label 'Nps Score' ;
    rdfs:comment 'Customer satisfaction score collected at journey completion, typically on a 0-10 scale. Used to measure customer experience and journey quality.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:outcome rdf:type rdf:Property ;
    rdfs:label 'Outcome' ;
    rdfs:comment 'Final outcome of the journey. Successful indicates the customer completed all stages and achieved the goal; unsuccessful indicates completion without goal achievement; abandoned indicates customer drop-off.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productAppliedFor rdf:type rdf:Property ;
    rdfs:label 'Product Applied For' ;
    rdfs:comment 'The specific banking product or service the customer is applying for or upgrading to through this journey (e.g., \'Premium Checking\', \'Mortgage Loan\', \'Wealth Management Advisory\').' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionCount rdf:type rdf:Property ;
    rdfs:label 'Session Count' ;
    rdfs:comment 'Number of distinct customer sessions (login/interaction events) that occurred during this journey. Measures engagement frequency.' ;
    rdfs:domain ind:Journey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaTargetMinutes rdf:type rdf:Property ;
    rdfs:label 'Sla Target Minutes' ;
    rdfs:comment 'Target completion time for this journey type as defined in the service level agreement, measured in minutes.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Total Duration Minutes' ;
    rdfs:comment 'Total elapsed time from journey start to completion or abandonment, measured in minutes. Used for performance analysis and SLA compliance.' ;
    rdfs:domain ind:Journey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalStages rdf:type rdf:Property ;
    rdfs:label 'Total Stages' ;
    rdfs:comment 'Total number of stages defined in the journey template. Used to calculate journey completion percentage.' ;
    rdfs:domain ind:Journey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:journeyInstanceId rdf:type rdf:Property ;
    rdfs:label 'Journey Instance Id' ;
    rdfs:comment 'Unique identifier for each individual customer journey instance. Primary key for tracking a specific customer\'s progression through a defined journey template.' ;
    rdfs:domain ind:JourneyInstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:initialChannelId rdf:type rdf:Property ;
    rdfs:label 'Initial Channel Id' ;
    rdfs:comment 'Foreign key linking to channel.channel. Business justification: Journey instances track individual customer progressions and need to reference the initial channel where the journey started. The initial_channel_code string is replaced with a proper FK. Label prefix' ;
    rdfs:domain ind:JourneyInstance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:abandonmentReasonCode rdf:type rdf:Property ;
    rdfs:label 'Abandonment Reason Code' ;
    rdfs:comment 'Coded reason for journey abandonment (e.g., \'TIMEOUT\', \'CUSTOMER_DECLINED\', \'TECHNICAL_ERROR\', \'INCOMPLETE_DOCS\'). Supports root cause analysis of abandonment patterns.' ;
    rdfs:domain ind:JourneyInstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:abandonmentStageCode rdf:type rdf:Property ;
    rdfs:label 'Abandonment Stage Code' ;
    rdfs:comment 'Code of the stage where the customer abandoned the journey. Null if the journey was not abandoned. Used to identify high-friction stages and optimize journey design.' ;
    rdfs:domain ind:JourneyInstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activeDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Active Duration Seconds' ;
    rdfs:comment 'Total time in seconds the customer was actively engaged in the journey (excluding idle time, wait time for approvals, or system processing time). Measures actual customer effort.' ;
    rdfs:domain ind:JourneyInstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:campaignCode rdf:type rdf:Property ;
    rdfs:label 'Campaign Code' ;
    rdfs:comment 'Marketing campaign code associated with this journey instance. Links journey performance to specific marketing initiatives and enables campaign Return on Investment (ROI) analysis.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cltvSegment rdf:type rdf:Property ;
    rdfs:label 'Cltv Segment' ;
    rdfs:comment 'Customer Lifetime Value (CLTV) segment of the customer at the time of journey initiation. Used to link journey experience and completion rates to customer value and prioritize high-value customer journeys.' ;
    rdfs:domain ind:JourneyInstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentChannelCode rdf:type rdf:Property ;
    rdfs:label 'Current Channel Code' ;
    rdfs:comment 'Channel where the customer is currently interacting in the journey. Tracks channel switches and omnichannel behavior (e.g., started online, continued in branch). [ENUM-REF-CANDIDATE: mobile|web|branch|atm|contact_center|relationship_manager|api|partner — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:JourneyInstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentStageCode rdf:type rdf:Property ;
    rdfs:label 'Current Stage Code' ;
    rdfs:comment 'Code representing the current stage in the journey where the customer is positioned (e.g., \'INIT\', \'KYC\', \'APPROVAL\', \'FULFILLMENT\', \'COMPLETE\'). Used for operational tracking and stage-level analytics.' ;
    rdfs:domain ind:JourneyInstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentStageName rdf:type rdf:Property ;
    rdfs:label 'Current Stage Name' ;
    rdfs:comment 'Human-readable name of the current stage (e.g., \'Initial Application\', \'Know Your Customer (KYC) Verification\', \'Credit Approval\', \'Account Fulfillment\'). Provides business context for the current position in the journey.' ;
    rdfs:domain ind:JourneyInstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerFeedbackText rdf:type rdf:Property ;
    rdfs:label 'Customer Feedback Text' ;
    rdfs:comment 'Free-text feedback provided by the customer about their journey experience. Supports qualitative analysis of customer sentiment and journey pain points.' ;
    rdfs:domain ind:JourneyInstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSegmentCode rdf:type rdf:Property ;
    rdfs:label 'Customer Segment Code' ;
    rdfs:comment 'Code representing the customer segment (e.g., \'RETAIL\', \'WEALTH\', \'CORPORATE\', \'SME\') at the time of journey initiation. Enables segment-specific journey performance analysis.' ;
    rdfs:domain ind:JourneyInstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceType rdf:type rdf:Property ;
    rdfs:label 'Device Type' ;
    rdfs:comment 'Type of device used by the customer to initiate the journey. Supports device-specific journey optimization and responsive design analytics.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endTimestamp rdf:type rdf:Property ;
    rdfs:label 'End Timestamp' ;
    rdfs:comment 'Timestamp when the journey was completed, abandoned, or terminated. Null for in-progress journeys. Used to calculate journey duration and completion metrics.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:errorCount rdf:type rdf:Property ;
    rdfs:label 'Error Count' ;
    rdfs:comment 'Number of errors or exceptions encountered during the journey. Indicates technical friction and system reliability issues impacting customer experience.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:finalOutcomeCode rdf:type rdf:Property ;
    rdfs:label 'Final Outcome Code' ;
    rdfs:comment 'Final outcome of the journey instance. Indicates whether the customer successfully completed the intended business objective, failed, partially completed, or abandoned.' ;
    rdfs:domain ind:JourneyInstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finalOutcomeDescription rdf:type rdf:Property ;
    rdfs:label 'Final Outcome Description' ;
    rdfs:comment 'Detailed description of the final journey outcome. Provides business context for the outcome code (e.g., \'Account opened successfully\', \'Application declined due to credit score\', \'Customer abandoned at document upload\').' ;
    rdfs:domain ind:JourneyInstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralSourceCode rdf:type rdf:Property ;
    rdfs:label 'Referral Source Code' ;
    rdfs:comment 'Code indicating how the customer was referred to this journey (e.g., \'ORGANIC\', \'CAMPAIGN\', \'PARTNER\', \'BRANCH_REFERRAL\'). Supports marketing attribution and channel effectiveness analysis.' ;
    rdfs:domain ind:JourneyInstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTargetDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Sla Target Duration Seconds' ;
    rdfs:comment 'Target duration in seconds for completing this journey as defined by the Service Level Agreement (SLA). Used to measure journey performance against business commitments.' ;
    rdfs:domain ind:JourneyInstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stageCount rdf:type rdf:Property ;
    rdfs:label 'Stage Count' ;
    rdfs:comment 'Total number of stages the customer progressed through in this journey instance. Used to measure journey complexity and compare actual vs. expected stage progression.' ;
    rdfs:domain ind:JourneyInstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Total Duration Seconds' ;
    rdfs:comment 'Total elapsed time in seconds from journey start to end. Calculated as the difference between end_timestamp and start_timestamp. Used for journey efficiency analysis and Service Level Agreement (SLA) tracking.' ;
    rdfs:domain ind:JourneyInstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:openBankingConsentId rdf:type rdf:Property ;
    rdfs:label 'Open Banking Consent Id' ;
    rdfs:comment 'Unique identifier for the open banking consent record. Primary key for the consent entity.' ;
    rdfs:domain ind:OpenBankingConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:modifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Modified By User Employee Id' ;
    rdfs:comment 'Identifier of the system user or process that last modified this consent record, supporting accountability and audit requirements.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:previousConsentOpenBankingConsentId rdf:type rdf:Property ;
    rdfs:label 'Previous Consent Open Banking Consent Id' ;
    rdfs:comment 'Reference to the previous consent record if this is a renewal, enabling consent history tracking and lineage.' ;
    rdfs:domain ind:OpenBankingConsent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OpenBankingConsent .

ind:thirdPartyProviderId rdf:type rdf:Property ;
    rdfs:label 'Third Party Provider Id' ;
    rdfs:comment 'Unique identifier of the third-party provider (TPP) or fintech application authorized to access customer data under open banking frameworks.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ThirdPartyProvider .

ind:accessCount rdf:type rdf:Property ;
    rdfs:label 'Access Count' ;
    rdfs:comment 'Total number of times the TPP has accessed customer data under this consent since grant, supporting usage analytics and compliance monitoring.' ;
    rdfs:domain ind:OpenBankingConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accessFrequencyLimit rdf:type rdf:Property ;
    rdfs:label 'Access Frequency Limit' ;
    rdfs:comment 'Maximum number of data access requests permitted per day under this consent, enforcing PSD2 access frequency rules (typically 4 times per day).' ;
    rdfs:domain ind:OpenBankingConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountScope rdf:type rdf:Property ;
    rdfs:label 'Account Scope' ;
    rdfs:comment 'Specific accounts or account types included in the consent scope, defining which customer accounts the TPP is authorized to access.' ;
    rdfs:domain ind:OpenBankingConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Review Status' ;
    rdfs:comment 'Status of regulatory compliance review for high-risk consents: not required for standard consents, pending review, approved after review, or rejected.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceReviewTimestamp rdf:type rdf:Property ;
    rdfs:label 'Compliance Review Timestamp' ;
    rdfs:comment 'Date and time when compliance review was completed for this consent. Null if no review was required or review is pending.' ;
    rdfs:domain ind:OpenBankingConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:consentChannel rdf:type rdf:Property ;
    rdfs:label 'Consent Channel' ;
    rdfs:comment 'Channel through which the customer granted the open banking consent: mobile app, web portal, branch, contact center, or direct API integration.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentLanguageCode rdf:type rdf:Property ;
    rdfs:label 'Consent Language Code' ;
    rdfs:comment 'ISO 639-1 two-letter language code indicating the language in which consent terms were presented to and accepted by the customer.' ;
    rdfs:domain ind:OpenBankingConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Consent Reference Number' ;
    rdfs:comment 'External business identifier for the consent, used for customer communication and audit trails.' ;
    rdfs:domain ind:OpenBankingConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentScope rdf:type rdf:Property ;
    rdfs:label 'Consent Scope' ;
    rdfs:comment 'Detailed scope of data access granted, including specific account types, transaction history depth, and data elements authorized for sharing.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentStatus rdf:type rdf:Property ;
    rdfs:label 'Consent Status' ;
    rdfs:comment 'Current lifecycle status of the consent: pending customer approval, active and in use, expired by time limit, revoked by customer, suspended by bank, or rejected.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentType rdf:type rdf:Property ;
    rdfs:label 'Consent Type' ;
    rdfs:comment 'Type of open banking consent granted: account information access, payment initiation, funds confirmation, identity verification, or combined services.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentVersion rdf:type rdf:Property ;
    rdfs:label 'Consent Version' ;
    rdfs:comment 'Version identifier of the consent terms and conditions accepted by the customer, enabling tracking of consent template changes over time.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerConsentConfirmationCode rdf:type rdf:Property ;
    rdfs:label 'Customer Consent Confirmation Code' ;
    rdfs:comment 'Unique confirmation code provided to the customer upon consent grant, used for customer service inquiries and consent verification.' ;
    rdfs:domain ind:OpenBankingConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerDeviceFingerprint rdf:type rdf:Property ;
    rdfs:label 'Customer Device Fingerprint' ;
    rdfs:comment 'Unique identifier of the device used by the customer to grant consent, supporting fraud detection and security monitoring.' ;
    rdfs:domain ind:OpenBankingConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerIpAddress rdf:type rdf:Property ;
    rdfs:label 'Customer Ip Address' ;
    rdfs:comment 'IP address from which the customer granted the consent, captured for fraud prevention and audit purposes.' ;
    rdfs:domain ind:OpenBankingConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataAccessLogReference rdf:type rdf:Property ;
    rdfs:label 'Data Access Log Reference' ;
    rdfs:comment 'Reference identifier linking to detailed audit logs of all data access events performed under this consent, enabling full traceability.' ;
    rdfs:domain ind:OpenBankingConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataRetentionPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Data Retention Period Days' ;
    rdfs:comment 'Number of days the consent record and associated audit logs must be retained for regulatory compliance after consent expiry or revocation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:grantTimestamp rdf:type rdf:Property ;
    rdfs:label 'Grant Timestamp' ;
    rdfs:comment 'Date and time when the customer granted the open banking consent, recorded in ISO 8601 format with timezone.' ;
    rdfs:domain ind:OpenBankingConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastAccessTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Access Timestamp' ;
    rdfs:comment 'Date and time of the most recent data access by the TPP under this consent, used for monitoring and compliance reporting.' ;
    rdfs:domain ind:OpenBankingConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recurringAccessIndicator rdf:type rdf:Property ;
    rdfs:label 'Recurring Access Indicator' ;
    rdfs:comment 'Indicates whether the consent authorizes recurring data access (true) or one-time access only (false).' ;
    rdfs:domain ind:OpenBankingConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalIndicator rdf:type rdf:Property ;
    rdfs:label 'Renewal Indicator' ;
    rdfs:comment 'Indicates whether this consent is a renewal of a previous expired consent (true) or a new initial consent (false).' ;
    rdfs:domain ind:OpenBankingConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revocationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Revocation Timestamp' ;
    rdfs:comment 'Date and time when the customer revoked the consent, terminating TPP data access authorization. Null if consent has not been revoked.' ;
    rdfs:domain ind:OpenBankingConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:riskAssessmentScore rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Score' ;
    rdfs:comment 'Risk score assigned to this consent at grant time based on customer profile, TPP reputation, and fraud indicators, ranging from 0.00 (low risk) to 100.00 (high risk).' ;
    rdfs:domain ind:OpenBankingConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tppCertificateReference rdf:type rdf:Property ;
    rdfs:label 'Tpp Certificate Reference' ;
    rdfs:comment 'Qualified certificate identifier issued to the TPP by a qualified trust service provider, validating TPP authorization under PSD2.' ;
    rdfs:domain ind:OpenBankingConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionHistoryPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Transaction History Period Days' ;
    rdfs:comment 'Number of days of historical transaction data the TPP is authorized to access, typically 90 days under PSD2.' ;
    rdfs:domain ind:OpenBankingConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preferenceId rdf:type rdf:Property ;
    rdfs:label 'Preference Id' ;
    rdfs:comment 'Primary key for preference' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preferredBranchId rdf:type rdf:Property ;
    rdfs:label 'Preferred Branch Id' ;
    rdfs:comment 'Reference to the customers preferred branch location for in-person banking services. Nullable if customer has no branch preference.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Branch .

ind:accessibilityRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Accessibility Requirement Flag' ;
    rdfs:comment 'Boolean flag indicating whether the customer has declared accessibility requirements (visual, auditory, mobility, cognitive). True triggers accessibility-enhanced service delivery.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:accessibilityRequirementType rdf:type rdf:Property ;
    rdfs:label 'Accessibility Requirement Type' ;
    rdfs:comment 'Type of accessibility requirement declared by the customer. Used to configure appropriate assistive technologies and service accommodations. Confidential to protect customer privacy.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audioFormatRequired rdf:type rdf:Property ;
    rdfs:label 'Audio Format Required' ;
    rdfs:comment 'Boolean flag indicating whether the customer requires audio formats for digital communications and statements.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:brailleRequired rdf:type rdf:Property ;
    rdfs:label 'Braille Required' ;
    rdfs:comment 'Boolean flag indicating whether the customer requires Braille formats for paper communications.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:branchChannelPreferenceScore rdf:type rdf:Property ;
    rdfs:label 'Branch Channel Preference Score' ;
    rdfs:comment 'System-calculated score (0.00 to 100.00) representing the customers propensity to use branch services. Complements digital preference score for omnichannel segmentation.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consentBasis rdf:type rdf:Property ;
    rdfs:label 'Consent Basis' ;
    rdfs:comment 'Legal basis for processing the preference data under GDPR Article 6: explicit consent, legitimate interest, contractual necessity, legal obligation, or vital interest.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentIpAddress rdf:type rdf:Property ;
    rdfs:label 'Consent Ip Address' ;
    rdfs:comment 'IP address from which digital consent was provided. Used for fraud detection and consent verification. Confidential for privacy protection.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Consent Timestamp' ;
    rdfs:comment 'Date and time when the customer provided consent for this preference. Critical for GDPR and TCPA compliance auditing.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:digitalChannelPreferenceScore rdf:type rdf:Property ;
    rdfs:label 'Digital Channel Preference Score' ;
    rdfs:comment 'System-calculated score (0.00 to 100.00) representing the customers propensity to use digital channels (mobile, web, API) versus traditional channels (branch, phone). Higher scores indicate stronger digital preference. Used for channel migration strategies and personalization.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inferenceConfidenceScore rdf:type rdf:Property ;
    rdfs:label 'Inference Confidence Score' ;
    rdfs:comment 'Confidence score (0.00 to 100.00) associated with system-inferred preferences. Higher scores indicate greater confidence in the inference. Nullable for customer-stated preferences.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inferenceModelVersion rdf:type rdf:Property ;
    rdfs:label 'Inference Model Version' ;
    rdfs:comment 'Version identifier of the machine learning or analytics model used to infer preferences when preference_source is system_inferred. Enables model governance and auditability.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:largePrintRequired rdf:type rdf:Property ;
    rdfs:label 'Large Print Required' ;
    rdfs:comment 'Boolean flag indicating whether the customer requires large-print formats for paper communications and statements.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastVerifiedDate rdf:type rdf:Property ;
    rdfs:label 'Last Verified Date' ;
    rdfs:comment 'Date when the preference was last verified or reconfirmed by the customer. Used to track consent freshness and trigger re-verification workflows.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:marketingEmailOptIn rdf:type rdf:Property ;
    rdfs:label 'Marketing Email Opt In' ;
    rdfs:comment 'Boolean flag indicating whether the customer has consented to receive marketing and promotional emails. True = opted in, False = opted out. Must comply with CAN-SPAM Act and GDPR.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketingMailOptIn rdf:type rdf:Property ;
    rdfs:label 'Marketing Mail Opt In' ;
    rdfs:comment 'Boolean flag indicating whether the customer has consented to receive marketing and promotional materials via postal mail.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketingPhoneOptIn rdf:type rdf:Property ;
    rdfs:label 'Marketing Phone Opt In' ;
    rdfs:comment 'Boolean flag indicating whether the customer has consented to receive marketing and promotional phone calls. Must comply with TCPA and Do Not Call Registry requirements.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketingSmsOptIn rdf:type rdf:Property ;
    rdfs:label 'Marketing Sms Opt In' ;
    rdfs:comment 'Boolean flag indicating whether the customer has consented to receive marketing and promotional SMS messages. Must comply with TCPA regulations.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextVerificationDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Verification Due Date' ;
    rdfs:comment 'Date by which the preference should be re-verified with the customer to maintain compliance with consent renewal policies.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notificationCategoryAlerts rdf:type rdf:Property ;
    rdfs:label 'Notification Category Alerts' ;
    rdfs:comment 'Boolean flag indicating opt-in status for account alert notifications (low balance, large transaction, unusual activity).' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationCategoryPayments rdf:type rdf:Property ;
    rdfs:label 'Notification Category Payments' ;
    rdfs:comment 'Boolean flag indicating opt-in status for payment-related notifications (payment due, payment received, payment failed).' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationCategoryProducts rdf:type rdf:Property ;
    rdfs:label 'Notification Category Products' ;
    rdfs:comment 'Boolean flag indicating opt-in status for product and service update notifications (new features, rate changes, terms updates).' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationCategorySecurity rdf:type rdf:Property ;
    rdfs:label 'Notification Category Security' ;
    rdfs:comment 'Boolean flag indicating opt-in status for security-related notifications (login from new device, password change, suspicious activity). Typically defaults to True for customer protection.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overrideAuthorizedBy rdf:type rdf:Property ;
    rdfs:label 'Override Authorized By' ;
    rdfs:comment 'Name or identifier of the person or system that authorized the preference override. Required for audit trail when override_flag is True.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferenceSource rdf:type rdf:Property ;
    rdfs:label 'Preference Source' ;
    rdfs:comment 'Origin of the preference data: customer-stated (self-service), system-inferred (behavioral analytics), relationship manager input, onboarding process, data migration, or third-party source.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferenceStatus rdf:type rdf:Property ;
    rdfs:label 'Preference Status' ;
    rdfs:comment 'Current lifecycle status of the preference record. Active preferences are enforced in omnichannel orchestration.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferenceType rdf:type rdf:Property ;
    rdfs:label 'Preference Type' ;
    rdfs:comment 'Category of preference being captured: contact channel, communication, notification, service delivery, accessibility, or privacy.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredContactChannel rdf:type rdf:Property ;
    rdfs:label 'Preferred Contact Channel' ;
    rdfs:comment 'The customers stated or inferred primary channel for bank-initiated contact and service delivery. [ENUM-REF-CANDIDATE: mobile_app|web_portal|email|sms|phone|branch|atm|relationship_manager|mail — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredLanguageCode rdf:type rdf:Property ;
    rdfs:label 'Preferred Language Code' ;
    rdfs:comment 'ISO 639-2 three-letter language code representing the customers preferred language for communication and service delivery (e.g., ENG, SPA, FRA, CHI).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statementDeliveryChannel rdf:type rdf:Property ;
    rdfs:label 'Statement Delivery Channel' ;
    rdfs:comment 'Customers preferred channel for receiving account statements: electronic (email/portal), paper (postal mail), both, or suppressed (no statements).' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionalEmailOptIn rdf:type rdf:Property ;
    rdfs:label 'Transactional Email Opt In' ;
    rdfs:comment 'Boolean flag indicating whether the customer has opted in to receive transactional and service-related emails (statements, alerts, confirmations). Typically defaults to True as these are essential communications.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transactionalSmsOptIn rdf:type rdf:Property ;
    rdfs:label 'Transactional Sms Opt In' ;
    rdfs:comment 'Boolean flag indicating whether the customer has opted in to receive transactional and service-related SMS notifications (fraud alerts, payment confirmations, balance alerts).' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:queueId rdf:type rdf:Property ;
    rdfs:label 'Queue Id' ;
    rdfs:comment 'Unique identifier for the customer service queue. Primary key for the queue entity.' ;
    rdfs:domain ind:Queue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:managerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to hr.employee. Business justification: Queue ownership is critical for SLA accountability, staffing decisions, routing rule changes, and performance management. Banking operations require clear responsibility for queue performance metrics ' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:overflowQueueId rdf:type rdf:Property ;
    rdfs:label 'Overflow Queue Id' ;
    rdfs:comment 'Reference to the alternate queue where interactions are routed when this queue reaches maximum capacity.' ;
    rdfs:domain ind:Queue ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Queue .

ind:abandonmentThresholdSeconds rdf:type rdf:Property ;
    rdfs:label 'Abandonment Threshold Seconds' ;
    rdfs:comment 'Time threshold in seconds after which a customer disconnect is counted as an abandonment for reporting purposes.' ;
    rdfs:domain ind:Queue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:agentsAvailable rdf:type rdf:Property ;
    rdfs:label 'Agents Available' ;
    rdfs:comment 'Real-time count of agents or service representatives currently available to service this queue.' ;
    rdfs:domain ind:Queue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:agentsBusy rdf:type rdf:Property ;
    rdfs:label 'Agents Busy' ;
    rdfs:comment 'Real-time count of agents currently handling interactions from this queue.' ;
    rdfs:domain ind:Queue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:agentsStaffed rdf:type rdf:Property ;
    rdfs:label 'Agents Staffed' ;
    rdfs:comment 'Total count of agents or service representatives currently staffed and logged into this queue.' ;
    rdfs:domain ind:Queue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:averageHandleTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Average Handle Time Seconds' ;
    rdfs:comment 'Historical average time in seconds to complete an interaction from this queue, including talk time and after-call work.' ;
    rdfs:domain ind:Queue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:callbackEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Callback Enabled Flag' ;
    rdfs:comment 'Indicates whether customers can request a callback instead of waiting in queue.' ;
    rdfs:domain ind:Queue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currentQueueDepth rdf:type rdf:Property ;
    rdfs:label 'Current Queue Depth' ;
    rdfs:comment 'Real-time count of interactions currently waiting in the queue.' ;
    rdfs:domain ind:Queue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:currentSlaCompliancePercentage rdf:type rdf:Property ;
    rdfs:label 'Current Sla Compliance Percentage' ;
    rdfs:comment 'Real-time percentage of interactions answered within SLA target time for the current measurement period.' ;
    rdfs:domain ind:Queue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentWaitTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Current Wait Time Seconds' ;
    rdfs:comment 'Real-time average wait time in seconds for interactions currently in the queue.' ;
    rdfs:domain ind:Queue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedWaitTimeAnnouncementFlag rdf:type rdf:Property ;
    rdfs:label 'Estimated Wait Time Announcement Flag' ;
    rdfs:comment 'Indicates whether estimated wait time is announced to customers in queue.' ;
    rdfs:domain ind:Queue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:languageSupport rdf:type rdf:Property ;
    rdfs:label 'Language Support' ;
    rdfs:comment 'Comma-separated list of language codes supported by agents servicing this queue.' ;
    rdfs:domain ind:Queue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxQueueCapacity rdf:type rdf:Property ;
    rdfs:label 'Max Queue Capacity' ;
    rdfs:comment 'Maximum number of interactions that can be held in the queue before overflow or rejection occurs.' ;
    rdfs:domain ind:Queue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:musicOnHoldEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Music On Hold Enabled Flag' ;
    rdfs:comment 'Indicates whether music or audio content is played while customers wait in queue.' ;
    rdfs:domain ind:Queue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operatingHoursEndTime rdf:type rdf:Property ;
    rdfs:label 'Operating Hours End Time' ;
    rdfs:comment 'Daily end time when the queue stops accepting new interactions, in HH:MM format.' ;
    rdfs:domain ind:Queue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:operatingHoursStartTime rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Start Time' ;
    rdfs:comment 'Daily start time when the queue begins accepting interactions, in HH:MM format.' ;
    rdfs:domain ind:Queue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:productScope rdf:type rdf:Property ;
    rdfs:label 'Product Scope' ;
    rdfs:comment 'Comma-separated list of product categories or codes that this queue supports.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityMonitoringSampleRate rdf:type rdf:Property ;
    rdfs:label 'Quality Monitoring Sample Rate' ;
    rdfs:comment 'Percentage of interactions from this queue that are sampled for quality monitoring and coaching.' ;
    rdfs:domain ind:Queue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:queueCode rdf:type rdf:Property ;
    rdfs:label 'Queue Code' ;
    rdfs:comment 'Unique business identifier code for the queue used in operational systems and reporting.' ;
    rdfs:domain ind:Queue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:queueName rdf:type rdf:Property ;
    rdfs:label 'Queue Name' ;
    rdfs:comment 'Human-readable name of the queue describing its purpose or service area.' ;
    rdfs:domain ind:Queue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:queueStatus rdf:type rdf:Property ;
    rdfs:label 'Queue Status' ;
    rdfs:comment 'Current operational status of the queue indicating whether it is accepting new interactions.' ;
    rdfs:domain ind:Queue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:queueType rdf:type rdf:Property ;
    rdfs:label 'Queue Type' ;
    rdfs:comment 'Classification of the queue by interaction channel and service delivery method. [ENUM-REF-CANDIDATE: inbound_call|outbound_call|chat|email|video|branch_teller|branch_advisor|callback — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Queue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryRecordingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Recording Required Flag' ;
    rdfs:comment 'Indicates whether interactions in this queue must be recorded for regulatory compliance purposes.' ;
    rdfs:domain ind:Queue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:routingAlgorithm rdf:type rdf:Property ;
    rdfs:label 'Routing Algorithm' ;
    rdfs:comment 'Algorithm used to route interactions from this queue to available agents or service representatives.' ;
    rdfs:domain ind:Queue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceCategory rdf:type rdf:Property ;
    rdfs:label 'Service Category' ;
    rdfs:comment 'Business service category or line of business that this queue supports. [ENUM-REF-CANDIDATE: account_inquiry|loan_servicing|card_services|fraud_reporting|technical_support|sales|complaints — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skillGroup rdf:type rdf:Property ;
    rdfs:label 'Skill Group' ;
    rdfs:comment 'Skill group or competency category required to service interactions in this queue, used for agent routing.' ;
    rdfs:domain ind:Queue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTargetAnswerTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Sla Target Answer Time Seconds' ;
    rdfs:comment 'Target time in seconds within which interactions should be answered to meet SLA commitments.' ;
    rdfs:domain ind:Queue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaTargetPercentage rdf:type rdf:Property ;
    rdfs:label 'Sla Target Percentage' ;
    rdfs:comment 'Target percentage of interactions that should be answered within the SLA target time (e.g., 80% answered in 20 seconds).' ;
    rdfs:domain ind:Queue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:aumCurrencyId rdf:type rdf:Property ;
    rdfs:label 'Aum Currency Id' ;
    rdfs:comment 'Foreign key linking to reference.currency. Business justification: Relationship managers track AUM in specific currencies for performance measurement and compensation calculations. Critical for portfolio management, revenue attribution, and RM performance reporting i' ;
    rdfs:domain ind:ChannelRelationshipManager ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:primaryChannelEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Channel Employee Id' ;
    rdfs:comment 'Human Capital Management system employee identifier for the relationship manager. Links to HR system of record.' ;
    rdfs:domain ind:ChannelRelationshipManager ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assignedBranchCode rdf:type rdf:Property ;
    rdfs:label 'Assigned Branch Code' ;
    rdfs:comment 'Branch or office location code where the relationship manager is primarily based. May be null for virtual or regional coverage models.' ;
    rdfs:domain ind:ChannelRelationshipManager ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aumUnderManagement rdf:type rdf:Property ;
    rdfs:label 'Aum Under Management' ;
    rdfs:comment 'Total assets under management attributed to this relationship manager, measured in the banks reporting currency. Updated periodically from portfolio valuation systems.' ;
    rdfs:domain ind:ChannelRelationshipManager ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificationList rdf:type rdf:Property ;
    rdfs:label 'Certification List' ;
    rdfs:comment 'Comma-separated list of professional certifications held by the relationship manager (e.g., CFA, CFP, CPA, MBA). Used for client matching and regulatory compliance.' ;
    rdfs:domain ind:ChannelRelationshipManager ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelRelationshipManagerStatus rdf:type rdf:Property ;
    rdfs:label 'Channel Relationship Manager Status' ;
    rdfs:comment 'Current employment and assignment status of the relationship manager. Determines whether the RM is actively managing clients.' ;
    rdfs:domain ind:ChannelRelationshipManager ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientCount rdf:type rdf:Property ;
    rdfs:label 'Client Count' ;
    rdfs:comment 'Total number of active clients assigned to this relationship manager as primary or secondary coverage.' ;
    rdfs:domain ind:ChannelRelationshipManager ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:compensationGrade rdf:type rdf:Property ;
    rdfs:label 'Compensation Grade' ;
    rdfs:comment 'Compensation grade or band assigned to the relationship manager. Used for salary benchmarking and equity analysis.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Status' ;
    rdfs:comment 'Current regulatory compliance status of the relationship manager. Indicates whether all required training, licenses, and certifications are current.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageRegion rdf:type rdf:Property ;
    rdfs:label 'Coverage Region' ;
    rdfs:comment 'Geographic region or territory assigned to the relationship manager for client coverage (e.g., Northeast, EMEA, Asia-Pacific, North America).' ;
    rdfs:domain ind:ChannelRelationshipManager ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fullName rdf:type rdf:Property ;
    rdfs:label 'Full Name' ;
    rdfs:comment 'Full legal name of the relationship manager as recorded in the HR system.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incentiveEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Incentive Eligible Flag' ;
    rdfs:comment 'Indicates whether the relationship manager is eligible for performance-based incentive compensation. True if eligible, False otherwise.' ;
    rdfs:domain ind:ChannelRelationshipManager ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:languageProficiency rdf:type rdf:Property ;
    rdfs:label 'Language Proficiency' ;
    rdfs:comment 'Comma-separated list of languages spoken by the relationship manager with proficiency levels (e.g., English-Native, Spanish-Fluent, Mandarin-Conversational). Used for client matching.' ;
    rdfs:domain ind:ChannelRelationshipManager ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastComplianceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Compliance Review Date' ;
    rdfs:comment 'Date of the most recent compliance review or audit for this relationship manager. Used to track regulatory adherence and training currency.' ;
    rdfs:domain ind:ChannelRelationshipManager ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licensedProducts rdf:type rdf:Property ;
    rdfs:label 'Licensed Products' ;
    rdfs:comment 'Comma-separated list of financial licenses and product authorizations held by the RM (e.g., Series 7, Series 65, insurance, derivatives, structured products).' ;
    rdfs:domain ind:ChannelRelationshipManager ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lobAssignment rdf:type rdf:Property ;
    rdfs:label 'Lob Assignment' ;
    rdfs:comment 'Primary line of business to which the relationship manager is assigned. Determines product authority and client segmentation.' ;
    rdfs:domain ind:ChannelRelationshipManager ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextReviewDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Review Due Date' ;
    rdfs:comment 'Scheduled date for the next compliance review or performance evaluation. Used for proactive compliance management.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:portfolioTier rdf:type rdf:Property ;
    rdfs:label 'Portfolio Tier' ;
    rdfs:comment 'Client portfolio tier classification indicating the seniority and complexity of clients managed by this RM.' ;
    rdfs:domain ind:ChannelRelationshipManager ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueTarget rdf:type rdf:Property ;
    rdfs:label 'Revenue Target' ;
    rdfs:comment 'Annual revenue target assigned to the relationship manager, measured in the banks reporting currency. Used for performance evaluation and compensation planning.' ;
    rdfs:domain ind:ChannelRelationshipManager ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:specialization rdf:type rdf:Property ;
    rdfs:label 'Specialization' ;
    rdfs:comment 'Industry sectors or client types in which the relationship manager has specialized expertise (e.g., healthcare, technology, real estate, family offices).' ;
    rdfs:domain ind:ChannelRelationshipManager ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rmClientAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Rm Client Assignment Id' ;
    rdfs:comment 'Unique identifier for the relationship manager client assignment record.' ;
    rdfs:domain ind:RmClientAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:orgUnitId rdf:type rdf:Property ;
    rdfs:label 'Org Unit Id' ;
    rdfs:comment 'Identifier of the RM team or group responsible for this client assignment. Used for team-based service models.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:primarySuccessorRmChannelRelationshipManagerId rdf:type rdf:Property ;
    rdfs:label 'Primary Successor Rm Channel Relationship Manager Id' ;
    rdfs:comment 'Identifier of the next relationship manager who will serve this client after the current assignment ends. Used for planned transitions and coverage continuity.' ;
    rdfs:domain ind:RmClientAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ChannelRelationshipManager .

ind:tertiaryRmChannelRelationshipManagerId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Rm Channel Relationship Manager Id' ;
    rdfs:comment 'Identifier of the previous relationship manager who served this client before the current assignment. Used to track RM succession and handoff history.' ;
    rdfs:domain ind:RmClientAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ChannelRelationshipManager .

ind:assignmentApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Assignment Approval Date' ;
    rdfs:comment 'Date when this RM-client assignment was formally approved by management or compliance. Used for governance and audit trail.' ;
    rdfs:domain ind:RmClientAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignmentChannel rdf:type rdf:Property ;
    rdfs:label 'Assignment Channel' ;
    rdfs:comment 'Primary channel through which the RM-client relationship is managed and serviced. Indicates the dominant interaction mode.' ;
    rdfs:domain ind:RmClientAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assignment Created Timestamp' ;
    rdfs:comment 'Timestamp when this RM-client assignment record was first created in the system. Used for audit trail and data lineage.' ;
    rdfs:domain ind:RmClientAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assignmentModifiedBy rdf:type rdf:Property ;
    rdfs:label 'Assignment Modified By' ;
    rdfs:comment 'User ID or system identifier of the person or process that last modified this assignment record. Used for audit trail and accountability.' ;
    rdfs:domain ind:RmClientAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assignment Modified Timestamp' ;
    rdfs:comment 'Timestamp when this RM-client assignment record was last modified or updated. Used for change tracking and audit trail.' ;
    rdfs:domain ind:RmClientAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assignmentSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Assignment Source System' ;
    rdfs:comment 'Name or code of the source system that originated this RM-client assignment record. Used for data lineage and reconciliation.' ;
    rdfs:domain ind:RmClientAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aumAtAssignment rdf:type rdf:Property ;
    rdfs:label 'Aum At Assignment' ;
    rdfs:comment 'Total assets under management for the client at the time of RM assignment. Snapshot value used for performance tracking and portfolio sizing.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clientSatisfactionScore rdf:type rdf:Property ;
    rdfs:label 'Client Satisfaction Score' ;
    rdfs:comment 'Most recent client satisfaction or Net Promoter Score (NPS) for this RM-client relationship. Used for relationship quality monitoring and RM performance evaluation.' ;
    rdfs:domain ind:RmClientAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clientTenureMonths rdf:type rdf:Property ;
    rdfs:label 'Client Tenure Months' ;
    rdfs:comment 'Number of months the client has been with the institution at the time of this assignment. Used for client lifecycle analysis and relationship maturity assessment.' ;
    rdfs:domain ind:RmClientAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:conflictOfInterestFlag rdf:type rdf:Property ;
    rdfs:label 'Conflict Of Interest Flag' ;
    rdfs:comment 'Boolean flag indicating whether a potential conflict of interest has been identified for this RM-client assignment. Used for compliance monitoring and risk management.' ;
    rdfs:domain ind:RmClientAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crossSellOpportunities rdf:type rdf:Property ;
    rdfs:label 'Cross Sell Opportunities' ;
    rdfs:comment 'Number of identified cross-sell or product expansion opportunities for this client under the current RM assignment. Used for revenue growth planning and RM performance tracking.' ;
    rdfs:domain ind:RmClientAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:handoffNotes rdf:type rdf:Property ;
    rdfs:label 'Handoff Notes' ;
    rdfs:comment 'Free-text notes documenting client context, preferences, history, and important information for RM transitions or coverage continuity. Critical for maintaining service quality during reassignments.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPrimaryRm rdf:type rdf:Property ;
    rdfs:label 'Is Primary Rm' ;
    rdfs:comment 'Boolean flag indicating whether this RM is the primary relationship manager for the client. True if primary, false if secondary or coverage role.' ;
    rdfs:domain ind:RmClientAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastContactDate rdf:type rdf:Property ;
    rdfs:label 'Last Contact Date' ;
    rdfs:comment 'Date of the most recent interaction or contact between the RM and the client. Used for relationship activity tracking and engagement monitoring.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:portfolioSegment rdf:type rdf:Property ;
    rdfs:label 'Portfolio Segment' ;
    rdfs:comment 'Client wealth or business segment classification for this assignment. Used for portfolio management and service level differentiation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Record Expiration Date' ;
    rdfs:comment 'Date when this version of the assignment record expired or was superseded by a new version. Null for current active records. Used for slowly changing dimension (SCD) Type 2 history tracking.' ;
    rdfs:domain ind:RmClientAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:relationshipHealthScore rdf:type rdf:Property ;
    rdfs:label 'Relationship Health Score' ;
    rdfs:comment 'Composite score measuring the overall health and strength of the RM-client relationship. Calculated from engagement metrics, satisfaction scores, revenue trends, and other relationship indicators.' ;
    rdfs:domain ind:RmClientAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueAttributed rdf:type rdf:Property ;
    rdfs:label 'Revenue Attributed' ;
    rdfs:comment 'Total revenue attributed to this RM-client relationship during the assignment period. Used for RM performance measurement and compensation calculations.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceModel rdf:type rdf:Property ;
    rdfs:label 'Service Model' ;
    rdfs:comment 'Service delivery model applied to this RM-client relationship. Defines how the RM interacts with and serves the client.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTargetResponseHours rdf:type rdf:Property ;
    rdfs:label 'Sla Target Response Hours' ;
    rdfs:comment 'Target number of hours for RM response to client inquiries or requests as defined by the service level agreement for this client segment.' ;
    rdfs:domain ind:RmClientAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicationVersion rdf:type rdf:Property ;
    rdfs:label 'Application Version' ;
    rdfs:comment 'Version number of the mobile or desktop application used for the session. Null for web browser sessions.' ;
    rdfs:domain ind:Session ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authenticationLevel rdf:type rdf:Property ;
    rdfs:label 'Authentication Level' ;
    rdfs:comment 'Strength level of authentication applied, aligned with regulatory requirements for customer due diligence and transaction authorization.' ;
    rdfs:domain ind:Session ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:browserName rdf:type rdf:Property ;
    rdfs:label 'Browser Name' ;
    rdfs:comment 'Name of the web browser used for the session (e.g., Chrome, Safari, Firefox, Edge). Null for non-browser channels.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:browserVersion rdf:type rdf:Property ;
    rdfs:label 'Browser Version' ;
    rdfs:comment 'Version number of the web browser used for the session. Null for non-browser channels.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceFingerprint rdf:type rdf:Property ;
    rdfs:label 'Device Fingerprint' ;
    rdfs:comment 'Unique identifier or hash representing the device characteristics used to access the session. Used for fraud detection and device recognition.' ;
    rdfs:domain ind:Session ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exitPageUrl rdf:type rdf:Property ;
    rdfs:label 'Exit Page Url' ;
    rdfs:comment 'URL of the last page or screen accessed before the session was terminated.' ;
    rdfs:domain ind:Session ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudRiskScore rdf:type rdf:Property ;
    rdfs:label 'Fraud Risk Score' ;
    rdfs:comment 'Real-time fraud risk score assigned to the session based on behavioral analytics, device fingerprinting, and transaction patterns. Scale 0-100, higher indicates greater risk.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geolocationCountryCode rdf:type rdf:Property ;
    rdfs:label 'Geolocation Country Code' ;
    rdfs:comment 'Three-letter ISO country code representing the geographic origin of the session.' ;
    rdfs:domain ind:Session ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:landingPageUrl rdf:type rdf:Property ;
    rdfs:label 'Landing Page Url' ;
    rdfs:comment 'URL of the first page or screen accessed in the session.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languagePreference rdf:type rdf:Property ;
    rdfs:label 'Language Preference' ;
    rdfs:comment 'Two-letter ISO language code representing the customer\'s preferred language for the session interface.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingSystem rdf:type rdf:Property ;
    rdfs:label 'Operating System' ;
    rdfs:comment 'Operating system of the device used during the session (e.g., iOS, Android, Windows, macOS).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pageViewCount rdf:type rdf:Property ;
    rdfs:label 'Page View Count' ;
    rdfs:comment 'Total number of pages or screens viewed during the session. Used for engagement analysis and customer journey mapping.' ;
    rdfs:domain ind:Session ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:referrerUrl rdf:type rdf:Property ;
    rdfs:label 'Referrer Url' ;
    rdfs:comment 'URL of the page or source that referred the customer to initiate the session. Used for marketing attribution and customer journey analysis.' ;
    rdfs:domain ind:Session ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionStatus rdf:type rdf:Property ;
    rdfs:label 'Session Status' ;
    rdfs:comment 'Current lifecycle status of the session.' ;
    rdfs:domain ind:Session ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionType rdf:type rdf:Property ;
    rdfs:label 'Session Type' ;
    rdfs:comment 'Classification of the session based on authentication and interaction mode.' ;
    rdfs:domain ind:Session ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaActualResponseTimeMs rdf:type rdf:Property ;
    rdfs:label 'Sla Actual Response Time Ms' ;
    rdfs:comment 'Actual average response time in milliseconds measured during the session.' ;
    rdfs:domain ind:Session ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaTargetResponseTimeMs rdf:type rdf:Property ;
    rdfs:label 'Sla Target Response Time Ms' ;
    rdfs:comment 'Target response time in milliseconds defined by the SLA for this session type and channel.' ;
    rdfs:domain ind:Session ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:token rdf:type rdf:Property ;
    rdfs:label 'Token' ;
    rdfs:comment 'Unique cryptographic token assigned to the session for authentication and authorization purposes. Used to maintain session state and security.' ;
    rdfs:domain ind:Session ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:userAgent rdf:type rdf:Property ;
    rdfs:label 'User Agent' ;
    rdfs:comment 'Browser or application user agent string identifying the client software, operating system, and device type used to access the session.' ;
    rdfs:domain ind:Session ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaId rdf:type rdf:Property ;
    rdfs:label 'Sla Id' ;
    rdfs:comment 'Primary key for sla' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:channelInteractionId rdf:type rdf:Property ;
    rdfs:label 'Channel Interaction Id' ;
    rdfs:comment 'Reference identifier of the specific customer interaction or transaction that experienced the SLA breach.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Interaction .

ind:slaBreachId rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Id' ;
    rdfs:comment 'Unique identifier for a specific SLA breach instance; null if this record is an SLA definition rather than a breach event.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SlaBreach .

ind:actualResolutionTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Actual Resolution Time Minutes' ;
    rdfs:comment 'Actual time in minutes taken to fully resolve customer interaction; used to compare against target for breach detection.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualResponseTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Actual Response Time Minutes' ;
    rdfs:comment 'Actual time in minutes taken to provide initial response to customer interaction; used to compare against target for breach detection.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:breachPenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Breach Penalty Amount' ;
    rdfs:comment 'Monetary penalty or credit applied to customer or internal cost center as a result of the SLA breach.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:breachPenaltyCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Breach Penalty Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the breach penalty amount.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachSeverity rdf:type rdf:Property ;
    rdfs:label 'Breach Severity' ;
    rdfs:comment 'Severity classification of the SLA breach based on magnitude of delay and customer impact.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerImpactAssessment rdf:type rdf:Property ;
    rdfs:label 'Customer Impact Assessment' ;
    rdfs:comment 'Assessment of the impact of the SLA breach on customer experience, satisfaction, and business relationship.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationThresholdMinutes rdf:type rdf:Property ;
    rdfs:label 'Escalation Threshold Minutes' ;
    rdfs:comment 'Time threshold in minutes after which unresolved interaction must be escalated to higher support tier or management.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:interactionCategory rdf:type rdf:Property ;
    rdfs:label 'Interaction Category' ;
    rdfs:comment 'Category of customer interaction or transaction type covered by this SLA (e.g., account inquiry, loan application, wire transfer, complaint).' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementMethodology rdf:type rdf:Property ;
    rdfs:label 'Measurement Methodology' ;
    rdfs:comment 'Description of how SLA performance is measured and calculated (e.g., business hours vs. calendar hours, start/end event definitions).' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Regulator Case Number' ;
    rdfs:comment 'Case or reference number assigned by the regulatory authority if the breach was escalated or reported.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationActionTaken rdf:type rdf:Property ;
    rdfs:label 'Remediation Action Taken' ;
    rdfs:comment 'Description of corrective or remediation actions taken in response to the SLA breach.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportedToRegulatorFlag rdf:type rdf:Property ;
    rdfs:label 'Reported To Regulator Flag' ;
    rdfs:comment 'Indicates whether this SLA breach was reported to a regulatory authority (CFPB, OCC) as part of compliance reporting.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responsibleChannel rdf:type rdf:Property ;
    rdfs:label 'Responsible Channel' ;
    rdfs:comment 'Name or identifier of the channel or operational unit responsible for the breach.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleTeam rdf:type rdf:Property ;
    rdfs:label 'Responsible Team' ;
    rdfs:comment 'Name or identifier of the team or department responsible for the breach.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaName rdf:type rdf:Property ;
    rdfs:label 'Sla Name' ;
    rdfs:comment 'Business-friendly name of the SLA definition (e.g., \'Mobile Banking Account Inquiry Response Time\', \'Branch Complaint Resolution SLA\').' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaStatus rdf:type rdf:Property ;
    rdfs:label 'Sla Status' ;
    rdfs:comment 'Current lifecycle status of the SLA definition.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetResolutionTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Target Resolution Time Minutes' ;
    rdfs:comment 'Target time in minutes for complete resolution of customer interaction or request.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetResponseTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Target Response Time Minutes' ;
    rdfs:comment 'Target time in minutes for initial response to customer interaction or request.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primarySlaResponsibleEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Sla Responsible Employee Id' ;
    rdfs:comment 'Reference to the employee or relationship manager responsible for handling the interaction that breached the SLA.' ;
    rdfs:domain ind:SlaBreach ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:relatedComplianceComplianceBreachId rdf:type rdf:Property ;
    rdfs:label 'Related Compliance Compliance Breach Id' ;
    rdfs:comment 'Foreign key linking to compliance.breach. Business justification: Channel SLA breaches that violate regulatory commitments (Reg E error resolution timing, complaint response deadlines, accessibility requirements) escalate to compliance breaches. Link enables regulat' ;
    rdfs:domain ind:SlaBreach ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Breach .

ind:actualMetricValue rdf:type rdf:Property ;
    rdfs:label 'Actual Metric Value' ;
    rdfs:comment 'The actual metric value achieved, which exceeded the SLA target (e.g., 45 seconds, 3 hours, 2 business days).' ;
    rdfs:domain ind:SlaBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:channelSlaId rdf:type rdf:Property ;
    rdfs:label 'Channel Sla Id' ;
    rdfs:comment 'Reference to the SLA definition that was breached.' ;
    rdfs:domain ind:SlaBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:compensationAmount rdf:type rdf:Property ;
    rdfs:label 'Compensation Amount' ;
    rdfs:comment 'Monetary value of compensation or credit offered to the customer for the SLA breach.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compensationCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Compensation Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the compensation amount.' ;
    rdfs:domain ind:SlaBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compensationOfferedFlag rdf:type rdf:Property ;
    rdfs:label 'Compensation Offered Flag' ;
    rdfs:comment 'Indicates whether compensation or goodwill gesture was offered to the customer due to the SLA breach.' ;
    rdfs:domain ind:SlaBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerNotificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Timestamp' ;
    rdfs:comment 'The date and time when the customer was notified about the SLA breach.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:customerNotifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Notified Flag' ;
    rdfs:comment 'Indicates whether the customer was notified about the SLA breach.' ;
    rdfs:domain ind:SlaBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deviationPercentage rdf:type rdf:Property ;
    rdfs:label 'Deviation Percentage' ;
    rdfs:comment 'The percentage deviation from the SLA target ((actual - target) / target * 100).' ;
    rdfs:domain ind:SlaBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deviationValue rdf:type rdf:Property ;
    rdfs:label 'Deviation Value' ;
    rdfs:comment 'The magnitude of deviation from the SLA target (actual minus target).' ;
    rdfs:domain ind:SlaBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:metricUnit rdf:type rdf:Property ;
    rdfs:label 'Metric Unit' ;
    rdfs:comment 'Unit of measure for the SLA metric (seconds, minutes, hours, business days, calendar days).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Submission Date' ;
    rdfs:comment 'The date when the regulatory report was submitted.' ;
    rdfs:domain ind:SlaBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remediationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Remediation Timestamp' ;
    rdfs:comment 'The date and time when remediation action was completed.' ;
    rdfs:domain ind:SlaBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:targetMetricValue rdf:type rdf:Property ;
    rdfs:label 'Target Metric Value' ;
    rdfs:comment 'The SLA target metric value that was expected to be met (e.g., 30 seconds, 2 hours, 1 business day).' ;
    rdfs:domain ind:SlaBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:instrumentClassificationId rdf:type rdf:Property ;
    rdfs:label 'Instrument Classification Id' ;
    rdfs:comment 'Foreign key linking to reference.instrument_classification. Business justification: Asset type and subtype should reference classification master for regulatory capital treatment, HQLA classification, and risk weighting. Creating new instrument_classification_id FK.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InstrumentClassification .

ind:issuerIndustryCodeId rdf:type rdf:Property ;
    rdfs:label 'Issuer Industry Code Id' ;
    rdfs:comment 'Foreign key linking to reference.industry_code. Business justification: For equity collateral, issuer industry classification is critical for concentration limit monitoring and sector risk management. Creating new issuer_industry_code_id FK.' ;
    rdfs:domain ind:CollateralAsset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IndustryCode .

ind:jurisdictionCountryId rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Country Id' ;
    rdfs:comment 'Foreign key linking to reference.country. Business justification: Jurisdiction determines legal perfection, enforcement, and Basel sovereign risk weights. Required for sanctions screening and regulatory capital treatment. Creating jurisdiction_country_id FK to repla' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:marketDataSourceId rdf:type rdf:Property ;
    rdfs:label 'Market Data Source Id' ;
    rdfs:comment 'Source of the valuation data (e.g., Bloomberg, Reuters, independent appraiser, internal model).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MarketDataSource .

ind:ownerPartyId rdf:type rdf:Property ;
    rdfs:label 'Owner Party Id' ;
    rdfs:comment 'Foreign key linking to customer.party. Business justification: Asset ownership tracking is fundamental for collateral perfection, lien priority determination, regulatory capital treatment (Basel III), and legal enforceability. Banking operations require definitiv' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:assetStatus rdf:type rdf:Property ;
    rdfs:label 'Asset Status' ;
    rdfs:comment 'Current lifecycle status of the collateral asset indicating its availability and encumbrance state. [ENUM-REF-CANDIDATE: eligible|pledged|released|ineligible|under_review|restricted|substituted — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CollateralAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetType rdf:type rdf:Property ;
    rdfs:label 'Asset Type' ;
    rdfs:comment 'Classification of the collateral asset by type. Determines eligibility rules, haircut schedules, and valuation methodology. [ENUM-REF-CANDIDATE: real_estate|securities|cash|commodities|receivables|letter_of_credit|bank_guarantee|inventory|equipment|other — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Collateral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Basel Eligible Flag' ;
    rdfs:comment 'Indicates whether the collateral asset qualifies as eligible collateral under Basel III capital and liquidity frameworks.' ;
    rdfs:domain ind:CollateralAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:collateralValue rdf:type rdf:Property ;
    rdfs:label 'Collateral Value' ;
    rdfs:comment 'Net collateral value after applying haircut to the market value. This is the value available for margin and credit risk mitigation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:concentrationLimitFlag rdf:type rdf:Property ;
    rdfs:label 'Concentration Limit Flag' ;
    rdfs:comment 'Indicates whether the collateral asset is subject to concentration limits under Basel III or internal risk policy.' ;
    rdfs:domain ind:CollateralAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditRating rdf:type rdf:Property ;
    rdfs:label 'Credit Rating' ;
    rdfs:comment 'External credit rating assigned to the collateral asset by a recognized rating agency. Used for eligibility determination and haircut calculation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:custodyLocation rdf:type rdf:Property ;
    rdfs:label 'Custody Location' ;
    rdfs:comment 'Physical or electronic location where the collateral asset is held (custodian name, vault location, depository, or registry).' ;
    rdfs:domain ind:CollateralAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Eligibility Flag' ;
    rdfs:comment 'Boolean indicator of whether the collateral asset meets the banks eligibility criteria for acceptance under Basel III, EMIR, and internal credit policy.' ;
    rdfs:domain ind:CollateralAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:emirEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Emir Eligible Flag' ;
    rdfs:comment 'Indicates whether the collateral asset meets EMIR eligibility requirements for central clearing and bilateral margin.' ;
    rdfs:domain ind:CollateralAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:encumbranceStatus rdf:type rdf:Property ;
    rdfs:label 'Encumbrance Status' ;
    rdfs:comment 'Indicates whether the collateral asset is free of liens or has existing encumbrances that affect its availability for pledging.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:haircutPercentage rdf:type rdf:Property ;
    rdfs:label 'Haircut Percentage' ;
    rdfs:comment 'Percentage discount applied to the market value of the collateral asset to determine its collateral value. Reflects credit risk, market risk, and liquidity risk.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hqlaClassification rdf:type rdf:Property ;
    rdfs:label 'Hqla Classification' ;
    rdfs:comment 'Classification of the collateral asset under Basel III Liquidity Coverage Ratio (LCR) framework as Level 1, Level 2A, Level 2B, or non-HQLA.' ;
    rdfs:domain ind:Collateral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalRating rdf:type rdf:Property ;
    rdfs:label 'Internal Rating' ;
    rdfs:comment 'Internal credit rating assigned to the collateral asset under the banks Internal Ratings-Based (IRB) approach.' ;
    rdfs:domain ind:CollateralAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalDescription rdf:type rdf:Property ;
    rdfs:label 'Legal Description' ;
    rdfs:comment 'Formal legal description of the collateral asset as documented in legal agreements, deeds, or certificates. Includes property descriptions, security identifiers (ISIN, CUSIP), or instrument details.' ;
    rdfs:domain ind:CollateralAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lienPosition rdf:type rdf:Property ;
    rdfs:label 'Lien Position' ;
    rdfs:comment 'Priority ranking of the banks security interest in the collateral asset relative to other creditors. Critical for Loss Given Default (LGD) calculations.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketValue rdf:type rdf:Property ;
    rdfs:label 'Market Value' ;
    rdfs:comment 'Current market value of the collateral asset in the reporting currency. Updated based on mark-to-market (MTM) or appraisal.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pledgedDate rdf:type rdf:Property ;
    rdfs:label 'Pledged Date' ;
    rdfs:comment 'Date on which the collateral asset was pledged to the bank or counterparty under a collateral agreement.' ;
    rdfs:domain ind:CollateralAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ratingAgency rdf:type rdf:Property ;
    rdfs:label 'Rating Agency' ;
    rdfs:comment 'Name of the external credit rating agency providing the credit rating for the collateral asset (e.g., Moodys, S&P, Fitch).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rehypothecationAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Rehypothecation Allowed Flag' ;
    rdfs:comment 'Indicates whether the bank is permitted to rehypothecate (re-pledge) the collateral asset to third parties under the collateral agreement terms.' ;
    rdfs:domain ind:Collateral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:releaseDate rdf:type rdf:Property ;
    rdfs:label 'Release Date' ;
    rdfs:comment 'Date on which the collateral asset was released from pledge and returned to the owner. Null if currently pledged.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:riskWeightPercentage rdf:type rdf:Property ;
    rdfs:label 'Risk Weight Percentage' ;
    rdfs:comment 'Risk weight percentage applied to the collateral asset for Risk-Weighted Assets (RWA) calculation under Basel III.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:substitutionAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Substitution Allowed Flag' ;
    rdfs:comment 'Indicates whether the collateral asset can be substituted with another eligible asset under the terms of the collateral agreement.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:valuationMethod rdf:type rdf:Property ;
    rdfs:label 'Valuation Method' ;
    rdfs:comment 'Methodology used to determine the market value of the collateral asset (e.g., mark-to-market for securities, appraisal for real estate).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optimizationId rdf:type rdf:Property ;
    rdfs:label 'Optimization Id' ;
    rdfs:comment 'Unique identifier for the collateral optimization allocation record.' ;
    rdfs:domain ind:Optimization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:custodianPartyId rdf:type rdf:Property ;
    rdfs:label 'Custodian Party Id' ;
    rdfs:comment 'Reference to the custodian or third-party agent holding the allocated collateral on behalf of the secured party.' ;
    rdfs:domain ind:Collateral ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:haircutScheduleId rdf:type rdf:Property ;
    rdfs:label 'Haircut Schedule Id' ;
    rdfs:comment 'Foreign key linking to collateral.haircut_schedule. Business justification: Optimization decisions apply haircut schedules to calculate net collateral value. The optimization product currently has haircut_percentage as a denormalized value. Adding haircut_schedule_id FK allow' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HaircutSchedule .

ind:marginAgreementId rdf:type rdf:Property ;
    rdfs:label 'Margin Agreement Id' ;
    rdfs:comment 'Reference to the ISDA CSA agreement governing this collateral allocation, if applicable to derivatives margin.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MarginAgreement .

ind:obligationId rdf:type rdf:Property ;
    rdfs:label 'Obligation Id' ;
    rdfs:comment 'Reference to the specific obligation (margin agreement, pledge, repo transaction) that this collateral allocation satisfies.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Obligation .

ind:allocatedHaircutValue rdf:type rdf:Property ;
    rdfs:label 'Allocated Haircut Value' ;
    rdfs:comment 'Eligible collateral value after applying the haircut, representing the net contribution to the obligation coverage.' ;
    rdfs:domain ind:Optimization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocatedMarketValue rdf:type rdf:Property ;
    rdfs:label 'Allocated Market Value' ;
    rdfs:comment 'Market value of the allocated collateral quantity at the time of allocation, before haircut application.' ;
    rdfs:domain ind:Optimization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationCost rdf:type rdf:Property ;
    rdfs:label 'Allocation Cost' ;
    rdfs:comment 'Estimated cost of allocating this collateral, including opportunity cost, funding cost, and operational cost.' ;
    rdfs:domain ind:Optimization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationCostCurrency rdf:type rdf:Property ;
    rdfs:label 'Allocation Cost Currency' ;
    rdfs:comment 'Three-letter ISO currency code for the allocation cost.' ;
    rdfs:domain ind:Optimization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Allocation Effective Date' ;
    rdfs:comment 'Date on which this collateral allocation becomes effective and the collateral is legally pledged or transferred.' ;
    rdfs:domain ind:Optimization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allocationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Allocation Expiry Date' ;
    rdfs:comment 'Date on which this collateral allocation expires or is scheduled for release, if applicable.' ;
    rdfs:domain ind:Optimization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allocationNotes rdf:type rdf:Property ;
    rdfs:label 'Allocation Notes' ;
    rdfs:comment 'Free-text notes or comments regarding this specific collateral allocation decision, including any exceptions or special conditions.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationPriorityRank rdf:type rdf:Property ;
    rdfs:label 'Allocation Priority Rank' ;
    rdfs:comment 'Priority ranking assigned by the optimization algorithm, with lower numbers indicating higher priority for allocation.' ;
    rdfs:domain ind:Optimization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocationQuantity rdf:type rdf:Property ;
    rdfs:label 'Allocation Quantity' ;
    rdfs:comment 'Quantity of the collateral asset allocated to satisfy the obligation, expressed in the asset\'s native unit of measure.' ;
    rdfs:domain ind:Optimization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationSequence rdf:type rdf:Property ;
    rdfs:label 'Allocation Sequence' ;
    rdfs:comment 'Sequential order of this allocation within the optimization run, indicating priority ranking.' ;
    rdfs:domain ind:Optimization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocationStatus rdf:type rdf:Property ;
    rdfs:label 'Allocation Status' ;
    rdfs:comment 'Current status of this allocation decision in the collateral management workflow.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Allocation Timestamp' ;
    rdfs:comment 'Date and time when this allocation decision was made by the optimization engine.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:allocationUnit rdf:type rdf:Property ;
    rdfs:label 'Allocation Unit' ;
    rdfs:comment 'Unit of measure for the allocated quantity (shares for equities, nominal value for bonds, troy ounces for gold, etc.). [ENUM-REF-CANDIDATE: shares|units|nominal_value|face_value|troy_ounces|kilograms|contracts — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Optimization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:concentrationLimitBreachFlag rdf:type rdf:Property ;
    rdfs:label 'Concentration Limit Breach Flag' ;
    rdfs:comment 'Indicates whether this allocation breaches concentration limits defined in the CSA or internal risk policy.' ;
    rdfs:domain ind:Collateral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fundingCost rdf:type rdf:Property ;
    rdfs:label 'Funding Cost' ;
    rdfs:comment 'Funding cost associated with holding or acquiring this collateral for allocation purposes.' ;
    rdfs:domain ind:Optimization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hqlaCategory rdf:type rdf:Property ;
    rdfs:label 'Hqla Category' ;
    rdfs:comment 'Classification of the allocated collateral under Basel III HQLA categories (Level 1, Level 2A, Level 2B, or non-HQLA).' ;
    rdfs:domain ind:Optimization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hqlaEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Hqla Eligible Flag' ;
    rdfs:comment 'Indicates whether this allocation satisfies a regulatory High-Quality Liquid Asset (HQLA) requirement under Basel III Liquidity Coverage Ratio (LCR) rules.' ;
    rdfs:domain ind:Optimization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:initialMarginFlag rdf:type rdf:Property ;
    rdfs:label 'Initial Margin Flag' ;
    rdfs:comment 'Indicates whether this allocation satisfies an initial margin requirement under derivatives margin rules.' ;
    rdfs:domain ind:Optimization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netCollateralContribution rdf:type rdf:Property ;
    rdfs:label 'Net Collateral Contribution' ;
    rdfs:comment 'Net value contributed by this allocation toward satisfying the obligation requirement, after all adjustments including haircut and concentration limits.' ;
    rdfs:domain ind:Optimization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:opportunityCost rdf:type rdf:Property ;
    rdfs:label 'Opportunity Cost' ;
    rdfs:comment 'Opportunity cost of allocating this collateral asset instead of using it for alternative purposes or investments.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:optimizationRunCode rdf:type rdf:Property ;
    rdfs:label 'Optimization Run Code' ;
    rdfs:comment 'Reference to the parent optimization run that generated this allocation decision.' ;
    rdfs:domain ind:Optimization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryCapitalReliefAmount rdf:type rdf:Property ;
    rdfs:label 'Regulatory Capital Relief Amount' ;
    rdfs:comment 'Amount of regulatory capital relief obtained through this collateral allocation under Basel III rules.' ;
    rdfs:domain ind:Collateral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:repoEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Repo Eligible Flag' ;
    rdfs:comment 'Indicates whether this allocation is eligible for use in repurchase (repo) or reverse repo transactions.' ;
    rdfs:domain ind:Optimization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rwaReductionAmount rdf:type rdf:Property ;
    rdfs:label 'Rwa Reduction Amount' ;
    rdfs:comment 'Reduction in Risk-Weighted Assets (RWA) achieved through this collateral allocation under Basel III capital rules.' ;
    rdfs:domain ind:Collateral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:score rdf:type rdf:Property ;
    rdfs:label 'Score' ;
    rdfs:comment 'Numerical score assigned by the optimization algorithm reflecting the efficiency and cost-effectiveness of this allocation decision.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:substitutionEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Substitution Eligible Flag' ;
    rdfs:comment 'Indicates whether this allocated collateral is eligible for substitution under the governing agreement terms.' ;
    rdfs:domain ind:Optimization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:variationMarginFlag rdf:type rdf:Property ;
    rdfs:label 'Variation Margin Flag' ;
    rdfs:comment 'Indicates whether this allocation satisfies a variation margin requirement under derivatives margin rules.' ;
    rdfs:domain ind:Optimization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:collateralPositionId rdf:type rdf:Property ;
    rdfs:label 'Collateral Position Id' ;
    rdfs:comment 'Unique identifier for the collateral position record. Primary key for this entity.' ;
    rdfs:domain ind:CollateralPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryCollateralPartyId rdf:type rdf:Property ;
    rdfs:label 'Primary Collateral Party Id' ;
    rdfs:comment 'Reference to the custodian bank or depository institution holding the physical or book-entry collateral asset.' ;
    rdfs:domain ind:CollateralPosition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:collateralPostedValue rdf:type rdf:Property ;
    rdfs:label 'Collateral Posted Value' ;
    rdfs:comment 'The total haircut-adjusted value of collateral already posted to the counterparty as of the position date. Applicable to exposure-type positions.' ;
    rdfs:domain ind:CollateralPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collateralReceivedValue rdf:type rdf:Property ;
    rdfs:label 'Collateral Received Value' ;
    rdfs:comment 'The total haircut-adjusted value of collateral received from the counterparty as of the position date. Applicable to exposure-type positions.' ;
    rdfs:domain ind:CollateralPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:concentrationLimitBreach rdf:type rdf:Property ;
    rdfs:label 'Concentration Limit Breach' ;
    rdfs:comment 'Boolean flag indicating whether this collateral position breaches concentration limits defined in the collateral agreement (e.g., maximum percentage of a single issuer or asset class).' ;
    rdfs:domain ind:Collateral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditValuationAdjustment rdf:type rdf:Property ;
    rdfs:label 'Credit Valuation Adjustment' ;
    rdfs:comment 'The adjustment to the fair value of derivative positions to account for counterparty credit risk. Represents the market value of counterparty default risk. Applicable to exposure-type positions.' ;
    rdfs:domain ind:CollateralPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eligibilityStatus rdf:type rdf:Property ;
    rdfs:label 'Eligibility Status' ;
    rdfs:comment 'Indicates whether the collateral asset meets the eligibility criteria defined in the collateral agreement or regulatory framework: eligible (accepted), ineligible (rejected), restricted (conditionally accepted), pending_review (under evaluation).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exposureDate rdf:type rdf:Property ;
    rdfs:label 'Exposure Date' ;
    rdfs:comment 'For exposure-type positions, the date on which the counterparty credit exposure was calculated. Typically aligns with position_date but may differ for forward-looking exposure calculations.' ;
    rdfs:domain ind:Collateral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:faceValue rdf:type rdf:Property ;
    rdfs:label 'Face Value' ;
    rdfs:comment 'The nominal or par value of the collateral asset at issuance or contract inception, expressed in the asset\'s denomination currency.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossNegativeExposure rdf:type rdf:Property ;
    rdfs:label 'Gross Negative Exposure' ;
    rdfs:comment 'The total mark-to-market value of all derivative and repo positions with the counterparty where the bank owes money, before netting or collateral offsets. Applicable to exposure-type positions.' ;
    rdfs:domain ind:CollateralPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossPositiveExposure rdf:type rdf:Property ;
    rdfs:label 'Gross Positive Exposure' ;
    rdfs:comment 'The total mark-to-market value of all derivative and repo positions with the counterparty where the bank is owed money, before netting or collateral offsets. Applicable to exposure-type positions.' ;
    rdfs:domain ind:CollateralPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:haircutValue rdf:type rdf:Property ;
    rdfs:label 'Haircut Value' ;
    rdfs:comment 'The collateral value after applying the haircut percentage. Calculated as market_value * (1 - haircut_percentage). This is the risk-adjusted collateral value recognized for margin and capital purposes.' ;
    rdfs:domain ind:CollateralPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:independentAmount rdf:type rdf:Property ;
    rdfs:label 'Independent Amount' ;
    rdfs:comment 'An additional fixed or formula-based collateral amount required by one party regardless of current exposure, often used to cover potential future exposure or as initial margin. Applicable to exposure-type positions.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:initialMargin rdf:type rdf:Property ;
    rdfs:label 'Initial Margin' ;
    rdfs:comment 'The upfront collateral required to cover potential future exposure over the margin period of risk, calculated using regulatory models (SIMM, grid-based) or internal models. Applicable to non-centrally cleared derivatives under margin reform rules.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netCollateralValue rdf:type rdf:Property ;
    rdfs:label 'Net Collateral Value' ;
    rdfs:comment 'The net value of collateral available after haircuts, accrued interest, fees, and any other adjustments. This is the effective collateral coverage amount.' ;
    rdfs:domain ind:Collateral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netCurrentExposure rdf:type rdf:Property ;
    rdfs:label 'Net Current Exposure' ;
    rdfs:comment 'The net mark-to-market exposure after bilateral netting under a qualifying master netting agreement (e.g., ISDA Master Agreement). Calculated as max(GPE - GNE, 0). Applicable to exposure-type positions.' ;
    rdfs:domain ind:CollateralPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netMarginRequirement rdf:type rdf:Property ;
    rdfs:label 'Net Margin Requirement' ;
    rdfs:comment 'The net amount of additional collateral required (positive) or excess collateral available for return (negative) after considering threshold, MTA, independent amount, and collateral already posted/received. Applicable to exposure-type positions.' ;
    rdfs:domain ind:Collateral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:positionDate rdf:type rdf:Property ;
    rdfs:label 'Position Date' ;
    rdfs:comment 'The business date for which this collateral position snapshot is recorded. Represents the valuation date for inventory and exposure calculations.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:positionType rdf:type rdf:Property ;
    rdfs:label 'Position Type' ;
    rdfs:comment 'Classification of the collateral position: held (owned but not pledged), posted (delivered to counterparty), received (accepted from counterparty), pledged (committed but not yet delivered), rehypothecated (received collateral reused), or exposure (calculated margin requirement record).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:potentialFutureExposure rdf:type rdf:Property ;
    rdfs:label 'Potential Future Exposure' ;
    rdfs:comment 'An estimate of the maximum exposure that could arise in the future due to market movements, calculated using regulatory or internal models. Used for capital and margin calculations. Applicable to exposure-type positions.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rehypothecationAllowed rdf:type rdf:Property ;
    rdfs:label 'Rehypothecation Allowed' ;
    rdfs:comment 'Boolean flag indicating whether the collateral receiver is permitted to rehypothecate (reuse) the received collateral under the terms of the collateral agreement.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riskWeightedAssets rdf:type rdf:Property ;
    rdfs:label 'Risk Weighted Assets' ;
    rdfs:comment 'The regulatory capital requirement for this collateral position, calculated by applying risk weights to the exposure amount under Basel III standardized or internal ratings-based approaches. Applicable to exposure-type positions.' ;
    rdfs:domain ind:CollateralPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:substitutionRightExercised rdf:type rdf:Property ;
    rdfs:label 'Substitution Right Exercised' ;
    rdfs:comment 'Boolean flag indicating whether the collateral provider has exercised their right to substitute this collateral asset with another eligible asset under the terms of the CSA.' ;
    rdfs:domain ind:CollateralPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:thresholdBreachAmount rdf:type rdf:Property ;
    rdfs:label 'Threshold Breach Amount' ;
    rdfs:comment 'The amount by which the net current exposure exceeds the threshold amount, triggering a margin call requirement. Calculated as max(NCE - threshold_amount, 0). Applicable to exposure-type positions.' ;
    rdfs:domain ind:Collateral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:variationMargin rdf:type rdf:Property ;
    rdfs:label 'Variation Margin' ;
    rdfs:comment 'The collateral exchanged daily to reflect changes in the mark-to-market value of derivative positions. Represents the current exposure component of margin. Applicable to exposure-type positions.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reviewId rdf:type rdf:Property ;
    rdfs:label 'Review Id' ;
    rdfs:comment 'Unique identifier for the collateral review event. Primary key for the collateral review record.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Review .

ind:approverEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Approver Employee Id' ;
    rdfs:comment 'Reference to the senior credit officer or risk manager who approved the review. Identifies the authority who validated the review findings.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:reviewEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Review Employee Id' ;
    rdfs:comment 'Reference to the credit officer or risk analyst who conducted the review. Identifies the responsible party for the review assessment.' ;
    rdfs:domain ind:Review ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:reviewObligorPartyId rdf:type rdf:Property ;
    rdfs:label 'Review Obligor Party Id' ;
    rdfs:comment 'Reference to the borrower or counterparty whose obligation is secured by the collateral. Identifies the party whose credit exposure is being reviewed.' ;
    rdfs:domain ind:Review ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:reviewSecuredPartyId rdf:type rdf:Property ;
    rdfs:label 'Review Secured Party Id' ;
    rdfs:comment 'Reference to the lender or secured party holding the collateral interest. Identifies the bank or entity whose interest is protected by the collateral.' ;
    rdfs:domain ind:Review ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:actionRationale rdf:type rdf:Property ;
    rdfs:label 'Action Rationale' ;
    rdfs:comment 'Detailed explanation of the rationale for the recommended action. Captures the credit risk assessment and business justification for the proposed remediation.' ;
    rdfs:domain ind:Review ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualCollateralCoverageRatio rdf:type rdf:Property ;
    rdfs:label 'Actual Collateral Coverage Ratio' ;
    rdfs:comment 'Actual collateral coverage ratio calculated at the time of review. Represents the eligible collateral value divided by the outstanding exposure, expressed as a percentage.' ;
    rdfs:domain ind:Review ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collateralCurrency rdf:type rdf:Property ;
    rdfs:label 'Collateral Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the collateral valuation. Identifies the denomination currency of the collateral asset value.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collateralMarketValue rdf:type rdf:Property ;
    rdfs:label 'Collateral Market Value' ;
    rdfs:comment 'Current market value of the collateral asset at the time of review. Represents the fair market value before application of haircuts.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:covenantComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Covenant Compliance Flag' ;
    rdfs:comment 'Indicates whether the collateral coverage meets all covenant requirements at the time of review. True if compliant, false if in breach.' ;
    rdfs:domain ind:Review ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coverageExcessAmount rdf:type rdf:Property ;
    rdfs:label 'Coverage Excess Amount' ;
    rdfs:comment 'Amount by which the actual collateral coverage exceeds the required coverage. Represents the surplus collateral value that may be eligible for release or substitution.' ;
    rdfs:domain ind:Collateral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coverageShortfallAmount rdf:type rdf:Property ;
    rdfs:label 'Coverage Shortfall Amount' ;
    rdfs:comment 'Amount by which the actual collateral coverage falls short of the required coverage. Represents the additional collateral value needed to meet covenant requirements.' ;
    rdfs:domain ind:Collateral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:department rdf:type rdf:Property ;
    rdfs:label 'Department' ;
    rdfs:comment 'Department or business unit responsible for conducting the review. Identifies the organizational unit performing the collateral assessment.' ;
    rdfs:domain ind:Review ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibleCollateralValue rdf:type rdf:Property ;
    rdfs:label 'Eligible Collateral Value' ;
    rdfs:comment 'Collateral value after application of haircut. Represents the amount of collateral value recognized for credit risk mitigation purposes.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exposureCurrency rdf:type rdf:Property ;
    rdfs:label 'Exposure Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the outstanding exposure. Identifies the denomination currency of the credit exposure.' ;
    rdfs:domain ind:Review ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ltvRatio rdf:type rdf:Property ;
    rdfs:label 'Ltv Ratio' ;
    rdfs:comment 'Loan-to-value ratio calculated at the time of review. Represents the outstanding exposure divided by the eligible collateral value, expressed as a percentage.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marginCallAmount rdf:type rdf:Property ;
    rdfs:label 'Margin Call Amount' ;
    rdfs:comment 'Amount of additional collateral required if a margin call is recommended. Represents the value of collateral that must be posted to restore adequate coverage.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marginCallDueDate rdf:type rdf:Property ;
    rdfs:label 'Margin Call Due Date' ;
    rdfs:comment 'Date by which the margin call must be satisfied. Represents the deadline for the obligor to post additional collateral.' ;
    rdfs:domain ind:Review ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextScheduledReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Review Date' ;
    rdfs:comment 'Date when the next scheduled collateral review is due. Supports proactive collateral monitoring and review planning.' ;
    rdfs:domain ind:Collateral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:outstandingExposureAmount rdf:type rdf:Property ;
    rdfs:label 'Outstanding Exposure Amount' ;
    rdfs:comment 'Total credit exposure amount outstanding at the time of review. Represents the principal, accrued interest, and fees owed by the obligor.' ;
    rdfs:domain ind:Review ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorLtvRatio rdf:type rdf:Property ;
    rdfs:label 'Prior Ltv Ratio' ;
    rdfs:comment 'Loan-to-value ratio from the previous review. Enables trend analysis of collateral coverage deterioration or improvement.' ;
    rdfs:domain ind:Review ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorReviewDate rdf:type rdf:Property ;
    rdfs:label 'Prior Review Date' ;
    rdfs:comment 'Date of the previous collateral review. Provides historical context for tracking changes in collateral adequacy over time.' ;
    rdfs:domain ind:Review ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recommendedAction rdf:type rdf:Property ;
    rdfs:label 'Recommended Action' ;
    rdfs:comment 'Recommended remediation action based on the review findings. Indicates the next step required to address any collateral adequacy issues or optimize collateral usage. [ENUM-REF-CANDIDATE: no_action|margin_call|top_up_required|substitution|partial_release|full_release|covenant_waiver|exposure_reduction — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredCollateralCoverageRatio rdf:type rdf:Property ;
    rdfs:label 'Required Collateral Coverage Ratio' ;
    rdfs:comment 'Minimum collateral coverage ratio required by the credit agreement or regulatory framework. Represents the threshold below which a margin call or remediation is triggered.' ;
    rdfs:domain ind:Review ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reviewerName rdf:type rdf:Property ;
    rdfs:label 'Reviewer Name' ;
    rdfs:comment 'Full name of the credit officer or risk analyst who conducted the review. Provides human-readable identification of the reviewer.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggerEvent rdf:type rdf:Property ;
    rdfs:label 'Trigger Event' ;
    rdfs:comment 'Description of the event that triggered the review, if applicable. Captures the specific covenant breach, credit rating downgrade, or market event that necessitated the review.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationSource rdf:type rdf:Property ;
    rdfs:label 'Valuation Source' ;
    rdfs:comment 'Source of the collateral valuation data. Identifies the pricing service, appraiser, or market data provider used for the valuation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substitutionId rdf:type rdf:Property ;
    rdfs:label 'Substitution Id' ;
    rdfs:comment 'Unique identifier for the collateral substitution transaction. Primary key for the collateral substitution record.' ;
    rdfs:domain ind:Collateral ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Substitution .

ind:collateralMarginCallId rdf:type rdf:Property ;
    rdfs:label 'Collateral Margin Call Id' ;
    rdfs:comment 'Reference to the margin call that triggered or is associated with this collateral substitution, if applicable.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CollateralMarginCall .

ind:originalInstrumentId rdf:type rdf:Property ;
    rdfs:label 'Original Instrument Id' ;
    rdfs:comment 'Foreign key linking to security.instrument. Business justification: Substitution workflows require instrument-level tracking for eligibility validation, value equivalence checks, and cheapest-to-deliver optimization. Links original security being replaced in collatera' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Instrument .

ind:pledgeAgreementId rdf:type rdf:Property ;
    rdfs:label 'Pledge Agreement Id' ;
    rdfs:comment 'Reference to the master collateral agreement or Credit Support Annex (CSA) under which this substitution is executed.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PledgeAgreement .

ind:primarySubstitutionPartyId rdf:type rdf:Property ;
    rdfs:label 'Primary Substitution Party Id' ;
    rdfs:comment 'Reference to the custodian or triparty agent responsible for holding and transferring the collateral assets in this substitution transaction.' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:substitutionCreatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Substitution Created By User Employee Id' ;
    rdfs:comment 'Reference to the user who initiated or created the collateral substitution request in the system.' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:substitutionEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Substitution Employee Id' ;
    rdfs:comment 'Reference to the internal user or approver who authorized the collateral substitution request.' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:substitutionOriginalCollateralAssetId rdf:type rdf:Property ;
    rdfs:label 'Substitution Original Collateral Asset Id' ;
    rdfs:comment 'Reference to the original pledged or posted collateral asset being replaced in this substitution transaction.' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CollateralAsset .

ind:substitutionReplacementCollateralAssetId rdf:type rdf:Property ;
    rdfs:label 'Substitution Replacement Collateral Asset Id' ;
    rdfs:comment 'Reference to the new collateral asset being substituted in place of the original asset.' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CollateralAsset .

ind:substitutionUpdatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Substitution Updated By User Employee Id' ;
    rdfs:comment 'Reference to the user who last modified the collateral substitution record.' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:approvalWorkflowStatus rdf:type rdf:Property ;
    rdfs:label 'Approval Workflow Status' ;
    rdfs:comment 'Current status of the internal approval workflow for the substitution request, tracking progression through risk review, credit approval, and operational authorization stages.' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cheapestToDeliverFlag rdf:type rdf:Property ;
    rdfs:label 'Cheapest To Deliver Flag' ;
    rdfs:comment 'Boolean indicator of whether this substitution is part of a cheapest-to-deliver optimization strategy (True) or driven by other operational or risk factors (False).' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:collateralCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Collateral Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the collateral valuation amounts (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Collateral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costSavingsAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Savings Amount' ;
    rdfs:comment 'Estimated or actual cost savings achieved through the collateral substitution, typically measured as the difference in funding costs or opportunity costs between the original and replacement assets.' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costSavingsCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Cost Savings Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the cost savings amount.' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterpartyConsentComments rdf:type rdf:Property ;
    rdfs:label 'Counterparty Consent Comments' ;
    rdfs:comment 'Free-text comments or conditions provided by the counterparty regarding their consent decision, including any stipulations for conditional approval.' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterpartyConsentDate rdf:type rdf:Property ;
    rdfs:label 'Counterparty Consent Date' ;
    rdfs:comment 'Date on which the counterparty provided their consent decision (approval or rejection) for the substitution request.' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:counterpartyConsentStatus rdf:type rdf:Property ;
    rdfs:label 'Counterparty Consent Status' ;
    rdfs:comment 'Current status of counterparty consent for the collateral substitution request. Tracks whether the counterparty has approved, rejected, conditionally approved, or is still reviewing the substitution request.' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibilityCheckDate rdf:type rdf:Property ;
    rdfs:label 'Eligibility Check Date' ;
    rdfs:comment 'Date on which the eligibility verification for the replacement collateral asset was completed.' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eligibilityCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Eligibility Check Status' ;
    rdfs:comment 'Status of the eligibility verification process for the replacement collateral asset, confirming it meets all criteria defined in the collateral agreement (asset class, credit rating, maturity, concentration limits).' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Internal Approval Date' ;
    rdfs:comment 'Date on which internal approval was granted for the collateral substitution request, following completion of risk and credit review processes.' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originalCollateralAdjustedValueAmount rdf:type rdf:Property ;
    rdfs:label 'Original Collateral Adjusted Value Amount' ;
    rdfs:comment 'Post-haircut value of the original collateral asset, representing the effective collateral coverage amount.' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalCollateralHaircutRate rdf:type rdf:Property ;
    rdfs:label 'Original Collateral Haircut Rate' ;
    rdfs:comment 'Haircut percentage applied to the original collateral asset based on asset class, credit quality, and liquidity characteristics. Expressed as a decimal (e.g., 0.0500 for 5%).' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalCollateralValueAmount rdf:type rdf:Property ;
    rdfs:label 'Original Collateral Value Amount' ;
    rdfs:comment 'Market value of the original collateral asset at the time of substitution request, before application of haircut.' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:replacementCollateralAdjustedValueAmount rdf:type rdf:Property ;
    rdfs:label 'Replacement Collateral Adjusted Value Amount' ;
    rdfs:comment 'Post-haircut value of the replacement collateral asset, representing the effective collateral coverage amount after substitution.' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:replacementCollateralHaircutRate rdf:type rdf:Property ;
    rdfs:label 'Replacement Collateral Haircut Rate' ;
    rdfs:comment 'Haircut percentage applied to the replacement collateral asset based on asset class, credit quality, and liquidity characteristics. Expressed as a decimal (e.g., 0.0500 for 5%).' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:replacementCollateralValueAmount rdf:type rdf:Property ;
    rdfs:label 'Replacement Collateral Value Amount' ;
    rdfs:comment 'Market value of the replacement collateral asset at the time of substitution request, before application of haircut.' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requestDate rdf:type rdf:Property ;
    rdfs:label 'Request Date' ;
    rdfs:comment 'Date on which the collateral substitution request was initiated by the requesting party.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestNumber rdf:type rdf:Property ;
    rdfs:label 'Request Number' ;
    rdfs:comment 'Business identifier for the substitution request, used for tracking and reference in operational workflows and counterparty communications.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementConfirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Settlement Confirmation Number' ;
    rdfs:comment 'Unique confirmation reference number issued by the settlement system or custodian upon successful completion of the collateral transfer.' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferId rdf:type rdf:Property ;
    rdfs:label 'Transfer Id' ;
    rdfs:comment 'Unique identifier for the collateral transfer settlement instruction and confirmation record.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Transfer .

ind:receivingCustodianPartyId rdf:type rdf:Property ;
    rdfs:label 'Receiving Custodian Party Id' ;
    rdfs:comment 'Reference to the custodian bank or depository that will hold the collateral on behalf of the receiving party after settlement.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:receivingPartyId rdf:type rdf:Property ;
    rdfs:label 'Receiving Party Id' ;
    rdfs:comment 'Reference to the legal entity or counterparty receiving the collateral in this transfer.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:repoAgreementId rdf:type rdf:Property ;
    rdfs:label 'Repo Agreement Id' ;
    rdfs:comment 'Foreign key linking to collateral.repo_agreement. Business justification: Collateral transfers can occur under repo agreements (near-leg and far-leg settlement). The existing margin_agreement_id covers margin-based transfers, but repo transfers need their own agreement refe' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RepoAgreement .

ind:sendingPartyId rdf:type rdf:Property ;
    rdfs:label 'Sending Party Id' ;
    rdfs:comment 'Reference to the legal entity or counterparty delivering the collateral in this transfer.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:transferPartyId rdf:type rdf:Property ;
    rdfs:label 'Transfer Party Id' ;
    rdfs:comment 'Reference to the custodian bank or depository holding the collateral on behalf of the sending party.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:marginType rdf:type rdf:Property ;
    rdfs:label 'Margin Type' ;
    rdfs:comment 'Classification of the margin obligation this transfer satisfies: initial margin (IM), variation margin (VM), or independent amount (IA).' ;
    rdfs:domain ind:Collateral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reason rdf:type rdf:Property ;
    rdfs:label 'Reason' ;
    rdfs:comment 'Business rationale or trigger for the collateral transfer, such as margin call satisfaction, substitution request, portfolio rebalancing, or contractual obligation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Receiving Account Number' ;
    rdfs:comment 'Custodian account number or securities account identifier to which the collateral is being transferred.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segregationStatus rdf:type rdf:Property ;
    rdfs:label 'Segregation Status' ;
    rdfs:comment 'Indicates whether the transferred collateral is held in a segregated account (isolated from other assets), unsegregated (commingled), or partially segregated.' ;
    rdfs:domain ind:Collateral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sendingAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Sending Account Number' ;
    rdfs:comment 'Custodian account number or securities account identifier from which the collateral is being transferred.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementConfirmationReference rdf:type rdf:Property ;
    rdfs:label 'Settlement Confirmation Reference' ;
    rdfs:comment 'Reference number or identifier provided by the custodian or settlement system confirming successful completion of the transfer.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementConfirmationStatus rdf:type rdf:Property ;
    rdfs:label 'Settlement Confirmation Status' ;
    rdfs:comment 'Status of settlement confirmation from the custodian or counterparty: confirmed (both parties agree), pending (awaiting confirmation), unconfirmed (no response), mismatched (discrepancy), or rejected (declined).' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementSystem rdf:type rdf:Property ;
    rdfs:label 'Settlement System' ;
    rdfs:comment 'Name or identifier of the settlement infrastructure or clearing system used to execute the transfer (e.g., Fedwire, SWIFT, DTC, Euroclear, Clearstream).' ;
    rdfs:domain ind:Collateral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Settlement Timestamp' ;
    rdfs:comment 'Precise date and time when the collateral transfer was confirmed as settled by the custodian or settlement system.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:swiftInstructionReference rdf:type rdf:Property ;
    rdfs:label 'Swift Instruction Reference' ;
    rdfs:comment 'Unique SWIFT message reference number assigned to the settlement instruction for tracking and reconciliation.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:swiftMessageType rdf:type rdf:Property ;
    rdfs:label 'Swift Message Type' ;
    rdfs:comment 'SWIFT message type code used for the settlement instruction (e.g., MT540 for receive free, MT541 for receive against payment, MT542 for deliver free, MT543 for deliver against payment).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:titleTransferFlag rdf:type rdf:Property ;
    rdfs:label 'Title Transfer Flag' ;
    rdfs:comment 'Indicates whether this transfer involves a full title transfer (ownership change) or a security interest (lien without ownership transfer).' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transferDate rdf:type rdf:Property ;
    rdfs:label 'Transfer Date' ;
    rdfs:comment 'Business date on which the collateral transfer was initiated or instructed.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transferStatus rdf:type rdf:Property ;
    rdfs:label 'Transfer Status' ;
    rdfs:comment 'Current lifecycle status of the collateral transfer: pending (awaiting instruction), instructed (sent to custodian), in_transit (processing), settled (completed), failed (unsuccessful), cancelled (withdrawn), or rejected (declined by counterparty). [ENUM-REF-CANDIDATE: pending|instructed|in_transit|settled|failed|cancelled|rejected — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferType rdf:type rdf:Property ;
    rdfs:label 'Transfer Type' ;
    rdfs:comment 'Classification of the collateral transfer action: delivery (initial pledge), return (release), substitution (exchange), recall (demand back), rebalancing (portfolio adjustment), or adjustment (correction).' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:umrComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Umr Compliance Flag' ;
    rdfs:comment 'Indicates whether this collateral transfer is subject to and compliant with Uncleared Margin Rules for non-cleared derivatives.' ;
    rdfs:domain ind:Collateral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:valuationAmount rdf:type rdf:Property ;
    rdfs:label 'Valuation Amount' ;
    rdfs:comment 'Market valuation of the transferred collateral at the time of transfer instruction, used for margin calculation and exposure management.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collateralValuationId rdf:type rdf:Property ;
    rdfs:label 'Collateral Valuation Id' ;
    rdfs:comment 'Unique identifier for the collateral valuation record.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CollateralValuation .

ind:collateralAssetClass rdf:type rdf:Property ;
    rdfs:label 'Collateral Asset Class' ;
    rdfs:comment 'The broad asset class category of the collateral being valued, determining applicable haircut schedules and eligibility rules under Basel III. [ENUM-REF-CANDIDATE: cash|government_securities|corporate_bonds|equities|real_estate|commodities|derivatives|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CollateralValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidenceIntervalLower rdf:type rdf:Property ;
    rdfs:label 'Confidence Interval Lower' ;
    rdfs:comment 'The lower bound of the confidence interval for the valuation, representing the minimum expected value within the statistical confidence range (typically 95% or 99%).' ;
    rdfs:domain ind:CollateralValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confidenceIntervalUpper rdf:type rdf:Property ;
    rdfs:label 'Confidence Interval Upper' ;
    rdfs:comment 'The upper bound of the confidence interval for the valuation, representing the maximum expected value within the statistical confidence range.' ;
    rdfs:domain ind:CollateralValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confidenceLevelPercentage rdf:type rdf:Property ;
    rdfs:label 'Confidence Level Percentage' ;
    rdfs:comment 'The statistical confidence level used for the valuation interval, typically 0.95 (95%) or 0.99 (99%), indicating the probability that the true value falls within the stated range.' ;
    rdfs:domain ind:CollateralValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditQualityStep rdf:type rdf:Property ;
    rdfs:label 'Credit Quality Step' ;
    rdfs:comment 'The Basel III credit quality step assigned to the collateral asset, ranging from 1 (highest quality) to 6 (lowest quality), determining risk weights and haircuts.' ;
    rdfs:domain ind:Collateral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibleForCentralBank rdf:type rdf:Property ;
    rdfs:label 'Eligible For Central Bank' ;
    rdfs:comment 'Indicates whether this collateral asset is eligible for use in central bank operations (e.g., Fed discount window, ECB refinancing operations).' ;
    rdfs:domain ind:CollateralValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:externalRating rdf:type rdf:Property ;
    rdfs:label 'External Rating' ;
    rdfs:comment 'The external credit rating assigned to the collateral asset by a recognized rating agency (e.g., AAA, AA+, BBB-), used for credit quality assessment and haircut determination.' ;
    rdfs:domain ind:CollateralValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossMarketValue rdf:type rdf:Property ;
    rdfs:label 'Gross Market Value' ;
    rdfs:comment 'The unadjusted market value of the collateral asset before applying any haircuts or adjustments.' ;
    rdfs:domain ind:CollateralValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:haircutAmount rdf:type rdf:Property ;
    rdfs:label 'Haircut Amount' ;
    rdfs:comment 'The absolute monetary value of the haircut applied, calculated as gross market value multiplied by haircut percentage.' ;
    rdfs:domain ind:CollateralValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modelVersion rdf:type rdf:Property ;
    rdfs:label 'Model Version' ;
    rdfs:comment 'The version identifier of the internal pricing model used for valuation, supporting model governance and audit trail requirements.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousNetValue rdf:type rdf:Property ;
    rdfs:label 'Previous Net Value' ;
    rdfs:comment 'The net collateral value from the previous valuation, used to calculate value changes and trigger margin calls when thresholds are breached.' ;
    rdfs:domain ind:CollateralValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:previousValuationDate rdf:type rdf:Property ;
    rdfs:label 'Previous Valuation Date' ;
    rdfs:comment 'The date of the immediately preceding valuation for this collateral asset, enabling time-series analysis and value change tracking.' ;
    rdfs:domain ind:CollateralValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:purpose rdf:type rdf:Property ;
    rdfs:label 'Purpose' ;
    rdfs:comment 'The business purpose for which this valuation was performed, such as margin call calculation, LTV monitoring, regulatory reporting (Basel III, CCAR, DFAST), credit underwriting decision, portfolio review, or stress testing scenario.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationStatus rdf:type rdf:Property ;
    rdfs:label 'Valuation Status' ;
    rdfs:comment 'The current status of the valuation record. Final indicates approved and active, preliminary for initial calculations, pending review for valuations awaiting approval, disputed for challenged valuations, overridden for manually adjusted values, stale for outdated valuations requiring refresh.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Valuation Timestamp' ;
    rdfs:comment 'Precise timestamp when the valuation was calculated, supporting intraday MTM (Mark-to-Market) for derivatives and trading book positions.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:valueChangeAmount rdf:type rdf:Property ;
    rdfs:label 'Value Change Amount' ;
    rdfs:comment 'The absolute change in net collateral value since the previous valuation, calculated as current net value minus previous net value.' ;
    rdfs:domain ind:CollateralValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valueChangePercentage rdf:type rdf:Property ;
    rdfs:label 'Value Change Percentage' ;
    rdfs:comment 'The percentage change in net collateral value since the previous valuation, expressed as a decimal (e.g., 0.0523 for 5.23% increase).' ;
    rdfs:domain ind:CollateralValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:concentrationLimitId rdf:type rdf:Property ;
    rdfs:label 'Concentration Limit Id' ;
    rdfs:comment 'Unique identifier for the concentration limit record. Primary key for the concentration limit reference data.' ;
    rdfs:domain ind:ConcentrationLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicableMarginType rdf:type rdf:Property ;
    rdfs:label 'Applicable Margin Type' ;
    rdfs:comment 'Type of margin calculation to which this concentration limit applies. Distinguishes between initial margin and variation margin constraints.' ;
    rdfs:domain ind:ConcentrationLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arrangementScope rdf:type rdf:Property ;
    rdfs:label 'Arrangement Scope' ;
    rdfs:comment 'Defines the scope of collateral arrangements to which this concentration limit applies. Determines whether the limit is global or specific to certain transaction types.' ;
    rdfs:domain ind:ConcentrationLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachAction rdf:type rdf:Property ;
    rdfs:label 'Breach Action' ;
    rdfs:comment 'Automated or manual action to be taken when the concentration limit is breached. Defines the operational response to limit violations.' ;
    rdfs:domain ind:Collateral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachTolerancePercentage rdf:type rdf:Property ;
    rdfs:label 'Breach Tolerance Percentage' ;
    rdfs:comment 'Allowable tolerance buffer above the threshold before breach action is triggered. Provides operational flexibility for minor exceedances.' ;
    rdfs:domain ind:ConcentrationLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:counterpartyIdentifier rdf:type rdf:Property ;
    rdfs:label 'Counterparty Identifier' ;
    rdfs:comment 'Unique identifier of the counterparty when the concentration limit applies to counterparty exposure. Used for counterparty-level concentration constraints.' ;
    rdfs:domain ind:ConcentrationLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuerIdentifier rdf:type rdf:Property ;
    rdfs:label 'Issuer Identifier' ;
    rdfs:comment 'Unique identifier of the issuer entity when the concentration limit applies to a specific issuer. Used for issuer-level concentration constraints.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Code' ;
    rdfs:comment 'Three-letter ISO 3166 country code when the concentration limit applies to geographic exposure. Used for jurisdiction-level concentration constraints.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limitCode rdf:type rdf:Property ;
    rdfs:label 'Limit Code' ;
    rdfs:comment 'Business identifier code for the concentration limit rule. Used for external reference and reporting purposes.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limitName rdf:type rdf:Property ;
    rdfs:label 'Limit Name' ;
    rdfs:comment 'Descriptive name of the concentration limit rule for business user identification and reporting.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limitType rdf:type rdf:Property ;
    rdfs:label 'Limit Type' ;
    rdfs:comment 'Classification of the concentration limit by the dimension being constrained. Determines what aspect of the collateral portfolio is being limited to prevent over-reliance.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Override Allowed Flag' ;
    rdfs:comment 'Indicates whether authorized users can override this concentration limit under exceptional circumstances. Controls operational flexibility.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overrideApprovalLevel rdf:type rdf:Property ;
    rdfs:label 'Override Approval Level' ;
    rdfs:comment 'Required approval authority level for overriding this concentration limit. Defines escalation path for limit exceptions.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingLine rdf:type rdf:Property ;
    rdfs:label 'Reporting Line' ;
    rdfs:comment 'Business unit or reporting line responsible for monitoring and managing compliance with this concentration limit.' ;
    rdfs:domain ind:ConcentrationLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewFrequency rdf:type rdf:Property ;
    rdfs:label 'Review Frequency' ;
    rdfs:comment 'Scheduled frequency for periodic review and validation of the concentration limit rule. Ensures limits remain appropriate for current risk environment.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdAbsoluteAmount rdf:type rdf:Property ;
    rdfs:label 'Threshold Absolute Amount' ;
    rdfs:comment 'Maximum allowable concentration expressed as an absolute monetary amount. Used when limit is defined as a fixed value rather than percentage.' ;
    rdfs:domain ind:ConcentrationLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:thresholdPercentage rdf:type rdf:Property ;
    rdfs:label 'Threshold Percentage' ;
    rdfs:comment 'Maximum allowable concentration expressed as a percentage of total collateral portfolio value. Used when limit is defined as a relative measure.' ;
    rdfs:domain ind:ConcentrationLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:umrPhase rdf:type rdf:Property ;
    rdfs:label 'Umr Phase' ;
    rdfs:comment 'Phase of the Uncleared Margin Rules implementation schedule to which this limit applies. Relevant for phased regulatory compliance.' ;
    rdfs:domain ind:Collateral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibilityRuleId rdf:type rdf:Property ;
    rdfs:label 'Eligibility Rule Id' ;
    rdfs:comment 'Unique identifier for the collateral eligibility rule. Primary key for the eligibility rule entity.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EligibilityRule .

ind:concentrationLimitAbsoluteAmount rdf:type rdf:Property ;
    rdfs:label 'Concentration Limit Absolute Amount' ;
    rdfs:comment 'Maximum absolute monetary amount that can be allocated to the specified concentration dimension, expressed in the base currency of the collateral arrangement. Used when limits are defined in absolute terms rather than percentages.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:concentrationLimitPercentage rdf:type rdf:Property ;
    rdfs:label 'Concentration Limit Percentage' ;
    rdfs:comment 'Maximum percentage of total collateral portfolio value that can be allocated to the specified concentration dimension (e.g., no more than 25% from a single issuer). Expressed as a percentage with two decimal places.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:concentrationLimitType rdf:type rdf:Property ;
    rdfs:label 'Concentration Limit Type' ;
    rdfs:comment 'Dimension along which the concentration limit is applied: issuer (single issuer exposure), asset_class (exposure to one asset class), currency (single currency exposure), counterparty (exposure to one counterparty), jurisdiction (geographic concentration), or sector (industry sector concentration).' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibleForCcp rdf:type rdf:Property ;
    rdfs:label 'Eligible For Ccp' ;
    rdfs:comment 'Boolean flag indicating whether collateral meeting this rule is eligible for posting to a central counterparty (CCP) for cleared derivatives transactions. True if eligible, false otherwise.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eligibleForInitialMargin rdf:type rdf:Property ;
    rdfs:label 'Eligible For Initial Margin' ;
    rdfs:comment 'Boolean flag indicating whether collateral meeting this rule is eligible to satisfy initial margin (IM) requirements under uncleared derivatives margin rules (UMR). True if eligible, false otherwise.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eligibleForRepo rdf:type rdf:Property ;
    rdfs:label 'Eligible For Repo' ;
    rdfs:comment 'Boolean flag indicating whether collateral meeting this rule is eligible for use in repurchase (repo) or reverse repurchase (reverse repo) transactions. True if eligible, false otherwise.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eligibleForSecuredLending rdf:type rdf:Property ;
    rdfs:label 'Eligible For Secured Lending' ;
    rdfs:comment 'Boolean flag indicating whether collateral meeting this rule is eligible for secured lending transactions, including securities lending and collateralized loans. True if eligible, false otherwise.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eligibleForVariationMargin rdf:type rdf:Property ;
    rdfs:label 'Eligible For Variation Margin' ;
    rdfs:comment 'Boolean flag indicating whether collateral meeting this rule is eligible to satisfy variation margin (VM) requirements under derivatives margining frameworks. True if eligible, false otherwise.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuerType rdf:type rdf:Property ;
    rdfs:label 'Issuer Type' ;
    rdfs:comment 'Classification of the issuer of the collateral asset: sovereign (government), supranational (international organizations), agency (government-sponsored entities), corporate (non-financial corporations), financial institution (banks, insurers), municipal (local government), or other. [ENUM-REF-CANDIDATE: sovereign|supranational|agency|corporate|financial_institution|municipal|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limitScope rdf:type rdf:Property ;
    rdfs:label 'Limit Scope' ;
    rdfs:comment 'Scope of application for the eligibility or concentration rule: portfolio-wide (applies across all collateral arrangements), agreement-specific (applies to a single CSA or collateral agreement), counterparty-specific (applies to all arrangements with one counterparty), or product-specific (applies to a specific product type).' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumMaturityDays rdf:type rdf:Property ;
    rdfs:label 'Maximum Maturity Days' ;
    rdfs:comment 'Maximum remaining time to maturity in days for collateral assets to be eligible under this rule. Assets with longer maturity are excluded.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumCreditRating rdf:type rdf:Property ;
    rdfs:label 'Minimum Credit Rating' ;
    rdfs:comment 'Minimum acceptable credit rating for collateral assets under this rule, expressed in standard rating agency notation (e.g., AAA, AA+, A-, BBB). Assets below this rating are ineligible. NR indicates no rating requirement.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumMaturityDays rdf:type rdf:Property ;
    rdfs:label 'Minimum Maturity Days' ;
    rdfs:comment 'Minimum remaining time to maturity in days for collateral assets to be eligible under this rule. Assets with shorter maturity are excluded.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ruleCode rdf:type rdf:Property ;
    rdfs:label 'Rule Code' ;
    rdfs:comment 'Business identifier code for the eligibility rule, used for external reference and reporting. Typically follows internal naming conventions for rule identification.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleName rdf:type rdf:Property ;
    rdfs:label 'Rule Name' ;
    rdfs:comment 'Human-readable name of the eligibility rule describing its purpose and scope.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleStatus rdf:type rdf:Property ;
    rdfs:label 'Rule Status' ;
    rdfs:comment 'Current lifecycle status of the eligibility rule indicating whether it is actively enforced, pending approval, temporarily suspended, or expired.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleType rdf:type rdf:Property ;
    rdfs:label 'Rule Type' ;
    rdfs:comment 'Classification of the rule defining its functional purpose: eligibility criterion (what assets qualify), concentration limit (diversification requirements), jurisdiction restriction (geographic constraints), haircut rule (valuation discount), rating threshold (minimum credit quality), or maturity constraint (time-to-maturity limits).' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substitutionAllowed rdf:type rdf:Property ;
    rdfs:label 'Substitution Allowed' ;
    rdfs:comment 'Boolean flag indicating whether collateral assets meeting this rule can be substituted with other eligible collateral during the life of the collateral arrangement. True if substitution rights are granted, false otherwise.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assetSubclass rdf:type rdf:Property ;
    rdfs:label 'Asset Subclass' ;
    rdfs:comment 'Granular sub-category within the asset class (e.g., sovereign bond, municipal bond, investment-grade corporate bond, high-yield bond). Provides additional segmentation for haircut determination.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bilateralCsaHaircutPct rdf:type rdf:Property ;
    rdfs:label 'Bilateral Csa Haircut Pct' ;
    rdfs:comment 'Negotiated haircut percentage specified in a bilateral Credit Support Annex under an ISDA Master Agreement. May differ from supervisory haircuts based on counterparty agreement.' ;
    rdfs:domain ind:HaircutSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ccpHaircutPct rdf:type rdf:Property ;
    rdfs:label 'Ccp Haircut Pct' ;
    rdfs:comment 'Haircut percentage applied by a qualifying central counterparty (QCCP) for cleared derivatives and securities financing transactions. Reflects CCP-specific margin methodology.' ;
    rdfs:domain ind:HaircutSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collateralEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Collateral Eligibility Flag' ;
    rdfs:comment 'Indicates whether this asset class is eligible as collateral under the applicable regulatory framework and internal policy. True if eligible, False if ineligible.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:concentrationLimitPct rdf:type rdf:Property ;
    rdfs:label 'Concentration Limit Pct' ;
    rdfs:comment 'Maximum percentage of total collateral pool that can be composed of this asset class. Prevents over-concentration in single asset types.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confidenceLevelPct rdf:type rdf:Property ;
    rdfs:label 'Confidence Level Pct' ;
    rdfs:comment 'Statistical confidence level used in VaR-based haircut calculations. Basel III requires 99% confidence level for own-estimate haircuts.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currencyMismatchAddonPct rdf:type rdf:Property ;
    rdfs:label 'Currency Mismatch Addon Pct' ;
    rdfs:comment 'Additional haircut percentage applied when collateral and exposure currencies differ. Typically 8% under Basel III standardized approach for major currency pairs.' ;
    rdfs:domain ind:HaircutSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currencyMismatchIndicator rdf:type rdf:Property ;
    rdfs:label 'Currency Mismatch Indicator' ;
    rdfs:comment 'Flag indicating whether the collateral currency differs from the exposure currency. True if mismatch exists, requiring an additional haircut add-on per Basel III.' ;
    rdfs:domain ind:HaircutSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:initialMarginHaircutPct rdf:type rdf:Property ;
    rdfs:label 'Initial Margin Haircut Pct' ;
    rdfs:comment 'Haircut applied to collateral posted as initial margin for non-cleared derivatives under the BCBS-IOSCO margin framework. Protects against potential future exposure.' ;
    rdfs:domain ind:HaircutSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:internalModelHaircutPct rdf:type rdf:Property ;
    rdfs:label 'Internal Model Haircut Pct' ;
    rdfs:comment 'Haircut percentage derived from the bank\'s own internal Value-at-Risk (VaR) model under the own-estimate approach, subject to regulatory approval and minimum floors.' ;
    rdfs:domain ind:HaircutSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:liquidityCategory rdf:type rdf:Property ;
    rdfs:label 'Liquidity Category' ;
    rdfs:comment 'Classification of the collateral asset based on market depth, trading volume, and ease of liquidation. Highly liquid assets (e.g., G7 sovereign bonds) receive lower haircuts.' ;
    rdfs:domain ind:HaircutSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lookbackPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Lookback Period Days' ;
    rdfs:comment 'Number of historical days used to calculate volatility and haircut estimates under internal models. Basel III requires minimum 1-year lookback for own-estimate approach.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumHaircutFloorPct rdf:type rdf:Property ;
    rdfs:label 'Minimum Haircut Floor Pct' ;
    rdfs:comment 'Regulatory minimum haircut percentage that must be applied regardless of internal model estimates. Ensures prudent collateral valuation under all circumstances.' ;
    rdfs:domain ind:HaircutSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:residualMaturityBucket rdf:type rdf:Property ;
    rdfs:label 'Residual Maturity Bucket' ;
    rdfs:comment 'The time-to-maturity band of the collateral instrument. Longer maturities typically attract higher haircuts due to increased interest rate and market risk.' ;
    rdfs:domain ind:HaircutSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supervisoryHaircutPct rdf:type rdf:Property ;
    rdfs:label 'Supervisory Haircut Pct' ;
    rdfs:comment 'The standardized haircut percentage prescribed by the Basel III supervisory framework for this asset class, credit quality, and maturity combination. Used under the standardized approach for credit risk mitigation.' ;
    rdfs:domain ind:HaircutSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:variationMarginHaircutPct rdf:type rdf:Property ;
    rdfs:label 'Variation Margin Haircut Pct' ;
    rdfs:comment 'Haircut applied to collateral posted as variation margin for non-cleared derivatives. Typically lower than initial margin haircuts as VM covers current exposure.' ;
    rdfs:domain ind:HaircutSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volatilityAdjustmentMethod rdf:type rdf:Property ;
    rdfs:label 'Volatility Adjustment Method' ;
    rdfs:comment 'The statistical or econometric method used to calculate volatility-based haircut adjustments. Relevant for internal model approaches and dynamic haircut schedules.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initialMarginId rdf:type rdf:Property ;
    rdfs:label 'Initial Margin Id' ;
    rdfs:comment 'Unique identifier for the initial margin record. Primary key for the initial margin data product.' ;
    rdfs:domain ind:InitialMargin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:initialPartyId rdf:type rdf:Property ;
    rdfs:label 'Initial Party Id' ;
    rdfs:comment 'Reference to the counterparty entity for which initial margin is calculated and exchanged under bilateral OTC derivative transactions.' ;
    rdfs:domain ind:InitialMargin ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:primaryInitialCustodianPartyId rdf:type rdf:Property ;
    rdfs:label 'Primary Initial Custodian Party Id' ;
    rdfs:comment 'Reference to the third-party custodian or triparty agent holding the segregated initial margin collateral on behalf of the posting party.' ;
    rdfs:domain ind:InitialMargin ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:tradePositionId rdf:type rdf:Property ;
    rdfs:label 'Trade Position Id' ;
    rdfs:comment 'Foreign key linking to trade.trade_position. Business justification: Initial margin requirements are calculated by aggregating trade positions in the netting set. Risk and margin teams drill down from IM requirements to underlying positions for SIMM sensitivity analysi' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TradePosition .

ind:aanaAmount rdf:type rdf:Property ;
    rdfs:label 'Aana Amount' ;
    rdfs:comment 'The aggregate average notional amount of uncleared derivatives for the counterparty group, calculated over a specified period (typically March, April, May of the prior year). AANA determines UMR phase-in applicability.' ;
    rdfs:domain ind:InitialMargin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:aanaCalculationDate rdf:type rdf:Property ;
    rdfs:label 'Aana Calculation Date' ;
    rdfs:comment 'The date on which the AANA was calculated for the counterparty group, used to determine UMR phase-in eligibility.' ;
    rdfs:domain ind:InitialMargin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disputeAmount rdf:type rdf:Property ;
    rdfs:label 'Dispute Amount' ;
    rdfs:comment 'The amount of initial margin under dispute between the entity and the counterparty due to calculation differences, valuation disagreements, or operational errors. Null if no dispute exists.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeReason rdf:type rdf:Property ;
    rdfs:label 'Dispute Reason' ;
    rdfs:comment 'Free-text description of the reason for the initial margin dispute, including details of the calculation or valuation disagreement.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibleCollateralTypes rdf:type rdf:Property ;
    rdfs:label 'Eligible Collateral Types' ;
    rdfs:comment 'Comma-separated list of collateral asset types eligible for posting as initial margin under the CSA agreement (e.g., Cash, Government Bonds, Corporate Bonds, Equities). Eligibility is defined by the CSA and regulatory requirements.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:haircutScheduleApplied rdf:type rdf:Property ;
    rdfs:label 'Haircut Schedule Applied' ;
    rdfs:comment 'The name or identifier of the haircut schedule applied to non-cash collateral posted as initial margin. Haircuts reduce the collateral value to account for market risk and liquidity risk.' ;
    rdfs:domain ind:InitialMargin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imPostedAmount rdf:type rdf:Property ;
    rdfs:label 'Im Posted Amount' ;
    rdfs:comment 'The actual initial margin amount posted by the entity to the counterparty as of the calculation date. This represents collateral delivered to meet the IM requirement.' ;
    rdfs:domain ind:InitialMargin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:imReceivedAmount rdf:type rdf:Property ;
    rdfs:label 'Im Received Amount' ;
    rdfs:comment 'The actual initial margin amount received by the entity from the counterparty as of the calculation date. This represents collateral received to cover the counterparty\'s IM obligation.' ;
    rdfs:domain ind:InitialMargin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:imRequirementAmount rdf:type rdf:Property ;
    rdfs:label 'Im Requirement Amount' ;
    rdfs:comment 'The total initial margin amount required to be posted by the entity to the counterparty, calculated based on the agreed methodology and the risk profile of the uncleared OTC derivative portfolio.' ;
    rdfs:domain ind:InitialMargin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interestRateOnCashCollateral rdf:type rdf:Property ;
    rdfs:label 'Interest Rate On Cash Collateral' ;
    rdfs:comment 'The interest rate applied to cash collateral posted as initial margin, as agreed in the CSA. Typically based on an overnight rate such as SOFR or ESTR.' ;
    rdfs:domain ind:Collateral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastMarginCallDate rdf:type rdf:Property ;
    rdfs:label 'Last Margin Call Date' ;
    rdfs:comment 'The date of the most recent initial margin call issued to or by the counterparty due to a change in the IM requirement exceeding the minimum transfer amount.' ;
    rdfs:domain ind:Collateral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:modelApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Model Approval Status' ;
    rdfs:comment 'The regulatory approval status of the internal model used for initial margin calculation, if applicable. ISDA SIMM is generally pre-approved; proprietary models require explicit regulatory approval.' ;
    rdfs:domain ind:InitialMargin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelValidationDate rdf:type rdf:Property ;
    rdfs:label 'Model Validation Date' ;
    rdfs:comment 'The date of the most recent independent validation of the initial margin calculation model, as required by model governance and regulatory standards.' ;
    rdfs:domain ind:InitialMargin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:netImExposure rdf:type rdf:Property ;
    rdfs:label 'Net Im Exposure' ;
    rdfs:comment 'The net initial margin exposure after netting posted and received amounts. Positive values indicate the entity has a net IM receivable; negative values indicate a net IM payable.' ;
    rdfs:domain ind:InitialMargin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:phaseInDate rdf:type rdf:Property ;
    rdfs:label 'Phase In Date' ;
    rdfs:comment 'The effective date on which the counterparty relationship became subject to UMR initial margin requirements, based on the applicable regulatory phase.' ;
    rdfs:domain ind:InitialMargin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reconciliationDate rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Date' ;
    rdfs:comment 'The date on which the most recent reconciliation of initial margin calculations and balances was performed with the counterparty.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryPhase rdf:type rdf:Property ;
    rdfs:label 'Regulatory Phase' ;
    rdfs:comment 'The UMR phase-in category to which the counterparty relationship belongs, based on aggregate average notional amount (AANA) thresholds. Phase 1 applies to the largest entities; Phase 6 to smaller entities. Out of Scope indicates the relationship does not meet UMR thresholds. [ENUM-REF-CANDIDATE: Phase 1|Phase 2|Phase 3|Phase 4|Phase 5|Phase 6|Out of Scope — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InitialMargin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Reporting Jurisdiction' ;
    rdfs:comment 'The regulatory jurisdiction(s) to which this initial margin record must be reported (e.g., US, EU, UK, Japan). Multiple jurisdictions may apply for cross-border transactions.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:simmVersion rdf:type rdf:Property ;
    rdfs:label 'Simm Version' ;
    rdfs:comment 'The version of the ISDA SIMM methodology applied for the calculation (e.g., SIMM 2.6, SIMM 2.5). Null if a non-SIMM methodology is used.' ;
    rdfs:domain ind:InitialMargin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insurancePolicyId rdf:type rdf:Property ;
    rdfs:label 'Insurance Policy Id' ;
    rdfs:comment 'Unique identifier for the insurance policy record. Primary key for the insurance policy entity.' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:insuredPartyId rdf:type rdf:Property ;
    rdfs:label 'Insured Party Id' ;
    rdfs:comment 'Foreign key linking to customer.party. Business justification: Insured party identification is required for insurance claims processing, coverage verification during collateral valuation, loss payee clause enforcement, and regulatory compliance (e.g., flood insur' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:additionalInsuredParties rdf:type rdf:Property ;
    rdfs:label 'Additional Insured Parties' ;
    rdfs:comment 'List of additional parties named as insured under the policy beyond the primary insured. May include co-lenders, servicers, trustees, or other parties with an insurable interest in the collateral.' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brokerContact rdf:type rdf:Property ;
    rdfs:label 'Broker Contact' ;
    rdfs:comment 'Contact information for the insurance broker, including phone number and email address. Used for policy servicing, renewals, and claims coordination.' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brokerName rdf:type rdf:Property ;
    rdfs:label 'Broker Name' ;
    rdfs:comment 'The name of the insurance broker or agent who facilitated the placement of the policy. The broker acts as an intermediary between the insured and the insurance carrier.' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateOfInsuranceReference rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Insurance Reference' ;
    rdfs:comment 'Reference identifier for the certificate of insurance (COI) document that provides evidence of coverage. The COI is typically required by secured lenders to verify that adequate insurance is in place.' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimCount rdf:type rdf:Property ;
    rdfs:label 'Claim Count' ;
    rdfs:comment 'The total number of claims filed against this insurance policy since inception. High claim frequency may impact renewal terms, premium pricing, or insurability of the collateral asset.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:collateralDescription rdf:type rdf:Property ;
    rdfs:label 'Collateral Description' ;
    rdfs:comment 'Description of the collateral asset that is insured under this policy. This should match the legal description of the asset and may include property address, asset identification numbers, or other identifying characteristics.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collateralEligibilityImpact rdf:type rdf:Property ;
    rdfs:label 'Collateral Eligibility Impact' ;
    rdfs:comment 'Indicates how the insurance policy status affects the eligibility of the collateral asset for use in secured lending, derivatives margining, or repo transactions. Eligible means the asset meets insurance requirements, ineligible means it does not, and conditional means additional documentation or coverage is needed.' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageAmount rdf:type rdf:Property ;
    rdfs:label 'Coverage Amount' ;
    rdfs:comment 'The maximum amount the insurance policy will pay in the event of a covered loss. This represents the face value or limit of the policy and should align with the collateral value to ensure adequate protection.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coverageCurrency rdf:type rdf:Property ;
    rdfs:label 'Coverage Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code indicating the currency in which the coverage amount and premium are denominated.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageDescription rdf:type rdf:Property ;
    rdfs:label 'Coverage Description' ;
    rdfs:comment 'Detailed description of what is covered under the insurance policy, including specific perils, exclusions, and coverage limits. This provides clarity on the scope of protection for the collateral asset.' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deductibleAmount rdf:type rdf:Property ;
    rdfs:label 'Deductible Amount' ;
    rdfs:comment 'The amount the insured party must pay out-of-pocket before the insurance coverage begins to pay for a covered loss. Higher deductibles typically result in lower premium costs.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insurerIdentifier rdf:type rdf:Property ;
    rdfs:label 'Insurer Identifier' ;
    rdfs:comment 'Unique identifier for the insurance carrier, such as National Association of Insurance Commissioners (NAIC) number or other regulatory identifier. Used for regulatory reporting and carrier verification.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insurerName rdf:type rdf:Property ;
    rdfs:label 'Insurer Name' ;
    rdfs:comment 'The legal name of the insurance company or carrier that underwrites and issues the policy. This is the entity responsible for paying claims under the policy terms.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastPremiumPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Last Premium Payment Date' ;
    rdfs:comment 'The date on which the most recent premium payment was received by the insurance carrier. Used to track payment status and identify policies at risk of lapse due to non-payment.' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lossPayeeClause rdf:type rdf:Property ;
    rdfs:label 'Loss Payee Clause' ;
    rdfs:comment 'The contractual clause that designates the secured lender or creditor as the party to receive insurance proceeds in the event of a loss. This protects the lenders collateral interest by ensuring claim payments are directed to the secured party.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mortgageeClauseFlag rdf:type rdf:Property ;
    rdfs:label 'Mortgagee Clause Flag' ;
    rdfs:comment 'Boolean flag indicating whether the policy includes a mortgagee clause (also known as standard mortgage clause) that protects the lenders interest even if the borrower violates policy terms. True indicates the clause is present, false indicates it is not.' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextPremiumDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Premium Due Date' ;
    rdfs:comment 'The date on which the next premium payment is due. Failure to pay by this date may result in policy lapse or cancellation, creating a coverage gap that affects collateral protection.' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:policyDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Policy Document Reference' ;
    rdfs:comment 'Reference identifier or location of the physical or electronic insurance policy document. Used to retrieve the full policy terms, conditions, and endorsements for review or audit purposes.' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyNotes rdf:type rdf:Property ;
    rdfs:label 'Policy Notes' ;
    rdfs:comment 'Free-form text field for recording additional information, special conditions, endorsements, or operational notes related to the insurance policy. Used for documenting exceptions, coverage modifications, or communication history with the insurer.' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyNumber rdf:type rdf:Property ;
    rdfs:label 'Policy Number' ;
    rdfs:comment 'The externally-known unique policy number assigned by the insurance carrier. This is the business identifier used for claims, renewals, and correspondence with the insurer.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyStatus rdf:type rdf:Property ;
    rdfs:label 'Policy Status' ;
    rdfs:comment 'Current lifecycle status of the insurance policy. Active policies provide coverage, pending policies are awaiting approval or payment, expired policies have reached their termination date, cancelled policies were terminated before expiry, lapsed policies were not renewed, and suspended policies have temporarily halted coverage.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyType rdf:type rdf:Property ;
    rdfs:label 'Policy Type' ;
    rdfs:comment 'Classification of the insurance policy based on the type of coverage provided. Property insurance covers physical assets, title insurance protects against ownership defects, marine cargo insurance covers goods in transit, liability insurance protects against third-party claims, fidelity insurance covers employee dishonesty, and business interruption insurance covers loss of income.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:premiumAmount rdf:type rdf:Property ;
    rdfs:label 'Premium Amount' ;
    rdfs:comment 'The total cost paid to the insurance carrier for the policy coverage. This may be paid annually, semi-annually, quarterly, or monthly depending on the payment frequency terms.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:premiumFrequency rdf:type rdf:Property ;
    rdfs:label 'Premium Frequency' ;
    rdfs:comment 'The frequency at which insurance premium payments are due. Annual premiums are paid once per year, semi-annual twice per year, quarterly four times per year, and monthly twelve times per year.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Flag' ;
    rdfs:comment 'Boolean flag indicating whether the insurance policy meets all applicable regulatory requirements for collateral insurance under Basel III, Dodd-Frank, or other relevant frameworks. True indicates compliance, false indicates non-compliance or pending review.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Date' ;
    rdfs:comment 'The date by which the policy must be renewed to maintain continuous coverage. Typically occurs 30-60 days before the expiry date to allow time for renewal processing.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalClaimsPaidAmount rdf:type rdf:Property ;
    rdfs:label 'Total Claims Paid Amount' ;
    rdfs:comment 'The cumulative amount paid by the insurance carrier for all claims under this policy. This metric helps assess the loss history and risk profile of the insured collateral asset.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lienFilingId rdf:type rdf:Property ;
    rdfs:label 'Lien Filing Id' ;
    rdfs:comment 'Unique identifier for the lien filing record. Primary key for the lien filing entity.' ;
    rdfs:domain ind:LienFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryLienSecuredPartyId rdf:type rdf:Property ;
    rdfs:label 'Primary Lien Secured Party Id' ;
    rdfs:comment 'Reference to the internal party identifier for the secured party (typically the bank or lending entity).' ;
    rdfs:domain ind:LienFiling ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:amendmentCount rdf:type rdf:Property ;
    rdfs:label 'Amendment Count' ;
    rdfs:comment 'The number of UCC-3 amendments filed against this lien filing record.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:collateralClassification rdf:type rdf:Property ;
    rdfs:label 'Collateral Classification' ;
    rdfs:comment 'The UCC or PPSA classification of the collateral type (e.g., inventory, equipment, accounts, general intangibles, farm products, consumer goods).' ;
    rdfs:domain ind:LienFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:continuationDueDate rdf:type rdf:Property ;
    rdfs:label 'Continuation Due Date' ;
    rdfs:comment 'The date by which a continuation filing (UCC-3 continuation) must be filed to maintain perfection (typically within 6 months before expiry).' ;
    rdfs:domain ind:LienFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:continuationFiledDate rdf:type rdf:Property ;
    rdfs:label 'Continuation Filed Date' ;
    rdfs:comment 'The date on which a continuation filing was submitted to extend the lien perfection period.' ;
    rdfs:domain ind:LienFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:debtorAddress rdf:type rdf:Property ;
    rdfs:label 'Debtor Address' ;
    rdfs:comment 'The legal address of the debtor as recorded on the lien filing.' ;
    rdfs:domain ind:LienFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:debtorName rdf:type rdf:Property ;
    rdfs:label 'Debtor Name' ;
    rdfs:comment 'The legal name of the debtor (borrower or obligor) against whom the lien is filed.' ;
    rdfs:domain ind:LienFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingAuthority rdf:type rdf:Property ;
    rdfs:label 'Filing Authority' ;
    rdfs:comment 'The name of the government agency or registry office that accepted and recorded the lien filing (e.g., Delaware Secretary of State, Ontario Personal Property Security Registration, Companies House).' ;
    rdfs:domain ind:LienFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingDate rdf:type rdf:Property ;
    rdfs:label 'Filing Date' ;
    rdfs:comment 'The date on which the lien filing was submitted to and accepted by the filing authority. This is the date of legal perfection.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:filingDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Filing Document Reference' ;
    rdfs:comment 'Reference to the physical or electronic filing document stored in the document management system.' ;
    rdfs:domain ind:LienFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Filing Fee Amount' ;
    rdfs:comment 'The fee paid to the filing authority to record this lien filing.' ;
    rdfs:domain ind:LienFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:filingFeeCurrency rdf:type rdf:Property ;
    rdfs:label 'Filing Fee Currency' ;
    rdfs:comment 'The currency in which the filing fee was paid, in ISO 4217 three-letter code format (e.g., USD, CAD, GBP).' ;
    rdfs:domain ind:LienFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Filing Jurisdiction' ;
    rdfs:comment 'The legal jurisdiction (state, province, country) where the lien filing was registered (e.g., Delaware, Ontario, England and Wales).' ;
    rdfs:domain ind:LienFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingNotes rdf:type rdf:Property ;
    rdfs:label 'Filing Notes' ;
    rdfs:comment 'Free-text notes or comments regarding this lien filing, including special instructions, exceptions, or historical context.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Filing Reference Number' ;
    rdfs:comment 'The externally-known unique filing number or registration number assigned by the filing authority (e.g., UCC filing number, mortgage registration number, charge registration number).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingStatus rdf:type rdf:Property ;
    rdfs:label 'Filing Status' ;
    rdfs:comment 'Current lifecycle status of the lien filing (active, expired, terminated, pending, rejected, lapsed).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingType rdf:type rdf:Property ;
    rdfs:label 'Filing Type' ;
    rdfs:comment 'The type of lien filing or perfection action taken (e.g., UCC-1 initial financing statement, UCC-3 amendment, mortgage registration, PPSA filing). [ENUM-REF-CANDIDATE: UCC-1|UCC-3 Amendment|UCC-3 Continuation|UCC-3 Termination|Mortgage Registration|Charge Registration|PPSA Filing|Security Agreement|Pledge Agreement|Other — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAmendmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Amendment Date' ;
    rdfs:comment 'The date of the most recent UCC-3 amendment filed against this lien filing.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalEnforceabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Legal Enforceability Flag' ;
    rdfs:comment 'Indicates whether the lien filing is currently legally enforceable (true) or has lapsed/expired/been terminated (false).' ;
    rdfs:domain ind:LienFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lienPriorityRank rdf:type rdf:Property ;
    rdfs:label 'Lien Priority Rank' ;
    rdfs:comment 'The priority ranking of this lien relative to other liens on the same collateral (1 = first lien, 2 = second lien, etc.). Lower numbers indicate higher priority.' ;
    rdfs:domain ind:LienFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalFilingDate rdf:type rdf:Property ;
    rdfs:label 'Original Filing Date' ;
    rdfs:comment 'The date of the original UCC-1 or initial filing, used to establish priority. For continuation or amendment filings, this preserves the original perfection date.' ;
    rdfs:domain ind:LienFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:perfectionMethod rdf:type rdf:Property ;
    rdfs:label 'Perfection Method' ;
    rdfs:comment 'The method by which the security interest was perfected (filing, possession, control, automatic perfection, temporary perfection).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryCapitalReliefFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Capital Relief Flag' ;
    rdfs:comment 'Indicates whether this perfected lien filing qualifies the collateral for regulatory capital relief under Basel III Risk-Weighted Asset (RWA) calculations.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:collateralLifecycleEventId rdf:type rdf:Property ;
    rdfs:label 'Collateral Lifecycle Event Id' ;
    rdfs:comment 'Primary key for lifecycle_event' ;
    rdfs:domain ind:CollateralLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approverUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Approver User Employee Id' ;
    rdfs:comment 'Identifier of the senior officer or manager who approved the recommended action for this collateral lifecycle event.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryCollateralEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Collateral Employee Id' ;
    rdfs:comment 'Identifier of the collateral desk analyst or risk officer who reviewed this lifecycle event and determined the recommended action.' ;
    rdfs:domain ind:CollateralLifecycleEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actionCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Action Completion Date' ;
    rdfs:comment 'The date on which the action in response to this event was completed and closed.' ;
    rdfs:domain ind:CollateralLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actionDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Action Deadline Date' ;
    rdfs:comment 'The deadline date by which the recommended action must be completed to maintain compliance or mitigate risk.' ;
    rdfs:domain ind:CollateralLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actionTaken rdf:type rdf:Property ;
    rdfs:label 'Action Taken' ;
    rdfs:comment 'Description of the actual action taken in response to this collateral lifecycle event, including any deviations from the recommended action.' ;
    rdfs:domain ind:CollateralLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualCollateralCoverage rdf:type rdf:Property ;
    rdfs:label 'Actual Collateral Coverage' ;
    rdfs:comment 'The actual collateral value available at the time of this event, after applying haircuts and eligibility adjustments.' ;
    rdfs:domain ind:CollateralLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approverName rdf:type rdf:Property ;
    rdfs:label 'Approver Name' ;
    rdfs:comment 'Full name of the individual who approved the action for this collateral lifecycle event.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capitalReliefImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Capital Relief Impact Amount' ;
    rdfs:comment 'The change in regulatory capital relief resulting from this collateral lifecycle event, such as loss of collateral eligibility or enforcement.' ;
    rdfs:domain ind:CollateralLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:counterpartyNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Counterparty Notification Date' ;
    rdfs:comment 'The date on which the counterparty was notified of this collateral lifecycle event.' ;
    rdfs:domain ind:CollateralLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:counterpartyNotifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Counterparty Notified Flag' ;
    rdfs:comment 'Indicates whether the counterparty has been formally notified of this collateral lifecycle event and any required actions.' ;
    rdfs:domain ind:CollateralLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eventSource rdf:type rdf:Property ;
    rdfs:label 'Event Source' ;
    rdfs:comment 'The origin or channel through which the collateral lifecycle event was identified or received. [ENUM-REF-CANDIDATE: internal_monitoring|external_notification|corporate_action_feed|rating_agency|regulatory_filing|counterparty_notice|automated_trigger|manual_identification — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CollateralLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventSubtype rdf:type rdf:Property ;
    rdfs:label 'Event Subtype' ;
    rdfs:comment 'Detailed sub-classification of the event type providing additional granularity for specific corporate actions or review triggers.' ;
    rdfs:domain ind:CollateralLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredCollateralCoverage rdf:type rdf:Property ;
    rdfs:label 'Required Collateral Coverage' ;
    rdfs:comment 'The minimum collateral value required to adequately cover the credit exposure at the time of this event, based on applicable haircuts and margin requirements.' ;
    rdfs:domain ind:CollateralLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:riskImpactAssessment rdf:type rdf:Property ;
    rdfs:label 'Risk Impact Assessment' ;
    rdfs:comment 'Qualitative assessment of the risk impact of this collateral lifecycle event on the institution\'s credit exposure, capital adequacy, or liquidity position.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rwaImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Rwa Impact Amount' ;
    rdfs:comment 'The estimated change in risk-weighted assets resulting from this collateral lifecycle event, affecting regulatory capital calculations under Basel III.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cashCollateralRateBenchmarkId rdf:type rdf:Property ;
    rdfs:label 'Cash Collateral Rate Benchmark Id' ;
    rdfs:comment 'Foreign key linking to reference.rate_benchmark. Business justification: Interest on cash collateral typically references benchmark rate for accrual calculations and settlement. Creating cash_collateral_rate_benchmark_id FK for benchmark-linked interest.' ;
    rdfs:domain ind:MarginAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RateBenchmark .

ind:isdaMasterAgreementId rdf:type rdf:Property ;
    rdfs:label 'Isda Master Agreement Id' ;
    rdfs:comment 'Foreign key linking to collateral.isda_master_agreement. Business justification: Margin agreements (CSAs) are executed as annexes under ISDA Master Agreements. The ISDA Master Agreement is the parent legal framework governing derivatives transactions, and the margin agreement (CSA' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Banking .

ind:kycReviewId rdf:type rdf:Property ;
    rdfs:label 'Kyc Review Id' ;
    rdfs:comment 'Foreign key linking to compliance.kyc_review. Business justification: Onboarding a new CSA counterparty requires KYC review per ISDA and UMR requirements. The review is tied to the specific margin agreement being established for risk rating and due diligence documentati' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:KycReview .

ind:nettingSetId rdf:type rdf:Property ;
    rdfs:label 'Netting Set Id' ;
    rdfs:comment 'Reference to the master netting agreement (e.g., ISDA Master Agreement) under which this margin agreement operates, enabling close-out netting upon default.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NettingSet .

ind:primaryMarginPartyId rdf:type rdf:Property ;
    rdfs:label 'Primary Margin Party Id' ;
    rdfs:comment 'Reference to the custodian or third-party agent holding segregated collateral under this agreement, if applicable.' ;
    rdfs:domain ind:MarginAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:updatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Updated By User Employee Id' ;
    rdfs:comment 'Identifier of the user or system process that last updated this margin agreement record.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accelerationClause rdf:type rdf:Property ;
    rdfs:label 'Acceleration Clause' ;
    rdfs:comment 'Indicates whether the agreement contains an acceleration clause allowing immediate termination and full collateral call upon default. True = acceleration allowed, False = no acceleration.' ;
    rdfs:domain ind:MarginAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:agreementNumber rdf:type rdf:Property ;
    rdfs:label 'Agreement Number' ;
    rdfs:comment 'Externally-known unique business identifier for the margin agreement, used in legal documentation and counterparty communications.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementStatus rdf:type rdf:Property ;
    rdfs:label 'Agreement Status' ;
    rdfs:comment 'Current lifecycle status of the margin agreement. DRAFT = under negotiation, PENDING_APPROVAL = awaiting internal or counterparty approval, ACTIVE = in force, SUSPENDED = temporarily inactive, TERMINATED = ended by mutual agreement or default, EXPIRED = reached natural end date.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementType rdf:type rdf:Property ;
    rdfs:label 'Agreement Type' ;
    rdfs:comment 'Classification of the collateral agreement type. CSA_BILATERAL = ISDA Credit Support Annex bilateral, CSA_UNILATERAL = ISDA CSA unilateral, CCP_CLEARING = Central Counterparty clearing agreement, GMRA = Global Master Repurchase Agreement, GMSLA = Global Master Securities Lending Agreement, PLEDGE = pledge agreement, SECURITY_AGREEMENT = security agreement, HYPOTHECATION = hypothecation agreement, CHARGE = charge agreement for secured commercial lending. [ENUM-REF-CANDIDATE: CSA_BILATERAL|CSA_UNILATERAL|CCP_CLEARING|GMRA|GMSLA|PLEDGE|SECURITY_AGREEMENT|HYPOTHECATION|CHARGE — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collateralAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Collateral Account Number' ;
    rdfs:comment 'Account number or identifier for the segregated collateral account associated with this margin agreement.' ;
    rdfs:domain ind:Collateral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossDefaultProvision rdf:type rdf:Property ;
    rdfs:label 'Cross Default Provision' ;
    rdfs:comment 'Indicates whether a default under this agreement triggers default under other agreements with the same counterparty. True = cross-default applies, False = standalone agreement.' ;
    rdfs:domain ind:MarginAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disputeResolutionTerms rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Terms' ;
    rdfs:comment 'Free-text description of the dispute resolution process and escalation procedures defined in the agreement, including timeframes and arbitration clauses.' ;
    rdfs:domain ind:MarginAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingLaw rdf:type rdf:Property ;
    rdfs:label 'Governing Law' ;
    rdfs:comment 'Legal jurisdiction whose laws govern the interpretation and enforcement of the margin agreement. [ENUM-REF-CANDIDATE: ENGLISH_LAW|NEW_YORK_LAW|JAPANESE_LAW|GERMAN_LAW|FRENCH_LAW|SWISS_LAW|SINGAPORE_LAW|HONG_KONG_LAW|OTHER — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:independentAmountCurrency rdf:type rdf:Property ;
    rdfs:label 'Independent Amount Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the independent amount.' ;
    rdfs:domain ind:Collateral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initialMarginMethodology rdf:type rdf:Property ;
    rdfs:label 'Initial Margin Methodology' ;
    rdfs:comment 'Methodology used to calculate initial margin requirements. ISDA_SIMM = ISDA Standard Initial Margin Model, SCHEDULE_BASED = fixed schedule approach, CCP_GRID = central counterparty grid-based calculation, INTERNAL_MODEL = proprietary internal model, STANDARDIZED = regulatory standardized approach.' ;
    rdfs:domain ind:MarginAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lienPriority rdf:type rdf:Property ;
    rdfs:label 'Lien Priority' ;
    rdfs:comment 'Priority ranking of the security interest relative to other creditors. FIRST = first lien, SECOND = second lien, THIRD = third lien, SUBORDINATED = subordinated to other creditors, PARI_PASSU = equal ranking with other creditors.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mtaCurrency rdf:type rdf:Property ;
    rdfs:label 'Mta Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the minimum transfer amount.' ;
    rdfs:domain ind:Collateral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryMarginRegime rdf:type rdf:Property ;
    rdfs:label 'Regulatory Margin Regime' ;
    rdfs:comment 'Applicable regulatory margin framework governing this agreement. UMR = Uncleared Margin Rules phases 1-6, EMIR = European Market Infrastructure Regulation, DODD_FRANK = Dodd-Frank Act margin rules, NONE = no specific regulatory regime applies. [ENUM-REF-CANDIDATE: UMR_PHASE_1|UMR_PHASE_2|UMR_PHASE_3|UMR_PHASE_4|UMR_PHASE_5|UMR_PHASE_6|EMIR|DODD_FRANK|NONE — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MarginAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rehypothecationRights rdf:type rdf:Property ;
    rdfs:label 'Rehypothecation Rights' ;
    rdfs:comment 'Indicates whether the collateral taker has the right to rehypothecate (reuse) posted collateral for its own purposes. True = rehypothecation allowed, False = collateral must be segregated.' ;
    rdfs:domain ind:MarginAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:roundingConvention rdf:type rdf:Property ;
    rdfs:label 'Rounding Convention' ;
    rdfs:comment 'Method used to round collateral transfer amounts. NEAREST = round to nearest unit, UP = always round up, DOWN = always round down, NONE = no rounding applied.' ;
    rdfs:domain ind:MarginAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roundingPrecision rdf:type rdf:Property ;
    rdfs:label 'Rounding Precision' ;
    rdfs:comment 'Precision unit for rounding collateral transfer amounts, typically expressed in the settlement currency (e.g., 1000 for rounding to nearest thousand).' ;
    rdfs:domain ind:MarginAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:substitutionRights rdf:type rdf:Property ;
    rdfs:label 'Substitution Rights' ;
    rdfs:comment 'Indicates whether the collateral provider has the right to substitute posted collateral with other eligible collateral. True = substitution allowed, False = no substitution permitted.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationAgent rdf:type rdf:Property ;
    rdfs:label 'Valuation Agent' ;
    rdfs:comment 'Entity responsible for determining the value of collateral and exposure. PARTY_A = bank, PARTY_B = counterparty, THIRD_PARTY = independent valuation service, MUTUAL = both parties agree on valuation.' ;
    rdfs:domain ind:Collateral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variationMarginSettlementCurrency rdf:type rdf:Property ;
    rdfs:label 'Variation Margin Settlement Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which variation margin is settled daily to reflect mark-to-market exposure changes.' ;
    rdfs:domain ind:MarginAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callDirection rdf:type rdf:Property ;
    rdfs:label 'Call Direction' ;
    rdfs:comment 'Indicates whether the margin call was issued by the institution to a counterparty or received from a counterparty.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callTimestamp rdf:type rdf:Property ;
    rdfs:label 'Call Timestamp' ;
    rdfs:comment 'Precise date and time when the margin call was generated and communicated to the counterparty.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:collateralPostedAmount rdf:type rdf:Property ;
    rdfs:label 'Collateral Posted Amount' ;
    rdfs:comment 'The total amount of collateral posted by the institution to the counterparty as of the call date.' ;
    rdfs:domain ind:Collateral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collateralReceivedAmount rdf:type rdf:Property ;
    rdfs:label 'Collateral Received Amount' ;
    rdfs:comment 'The total amount of collateral received by the institution from the counterparty as of the call date.' ;
    rdfs:domain ind:Collateral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currency rdf:type rdf:Property ;
    rdfs:label 'Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the margin call amount.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dailyVmRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Daily Vm Requirement Flag' ;
    rdfs:comment 'Indicates whether this margin call is subject to daily Variation Margin exchange requirements per regulatory rules.' ;
    rdfs:domain ind:CollateralMarginCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Delivery Deadline Date' ;
    rdfs:comment 'The date by which the margin must be delivered to satisfy the call, per CSA or CCP rules.' ;
    rdfs:domain ind:CollateralMarginCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deliveryDeadlineTimestamp rdf:type rdf:Property ;
    rdfs:label 'Delivery Deadline Timestamp' ;
    rdfs:comment 'Precise date and time by which the margin must be delivered, including intraday deadlines for VM settlements.' ;
    rdfs:domain ind:CollateralMarginCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:disputeRaisedDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Raised Date' ;
    rdfs:comment 'The date on which the dispute was formally raised by either party.' ;
    rdfs:domain ind:CollateralMarginCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disputeResolutionStatus rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Status' ;
    rdfs:comment 'Current status of the dispute resolution process from initial dispute through final resolution or withdrawal.' ;
    rdfs:domain ind:CollateralMarginCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doddFrankComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Dodd Frank Compliance Flag' ;
    rdfs:comment 'Indicates whether this margin call is subject to and compliant with Dodd-Frank Act margin requirements for uncleared swaps.' ;
    rdfs:domain ind:Collateral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:emirComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Emir Compliance Flag' ;
    rdfs:comment 'Indicates whether this margin call is subject to and compliant with EMIR margin requirements for OTC derivatives.' ;
    rdfs:domain ind:Collateral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:imCalculationMethodology rdf:type rdf:Property ;
    rdfs:label 'Im Calculation Methodology' ;
    rdfs:comment 'The methodology used to calculate Initial Margin: ISDA SIMM (Standard Initial Margin Model), schedule-based approach, internal model, or CCP-prescribed method.' ;
    rdfs:domain ind:CollateralMarginCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imCustodianIdentifier rdf:type rdf:Property ;
    rdfs:label 'Im Custodian Identifier' ;
    rdfs:comment 'Legal Entity Identifier (LEI) or other unique identifier for the IM custodian.' ;
    rdfs:domain ind:CollateralMarginCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imCustodianName rdf:type rdf:Property ;
    rdfs:label 'Im Custodian Name' ;
    rdfs:comment 'Name of the third-party custodian holding the segregated Initial Margin collateral.' ;
    rdfs:domain ind:CollateralMarginCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imSegregationStatus rdf:type rdf:Property ;
    rdfs:label 'Im Segregation Status' ;
    rdfs:comment 'Indicates whether the Initial Margin is held in a segregated account per regulatory requirements (UMR, Dodd-Frank, EMIR).' ;
    rdfs:domain ind:CollateralMarginCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marginCallStatus rdf:type rdf:Property ;
    rdfs:label 'Margin Call Status' ;
    rdfs:comment 'Current lifecycle status of the margin call from issuance through settlement or dispute resolution. [ENUM-REF-CANDIDATE: pending|issued|acknowledged|partially_settled|fully_settled|disputed|cancelled|expired — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marginCallType rdf:type rdf:Property ;
    rdfs:label 'Margin Call Type' ;
    rdfs:comment 'Classification of the margin arrangement: bilateral (under CSA), central counterparty (CCP), or tri-party collateral management.' ;
    rdfs:domain ind:CollateralMarginCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netExposureAmount rdf:type rdf:Property ;
    rdfs:label 'Net Exposure Amount' ;
    rdfs:comment 'The net mark-to-market exposure of the netting set after netting all trades, used as the basis for margin calculation.' ;
    rdfs:domain ind:CollateralMarginCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vmSettlementStatus rdf:type rdf:Property ;
    rdfs:label 'Vm Settlement Status' ;
    rdfs:comment 'Current status of the Variation Margin settlement process from call issuance through final settlement confirmation.' ;
    rdfs:domain ind:CollateralMarginCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marginExposureId rdf:type rdf:Property ;
    rdfs:label 'Margin Exposure Id' ;
    rdfs:comment 'Unique identifier for the margin exposure calculation record.' ;
    rdfs:domain ind:MarginExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calculationRunCode rdf:type rdf:Property ;
    rdfs:label 'Calculation Run Code' ;
    rdfs:comment 'Identifier for the batch calculation run that produced this exposure record. Used for audit trail and reconciliation purposes.' ;
    rdfs:domain ind:MarginExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collateralSegregationRequired rdf:type rdf:Property ;
    rdfs:label 'Collateral Segregation Required' ;
    rdfs:comment 'Indicates whether initial margin collateral must be held in a segregated account at a third-party custodian, as required by regulatory mandates for certain counterparties and jurisdictions.' ;
    rdfs:domain ind:MarginExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cvaAmount rdf:type rdf:Property ;
    rdfs:label 'Cva Amount' ;
    rdfs:comment 'The adjustment to the fair value of derivative positions to account for counterparty credit risk. Represents the market value of counterparty default risk and is used for regulatory capital calculations.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Dispute Threshold Amount' ;
    rdfs:comment 'The minimum exposure difference amount that can trigger a formal dispute resolution process under the CSA. Valuation differences below this amount are typically resolved informally.' ;
    rdfs:domain ind:MarginExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dvaAmount rdf:type rdf:Property ;
    rdfs:label 'Dva Amount' ;
    rdfs:comment 'The adjustment to the fair value of derivative positions to account for the bank\'s own credit risk. Represents the benefit the bank receives from its own default risk.' ;
    rdfs:domain ind:MarginExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eadAmount rdf:type rdf:Property ;
    rdfs:label 'Ead Amount' ;
    rdfs:comment 'The estimated exposure amount at the time of counterparty default, used for regulatory capital calculations. Incorporates current exposure and potential future exposure.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exposureCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Exposure Currency Code' ;
    rdfs:comment 'The three-letter ISO 4217 currency code in which the exposure amounts are denominated. All monetary amounts in this record are expressed in this currency.' ;
    rdfs:domain ind:MarginExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exposureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Exposure Timestamp' ;
    rdfs:comment 'The precise timestamp when the margin exposure calculation was performed, including time zone information.' ;
    rdfs:domain ind:MarginExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:gneAmount rdf:type rdf:Property ;
    rdfs:label 'Gne Amount' ;
    rdfs:comment 'The total mark-to-market value of all positions where the bank has a negative exposure to the counterparty (bank owes the counterparty). Represents the gross liability before netting and collateral.' ;
    rdfs:domain ind:MarginExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gpeAmount rdf:type rdf:Property ;
    rdfs:label 'Gpe Amount' ;
    rdfs:comment 'The total mark-to-market value of all positions where the bank has a positive exposure to the counterparty (counterparty owes the bank). Represents the gross amount at risk before netting and collateral.' ;
    rdfs:domain ind:MarginExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:initialMarginAmount rdf:type rdf:Property ;
    rdfs:label 'Initial Margin Amount' ;
    rdfs:comment 'The collateral amount required to cover potential future exposure over the margin period of risk, calculated using regulatory models (SIMM) or internal models. Required for non-cleared derivatives under regulatory mandates.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marginCallDirection rdf:type rdf:Property ;
    rdfs:label 'Margin Call Direction' ;
    rdfs:comment 'Indicates the direction of the margin call: whether the bank is calling for collateral from the counterparty, the counterparty is calling from the bank, or no call is required.' ;
    rdfs:domain ind:MarginExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marginPeriodOfRiskDays rdf:type rdf:Property ;
    rdfs:label 'Margin Period Of Risk Days' ;
    rdfs:comment 'The number of days between the last margin call and the closeout of positions following a counterparty default. Used in calculating initial margin requirements. Typically 10 days for standard CSAs.' ;
    rdfs:domain ind:MarginExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nceAmount rdf:type rdf:Property ;
    rdfs:label 'Nce Amount' ;
    rdfs:comment 'The net mark-to-market exposure after bilateral netting of all positions under the margin agreement. Calculated as GPE minus GNE. Positive values indicate the bank is owed; negative values indicate the bank owes.' ;
    rdfs:domain ind:MarginExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netCollateralPosition rdf:type rdf:Property ;
    rdfs:label 'Net Collateral Position' ;
    rdfs:comment 'The net collateral position calculated as collateral received minus collateral posted. Positive values indicate the bank holds net collateral; negative values indicate the bank has posted net collateral.' ;
    rdfs:domain ind:MarginExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextMarginCallDate rdf:type rdf:Property ;
    rdfs:label 'Next Margin Call Date' ;
    rdfs:comment 'The next scheduled date on which a margin call may be issued based on the CSA terms. Typically daily for most CSAs but may be less frequent for certain counterparties.' ;
    rdfs:domain ind:MarginExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pfeAmount rdf:type rdf:Property ;
    rdfs:label 'Pfe Amount' ;
    rdfs:comment 'The estimated maximum exposure that could arise in the future due to market movements, calculated using regulatory or internal models. Used for regulatory capital calculations and risk management.' ;
    rdfs:domain ind:MarginExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryImModel rdf:type rdf:Property ;
    rdfs:label 'Regulatory Im Model' ;
    rdfs:comment 'The regulatory model used to calculate initial margin requirements. SIMM (Standard Initial Margin Model) is the industry standard; grid and schedule are simplified approaches; internal models require regulatory approval.' ;
    rdfs:domain ind:MarginExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rwaAmount rdf:type rdf:Property ;
    rdfs:label 'Rwa Amount' ;
    rdfs:comment 'The risk-weighted asset amount calculated for this exposure under Basel III regulatory capital requirements. Used to determine the capital charge for counterparty credit risk.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:variationMarginAmount rdf:type rdf:Property ;
    rdfs:label 'Variation Margin Amount' ;
    rdfs:comment 'The collateral amount required to cover the current mark-to-market exposure, calculated daily based on changes in position values. Distinct from initial margin which covers potential future exposure.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:governingLawJurisdictionCountryId rdf:type rdf:Property ;
    rdfs:label 'Governing Law Jurisdiction Country Id' ;
    rdfs:comment 'Foreign key linking to reference.country. Business justification: Governing law jurisdiction determines netting enforceability and regulatory capital recognition. Creating governing_law_jurisdiction_country_id FK to replace jurisdiction code.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:nettingPartyId rdf:type rdf:Property ;
    rdfs:label 'Netting Party Id' ;
    rdfs:comment 'Reference to the counterparty with whom the netting set is established. All derivative transactions within this netting set are with this single counterparty.' ;
    rdfs:domain ind:NettingSet ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:primaryNettingCustodianPartyId rdf:type rdf:Property ;
    rdfs:label 'Primary Netting Custodian Party Id' ;
    rdfs:comment 'Reference to the third-party custodian holding segregated initial margin collateral for this netting set, if segregation is required.' ;
    rdfs:domain ind:NettingSet ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:capitalTreatmentApproach rdf:type rdf:Property ;
    rdfs:label 'Capital Treatment Approach' ;
    rdfs:comment 'Regulatory approach used for calculating counterparty credit risk capital requirements for this netting set: SA-CCR (Standardized Approach for Counterparty Credit Risk), IMM (Internal Models Method), CEM (Current Exposure Method), or Standardized Approach.' ;
    rdfs:domain ind:NettingSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initialMarginRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Initial Margin Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether initial margin is required for this netting set under the applicable margin agreement or regulatory requirements (e.g., UMR).' ;
    rdfs:domain ind:NettingSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalOpinionDate rdf:type rdf:Property ;
    rdfs:label 'Legal Opinion Date' ;
    rdfs:comment 'Date on which the legal opinion confirming netting enforceability was issued or last reviewed by legal counsel.' ;
    rdfs:domain ind:NettingSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:marginAgreementType rdf:type rdf:Property ;
    rdfs:label 'Margin Agreement Type' ;
    rdfs:comment 'Type of margin agreement governing collateral exchange: bilateral (both parties post collateral), unilateral (only one party posts), or no margin agreement in place.' ;
    rdfs:domain ind:NettingSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nettingEnforceabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Netting Enforceability Status' ;
    rdfs:comment 'Legal opinion status indicating whether close-out netting under the ISDA Master Agreement is legally enforceable in the relevant jurisdiction. Critical for regulatory capital treatment.' ;
    rdfs:domain ind:NettingSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nettingSetStatus rdf:type rdf:Property ;
    rdfs:label 'Netting Set Status' ;
    rdfs:comment 'Current lifecycle status of the netting set indicating whether it is actively used for netting derivative exposures or has been suspended or terminated.' ;
    rdfs:domain ind:NettingSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextValuationDate rdf:type rdf:Property ;
    rdfs:label 'Next Valuation Date' ;
    rdfs:comment 'Next scheduled date on which derivative positions within the netting set will be valued for exposure and margin call calculation purposes.' ;
    rdfs:domain ind:Collateral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notificationTime rdf:type rdf:Property ;
    rdfs:label 'Notification Time' ;
    rdfs:comment 'Deadline by which margin call notifications must be sent to the counterparty, typically expressed as a time of day in a specific time zone.' ;
    rdfs:domain ind:Collateral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryRecognitionStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Recognition Status' ;
    rdfs:comment 'Status indicating whether the netting set is recognized for regulatory capital purposes under Basel III SA-CCR or Internal Models Method (IMM). Determines eligibility for capital relief.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rehypothecationRightsFlag rdf:type rdf:Property ;
    rdfs:label 'Rehypothecation Rights Flag' ;
    rdfs:comment 'Boolean flag indicating whether the secured party has the right to rehypothecate (reuse) collateral posted by the counterparty for its own purposes.' ;
    rdfs:domain ind:NettingSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:roundingAmount rdf:type rdf:Property ;
    rdfs:label 'Rounding Amount' ;
    rdfs:comment 'Amount to which margin call calculations are rounded to simplify collateral transfers and reduce operational complexity.' ;
    rdfs:domain ind:Collateral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:roundingCurrency rdf:type rdf:Property ;
    rdfs:label 'Rounding Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the rounding amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:NettingSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segregationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Segregation Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether initial margin must be segregated with a third-party custodian to protect against counterparty default, as required under UMR.' ;
    rdfs:domain ind:NettingSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:substitutionRightsFlag rdf:type rdf:Property ;
    rdfs:label 'Substitution Rights Flag' ;
    rdfs:comment 'Boolean flag indicating whether the posting party has the right to substitute posted collateral with other eligible collateral of equivalent value.' ;
    rdfs:domain ind:Collateral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:valuationTime rdf:type rdf:Property ;
    rdfs:label 'Valuation Time' ;
    rdfs:comment 'Specified time of day (e.g., close of business, 4:00 PM New York time) at which derivative positions are valued for margin call calculations.' ;
    rdfs:domain ind:Collateral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variationMarginRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Variation Margin Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether variation margin is required for this netting set to cover mark-to-market exposure fluctuations.' ;
    rdfs:domain ind:NettingSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:collateralPledgeCustodianPartyId rdf:type rdf:Property ;
    rdfs:label 'Collateral Pledge Custodian Party Id' ;
    rdfs:comment 'Reference to the third-party custodian or depository holding the pledged collateral on behalf of the secured party.' ;
    rdfs:domain ind:CollateralPledge ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:collateralPledgeObligorPartyId rdf:type rdf:Property ;
    rdfs:label 'Collateral Pledge Obligor Party Id' ;
    rdfs:comment 'Reference to the party providing the collateral (the pledgor or obligor).' ;
    rdfs:domain ind:CollateralPledge ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:collateralPledgeSecuredPartyId rdf:type rdf:Property ;
    rdfs:label 'Collateral Pledge Secured Party Id' ;
    rdfs:comment 'Reference to the party receiving the collateral (the secured party or beneficiary).' ;
    rdfs:domain ind:CollateralPledge ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:perfectionJurisdictionCountryId rdf:type rdf:Property ;
    rdfs:label 'Perfection Jurisdiction Country Id' ;
    rdfs:comment 'Foreign key linking to reference.country. Business justification: Perfection jurisdiction determines legal enforceability and priority. Required for netting opinions, insolvency regime assessment, and regulatory capital relief eligibility. Creating perfection_jurisd' ;
    rdfs:domain ind:Collateral ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:collateralCoverageRatio rdf:type rdf:Property ;
    rdfs:label 'Collateral Coverage Ratio' ;
    rdfs:comment 'The ratio of eligible collateral value to the credit exposure, expressed as a percentage, indicating the degree of over-collateralization or under-collateralization.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enforcementDate rdf:type rdf:Property ;
    rdfs:label 'Enforcement Date' ;
    rdfs:comment 'The date on which the secured party exercised its right to seize and liquidate the pledged collateral due to obligor default.' ;
    rdfs:domain ind:CollateralPledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalPerfectionStatus rdf:type rdf:Property ;
    rdfs:label 'Legal Perfection Status' ;
    rdfs:comment 'Indicates whether the security interest has been legally perfected (enforceable against third parties): perfected (fully enforceable), pending (perfection in progress), unperfected (not yet enforceable), disputed (under legal challenge).' ;
    rdfs:domain ind:CollateralPledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lienRank rdf:type rdf:Property ;
    rdfs:label 'Lien Rank' ;
    rdfs:comment 'The priority ranking of this pledge relative to other liens on the same collateral: first (highest priority), second, subordinate, pari passu (equal ranking), junior, senior.' ;
    rdfs:domain ind:CollateralPledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:perfectionDate rdf:type rdf:Property ;
    rdfs:label 'Perfection Date' ;
    rdfs:comment 'The date on which the security interest was legally perfected through filing, registration, or other required action.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pledgeDate rdf:type rdf:Property ;
    rdfs:label 'Pledge Date' ;
    rdfs:comment 'The date on which the collateral was formally pledged to secure the obligation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pledgeStatus rdf:type rdf:Property ;
    rdfs:label 'Pledge Status' ;
    rdfs:comment 'Current lifecycle status of the pledge: active (in force), released (returned to obligor), substituted (replaced with alternative collateral), enforced (collateral seized), defaulted (obligor in default), pending (awaiting perfection).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pledgeType rdf:type rdf:Property ;
    rdfs:label 'Pledge Type' ;
    rdfs:comment 'The type of obligation being secured by this pledge: loan collateral (secured lending), derivative margin (ISDA CSA), repo collateral (repo/reverse repo), guarantee backing, letter of credit collateral.' ;
    rdfs:domain ind:CollateralPledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substitutionDate rdf:type rdf:Property ;
    rdfs:label 'Substitution Date' ;
    rdfs:comment 'The date on which this collateral was substituted with alternative collateral, if applicable.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:primaryPledgeObligorPartyId rdf:type rdf:Property ;
    rdfs:label 'Primary Pledge Obligor Party Id' ;
    rdfs:comment 'Identifier of the party pledging collateral (borrower or debtor) under this agreement.' ;
    rdfs:domain ind:PledgeAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:tertiaryPledgeCustodianPartyId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Pledge Custodian Party Id' ;
    rdfs:comment 'Identifier of the third-party custodian or trustee holding the collateral assets on behalf of the secured party.' ;
    rdfs:domain ind:PledgeAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:accelerationClauseFlag rdf:type rdf:Property ;
    rdfs:label 'Acceleration Clause Flag' ;
    rdfs:comment 'Indicates whether the agreement contains acceleration provisions allowing the secured party to demand immediate payment of all obligations upon default.' ;
    rdfs:domain ind:PledgeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:agreementNotes rdf:type rdf:Property ;
    rdfs:label 'Agreement Notes' ;
    rdfs:comment 'Free-form text field for additional comments, special terms, exceptions, or operational notes related to this pledge agreement.' ;
    rdfs:domain ind:PledgeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Agreement Reference Number' ;
    rdfs:comment 'External business reference number or contract identifier for the pledge agreement, used in legal documentation and correspondence.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossDefaultProvisionFlag rdf:type rdf:Property ;
    rdfs:label 'Cross Default Provision Flag' ;
    rdfs:comment 'Indicates whether the agreement includes cross-default clauses that trigger default if the obligor defaults on other obligations.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:executionDate rdf:type rdf:Property ;
    rdfs:label 'Execution Date' ;
    rdfs:comment 'Date when the pledge agreement was signed by all parties.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:marginCallThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Margin Call Threshold Amount' ;
    rdfs:comment 'Minimum collateral value shortfall that triggers a margin call requiring additional collateral to be posted.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumCollateralCoverageRatio rdf:type rdf:Property ;
    rdfs:label 'Minimum Collateral Coverage Ratio' ;
    rdfs:comment 'Required minimum ratio of collateral value to secured obligation amount, expressed as a percentage (e.g., 125.00 means 125% coverage required).' ;
    rdfs:domain ind:PledgeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nettingAgreementFlag rdf:type rdf:Property ;
    rdfs:label 'Netting Agreement Flag' ;
    rdfs:comment 'Indicates whether this pledge agreement is part of a master netting arrangement allowing offset of obligations across multiple transactions.' ;
    rdfs:domain ind:PledgeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:perfectionStatus rdf:type rdf:Property ;
    rdfs:label 'Perfection Status' ;
    rdfs:comment 'Current state of the legal perfection process indicating whether the security interest has been properly registered and is enforceable against third parties.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryCapitalTreatment rdf:type rdf:Property ;
    rdfs:label 'Regulatory Capital Treatment' ;
    rdfs:comment 'Classification of how this collateral arrangement is treated for regulatory capital calculations under Basel III framework.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rwaReductionPercentage rdf:type rdf:Property ;
    rdfs:label 'Rwa Reduction Percentage' ;
    rdfs:comment 'Percentage reduction in Risk-Weighted Assets (RWA) achieved through this collateral arrangement for regulatory capital purposes.' ;
    rdfs:domain ind:PledgeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:securedObligationAmount rdf:type rdf:Property ;
    rdfs:label 'Secured Obligation Amount' ;
    rdfs:comment 'Total monetary amount of the debt or obligation secured by this pledge agreement.' ;
    rdfs:domain ind:PledgeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collateralBasketId rdf:type rdf:Property ;
    rdfs:label 'Collateral Basket Id' ;
    rdfs:comment 'Identifier of the collateral basket pledged or received under this repo agreement.' ;
    rdfs:domain ind:Collateral ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CollateralBasket .

ind:primaryRepoPartyId rdf:type rdf:Property ;
    rdfs:label 'Primary Repo Party Id' ;
    rdfs:comment 'Identifier of the custodian bank or tri-party agent managing collateral settlement and safekeeping.' ;
    rdfs:domain ind:RepoAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:repoRateBenchmarkId rdf:type rdf:Property ;
    rdfs:label 'Repo Rate Benchmark Id' ;
    rdfs:comment 'Foreign key linking to reference.rate_benchmark. Business justification: Repo rate often references benchmark (SOFR + spread) for pricing and accrual calculations. Creating repo_rate_benchmark_id FK for benchmark-linked repos.' ;
    rdfs:domain ind:RepoAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RateBenchmark .

ind:couponPassThroughFlag rdf:type rdf:Property ;
    rdfs:label 'Coupon Pass Through Flag' ;
    rdfs:comment 'Indicates whether coupon or dividend payments on the collateral securities are passed through to the cash lender during the repo term. True if pass-through applies, False otherwise.' ;
    rdfs:domain ind:RepoAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:couponPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Coupon Payment Date' ;
    rdfs:comment 'The date on which any coupon or dividend payment on the collateral is due to be passed through, if applicable.' ;
    rdfs:domain ind:RepoAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:failReason rdf:type rdf:Property ;
    rdfs:label 'Fail Reason' ;
    rdfs:comment 'Textual description of the reason for settlement failure, such as insufficient collateral, cash shortfall, or operational error.' ;
    rdfs:domain ind:RepoAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Fail Resolution Date' ;
    rdfs:comment 'The date on which a failed trade was resolved and settlement completed.' ;
    rdfs:domain ind:RepoAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:failedTradeFlag rdf:type rdf:Property ;
    rdfs:label 'Failed Trade Flag' ;
    rdfs:comment 'Indicates whether the repo transaction has experienced a settlement failure on either leg. True if failed, False otherwise.' ;
    rdfs:domain ind:RepoAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:farLegAmount rdf:type rdf:Property ;
    rdfs:label 'Far Leg Amount' ;
    rdfs:comment 'The total repurchase amount on the far leg, including principal and accrued repo interest.' ;
    rdfs:domain ind:RepoAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:farLegConfirmationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Far Leg Confirmation Timestamp' ;
    rdfs:comment 'Date and time when the far leg settlement was confirmed by the custodian or settlement system.' ;
    rdfs:domain ind:RepoAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:farLegCurrency rdf:type rdf:Property ;
    rdfs:label 'Far Leg Currency' ;
    rdfs:comment 'The three-letter ISO 4217 currency code for the far leg repurchase amount.' ;
    rdfs:domain ind:RepoAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:farLegRepurchaseDate rdf:type rdf:Property ;
    rdfs:label 'Far Leg Repurchase Date' ;
    rdfs:comment 'The scheduled maturity or repurchase date for the far leg when collateral is returned and cash plus interest is repaid. Null for open repos until termination notice is given.' ;
    rdfs:domain ind:RepoAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:farLegSettlementReference rdf:type rdf:Property ;
    rdfs:label 'Far Leg Settlement Reference' ;
    rdfs:comment 'SWIFT message reference or RTGS transaction identifier for the far leg repurchase settlement.' ;
    rdfs:domain ind:RepoAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:farLegSettlementStatus rdf:type rdf:Property ;
    rdfs:label 'Far Leg Settlement Status' ;
    rdfs:comment 'Current settlement status of the far leg: pending (awaiting maturity), settled (completed), failed (settlement failure), or cancelled.' ;
    rdfs:domain ind:RepoAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marginCallThreshold rdf:type rdf:Property ;
    rdfs:label 'Margin Call Threshold' ;
    rdfs:comment 'The minimum collateral value shortfall that triggers a margin call under the repo agreement.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nearLegAmount rdf:type rdf:Property ;
    rdfs:label 'Near Leg Amount' ;
    rdfs:comment 'The principal cash amount exchanged on the near leg settlement date.' ;
    rdfs:domain ind:RepoAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nearLegConfirmationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Near Leg Confirmation Timestamp' ;
    rdfs:comment 'Date and time when the near leg settlement was confirmed by the custodian or settlement system.' ;
    rdfs:domain ind:RepoAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:nearLegSettlementDate rdf:type rdf:Property ;
    rdfs:label 'Near Leg Settlement Date' ;
    rdfs:comment 'The settlement date for the initial cash and collateral exchange (near leg) of the repo transaction, typically T+1 or T+0.' ;
    rdfs:domain ind:RepoAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nearLegSettlementReference rdf:type rdf:Property ;
    rdfs:label 'Near Leg Settlement Reference' ;
    rdfs:comment 'SWIFT message reference or RTGS transaction identifier for the near leg cash settlement.' ;
    rdfs:domain ind:RepoAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nearLegSettlementStatus rdf:type rdf:Property ;
    rdfs:label 'Near Leg Settlement Status' ;
    rdfs:comment 'Current settlement status of the near leg: pending (awaiting settlement), settled (completed), failed (settlement failure), or cancelled.' ;
    rdfs:domain ind:RepoAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openTermFlag rdf:type rdf:Property ;
    rdfs:label 'Open Term Flag' ;
    rdfs:comment 'Indicates whether the repo is open-ended (callable on demand) or term (fixed maturity). True for open repo, False for term repo.' ;
    rdfs:domain ind:RepoAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:repoAgreementNumber rdf:type rdf:Property ;
    rdfs:label 'Repo Agreement Number' ;
    rdfs:comment 'Externally-known business identifier or reference number for the repo transaction, used for trade confirmation and settlement messaging.' ;
    rdfs:domain ind:RepoAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repoDirection rdf:type rdf:Property ;
    rdfs:label 'Repo Direction' ;
    rdfs:comment 'Indicates whether the institution is borrowing cash (repo) or lending cash (reverse repo).' ;
    rdfs:domain ind:RepoAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repoRate rdf:type rdf:Property ;
    rdfs:label 'Repo Rate' ;
    rdfs:comment 'The annualized interest rate applied to the repo transaction, expressed as a decimal (e.g., 0.0525 for 5.25%).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:repoRateBasis rdf:type rdf:Property ;
    rdfs:label 'Repo Rate Basis' ;
    rdfs:comment 'The day count convention used to calculate repo interest: actual/360, actual/365, or 30/360.' ;
    rdfs:domain ind:RepoAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repoStatus rdf:type rdf:Property ;
    rdfs:label 'Repo Status' ;
    rdfs:comment 'Current lifecycle status of the repo agreement: active (in force), matured (far leg settled), terminated (early termination), cancelled (voided before settlement), or defaulted (counterparty default).' ;
    rdfs:domain ind:RepoAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repoType rdf:type rdf:Property ;
    rdfs:label 'Repo Type' ;
    rdfs:comment 'Classification of the repo structure: classic repo (legal title transfer with repurchase obligation), sell/buy-back (two separate sale transactions), tri-party (custodian-managed collateral), or hold-in-custody (bilateral custody).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repoLegId rdf:type rdf:Property ;
    rdfs:label 'Repo Leg Id' ;
    rdfs:comment 'Unique identifier for the repo leg. Primary key.' ;
    rdfs:domain ind:RepoLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:repoTransactionId rdf:type rdf:Property ;
    rdfs:label 'Repo Transaction Id' ;
    rdfs:comment 'Reference to the parent repo transaction that this leg belongs to.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RepoTransaction .

ind:settlementInstructionId rdf:type rdf:Property ;
    rdfs:label 'Settlement Instruction Id' ;
    rdfs:comment 'Foreign key linking to trade.settlement_instruction. Business justification: Each repo leg (near/far) generates settlement instructions for cash and securities. Operations teams match repo leg settlements to trade settlement instructions to reconcile nostro movements, resolve ' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SettlementInstruction .

ind:actualSettlementAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Settlement Amount' ;
    rdfs:comment 'The actual monetary amount that was settled for this leg, which may differ from the scheduled amount due to adjustments or partial settlements.' ;
    rdfs:domain ind:RepoLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualSettlementDate rdf:type rdf:Property ;
    rdfs:label 'Actual Settlement Date' ;
    rdfs:comment 'The actual date on which this leg settled, which may differ from the scheduled settlement date in case of delays or early settlement.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:counterpartySettlementAccount rdf:type rdf:Property ;
    rdfs:label 'Counterparty Settlement Account' ;
    rdfs:comment 'The counterparty\'s account number or IBAN used for settlement of this leg.' ;
    rdfs:domain ind:RepoLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:couponPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Coupon Payment Amount' ;
    rdfs:comment 'The coupon payment amount passed through to the counterparty for this leg, if applicable to coupon pass-through legs.' ;
    rdfs:domain ind:RepoLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:custodianInstructionReference rdf:type rdf:Property ;
    rdfs:label 'Custodian Instruction Reference' ;
    rdfs:comment 'Reference number for the settlement instruction sent to the custodian for this leg.' ;
    rdfs:domain ind:RepoLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failedSettlementDate rdf:type rdf:Property ;
    rdfs:label 'Failed Settlement Date' ;
    rdfs:comment 'The date on which the settlement failure was recorded for this leg.' ;
    rdfs:domain ind:RepoLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:failedSettlementReason rdf:type rdf:Property ;
    rdfs:label 'Failed Settlement Reason' ;
    rdfs:comment 'Reason code or description explaining why the settlement failed, if applicable (e.g., insufficient funds, securities unavailable, system error).' ;
    rdfs:domain ind:RepoLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:haircutAdjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Haircut Adjustment Amount' ;
    rdfs:comment 'The haircut adjustment applied to the collateral value for this leg, reflecting the discount applied to mitigate market risk.' ;
    rdfs:domain ind:RepoLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:legNotes rdf:type rdf:Property ;
    rdfs:label 'Leg Notes' ;
    rdfs:comment 'Free-text notes or comments related to this specific leg, capturing operational details, exceptions, or special instructions.' ;
    rdfs:domain ind:RepoLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Leg Reference Number' ;
    rdfs:comment 'External business reference number for this specific leg, used for operational tracking and reconciliation.' ;
    rdfs:domain ind:RepoLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Leg Sequence Number' ;
    rdfs:comment 'Sequential ordering of this leg within the parent repo transaction (1 for near leg, 2 for far leg, etc.).' ;
    rdfs:domain ind:RepoLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:legType rdf:type rdf:Property ;
    rdfs:label 'Leg Type' ;
    rdfs:comment 'Type of repo leg: near leg (initial purchase/sale), far leg (repurchase/resale), or coupon pass-through leg.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marginCallAdjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Margin Call Adjustment Amount' ;
    rdfs:comment 'Any margin call adjustment amount applied to this leg\'s settlement, reflecting variation margin requirements.' ;
    rdfs:domain ind:RepoLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextRetryDate rdf:type rdf:Property ;
    rdfs:label 'Next Retry Date' ;
    rdfs:comment 'The scheduled date for the next settlement retry attempt, if the leg has failed settlement.' ;
    rdfs:domain ind:RepoLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rtgsReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Rtgs Reference Number' ;
    rdfs:comment 'Real-Time Gross Settlement system reference number for this leg\'s payment settlement.' ;
    rdfs:domain ind:RepoLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementConfirmationDate rdf:type rdf:Property ;
    rdfs:label 'Settlement Confirmation Date' ;
    rdfs:comment 'The date on which settlement confirmation was received from the custodian or settlement system for this leg.' ;
    rdfs:domain ind:RepoLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:settlementFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Settlement Fee Amount' ;
    rdfs:comment 'Fees charged by the settlement agent, custodian, or payment system for processing this leg\'s settlement.' ;
    rdfs:domain ind:RepoLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementInstructionDate rdf:type rdf:Property ;
    rdfs:label 'Settlement Instruction Date' ;
    rdfs:comment 'The date on which settlement instructions were issued to the custodian or settlement agent for this leg.' ;
    rdfs:domain ind:RepoLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:settlementRetryCount rdf:type rdf:Property ;
    rdfs:label 'Settlement Retry Count' ;
    rdfs:comment 'Number of times settlement has been attempted for this leg after initial failure.' ;
    rdfs:domain ind:RepoLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:settlementVarianceAmount rdf:type rdf:Property ;
    rdfs:label 'Settlement Variance Amount' ;
    rdfs:comment 'The difference between the scheduled settlement amount and the actual settlement amount, capturing any discrepancies or adjustments.' ;
    rdfs:domain ind:RepoLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sftrReportingStatus rdf:type rdf:Property ;
    rdfs:label 'Sftr Reporting Status' ;
    rdfs:comment 'Status of SFTR regulatory reporting for this leg: not required, pending submission, submitted, accepted by regulator, or rejected.' ;
    rdfs:domain ind:RepoLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sftrUti rdf:type rdf:Property ;
    rdfs:label 'Sftr Uti' ;
    rdfs:comment 'Unique Transaction Identifier assigned for SFTR regulatory reporting purposes for this leg.' ;
    rdfs:domain ind:RepoLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:swiftMessageReference rdf:type rdf:Property ;
    rdfs:label 'Swift Message Reference' ;
    rdfs:comment 'SWIFT message reference number (e.g., MT202, MT300) associated with this leg\'s settlement instruction.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeRepositoryReference rdf:type rdf:Property ;
    rdfs:label 'Trade Repository Reference' ;
    rdfs:comment 'Reference number assigned by the trade repository where this leg\'s transaction details are reported.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variationMarginId rdf:type rdf:Property ;
    rdfs:label 'Variation Margin Id' ;
    rdfs:comment 'Unique identifier for the variation margin settlement record.' ;
    rdfs:domain ind:VariationMargin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryVariationPartyId rdf:type rdf:Property ;
    rdfs:label 'Primary Variation Party Id' ;
    rdfs:comment 'Reference to the central clearing house if the variation margin is for a cleared derivative transaction (e.g., LCH, CME, ICE Clear).' ;
    rdfs:domain ind:VariationMargin ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:calculationAgent rdf:type rdf:Property ;
    rdfs:label 'Calculation Agent' ;
    rdfs:comment 'The party responsible for calculating the variation margin amount, as designated in the CSA. Typically one of the counterparties or a third-party agent.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collateralType rdf:type rdf:Property ;
    rdfs:label 'Collateral Type' ;
    rdfs:comment 'The type of collateral used to satisfy the variation margin requirement. Cash is most common for VM; some CSAs allow securities with appropriate haircuts.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fxRate rdf:type rdf:Property ;
    rdfs:label 'Fx Rate' ;
    rdfs:comment 'The foreign exchange rate used to convert the portfolio mark-to-market value to the variation margin settlement currency, if different.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fxRateSource rdf:type rdf:Property ;
    rdfs:label 'Fx Rate Source' ;
    rdfs:comment 'The source of the FX rate used for currency conversion, such as Bloomberg, Reuters, ECB reference rates, or as specified in the CSA.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interestAccrualFlag rdf:type rdf:Property ;
    rdfs:label 'Interest Accrual Flag' ;
    rdfs:comment 'Indicates whether interest accrues on the variation margin cash balance held, as specified in the CSA terms.' ;
    rdfs:domain ind:VariationMargin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:portfolioMtmValue rdf:type rdf:Property ;
    rdfs:label 'Portfolio Mtm Value' ;
    rdfs:comment 'The total mark-to-market value of the derivative portfolio within the netting set at the calculation date, used as the basis for variation margin calculation.' ;
    rdfs:domain ind:VariationMargin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:previousVmBalance rdf:type rdf:Property ;
    rdfs:label 'Previous Vm Balance' ;
    rdfs:comment 'The cumulative variation margin balance from the previous calculation date, used to determine the incremental margin call amount.' ;
    rdfs:domain ind:VariationMargin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responseDeadline rdf:type rdf:Property ;
    rdfs:label 'Response Deadline' ;
    rdfs:comment 'The deadline by which the counterparty must respond to or fulfill the variation margin call, as specified in the CSA.' ;
    rdfs:domain ind:VariationMargin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:tradePopulationCount rdf:type rdf:Property ;
    rdfs:label 'Trade Population Count' ;
    rdfs:comment 'The number of derivative trades included in the netting set for this variation margin calculation.' ;
    rdfs:domain ind:VariationMargin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vmAmount rdf:type rdf:Property ;
    rdfs:label 'Vm Amount' ;
    rdfs:comment 'The calculated variation margin amount to be exchanged. Positive values indicate amounts receivable by the reporting entity; negative values indicate amounts payable.' ;
    rdfs:domain ind:VariationMargin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vmDirection rdf:type rdf:Property ;
    rdfs:label 'Vm Direction' ;
    rdfs:comment 'Indicates whether the reporting entity is paying or receiving the variation margin. Pay indicates cash outflow; receive indicates cash inflow.' ;
    rdfs:domain ind:VariationMargin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amlAlertId rdf:type rdf:Property ;
    rdfs:label 'Aml Alert Id' ;
    rdfs:comment 'Unique identifier for the AML transaction monitoring alert generated by the financial crime detection engine.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AmlAlert .

ind:detectionBranchId rdf:type rdf:Property ;
    rdfs:label 'Detection Branch Id' ;
    rdfs:comment 'Foreign key linking to channel.branch. Business justification: Branch-originated AML alerts require branch attribution for investigation context, regulatory exam support, and branch-level BSA/AML program effectiveness assessment. Critical for targeted examiner re' ;
    rdfs:domain ind:AmlAlert ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Branch .

ind:detectionChannelId rdf:type rdf:Property ;
    rdfs:label 'Detection Channel Id' ;
    rdfs:comment 'Foreign key linking to channel.channel. Business justification: AML alerts must track detection channel (branch, ATM, digital, wire) for BSA/AML regulatory reporting, pattern analysis, and FinCEN SAR filing requirements. Channel attribution is mandatory for regula' ;
    rdfs:domain ind:AmlAlert ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:adverseMediaFlag rdf:type rdf:Property ;
    rdfs:label 'Adverse Media Flag' ;
    rdfs:comment 'Indicator whether adverse media or negative news has been identified for the customer or counterparty during the alert review process.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:alertNarrative rdf:type rdf:Property ;
    rdfs:label 'Alert Narrative' ;
    rdfs:comment 'Detailed narrative generated by the detection system describing the suspicious pattern, transactions, and risk indicators that triggered the alert.' ;
    rdfs:domain ind:AmlAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertNumber rdf:type rdf:Property ;
    rdfs:label 'Alert Number' ;
    rdfs:comment 'Business-facing unique reference number for the alert, typically displayed to analysts and used in case management workflows.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertStatus rdf:type rdf:Property ;
    rdfs:label 'Alert Status' ;
    rdfs:comment 'Current workflow status of the alert in the Level 1 review process (new, assigned to analyst, under review, escalated to case, closed, reopened).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analystNotes rdf:type rdf:Property ;
    rdfs:label 'Analyst Notes' ;
    rdfs:comment 'Free-text notes entered by the reviewing analyst documenting their investigation findings, rationale for disposition, and any additional context.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentDate rdf:type rdf:Property ;
    rdfs:label 'Assignment Date' ;
    rdfs:comment 'Date when the alert was assigned to an analyst for review.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:counterpartyCountryCode rdf:type rdf:Property ;
    rdfs:label 'Counterparty Country Code' ;
    rdfs:comment 'Three-letter ISO 3166 country code of the counterparty\'s jurisdiction, used to assess geographic risk.' ;
    rdfs:domain ind:AmlAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionDate rdf:type rdf:Property ;
    rdfs:label 'Detection Date' ;
    rdfs:comment 'Date when the alert was generated by the AML transaction monitoring system.' ;
    rdfs:domain ind:AmlAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:detectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Detection Timestamp' ;
    rdfs:comment 'Precise timestamp when the alert was generated by the detection engine, capturing the exact moment the threshold or rule was breached.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:highRiskGeographyFlag rdf:type rdf:Property ;
    rdfs:label 'High Risk Geography Flag' ;
    rdfs:comment 'Indicator whether the alert involves transactions with countries or jurisdictions identified as high-risk for money laundering or terrorist financing per FATF or internal risk ratings.' ;
    rdfs:domain ind:AmlAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pepFlag rdf:type rdf:Property ;
    rdfs:label 'Pep Flag' ;
    rdfs:comment 'Indicator whether the customer or beneficial owner associated with the alert is classified as a Politically Exposed Person, requiring enhanced due diligence.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Review Completion Timestamp' ;
    rdfs:comment 'Timestamp when the analyst completed the review and assigned a disposition to the alert.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reviewStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Review Start Timestamp' ;
    rdfs:comment 'Timestamp when the analyst began reviewing the alert, marking the start of the investigation workflow.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:riskScore rdf:type rdf:Property ;
    rdfs:label 'Risk Score' ;
    rdfs:comment 'Quantitative risk score assigned by the detection engine indicating the severity or likelihood of money laundering activity, typically on a 0-100 or 0-1000 scale.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sarFiledFlag rdf:type rdf:Property ;
    rdfs:label 'Sar Filed Flag' ;
    rdfs:comment 'Indicator whether a Suspicious Activity Report was filed with FinCEN as a result of this alert and subsequent investigation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sarFilingDate rdf:type rdf:Property ;
    rdfs:label 'Sar Filing Date' ;
    rdfs:comment 'Date when the Suspicious Activity Report was filed with FinCEN, if applicable.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:slaDeadline rdf:type rdf:Property ;
    rdfs:label 'Sla Deadline' ;
    rdfs:comment 'Target date and time by which the alert must be reviewed and dispositioned per internal SLA policies and regulatory requirements.' ;
    rdfs:domain ind:AmlAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalAmount rdf:type rdf:Property ;
    rdfs:label 'Total Amount' ;
    rdfs:comment 'Aggregate monetary value of all transactions associated with the alert, expressed in the account\'s base currency.' ;
    rdfs:domain ind:AmlAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originatingChannelId rdf:type rdf:Property ;
    rdfs:label 'Originating Channel Id' ;
    rdfs:comment 'Foreign key linking to channel.channel. Business justification: AML cases track originating channel for risk assessment, SAR narrative requirements (FinCEN requires channel disclosure), and channel-specific typology detection. Essential for regulatory reporting an' ;
    rdfs:domain ind:AmlCase ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:primaryPartyId rdf:type rdf:Property ;
    rdfs:label 'Primary Party Id' ;
    rdfs:comment 'Identifier of the primary customer or entity under investigation in this case.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:sarFilingId rdf:type rdf:Property ;
    rdfs:label 'Sar Filing Id' ;
    rdfs:comment 'BSA identifier assigned by FinCEN upon SAR submission.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SarFiling .

ind:alertCount rdf:type rdf:Property ;
    rdfs:label 'Alert Count' ;
    rdfs:comment 'Number of AML alerts that were escalated and aggregated into this case.' ;
    rdfs:domain ind:AmlCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:caseClosedDate rdf:type rdf:Property ;
    rdfs:label 'Case Closed Date' ;
    rdfs:comment 'Date when the AML case investigation was completed and the case was closed.' ;
    rdfs:domain ind:AmlCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:caseClosedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Case Closed Timestamp' ;
    rdfs:comment 'Precise timestamp when the AML case investigation was completed and the case was closed.' ;
    rdfs:domain ind:AmlCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:caseNumber rdf:type rdf:Property ;
    rdfs:label 'Case Number' ;
    rdfs:comment 'Business-facing unique case identifier used for regulatory reporting and internal tracking. Format: AAA-YYYY-NNNNNN.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseOpenedDate rdf:type rdf:Property ;
    rdfs:label 'Case Opened Date' ;
    rdfs:comment 'Date when the AML case was officially opened for investigation.' ;
    rdfs:domain ind:AmlCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:caseOpenedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Case Opened Timestamp' ;
    rdfs:comment 'Precise timestamp when the AML case was officially opened for investigation.' ;
    rdfs:domain ind:AmlCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:caseStatus rdf:type rdf:Property ;
    rdfs:label 'Case Status' ;
    rdfs:comment 'Current lifecycle status of the AML case investigation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseType rdf:type rdf:Property ;
    rdfs:label 'Case Type' ;
    rdfs:comment 'Classification of the financial crime case type being investigated.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctrFilingDate rdf:type rdf:Property ;
    rdfs:label 'Ctr Filing Date' ;
    rdfs:comment 'Date when the CTR was filed with FinCEN.' ;
    rdfs:domain ind:AmlCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ctrFilingRequired rdf:type rdf:Property ;
    rdfs:label 'Ctr Filing Required' ;
    rdfs:comment 'Indicates whether a Currency Transaction Report must be filed for this case.' ;
    rdfs:domain ind:AmlCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dispositionOutcome rdf:type rdf:Property ;
    rdfs:label 'Disposition Outcome' ;
    rdfs:comment 'Final outcome or resolution of the case investigation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dueDate rdf:type rdf:Property ;
    rdfs:label 'Due Date' ;
    rdfs:comment 'Target date by which the case investigation must be completed to meet regulatory timelines.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:investigationNarrative rdf:type rdf:Property ;
    rdfs:label 'Investigation Narrative' ;
    rdfs:comment 'Detailed narrative documenting the investigation findings, analysis, and rationale for case disposition.' ;
    rdfs:domain ind:AmlCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lawEnforcementAgency rdf:type rdf:Property ;
    rdfs:label 'Law Enforcement Agency' ;
    rdfs:comment 'Name of the law enforcement agency to which the case was referred.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lawEnforcementReferral rdf:type rdf:Property ;
    rdfs:label 'Law Enforcement Referral' ;
    rdfs:comment 'Indicates whether the case has been referred to law enforcement agencies for further investigation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ofacScreeningResult rdf:type rdf:Property ;
    rdfs:label 'Ofac Screening Result' ;
    rdfs:comment 'Result of OFAC sanctions screening performed on the parties involved in this case.' ;
    rdfs:domain ind:AmlCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Primary Account Number' ;
    rdfs:comment 'Account number of the primary account involved in the suspicious activity.' ;
    rdfs:domain ind:AmlCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewedBy rdf:type rdf:Property ;
    rdfs:label 'Reviewed By' ;
    rdfs:comment 'User ID or name of the senior compliance officer or manager who reviewed and approved the case disposition.' ;
    rdfs:domain ind:AmlCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reviewed Timestamp' ;
    rdfs:comment 'Timestamp when the case was reviewed and approved by senior compliance management.' ;
    rdfs:domain ind:AmlCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sanctionsListMatch rdf:type rdf:Property ;
    rdfs:label 'Sanctions List Match' ;
    rdfs:comment 'Name of the sanctions list (e.g., SDN, EU Sanctions) if a match was identified during screening.' ;
    rdfs:domain ind:AmlCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sarFilingRequired rdf:type rdf:Property ;
    rdfs:label 'Sar Filing Required' ;
    rdfs:comment 'Indicates whether a Suspicious Activity Report must be filed with FinCEN for this case.' ;
    rdfs:domain ind:AmlCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalTransactionAmount rdf:type rdf:Property ;
    rdfs:label 'Total Transaction Amount' ;
    rdfs:comment 'Aggregate monetary value of all transactions under investigation in this case.' ;
    rdfs:domain ind:AmlCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:breachId rdf:type rdf:Property ;
    rdfs:label 'Breach Id' ;
    rdfs:comment 'Primary key for breach' ;
    rdfs:domain ind:Breach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedPartyId rdf:type rdf:Property ;
    rdfs:label 'Affected Party Id' ;
    rdfs:comment 'Foreign key linking to customer.party. Business justification: Compliance breaches (KYC failures, transaction monitoring gaps, data privacy violations) often involve specific customers. Regulatory reporting and remediation require identifying affected parties. Es' ;
    rdfs:domain ind:Breach ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:examFindingId rdf:type rdf:Property ;
    rdfs:label 'Exam Finding Id' ;
    rdfs:comment 'Reference to a regulatory examination finding if the breach was identified during a regulatory exam. Null if discovered internally.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ExamFinding .

ind:relatedBreachId rdf:type rdf:Property ;
    rdfs:label 'Related Breach Id' ;
    rdfs:comment 'Reference to a prior breach record if this is a recurrence or related incident. Null if this is a standalone breach.' ;
    rdfs:domain ind:Breach ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Breach .

ind:affectedBusinessUnit rdf:type rdf:Property ;
    rdfs:label 'Affected Business Unit' ;
    rdfs:comment 'Name or code of the Line of Business (LOB) or organizational unit where the breach occurred (e.g., Retail Banking, Investment Banking, Wealth Management, Treasury).' ;
    rdfs:domain ind:Breach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Closure Approved By' ;
    rdfs:comment 'Name or identifier of the individual or committee that approved the closure of the breach (e.g., Chief Compliance Officer, Compliance Committee, Board Risk Committee).' ;
    rdfs:domain ind:Breach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctrFiledFlag rdf:type rdf:Property ;
    rdfs:label 'Ctr Filed Flag' ;
    rdfs:comment 'Indicates whether a Currency Transaction Report (CTR) was filed with FinCEN as a result of this breach (True) or not (False).' ;
    rdfs:domain ind:Breach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discoveryDate rdf:type rdf:Property ;
    rdfs:label 'Discovery Date' ;
    rdfs:comment 'Date when the breach was first identified or discovered by internal controls, audit, or monitoring systems.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:discoveryMethod rdf:type rdf:Property ;
    rdfs:label 'Discovery Method' ;
    rdfs:comment 'Method or channel through which the breach was discovered: internal audit, transaction monitoring system, customer complaint, regulatory examination, self-assessment, or whistleblower report.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:occurrenceDate rdf:type rdf:Property ;
    rdfs:label 'Occurrence Date' ;
    rdfs:comment 'Estimated or actual date when the breach event occurred or when the control failure first manifested.' ;
    rdfs:domain ind:Breach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recurrenceFlag rdf:type rdf:Property ;
    rdfs:label 'Recurrence Flag' ;
    rdfs:comment 'Indicates whether this breach is a recurrence of a previously identified and remediated breach (True) or a new, first-time breach (False).' ;
    rdfs:domain ind:Breach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatorReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Regulator Reference Number' ;
    rdfs:comment 'Reference or case number assigned by the regulatory authority upon notification (e.g., SAR filing number, examination reference). Null if not applicable.' ;
    rdfs:domain ind:Breach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Date' ;
    rdfs:comment 'Date when the breach was formally notified to the relevant regulatory authority (e.g., Federal Reserve, OCC, FinCEN, SEC). Null if notification was not required.' ;
    rdfs:domain ind:Breach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryNotificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Required Flag' ;
    rdfs:comment 'Indicates whether the breach must be reported to a regulatory authority (True) or can be managed internally (False).' ;
    rdfs:domain ind:Breach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remediationActionPlan rdf:type rdf:Property ;
    rdfs:label 'Remediation Action Plan' ;
    rdfs:comment 'Detailed description of corrective actions, process improvements, system enhancements, or policy changes implemented or planned to address the breach and prevent recurrence.' ;
    rdfs:domain ind:Breach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Remediation Completion Date' ;
    rdfs:comment 'Actual date when all remediation actions were completed and validated. Null if remediation is still in progress.' ;
    rdfs:domain ind:Breach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingDate rdf:type rdf:Property ;
    rdfs:label 'Reporting Date' ;
    rdfs:comment 'Date when the breach was formally reported to senior management, compliance committee, or governance body.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceRegulatoryFilingId rdf:type rdf:Property ;
    rdfs:label 'Compliance Regulatory Filing Id' ;
    rdfs:comment 'Unique identifier for the regulatory filing record. Primary key for the compliance regulatory filing entity.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ComplianceRegulatoryFiling .

ind:filingBranchId rdf:type rdf:Property ;
    rdfs:label 'Filing Branch Id' ;
    rdfs:comment 'Foreign key linking to channel.branch. Business justification: CTR and SAR filings require conducting location (branch) as mandatory FinCEN BSA E-Filing field. Branch attribution enables filing accuracy validation, branch-level BSA program assessment, and regulat' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Branch .

ind:accountBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Account Balance Amount' ;
    rdfs:comment 'Account balance or value as of the end of the FATCA or CRS reporting year. This is the total value of financial assets held in the account, including deposits, securities, and other investments.' ;
    rdfs:domain ind:ComplianceRegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accountHolderTin rdf:type rdf:Property ;
    rdfs:label 'Account Holder Tin' ;
    rdfs:comment 'Tax identification number of the account holder for FATCA or CRS reporting. For U.S. persons, this is the Social Security Number (SSN) or Employer Identification Number (EIN). For foreign persons, this is the foreign tax identification number.' ;
    rdfs:domain ind:ComplianceRegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acknowledgmentDate rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Date' ;
    rdfs:comment 'Date on which the regulatory agency acknowledged receipt of the filing. For FinCEN filings, this is the date the BSA E-Filing System confirms successful submission.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Submission Date' ;
    rdfs:comment 'Date on which the filing was actually submitted to the regulatory agency. Used to track timeliness and compliance with submission deadlines.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:amendmentIndicator rdf:type rdf:Property ;
    rdfs:label 'Amendment Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this filing is an amendment or correction to a previously submitted filing. True = this is an amended filing, False = this is an original filing.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conductingPartyIdentifier rdf:type rdf:Property ;
    rdfs:label 'Conducting Party Identifier' ;
    rdfs:comment 'Unique identifier for the conducting party, such as driver\'s license number, passport number, or other government-issued identification. Required for CTR filings to verify the identity of the person conducting the transaction.' ;
    rdfs:domain ind:ComplianceRegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conductingPartyName rdf:type rdf:Property ;
    rdfs:label 'Conducting Party Name' ;
    rdfs:comment 'Name of the individual or entity that conducted the transaction reported in a CTR filing. This is the person who physically presented the currency or initiated the transaction.' ;
    rdfs:domain ind:ComplianceRegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityFlag rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Flag' ;
    rdfs:comment 'Boolean flag indicating whether this filing contains confidential or sensitive information that requires special handling and access controls. True = confidential, False = standard handling. SAR filings are always confidential by law.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exemptionStatus rdf:type rdf:Property ;
    rdfs:label 'Exemption Status' ;
    rdfs:comment 'Indicates whether the transaction or customer is exempt from CTR reporting requirements under FinCEN exemption rules. Phase I exemptions apply to banks and government entities. Phase II exemptions apply to certain non-listed businesses and payroll customers.' ;
    rdfs:domain ind:ComplianceRegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fatcaJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Fatca Jurisdiction' ;
    rdfs:comment 'Three-letter ISO country code representing the jurisdiction to which FATCA or CRS reporting is submitted. For FATCA, this is typically the jurisdiction of the foreign financial institution. For CRS, this is the jurisdiction of the account holder\'s tax residency.' ;
    rdfs:domain ind:ComplianceRegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fatcaReportingYear rdf:type rdf:Property ;
    rdfs:label 'Fatca Reporting Year' ;
    rdfs:comment 'Calendar year for which FATCA or CRS reporting is being submitted. FATCA requires annual reporting of financial accounts held by U.S. persons at foreign financial institutions, and CRS requires reporting of accounts held by foreign tax residents.' ;
    rdfs:domain ind:ComplianceRegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fincenTrackingNumber rdf:type rdf:Property ;
    rdfs:label 'Fincen Tracking Number' ;
    rdfs:comment 'Unique tracking number assigned by FinCEN upon successful submission of a BSA filing (SAR, CTR, FBAR, Form 8300). This number is used for all subsequent correspondence and inquiries regarding the filing.' ;
    rdfs:domain ind:ComplianceRegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incomeAmount rdf:type rdf:Property ;
    rdfs:label 'Income Amount' ;
    rdfs:comment 'Total income paid or credited to the account during the FATCA or CRS reporting year. Includes interest, dividends, gross proceeds from sales, and other income types as defined by FATCA and CRS regulations.' ;
    rdfs:domain ind:ComplianceRegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preparerContactPhone rdf:type rdf:Property ;
    rdfs:label 'Preparer Contact Phone' ;
    rdfs:comment 'Phone number of the preparer for follow-up inquiries by the regulatory agency. Required on many regulatory filings to facilitate communication.' ;
    rdfs:domain ind:ComplianceRegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preparerName rdf:type rdf:Property ;
    rdfs:label 'Preparer Name' ;
    rdfs:comment 'Name of the compliance officer, analyst, or staff member who prepared the regulatory filing. Used for accountability, audit trail, and quality control purposes.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorFilingReference rdf:type rdf:Property ;
    rdfs:label 'Prior Filing Reference' ;
    rdfs:comment 'Reference number or tracking identifier of the original filing that this amendment or correction is replacing. Required when amendment_indicator is True.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAgency rdf:type rdf:Property ;
    rdfs:label 'Regulatory Agency' ;
    rdfs:comment 'Governing body or regulatory authority to which the filing is submitted. FinCEN = Financial Crimes Enforcement Network, Fed = Federal Reserve System, OCC = Office of the Comptroller of the Currency, FDIC = Federal Deposit Insurance Corporation, SEC = Securities and Exchange Commission, FINRA = Financial Industry Regulatory Authority, CFTC = Commodity Futures Trading Commission, CFPB = Consumer Financial Protection Bureau, IRS = Internal Revenue Service, EBA = European Banking Authority, PRA = Prudential Regulation Authority. [ENUM-REF-CANDIDATE: FinCEN|Fed|OCC|FDIC|SEC|FINRA|CFTC|CFPB|IRS|EBA|PRA — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ComplianceRegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Retention Expiration Date' ;
    rdfs:comment 'Date on which the regulatory filing record is eligible for archival or deletion based on regulatory retention requirements. BSA records must be retained for 5 years from the date of filing. Other filings may have different retention periods.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:submissionMethod rdf:type rdf:Property ;
    rdfs:label 'Submission Method' ;
    rdfs:comment 'Technical method or channel used to submit the filing to the regulatory agency. BSA E-Filing = FinCEN\'s electronic filing system, FRB E-Filing = Federal Reserve electronic submission, SEC EDGAR = SEC\'s Electronic Data Gathering Analysis and Retrieval system, FINRA Gateway = FINRA\'s submission portal, Manual Upload = web-based manual submission, API = application programming interface, SFTP = secure file transfer protocol. [ENUM-REF-CANDIDATE: BSA E-Filing|FRB E-Filing|SEC EDGAR|FINRA Gateway|Manual Upload|API|SFTP — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suspiciousActivityAmount rdf:type rdf:Property ;
    rdfs:label 'Suspicious Activity Amount' ;
    rdfs:comment 'Total dollar amount involved in the suspicious activity reported in a SAR filing. Represents the cumulative value of transactions or account activity that triggered the filing.' ;
    rdfs:domain ind:ComplianceRegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:suspiciousActivityDescription rdf:type rdf:Property ;
    rdfs:label 'Suspicious Activity Description' ;
    rdfs:comment 'Detailed narrative description of the suspicious activity, including facts, circumstances, and reasons for suspicion. This is the free-text explanation provided in Part V of the SAR form and is critical for law enforcement review.' ;
    rdfs:domain ind:ComplianceRegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suspiciousActivityType rdf:type rdf:Property ;
    rdfs:label 'Suspicious Activity Type' ;
    rdfs:comment 'Classification of the type of suspicious activity reported in a SAR filing. Examples include structuring, money laundering, terrorist financing, fraud, identity theft, elder financial exploitation, cyber event, or other financial crimes. [ENUM-REF-CANDIDATE: Structuring|Money Laundering|Terrorist Financing|Fraud|Identity Theft|Elder Financial Exploitation|Cyber Event|Bribery/Corruption|Embezzlement|Check Fraud|Wire Fraud|ACH Fraud|Credit Card Fraud|Mortgage Loan Fraud|Consumer Loan Fraud|Trade-Based Money Laundering|Bulk Cash Smuggling|Funnel Account|Unlicensed Money Services Business|Other — promote to reference product]' ;
    rdfs:domain ind:ComplianceRegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyCurrencyId rdf:type rdf:Property ;
    rdfs:label 'Penalty Currency Id' ;
    rdfs:comment 'Foreign key linking to reference.currency. Business justification: Consent orders specify civil money penalties in specific currencies; currency reference essential for payment tracking, financial reporting, and multi-jurisdiction penalty aggregation. Direct operatio' ;
    rdfs:domain ind:ConsentOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:affectedCustomerCount rdf:type rdf:Property ;
    rdfs:label 'Affected Customer Count' ;
    rdfs:comment 'Estimated or actual number of customers impacted by the deficiencies addressed in the consent order.' ;
    rdfs:domain ind:ConsentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:boardResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Board Resolution Date' ;
    rdfs:comment 'Date on which the board of directors formally approved the resolution accepting the consent order terms.' ;
    rdfs:domain ind:ConsentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:boardResolutionNumber rdf:type rdf:Property ;
    rdfs:label 'Board Resolution Number' ;
    rdfs:comment 'Internal board of directors resolution number documenting formal acceptance and acknowledgment of the consent order obligations.' ;
    rdfs:domain ind:ConsentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceDeadline rdf:type rdf:Property ;
    rdfs:label 'Compliance Deadline' ;
    rdfs:comment 'The final date by which the institution must achieve full compliance with all remediation requirements specified in the consent order.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentUrl rdf:type rdf:Property ;
    rdfs:label 'Document Url' ;
    rdfs:comment 'Uniform Resource Locator pointing to the official consent order document or public disclosure on the regulatory agency website.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedRestitutionAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Restitution Amount' ;
    rdfs:comment 'Estimated total monetary amount to be paid to affected customers as restitution or remediation under the consent order terms.' ;
    rdfs:domain ind:ConsentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:independentConsultantName rdf:type rdf:Property ;
    rdfs:label 'Independent Consultant Name' ;
    rdfs:comment 'Name of the independent consulting firm or individual engaged to provide oversight or validation of remediation activities as required by the consent order.' ;
    rdfs:domain ind:ConsentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:independentConsultantRequired rdf:type rdf:Property ;
    rdfs:label 'Independent Consultant Required' ;
    rdfs:comment 'Indicates whether the consent order mandates engagement of an independent third-party consultant to oversee or validate remediation efforts.' ;
    rdfs:domain ind:ConsentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:internalCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Internal Case Number' ;
    rdfs:comment 'Internal compliance case management system identifier linking this consent order to related remediation activities and tracking records.' ;
    rdfs:domain ind:ConsentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingAgency rdf:type rdf:Property ;
    rdfs:label 'Issuing Agency' ;
    rdfs:comment 'The regulatory body or governing authority that issued the consent order or enforcement action. [ENUM-REF-CANDIDATE: fed|occ|fdic|cfpb|fincen|sec|finra — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ConsentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastStatusUpdateDate rdf:type rdf:Property ;
    rdfs:label 'Last Status Update Date' ;
    rdfs:comment 'Date of the most recent status update or progress report submitted to the regulatory agency regarding consent order compliance.' ;
    rdfs:domain ind:ConsentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalEntityIdentifier rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Identifier' ;
    rdfs:comment 'ISO 17442 Legal Entity Identifier for the institution subject to the consent order.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lookbackPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Lookback Period End Date' ;
    rdfs:comment 'Ending date of the historical review or lookback period mandated by the consent order for transaction or account remediation.' ;
    rdfs:domain ind:ConsentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lookbackPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Lookback Period Start Date' ;
    rdfs:comment 'Beginning date of the historical review or lookback period mandated by the consent order for transaction or account remediation.' ;
    rdfs:domain ind:ConsentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:milestoneCount rdf:type rdf:Property ;
    rdfs:label 'Milestone Count' ;
    rdfs:comment 'Total number of interim compliance milestones or checkpoints established by the regulatory agency for tracking remediation progress.' ;
    rdfs:domain ind:ConsentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:orderStatus rdf:type rdf:Property ;
    rdfs:label 'Order Status' ;
    rdfs:comment 'Current lifecycle status of the consent order indicating compliance state and enforcement standing.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyPaidDate rdf:type rdf:Property ;
    rdfs:label 'Penalty Paid Date' ;
    rdfs:comment 'The date on which the assessed civil money penalty was paid in full to the regulatory agency.' ;
    rdfs:domain ind:ConsentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:publicDisclosureDate rdf:type rdf:Property ;
    rdfs:label 'Public Disclosure Date' ;
    rdfs:comment 'The date on which the consent order was made publicly available by the regulatory agency.' ;
    rdfs:domain ind:ConsentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryCorrespondenceCount rdf:type rdf:Property ;
    rdfs:label 'Regulatory Correspondence Count' ;
    rdfs:comment 'Total number of formal correspondence items exchanged with the regulatory agency regarding this consent order.' ;
    rdfs:domain ind:ConsentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:remediationProgramName rdf:type rdf:Property ;
    rdfs:label 'Remediation Program Name' ;
    rdfs:comment 'Name or title of the internal remediation program or project established to address consent order requirements.' ;
    rdfs:domain ind:ConsentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredActions rdf:type rdf:Property ;
    rdfs:label 'Required Actions' ;
    rdfs:comment 'Comprehensive list of corrective actions, remediation steps, and compliance measures mandated by the regulatory agency to address identified deficiencies.' ;
    rdfs:domain ind:ConsentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleExecutive rdf:type rdf:Property ;
    rdfs:label 'Responsible Executive' ;
    rdfs:comment 'Name or identifier of the senior executive officer designated as accountable for overseeing consent order remediation and compliance.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restitutionRequired rdf:type rdf:Property ;
    rdfs:label 'Restitution Required' ;
    rdfs:comment 'Indicates whether the consent order requires the institution to provide financial restitution or remediation payments to affected customers.' ;
    rdfs:domain ind:ConsentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:subjectMatter rdf:type rdf:Property ;
    rdfs:label 'Subject Matter' ;
    rdfs:comment 'Detailed description of the regulatory deficiencies, violations, or areas of concern that prompted the enforcement action.' ;
    rdfs:domain ind:ConsentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationCategory rdf:type rdf:Property ;
    rdfs:label 'Violation Category' ;
    rdfs:comment 'Primary regulatory domain or compliance area in which the deficiency occurred. [ENUM-REF-CANDIDATE: aml|kyc|bsa|ofac_sanctions|capital_adequacy|liquidity|consumer_protection|fair_lending|sox|data_privacy|operational_risk — promote to reference product]' ;
    rdfs:domain ind:ConsentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctrFilingId rdf:type rdf:Property ;
    rdfs:label 'Ctr Filing Id' ;
    rdfs:comment 'Unique identifier for the Currency Transaction Report filing record. Primary key.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CtrFiling .

ind:fraudCaseId rdf:type rdf:Property ;
    rdfs:label 'Fraud Case Id' ;
    rdfs:comment 'Foreign key linking to fraud.case. Business justification: CTR filings may be associated with structuring fraud cases. Banks link CTRs to fraud cases when cash transactions are part of a fraud investigation for SAR coordination and regulatory reporting.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Case .

ind:fraudSarFilingId rdf:type rdf:Property ;
    rdfs:label 'Fraud Sar Filing Id' ;
    rdfs:comment 'Foreign key reference to a related SAR filing if suspicious activity was also identified.' ;
    rdfs:domain ind:CtrFiling ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SarFiling .

ind:aggregatedTransactionsFlag rdf:type rdf:Property ;
    rdfs:label 'Aggregated Transactions Flag' ;
    rdfs:comment 'Indicates whether this CTR represents multiple transactions aggregated to exceed the $10,000 threshold.' ;
    rdfs:domain ind:CtrFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:amendmentFlag rdf:type rdf:Property ;
    rdfs:label 'Amendment Flag' ;
    rdfs:comment 'Indicates whether this CTR filing is an amendment to a previously filed CTR.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:armoredCarServiceFlag rdf:type rdf:Property ;
    rdfs:label 'Armored Car Service Flag' ;
    rdfs:comment 'Indicates whether the cash transaction involved an armored car service.' ;
    rdfs:domain ind:CtrFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:atmTransactionFlag rdf:type rdf:Property ;
    rdfs:label 'Atm Transaction Flag' ;
    rdfs:comment 'Indicates whether the cash transaction occurred at an ATM.' ;
    rdfs:domain ind:CtrFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bsaIdentifier rdf:type rdf:Property ;
    rdfs:label 'Bsa Identifier' ;
    rdfs:comment 'FinCEN-assigned BSA identifier for this CTR filing, used for regulatory tracking and acknowledgment.' ;
    rdfs:domain ind:CtrFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Filing Deadline Date' ;
    rdfs:comment 'Regulatory deadline by which this CTR must be filed (typically 15 calendar days after the transaction date).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:filingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Filing Timestamp' ;
    rdfs:comment 'Precise timestamp when the CTR was submitted to FinCEN BSA E-Filing System.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:multiplePersonsFlag rdf:type rdf:Property ;
    rdfs:label 'Multiple Persons Flag' ;
    rdfs:comment 'Indicates whether multiple persons were involved in conducting the reportable transaction(s).' ;
    rdfs:domain ind:CtrFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preparerPhoneNumber rdf:type rdf:Property ;
    rdfs:label 'Preparer Phone Number' ;
    rdfs:comment 'Contact phone number for the bank employee who prepared the CTR.' ;
    rdfs:domain ind:CtrFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorFilingReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Prior Filing Reference Number' ;
    rdfs:comment 'Reference number of the original CTR filing if this is an amendment.' ;
    rdfs:domain ind:CtrFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewTimestamp rdf:type rdf:Property ;
    rdfs:label 'Review Timestamp' ;
    rdfs:comment 'Timestamp when the CTR filing was reviewed and approved by compliance.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:suspiciousActivityIndicator rdf:type rdf:Property ;
    rdfs:label 'Suspicious Activity Indicator' ;
    rdfs:comment 'Indicates whether the transaction also warrants a Suspicious Activity Report (SAR) filing due to suspicious characteristics.' ;
    rdfs:domain ind:CtrFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalCashInAmount rdf:type rdf:Property ;
    rdfs:label 'Total Cash In Amount' ;
    rdfs:comment 'Total amount of cash received (deposited) in the reportable transaction(s).' ;
    rdfs:domain ind:CtrFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCashOutAmount rdf:type rdf:Property ;
    rdfs:label 'Total Cash Out Amount' ;
    rdfs:comment 'Total amount of cash disbursed (withdrawn) in the reportable transaction(s).' ;
    rdfs:domain ind:CtrFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:findingBranchId rdf:type rdf:Property ;
    rdfs:label 'Finding Branch Id' ;
    rdfs:comment 'Foreign key linking to channel.branch. Business justification: Branch-specific exam findings (BSA program deficiencies, CTR filing gaps, fair lending violations) require branch attribution for remediation assignment, validation testing, and repeat finding trackin' ;
    rdfs:domain ind:ExamFinding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Branch .

ind:priorFindingExamFindingId rdf:type rdf:Property ;
    rdfs:label 'Prior Finding Exam Finding Id' ;
    rdfs:comment 'Reference to the prior examination finding identifier if this is a repeat finding.' ;
    rdfs:domain ind:ExamFinding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ExamFinding .

ind:actualRemediationCost rdf:type rdf:Property ;
    rdfs:label 'Actual Remediation Cost' ;
    rdfs:comment 'Actual financial cost in USD incurred to remediate the finding.' ;
    rdfs:domain ind:ExamFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignedOwner rdf:type rdf:Property ;
    rdfs:label 'Assigned Owner' ;
    rdfs:comment 'Name or identifier of the individual or role assigned primary accountability for remediating the finding.' ;
    rdfs:domain ind:ExamFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionStatus rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Status' ;
    rdfs:comment 'Current status of corrective action implementation for the finding.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedRemediationCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Remediation Cost' ;
    rdfs:comment 'Estimated financial cost in USD to fully remediate the finding, including technology, personnel, and consulting expenses.' ;
    rdfs:domain ind:ExamFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:governanceCommittee rdf:type rdf:Property ;
    rdfs:label 'Governance Committee' ;
    rdfs:comment 'Name of the governance committee or board subcommittee responsible for oversight of this finding (e.g., Risk Committee, Audit Committee, Compliance Committee).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactAssessment rdf:type rdf:Property ;
    rdfs:label 'Impact Assessment' ;
    rdfs:comment 'Assessment of the potential or actual business impact of the finding, including financial, operational, reputational, and regulatory consequences.' ;
    rdfs:domain ind:ExamFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalAuditValidationDate rdf:type rdf:Property ;
    rdfs:label 'Internal Audit Validation Date' ;
    rdfs:comment 'Date on which internal audit completed validation testing of the remediation.' ;
    rdfs:domain ind:ExamFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:internalAuditValidationFlag rdf:type rdf:Property ;
    rdfs:label 'Internal Audit Validation Flag' ;
    rdfs:comment 'Boolean indicator of whether internal audit has validated the effectiveness of the remediation actions.' ;
    rdfs:domain ind:ExamFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatorClosureComments rdf:type rdf:Property ;
    rdfs:label 'Regulator Closure Comments' ;
    rdfs:comment 'Comments or feedback provided by the regulatory authority upon closure or validation of the finding.' ;
    rdfs:domain ind:ExamFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorClosureDate rdf:type rdf:Property ;
    rdfs:label 'Regulator Closure Date' ;
    rdfs:comment 'Date on which the regulatory authority formally accepted the remediation and closed the finding.' ;
    rdfs:domain ind:ExamFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validationEvidence rdf:type rdf:Property ;
    rdfs:label 'Validation Evidence' ;
    rdfs:comment 'Description or reference to documentation and evidence provided to demonstrate effective remediation and control implementation.' ;
    rdfs:domain ind:ExamFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentIssuingCountryId rdf:type rdf:Property ;
    rdfs:label 'Document Issuing Country Id' ;
    rdfs:comment 'Foreign key linking to reference.country. Business justification: KYC reviews validate identity documents issued by specific countries; country AML risk rating, FATF status, sanctions flags, and document verification standards inform due diligence level and approval' ;
    rdfs:domain ind:KycReview ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:primaryKycEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Kyc Employee Id' ;
    rdfs:comment 'Identifier of the compliance analyst or KYC officer assigned to conduct this review.' ;
    rdfs:domain ind:KycReview ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:reviewChannelId rdf:type rdf:Property ;
    rdfs:label 'Review Channel Id' ;
    rdfs:comment 'Foreign key linking to channel.channel. Business justification: KYC reviews track review channel (branch meeting, digital document upload, mail) for audit trail completeness, regulatory examination support, and CDD program effectiveness assessment. Required for de' ;
    rdfs:domain ind:KycReview ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:assignedAnalystName rdf:type rdf:Property ;
    rdfs:label 'Assigned Analyst Name' ;
    rdfs:comment 'Full name of the compliance analyst assigned to this review for audit trail and accountability.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficialOwnerIdentified rdf:type rdf:Property ;
    rdfs:label 'Beneficial Owner Identified' ;
    rdfs:comment 'Indicates whether ultimate beneficial owners (UBOs) have been identified and documented for corporate customers, as required by CDD regulations.' ;
    rdfs:domain ind:KycReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currentRiskRating rdf:type rdf:Property ;
    rdfs:label 'Current Risk Rating' ;
    rdfs:comment 'The updated customer risk rating determined as an outcome of this KYC review.' ;
    rdfs:domain ind:KycReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Document Expiry Date' ;
    rdfs:comment 'Expiration date of the document, if applicable. Null for documents without expiry (e.g., birth certificates).' ;
    rdfs:domain ind:KycReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentIssueDate rdf:type rdf:Property ;
    rdfs:label 'Document Issue Date' ;
    rdfs:comment 'Date when the document was originally issued by the authority.' ;
    rdfs:domain ind:KycReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Document Reference Number' ;
    rdfs:comment 'The unique reference or serial number of the document collected (e.g., passport number, utility bill account number).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentType rdf:type rdf:Property ;
    rdfs:label 'Document Type' ;
    rdfs:comment 'Type of documentary evidence collected during the review (e.g., passport, utility bill, articles of incorporation, audited financials, bank statement, tax return). [ENUM-REF-CANDIDATE: passport|national_id|drivers_license|utility_bill|bank_statement|articles_of_incorporation|audited_financials|tax_return|proof_of_address|business_license — promote to reference product]' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentationCompletenessFlag rdf:type rdf:Property ;
    rdfs:label 'Documentation Completeness Flag' ;
    rdfs:comment 'Indicates whether all required documentation for the due diligence level has been collected and verified. True if complete, False if incomplete.' ;
    rdfs:domain ind:KycReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dueDiligenceLevel rdf:type rdf:Property ;
    rdfs:label 'Due Diligence Level' ;
    rdfs:comment 'Level of due diligence applied: SDD (Simplified Due Diligence), CDD (Customer Due Diligence), or EDD (Enhanced Due Diligence). Determines the depth and frequency of review.' ;
    rdfs:domain ind:KycReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outstandingDocumentList rdf:type rdf:Property ;
    rdfs:label 'Outstanding Document List' ;
    rdfs:comment 'Comma-separated list of document types still required to complete the KYC review. Null if documentation is complete.' ;
    rdfs:domain ind:KycReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousRiskRating rdf:type rdf:Property ;
    rdfs:label 'Previous Risk Rating' ;
    rdfs:comment 'The customer risk rating assigned prior to this review, used for comparison and trend analysis.' ;
    rdfs:domain ind:KycReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewApprovedDate rdf:type rdf:Property ;
    rdfs:label 'Review Approved Date' ;
    rdfs:comment 'Date when the completed KYC review was formally approved by the authorized approver.' ;
    rdfs:domain ind:KycReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Review Completed Date' ;
    rdfs:comment 'Actual date when the KYC review was completed and all required documentation was verified.' ;
    rdfs:domain ind:KycReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewCycleNumber rdf:type rdf:Property ;
    rdfs:label 'Review Cycle Number' ;
    rdfs:comment 'Sequential number indicating which periodic review cycle this represents for the party (e.g., 1st annual review, 2nd annual review).' ;
    rdfs:domain ind:KycReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewDueDate rdf:type rdf:Property ;
    rdfs:label 'Review Due Date' ;
    rdfs:comment 'Target completion date for the KYC review based on regulatory requirements and internal policy.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewInitiatedDate rdf:type rdf:Property ;
    rdfs:label 'Review Initiated Date' ;
    rdfs:comment 'Date when the KYC review was formally initiated or triggered.' ;
    rdfs:domain ind:KycReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewTriggerType rdf:type rdf:Property ;
    rdfs:label 'Review Trigger Type' ;
    rdfs:comment 'The event or condition that initiated this KYC review: periodic (scheduled refresh), event-driven (material change), risk-based (risk score threshold), regulatory (examiner request), ad-hoc (manual), or onboarding (initial review).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskRatingChangeReason rdf:type rdf:Property ;
    rdfs:label 'Risk Rating Change Reason' ;
    rdfs:comment 'Explanation for any change in risk rating from previous to current, documenting the rationale for the adjustment.' ;
    rdfs:domain ind:KycReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceOfFundsVerified rdf:type rdf:Property ;
    rdfs:label 'Source Of Funds Verified' ;
    rdfs:comment 'Indicates whether the source of funds has been verified and documented as part of the review. Required for EDD cases.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceOfWealthVerified rdf:type rdf:Property ;
    rdfs:label 'Source Of Wealth Verified' ;
    rdfs:comment 'Indicates whether the source of wealth has been verified and documented. Typically required for high-risk and EDD customers.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:systemOfRecord rdf:type rdf:Property ;
    rdfs:label 'System Of Record' ;
    rdfs:comment 'The source system where this KYC review record was originally created (e.g., NICE Actimize, Oracle Financial Crime, internal KYC platform).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationMethod rdf:type rdf:Property ;
    rdfs:label 'Verification Method' ;
    rdfs:comment 'Method used to verify the authenticity of the document: manual (visual inspection), electronic (e-verification), third_party (external service), biometric, notarized, or certified_copy.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationStatus rdf:type rdf:Property ;
    rdfs:label 'Verification Status' ;
    rdfs:comment 'Current status of document verification: verified (passed), pending (awaiting verification), failed (could not verify), expired (document expired), rejected (document not acceptable), or not_required.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableChannelId rdf:type rdf:Property ;
    rdfs:label 'Applicable Channel Id' ;
    rdfs:comment 'Foreign key linking to channel.channel. Business justification: AML monitoring rules scope applicable channels (wire transfer rules don\'t apply to ATM, structuring rules target branch/teller) for scenario configuration, alert generation logic, and false positive r' ;
    rdfs:domain ind:MonitoringRule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:ruleOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Rule Owner Employee Id' ;
    rdfs:comment 'Employee identifier of the compliance officer or business owner responsible for this rule.' ;
    rdfs:domain ind:MonitoringRule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:supersededByRuleMonitoringRuleId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Rule Monitoring Rule Id' ;
    rdfs:comment 'Identifier of the monitoring rule that replaces this rule, if applicable.' ;
    rdfs:domain ind:MonitoringRule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MonitoringRule .

ind:thresholdCurrencyId rdf:type rdf:Property ;
    rdfs:label 'Threshold Currency Id' ;
    rdfs:comment 'Foreign key linking to reference.currency. Business justification: AML monitoring rules define thresholds in specific currencies; currency reference enables multi-currency normalization, alert generation, and threshold tuning. Core AML transaction monitoring operatio' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:aggregationMethod rdf:type rdf:Property ;
    rdfs:label 'Aggregation Method' ;
    rdfs:comment 'Statistical method used to aggregate transaction data for threshold comparison (sum, count, average, maximum, peer comparison).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertVolumeMonthlyAverage rdf:type rdf:Property ;
    rdfs:label 'Alert Volume Monthly Average' ;
    rdfs:comment 'Average number of alerts generated by this rule per month, used for capacity planning and effectiveness assessment.' ;
    rdfs:domain ind:MonitoringRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicableCustomerSegments rdf:type rdf:Property ;
    rdfs:label 'Applicable Customer Segments' ;
    rdfs:comment 'Customer segments or types to which this rule applies (e.g., retail, commercial, private banking, correspondent banking).' ;
    rdfs:domain ind:MonitoringRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableProductTypes rdf:type rdf:Property ;
    rdfs:label 'Applicable Product Types' ;
    rdfs:comment 'Banking product types monitored by this rule (e.g., checking accounts, wire transfers, trade finance, securities trading).' ;
    rdfs:domain ind:MonitoringRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionLogic rdf:type rdf:Property ;
    rdfs:label 'Detection Logic' ;
    rdfs:comment 'Technical description of the rule logic, including conditions, thresholds, and aggregation methods used for alert generation.' ;
    rdfs:domain ind:MonitoringRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:falsePositiveRate rdf:type rdf:Property ;
    rdfs:label 'False Positive Rate' ;
    rdfs:comment 'Calculated percentage of alerts generated by this rule that are determined to be false positives upon investigation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastExaminationDate rdf:type rdf:Property ;
    rdfs:label 'Last Examination Date' ;
    rdfs:comment 'Date of the most recent regulatory examination that reviewed this rule.' ;
    rdfs:domain ind:MonitoringRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastTuningDate rdf:type rdf:Property ;
    rdfs:label 'Last Tuning Date' ;
    rdfs:comment 'Date when the rule thresholds or parameters were last adjusted during tuning activities.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastValidationDate rdf:type rdf:Property ;
    rdfs:label 'Last Validation Date' ;
    rdfs:comment 'Date when the rule model was last validated by the Model Risk Management team.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:modelValidationStatus rdf:type rdf:Property ;
    rdfs:label 'Model Validation Status' ;
    rdfs:comment 'Current validation status of the rule model under the Model Risk Management framework.' ;
    rdfs:domain ind:MonitoringRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextValidationDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Validation Due Date' ;
    rdfs:comment 'Scheduled date for the next required model validation review.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:peerGroupDefinition rdf:type rdf:Property ;
    rdfs:label 'Peer Group Definition' ;
    rdfs:comment 'Criteria used to define peer groups for peer-based anomaly detection rules (e.g., industry, geography, account type).' ;
    rdfs:domain ind:MonitoringRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retirementReason rdf:type rdf:Property ;
    rdfs:label 'Retirement Reason' ;
    rdfs:comment 'Explanation for why the rule was retired or deactivated, if applicable.' ;
    rdfs:domain ind:MonitoringRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleCategory rdf:type rdf:Property ;
    rdfs:label 'Rule Category' ;
    rdfs:comment 'Regulatory or compliance category that this rule supports (AML, BSA, OFAC, sanctions, fraud, KYC, CDD). [ENUM-REF-CANDIDATE: aml|bsa|ofac|sanctions|fraud|kyc|cdd — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sarConversionRate rdf:type rdf:Property ;
    rdfs:label 'Sar Conversion Rate' ;
    rdfs:comment 'Percentage of alerts from this rule that result in SAR filings, indicating rule effectiveness.' ;
    rdfs:domain ind:MonitoringRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scenarioType rdf:type rdf:Property ;
    rdfs:label 'Scenario Type' ;
    rdfs:comment 'Classification of the detection scenario that this rule implements (e.g., structuring, rapid movement, high-risk geography).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaReviewHours rdf:type rdf:Property ;
    rdfs:label 'Sla Review Hours' ;
    rdfs:comment 'Number of hours within which alerts generated by this rule must be reviewed, per internal SLA policy.' ;
    rdfs:domain ind:MonitoringRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:thresholdCount rdf:type rdf:Property ;
    rdfs:label 'Threshold Count' ;
    rdfs:comment 'Transaction count threshold that triggers an alert when exceeded. Used in frequency-based detection scenarios.' ;
    rdfs:domain ind:MonitoringRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tuningHistoryCount rdf:type rdf:Property ;
    rdfs:label 'Tuning History Count' ;
    rdfs:comment 'Number of times this rule has been tuned or recalibrated since initial deployment.' ;
    rdfs:domain ind:MonitoringRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tuningRationale rdf:type rdf:Property ;
    rdfs:label 'Tuning Rationale' ;
    rdfs:comment 'Business justification and explanation for the most recent rule tuning or threshold adjustment.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByObligationId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Obligation Id' ;
    rdfs:comment 'Reference to the obligation ID that supersedes or replaces this obligation, if applicable. Used to track regulatory changes and obligation evolution. Null if not superseded.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Obligation .

ind:applicabilityScope rdf:type rdf:Property ;
    rdfs:label 'Applicability Scope' ;
    rdfs:comment 'Textual description of the scope of applicability within the bank: which lines of business (LOB), product types, geographies, or legal entities this obligation applies to (e.g., \'All retail banking operations in USA\', \'Investment banking M&A advisory\', \'All deposit accounts\').' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceFrequency rdf:type rdf:Property ;
    rdfs:label 'Compliance Frequency' ;
    rdfs:comment 'The frequency at which compliance with this obligation must be demonstrated or reported: continuous monitoring, daily, weekly, monthly, quarterly, semi-annual, annual, ad-hoc, or event-driven. [ENUM-REF-CANDIDATE: continuous|daily|weekly|monthly|quarterly|semi_annual|annual|ad_hoc|event_driven — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationProcedure rdf:type rdf:Property ;
    rdfs:label 'Escalation Procedure' ;
    rdfs:comment 'Description of the escalation path and procedures to follow when non-compliance is identified or when issues arise (e.g., \'Escalate to Chief Compliance Officer within 24 hours\', \'Notify Board Risk Committee for critical violations\').' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceRequirement rdf:type rdf:Property ;
    rdfs:label 'Evidence Requirement' ;
    rdfs:comment 'Description of the documentation, records, or evidence that must be maintained to demonstrate compliance with this obligation (e.g., \'Transaction monitoring reports\', \'SAR filing confirmations\', \'Board meeting minutes\', \'Audit trails\').' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:examFindings rdf:type rdf:Property ;
    rdfs:label 'Exam Findings' ;
    rdfs:comment 'Summary of findings, observations, or matters requiring attention (MRA) from the most recent regulatory examination related to this obligation.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalAuditFlag rdf:type rdf:Property ;
    rdfs:label 'External Audit Flag' ;
    rdfs:comment 'Boolean indicator of whether this obligation is subject to external audit or regulatory examination (True) or is only internally monitored (False).' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:implementationGuidance rdf:type rdf:Property ;
    rdfs:label 'Implementation Guidance' ;
    rdfs:comment 'Summary of implementation guidance, best practices, or internal procedures for meeting this obligation. May reference internal policy documents or control procedures.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Assessment Date' ;
    rdfs:comment 'The date of the most recent compliance assessment or audit for this obligation.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastRegulatoryExamDate rdf:type rdf:Property ;
    rdfs:label 'Last Regulatory Exam Date' ;
    rdfs:comment 'The date of the most recent regulatory examination or supervisory review that covered this obligation.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lobApplicability rdf:type rdf:Property ;
    rdfs:label 'Lob Applicability' ;
    rdfs:comment 'Comma-separated list of lines of business to which this obligation applies (e.g., \'Retail Banking\', \'Investment Banking\', \'Wealth Management\', \'Treasury\'). Null if applicable to all LOBs.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Next Assessment Date' ;
    rdfs:comment 'The scheduled date for the next compliance assessment or review of this obligation.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:obligationCode rdf:type rdf:Property ;
    rdfs:label 'Obligation Code' ;
    rdfs:comment 'Business-assigned unique code or reference number for the obligation, used for external identification and regulatory mapping (e.g., BSA-AML-001, FATCA-2023-05).' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationDescription rdf:type rdf:Property ;
    rdfs:label 'Obligation Description' ;
    rdfs:comment 'Detailed narrative description of the obligation, including the specific requirement, scope, and what the bank must do to comply.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationStatus rdf:type rdf:Property ;
    rdfs:label 'Obligation Status' ;
    rdfs:comment 'Current lifecycle status of the obligation: active (in force), inactive (not currently applicable), pending (awaiting effective date), superseded (replaced by newer obligation), under review (being assessed), or retired (no longer applicable).' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationType rdf:type rdf:Property ;
    rdfs:label 'Obligation Type' ;
    rdfs:comment 'Classification of the obligation by its nature: regulatory reporting (e.g., CCAR, DFAST), operational control (e.g., SOX control), policy requirement, supervisory guidance, legal mandate, or contractual obligation.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:owner rdf:type rdf:Property ;
    rdfs:label 'Owner' ;
    rdfs:comment 'Name or identifier of the business unit, department, or individual responsible for ensuring compliance with this obligation (e.g., \'Chief Compliance Officer\', \'AML Compliance Team\', \'Risk Management Division\').' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerEmail rdf:type rdf:Property ;
    rdfs:label 'Owner Email' ;
    rdfs:comment 'Primary email contact for the obligation owner or responsible party.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyDescription rdf:type rdf:Property ;
    rdfs:label 'Penalty Description' ;
    rdfs:comment 'Description of potential penalties, fines, sanctions, or consequences for non-compliance with this obligation (e.g., \'Civil monetary penalties up to $1M per violation\', \'Regulatory enforcement action\', \'License suspension\').' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productTypeApplicability rdf:type rdf:Property ;
    rdfs:label 'Product Type Applicability' ;
    rdfs:comment 'Comma-separated list of product types to which this obligation applies (e.g., \'Demand Deposit Accounts\', \'Mortgage Loans\', \'Derivatives\', \'Securities Trading\'). Null if applicable to all products.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relatedFramework rdf:type rdf:Property ;
    rdfs:label 'Related Framework' ;
    rdfs:comment 'The broader regulatory or compliance framework this obligation belongs to (e.g., \'Anti-Money Laundering (AML)\', \'Know Your Customer (KYC)\', \'Basel III Capital Requirements\', \'Sarbanes-Oxley Act (SOX)\', \'FATCA\', \'GDPR\').' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingRequirement rdf:type rdf:Property ;
    rdfs:label 'Reporting Requirement' ;
    rdfs:comment 'Description of any regulatory reporting obligations associated with this requirement (e.g., \'Quarterly CCAR submission\', \'Annual FATCA reporting\', \'SAR filing within 30 days of detection\').' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Owner Employee Id' ;
    rdfs:comment 'Identifier of the employee who is accountable for the policy\'s maintenance, compliance, and effectiveness.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:supersededByPolicyId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Policy Id' ;
    rdfs:comment 'Identifier of the policy that replaces this one, if applicable. Null if the policy is current.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Policy .

ind:attestationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Attestation Required Flag' ;
    rdfs:comment 'Indicates whether employees must formally attest to their understanding and compliance with this policy.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:enforcementLevel rdf:type rdf:Property ;
    rdfs:label 'Enforcement Level' ;
    rdfs:comment 'Degree of enforceability and consequences for non-adherence to the policy.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyCategory rdf:type rdf:Property ;
    rdfs:label 'Policy Category' ;
    rdfs:comment 'Regulatory domain or compliance area that this policy addresses, aligned with industry-standard frameworks and regulatory requirements. [ENUM-REF-CANDIDATE: aml|kyc|sanctions|sox|fatca|crs|bsa|ccar|dfast|ifrs9|cecl|frtb — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyDescription rdf:type rdf:Property ;
    rdfs:label 'Policy Description' ;
    rdfs:comment 'Comprehensive description of the policy objectives, scope, and key requirements it implements.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyName rdf:type rdf:Property ;
    rdfs:label 'Policy Name' ;
    rdfs:comment 'Full name of the compliance policy as it appears in official documentation and regulatory filings.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewCycleMonths rdf:type rdf:Property ;
    rdfs:label 'Review Cycle Months' ;
    rdfs:comment 'Frequency in months at which the policy must be reviewed and reaffirmed to ensure continued relevance and compliance.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trainingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Training Required Flag' ;
    rdfs:comment 'Indicates whether employees subject to this policy must complete mandatory training.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:citationReference rdf:type rdf:Property ;
    rdfs:label 'Citation Reference' ;
    rdfs:comment 'Legal or regulatory citation that mandates the filing requirement. References specific sections of laws, regulations, or regulatory guidance.' ;
    rdfs:domain ind:RegulatoryCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalDueDate rdf:type rdf:Property ;
    rdfs:label 'Internal Due Date' ;
    rdfs:comment 'Internal deadline for completing the filing before the regulatory submission due date. Accounts for review, approval, and submission buffer.' ;
    rdfs:domain ind:RegulatoryCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:publicDisclosureRequired rdf:type rdf:Property ;
    rdfs:label 'Public Disclosure Required' ;
    rdfs:comment 'Indicates whether the filing or its results must be publicly disclosed. Applies to filings such as stress test results or capital adequacy reports.' ;
    rdfs:domain ind:RegulatoryCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responsibleOwner rdf:type rdf:Property ;
    rdfs:label 'Responsible Owner' ;
    rdfs:comment 'Name of the individual owner or primary contact responsible for the filing. Accountable party for ensuring timely and accurate submission.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleOwnerEmail rdf:type rdf:Property ;
    rdfs:label 'Responsible Owner Email' ;
    rdfs:comment 'Email address of the responsible owner. Used for notifications, escalations, and regulatory correspondence.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaBufferDays rdf:type rdf:Property ;
    rdfs:label 'Sla Buffer Days' ;
    rdfs:comment 'Number of days before the regulatory deadline that internal submission must be completed. Provides buffer for review, approval, and contingency.' ;
    rdfs:domain ind:RegulatoryCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:submissionDueDate rdf:type rdf:Property ;
    rdfs:label 'Submission Due Date' ;
    rdfs:comment 'Regulatory deadline by which the filing must be submitted to the governing body. Critical for compliance tracking and SLA management.' ;
    rdfs:domain ind:RegulatoryCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:submissionFormat rdf:type rdf:Property ;
    rdfs:label 'Submission Format' ;
    rdfs:comment 'Data format required for the regulatory filing. Specifies technical structure and schema for submission. [ENUM-REF-CANDIDATE: XBRL|XML|CSV|PDF|Excel|JSON|Fixed-Width — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionFrequency rdf:type rdf:Property ;
    rdfs:label 'Submission Frequency' ;
    rdfs:comment 'Frequency with which the regulatory filing must be submitted. Determines recurrence pattern for calendar scheduling. [ENUM-REF-CANDIDATE: Daily|Weekly|Monthly|Quarterly|Semi-Annual|Annual|Ad-Hoc|Event-Driven — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RegulatoryCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByChangeRegulatoryChangeId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Change Regulatory Change Id' ;
    rdfs:comment 'Identifier of a subsequent regulatory change that supersedes or replaces this regulatory change, establishing a lineage of regulatory evolution.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryChange .

ind:actualImplementationCost rdf:type rdf:Property ;
    rdfs:label 'Actual Implementation Cost' ;
    rdfs:comment 'Actual total cost in USD incurred to implement the regulatory change, tracked upon completion of implementation activities.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:affectedBusinessLines rdf:type rdf:Property ;
    rdfs:label 'Affected Business Lines' ;
    rdfs:comment 'Comma-separated list or description of the business lines impacted by the regulatory change, such as Commercial Lending, Investment Banking, Trading, Wealth Management, Retail Banking, Treasury, etc.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedProducts rdf:type rdf:Property ;
    rdfs:label 'Affected Products' ;
    rdfs:comment 'Description of the specific products or services impacted by the regulatory change, such as deposit accounts, loans, derivatives, securities, payment services, etc.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedSystems rdf:type rdf:Property ;
    rdfs:label 'Affected Systems' ;
    rdfs:comment 'List or description of the operational systems and platforms that require changes to comply with the regulatory change, such as core banking, trading systems, risk platforms, reporting systems, etc.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeDescription rdf:type rdf:Property ;
    rdfs:label 'Change Description' ;
    rdfs:comment 'Detailed description of the regulatory change, including the specific provisions, amendments, or repeals and their implications for the bank.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Change Reference Number' ;
    rdfs:comment 'Business-assigned unique reference number for the regulatory change, used for tracking and correspondence with regulators and internal stakeholders.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeStatus rdf:type rdf:Property ;
    rdfs:label 'Change Status' ;
    rdfs:comment 'Current status of the regulatory change in the bank\'s change management lifecycle, from initial identification through completion of implementation. [ENUM-REF-CANDIDATE: identified|under_review|impact_assessed|implementation_planned|in_progress|completed|deferred — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeTitle rdf:type rdf:Property ;
    rdfs:label 'Change Title' ;
    rdfs:comment 'Short descriptive title of the regulatory change, summarizing the nature of the new, amended, or repealed requirement.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeType rdf:type rdf:Property ;
    rdfs:label 'Change Type' ;
    rdfs:comment 'Classification of the regulatory change indicating whether it is a new regulation, an amendment to existing regulation, a repeal, supervisory guidance, interpretive letter, or advisory notice.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedImplementationCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Implementation Cost' ;
    rdfs:comment 'Estimated total cost in USD to implement the regulatory change, including system changes, process redesign, training, consulting, and other related expenses.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:examinationReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Examination Reference Number' ;
    rdfs:comment 'Reference number of the regulatory examination or supervisory review during which the regulatory change was identified or discussed.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactAssessmentStatus rdf:type rdf:Property ;
    rdfs:label 'Impact Assessment Status' ;
    rdfs:comment 'Status of the impact assessment process to determine how the regulatory change affects the bank\'s operations, systems, policies, and procedures.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactAssessmentSummary rdf:type rdf:Property ;
    rdfs:label 'Impact Assessment Summary' ;
    rdfs:comment 'Summary of the impact assessment findings, describing which business lines, products, systems, policies, and controls are affected by the regulatory change.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactSeverity rdf:type rdf:Property ;
    rdfs:label 'Impact Severity' ;
    rdfs:comment 'The assessed severity level of the regulatory change\'s impact on the bank, considering scope of affected operations, implementation complexity, and compliance risk.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implementationApproach rdf:type rdf:Property ;
    rdfs:label 'Implementation Approach' ;
    rdfs:comment 'High-level description of the strategy and approach for implementing the regulatory change, including policy updates, system changes, process redesign, and training requirements.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implementationCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Implementation Completion Date' ;
    rdfs:comment 'The actual date on which all implementation activities were completed and the bank achieved full compliance with the regulatory change.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:implementationStartDate rdf:type rdf:Property ;
    rdfs:label 'Implementation Start Date' ;
    rdfs:comment 'The date on which implementation activities for the regulatory change officially began.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:implementationStatus rdf:type rdf:Property ;
    rdfs:label 'Implementation Status' ;
    rdfs:comment 'Current status of the implementation activities required to achieve compliance with the regulatory change.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicationDate rdf:type rdf:Property ;
    rdfs:label 'Publication Date' ;
    rdfs:comment 'The date on which the regulatory change was officially published or announced by the regulatory body.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatorySource rdf:type rdf:Property ;
    rdfs:label 'Regulatory Source' ;
    rdfs:comment 'The official publication or communication channel through which the regulatory change was announced, such as Federal Register, OCC Bulletin, Federal Reserve SR Letter, or other regulatory issuance. [ENUM-REF-CANDIDATE: federal_register|occ_bulletin|federal_reserve_sr_letter|fdic_financial_institution_letter|sec_release|finra_notice|cftc_advisory|cfpb_bulletin|basel_committee_publication|fsb_report|other — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleDepartment rdf:type rdf:Property ;
    rdfs:label 'Responsible Department' ;
    rdfs:comment 'The department or organizational unit with primary accountability for implementing and maintaining compliance with the regulatory change.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:examinedChannelId rdf:type rdf:Property ;
    rdfs:label 'Examined Channel Id' ;
    rdfs:comment 'Foreign key linking to channel.channel. Business justification: Regulatory exams often scope specific channels (branch network BSA exam, digital banking security exam, ATM ADA compliance). Exam findings and MRAs cite channel scope for targeted remediation and foll' ;
    rdfs:domain ind:RegulatoryExam ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:confidentialFlag rdf:type rdf:Property ;
    rdfs:label 'Confidential Flag' ;
    rdfs:comment 'Indicates whether the examination report and findings are subject to confidential supervisory information restrictions and cannot be publicly disclosed.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:examMethodology rdf:type rdf:Property ;
    rdfs:label 'Exam Methodology' ;
    rdfs:comment 'The approach or format used to conduct the examination. Specifies whether examiners conducted the review on-site at the institution, remotely off-site, or using a hybrid approach.' ;
    rdfs:domain ind:RegulatoryExam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:examNotes rdf:type rdf:Property ;
    rdfs:label 'Exam Notes' ;
    rdfs:comment 'Free-form text field for capturing additional notes, observations, or context related to the examination engagement that do not fit into structured fields.' ;
    rdfs:domain ind:RegulatoryExam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:examNumber rdf:type rdf:Property ;
    rdfs:label 'Exam Number' ;
    rdfs:comment 'The official examination number or reference code assigned by the regulatory agency. This is the externally-known identifier used in all regulatory correspondence and documentation.' ;
    rdfs:domain ind:RegulatoryExam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:examPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Exam Period End Date' ;
    rdfs:comment 'The ending date of the period under examination. Defines the end of the lookback window for transactions, controls, and activities being reviewed.' ;
    rdfs:domain ind:RegulatoryExam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:examPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Exam Period Start Date' ;
    rdfs:comment 'The beginning date of the period under examination. Defines the start of the lookback window for transactions, controls, and activities being reviewed.' ;
    rdfs:domain ind:RegulatoryExam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:examPriority rdf:type rdf:Property ;
    rdfs:label 'Exam Priority' ;
    rdfs:comment 'The priority classification of the examination. Indicates whether this is a routine supervisory cycle exam, a targeted review of specific risks, a for-cause examination due to concerns, or a follow-up to prior findings.' ;
    rdfs:domain ind:RegulatoryExam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:examScope rdf:type rdf:Property ;
    rdfs:label 'Exam Scope' ;
    rdfs:comment 'Detailed description of the examination scope, including specific business lines, processes, systems, or risk areas to be reviewed. Defines the boundaries and focus areas for the examination engagement.' ;
    rdfs:domain ind:RegulatoryExam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:examStatus rdf:type rdf:Property ;
    rdfs:label 'Exam Status' ;
    rdfs:comment 'Current lifecycle state of the regulatory examination. Tracks the examination from initial scheduling through final closure and response completion.' ;
    rdfs:domain ind:RegulatoryExam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:examTeamSize rdf:type rdf:Property ;
    rdfs:label 'Exam Team Size' ;
    rdfs:comment 'The total number of examiners assigned to the examination engagement. Indicates the scale and resource commitment of the regulatory review.' ;
    rdfs:domain ind:RegulatoryExam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:examType rdf:type rdf:Property ;
    rdfs:label 'Exam Type' ;
    rdfs:comment 'The category or focus area of the regulatory examination. Defines the primary scope and regulatory framework under which the examination is conducted.' ;
    rdfs:domain ind:RegulatoryExam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exitMeetingDate rdf:type rdf:Property ;
    rdfs:label 'Exit Meeting Date' ;
    rdfs:comment 'The date of the formal exit meeting or closing conference between examiners and institution management. Represents the date when preliminary findings were discussed.' ;
    rdfs:domain ind:RegulatoryExam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fieldworkEndDate rdf:type rdf:Property ;
    rdfs:label 'Fieldwork End Date' ;
    rdfs:comment 'The date when on-site or remote examination fieldwork activities concluded. Marks the completion of active data gathering and testing by examiners.' ;
    rdfs:domain ind:RegulatoryExam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:internalCoordinatorEmail rdf:type rdf:Property ;
    rdfs:label 'Internal Coordinator Email' ;
    rdfs:comment 'The email address of the internal bank coordinator responsible for managing examination logistics and information requests.' ;
    rdfs:domain ind:RegulatoryExam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalCoordinatorName rdf:type rdf:Property ;
    rdfs:label 'Internal Coordinator Name' ;
    rdfs:comment 'The name of the internal bank employee or officer designated as the primary coordinator and liaison for the examination engagement.' ;
    rdfs:domain ind:RegulatoryExam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mattersRequiringAttentionCount rdf:type rdf:Property ;
    rdfs:label 'Matters Requiring Attention Count' ;
    rdfs:comment 'The number of Matters Requiring Attention (MRA) or Matters Requiring Board Attention (MRBA) formally cited in the examination report. Represents significant supervisory concerns requiring corrective action.' ;
    rdfs:domain ind:RegulatoryExam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sensitivityRating rdf:type rdf:Property ;
    rdfs:label 'Sensitivity Rating' ;
    rdfs:comment 'The CAMELS component rating for sensitivity to market risk. Evaluates exposure to interest rate risk, foreign exchange risk, and other market risks. Scale of 1 (strongest) to 5 (weakest).' ;
    rdfs:domain ind:RegulatoryExam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchedListEntryId rdf:type rdf:Property ;
    rdfs:label 'Matched List Entry Id' ;
    rdfs:comment 'Unique identifier of the specific watchlist entry that matched.' ;
    rdfs:domain ind:SanctionsScreeningEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SanctionsListEntry .

ind:screenedAccountDepositAccountId rdf:type rdf:Property ;
    rdfs:label 'Screened Account Deposit Account Id' ;
    rdfs:comment 'Foreign key linking to account.deposit_account. Business justification: Account opening and transaction screening require account-level linkage. Screened_entity_id(unlinked) represents various entity types; explicit account FK enables account screening event queries for O' ;
    rdfs:domain ind:SanctionsScreeningEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DepositAccount .

ind:screenedPartyId rdf:type rdf:Property ;
    rdfs:label 'Screened Party Id' ;
    rdfs:comment 'Foreign key linking to customer.party. Business justification: Sanctions screening in banking operates on customer parties for AML/OFAC compliance. Every screening event must identify which customer was screened. Critical for regulatory audit trails and case inve' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:screeningChannelId rdf:type rdf:Property ;
    rdfs:label 'Screening Channel Id' ;
    rdfs:comment 'Foreign key linking to channel.channel. Business justification: Sanctions screening events track channel context (payment channel, account opening channel, wire transfer) for OFAC reporting, blocking action implementation, and channel-specific screening rule confi' ;
    rdfs:domain ind:SanctionsScreeningEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:analystReviewNotes rdf:type rdf:Property ;
    rdfs:label 'Analyst Review Notes' ;
    rdfs:comment 'Detailed notes and rationale documented by the compliance analyst during review of the sanctions match.' ;
    rdfs:domain ind:SanctionsScreeningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analystReviewRequired rdf:type rdf:Property ;
    rdfs:label 'Analyst Review Required' ;
    rdfs:comment 'Indicates whether the screening result requires manual analyst review.' ;
    rdfs:domain ind:SanctionsScreeningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:analystReviewTimestamp rdf:type rdf:Property ;
    rdfs:label 'Analyst Review Timestamp' ;
    rdfs:comment 'Date and time when the compliance analyst completed their review of the screening event.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:blockingActionTaken rdf:type rdf:Property ;
    rdfs:label 'Blocking Action Taken' ;
    rdfs:comment 'Indicates whether a blocking action was taken on the transaction or relationship due to the sanctions match.' ;
    rdfs:domain ind:SanctionsScreeningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:blockingActionType rdf:type rdf:Property ;
    rdfs:label 'Blocking Action Type' ;
    rdfs:comment 'Specific type of blocking action taken in response to the sanctions match.' ;
    rdfs:domain ind:SanctionsScreeningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Escalation Timestamp' ;
    rdfs:comment 'Date and time when the screening event was escalated to a higher authority.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:falsePositiveIndicator rdf:type rdf:Property ;
    rdfs:label 'False Positive Indicator' ;
    rdfs:comment 'Indicates whether the sanctions match was determined to be a false positive after investigation.' ;
    rdfs:domain ind:SanctionsScreeningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:matchScore rdf:type rdf:Property ;
    rdfs:label 'Match Score' ;
    rdfs:comment 'Numerical confidence score of the sanctions match (0-100 scale).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:matchStatus rdf:type rdf:Property ;
    rdfs:label 'Match Status' ;
    rdfs:comment 'Overall result of the sanctions screening indicating whether a match was found.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchType rdf:type rdf:Property ;
    rdfs:label 'Match Type' ;
    rdfs:comment 'Type of match algorithm that identified the potential sanctions hit.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchedEntityName rdf:type rdf:Property ;
    rdfs:label 'Matched Entity Name' ;
    rdfs:comment 'Name of the entity on the sanctions watchlist that matched the screened entity.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchedListType rdf:type rdf:Property ;
    rdfs:label 'Matched List Type' ;
    rdfs:comment 'Category of the watchlist where the match was identified.' ;
    rdfs:domain ind:SanctionsScreeningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ofacReportFiled rdf:type rdf:Property ;
    rdfs:label 'Ofac Report Filed' ;
    rdfs:comment 'Indicates whether a blocking report was filed with OFAC for this sanctions match.' ;
    rdfs:domain ind:SanctionsScreeningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ofacReportFilingDate rdf:type rdf:Property ;
    rdfs:label 'Ofac Report Filing Date' ;
    rdfs:comment 'Date when the OFAC blocking report was filed.' ;
    rdfs:domain ind:SanctionsScreeningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryHoldApplied rdf:type rdf:Property ;
    rdfs:label 'Regulatory Hold Applied' ;
    rdfs:comment 'Indicates whether a regulatory hold was placed on the entity or transaction due to the sanctions match.' ;
    rdfs:domain ind:SanctionsScreeningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryHoldDetails rdf:type rdf:Property ;
    rdfs:label 'Regulatory Hold Details' ;
    rdfs:comment 'Detailed information about the regulatory hold including scope, duration, and legal basis.' ;
    rdfs:domain ind:SanctionsScreeningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sarFiled rdf:type rdf:Property ;
    rdfs:label 'Sar Filed' ;
    rdfs:comment 'Indicates whether a Suspicious Activity Report was filed with FinCEN as a result of this screening event.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:screenedEntityName rdf:type rdf:Property ;
    rdfs:label 'Screened Entity Name' ;
    rdfs:comment 'Name of the entity submitted for sanctions screening.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screenedEntityType rdf:type rdf:Property ;
    rdfs:label 'Screened Entity Type' ;
    rdfs:comment 'Type of entity being screened for sanctions compliance.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningSystemCode rdf:type rdf:Property ;
    rdfs:label 'Screening System Code' ;
    rdfs:comment 'Identifier of the sanctions screening system that performed the screening (e.g., NICE Actimize, Oracle Financial Crime).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningTimestamp rdf:type rdf:Property ;
    rdfs:label 'Screening Timestamp' ;
    rdfs:comment 'Date and time when the sanctions screening was performed.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:screeningTrigger rdf:type rdf:Property ;
    rdfs:label 'Screening Trigger' ;
    rdfs:comment 'Business event that triggered the sanctions screening.' ;
    rdfs:domain ind:SanctionsScreeningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningType rdf:type rdf:Property ;
    rdfs:label 'Screening Type' ;
    rdfs:comment 'Type of screening workflow executed (real-time payment screening, batch customer screening, event-driven screening).' ;
    rdfs:domain ind:SanctionsScreeningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:watchlistConsulted rdf:type rdf:Property ;
    rdfs:label 'Watchlist Consulted' ;
    rdfs:comment 'Comma-separated list of sanctions watchlists consulted during screening (OFAC SDN, EU Consolidated, UN Security Council, HMT, internal high-risk).' ;
    rdfs:domain ind:SanctionsScreeningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:watchlistLastRefreshDate rdf:type rdf:Property ;
    rdfs:label 'Watchlist Last Refresh Date' ;
    rdfs:comment 'Date when the sanctions watchlist was last updated or refreshed.' ;
    rdfs:domain ind:SanctionsScreeningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:watchlistVersion rdf:type rdf:Property ;
    rdfs:label 'Watchlist Version' ;
    rdfs:comment 'Version identifier of the sanctions watchlist used during screening.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlChannelId rdf:type rdf:Property ;
    rdfs:label 'Control Channel Id' ;
    rdfs:comment 'Foreign key linking to channel.channel. Business justification: SOX controls scope specific channels (branch cash handling controls, digital authentication controls, ATM reconciliation controls) for testing scope definition, control design assessment, and operatin' ;
    rdfs:domain ind:ComplianceSoxControl ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:controlOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Control Owner Employee Id' ;
    rdfs:comment 'Identifier of the employee who is designated as the owner responsible for the design, execution, and maintenance of this control.' ;
    rdfs:domain ind:ComplianceSoxControl ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:controlDescription rdf:type rdf:Property ;
    rdfs:label 'Control Description' ;
    rdfs:comment 'Comprehensive narrative description of the control activity, including what is performed, by whom, how, and what evidence is retained.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlFrequency rdf:type rdf:Property ;
    rdfs:label 'Control Frequency' ;
    rdfs:comment 'How often the control is performed or operates (e.g., daily reconciliation, monthly review, event-driven approval). [ENUM-REF-CANDIDATE: daily|weekly|monthly|quarterly|annually|event_driven|continuous — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlNature rdf:type rdf:Property ;
    rdfs:label 'Control Nature' ;
    rdfs:comment 'Describes whether the control is performed manually by personnel, automated by system, manual but dependent on automated inputs, or an IT general control supporting application controls.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlNumber rdf:type rdf:Property ;
    rdfs:label 'Control Number' ;
    rdfs:comment 'Business identifier for the SOX control, typically formatted as process area prefix followed by sequential number (e.g., GL-001, AP-045, TR-123).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlStatus rdf:type rdf:Property ;
    rdfs:label 'Control Status' ;
    rdfs:comment 'Current lifecycle status of the control within the SOX compliance program.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlTitle rdf:type rdf:Property ;
    rdfs:label 'Control Title' ;
    rdfs:comment 'Short descriptive title of the SOX control summarizing its purpose and scope.' ;
    rdfs:domain ind:ComplianceSoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlType rdf:type rdf:Property ;
    rdfs:label 'Control Type' ;
    rdfs:comment 'Classification of the control based on its timing and purpose: preventive (stops errors before they occur), detective (identifies errors after occurrence), or corrective (remediates identified errors).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deficiencyClassification rdf:type rdf:Property ;
    rdfs:label 'Deficiency Classification' ;
    rdfs:comment 'Classification of any identified control deficiency per PCAOB standards: none (control effective), control deficiency (minor issue), significant deficiency (important enough to merit attention), or material weakness (reasonable possibility of material misstatement).' ;
    rdfs:domain ind:ComplianceSoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deficiencyDescription rdf:type rdf:Property ;
    rdfs:label 'Deficiency Description' ;
    rdfs:comment 'Detailed description of any identified control deficiency, including root cause analysis and potential impact on financial reporting.' ;
    rdfs:domain ind:ComplianceSoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designAssessedBy rdf:type rdf:Property ;
    rdfs:label 'Design Assessed By' ;
    rdfs:comment 'Name or identifier of the individual or team who performed the design effectiveness assessment (typically internal audit or SOX compliance team).' ;
    rdfs:domain ind:ComplianceSoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Design Assessment Date' ;
    rdfs:comment 'Date when the most recent design effectiveness assessment was completed.' ;
    rdfs:domain ind:ComplianceSoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:designEffectivenessRating rdf:type rdf:Property ;
    rdfs:label 'Design Effectiveness Rating' ;
    rdfs:comment 'Assessment of whether the control, as designed, is capable of preventing or detecting material misstatements if operating as prescribed.' ;
    rdfs:domain ind:ComplianceSoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entityLevelControlIndicator rdf:type rdf:Property ;
    rdfs:label 'Entity Level Control Indicator' ;
    rdfs:comment 'Flag indicating whether this is an entity-level control (True) that operates across the organization or a process-level control (False) specific to a business process.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:externalAuditorRelianceIndicator rdf:type rdf:Property ;
    rdfs:label 'External Auditor Reliance Indicator' ;
    rdfs:comment 'Flag indicating whether the external auditor has indicated they will rely on this control (True) as part of their financial statement audit approach.' ;
    rdfs:domain ind:ComplianceSoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:financialStatementAssertion rdf:type rdf:Property ;
    rdfs:label 'Financial Statement Assertion' ;
    rdfs:comment 'The specific financial statement assertion this control addresses per PCAOB standards: existence, completeness, accuracy/valuation, rights and obligations, or presentation and disclosure.' ;
    rdfs:domain ind:ComplianceSoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyControlIndicator rdf:type rdf:Property ;
    rdfs:label 'Key Control Indicator' ;
    rdfs:comment 'Flag indicating whether this is a key control (True) or supporting control (False). Key controls are those that directly address significant risks to financial reporting.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastTestDate rdf:type rdf:Property ;
    rdfs:label 'Last Test Date' ;
    rdfs:comment 'Date when the most recent operating effectiveness test was completed.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastTestPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Last Test Period End' ;
    rdfs:comment 'End date of the period covered by the most recent operating effectiveness test.' ;
    rdfs:domain ind:ComplianceSoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastTestPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Last Test Period Start' ;
    rdfs:comment 'Start date of the period covered by the most recent operating effectiveness test.' ;
    rdfs:domain ind:ComplianceSoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operatingEffectivenessRating rdf:type rdf:Property ;
    rdfs:label 'Operating Effectiveness Rating' ;
    rdfs:comment 'Assessment of whether the control is operating as designed and achieving its control objective based on testing results.' ;
    rdfs:domain ind:ComplianceSoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processArea rdf:type rdf:Property ;
    rdfs:label 'Process Area' ;
    rdfs:comment 'The business process or functional area to which this control belongs (e.g., General Ledger, Accounts Payable, Treasury, Loan Origination, Trading Operations).' ;
    rdfs:domain ind:ComplianceSoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationRequiredIndicator rdf:type rdf:Property ;
    rdfs:label 'Remediation Required Indicator' ;
    rdfs:comment 'Flag indicating whether remediation action is required (True) to address identified deficiencies or improve control effectiveness.' ;
    rdfs:domain ind:ComplianceSoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retirementDate rdf:type rdf:Property ;
    rdfs:label 'Retirement Date' ;
    rdfs:comment 'Date when this control was retired or superseded, if applicable.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:subProcess rdf:type rdf:Property ;
    rdfs:label 'Sub Process' ;
    rdfs:comment 'More granular sub-process within the process area (e.g., within General Ledger: Journal Entry, Account Reconciliation, Period Close).' ;
    rdfs:domain ind:ComplianceSoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testerName rdf:type rdf:Property ;
    rdfs:label 'Tester Name' ;
    rdfs:comment 'Name of the individual who performed the most recent control test (typically internal audit staff or SOX compliance analyst).' ;
    rdfs:domain ind:ComplianceSoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testingMethodology rdf:type rdf:Property ;
    rdfs:label 'Testing Methodology' ;
    rdfs:comment 'The audit procedure used to test the control: inquiry (asking questions), observation (watching performance), inspection (examining evidence), reperformance (executing control independently), or data analytics (automated testing).' ;
    rdfs:domain ind:ComplianceSoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingRecordId rdf:type rdf:Property ;
    rdfs:label 'Training Record Id' ;
    rdfs:comment 'Primary key for training_record' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trainingBranchId rdf:type rdf:Property ;
    rdfs:label 'Training Branch Id' ;
    rdfs:comment 'Foreign key linking to channel.branch. Business justification: Branch staff compliance training records track training location for audit trail completeness, regulatory exam support, and branch-level training compliance assessment. Required for demonstrating adeq' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Branch .

ind:trainingProgramId rdf:type rdf:Property ;
    rdfs:label 'Training Program Id' ;
    rdfs:comment 'Reference to the specific compliance training program completed.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Program .

ind:assessmentScore rdf:type rdf:Property ;
    rdfs:label 'Assessment Score' ;
    rdfs:comment 'Numerical score achieved by the employee on the training assessment or examination, typically expressed as a percentage.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignedDate rdf:type rdf:Property ;
    rdfs:label 'Assigned Date' ;
    rdfs:comment 'Date when the training was assigned to the employee.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:attemptNumber rdf:type rdf:Property ;
    rdfs:label 'Attempt Number' ;
    rdfs:comment 'Number of attempts the employee has made to complete the training assessment.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:attestationDate rdf:type rdf:Property ;
    rdfs:label 'Attestation Date' ;
    rdfs:comment 'Date when the employee signed the training attestation or acknowledgment.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:attestationSignedFlag rdf:type rdf:Property ;
    rdfs:label 'Attestation Signed Flag' ;
    rdfs:comment 'Indicates whether the employee signed the required attestation or acknowledgment statement confirming understanding and compliance.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Certification Expiry Date' ;
    rdfs:comment 'Date when the training certification expires and requires renewal or re-completion.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:completionStatus rdf:type rdf:Property ;
    rdfs:label 'Completion Status' ;
    rdfs:comment 'Current status of the training completion for the employee.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceNotes rdf:type rdf:Property ;
    rdfs:label 'Compliance Notes' ;
    rdfs:comment 'Additional notes or comments related to compliance aspects of the training completion.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instructorName rdf:type rdf:Property ;
    rdfs:label 'Instructor Name' ;
    rdfs:comment 'Name of the instructor or facilitator for instructor-led training sessions.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passFailStatus rdf:type rdf:Property ;
    rdfs:label 'Pass Fail Status' ;
    rdfs:comment 'Indicates whether the employee passed or failed the training assessment.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passingScoreThreshold rdf:type rdf:Property ;
    rdfs:label 'Passing Score Threshold' ;
    rdfs:comment 'Minimum score required to pass the training assessment and achieve completion status.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recertificationFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Recertification Frequency Months' ;
    rdfs:comment 'Number of months between required recertification cycles for this training program.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recertificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Recertification Required Flag' ;
    rdfs:comment 'Indicates whether this training requires periodic recertification or renewal.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:startedDate rdf:type rdf:Property ;
    rdfs:label 'Started Date' ;
    rdfs:comment 'Date when the employee first accessed or began the training program.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trainingDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Training Duration Minutes' ;
    rdfs:comment 'Total time in minutes spent by the employee completing the training program.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trainingProvider rdf:type rdf:Property ;
    rdfs:label 'Training Provider' ;
    rdfs:comment 'Name of the organization or vendor that provided the training content and platform.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Waiver Approval Date' ;
    rdfs:comment 'Date when the training waiver was approved.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:waiverApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Waiver Approved By' ;
    rdfs:comment 'Name or identifier of the manager or compliance officer who approved the training waiver.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerBeneficialOwnerId rdf:type rdf:Property ;
    rdfs:label 'Customer Beneficial Owner Id' ;
    rdfs:comment 'Unique identifier for the beneficial ownership record. Primary key for the customer beneficial owner registry.' ;
    rdfs:domain ind:CustomerBeneficialOwner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:beneficialOwnerId rdf:type rdf:Property ;
    rdfs:label 'Beneficial Owner Id' ;
    rdfs:comment 'Unique identifier for the beneficial ownership record. Primary key for this entity.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BeneficialOwner .

ind:controlTypeCodeListId rdf:type rdf:Property ;
    rdfs:label 'Control Type Code List Id' ;
    rdfs:comment 'Foreign key linking to reference.code_list. Business justification: UBO control classification - control types (Ownership, Voting Rights, Senior Management, Other Means) must be standardized for FinCEN CTA reporting and 4AMLD/5AMLD compliance.' ;
    rdfs:domain ind:CustomerBeneficialOwner ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CodeList .

ind:ownerCountryId rdf:type rdf:Property ;
    rdfs:label 'Owner Country Id' ;
    rdfs:comment 'Foreign key linking to reference.country. Business justification: CTA compliance - beneficial owner country must be validated for FinCEN Corporate Transparency Act reporting, sanctions screening, and UBO risk assessment.' ;
    rdfs:domain ind:CustomerBeneficialOwner ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:primaryCustomerCountryId rdf:type rdf:Property ;
    rdfs:label 'Primary Customer Country Id' ;
    rdfs:comment 'Foreign key linking to reference.country. Business justification: UBO verification - beneficial owner country of residence drives AML risk rating, CRS/FATCA reporting obligations, and sanctions screening. Core UBO compliance requirement.' ;
    rdfs:domain ind:CustomerBeneficialOwner ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:primaryCustomerLegalEntityPartyId rdf:type rdf:Property ;
    rdfs:label 'Primary Customer Legal Entity Party Id' ;
    rdfs:comment 'Reference to the legal entity customer for which this beneficial ownership record applies. Links to the party master for the corporate or legal entity customer.' ;
    rdfs:domain ind:CustomerBeneficialOwner ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:quaternaryCustomerPartyId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Customer Party Id' ;
    rdfs:comment 'Reference to the intermediate legal entity in the ownership chain for indirect ownership structures. Null for direct ownership. Links to customer master for the intermediary entity.' ;
    rdfs:domain ind:CustomerBeneficialOwner ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:tertiaryCustomerOwnedPartyId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Customer Owned Party Id' ;
    rdfs:comment 'Reference to the legal entity (corporation, trust, partnership) that is owned or controlled. Links to the customer master for the legal entity.' ;
    rdfs:domain ind:CustomerBeneficialOwner ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:adverseMediaScreeningDate rdf:type rdf:Property ;
    rdfs:label 'Adverse Media Screening Date' ;
    rdfs:comment 'Date on which the most recent adverse media screening was performed for the beneficial owner.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationDate rdf:type rdf:Property ;
    rdfs:label 'Certification Date' ;
    rdfs:comment 'Date on which the beneficial ownership certification was obtained from the legal entity customer, confirming the accuracy of beneficial owner information.' ;
    rdfs:domain ind:CustomerBeneficialOwner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationFormReference rdf:type rdf:Property ;
    rdfs:label 'Certification Form Reference' ;
    rdfs:comment 'Reference number or identifier for the beneficial ownership certification form completed by the legal entity customer.' ;
    rdfs:domain ind:CustomerBeneficialOwner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlIndicator rdf:type rdf:Property ;
    rdfs:label 'Control Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this person exercises significant control over the entity regardless of ownership percentage. True for senior managing officials and others with control authority per FinCEN rules.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ctaReportDate rdf:type rdf:Property ;
    rdfs:label 'Cta Report Date' ;
    rdfs:comment 'Date on which the beneficial ownership information was reported to FinCEN under the Corporate Transparency Act.' ;
    rdfs:domain ind:CustomerBeneficialOwner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ctaReportReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Cta Report Reference Number' ;
    rdfs:comment 'Unique reference number assigned by FinCEN for the beneficial ownership report filed under the Corporate Transparency Act.' ;
    rdfs:domain ind:CustomerBeneficialOwner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctaReportingStatus rdf:type rdf:Property ;
    rdfs:label 'Cta Reporting Status' ;
    rdfs:comment 'Status of beneficial ownership reporting to FinCEN under the Corporate Transparency Act. Reported indicates information has been filed with FinCEN, pending indicates filing is in progress, exempt indicates the entity is exempt from CTA reporting, not_required indicates reporting is not required for this ownership record.' ;
    rdfs:domain ind:CustomerBeneficialOwner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identificationDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Identification Document Number' ;
    rdfs:comment 'Unique number or identifier on the government-issued identification document used for beneficial owner verification.' ;
    rdfs:domain ind:CustomerBeneficialOwner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identificationDocumentType rdf:type rdf:Property ;
    rdfs:label 'Identification Document Type' ;
    rdfs:comment 'Type of government-issued identification document used to verify the identity of the beneficial owner.' ;
    rdfs:domain ind:CustomerBeneficialOwner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Identification Expiry Date' ;
    rdfs:comment 'Date on which the identification document expires. Null if the document does not expire.' ;
    rdfs:domain ind:CustomerBeneficialOwner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:identificationIssueDate rdf:type rdf:Property ;
    rdfs:label 'Identification Issue Date' ;
    rdfs:comment 'Date on which the identification document was issued by the issuing authority.' ;
    rdfs:domain ind:CustomerBeneficialOwner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:identificationIssuingCountry rdf:type rdf:Property ;
    rdfs:label 'Identification Issuing Country' ;
    rdfs:comment 'Three-letter ISO country code for the country that issued the identification document.' ;
    rdfs:domain ind:CustomerBeneficialOwner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReportedDate rdf:type rdf:Property ;
    rdfs:label 'Last Reported Date' ;
    rdfs:comment 'Date when this beneficial ownership information was last reported to regulatory authorities. Used to track reporting compliance and identify records requiring updated filings.' ;
    rdfs:domain ind:CustomerBeneficialOwner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nationality rdf:type rdf:Property ;
    rdfs:label 'Nationality' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code for the beneficial owner\'s nationality or citizenship. May differ from residence. Used for sanctions screening and tax reporting.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerCity rdf:type rdf:Property ;
    rdfs:label 'Owner City' ;
    rdfs:comment 'City of residence for the beneficial owner.' ;
    rdfs:domain ind:CustomerBeneficialOwner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerDateOfBirth rdf:type rdf:Property ;
    rdfs:label 'Owner Date Of Birth' ;
    rdfs:comment 'Date of birth of the beneficial owner individual, required for identity verification and regulatory reporting.' ;
    rdfs:domain ind:CustomerBeneficialOwner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ownerFullName rdf:type rdf:Property ;
    rdfs:label 'Owner Full Name' ;
    rdfs:comment 'Full legal name of the individual beneficial owner as it appears on official identification documents.' ;
    rdfs:domain ind:CustomerBeneficialOwner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerPostalCode rdf:type rdf:Property ;
    rdfs:label 'Owner Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the beneficial owner\'s residential address.' ;
    rdfs:domain ind:CustomerBeneficialOwner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerResidentialAddress rdf:type rdf:Property ;
    rdfs:label 'Owner Residential Address' ;
    rdfs:comment 'Complete residential street address of the beneficial owner, including street number, street name, apartment or suite number.' ;
    rdfs:domain ind:CustomerBeneficialOwner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerStateProvince rdf:type rdf:Property ;
    rdfs:label 'Owner State Province' ;
    rdfs:comment 'State or province of residence for the beneficial owner.' ;
    rdfs:domain ind:CustomerBeneficialOwner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipStatus rdf:type rdf:Property ;
    rdfs:label 'Ownership Status' ;
    rdfs:comment 'Current lifecycle status of the beneficial ownership record. Verified: ownership confirmed and documented. Pending verification: awaiting documentation. Under review: being investigated or updated. Disputed: conflicting information. Expired: verification period lapsed. Terminated: ownership ended.' ;
    rdfs:domain ind:CustomerBeneficialOwner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipTierLevel rdf:type rdf:Property ;
    rdfs:label 'Ownership Tier Level' ;
    rdfs:comment 'Numeric indicator of the ownership chain depth. 1 = direct ownership, 2 = one intermediary, 3 = two intermediaries, etc. Supports recursive traversal of multi-tier ownership structures for UBO graph construction.' ;
    rdfs:domain ind:CustomerBeneficialOwner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pepScreeningDate rdf:type rdf:Property ;
    rdfs:label 'Pep Screening Date' ;
    rdfs:comment 'Date on which the most recent PEP screening was performed for the beneficial owner.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:riskRatingDate rdf:type rdf:Property ;
    rdfs:label 'Risk Rating Date' ;
    rdfs:comment 'Date when the risk rating was assigned or last reviewed. Used to track risk assessment refresh cycles per risk-based approach requirements.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceOfWealth rdf:type rdf:Property ;
    rdfs:label 'Source Of Wealth' ;
    rdfs:comment 'Description of how the beneficial owner accumulated their wealth (e.g., inheritance, business ownership, employment, investments). Required for enhanced due diligence on high-risk customers and PEPs.' ;
    rdfs:domain ind:CustomerBeneficialOwner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxIdentificationNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Identification Number' ;
    rdfs:comment 'Tax identification number for the beneficial owner in their country of tax residence. Required for FATCA and CRS reporting of beneficial ownership information to tax authorities.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxResidenceCountry rdf:type rdf:Property ;
    rdfs:label 'Tax Residence Country' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code for the beneficial owner\'s country of tax residence. Used for FATCA, CRS, and cross-border tax reporting obligations.' ;
    rdfs:domain ind:CustomerBeneficialOwner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uboThresholdMet rdf:type rdf:Property ;
    rdfs:label 'Ubo Threshold Met' ;
    rdfs:comment 'Boolean indicator of whether this ownership meets the regulatory threshold for UBO reporting (typically 25% ownership or control). True = meets threshold and must be reported. False = below threshold.' ;
    rdfs:domain ind:CustomerBeneficialOwner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:verificationDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Verification Document Reference' ;
    rdfs:comment 'Reference identifier or file path to the supporting documentation used to verify beneficial ownership. Links to document management system for audit trail and regulatory examination.' ;
    rdfs:domain ind:CustomerBeneficialOwner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:votingRightsPercentage rdf:type rdf:Property ;
    rdfs:label 'Voting Rights Percentage' ;
    rdfs:comment 'Percentage of voting rights held by the beneficial owner, which may differ from ownership percentage in cases of non-voting shares or special voting arrangements. Used to assess control for UBO determination.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complaintId rdf:type rdf:Property ;
    rdfs:label 'Complaint Id' ;
    rdfs:comment 'Unique identifier for the customer complaint record. Primary key.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:categoryCodeListId rdf:type rdf:Property ;
    rdfs:label 'Category Code List Id' ;
    rdfs:comment 'Foreign key linking to reference.code_list. Business justification: Complaint management - complaint categories must be standardized for regulatory reporting (CFPB, FCA, ASIC), root cause analysis, and product/service quality improvement initiatives.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CodeList .

ind:complaintAssignedHandlerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Complaint Assigned Handler Employee Id' ;
    rdfs:comment 'Employee identifier of the staff member assigned to investigate and resolve the complaint.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:handlingCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Handling Cost Center Id' ;
    rdfs:comment 'Foreign key linking to ledger.cost_center. Business justification: Complaint handling costs are tracked by cost center for operational risk measurement, service quality cost analysis, and non-interest expense allocation. Required for operational efficiency metrics an' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:managedPortfolioId rdf:type rdf:Property ;
    rdfs:label 'Managed Portfolio Id' ;
    rdfs:comment 'Foreign key linking to wealth.managed_portfolio. Business justification: Portfolio-specific complaints (performance disputes, unauthorized trades, fee billing errors) require direct portfolio linkage for root cause analysis, MiFID II complaint reporting, remediation tracki' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ManagedPortfolio .

ind:channel rdf:type rdf:Property ;
    rdfs:label 'Channel' ;
    rdfs:comment 'Channel through which the complaint was received (branch, digital, phone, written correspondence). [ENUM-REF-CANDIDATE: branch|phone|email|web|mobile_app|written_letter|social_media|atm|relationship_manager — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compensationCurrency rdf:type rdf:Property ;
    rdfs:label 'Compensation Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the compensation amount.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintDate rdf:type rdf:Property ;
    rdfs:label 'Complaint Date' ;
    rdfs:comment 'Date when the complaint was formally received and logged by the institution.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complaintStatus rdf:type rdf:Property ;
    rdfs:label 'Complaint Status' ;
    rdfs:comment 'Current lifecycle status of the complaint in the resolution workflow. [ENUM-REF-CANDIDATE: open|investigating|pending_customer_response|resolved|closed|escalated_to_regulator|withdrawn — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintTimestamp rdf:type rdf:Property ;
    rdfs:label 'Complaint Timestamp' ;
    rdfs:comment 'Precise timestamp when the complaint was received and entered into the system.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:customerSatisfactionRating rdf:type rdf:Property ;
    rdfs:label 'Customer Satisfaction Rating' ;
    rdfs:comment 'Post-resolution customer satisfaction score provided by the complainant, typically on a scale of 1 to 5 or 1 to 10.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productServiceComplained rdf:type rdf:Property ;
    rdfs:label 'Product Service Complained' ;
    rdfs:comment 'The specific banking product or service that is the subject of the complaint (e.g., checking account, credit card, mortgage, wire transfer).' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reference Number' ;
    rdfs:comment 'Reference number assigned by the regulatory authority for tracking the reported complaint.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Date' ;
    rdfs:comment 'Date when the complaint was formally reported to the regulatory authority.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rootCauseCode rdf:type rdf:Property ;
    rdfs:label 'Root Cause Code' ;
    rdfs:comment 'Standardized code identifying the underlying root cause of the complaint for trend analysis and process improvement.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTargetResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Sla Target Resolution Date' ;
    rdfs:comment 'Target date by which the complaint must be resolved according to internal Service Level Agreement (SLA) commitments or regulatory requirements.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:subcategory rdf:type rdf:Property ;
    rdfs:label 'Subcategory' ;
    rdfs:comment 'Detailed subcategory providing granular classification of the complaint issue.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentRecordId rdf:type rdf:Property ;
    rdfs:label 'Consent Record Id' ;
    rdfs:comment 'Unique identifier for the consent record. Primary key.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:consentTypeCodeListId rdf:type rdf:Property ;
    rdfs:label 'Consent Type Code List Id' ;
    rdfs:comment 'Foreign key linking to reference.code_list. Business justification: GDPR/privacy compliance - consent types (Marketing, Data Sharing, Profiling, Third-Party Transfer) must be standardized for regulatory audit trails, consent withdrawal processing, and privacy impact a' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CodeList .

ind:dataSubjectRequestId rdf:type rdf:Property ;
    rdfs:label 'Data Subject Request Id' ;
    rdfs:comment 'Reference to a formal data subject access request (DSAR), right to be forgotten request, or other privacy rights request that triggered the creation or update of this consent record. Null if not associated with a formal request.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DataSubjectRequest .

ind:parentConsentRecordId rdf:type rdf:Property ;
    rdfs:label 'Parent Consent Record Id' ;
    rdfs:comment 'Reference to a prior consent record that this record supersedes or amends. Null for original consent grants. Supports consent version history and audit trail.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConsentRecord .

ind:primaryConsentPartyId rdf:type rdf:Property ;
    rdfs:label 'Primary Consent Party Id' ;
    rdfs:comment 'Reference to the customer, counterparty, or legal entity who granted or withdrew the consent. Links to the party master in the Customer domain.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:consentAuditTrail rdf:type rdf:Property ;
    rdfs:label 'Consent Audit Trail' ;
    rdfs:comment 'Structured or semi-structured log of all state changes, amendments, and actions taken on this consent record. Supports regulatory audit and internal compliance review.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentEvidenceReference rdf:type rdf:Property ;
    rdfs:label 'Consent Evidence Reference' ;
    rdfs:comment 'Reference identifier or URI to the stored evidence of consent, such as a scanned document, recorded call, or digital audit log. Supports regulatory audit and dispute resolution.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Consent Expiry Date' ;
    rdfs:comment 'The date on which the consent automatically expires and is no longer valid. Null for consents with indefinite validity subject to withdrawal.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consentGrantedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Consent Granted Timestamp' ;
    rdfs:comment 'The date and time when the consent was originally granted by the party. Represents the principal business event timestamp for this record.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:consentJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Consent Jurisdiction' ;
    rdfs:comment 'The ISO 3166-1 alpha-3 country code representing the legal jurisdiction under which the consent was granted. Determines applicable privacy and data protection regulations.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentLanguage rdf:type rdf:Property ;
    rdfs:label 'Consent Language' ;
    rdfs:comment 'The ISO 639-2 three-letter language code in which the consent was presented and granted. Ensures compliance with multilingual disclosure requirements.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentMethod rdf:type rdf:Property ;
    rdfs:label 'Consent Method' ;
    rdfs:comment 'The mechanism by which consent was obtained. Distinguishes between explicit opt-in, implicit consent, verbal agreement, or signature-based consent.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentNotes rdf:type rdf:Property ;
    rdfs:label 'Consent Notes' ;
    rdfs:comment 'Free-text field for additional context, special instructions, or clarifications related to the consent. Used for edge cases or manual overrides documented by compliance officers.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentPurpose rdf:type rdf:Property ;
    rdfs:label 'Consent Purpose' ;
    rdfs:comment 'The stated business purpose for which the consent was requested and granted. Aligns with lawful basis for processing under GDPR and business purpose disclosure under CCPA.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentRenewalFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Consent Renewal Frequency Months' ;
    rdfs:comment 'The number of months after which the consent must be renewed, if renewal is required. Null if no periodic renewal is mandated.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:consentRenewalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Consent Renewal Required Flag' ;
    rdfs:comment 'Indicates whether this consent requires periodic renewal or re-confirmation. True if the consent must be refreshed at intervals; false if it remains valid until withdrawn or expired.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Consent Source System' ;
    rdfs:comment 'The name or identifier of the operational system or application that originally captured this consent. Supports data lineage and system-of-record tracking.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentWithdrawnTimestamp rdf:type rdf:Property ;
    rdfs:label 'Consent Withdrawn Timestamp' ;
    rdfs:comment 'The date and time when the consent was withdrawn or revoked by the party. Null if consent has not been withdrawn.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:minorConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Minor Consent Flag' ;
    rdfs:comment 'Indicates whether this consent was granted on behalf of a minor by a parent or legal guardian. True if the party is a minor; false otherwise.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optOutProcessedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Opt Out Processed Timestamp' ;
    rdfs:comment 'The date and time when the opt-out or withdrawal request was fully processed and the consent status was updated. Tracks compliance with regulatory timelines for honoring opt-out requests.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:optOutRequestTimestamp rdf:type rdf:Property ;
    rdfs:label 'Opt Out Request Timestamp' ;
    rdfs:comment 'The date and time when the party submitted a request to opt out or withdraw consent. May differ from consent_withdrawn_timestamp if there is a processing delay.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:thirdPartyRecipient rdf:type rdf:Property ;
    rdfs:label 'Third Party Recipient' ;
    rdfs:comment 'The name or identifier of the third-party organization or affiliate with whom data may be shared under this consent. Null if consent does not involve third-party data sharing.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:corporateProfileId rdf:type rdf:Property ;
    rdfs:label 'Corporate Profile Id' ;
    rdfs:comment 'Unique identifier for the corporate profile record. Primary key.' ;
    rdfs:domain ind:CorporateProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bankingLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Banking Legal Entity Id' ;
    rdfs:comment 'Foreign key linking to ledger.legal_entity. Business justification: Corporate banking relationships are booked to specific bank legal entities for credit risk concentration limits, regulatory capital calculations, and legal entity financial reporting. Essential for Ba' ;
    rdfs:domain ind:CorporateProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:legalFormCodeListId rdf:type rdf:Property ;
    rdfs:label 'Legal Form Code List Id' ;
    rdfs:comment 'Foreign key linking to reference.code_list. Business justification: Legal entity type validation - legal form (LLC, Corporation, Partnership, Trust) affects regulatory treatment, tax reporting, liability assessment, and credit risk evaluation. Must use standardized co' ;
    rdfs:domain ind:CorporateProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CodeList .

ind:parentPartyId rdf:type rdf:Property ;
    rdfs:label 'Parent Party Id' ;
    rdfs:comment 'Foreign key reference to the party_id of the immediate parent company in the corporate hierarchy. Null if the entity is the ultimate parent or has no parent relationship. Used for consolidated reporting and group exposure management.' ;
    rdfs:domain ind:CorporateProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:primaryCorporatePartyId rdf:type rdf:Property ;
    rdfs:label 'Primary Corporate Party Id' ;
    rdfs:comment 'Foreign key reference to the party master table. Links this corporate profile to the corresponding party entity where entity_type is non-individual (corporation, partnership, trust, government agency, etc.).' ;
    rdfs:domain ind:CorporateProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:annualRevenueBand rdf:type rdf:Property ;
    rdfs:label 'Annual Revenue Band' ;
    rdfs:comment 'The revenue size band representing the entity\'s approximate annual revenue or turnover. Used for credit assessment, relationship pricing, and regulatory segmentation. [ENUM-REF-CANDIDATE: 0-1M|1M-10M|10M-50M|50M-100M|100M-500M|500M-1B|1B+ — promote to reference product]' ;
    rdfs:domain ind:CorporateProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditRatingFitch rdf:type rdf:Property ;
    rdfs:label 'Credit Rating Fitch' ;
    rdfs:comment 'The long-term issuer credit rating assigned by Fitch Ratings (e.g., AAA, AA+, BBB-, CCC). Used for credit risk assessment, capital allocation, and pricing decisions.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditRatingMoodys rdf:type rdf:Property ;
    rdfs:label 'Credit Rating Moodys' ;
    rdfs:comment 'The long-term issuer credit rating assigned by Moody\'s Investors Service (e.g., Aaa, Aa1, Baa3, Caa1). Used for credit risk assessment, capital allocation, and pricing decisions.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditRatingSp rdf:type rdf:Property ;
    rdfs:label 'Credit Rating Sp' ;
    rdfs:comment 'The long-term issuer credit rating assigned by Standard & Poor\'s (e.g., AAA, AA+, BBB-, CCC). Used for credit risk assessment, capital allocation, and pricing decisions.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crsJurisdictionOfTaxResidence rdf:type rdf:Property ;
    rdfs:label 'Crs Jurisdiction Of Tax Residence' ;
    rdfs:comment 'The ISO 3166-1 alpha-3 country code of the jurisdiction where the entity is tax resident for CRS purposes. May differ from jurisdiction of incorporation.' ;
    rdfs:domain ind:CorporateProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeCountBand rdf:type rdf:Property ;
    rdfs:label 'Employee Count Band' ;
    rdfs:comment 'The size band representing the approximate number of employees working for the entity. Used for segmentation, credit risk assessment, and regulatory reporting (e.g., SME classification).' ;
    rdfs:domain ind:CorporateProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fatcaClassification rdf:type rdf:Property ;
    rdfs:label 'Fatca Classification' ;
    rdfs:comment 'The entity classification under FATCA regulations: Active NFFE (Non-Financial Foreign Entity), Passive NFFE, FFI (Foreign Financial Institution), Exempt Beneficial Owner, or Non-Participating FFI. Determines FATCA reporting obligations.' ;
    rdfs:domain ind:CorporateProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incorporationDate rdf:type rdf:Property ;
    rdfs:label 'Incorporation Date' ;
    rdfs:comment 'The date on which the entity was legally incorporated or registered in its jurisdiction. Used for entity age calculations and regulatory compliance.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:industryClassificationSystem rdf:type rdf:Property ;
    rdfs:label 'Industry Classification System' ;
    rdfs:comment 'The classification system used for the industry_classification_code field (SIC, NAICS, or ISIC).' ;
    rdfs:domain ind:CorporateProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalCreditRating rdf:type rdf:Property ;
    rdfs:label 'Internal Credit Rating' ;
    rdfs:comment 'The bank\'s internal credit rating assigned to the entity based on proprietary credit risk models and assessment frameworks. Used for IRB (Internal Ratings-Based) approach under Basel III and internal risk management.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kycCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Kyc Completion Date' ;
    rdfs:comment 'The date when the most recent KYC/CDD (Customer Due Diligence) review was completed for this corporate entity. Used to track KYC refresh cycles and regulatory compliance.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalName rdf:type rdf:Property ;
    rdfs:label 'Legal Name' ;
    rdfs:comment 'The full legal name of the corporate entity as registered with the jurisdiction of incorporation. This is the official name used in all legal documents, contracts, and regulatory filings.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Operating Address Line 1' ;
    rdfs:comment 'The first line of the entity\'s primary operating or business address. This may differ from the registered address and represents where the entity conducts its day-to-day business operations.' ;
    rdfs:domain ind:CorporateProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Operating Address Line 2' ;
    rdfs:comment 'The second line of the entity\'s primary operating address (suite, floor, building name, etc.).' ;
    rdfs:domain ind:CorporateProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingCity rdf:type rdf:Property ;
    rdfs:label 'Operating City' ;
    rdfs:comment 'The city or municipality of the entity\'s primary operating address.' ;
    rdfs:domain ind:CorporateProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Operating Country Code' ;
    rdfs:comment 'The ISO 3166-1 alpha-3 country code of the entity\'s primary operating address (e.g., USA, GBR, DEU).' ;
    rdfs:domain ind:CorporateProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingPostalCode rdf:type rdf:Property ;
    rdfs:label 'Operating Postal Code' ;
    rdfs:comment 'The postal or ZIP code of the entity\'s primary operating address.' ;
    rdfs:domain ind:CorporateProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingStateProvince rdf:type rdf:Property ;
    rdfs:label 'Operating State Province' ;
    rdfs:comment 'The state, province, or administrative region of the entity\'s primary operating address.' ;
    rdfs:domain ind:CorporateProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publiclyListedFlag rdf:type rdf:Property ;
    rdfs:label 'Publicly Listed Flag' ;
    rdfs:comment 'Indicates whether the entity is publicly traded on a stock exchange (True) or privately held (False). Affects regulatory requirements, disclosure obligations, and credit risk assessment.' ;
    rdfs:domain ind:CorporateProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:registeredAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Registered Address Line 1' ;
    rdfs:comment 'The first line of the entity\'s registered legal address as filed with the corporate registry. This is the official address for legal correspondence and service of process.' ;
    rdfs:domain ind:CorporateProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Registered Address Line 2' ;
    rdfs:comment 'The second line of the entity\'s registered legal address (suite, floor, building name, etc.).' ;
    rdfs:domain ind:CorporateProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredCity rdf:type rdf:Property ;
    rdfs:label 'Registered City' ;
    rdfs:comment 'The city or municipality of the entity\'s registered legal address.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredCountryCode rdf:type rdf:Property ;
    rdfs:label 'Registered Country Code' ;
    rdfs:comment 'The ISO 3166-1 alpha-3 country code of the entity\'s registered legal address (e.g., USA, GBR, DEU).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredPostalCode rdf:type rdf:Property ;
    rdfs:label 'Registered Postal Code' ;
    rdfs:comment 'The postal or ZIP code of the entity\'s registered legal address.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredStateProvince rdf:type rdf:Property ;
    rdfs:label 'Registered State Province' ;
    rdfs:comment 'The state, province, or administrative region of the entity\'s registered legal address.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationNumber rdf:type rdf:Property ;
    rdfs:label 'Registration Number' ;
    rdfs:comment 'The official registration or incorporation number assigned by the jurisdiction\'s corporate registry (e.g., Companies House number in UK, EIN in USA). Used for legal identification and verification.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockExchangeCode rdf:type rdf:Property ;
    rdfs:label 'Stock Exchange Code' ;
    rdfs:comment 'The Market Identifier Code (MIC) of the primary stock exchange where the entity\'s shares are listed (e.g., XNYS for NYSE, XLON for London Stock Exchange). Null if not publicly listed.' ;
    rdfs:domain ind:CorporateProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockTickerSymbol rdf:type rdf:Property ;
    rdfs:label 'Stock Ticker Symbol' ;
    rdfs:comment 'The ticker symbol or trading symbol used to identify the entity\'s publicly traded shares on the stock exchange. Null if not publicly listed.' ;
    rdfs:domain ind:CorporateProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uboFlag rdf:type rdf:Property ;
    rdfs:label 'Ubo Flag' ;
    rdfs:comment 'Indicates whether this entity is itself an ultimate beneficial owner (True) or is owned by another entity (False). Used for AML/KYC compliance and ownership transparency.' ;
    rdfs:domain ind:CorporateProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerRelationshipManagerId rdf:type rdf:Property ;
    rdfs:label 'Customer Relationship Manager Id' ;
    rdfs:comment 'Unique identifier for the customer relationship manager assignment record.' ;
    rdfs:domain ind:CustomerRelationshipManager ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:coverageRoleCodeListId rdf:type rdf:Property ;
    rdfs:label 'Coverage Role Code List Id' ;
    rdfs:comment 'Foreign key linking to reference.code_list. Business justification: RM role standardization - coverage roles (Primary RM, Secondary RM, Product Specialist, Credit Officer) must be standardized for revenue attribution, client coverage reporting, and compensation calcul' ;
    rdfs:domain ind:CustomerRelationshipManager ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CodeList .

ind:primaryCustomerRmEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Customer Rm Employee Id' ;
    rdfs:comment 'Identifier of the employee serving as the relationship manager or coverage banker for this client party.' ;
    rdfs:domain ind:CustomerRelationshipManager ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:rmProfitCenterId rdf:type rdf:Property ;
    rdfs:label 'Rm Profit Center Id' ;
    rdfs:comment 'Foreign key linking to ledger.profit_center. Business justification: Relationship managers are assigned to profit centers for revenue attribution, performance measurement, and incentive compensation calculation. Required for sales force effectiveness analysis and manag' ;
    rdfs:domain ind:CustomerRelationshipManager ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProfitCenter .

ind:tertiaryCustomerHandoverToRmEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Customer Handover To Rm Employee Id' ;
    rdfs:comment 'Identifier of the new relationship manager to whom this client coverage is being handed over when the current assignment is terminated. Null if no handover is planned.' ;
    rdfs:domain ind:CustomerRelationshipManager ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:clientAum rdf:type rdf:Property ;
    rdfs:label 'Client Aum' ;
    rdfs:comment 'The total assets under management for this client at the time of assignment or most recent valuation. Used for RM portfolio sizing and performance benchmarking. Expressed in the bank\'s reporting currency.' ;
    rdfs:domain ind:CustomerRelationshipManager ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clientRevenueTarget rdf:type rdf:Property ;
    rdfs:label 'Client Revenue Target' ;
    rdfs:comment 'The annual revenue target assigned to this relationship manager for this client. Used for goal setting and performance evaluation. Expressed in the bank\'s reporting currency.' ;
    rdfs:domain ind:CustomerRelationshipManager ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clientSegment rdf:type rdf:Property ;
    rdfs:label 'Client Segment' ;
    rdfs:comment 'The client segmentation category at the time of this assignment. Used to align RM expertise with client needs and for segment-based performance reporting. [ENUM-REF-CANDIDATE: retail|mass_affluent|high_net_worth|ultra_high_net_worth|small_business|middle_market|corporate|institutional|government — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CustomerRelationshipManager ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmRoutingFlag rdf:type rdf:Property ;
    rdfs:label 'Crm Routing Flag' ;
    rdfs:comment 'Boolean flag indicating whether client communications and CRM workflows should be routed to this relationship manager. True for active routing, false otherwise.' ;
    rdfs:domain ind:CustomerRelationshipManager ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geographicCoverageRegion rdf:type rdf:Property ;
    rdfs:label 'Geographic Coverage Region' ;
    rdfs:comment 'The geographic region or territory for which this relationship manager has coverage responsibility. May be country, state, city, or custom-defined territory code.' ;
    rdfs:domain ind:CustomerRelationshipManager ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handoverCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Handover Completion Date' ;
    rdfs:comment 'The date on which the client handover process from the current RM to the new RM was completed. Used to track transition effectiveness.' ;
    rdfs:domain ind:CustomerRelationshipManager ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isPrimary rdf:type rdf:Property ;
    rdfs:label 'Is Primary' ;
    rdfs:comment 'Boolean flag indicating whether this relationship manager is the primary RM for the client. True for primary RM, false for secondary or supporting roles.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:performanceAttributionFlag rdf:type rdf:Property ;
    rdfs:label 'Performance Attribution Flag' ;
    rdfs:comment 'Boolean flag indicating whether this assignment should be included in RM performance attribution and compensation calculations. True for inclusion, false for exclusion.' ;
    rdfs:domain ind:CustomerRelationshipManager ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productCoverageScope rdf:type rdf:Property ;
    rdfs:label 'Product Coverage Scope' ;
    rdfs:comment 'The product or service categories that this relationship manager is authorized to cover for the client. Examples include lending, deposits, treasury, trade finance, capital markets, wealth advisory.' ;
    rdfs:domain ind:CustomerRelationshipManager ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueAttributionPercentage rdf:type rdf:Property ;
    rdfs:label 'Revenue Attribution Percentage' ;
    rdfs:comment 'The percentage of client-generated revenue attributed to this relationship manager for performance measurement and compensation purposes. May differ from coverage percentage based on contribution model.' ;
    rdfs:domain ind:CustomerRelationshipManager ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:riskRatingId rdf:type rdf:Property ;
    rdfs:label 'Risk Rating Id' ;
    rdfs:comment 'Unique identifier for the customer risk rating record. Primary key for this entity.' ;
    rdfs:domain ind:RiskRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryRiskOverrideApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Risk Override Approved By Employee Id' ;
    rdfs:comment 'Employee identifier of the senior compliance officer or Money Laundering Reporting Officer (MLRO) who approved the manual override.' ;
    rdfs:domain ind:RiskRating ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:riskAnalystEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Risk Analyst Employee Id' ;
    rdfs:comment 'Employee identifier of the compliance analyst who performed the risk rating assessment and analysis.' ;
    rdfs:domain ind:RiskRating ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:riskTierCodeListId rdf:type rdf:Property ;
    rdfs:label 'Risk Tier Code List Id' ;
    rdfs:comment 'Foreign key linking to reference.code_list. Business justification: Risk tier standardization - risk tiers (Low, Medium, High, Prohibited) must use enterprise-standard codes for portfolio reporting, transaction monitoring intensity, and regulatory submissions.' ;
    rdfs:domain ind:RiskRating ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CodeList .

ind:adverseInformationRiskScore rdf:type rdf:Property ;
    rdfs:label 'Adverse Information Risk Score' ;
    rdfs:comment 'Risk score component based on adverse media findings, sanctions screening hits, Politically Exposed Person (PEP) status, and negative news. Scale 0-100.' ;
    rdfs:domain ind:RiskRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adverseMediaSummary rdf:type rdf:Property ;
    rdfs:label 'Adverse Media Summary' ;
    rdfs:comment 'Summary of adverse media findings identified during screening, including source, date, and nature of the negative news.' ;
    rdfs:domain ind:RiskRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cddTierRequired rdf:type rdf:Property ;
    rdfs:label 'Cdd Tier Required' ;
    rdfs:comment 'Level of Customer Due Diligence (CDD) required based on the assigned risk tier: simplified for low-risk, standard for medium-risk, enhanced for high-risk and very-high-risk customers.' ;
    rdfs:domain ind:RiskRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerTypeRiskScore rdf:type rdf:Property ;
    rdfs:label 'Customer Type Risk Score' ;
    rdfs:comment 'Risk score component based on customer type classification (individual, corporate, Politically Exposed Person (PEP), non-profit, money services business). Scale 0-100.' ;
    rdfs:domain ind:RiskRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eddRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Edd Required Flag' ;
    rdfs:comment 'Flag indicating whether Enhanced Due Diligence (EDD) procedures are required for this customer based on their risk tier and profile.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geographicRiskScore rdf:type rdf:Property ;
    rdfs:label 'Geographic Risk Score' ;
    rdfs:comment 'Risk score component based on customer domicile, transaction jurisdictions, and exposure to high-risk or sanctioned countries per Financial Action Task Force (FATF) and Office of Foreign Assets Control (OFAC) lists. Scale 0-100.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:kycReviewFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Kyc Review Frequency Months' ;
    rdfs:comment 'Frequency in months for mandatory Know Your Customer (KYC) refresh reviews. Typically 12 months for low-risk, 6 months for medium-risk, 3 months for high-risk customers.' ;
    rdfs:domain ind:RiskRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overallRiskScore rdf:type rdf:Property ;
    rdfs:label 'Overall Risk Score' ;
    rdfs:comment 'Composite risk score calculated from weighted combination of all contributing risk factor scores. This score drives the risk tier assignment. Scale 0-100.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overrideApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Override Approval Date' ;
    rdfs:comment 'Date on which the manual override was formally approved by the authorized compliance officer.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:overrideIndicator rdf:type rdf:Property ;
    rdfs:label 'Override Indicator' ;
    rdfs:comment 'Flag indicating whether the risk tier was manually overridden by a compliance officer, deviating from the model-recommended rating.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overrideJustification rdf:type rdf:Property ;
    rdfs:label 'Override Justification' ;
    rdfs:comment 'Detailed justification narrative for any manual override of the model-recommended risk tier. Required when override_indicator is true.' ;
    rdfs:domain ind:RiskRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorRiskTier rdf:type rdf:Property ;
    rdfs:label 'Prior Risk Tier' ;
    rdfs:comment 'Previous risk tier assigned to this customer before the current rating. Used to track risk rating migration and escalation trends.' ;
    rdfs:domain ind:RiskRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productServiceRiskScore rdf:type rdf:Property ;
    rdfs:label 'Product Service Risk Score' ;
    rdfs:comment 'Risk score component based on the products and services used by the customer (e.g., private banking, correspondent banking, wire transfers, trade finance). Scale 0-100.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ratingDate rdf:type rdf:Property ;
    rdfs:label 'Rating Date' ;
    rdfs:comment 'Date on which the risk rating assessment was performed and the rating was assigned.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ratingMethodology rdf:type rdf:Property ;
    rdfs:label 'Rating Methodology' ;
    rdfs:comment 'Methodology used to derive the risk rating: rule-based scoring, quantitative model, hybrid approach, or manual override by compliance officer.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingRationale rdf:type rdf:Property ;
    rdfs:label 'Rating Rationale' ;
    rdfs:comment 'Detailed narrative explanation of the rationale for the assigned risk tier, including key risk factors, mitigating controls, and compliance officer judgment.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Rating Reference Number' ;
    rdfs:comment 'Business-facing unique reference number for this risk rating assessment, used for audit trails and regulatory reporting.' ;
    rdfs:domain ind:RiskRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingStatus rdf:type rdf:Property ;
    rdfs:label 'Rating Status' ;
    rdfs:comment 'Current lifecycle status of the risk rating record. Active ratings drive operational controls; expired ratings trigger mandatory refresh.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipExitConsiderationFlag rdf:type rdf:Property ;
    rdfs:label 'Relationship Exit Consideration Flag' ;
    rdfs:comment 'Flag indicating whether the risk profile is severe enough to warrant consideration of customer relationship termination or exit.' ;
    rdfs:domain ind:RiskRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riskTierChangeDate rdf:type rdf:Property ;
    rdfs:label 'Risk Tier Change Date' ;
    rdfs:comment 'Date on which the risk tier changed from the prior tier to the current tier. Null if this is the initial rating.' ;
    rdfs:domain ind:RiskRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:riskTierChangeReason rdf:type rdf:Property ;
    rdfs:label 'Risk Tier Change Reason' ;
    rdfs:comment 'Explanation of the reason for the risk tier change, such as change in transaction behavior, new adverse information, or geographic risk escalation.' ;
    rdfs:domain ind:RiskRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sanctionsLastScreenedDate rdf:type rdf:Property ;
    rdfs:label 'Sanctions Last Screened Date' ;
    rdfs:comment 'Date of the most recent sanctions screening performed for this customer. Sanctions screening must be performed at onboarding and periodically thereafter.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sarFilingConsiderationFlag rdf:type rdf:Property ;
    rdfs:label 'Sar Filing Consideration Flag' ;
    rdfs:comment 'Flag indicating whether the risk rating assessment identified activity warranting consideration for Suspicious Activity Report (SAR) filing.' ;
    rdfs:domain ind:RiskRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transactionBehaviorRiskScore rdf:type rdf:Property ;
    rdfs:label 'Transaction Behavior Risk Score' ;
    rdfs:comment 'Risk score component based on transaction volume, velocity, complexity, and deviation from expected activity profile. Scale 0-100.' ;
    rdfs:domain ind:RiskRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionMonitoringRuleIntensity rdf:type rdf:Property ;
    rdfs:label 'Transaction Monitoring Rule Intensity' ;
    rdfs:comment 'Intensity level for transaction monitoring rules and thresholds applied to this customer. Higher risk tiers trigger more sensitive detection rules and lower alert thresholds.' ;
    rdfs:domain ind:RiskRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentId rdf:type rdf:Property ;
    rdfs:label 'Segment Id' ;
    rdfs:comment 'Foreign key reference to the segment definition. Links to the segment master table that defines segment criteria and characteristics.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Assigned By Employee Id' ;
    rdfs:comment 'Foreign key reference to the employee who manually assigned or approved this segment assignment. Populated for MANUAL_OVERRIDE assignments or when manual approval is required.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:lobCodeListId rdf:type rdf:Property ;
    rdfs:label 'Lob Code List Id' ;
    rdfs:comment 'Foreign key linking to reference.code_list. Business justification: Line of business standardization - LOB codes (Retail Banking, Commercial Banking, Investment Banking, Wealth Management) must be consistent for P&L reporting, regulatory submissions, and segment perfo' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CodeList .

ind:assignmentMethod rdf:type rdf:Property ;
    rdfs:label 'Assignment Method' ;
    rdfs:comment 'The methodology used to assign the party to this segment. RULE_BASED: automated rule engine based on predefined criteria; MANUAL_OVERRIDE: manual assignment by relationship manager or operations; MODEL_DRIVEN: machine learning or statistical model output.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assignment Timestamp' ;
    rdfs:comment 'Timestamp when this segment assignment record was created in the system. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX. Supports audit trail and temporal analysis.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:aumThresholdMax rdf:type rdf:Property ;
    rdfs:label 'Aum Threshold Max' ;
    rdfs:comment 'Maximum Assets Under Management threshold for this segment assignment. Defines the upper bound of the segment tier. Expressed in base currency.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:aumThresholdMin rdf:type rdf:Property ;
    rdfs:label 'Aum Threshold Min' ;
    rdfs:comment 'Minimum Assets Under Management threshold required for this segment assignment. Used for wealth management and private banking segmentation. Expressed in base currency.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:campaignEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Campaign Eligibility Flag' ;
    rdfs:comment 'Boolean flag indicating whether customers in this segment are eligible for targeted marketing campaigns. False may indicate regulatory restrictions or opt-out status.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cltvCohort rdf:type rdf:Property ;
    rdfs:label 'Cltv Cohort' ;
    rdfs:comment 'CLTV-based cohort classification for segment analysis and targeted campaigns. Values: HIGH (top tier value), MEDIUM (mid tier value), LOW (entry tier value).' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cltvScore rdf:type rdf:Property ;
    rdfs:label 'Cltv Score' ;
    rdfs:comment 'Calculated Customer Lifetime Value score at the time of segment assignment. Used for cohort analysis and segment migration tracking. Higher scores indicate greater long-term value.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ftpPricingTier rdf:type rdf:Property ;
    rdfs:label 'Ftp Pricing Tier' ;
    rdfs:comment 'Funds Transfer Pricing tier associated with this segment. Determines internal cost of funds allocation and profitability measurement. Aligns with segment-based pricing strategy.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCurrent rdf:type rdf:Property ;
    rdfs:label 'Is Current' ;
    rdfs:comment 'Boolean flag indicating whether this is the currently active segment assignment for the party. True for the active record, False for historical records.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:modelRunReference rdf:type rdf:Property ;
    rdfs:label 'Model Run Reference' ;
    rdfs:comment 'Identifier of the segmentation model execution run that produced this assignment. Enables traceability and model performance analysis. Populated only when assignment_method is MODEL_DRIVEN.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideRationale rdf:type rdf:Property ;
    rdfs:label 'Override Rationale' ;
    rdfs:comment 'Business justification for manual override of the system-recommended segment assignment. Required when override_flag is True. Supports audit and compliance review.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousSegmentCode rdf:type rdf:Property ;
    rdfs:label 'Previous Segment Code' ;
    rdfs:comment 'The segment code that was active immediately prior to this assignment. Enables segment migration analysis and transition tracking. Null for initial segment assignments.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordStatus rdf:type rdf:Property ;
    rdfs:label 'Record Status' ;
    rdfs:comment 'Current status of this segment assignment record in the data warehouse. ACTIVE: currently in effect; INACTIVE: expired or terminated; SUPERSEDED: replaced by a newer assignment; PENDING: awaiting approval or activation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueThresholdMax rdf:type rdf:Property ;
    rdfs:label 'Revenue Threshold Max' ;
    rdfs:comment 'Maximum annual revenue threshold for corporate and commercial customer segmentation. Defines the upper bound of the segment tier. Expressed in base currency.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueThresholdMin rdf:type rdf:Property ;
    rdfs:label 'Revenue Threshold Min' ;
    rdfs:comment 'Minimum annual revenue threshold for corporate and commercial customer segmentation. Used to classify SME, mid-market, and large corporate segments. Expressed in base currency.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:segmentCode rdf:type rdf:Property ;
    rdfs:label 'Segment Code' ;
    rdfs:comment 'Business code representing the customer segment classification. Values include: MASS_MARKET (mass market retail), MASS_AFFLUENT (mass affluent retail), HNW (High Net Worth), UHNW (Ultra High Net Worth), SME (Small and Medium Enterprise), MID_MARKET (mid-market corporate). [ENUM-REF-CANDIDATE: MASS_MARKET|MASS_AFFLUENT|HNW|UHNW|SME|MID_MARKET|LARGE_CORPORATE|INSTITUTIONAL|GOVERNMENT — promote to reference product]' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentName rdf:type rdf:Property ;
    rdfs:label 'Segment Name' ;
    rdfs:comment 'Human-readable name of the customer segment for reporting and display purposes.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceLevel rdf:type rdf:Property ;
    rdfs:label 'Service Level' ;
    rdfs:comment 'Service level entitlement associated with this segment. Determines access to relationship managers, priority servicing, and product offerings. Values: PREMIUM (dedicated RM, priority service), STANDARD (shared RM, standard service), BASIC (self-service, limited support).' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subSegment rdf:type rdf:Property ;
    rdfs:label 'Sub Segment' ;
    rdfs:comment 'Granular sub-classification within the primary segment, enabling more precise targeting and analysis (e.g., within HNW: emerging wealth, established wealth, legacy wealth).' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transitionDate rdf:type rdf:Property ;
    rdfs:label 'Transition Date' ;
    rdfs:comment 'The date on which the customer transitioned from the previous segment to the current segment. Used for segment migration reporting and trend analysis. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transitionReason rdf:type rdf:Property ;
    rdfs:label 'Transition Reason' ;
    rdfs:comment 'Business reason for the segment transition (e.g., AUM growth, revenue decline, relationship upgrade, regulatory reclassification). Supports root cause analysis of segment movements.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fatcaCrsClassificationId rdf:type rdf:Property ;
    rdfs:label 'Fatca Crs Classification Id' ;
    rdfs:comment 'Unique identifier for the FATCA and CRS tax classification record.' ;
    rdfs:domain ind:FatcaCrsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fatcaClassificationCodeListId rdf:type rdf:Property ;
    rdfs:label 'Fatca Classification Code List Id' ;
    rdfs:comment 'Foreign key linking to reference.code_list. Business justification: FATCA compliance - classification codes (US Person, Passive NFFE, Active NFFE, FFI) must use IRS-standard codes for Form 1099/8966 reporting and withholding calculations.' ;
    rdfs:domain ind:FatcaCrsClassification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CodeList .

ind:reportingLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Reporting Legal Entity Id' ;
    rdfs:comment 'Foreign key linking to ledger.legal_entity. Business justification: FATCA and CRS reporting obligations are legal-entity-specific; each classification must identify which bank legal entity has the reporting obligation to IRS or foreign tax authorities. Required for re' ;
    rdfs:domain ind:FatcaCrsClassification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:taxResidenceCountryId rdf:type rdf:Property ;
    rdfs:label 'Tax Residence Country Id' ;
    rdfs:comment 'Foreign key linking to reference.country. Business justification: FATCA/CRS compliance - tax residence country must be validated for automatic exchange of information (AEOI) reporting, withholding calculations, and treaty benefit determination.' ;
    rdfs:domain ind:FatcaCrsClassification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:chapter4Status rdf:type rdf:Property ;
    rdfs:label 'Chapter 4 Status' ;
    rdfs:comment 'The detailed Chapter 4 (FATCA) status code assigned to the party by the financial institution. This is a more granular classification than the basic FATCA classification code and aligns with IRS reporting requirements. Examples include specific FFI types, exempt beneficial owner categories, and NFFE subcategories.' ;
    rdfs:domain ind:FatcaCrsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classificationStatus rdf:type rdf:Property ;
    rdfs:label 'Classification Status' ;
    rdfs:comment 'Current status of this FATCA/CRS classification record. Active indicates the classification is current and valid; Pending Review indicates documentation is under review; Expired indicates the certification has expired; Superseded indicates a newer classification exists; Invalid indicates the classification was determined to be incorrect.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controllingPersonFlag rdf:type rdf:Property ;
    rdfs:label 'Controlling Person Flag' ;
    rdfs:comment 'Indicates whether this classification record pertains to a controlling person of a passive NFE (Non-Financial Entity) under CRS. Controlling persons of passive NFEs must be identified and reported.' ;
    rdfs:domain ind:FatcaCrsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crsReportableJurisdictionList rdf:type rdf:Property ;
    rdfs:label 'Crs Reportable Jurisdiction List' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes representing jurisdictions to which this party\'s financial account information must be reported under CRS. Empty if not reportable.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:curePeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Cure Period End Date' ;
    rdfs:comment 'The date on which the cure period expires. Typically 90 days from the cure period start date.' ;
    rdfs:domain ind:FatcaCrsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:curePeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Cure Period Start Date' ;
    rdfs:comment 'The date on which the cure period began for resolving US indicia or documentation deficiencies. Typically triggered when indicia are detected.' ;
    rdfs:domain ind:FatcaCrsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:curePeriodStatus rdf:type rdf:Property ;
    rdfs:label 'Cure Period Status' ;
    rdfs:comment 'Status of the cure period for resolving US indicia or documentation deficiencies. Cure Pending indicates the party is within the 90-day cure period; Cure Completed indicates documentation was provided; Cure Expired indicates the cure period lapsed without resolution.' ;
    rdfs:domain ind:FatcaCrsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentationCompleteFlag rdf:type rdf:Property ;
    rdfs:label 'Documentation Complete Flag' ;
    rdfs:comment 'Indicates whether all required FATCA/CRS documentation has been collected and validated for this party. True if documentation is complete and valid.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:documentationReference rdf:type rdf:Property ;
    rdfs:label 'Documentation Reference' ;
    rdfs:comment 'Reference identifier or file path to the stored self-certification forms and supporting documentation for this FATCA/CRS classification.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fatcaGiin rdf:type rdf:Property ;
    rdfs:label 'Fatca Giin' ;
    rdfs:comment 'The Global Intermediary Identification Number assigned to the party if it is a Foreign Financial Institution (FFI) registered with the IRS for FATCA compliance. Format: 6 alphanumeric characters, dot, 5 alphanumeric characters, dot, 2-letter entity type, dot, 3-digit branch code.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonNoTin rdf:type rdf:Property ;
    rdfs:label 'Reason No Tin' ;
    rdfs:comment 'The reason why a Tax Identification Number (TIN) was not provided by the party. Not Required indicates the jurisdiction does not issue TINs; Not Issued indicates the party has not been issued a TIN; Applied For indicates the party has applied but not yet received a TIN; Other requires explanation.' ;
    rdfs:domain ind:FatcaCrsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recalcitrantAccountHolderFlag rdf:type rdf:Property ;
    rdfs:label 'Recalcitrant Account Holder Flag' ;
    rdfs:comment 'Indicates whether the party is classified as a recalcitrant account holder under FATCA due to failure to provide required documentation or information. Recalcitrant account holders are subject to 30% withholding.' ;
    rdfs:domain ind:FatcaCrsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportingObligationFlag rdf:type rdf:Property ;
    rdfs:label 'Reporting Obligation Flag' ;
    rdfs:comment 'Indicates whether the financial institution has a reporting obligation for this party under FATCA or CRS. True if the party is reportable to IRS or foreign tax authorities.' ;
    rdfs:domain ind:FatcaCrsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:secondaryTaxResidenceCountryCode rdf:type rdf:Property ;
    rdfs:label 'Secondary Tax Residence Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing a secondary country of tax residence for the party, if applicable. Some individuals or entities may have dual tax residency.' ;
    rdfs:domain ind:FatcaCrsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:selfCertificationDate rdf:type rdf:Property ;
    rdfs:label 'Self Certification Date' ;
    rdfs:comment 'The date on which the party completed and submitted the self-certification form.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:selfCertificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Self Certification Expiry Date' ;
    rdfs:comment 'The date on which the current self-certification expires and requires renewal. Typically 3 years from certification date or upon change in circumstances.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:selfCertificationFormType rdf:type rdf:Property ;
    rdfs:label 'Self Certification Form Type' ;
    rdfs:comment 'The type of tax self-certification form provided by the party. W-9 for US persons; W-8 series for non-US persons claiming treaty benefits or exemptions; CRS Self-Certification for CRS reportable persons; Entity Self-Certification for entities. [ENUM-REF-CANDIDATE: W-9|W-8BEN|W-8BEN-E|W-8ECI|W-8EXP|W-8IMY|CRS_SELF_CERT|ENTITY_SELF_CERT|NOT_PROVIDED — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usIndiciaAddressFlag rdf:type rdf:Property ;
    rdfs:label 'Us Indicia Address Flag' ;
    rdfs:comment 'Indicates whether the party has a US address on file, which is an indicium of US person status under FATCA.' ;
    rdfs:domain ind:FatcaCrsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:usIndiciaBirthplaceFlag rdf:type rdf:Property ;
    rdfs:label 'Us Indicia Birthplace Flag' ;
    rdfs:comment 'Indicates whether the party has a US place of birth recorded, which is an indicium of US person status under FATCA.' ;
    rdfs:domain ind:FatcaCrsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:usIndiciaInCareOfFlag rdf:type rdf:Property ;
    rdfs:label 'Us Indicia In Care Of Flag' ;
    rdfs:comment 'Indicates whether the party has an in-care-of address or hold mail instruction that is the sole address on file, which is an indicium requiring further documentation under FATCA.' ;
    rdfs:domain ind:FatcaCrsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:usIndiciaPhoneFlag rdf:type rdf:Property ;
    rdfs:label 'Us Indicia Phone Flag' ;
    rdfs:comment 'Indicates whether the party has a US telephone number on file, which is an indicium of US person status under FATCA.' ;
    rdfs:domain ind:FatcaCrsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:usIndiciaPowerOfAttorneyFlag rdf:type rdf:Property ;
    rdfs:label 'Us Indicia Power Of Attorney Flag' ;
    rdfs:comment 'Indicates whether the party has granted power of attorney or signatory authority to a person with a US address, which is an indicium of US person status under FATCA.' ;
    rdfs:domain ind:FatcaCrsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:usIndiciaStandingInstructionFlag rdf:type rdf:Property ;
    rdfs:label 'Us Indicia Standing Instruction Flag' ;
    rdfs:comment 'Indicates whether the party has standing instructions to transfer funds to a US address, which is an indicium of US person status under FATCA.' ;
    rdfs:domain ind:FatcaCrsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:withholdingRatePercent rdf:type rdf:Property ;
    rdfs:label 'Withholding Rate Percent' ;
    rdfs:comment 'The applicable FATCA withholding tax rate (as a percentage) for this party. Typically 30% for recalcitrant account holders or non-participating FFIs, 0% for compliant parties.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:individualProfileId rdf:type rdf:Property ;
    rdfs:label 'Individual Profile Id' ;
    rdfs:comment 'Unique identifier for the individual profile record. Primary key for natural-person parties in retail and private banking segments.' ;
    rdfs:domain ind:IndividualProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:genderCodeListId rdf:type rdf:Property ;
    rdfs:label 'Gender Code List Id' ;
    rdfs:comment 'Foreign key linking to reference.code_list. Business justification: Demographic standardization - gender codes must be standardized for fair lending analysis (HMDA reporting), regulatory compliance, and demographic segmentation. Regulatory reporting requirement.' ;
    rdfs:domain ind:IndividualProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CodeList .

ind:annualIncomeAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Income Amount' ;
    rdfs:comment 'Total gross annual income declared by the individual in the banks reporting currency. Core input for credit decisioning, loan-to-income ratio calculations, and wealth management suitability assessments.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annualIncomeCurrency rdf:type rdf:Property ;
    rdfs:label 'Annual Income Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the declared annual income. Required for multi-currency operations and foreign exchange risk assessment.' ;
    rdfs:domain ind:IndividualProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:biometricAuthenticationEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Biometric Authentication Enabled Flag' ;
    rdfs:comment 'Indicates whether the individual has enabled biometric authentication (fingerprint, face recognition) for digital banking access. Used for security posture assessment and fraud risk scoring.' ;
    rdfs:domain ind:IndividualProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cltvCalculationDate rdf:type rdf:Property ;
    rdfs:label 'Cltv Calculation Date' ;
    rdfs:comment 'Date when the CLTV score was last calculated or refreshed. Used for model recency validation and refresh scheduling.' ;
    rdfs:domain ind:IndividualProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditBureauReportingConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Credit Bureau Reporting Consent Flag' ;
    rdfs:comment 'Indicates whether the individual has consented to the bank reporting their credit activity to credit bureaus. Required in jurisdictions with opt-in credit reporting regimes.' ;
    rdfs:domain ind:IndividualProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataSharingConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Consent Flag' ;
    rdfs:comment 'Indicates whether the individual has consented to sharing their data with third parties (affiliates, partners, credit bureaus). Required for GDPR and CCPA compliance.' ;
    rdfs:domain ind:IndividualProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:digitalBankingEnrollmentDate rdf:type rdf:Property ;
    rdfs:label 'Digital Banking Enrollment Date' ;
    rdfs:comment 'Date when the individual first enrolled in digital banking services. Used for cohort analysis, digital maturity scoring, and customer lifecycle stage determination.' ;
    rdfs:domain ind:IndividualProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:digitalBankingEnrollmentFlag rdf:type rdf:Property ;
    rdfs:label 'Digital Banking Enrollment Flag' ;
    rdfs:comment 'Indicates whether the individual has completed enrollment in the banks digital banking platform (online and mobile banking). Used for channel analytics, digital adoption tracking, and omnichannel strategy.' ;
    rdfs:domain ind:IndividualProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:educationLevel rdf:type rdf:Property ;
    rdfs:label 'Education Level' ;
    rdfs:comment 'Highest level of formal education attained by the individual. Used for customer segmentation, product targeting, and financial literacy program design. [ENUM-REF-CANDIDATE: high_school|associate|bachelor|master|doctorate|professional|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:IndividualProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employerName rdf:type rdf:Property ;
    rdfs:label 'Employer Name' ;
    rdfs:comment 'Legal name of the individuals current employer or business entity if self-employed. Used for income verification, employment stability assessment, and corporate banking cross-sell opportunities.' ;
    rdfs:domain ind:IndividualProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employmentStatus rdf:type rdf:Property ;
    rdfs:label 'Employment Status' ;
    rdfs:comment 'Current employment classification of the individual. Critical input for credit risk assessment, loan origination decisioning, and income verification workflows.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kycRefreshDueDate rdf:type rdf:Property ;
    rdfs:label 'Kyc Refresh Due Date' ;
    rdfs:comment 'Next scheduled date for periodic KYC refresh and customer due diligence update. Frequency is risk-based per AML regulations (typically annual for high-risk, biennial for medium-risk, triennial for low-risk).' ;
    rdfs:domain ind:IndividualProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maritalStatus rdf:type rdf:Property ;
    rdfs:label 'Marital Status' ;
    rdfs:comment 'Current marital or civil partnership status of the individual. Impacts credit assessment, joint account eligibility, and wealth planning strategies.' ;
    rdfs:domain ind:IndividualProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingConsentDate rdf:type rdf:Property ;
    rdfs:label 'Marketing Consent Date' ;
    rdfs:comment 'Date when the individual provided or last updated their marketing consent. Used for consent lifecycle management and regulatory audit trails.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:marketingConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Marketing Consent Flag' ;
    rdfs:comment 'Indicates whether the individual has provided explicit consent to receive marketing communications. Required for GDPR, CCPA, and CAN-SPAM compliance.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mobileAppUserFlag rdf:type rdf:Property ;
    rdfs:label 'Mobile App User Flag' ;
    rdfs:comment 'Indicates whether the individual has downloaded and activated the banks mobile banking application. Used for mobile engagement metrics and push notification eligibility.' ;
    rdfs:domain ind:IndividualProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netWorthBand rdf:type rdf:Property ;
    rdfs:label 'Net Worth Band' ;
    rdfs:comment 'Categorized range of the individuals total net worth (assets minus liabilities). Used for private banking eligibility, wealth management segmentation, and high-net-worth individual (HNWI) identification.' ;
    rdfs:domain ind:IndividualProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npsSurveyDate rdf:type rdf:Property ;
    rdfs:label 'Nps Survey Date' ;
    rdfs:comment 'Date when the most recent NPS score was collected. Used for trend analysis and survey recency validation.' ;
    rdfs:domain ind:IndividualProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:numberOfDependents rdf:type rdf:Property ;
    rdfs:label 'Number Of Dependents' ;
    rdfs:comment 'Count of financial dependents claimed by the individual. Used in credit underwriting, affordability assessments, and wealth management planning.' ;
    rdfs:domain ind:IndividualProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:occupationCode rdf:type rdf:Property ;
    rdfs:label 'Occupation Code' ;
    rdfs:comment 'Standardized occupation classification code (NAICS or SIC) representing the individuals primary profession. Enables industry-based risk segmentation and targeted product offerings.' ;
    rdfs:domain ind:IndividualProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:occupationDescription rdf:type rdf:Property ;
    rdfs:label 'Occupation Description' ;
    rdfs:comment 'Free-text description of the individuals job title or professional role. Complements occupation_code with human-readable context for relationship managers and underwriters.' ;
    rdfs:domain ind:IndividualProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pepClassification rdf:type rdf:Property ;
    rdfs:label 'Pep Classification' ;
    rdfs:comment 'Specific category of PEP status if pep_flag is true. Determines the level of enhanced due diligence and monitoring intensity required under AML frameworks.' ;
    rdfs:domain ind:IndividualProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredContactMethod rdf:type rdf:Property ;
    rdfs:label 'Preferred Contact Method' ;
    rdfs:comment 'Individuals stated preference for primary communication channel. Used by CRM systems to optimize customer engagement, regulatory notifications, and marketing campaign delivery.' ;
    rdfs:domain ind:IndividualProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredLanguage rdf:type rdf:Property ;
    rdfs:label 'Preferred Language' ;
    rdfs:comment 'ISO 639-1 two-letter language code representing the individuals preferred language for communications and service delivery. Ensures compliance with language access requirements and enhances customer experience.' ;
    rdfs:domain ind:IndividualProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Profile Created Timestamp' ;
    rdfs:comment 'Timestamp when the individual profile record was first created in the system. Used for audit trails, data lineage, and customer tenure calculations.' ;
    rdfs:domain ind:IndividualProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:profileStatus rdf:type rdf:Property ;
    rdfs:label 'Profile Status' ;
    rdfs:comment 'Current lifecycle status of the individual profile. Controls access to banking services, reporting inclusion, and regulatory treatment.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Profile Updated Timestamp' ;
    rdfs:comment 'Timestamp when the individual profile record was last modified. Used for change tracking, data freshness assessment, and audit compliance.' ;
    rdfs:domain ind:IndividualProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:taxResidencyCountries rdf:type rdf:Property ;
    rdfs:label 'Tax Residency Countries' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes representing all jurisdictions where the individual is a tax resident. Required for CRS (Common Reporting Standard) compliance and automatic exchange of information.' ;
    rdfs:domain ind:IndividualProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usPersonFlag rdf:type rdf:Property ;
    rdfs:label 'Us Person Flag' ;
    rdfs:comment 'Indicates whether the individual is classified as a US person under FATCA regulations (US citizen, green card holder, or US tax resident). Triggers IRS Form W-9 collection and FATCA reporting obligations.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kycRecordId rdf:type rdf:Property ;
    rdfs:label 'Kyc Record Id' ;
    rdfs:comment 'Unique identifier for the KYC/CDD record. Primary key.' ;
    rdfs:domain ind:KycRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:kycTierCodeListId rdf:type rdf:Property ;
    rdfs:label 'Kyc Tier Code List Id' ;
    rdfs:comment 'Foreign key linking to reference.code_list. Business justification: KYC framework standardization - KYC tiers (Simplified, Standard, Enhanced Due Diligence) must be standardized per regulatory framework (risk-based approach) for consistent compliance application.' ;
    rdfs:domain ind:KycRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CodeList .

ind:primaryKycAnalystEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Kyc Analyst Employee Id' ;
    rdfs:comment 'Reference to the compliance analyst employee who performed the KYC review.' ;
    rdfs:domain ind:KycRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:adverseMediaScreeningResult rdf:type rdf:Property ;
    rdfs:label 'Adverse Media Screening Result' ;
    rdfs:comment 'Result of screening against adverse media sources for negative news related to financial crime, fraud, or reputational risk.' ;
    rdfs:domain ind:KycRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficialOwnershipVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Beneficial Ownership Verification Date' ;
    rdfs:comment 'The date when beneficial ownership information was last verified.' ;
    rdfs:domain ind:KycRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:beneficialOwnershipVerified rdf:type rdf:Property ;
    rdfs:label 'Beneficial Ownership Verified' ;
    rdfs:comment 'Indicates whether beneficial ownership information has been collected and verified for corporate or trust entities, as required by FinCEN CDD Rule.' ;
    rdfs:domain ind:KycRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cddCompletionStatus rdf:type rdf:Property ;
    rdfs:label 'Cdd Completion Status' ;
    rdfs:comment 'Status of the standard Customer Due Diligence process completion.' ;
    rdfs:domain ind:KycRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerRiskProfile rdf:type rdf:Property ;
    rdfs:label 'Customer Risk Profile' ;
    rdfs:comment 'Comprehensive narrative risk profile summarizing all risk factors, business activities, geographic exposure, and other considerations relevant to AML risk assessment.' ;
    rdfs:domain ind:KycRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eddCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Edd Completion Date' ;
    rdfs:comment 'The date when Enhanced Due Diligence procedures were completed, if applicable.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eddCompletionStatus rdf:type rdf:Property ;
    rdfs:label 'Edd Completion Status' ;
    rdfs:comment 'Status of the Enhanced Due Diligence process if required.' ;
    rdfs:domain ind:KycRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionRiskScore rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Risk Score' ;
    rdfs:comment 'Numeric risk score (0-100) based on the customer\'s operating jurisdictions and geographic risk factors, with higher scores indicating higher risk.' ;
    rdfs:domain ind:KycRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:kycDocumentationComplete rdf:type rdf:Property ;
    rdfs:label 'Kyc Documentation Complete' ;
    rdfs:comment 'Indicates whether all required KYC documentation (identity documents, proof of address, business registration, etc.) has been collected and verified.' ;
    rdfs:domain ind:KycRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastSarFilingDate rdf:type rdf:Property ;
    rdfs:label 'Last Sar Filing Date' ;
    rdfs:comment 'The date when the most recent Suspicious Activity Report was filed for this customer, if applicable. Highly confidential.' ;
    rdfs:domain ind:KycRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:onboardingDate rdf:type rdf:Property ;
    rdfs:label 'Onboarding Date' ;
    rdfs:comment 'The date when the customer relationship was initially established and KYC onboarding was completed.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pepScreeningResult rdf:type rdf:Property ;
    rdfs:label 'Pep Screening Result' ;
    rdfs:comment 'Result of screening against Politically Exposed Person lists. Match identified requires enhanced scrutiny.' ;
    rdfs:domain ind:KycRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorRiskRating rdf:type rdf:Property ;
    rdfs:label 'Prior Risk Rating' ;
    rdfs:comment 'The AML risk rating assigned before the most recent review, used to track rating changes over time.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipRiskScore rdf:type rdf:Property ;
    rdfs:label 'Relationship Risk Score' ;
    rdfs:comment 'Numeric risk score (0-100) based on the customer\'s business relationships, ownership structure, and counterparty network, with higher scores indicating higher risk.' ;
    rdfs:domain ind:KycRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reviewOutcome rdf:type rdf:Property ;
    rdfs:label 'Review Outcome' ;
    rdfs:comment 'The outcome of the most recent KYC review: no change to risk rating, risk upgraded, risk downgraded, escalated to Enhanced Due Diligence, or relationship terminated/exited.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskRatingRationale rdf:type rdf:Property ;
    rdfs:label 'Risk Rating Rationale' ;
    rdfs:comment 'Detailed explanation and justification for the assigned AML risk rating, including contributing factors and risk indicators.' ;
    rdfs:domain ind:KycRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sanctionsScreeningResult rdf:type rdf:Property ;
    rdfs:label 'Sanctions Screening Result' ;
    rdfs:comment 'Result of screening against international sanctions lists (OFAC, UN, EU, etc.). Match identified triggers immediate escalation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionRiskScore rdf:type rdf:Property ;
    rdfs:label 'Transaction Risk Score' ;
    rdfs:comment 'Numeric risk score (0-100) based on the customer\'s transaction patterns, volumes, and behaviors, with higher scores indicating higher risk.' ;
    rdfs:domain ind:KycRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:kycReviewEventId rdf:type rdf:Property ;
    rdfs:label 'Kyc Review Event Id' ;
    rdfs:comment 'Unique identifier for the KYC review event record.' ;
    rdfs:domain ind:KycReviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Review Cost Center Id' ;
    rdfs:comment 'Foreign key linking to ledger.cost_center. Business justification: KYC review activities incur compliance costs allocated to cost centers for regulatory cost tracking, AML program cost measurement, and operational expense budgeting. Required for compliance function c' ;
    rdfs:domain ind:KycReviewEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:reviewTypeCodeListId rdf:type rdf:Property ;
    rdfs:label 'Review Type Code List Id' ;
    rdfs:comment 'Foreign key linking to reference.code_list. Business justification: KYC review classification - review types (Periodic, Event-Driven, Regulatory, Risk-Based) must be standardized for compliance reporting, audit trails, and KYC program effectiveness measurement.' ;
    rdfs:domain ind:KycReviewEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CodeList .

ind:adverseMediaFindingsFlag rdf:type rdf:Property ;
    rdfs:label 'Adverse Media Findings Flag' ;
    rdfs:comment 'Indicates whether adverse media findings were identified during this review (True if adverse media found, False otherwise).' ;
    rdfs:domain ind:KycReviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:beneficialOwnershipVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Beneficial Ownership Verified Flag' ;
    rdfs:comment 'Indicates whether beneficial ownership information was verified during this review (True if verified, False otherwise). Applicable for legal entity customers.' ;
    rdfs:domain ind:KycReviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:documentsReviewedCount rdf:type rdf:Property ;
    rdfs:label 'Documents Reviewed Count' ;
    rdfs:comment 'The number of customer documents reviewed and validated during this KYC review event.' ;
    rdfs:domain ind:KycReviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:documentsUpdatedCount rdf:type rdf:Property ;
    rdfs:label 'Documents Updated Count' ;
    rdfs:comment 'The number of customer documents that were updated or refreshed as a result of this KYC review.' ;
    rdfs:domain ind:KycReviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:newRiskRating rdf:type rdf:Property ;
    rdfs:label 'New Risk Rating' ;
    rdfs:comment 'The customer risk rating assigned as a result of this review event.' ;
    rdfs:domain ind:KycReviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryMandateReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Mandate Reference' ;
    rdfs:comment 'Reference number or citation of the regulatory mandate or examination request that triggered this review, if applicable.' ;
    rdfs:domain ind:KycReviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipExitDate rdf:type rdf:Property ;
    rdfs:label 'Relationship Exit Date' ;
    rdfs:comment 'The date on which the customer relationship was exited or terminated as a result of this review, if applicable. Null if relationship continues.' ;
    rdfs:domain ind:KycReviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:relationshipExitReason rdf:type rdf:Property ;
    rdfs:label 'Relationship Exit Reason' ;
    rdfs:comment 'Detailed reason for exiting the customer relationship, if applicable.' ;
    rdfs:domain ind:KycReviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewScope rdf:type rdf:Property ;
    rdfs:label 'Review Scope' ;
    rdfs:comment 'The scope or depth of the KYC review conducted (full comprehensive review, limited refresh, targeted investigation, or expedited review).' ;
    rdfs:domain ind:KycReviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskRatingChangeFlag rdf:type rdf:Property ;
    rdfs:label 'Risk Rating Change Flag' ;
    rdfs:comment 'Indicates whether the risk rating changed as a result of this review (True if changed, False if no change).' ;
    rdfs:domain ind:KycReviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sarReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Sar Reference Number' ;
    rdfs:comment 'Reference number of the Suspicious Activity Report filed, if applicable. Null if no SAR was filed.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceOfFundsVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Source Of Funds Verified Flag' ;
    rdfs:comment 'Indicates whether the source of funds was verified during this review (True if verified, False otherwise).' ;
    rdfs:domain ind:KycReviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceOfWealthVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Source Of Wealth Verified Flag' ;
    rdfs:comment 'Indicates whether the source of wealth was verified during this review (True if verified, False otherwise). Typically required for high-risk customers.' ;
    rdfs:domain ind:KycReviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:triggerReason rdf:type rdf:Property ;
    rdfs:label 'Trigger Reason' ;
    rdfs:comment 'Detailed explanation of the specific reason or event that triggered this KYC review (e.g., scheduled refresh, suspicious transaction alert, adverse media hit, regulatory request).' ;
    rdfs:domain ind:KycReviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onboardingCaseId rdf:type rdf:Property ;
    rdfs:label 'Onboarding Case Id' ;
    rdfs:comment 'Unique identifier for the onboarding case record. Primary key for the onboarding case entity.' ;
    rdfs:domain ind:OnboardingCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originationProfitCenterId rdf:type rdf:Property ;
    rdfs:label 'Origination Profit Center Id' ;
    rdfs:comment 'Foreign key linking to ledger.profit_center. Business justification: New customer origination is attributed to profit centers for customer acquisition revenue recognition, origination team performance measurement, and new business P&L tracking. Essential for growth str' ;
    rdfs:domain ind:OnboardingCase ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProfitCenter .

ind:primaryOnboardingAssignedAnalystEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Onboarding Assigned Analyst Employee Id' ;
    rdfs:comment 'Employee identifier of the analyst or case manager currently assigned to process and manage this onboarding case through its workflow stages.' ;
    rdfs:domain ind:OnboardingCase ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:regulatoryJurisdictionId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Jurisdiction Id' ;
    rdfs:comment 'Foreign key linking to reference.jurisdiction. Business justification: Onboarding workflow - regulatory jurisdiction determines which licensing, disclosure, suitability, and KYC rules apply. Drives onboarding checklist, required documents, and approval workflows.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Jurisdiction .

ind:rejectionReasonCodeListId rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason Code List Id' ;
    rdfs:comment 'Foreign key linking to reference.code_list. Business justification: Onboarding analytics - rejection reasons must be standardized for root cause analysis, fair lending reporting (adverse action notices), and process improvement initiatives.' ;
    rdfs:domain ind:OnboardingCase ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CodeList .

ind:servicingCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Servicing Cost Center Id' ;
    rdfs:comment 'Foreign key linking to ledger.cost_center. Business justification: Onboarding activities incur operational costs that must be allocated to cost centers for customer acquisition cost analysis, profitability measurement, and management accounting. Required for activity' ;
    rdfs:domain ind:OnboardingCase ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:tertiaryOnboardingLastModifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Onboarding Last Modified By Employee Id' ;
    rdfs:comment 'Employee identifier of the user who last modified this onboarding case record, supporting audit trail and accountability requirements.' ;
    rdfs:domain ind:OnboardingCase ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:applicationDate rdf:type rdf:Property ;
    rdfs:label 'Application Date' ;
    rdfs:comment 'Date when the onboarding application was initially submitted by the party or on behalf of the party.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:applicationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Application Timestamp' ;
    rdfs:comment 'Precise timestamp when the onboarding application was submitted, capturing the exact moment of case initiation for audit and SLA tracking purposes.' ;
    rdfs:domain ind:OnboardingCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:beneficialOwnerVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Beneficial Owner Verified Flag' ;
    rdfs:comment 'Boolean indicator of whether beneficial ownership has been verified and documented for this onboarding case, required for corporate and institutional entities. True indicates verified, False indicates pending or not applicable.' ;
    rdfs:domain ind:OnboardingCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Credit Check Status' ;
    rdfs:comment 'Status of credit assessment for this onboarding case: not required (for non-credit products), pending, completed, approved, declined, or requiring manual review.' ;
    rdfs:domain ind:OnboardingCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditScore rdf:type rdf:Property ;
    rdfs:label 'Credit Score' ;
    rdfs:comment 'Credit score obtained during the onboarding credit assessment, typically from credit bureaus. Used for risk rating and product eligibility determination.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:crsStatus rdf:type rdf:Property ;
    rdfs:label 'Crs Status' ;
    rdfs:comment 'CRS compliance status for this onboarding case, applicable for international tax reporting: not applicable, pending review, compliant, non-compliant, or exempt.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentChecklistCompleteFlag rdf:type rdf:Property ;
    rdfs:label 'Document Checklist Complete Flag' ;
    rdfs:comment 'Boolean indicator of whether all required documentation has been collected and verified for this onboarding case. True indicates complete, False indicates pending documents.' ;
    rdfs:domain ind:OnboardingCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:expectedAccountBalance rdf:type rdf:Property ;
    rdfs:label 'Expected Account Balance' ;
    rdfs:comment 'Expected initial account balance or Assets Under Management (AUM) indicated by the applicant during onboarding, used for relationship planning and resource allocation.' ;
    rdfs:domain ind:OnboardingCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedMonthlyTransactionVolume rdf:type rdf:Property ;
    rdfs:label 'Expected Monthly Transaction Volume' ;
    rdfs:comment 'Expected number of transactions per month indicated by the applicant, used for account type recommendation and fee structure determination.' ;
    rdfs:domain ind:OnboardingCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:onboardingChannel rdf:type rdf:Property ;
    rdfs:label 'Onboarding Channel' ;
    rdfs:comment 'Channel through which the onboarding case was initiated: branch, digital web, digital mobile app, relationship manager assisted, call center, or API partner integration.' ;
    rdfs:domain ind:OnboardingCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onboardingType rdf:type rdf:Property ;
    rdfs:label 'Onboarding Type' ;
    rdfs:comment 'Classification of the onboarding scenario: new-to-bank (first relationship), new-to-product (existing customer adding product), existing-party-new-segment (moving from retail to corporate), cross-sell, relationship upgrade, or entity conversion.' ;
    rdfs:domain ind:OnboardingCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTargetCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Sla Target Completion Date' ;
    rdfs:comment 'Target date by which the onboarding case should be completed according to the applicable SLA for the customer segment and product type.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:stageEntryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Stage Entry Timestamp' ;
    rdfs:comment 'Timestamp when the onboarding case entered the current workflow stage. Used for stage duration calculation and SLA (Service Level Agreement) monitoring.' ;
    rdfs:domain ind:OnboardingCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:withdrawalDate rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Date' ;
    rdfs:comment 'Date when the onboarding case was withdrawn by the applicant before completion.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:workflowStage rdf:type rdf:Property ;
    rdfs:label 'Workflow Stage' ;
    rdfs:comment 'Detailed workflow stage within the onboarding process: application, document submission, identity verification, KYC/CDD (Customer Due Diligence), AML check, credit assessment, risk rating, compliance review, management approval, account setup, funding, or activation. [ENUM-REF-CANDIDATE: application|document_submission|identity_verification|kyc_cdd|aml_check|credit_assessment|risk_rating|compliance_review|management_approval|account_setup|funding|activation — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:OnboardingCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredCurrencyId rdf:type rdf:Property ;
    rdfs:label 'Preferred Currency Id' ;
    rdfs:comment 'Foreign key linking to reference.currency. Business justification: Operational necessity - preferred currency drives statement generation, pricing display, FX conversion rules for multi-currency customers, and fee calculations. Real daily banking operations dependenc' ;
    rdfs:domain ind:Party ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:primaryLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Primary Legal Entity Id' ;
    rdfs:comment 'Foreign key linking to ledger.legal_entity. Business justification: Every banking customer relationship exists with a specific legal entity of the bank for regulatory capital allocation, financial statement consolidation, and legal entity P&L attribution. Required for' ;
    rdfs:domain ind:Party ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:typeCodeListId rdf:type rdf:Property ;
    rdfs:label 'Type Code List Id' ;
    rdfs:comment 'Foreign key linking to reference.code_list. Business justification: Core entity classification - party types (Individual, Corporate, Trust, Partnership) drive regulatory treatment, product eligibility, KYC requirements, and reporting obligations. Must use standardized' ;
    rdfs:domain ind:Party ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CodeList .

ind:cifNumber rdf:type rdf:Property ;
    rdfs:label 'Cif Number' ;
    rdfs:comment 'Core banking system Customer Information File number. Internal unique identifier from the source system (Temenos T24 / FIS Profile).' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:citizenshipCountryCode rdf:type rdf:Property ;
    rdfs:label 'Citizenship Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the party\'s citizenship. For individuals only. May be multi-valued in source systems but stored as primary citizenship here.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dateOfBirth rdf:type rdf:Property ;
    rdfs:label 'Date Of Birth' ;
    rdfs:comment 'Date of birth for individual parties. Used for age verification, regulatory compliance, and customer segmentation. Null for non-individual party types.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dunsNumber rdf:type rdf:Property ;
    rdfs:label 'Duns Number' ;
    rdfs:comment 'Dun & Bradstreet DUNS number for corporate parties. 9-digit unique identifier for business entities.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPep rdf:type rdf:Property ;
    rdfs:label 'Is Pep' ;
    rdfs:comment 'Flag indicating whether the party is classified as a Politically Exposed Person. PEPs require enhanced due diligence under AML regulations.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSanctioned rdf:type rdf:Property ;
    rdfs:label 'Is Sanctioned' ;
    rdfs:comment 'Flag indicating whether the party appears on any sanctions lists (OFAC, UN, EU, etc.). Sanctioned parties are prohibited from transacting.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nationalIdNumber rdf:type rdf:Property ;
    rdfs:label 'National Id Number' ;
    rdfs:comment 'Government-issued national identification number for individuals. Format varies by country (e.g., Social Security Number in USA, National Insurance Number in UK).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passportExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Passport Expiry Date' ;
    rdfs:comment 'Expiration date of the passport. Used to ensure identity documents remain current for compliance purposes.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:passportIssuingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Passport Issuing Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the authority that issued the passport.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passportNumber rdf:type rdf:Property ;
    rdfs:label 'Passport Number' ;
    rdfs:comment 'Passport number for individual parties. Used for identity verification and cross-border compliance.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryAddressCity rdf:type rdf:Property ;
    rdfs:label 'Primary Address City' ;
    rdfs:comment 'City or municipality of the party\'s primary physical address.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryAddressCountryCode rdf:type rdf:Property ;
    rdfs:label 'Primary Address Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the party\'s primary physical address.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Primary Address Line 1' ;
    rdfs:comment 'First line of the party\'s primary physical address. Typically contains street number and street name.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Primary Address Line 2' ;
    rdfs:comment 'Second line of the party\'s primary physical address. Typically contains apartment, suite, or unit number.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryAddressPostalCode rdf:type rdf:Property ;
    rdfs:label 'Primary Address Postal Code' ;
    rdfs:comment 'Postal code or ZIP code of the party\'s primary physical address.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryAddressStateProvince rdf:type rdf:Property ;
    rdfs:label 'Primary Address State Province' ;
    rdfs:comment 'State, province, or region of the party\'s primary physical address.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryEmailAddress rdf:type rdf:Property ;
    rdfs:label 'Primary Email Address' ;
    rdfs:comment 'Primary email address for party communication. Used for statements, notifications, and digital correspondence.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPhoneNumber rdf:type rdf:Property ;
    rdfs:label 'Primary Phone Number' ;
    rdfs:comment 'Primary contact phone number for the party. Used for customer service, fraud alerts, and operational communication.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipEndDate rdf:type rdf:Property ;
    rdfs:label 'Relationship End Date' ;
    rdfs:comment 'Date when the party\'s relationship with the bank was terminated. Null for active relationships.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:relationshipStartDate rdf:type rdf:Property ;
    rdfs:label 'Relationship Start Date' ;
    rdfs:comment 'Date when the party first established a relationship with the bank. Represents the initial onboarding or account opening date.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:residencyStatus rdf:type rdf:Property ;
    rdfs:label 'Residency Status' ;
    rdfs:comment 'Tax residency classification of the party. Critical for regulatory reporting under FATCA and CRS.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partyAddressId rdf:type rdf:Property ;
    rdfs:label 'Party Address Id' ;
    rdfs:comment 'Unique identifier for the party address record. Primary key.' ;
    rdfs:domain ind:PartyAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:addressTypeCodeListId rdf:type rdf:Property ;
    rdfs:label 'Address Type Code List Id' ;
    rdfs:comment 'Foreign key linking to reference.code_list. Business justification: Address management - address types (Residential, Business, Mailing, Legal) must be standardized for correspondence routing, regulatory notifications, and KYC address verification.' ;
    rdfs:domain ind:PartyAddress ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CodeList .

ind:addressLine3 rdf:type rdf:Property ;
    rdfs:label 'Address Line 3' ;
    rdfs:comment 'Third line of the physical address (additional location details). Applicable only when contact_type is physical_address.' ;
    rdfs:domain ind:PartyAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactType rdf:type rdf:Property ;
    rdfs:label 'Contact Type' ;
    rdfs:comment 'Type of contact information: physical_address (registered, mailing, residential, business, branch, billing), mobile, home_phone, work_phone, fax, primary_email, secondary_email, or digital identifier. [ENUM-REF-CANDIDATE: physical_address|mobile|home_phone|work_phone|fax|primary_email|secondary_email — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PartyAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactValue rdf:type rdf:Property ;
    rdfs:label 'Contact Value' ;
    rdfs:comment 'The actual contact detail value: phone number (with country code), email address, fax number, or digital identifier. Applicable for electronic contact types (mobile, home_phone, work_phone, fax, primary_email, secondary_email).' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:doNotCall rdf:type rdf:Property ;
    rdfs:label 'Do Not Call' ;
    rdfs:comment 'Flag indicating whether the party has requested not to be contacted via phone at this number. True if do-not-call requested, False otherwise. Applicable for phone contact types.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:doNotMail rdf:type rdf:Property ;
    rdfs:label 'Do Not Mail' ;
    rdfs:comment 'Flag indicating whether the party has requested not to receive physical mail at this address. True if do-not-mail requested, False otherwise. Applicable for physical address contact types.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVerified rdf:type rdf:Property ;
    rdfs:label 'Is Verified' ;
    rdfs:comment 'Flag indicating whether this contact detail or address has been verified through a validation process. True if verified, False otherwise.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optInEstatements rdf:type rdf:Property ;
    rdfs:label 'Opt In Estatements' ;
    rdfs:comment 'Flag indicating whether the party has consented to receive electronic statements at this contact point. True if opted in, False otherwise. Applicable for email contact types.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optInMarketing rdf:type rdf:Property ;
    rdfs:label 'Opt In Marketing' ;
    rdfs:comment 'Flag indicating whether the party has consented to receive marketing communications at this contact point. True if opted in, False otherwise. Applicable for electronic contact types.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:partyAddressStatus rdf:type rdf:Property ;
    rdfs:label 'Party Address Status' ;
    rdfs:comment 'Current lifecycle status of the contact detail or address: active (in use), inactive (not in use but valid), pending (awaiting verification), invalid (failed verification), expired (past expiry_date), or suspended (temporarily disabled).' ;
    rdfs:domain ind:PartyAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryNotificationFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Flag' ;
    rdfs:comment 'Flag indicating whether this contact point is designated for receiving regulatory and compliance notifications. True if designated, False otherwise.' ;
    rdfs:domain ind:PartyAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxDomicileFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Domicile Flag' ;
    rdfs:comment 'Flag indicating whether this address is used to determine the party\'s tax domicile for FATCA (Foreign Account Tax Compliance Act) and CRS (Common Reporting Standard) reporting. True if tax domicile, False otherwise. Applicable for physical address contact types.' ;
    rdfs:domain ind:PartyAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:partyContactId rdf:type rdf:Property ;
    rdfs:label 'Party Contact Id' ;
    rdfs:comment 'Unique identifier for the party contact record. Primary key for the party_contact data product.' ;
    rdfs:domain ind:PartyContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contactTypeCodeListId rdf:type rdf:Property ;
    rdfs:label 'Contact Type Code List Id' ;
    rdfs:comment 'Foreign key linking to reference.code_list. Business justification: Contact management - contact types (Mobile, Email, Landline, Fax) must be standardized for omnichannel communication, regulatory notifications, and contact preference management.' ;
    rdfs:domain ind:PartyContact ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CodeList .

ind:areaCode rdf:type rdf:Property ;
    rdfs:label 'Area Code' ;
    rdfs:comment 'Geographic area code or regional prefix for phone numbers. Applicable to phone contact types only.' ;
    rdfs:domain ind:PartyContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bounceCount rdf:type rdf:Property ;
    rdfs:label 'Bounce Count' ;
    rdfs:comment 'The number of times an email sent to this contact has bounced (failed delivery). Used to identify invalid or inactive email addresses. Applicable to email contact types only.' ;
    rdfs:domain ind:PartyContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contactPreferenceRank rdf:type rdf:Property ;
    rdfs:label 'Contact Preference Rank' ;
    rdfs:comment 'Numeric ranking indicating the party\'s preference order for this contact method. Lower numbers indicate higher preference (1 = most preferred). Used for omnichannel communication routing.' ;
    rdfs:domain ind:PartyContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contactPurpose rdf:type rdf:Property ;
    rdfs:label 'Contact Purpose' ;
    rdfs:comment 'The intended purpose or use case for this contact information. Personal for personal communications, business for business-related communications, emergency for urgent notifications, billing for payment-related communications, correspondence for general account communications.' ;
    rdfs:domain ind:PartyContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactStatus rdf:type rdf:Property ;
    rdfs:label 'Contact Status' ;
    rdfs:comment 'Current operational status of the contact information. Active indicates the contact is valid and in use. Inactive indicates the contact is no longer in use. Bounced indicates email delivery failures. Invalid indicates the contact failed validation. Suspended indicates temporary restriction.' ;
    rdfs:domain ind:PartyContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doNotEmail rdf:type rdf:Property ;
    rdfs:label 'Do Not Email' ;
    rdfs:comment 'Boolean flag indicating whether the party has requested not to be contacted via email for marketing purposes. True if do-not-email is active, False otherwise. Required for CAN-SPAM compliance.' ;
    rdfs:domain ind:PartyContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:extension rdf:type rdf:Property ;
    rdfs:label 'Extension' ;
    rdfs:comment 'Internal phone extension number for work or business phone contacts. Applicable to work phone contact types only.' ;
    rdfs:domain ind:PartyContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastBounceDate rdf:type rdf:Property ;
    rdfs:label 'Last Bounce Date' ;
    rdfs:comment 'The date of the most recent email bounce. Null if no bounces have occurred. Format: yyyy-MM-dd. Applicable to email contact types only.' ;
    rdfs:domain ind:PartyContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:optInEstatementsDate rdf:type rdf:Property ;
    rdfs:label 'Opt In Estatements Date' ;
    rdfs:comment 'The date when the party provided consent for electronic statements. Null if not opted in. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:PartyContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:optInMarketingDate rdf:type rdf:Property ;
    rdfs:label 'Opt In Marketing Date' ;
    rdfs:comment 'The date when the party provided consent for marketing communications. Null if not opted in. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:PartyContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:partyDocumentId rdf:type rdf:Property ;
    rdfs:label 'Party Document Id' ;
    rdfs:comment 'Unique identifier for the party document record. Primary key.' ;
    rdfs:domain ind:PartyDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:documentTypeCodeListId rdf:type rdf:Property ;
    rdfs:label 'Document Type Code List Id' ;
    rdfs:comment 'Foreign key linking to reference.code_list. Business justification: Document type validation - KYC document types (Passport, Driver\'s License, Utility Bill, Bank Statement) must be standardized for regulatory reporting consistency and document verification workflows.' ;
    rdfs:domain ind:PartyDocument ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CodeList .

ind:issuingCountryId rdf:type rdf:Property ;
    rdfs:label 'Issuing Country Id' ;
    rdfs:comment 'Foreign key linking to reference.country. Business justification: KYC/AML compliance - passport/ID issuing country must be validated for document verification, sanctions screening, and regulatory reporting. Core identity verification process.' ;
    rdfs:domain ind:PartyDocument ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:primaryPartyVerifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Party Verified By Employee Id' ;
    rdfs:comment 'Identifier of the employee or compliance officer who performed or approved the document verification. Links to the employee master record for audit trail purposes.' ;
    rdfs:domain ind:PartyDocument ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:collectionChannel rdf:type rdf:Property ;
    rdfs:label 'Collection Channel' ;
    rdfs:comment 'Channel or method through which the document was collected from the party. Examples include branch submission, online portal upload, mobile app, email attachment, postal mail, or third-party agent.' ;
    rdfs:domain ind:PartyDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionDate rdf:type rdf:Property ;
    rdfs:label 'Collection Date' ;
    rdfs:comment 'Date on which the document was collected or received from the party during the KYC onboarding or periodic review process. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:destructionEligibleDate rdf:type rdf:Property ;
    rdfs:label 'Destruction Eligible Date' ;
    rdfs:comment 'Date on which the document becomes eligible for secure destruction or deletion based on retention policy and regulatory requirements. Nullable if document must be retained indefinitely. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentLanguage rdf:type rdf:Property ;
    rdfs:label 'Document Language' ;
    rdfs:comment 'ISO 639-2 three-letter language code indicating the primary language in which the document is written (e.g., ENG for English, SPA for Spanish, FRA for French, DEU for German, CHI for Chinese).' ;
    rdfs:domain ind:PartyDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentNumber rdf:type rdf:Property ;
    rdfs:label 'Document Number' ;
    rdfs:comment 'The unique identification number or reference code printed on the document (e.g., passport number, national ID number, driver\'s license number, corporate registration number).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentSizeKb rdf:type rdf:Property ;
    rdfs:label 'Document Size Kb' ;
    rdfs:comment 'Size of the stored document file in kilobytes. Used for storage management and audit purposes.' ;
    rdfs:domain ind:PartyDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:documentStorageUri rdf:type rdf:Property ;
    rdfs:label 'Document Storage Uri' ;
    rdfs:comment 'Secure storage location reference (URI, file path, or vault key) pointing to the digitized copy of the document in the bank\'s document management system or secure vault. Used to retrieve the document image or PDF for audit and review.' ;
    rdfs:domain ind:PartyDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPrimaryIdentityDocument rdf:type rdf:Property ;
    rdfs:label 'Is Primary Identity Document' ;
    rdfs:comment 'Boolean flag indicating whether this document is the primary identity document used for KYC verification (e.g., the main passport or national ID). True if primary, False otherwise.' ;
    rdfs:domain ind:PartyDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:translationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Translation Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether the document requires translation into the bank\'s primary operating language for compliance or operational purposes. True if translation is required, False otherwise.' ;
    rdfs:domain ind:PartyDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:translationStatus rdf:type rdf:Property ;
    rdfs:label 'Translation Status' ;
    rdfs:comment 'Status of the document translation process. Indicates whether translation is not required, pending, completed, or certified by a professional translator.' ;
    rdfs:domain ind:PartyDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partyIdentifierId rdf:type rdf:Property ;
    rdfs:label 'Party Identifier Id' ;
    rdfs:comment 'Unique identifier for the party identifier record. Primary key for this entity.' ;
    rdfs:domain ind:PartyIdentifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:identifierTypeCodeListId rdf:type rdf:Property ;
    rdfs:label 'Identifier Type Code List Id' ;
    rdfs:comment 'Foreign key linking to reference.code_list. Business justification: Identifier type standardization - identifier types (CIF, Account Number, Tax ID, SSN, Passport) must be consistent across systems for deduplication, regulatory reporting, and customer matching.' ;
    rdfs:domain ind:PartyIdentifier ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CodeList .

ind:deduplicationKey rdf:type rdf:Property ;
    rdfs:label 'Deduplication Key' ;
    rdfs:comment 'Normalized or hashed representation of the identifier value used for deduplication and matching across systems. Supports golden record management and cross-system reconciliation by providing a standardized matching key that accounts for formatting variations.' ;
    rdfs:domain ind:PartyIdentifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identifierStatus rdf:type rdf:Property ;
    rdfs:label 'Identifier Status' ;
    rdfs:comment 'Current lifecycle status of the identifier. Indicates whether the identifier is currently valid and usable for business operations, regulatory reporting, and cross-system reconciliation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identifierValue rdf:type rdf:Property ;
    rdfs:label 'Identifier Value' ;
    rdfs:comment 'The actual identifier value or number assigned to the party. This is the unique alphanumeric string that represents the party in the external or internal system (e.g., the 20-character LEI code, the 8 or 11-character SWIFT BIC, the 9-digit DUNS number, the CIF account number, the tax identification number, passport number, or national ID number).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastUpdatedBy rdf:type rdf:Property ;
    rdfs:label 'Last Updated By' ;
    rdfs:comment 'The user ID, employee ID, or system process name that last modified this identifier record. Supports audit trail requirements and accountability for data changes.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemIdentifier rdf:type rdf:Property ;
    rdfs:label 'Source System Identifier' ;
    rdfs:comment 'The unique identifier or primary key of this record in the source operational system. Used for traceability, reconciliation, and troubleshooting data quality issues back to the originating system.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationSource rdf:type rdf:Property ;
    rdfs:label 'Verification Source' ;
    rdfs:comment 'The name of the system, service, or authority used to verify the identifier. Examples include GLEIF API for LEI verification, SWIFT directory for BIC verification, Dun & Bradstreet API for DUNS verification, government registry for national ID or passport verification, or internal compliance system name.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partyLifecycleEventId rdf:type rdf:Property ;
    rdfs:label 'Party Lifecycle Event Id' ;
    rdfs:comment 'Unique identifier for each party lifecycle event record. Primary key for the party lifecycle event audit log.' ;
    rdfs:domain ind:PartyLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eventTypeCodeListId rdf:type rdf:Property ;
    rdfs:label 'Event Type Code List Id' ;
    rdfs:comment 'Foreign key linking to reference.code_list. Business justification: Event type standardization - lifecycle event types (Account Opening, Status Change, Closure, Merger, Deduplication) must be catalogued for audit trails, regulatory reporting, and lifecycle analytics.' ;
    rdfs:domain ind:PartyLifecycleEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CodeList .

ind:primaryPartyInitiatingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Party Initiating Employee Id' ;
    rdfs:comment 'Reference to the employee or user who initiated or requested the lifecycle status change. May be null for system-triggered events such as automated dormancy detection.' ;
    rdfs:domain ind:PartyLifecycleEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:reversedEventPartyLifecycleEventId rdf:type rdf:Property ;
    rdfs:label 'Reversed Event Party Lifecycle Event Id' ;
    rdfs:comment 'For reversal events, this field references the party_lifecycle_event_id of the original event being reversed. Null for non-reversal events.' ;
    rdfs:domain ind:PartyLifecycleEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PartyLifecycleEvent .

ind:dedupConfidenceScore rdf:type rdf:Property ;
    rdfs:label 'Dedup Confidence Score' ;
    rdfs:comment 'For deduplication events, this field captures the algorithmic confidence score (0.00 to 100.00) that the two party records represent the same real-world entity. Higher scores indicate stronger match confidence. Null for non-dedup events.' ;
    rdfs:domain ind:PartyLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eventReasonCode rdf:type rdf:Property ;
    rdfs:label 'Event Reason Code' ;
    rdfs:comment 'Standardized code representing the business reason for the lifecycle transition. Examples: CUST_REQUEST (customer-initiated closure), INACTIVITY (dormancy due to no transactions), REGULATORY (compliance-driven suspension), DEATH_CERT (deceased status based on death certificate), DUPLICATE (deduplication event). Links to internal reason code reference table.' ;
    rdfs:domain ind:PartyLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Event Reason Description' ;
    rdfs:comment 'Free-text explanation or additional context describing why the lifecycle status change occurred. Supplements the event_reason_code with narrative detail.' ;
    rdfs:domain ind:PartyLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kycRefreshTriggeredFlag rdf:type rdf:Property ;
    rdfs:label 'Kyc Refresh Triggered Flag' ;
    rdfs:comment 'Indicates whether this lifecycle event automatically triggered a KYC refresh or re-verification process. True for events such as reactivation, status upgrade, or significant relationship changes.' ;
    rdfs:domain ind:PartyLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationSentFlag rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Flag' ;
    rdfs:comment 'Indicates whether an automated notification (email, SMS, letter) was sent to the party or relationship manager informing them of the lifecycle status change.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorStatus rdf:type rdf:Property ;
    rdfs:label 'Prior Status' ;
    rdfs:comment 'The party lifecycle status immediately before this event occurred. Captures the from-state in the state transition for audit trail purposes. [ENUM-REF-CANDIDATE: prospect|pending|active|dormant|suspended|inactive|closed|deceased|merged — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemEventReference rdf:type rdf:Property ;
    rdfs:label 'Source System Event Reference' ;
    rdfs:comment 'The unique identifier or transaction ID assigned to this lifecycle event in the source system. Used for traceability and reconciliation back to the operational system.' ;
    rdfs:domain ind:PartyLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggeringSystem rdf:type rdf:Property ;
    rdfs:label 'Triggering System' ;
    rdfs:comment 'The source system or application that initiated or recorded the lifecycle event. Examples: Core Banking System, CRM, KYC Platform, Batch Job, Manual Entry.' ;
    rdfs:domain ind:PartyLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partyRelationshipId rdf:type rdf:Property ;
    rdfs:label 'Party Relationship Id' ;
    rdfs:comment 'Unique identifier for the bilateral party relationship record. Primary key.' ;
    rdfs:domain ind:PartyRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:relationshipTypeCodeListId rdf:type rdf:Property ;
    rdfs:label 'Relationship Type Code List Id' ;
    rdfs:comment 'Foreign key linking to reference.code_list. Business justification: Relationship standardization - relationship types (Authorized Signer, Power of Attorney, Guardian, Trustee, Beneficiary) must be standardized for access control, regulatory reporting, and relationship' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CodeList .

ind:relationshipLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Relationship Limit Amount' ;
    rdfs:comment 'Monetary limit or cap associated with this relationship (e.g., maximum guarantee amount, authorization limit, credit exposure limit).' ;
    rdfs:domain ind:PartyRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:relationshipLimitCurrency rdf:type rdf:Property ;
    rdfs:label 'Relationship Limit Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the relationship limit amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:PartyRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipPercentage rdf:type rdf:Property ;
    rdfs:label 'Relationship Percentage' ;
    rdfs:comment 'Percentage value representing the extent or share of the relationship (e.g., guarantee coverage percentage, ownership percentage, authorization limit percentage). Range 0.00 to 100.00.' ;
    rdfs:domain ind:PartyRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:relationshipRoleA rdf:type rdf:Property ;
    rdfs:label 'Relationship Role A' ;
    rdfs:comment 'The role that Party A plays in this bilateral relationship (e.g., guarantor, borrower, co-applicant, authorized signatory, power of attorney, referral source, introducer). [ENUM-REF-CANDIDATE: guarantor|borrower|co_applicant|authorized_signatory|power_of_attorney|referral_source|introducer|beneficial_owner|trustee|custodian|nominee|agent|principal|counterparty|correspondent_bank — promote to reference product]' ;
    rdfs:domain ind:PartyRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipRoleB rdf:type rdf:Property ;
    rdfs:label 'Relationship Role B' ;
    rdfs:comment 'The role that Party B plays in this bilateral relationship (e.g., guarantor, borrower, co-applicant, authorized signatory, power of attorney, referral source, introducer). [ENUM-REF-CANDIDATE: guarantor|borrower|co_applicant|authorized_signatory|power_of_attorney|referral_source|introducer|beneficial_owner|trustee|custodian|nominee|agent|principal|counterparty|correspondent_bank — promote to reference product]' ;
    rdfs:domain ind:PartyRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipSource rdf:type rdf:Property ;
    rdfs:label 'Relationship Source' ;
    rdfs:comment 'Source or channel through which this relationship was established (e.g., direct, referral, branch, online, third party, data migration).' ;
    rdfs:domain ind:PartyRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipStrength rdf:type rdf:Property ;
    rdfs:label 'Relationship Strength' ;
    rdfs:comment 'Indicator of the relationship importance or priority level (e.g., primary, secondary, tertiary) for credit exposure aggregation and risk assessment.' ;
    rdfs:domain ind:PartyRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partyRiskRatingId rdf:type rdf:Property ;
    rdfs:label 'Party Risk Rating Id' ;
    rdfs:comment 'Unique identifier for the party risk rating record.' ;
    rdfs:domain ind:PartyRiskRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryPartyRatingAnalystEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Party Rating Analyst Employee Id' ;
    rdfs:comment 'Reference to the employee who performed the risk rating analysis and assigned the rating grade.' ;
    rdfs:domain ind:PartyRiskRating ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:ratingMethodologyCodeListId rdf:type rdf:Property ;
    rdfs:label 'Rating Methodology Code List Id' ;
    rdfs:comment 'Foreign key linking to reference.code_list. Business justification: Risk methodology governance - rating methodologies must be catalogued for model risk management, regulatory validation (SR 11-7), and methodology version control across rating systems.' ;
    rdfs:domain ind:PartyRiskRating ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CodeList .

ind:externalRatingAgency rdf:type rdf:Property ;
    rdfs:label 'External Rating Agency' ;
    rdfs:comment 'Name of the external credit rating agency (e.g., S&P, Moody\'s, Fitch) whose rating was referenced or used as input to the internal rating process. Nullable if no external rating was considered.' ;
    rdfs:domain ind:PartyRiskRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalRatingDate rdf:type rdf:Property ;
    rdfs:label 'External Rating Date' ;
    rdfs:comment 'The date on which the external rating agency published or updated the external rating grade.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:externalRatingGrade rdf:type rdf:Property ;
    rdfs:label 'External Rating Grade' ;
    rdfs:comment 'The credit rating assigned by the external rating agency (e.g., AAA, Baa2, BB+). Used for benchmarking and validation of internal ratings.' ;
    rdfs:domain ind:PartyRiskRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industrySector rdf:type rdf:Property ;
    rdfs:label 'Industry Sector' ;
    rdfs:comment 'The primary industry or economic sector in which the party operates (e.g., Financial Services, Manufacturing, Real Estate, Healthcare). Used for sector concentration risk analysis and portfolio segmentation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalRatingGrade rdf:type rdf:Property ;
    rdfs:label 'Internal Rating Grade' ;
    rdfs:comment 'The bank\'s internal risk rating grade assigned to the party, expressed in the institution\'s proprietary rating scale (e.g., AAA, AA+, A, BBB, BB, B, CCC, D or 1-10 numeric scale). This is the primary output of the rating process.' ;
    rdfs:domain ind:PartyRiskRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lgdEstimate rdf:type rdf:Property ;
    rdfs:label 'Lgd Estimate' ;
    rdfs:comment 'Estimated percentage of exposure that will be lost if the party defaults, expressed as a decimal (e.g., 0.45 = 45% loss severity). Used in conjunction with PD and EAD for ECL and capital adequacy calculations.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modelScore rdf:type rdf:Property ;
    rdfs:label 'Model Score' ;
    rdfs:comment 'Raw quantitative score output by the rating model or scorecard before mapping to the internal rating grade. Provides granular risk differentiation within rating grades.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pdEstimate rdf:type rdf:Property ;
    rdfs:label 'Pd Estimate' ;
    rdfs:comment 'Quantitative estimate of the probability that the party will default within a one-year horizon, expressed as a decimal (e.g., 0.025 = 2.5%). Core input for Expected Credit Loss (ECL) and Risk-Weighted Assets (RWA) calculations.' ;
    rdfs:domain ind:PartyRiskRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:previousRatingGrade rdf:type rdf:Property ;
    rdfs:label 'Previous Rating Grade' ;
    rdfs:comment 'The internal rating grade that was in effect immediately prior to the current rating, enabling trend analysis and rating migration tracking.' ;
    rdfs:domain ind:PartyRiskRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingChangeDate rdf:type rdf:Property ;
    rdfs:label 'Rating Change Date' ;
    rdfs:comment 'The date on which the rating was changed from the previous rating grade to the current rating grade. Nullable for initial ratings.' ;
    rdfs:domain ind:PartyRiskRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ratingConfidenceLevel rdf:type rdf:Property ;
    rdfs:label 'Rating Confidence Level' ;
    rdfs:comment 'Qualitative assessment of the confidence or reliability of the assigned rating, based on data quality, model performance, and analyst judgment. High indicates strong supporting evidence, low indicates limited data or high uncertainty.' ;
    rdfs:domain ind:PartyRiskRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingMigrationDirection rdf:type rdf:Property ;
    rdfs:label 'Rating Migration Direction' ;
    rdfs:comment 'Indicates the direction of rating change compared to the previous rating: upgrade (improved credit quality), downgrade (deteriorated credit quality), stable (no change), or new (first-time rating).' ;
    rdfs:domain ind:PartyRiskRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingScale rdf:type rdf:Property ;
    rdfs:label 'Rating Scale' ;
    rdfs:comment 'Identifier of the rating scale or methodology framework used (e.g., \'S&P_Equivalent\', \'Moody_Equivalent\', \'Internal_10_Point\', \'IRB_Master_Scale\'). Provides context for interpreting the internal_rating_grade.' ;
    rdfs:domain ind:PartyRiskRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingType rdf:type rdf:Property ;
    rdfs:label 'Rating Type' ;
    rdfs:comment 'The dimension of risk being assessed: credit risk (probability of default), Anti-Money Laundering (AML) risk (financial crime exposure), operational risk (process/system failure), market risk (price volatility exposure), country risk (sovereign/geopolitical), or concentration risk (portfolio exposure).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stressTestScenario rdf:type rdf:Property ;
    rdfs:label 'Stress Test Scenario' ;
    rdfs:comment 'Identifier of the stress testing scenario (e.g., CCAR Severely Adverse, DFAST Baseline, Internal Recession Scenario) under which this rating was assessed or projected. Nullable for baseline ratings.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stressedPdEstimate rdf:type rdf:Property ;
    rdfs:label 'Stressed Pd Estimate' ;
    rdfs:comment 'Probability of Default (PD) estimate under the specified stress test scenario, reflecting the party\'s credit risk under adverse economic conditions. Used for stress testing and capital planning.' ;
    rdfs:domain ind:PartyRiskRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:watchListFlag rdf:type rdf:Property ;
    rdfs:label 'Watch List Flag' ;
    rdfs:comment 'Indicates whether the party is on a credit watch list or special monitoring list due to deteriorating credit quality, heightened risk, or regulatory concern. True if on watch list, False otherwise.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:watchListReason rdf:type rdf:Property ;
    rdfs:label 'Watch List Reason' ;
    rdfs:comment 'Explanation of why the party was placed on the watch list, including specific risk indicators or events that triggered heightened monitoring.' ;
    rdfs:domain ind:PartyRiskRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partySegmentAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Party Segment Assignment Id' ;
    rdfs:comment 'Unique identifier for each party segment assignment record. Primary key for the party segment assignment entity.' ;
    rdfs:domain ind:PartySegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:attributedProfitCenterId rdf:type rdf:Property ;
    rdfs:label 'Attributed Profit Center Id' ;
    rdfs:comment 'Foreign key linking to ledger.profit_center. Business justification: Customer segments are mapped to profit centers for revenue attribution, segment P&L reporting, RAROC calculation, and management reporting. Essential for line-of-business profitability analysis and st' ;
    rdfs:domain ind:PartySegmentAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProfitCenter .

ind:lineOfBusinessCodeListId rdf:type rdf:Property ;
    rdfs:label 'Line Of Business Code List Id' ;
    rdfs:comment 'Foreign key linking to reference.code_list. Business justification: LOB standardization for segment assignment - line of business codes must be consistent for segment performance reporting, cross-LOB analytics, and customer profitability analysis.' ;
    rdfs:domain ind:PartySegmentAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CodeList .

ind:primaryPartyAssignedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Party Assigned By Employee Id' ;
    rdfs:comment 'Reference to the employee who created or approved the segment assignment, supporting accountability and audit trail requirements.' ;
    rdfs:domain ind:PartySegmentAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryPartySegmentId rdf:type rdf:Property ;
    rdfs:label 'Primary Party Segment Id' ;
    rdfs:comment 'Reference to the customer segment classification being assigned. Links to the customer segment reference entity.' ;
    rdfs:domain ind:PartySegmentAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:aumBand rdf:type rdf:Property ;
    rdfs:label 'Aum Band' ;
    rdfs:comment 'Assets Under Management band or range associated with the segment assignment, particularly relevant for wealth management and private banking segments.' ;
    rdfs:domain ind:PartySegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidenceLevel rdf:type rdf:Property ;
    rdfs:label 'Confidence Level' ;
    rdfs:comment 'Statistical confidence level (expressed as percentage) associated with the segment assignment, indicating the reliability of the classification.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelName rdf:type rdf:Property ;
    rdfs:label 'Model Name' ;
    rdfs:comment 'Name of the analytical or segmentation model used to determine the segment assignment (e.g., Customer Lifetime Value (CLTV) Model, Risk-Based Segmentation Model).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueBand rdf:type rdf:Property ;
    rdfs:label 'Revenue Band' ;
    rdfs:comment 'Revenue band or range associated with the segment assignment, supporting revenue-based segmentation strategies.' ;
    rdfs:domain ind:PartySegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentTier rdf:type rdf:Property ;
    rdfs:label 'Segment Tier' ;
    rdfs:comment 'Hierarchical tier classification within the segment, supporting multi-level segmentation strategies (e.g., Tier 1 for highest value customers).' ;
    rdfs:domain ind:PartySegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prospectId rdf:type rdf:Property ;
    rdfs:label 'Prospect Id' ;
    rdfs:comment 'Unique identifier for the prospect record. Primary key.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedRmEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Assigned Rm Employee Id' ;
    rdfs:comment 'Employee identifier of the relationship manager or sales representative assigned to cultivate and convert this prospect.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:leadSourceCampaignId rdf:type rdf:Property ;
    rdfs:label 'Lead Source Campaign Id' ;
    rdfs:comment 'Identifier of the specific marketing campaign or initiative that generated this prospect lead for attribution and ROI (Return on Investment) tracking.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MarketingCampaign .

ind:leadSourceCodeListId rdf:type rdf:Property ;
    rdfs:label 'Lead Source Code List Id' ;
    rdfs:comment 'Foreign key linking to reference.code_list. Business justification: Marketing attribution - lead sources (Referral, Campaign, Walk-in, Digital, Partner) must be standardized for marketing ROI analysis, channel effectiveness measurement, and customer acquisition cost t' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CodeList .

ind:prospectConvertedPartyId rdf:type rdf:Property ;
    rdfs:label 'Prospect Converted Party Id' ;
    rdfs:comment 'Party identifier assigned to the prospect upon successful conversion to customer status linking the prospect record to the customer master record.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:prospectReferralSourcePartyId rdf:type rdf:Property ;
    rdfs:label 'Prospect Referral Source Party Id' ;
    rdfs:comment 'Party identifier of the existing customer or partner who referred this prospect for relationship attribution and incentive tracking.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:conversionDate rdf:type rdf:Property ;
    rdfs:label 'Conversion Date' ;
    rdfs:comment 'Date when the prospect was successfully converted to an active customer and onboarding was completed.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dataPrivacyConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Data Privacy Consent Flag' ;
    rdfs:comment 'Indicates whether the prospect has provided consent for data collection and processing in accordance with privacy regulations.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disqualificationDate rdf:type rdf:Property ;
    rdfs:label 'Disqualification Date' ;
    rdfs:comment 'Date when the prospect was formally disqualified and removed from active pursuit.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disqualificationReason rdf:type rdf:Property ;
    rdfs:label 'Disqualification Reason' ;
    rdfs:comment 'Reason code or description explaining why the prospect was disqualified such as insufficient assets, regulatory restrictions, or lack of interest.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementScore rdf:type rdf:Property ;
    rdfs:label 'Engagement Score' ;
    rdfs:comment 'Numerical score representing the level of prospect engagement based on interaction frequency, response rates, and expressed interest for prioritization.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedAnnualRevenuePotential rdf:type rdf:Property ;
    rdfs:label 'Estimated Annual Revenue Potential' ;
    rdfs:comment 'Projected annual revenue the bank could generate from this prospect based on expected product usage and fee income.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedAum rdf:type rdf:Property ;
    rdfs:label 'Estimated Aum' ;
    rdfs:comment 'Estimated total assets under management that the prospect could bring to the bank if converted, used for prioritization and resource allocation.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:firstContactDate rdf:type rdf:Property ;
    rdfs:label 'First Contact Date' ;
    rdfs:comment 'Date of the first documented contact or interaction with the prospect.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextFollowUpDate rdf:type rdf:Property ;
    rdfs:label 'Next Follow Up Date' ;
    rdfs:comment 'Scheduled date for the next planned follow-up activity or touchpoint with the prospect.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pepIndicatorPreliminary rdf:type rdf:Property ;
    rdfs:label 'Pep Indicator Preliminary' ;
    rdfs:comment 'Flag indicating whether initial screening suggests the prospect may be a Politically Exposed Person requiring enhanced due diligence.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productsOfInterest rdf:type rdf:Property ;
    rdfs:label 'Products Of Interest' ;
    rdfs:comment 'Comma-separated list of banking products or services the prospect has expressed interest in such as checking accounts, loans, investment advisory, or trade finance.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prospectType rdf:type rdf:Property ;
    rdfs:label 'Prospect Type' ;
    rdfs:comment 'Classification of the prospect entity type indicating whether the prospect is an individual, corporation, institutional investor, government entity, partnership, or trust.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationDate rdf:type rdf:Property ;
    rdfs:label 'Qualification Date' ;
    rdfs:comment 'Date when the prospect was formally qualified or disqualified based on established criteria.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualificationStatus rdf:type rdf:Property ;
    rdfs:label 'Qualification Status' ;
    rdfs:comment 'Assessment of whether the prospect meets the banks criteria for target customer profile based on initial screening and discovery.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskRatingPreliminary rdf:type rdf:Property ;
    rdfs:label 'Risk Rating Preliminary' ;
    rdfs:comment 'Initial risk assessment of the prospect based on available information prior to full KYC (Know Your Customer) and due diligence for AML (Anti-Money Laundering) and compliance screening.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sanctionsScreeningPreliminary rdf:type rdf:Property ;
    rdfs:label 'Sanctions Screening Preliminary' ;
    rdfs:comment 'Result of initial sanctions list screening against OFAC (Office of Foreign Assets Control), UN, EU, and other watchlists prior to onboarding.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCustomerSegment rdf:type rdf:Property ;
    rdfs:label 'Target Customer Segment' ;
    rdfs:comment 'Anticipated customer segment classification if the prospect is successfully onboarded such as retail mass market, affluent, high net worth, corporate SME (Small and Medium Enterprise), or institutional.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipHierarchyId rdf:type rdf:Property ;
    rdfs:label 'Relationship Hierarchy Id' ;
    rdfs:comment 'Unique identifier for the party-to-party relationship record. Primary key for the relationship hierarchy entity.' ;
    rdfs:domain ind:RelationshipHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryRelationshipPartyId rdf:type rdf:Property ;
    rdfs:label 'Primary Relationship Party Id' ;
    rdfs:comment 'Identifier of the first party in the relationship. For hierarchical relationships, this is typically the parent, controlling entity, or primary party. For bilateral relationships, this is one side of the association.' ;
    rdfs:domain ind:RelationshipHierarchy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:consolidatedExposureFlag rdf:type rdf:Property ;
    rdfs:label 'Consolidated Exposure Flag' ;
    rdfs:comment 'Indicates whether this relationship should be included in consolidated exposure calculations for regulatory capital and large exposure reporting (Basel III). True for relationships that create economic dependency or control (e.g., parent-subsidiary, guarantor-borrower).' ;
    rdfs:domain ind:RelationshipHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crossSellEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Cross Sell Eligibility Flag' ;
    rdfs:comment 'Indicates whether this relationship enables cross-sell opportunities (e.g., household members, corporate group entities). Used for CRM analytics, marketing campaigns, and customer lifetime value (CLTV) scoring.' ;
    rdfs:domain ind:RelationshipHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Level' ;
    rdfs:comment 'The depth or tier of this relationship within a hierarchical tree structure. Level 1 represents the top-most parent or ultimate controlling entity. Used for corporate group structure traversal and consolidated exposure calculation. Null for non-hierarchical (bilateral or reciprocal) relationships.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:kycLastReviewDate rdf:type rdf:Property ;
    rdfs:label 'Kyc Last Review Date' ;
    rdfs:comment 'The date on which this relationship was last reviewed or refreshed as part of KYC/CDD procedures. Used for tracking KYC refresh cycles and ensuring compliance with periodic review requirements.' ;
    rdfs:domain ind:RelationshipHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pepIndicator rdf:type rdf:Property ;
    rdfs:label 'Pep Indicator' ;
    rdfs:comment 'Indicates whether either party in this relationship is classified as a Politically Exposed Person (PEP) or is associated with a PEP. Used for enhanced due diligence requirements and AML compliance.' ;
    rdfs:domain ind:RelationshipHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:relatedPartyTransactionFlag rdf:type rdf:Property ;
    rdfs:label 'Related Party Transaction Flag' ;
    rdfs:comment 'Indicates whether transactions between these parties are classified as related party transactions under accounting standards (IAS 24) or regulatory frameworks. Used for disclosure requirements, conflict of interest management, and regulatory reporting.' ;
    rdfs:domain ind:RelationshipHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:relationshipDirection rdf:type rdf:Property ;
    rdfs:label 'Relationship Direction' ;
    rdfs:comment 'Indicates whether the relationship is directional (hierarchical, with a clear parent-child or controlling-controlled structure), bilateral (symmetric association where both parties have equal standing), or reciprocal (mutual obligations or roles).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipSourceCode rdf:type rdf:Property ;
    rdfs:label 'Relationship Source Code' ;
    rdfs:comment 'The unique identifier of this relationship in the source system. Used for traceability, reconciliation, and bi-directional synchronization with operational systems.' ;
    rdfs:domain ind:RelationshipHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Relationship Source System' ;
    rdfs:comment 'The operational system of record from which this relationship was sourced (e.g., Core Banking System, CRM, Loan Origination System). Used for data lineage, reconciliation, and troubleshooting.' ;
    rdfs:domain ind:RelationshipHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleA rdf:type rdf:Property ;
    rdfs:label 'Role A' ;
    rdfs:comment 'The role or function that Party A plays in this relationship (e.g., parent, guarantor, account holder, introducer, controlling shareholder, trustee). Provides semantic context for Party A\'s position.' ;
    rdfs:domain ind:RelationshipHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleB rdf:type rdf:Property ;
    rdfs:label 'Role B' ;
    rdfs:comment 'The role or function that Party B plays in this relationship (e.g., subsidiary, borrower, co-applicant, authorized signatory, beneficial owner, beneficiary). Provides semantic context for Party B\'s position.' ;
    rdfs:domain ind:RelationshipHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxProfileId rdf:type rdf:Property ;
    rdfs:label 'Tax Profile Id' ;
    rdfs:comment 'Unique identifier for the customer tax profile record. Primary key.' ;
    rdfs:domain ind:TaxProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:w8FormTypeCodeListId rdf:type rdf:Property ;
    rdfs:label 'W8 Form Type Code List Id' ;
    rdfs:comment 'Foreign key linking to reference.code_list. Business justification: Tax form standardization - W-8 form types (W-8BEN, W-8BEN-E, W-8ECI, W-8EXP, W-8IMY) must be standardized for withholding calculations, IRS reporting, and tax documentation management.' ;
    rdfs:domain ind:TaxProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CodeList .

ind:backupWithholdingFlag rdf:type rdf:Property ;
    rdfs:label 'Backup Withholding Flag' ;
    rdfs:comment 'Indicates whether the customer is subject to backup withholding due to missing or incorrect TIN, underreporting of interest/dividends, or IRS notification.' ;
    rdfs:domain ind:TaxProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:backupWithholdingRatePercent rdf:type rdf:Property ;
    rdfs:label 'Backup Withholding Rate Percent' ;
    rdfs:comment 'Backup withholding tax rate percentage applicable to the customer if backup withholding is required. Typically 24% in the US.' ;
    rdfs:domain ind:TaxProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chapter3StatusCode rdf:type rdf:Property ;
    rdfs:label 'Chapter 3 Status Code' ;
    rdfs:comment 'IRC Chapter 3 withholding status code indicating the customers classification for withholding purposes on US-source income (e.g., foreign individual, foreign corporation, foreign partnership). [ENUM-REF-CANDIDATE: promote to reference product if more than 6 distinct codes are used]' ;
    rdfs:domain ind:TaxProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chapter4StatusCode rdf:type rdf:Property ;
    rdfs:label 'Chapter 4 Status Code' ;
    rdfs:comment 'IRC Chapter 4 (FATCA) withholding status code indicating the customers classification for FATCA purposes (e.g., Participating FFI, Certified Deemed-Compliant FFI, Passive NFFE, Active NFFE). [ENUM-REF-CANDIDATE: promote to reference product if more than 6 distinct codes are used]' ;
    rdfs:domain ind:TaxProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentationStatus rdf:type rdf:Property ;
    rdfs:label 'Documentation Status' ;
    rdfs:comment 'Current status of the tax documentation on file for the customer (complete, incomplete, pending receipt, expired, or not required).' ;
    rdfs:domain ind:TaxProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fatcaClassificationCode rdf:type rdf:Property ;
    rdfs:label 'Fatca Classification Code' ;
    rdfs:comment 'FATCA classification code indicating the customer entity type and reporting obligations (e.g., Chapter 3 status codes, Chapter 4 status codes such as Owner-Documented FFI, Passive NFFE, Active NFFE). [ENUM-REF-CANDIDATE: promote to reference product if more than 6 distinct codes are used]' ;
    rdfs:domain ind:TaxProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryTaxResidencyCountryCode rdf:type rdf:Property ;
    rdfs:label 'Secondary Tax Residency Country Code' ;
    rdfs:comment 'Secondary country of tax residency if the customer has dual tax residency status, represented as ISO 3166-1 alpha-3 country code.' ;
    rdfs:domain ind:TaxProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryTin rdf:type rdf:Property ;
    rdfs:label 'Secondary Tin' ;
    rdfs:comment 'Secondary Tax Identification Number if the customer has tax obligations in multiple jurisdictions.' ;
    rdfs:domain ind:TaxProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryTinIssuingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Secondary Tin Issuing Country Code' ;
    rdfs:comment 'Country that issued the secondary Tax Identification Number, represented as ISO 3166-1 alpha-3 country code.' ;
    rdfs:domain ind:TaxProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExemptFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Exempt Flag' ;
    rdfs:comment 'Indicates whether the customer is exempt from withholding tax (e.g., foreign governments, international organizations, qualified pension funds).' ;
    rdfs:domain ind:TaxProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxExemptionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Tax Exemption Reason Code' ;
    rdfs:comment 'Code indicating the reason for tax exemption (e.g., foreign government, international organization, pension fund, charitable organization). [ENUM-REF-CANDIDATE: promote to reference product if more than 6 distinct codes are used]' ;
    rdfs:domain ind:TaxProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tin rdf:type rdf:Property ;
    rdfs:label 'Tin' ;
    rdfs:comment 'Tax Identification Number issued by the primary tax jurisdiction. Format varies by country (e.g., SSN in USA, NI in UK).' ;
    rdfs:domain ind:TaxProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tinIssuingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Tin Issuing Country Code' ;
    rdfs:comment 'Country that issued the Tax Identification Number, represented as ISO 3166-1 alpha-3 country code.' ;
    rdfs:domain ind:TaxProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tinType rdf:type rdf:Property ;
    rdfs:label 'Tin Type' ;
    rdfs:comment 'Type of Tax Identification Number provided (e.g., SSN for Social Security Number, EIN for Employer Identification Number, ITIN for Individual Taxpayer Identification Number, NI for National Insurance, VAT for Value Added Tax number).' ;
    rdfs:domain ind:TaxProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatyArticleReference rdf:type rdf:Property ;
    rdfs:label 'Treaty Article Reference' ;
    rdfs:comment 'Specific article or section of the tax treaty under which the customer claims treaty benefits (e.g., Article 10 for dividends, Article 11 for interest).' ;
    rdfs:domain ind:TaxProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatyBenefitEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Treaty Benefit Eligibility Flag' ;
    rdfs:comment 'Indicates whether the customer is eligible for reduced withholding tax rates under an applicable tax treaty between the US and the customers country of residence.' ;
    rdfs:domain ind:TaxProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:treatyCountryCode rdf:type rdf:Property ;
    rdfs:label 'Treaty Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the country with which a tax treaty applies, enabling reduced withholding rates.' ;
    rdfs:domain ind:TaxProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:w8FormExpiryDate rdf:type rdf:Property ;
    rdfs:label 'W8 Form Expiry Date' ;
    rdfs:comment 'Date on which the IRS Form W-8 expires and requires renewal. Typically three years from the date of signature unless a change in circumstances occurs.' ;
    rdfs:domain ind:TaxProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:w8FormReceivedDate rdf:type rdf:Property ;
    rdfs:label 'W8 Form Received Date' ;
    rdfs:comment 'Date on which the IRS Form W-8 was received from the customer.' ;
    rdfs:domain ind:TaxProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:w9FormReceivedDate rdf:type rdf:Property ;
    rdfs:label 'W9 Form Received Date' ;
    rdfs:comment 'Date on which the IRS Form W-9 (Request for Taxpayer Identification Number and Certification) was received from the US person customer.' ;
    rdfs:domain ind:TaxProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:caseId rdf:type rdf:Property ;
    rdfs:label 'Case Id' ;
    rdfs:comment 'Primary key for case' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountId rdf:type rdf:Property ;
    rdfs:label 'Account Id' ;
    rdfs:comment 'Reference to the deposit or loan account involved in the fraud incident. Nullable for party-level fraud cases without specific account context.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DepositAccount .

ind:bankingChannelId rdf:type rdf:Property ;
    rdfs:label 'Banking Channel Id' ;
    rdfs:comment 'Foreign key linking to channel.channel. Business justification: Fraud cases document the channel where fraud was perpetrated. Required for SAR filings (FinCEN requires channel context), Basel II operational risk reporting, channel security investment decisions, an' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:caseEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Case Employee Id' ;
    rdfs:comment 'Reference to the fraud investigator or analyst assigned to work this case. Links to employee or user master data.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:caseUpdatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Case Updated By User Employee Id' ;
    rdfs:comment 'Identifier of the system user who last modified this case record. Used for audit trail and accountability.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:customerJourneyId rdf:type rdf:Property ;
    rdfs:label 'Customer Journey Id' ;
    rdfs:comment 'Foreign key linking to channel.journey. Business justification: Fraud occurring during customer journeys (account opening, loan application, product enrollment) requires journey context for fraud typology classification (application fraud vs. transaction fraud), j' ;
    rdfs:domain ind:Case ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Journey .

ind:fraudAlertId rdf:type rdf:Property ;
    rdfs:label 'Fraud Alert Id' ;
    rdfs:comment 'Reference to the originating fraud detection alert that triggered this case. Links to alert management system for detection effectiveness analysis.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FraudAlert .

ind:fraudRingId rdf:type rdf:Property ;
    rdfs:label 'Fraud Ring Id' ;
    rdfs:comment 'Identifier linking this case to a known fraud ring or organized crime group. Nullable if not part of a ring.' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FraudRing .

ind:investigationBranchId rdf:type rdf:Property ;
    rdfs:label 'Investigation Branch Id' ;
    rdfs:comment 'Foreign key linking to channel.branch. Business justification: Complex fraud cases may require branch-based investigation (safe deposit box fraud, teller collusion, check fraud, cash vault discrepancies). Links case to physical location for evidence collection, s' ;
    rdfs:domain ind:Case ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Branch .

ind:originatingInteractionId rdf:type rdf:Property ;
    rdfs:label 'Originating Interaction Id' ;
    rdfs:comment 'Foreign key linking to channel.interaction. Business justification: Fraud cases originate from specific customer interactions. Linking provides forensic detail (employee involved, transaction amount, override codes, authentication method) for investigations, employee ' ;
    rdfs:domain ind:Case ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Interaction .

ind:originatingSessionId rdf:type rdf:Property ;
    rdfs:label 'Originating Session Id' ;
    rdfs:comment 'Foreign key linking to channel.session. Business justification: Fraud cases often originate from specific customer sessions. Session data provides forensic evidence (IP, device, geolocation, user actions, authentication method) required for investigations, SAR nar' ;
    rdfs:domain ind:Case ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Session .

ind:typologyId rdf:type rdf:Property ;
    rdfs:label 'Typology Id' ;
    rdfs:comment 'Foreign key linking to fraud.typology. Business justification: Each case can be classified by a fraud typology. N:1 relationship. No bidirectional conflict (typology does not have case_id FK back). Note: fraud_detection_method is different from typology classific' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Typology .

ind:assignedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assigned Timestamp' ;
    rdfs:comment 'Date and time when the case was assigned to an investigator. Used for SLA tracking and workload analytics.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:chargebackInitiatedFlag rdf:type rdf:Property ;
    rdfs:label 'Chargeback Initiated Flag' ;
    rdfs:comment 'Indicates whether a chargeback was initiated with the card network or payment processor for loss recovery.' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:confirmedLossAmount rdf:type rdf:Property ;
    rdfs:label 'Confirmed Loss Amount' ;
    rdfs:comment 'Final confirmed financial loss amount after investigation completion. Used for regulatory reporting and loss provisioning. Expressed in base currency.' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerReimbursedFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Reimbursed Flag' ;
    rdfs:comment 'Indicates whether the affected customer was reimbursed for their loss. Used for customer satisfaction and regulatory compliance tracking.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dispositionReason rdf:type rdf:Property ;
    rdfs:label 'Disposition Reason' ;
    rdfs:comment 'Detailed narrative explanation of the disposition outcome. Captures investigator findings and supporting rationale.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedLossAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Loss Amount' ;
    rdfs:comment 'Initial estimated financial loss amount at case opening. May be revised during investigation. Expressed in base currency.' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fraudDetectionMethod rdf:type rdf:Property ;
    rdfs:label 'Fraud Detection Method' ;
    rdfs:comment 'The method or system that initially detected the fraud. Used to measure detection effectiveness and optimize fraud controls.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudRingIndicator rdf:type rdf:Property ;
    rdfs:label 'Fraud Ring Indicator' ;
    rdfs:comment 'Indicates whether this case is part of an identified organized fraud ring or syndicate. Used for pattern analysis and network investigation.' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insuranceClaimFiledFlag rdf:type rdf:Property ;
    rdfs:label 'Insurance Claim Filed Flag' ;
    rdfs:comment 'Indicates whether an insurance claim was filed for fraud loss recovery under the banks fraud insurance policy.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lawEnforcementReferralFlag rdf:type rdf:Property ;
    rdfs:label 'Law Enforcement Referral Flag' ;
    rdfs:comment 'Indicates whether the case was referred to law enforcement agencies for criminal investigation or prosecution.' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:openedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Opened Timestamp' ;
    rdfs:comment 'Date and time when the fraud case was initially opened in the case management system. Marks the start of the investigation lifecycle.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recoveredAmount rdf:type rdf:Property ;
    rdfs:label 'Recovered Amount' ;
    rdfs:comment 'Total amount recovered through chargeback, insurance claim, or legal action. Used to calculate net loss. Expressed in base currency.' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reimbursementAmount rdf:type rdf:Property ;
    rdfs:label 'Reimbursement Amount' ;
    rdfs:comment 'Total amount reimbursed to the customer. Nullable if no reimbursement was made. Expressed in base currency.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reimbursementDate rdf:type rdf:Property ;
    rdfs:label 'Reimbursement Date' ;
    rdfs:comment 'Date when the customer reimbursement was processed. Nullable if no reimbursement was made. Used for SLA compliance tracking.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:relatedCaseCount rdf:type rdf:Property ;
    rdfs:label 'Related Case Count' ;
    rdfs:comment 'Number of related fraud cases linked to this case through common attributes such as party, device, or transaction pattern.' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:severity rdf:type rdf:Property ;
    rdfs:label 'Severity' ;
    rdfs:comment 'Risk-based severity classification reflecting potential financial and reputational impact. Level 1 is highest severity.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTargetCloseDate rdf:type rdf:Property ;
    rdfs:label 'Sla Target Close Date' ;
    rdfs:comment 'Target date by which the case should be closed based on SLA policy and case priority. Used for workload planning and escalation.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:chargebackId rdf:type rdf:Property ;
    rdfs:label 'Chargeback Id' ;
    rdfs:comment 'Primary key for chargeback' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cardTransactionId rdf:type rdf:Property ;
    rdfs:label 'Card Transaction Id' ;
    rdfs:comment 'Reference to the original payment transaction that is being disputed through this chargeback.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CardTransaction .

ind:disputeChannelId rdf:type rdf:Property ;
    rdfs:label 'Dispute Channel Id' ;
    rdfs:comment 'Foreign key linking to channel.channel. Business justification: Chargebacks document the channel where the disputed transaction occurred. Required for chargeback representment (channel-specific evidence requirements), network dispute resolution, channel-specific f' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:fraudIncidentId rdf:type rdf:Property ;
    rdfs:label 'Fraud Incident Id' ;
    rdfs:comment 'Foreign key linking to fraud.fraud_incident. Business justification: A chargeback can be linked to the underlying fraud incident that triggered it. N:1 relationship. No bidirectional conflict (fraud_incident does not have chargeback_id FK back). Chargeback has its own ' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FraudIncident .

ind:glJournalEntryId rdf:type rdf:Property ;
    rdfs:label 'Gl Journal Entry Id' ;
    rdfs:comment 'Foreign key linking to ledger.journal_entry. Business justification: Chargebacks generate accounting entries (debit loss account, credit customer account or suspense) that must be traceable to specific journal entries for subledger reconciliation, SOX controls, and aud' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntry .

ind:merchantId rdf:type rdf:Property ;
    rdfs:label 'Merchant Id' ;
    rdfs:comment 'Unique identifier for the merchant where the original transaction occurred. Used for merchant risk assessment and chargeback ratio monitoring.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Merchant .

ind:merchantIndustryCodeId rdf:type rdf:Property ;
    rdfs:label 'Merchant Industry Code Id' ;
    rdfs:comment 'Foreign key linking to reference.industry_code. Business justification: Chargebacks analyze merchant industry for dispute trend analysis, high-risk MCC identification, and chargeback prevention strategy. Card network and fraud operations requirement. New FK replaces denor' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IndustryCode .

ind:originalInteractionId rdf:type rdf:Property ;
    rdfs:label 'Original Interaction Id' ;
    rdfs:comment 'Foreign key linking to channel.interaction. Business justification: Chargebacks reference the original transaction interaction for representment evidence (signed receipts, authorization codes, delivery confirmation, EMV chip data). Critical for chargeback defense, net' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Interaction .

ind:acquirerBin rdf:type rdf:Property ;
    rdfs:label 'Acquirer Bin' ;
    rdfs:comment 'Bank Identification Number of the acquiring bank that processed the original transaction. Identifies the financial institution responsible for the merchant relationship.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arbitrationFiledDate rdf:type rdf:Property ;
    rdfs:label 'Arbitration Filed Date' ;
    rdfs:comment 'The date when either party escalated the dispute to formal arbitration with the card network.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cardNetwork rdf:type rdf:Property ;
    rdfs:label 'Card Network' ;
    rdfs:comment 'The payment card network that governs the chargeback dispute process (e.g., Visa, Mastercard, American Express). Each network has distinct rules and timelines.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardType rdf:type rdf:Property ;
    rdfs:label 'Card Type' ;
    rdfs:comment 'Type of payment card involved in the disputed transaction (credit, debit, prepaid, or charge card).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargebackStatus rdf:type rdf:Property ;
    rdfs:label 'Chargeback Status' ;
    rdfs:comment 'Current processing status of the chargeback within the current stage. Indicates whether the chargeback is awaiting action, under investigation, or has reached a decision point.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fee rdf:type rdf:Property ;
    rdfs:label 'Fee' ;
    rdfs:comment 'Administrative fee charged by the card network or acquiring bank for processing the chargeback. Typically ranges from $15 to $100 depending on the network and merchant agreement.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fraudIndicator rdf:type rdf:Property ;
    rdfs:label 'Fraud Indicator' ;
    rdfs:comment 'Boolean flag indicating whether the chargeback is related to confirmed or suspected fraudulent activity. True if the chargeback reason code indicates fraud.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:initiatedDate rdf:type rdf:Property ;
    rdfs:label 'Initiated Date' ;
    rdfs:comment 'The date when the chargeback was first initiated by the cardholder or issuing bank.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:issuerBin rdf:type rdf:Property ;
    rdfs:label 'Issuer Bin' ;
    rdfs:comment 'Bank Identification Number of the card-issuing bank. Identifies the financial institution that issued the payment card to the cardholder.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lossAmount rdf:type rdf:Property ;
    rdfs:label 'Loss Amount' ;
    rdfs:comment 'The net financial loss incurred by the bank after resolution of the chargeback, accounting for any recoveries, fees, and adjustments.' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maskedCardNumber rdf:type rdf:Property ;
    rdfs:label 'Masked Card Number' ;
    rdfs:comment 'Partially masked payment card number (e.g., ****1234) used to identify the card while maintaining PCI DSS compliance. Only the last four digits are visible.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:merchantName rdf:type rdf:Property ;
    rdfs:label 'Merchant Name' ;
    rdfs:comment 'Name of the merchant or business where the disputed transaction took place.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Network Case Number' ;
    rdfs:comment 'Unique case identifier assigned by the payment card network (Visa, Mastercard, Amex) for tracking the chargeback through the network dispute resolution process.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalTransactionAmount rdf:type rdf:Property ;
    rdfs:label 'Original Transaction Amount' ;
    rdfs:comment 'The full amount of the original transaction that is subject to the chargeback dispute.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalTransactionCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Original Transaction Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the original transaction amount.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalTransactionDate rdf:type rdf:Property ;
    rdfs:label 'Original Transaction Date' ;
    rdfs:comment 'The date when the original disputed transaction was processed.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:receivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Received Timestamp' ;
    rdfs:comment 'The precise date and time when the bank received the chargeback notification from the payment network.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recoveryAmount rdf:type rdf:Property ;
    rdfs:label 'Recovery Amount' ;
    rdfs:comment 'The amount recovered by the bank through the chargeback process, representment, or other loss recovery mechanisms. May differ from the original dispute amount.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:representmentFiledDate rdf:type rdf:Property ;
    rdfs:label 'Representment Filed Date' ;
    rdfs:comment 'The date when the merchant or acquiring bank filed a representment (rebuttal) to challenge the chargeback.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:resolutionOutcome rdf:type rdf:Property ;
    rdfs:label 'Resolution Outcome' ;
    rdfs:comment 'Final outcome of the chargeback dispute. Cardholder favor means the chargeback stands; merchant favor means the chargeback was reversed; partial reversal indicates a compromise; withdrawn means the cardholder retracted the dispute; expired means no response was filed within the deadline.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Response Deadline Date' ;
    rdfs:comment 'The date by which the bank or merchant must respond to the chargeback to avoid automatic acceptance. Deadlines are typically set by card network rules (e.g., 30-45 days).' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sarFiledIndicator rdf:type rdf:Property ;
    rdfs:label 'Sar Filed Indicator' ;
    rdfs:comment 'Boolean flag indicating whether a Suspicious Activity Report was filed with FinCEN in connection with this chargeback due to suspected fraud or money laundering.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stage rdf:type rdf:Property ;
    rdfs:label 'Stage' ;
    rdfs:comment 'Current stage in the chargeback dispute lifecycle. First chargeback is the initial dispute; representment is the merchant\'s response; pre-arbitration and arbitration are escalation stages; closed indicates final resolution.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionRuleId rdf:type rdf:Property ;
    rdfs:label 'Detection Rule Id' ;
    rdfs:comment 'Unique identifier for the fraud detection rule within the transaction monitoring engine.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DetectionRule .

ind:alertPriorityScore rdf:type rdf:Property ;
    rdfs:label 'Alert Priority Score' ;
    rdfs:comment 'Numeric priority score (1-100) assigned to alerts generated by this rule, used for case queue prioritization and resource allocation. Higher scores indicate higher priority.' ;
    rdfs:domain ind:DetectionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:alertVolume rdf:type rdf:Property ;
    rdfs:label 'Alert Volume' ;
    rdfs:comment 'Total number of alerts generated by this rule during the measurement period. Used for capacity planning and rule efficiency assessment.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:caseConversionRate rdf:type rdf:Property ;
    rdfs:label 'Case Conversion Rate' ;
    rdfs:comment 'Proportion of alerts that resulted in formal fraud investigation cases, calculated as cases opened divided by total alerts. Indicates rule precision and investigative value.' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:channelApplicability rdf:type rdf:Property ;
    rdfs:label 'Channel Applicability' ;
    rdfs:comment 'Comma-separated list of banking channels to which this rule applies: online banking, mobile app, ATM (Automated Teller Machine), branch, call center, wire transfer, ACH (Automated Clearing House), card payment. Empty indicates all channels.' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSegmentApplicability rdf:type rdf:Property ;
    rdfs:label 'Customer Segment Applicability' ;
    rdfs:comment 'Target customer segments for rule application: retail, commercial, wealth management, institutional. Allows segment-specific tuning of detection thresholds.' ;
    rdfs:domain ind:DetectionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionEffectivenessScore rdf:type rdf:Property ;
    rdfs:label 'Detection Effectiveness Score' ;
    rdfs:comment 'Composite metric (0-100) evaluating overall rule performance, incorporating true positive rate, false positive rate, and case conversion rate. Used for rule ranking and optimization prioritization.' ;
    rdfs:domain ind:DetectionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Measurement Period End Date' ;
    rdfs:comment 'End date of the performance measurement period for the recorded metrics. Defines the temporal scope of performance statistics.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Measurement Period Start Date' ;
    rdfs:comment 'Start date of the performance measurement period for the recorded metrics. Enables time-series analysis of rule effectiveness.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mlModelName rdf:type rdf:Property ;
    rdfs:label 'Ml Model Name' ;
    rdfs:comment 'Name or identifier of the machine learning model used for detection, if applicable. References trained model artifacts in the fraud analytics platform.' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mlModelVersion rdf:type rdf:Property ;
    rdfs:label 'Ml Model Version' ;
    rdfs:comment 'Version identifier of the machine learning model, enabling model lineage tracking and performance comparison across model iterations.' ;
    rdfs:domain ind:DetectionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelType rdf:type rdf:Property ;
    rdfs:label 'Model Type' ;
    rdfs:comment 'Detection methodology employed: rule-based (deterministic logic), machine learning (ML/AI model), hybrid (combination of rules and ML), statistical (statistical anomaly detection).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productApplicability rdf:type rdf:Property ;
    rdfs:label 'Product Applicability' ;
    rdfs:comment 'Comma-separated list of banking products to which this rule applies: DDA (Demand Deposit Account), savings account, credit card, debit card, wire transfer, loan, investment account. Empty indicates all products.' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportingRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Required' ;
    rdfs:comment 'Indicates whether confirmed fraud cases from this rule must be included in regulatory reports such as CTR (Currency Transaction Report) or SAR (Suspicious Activity Report) filings.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ruleDocumentationUrl rdf:type rdf:Property ;
    rdfs:label 'Rule Documentation Url' ;
    rdfs:comment 'URL or file path to detailed technical documentation, configuration guides, and tuning history for the rule. Supports knowledge management and operational continuity.' ;
    rdfs:domain ind:DetectionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleLogic rdf:type rdf:Property ;
    rdfs:label 'Rule Logic' ;
    rdfs:comment 'Detailed description of the rule\'s detection logic, including conditions, thresholds, and decision criteria. May reference SQL-like expressions, business rules, or machine learning model invocation logic.' ;
    rdfs:domain ind:DetectionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleOwner rdf:type rdf:Property ;
    rdfs:label 'Rule Owner' ;
    rdfs:comment 'Name or identifier of the business unit, team, or individual responsible for rule governance, performance monitoring, and tuning decisions.' ;
    rdfs:domain ind:DetectionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleSeverity rdf:type rdf:Property ;
    rdfs:label 'Rule Severity' ;
    rdfs:comment 'Severity classification of alerts generated by this rule, indicating priority for investigation: critical (immediate action required), high (urgent review), medium (standard review), low (informational).' ;
    rdfs:domain ind:DetectionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sarEscalationFlag rdf:type rdf:Property ;
    rdfs:label 'Sar Escalation Flag' ;
    rdfs:comment 'Indicates whether alerts from this rule automatically trigger SAR (Suspicious Activity Report) escalation workflow for regulatory reporting to FinCEN (Financial Crimes Enforcement Network).' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:timeWindowUnit rdf:type rdf:Property ;
    rdfs:label 'Time Window Unit' ;
    rdfs:comment 'Unit of time for the evaluation window: minute, hour, day, week, or month. Defines the temporal scope for transaction aggregation and pattern detection.' ;
    rdfs:domain ind:DetectionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeWindowValue rdf:type rdf:Property ;
    rdfs:label 'Time Window Value' ;
    rdfs:comment 'Numeric value defining the lookback or evaluation period for the rule (e.g., 24 for 24 hours, 7 for 7 days). Used in velocity checks and pattern analysis.' ;
    rdfs:domain ind:DetectionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:truePositiveRate rdf:type rdf:Property ;
    rdfs:label 'True Positive Rate' ;
    rdfs:comment 'Proportion of actual fraud cases correctly identified by the rule, calculated as true positives divided by total actual fraud cases. Key performance metric for detection effectiveness.' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tuningFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Tuning Frequency Days' ;
    rdfs:comment 'Recommended number of days between rule performance reviews and parameter adjustments. Supports proactive rule maintenance scheduling.' ;
    rdfs:domain ind:DetectionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deviceFingerprintId rdf:type rdf:Property ;
    rdfs:label 'Device Fingerprint Id' ;
    rdfs:comment 'Unique identifier for the device fingerprint record. Primary key.' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeviceFingerprint .

ind:customerSessionId rdf:type rdf:Property ;
    rdfs:label 'Customer Session Id' ;
    rdfs:comment 'Foreign key linking to channel.session. Business justification: Device fingerprinting is performed during customer sessions. Linking enables real-time fraud scoring during active sessions, session replay analysis post-fraud, behavioral biometrics correlation, and ' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Session .

ind:geolocationCountryId rdf:type rdf:Property ;
    rdfs:label 'Geolocation Country Id' ;
    rdfs:comment 'Foreign key linking to reference.country. Business justification: Device geolocation enables geographic velocity checks (impossible travel), sanctions screening, high-risk jurisdiction flagging, and cross-border fraud detection. Essential for digital fraud preventio' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:associatedAccountCount rdf:type rdf:Property ;
    rdfs:label 'Associated Account Count' ;
    rdfs:comment 'Number of distinct accounts that have been accessed from this device fingerprint. Abnormally high counts may indicate account takeover activity.' ;
    rdfs:domain ind:DeviceFingerprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:associatedPartyCount rdf:type rdf:Property ;
    rdfs:label 'Associated Party Count' ;
    rdfs:comment 'Number of distinct customer or party identifiers that have used this device fingerprint. High counts may indicate shared devices or fraud rings.' ;
    rdfs:domain ind:DeviceFingerprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:blacklistDate rdf:type rdf:Property ;
    rdfs:label 'Blacklist Date' ;
    rdfs:comment 'Date when the device was added to the blacklist. Null if not blacklisted.' ;
    rdfs:domain ind:DeviceFingerprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:blacklistReason rdf:type rdf:Property ;
    rdfs:label 'Blacklist Reason' ;
    rdfs:comment 'Business reason or fraud typology that caused the device to be blacklisted (e.g., account takeover, card-not-present fraud, multiple failed authentication attempts).' ;
    rdfs:domain ind:DeviceFingerprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blacklistStatus rdf:type rdf:Property ;
    rdfs:label 'Blacklist Status' ;
    rdfs:comment 'Indicates whether the device is on a fraud blacklist, watchlist, or whitelist for monitoring and blocking purposes.' ;
    rdfs:domain ind:DeviceFingerprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cookieEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Cookie Enabled Flag' ;
    rdfs:comment 'Indicates whether cookies are enabled on the device browser. False may indicate privacy tools or fraud evasion techniques.' ;
    rdfs:domain ind:DeviceFingerprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deviceIdentifier rdf:type rdf:Property ;
    rdfs:label 'Device Identifier' ;
    rdfs:comment 'Unique device identifier such as IMEI, MAC address, or vendor-assigned device ID used to track the physical device across sessions.' ;
    rdfs:domain ind:DeviceFingerprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceReputationScore rdf:type rdf:Property ;
    rdfs:label 'Device Reputation Score' ;
    rdfs:comment 'Aggregated reputation score (0-100) based on historical behavior, fraud incidents, and third-party threat intelligence feeds. Lower scores indicate higher risk.' ;
    rdfs:domain ind:DeviceFingerprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emulatorIndicator rdf:type rdf:Property ;
    rdfs:label 'Emulator Indicator' ;
    rdfs:comment 'Flag indicating whether the device appears to be an emulator rather than a physical device, often used in automated fraud attacks.' ;
    rdfs:domain ind:DeviceFingerprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fingerprintHash rdf:type rdf:Property ;
    rdfs:label 'Fingerprint Hash' ;
    rdfs:comment 'Cryptographic hash representing the unique combination of device attributes (browser, OS, screen resolution, plugins, fonts, timezone) used for device identification and fraud detection.' ;
    rdfs:domain ind:DeviceFingerprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstSeenTimestamp rdf:type rdf:Property ;
    rdfs:label 'First Seen Timestamp' ;
    rdfs:comment 'Date and time when this device fingerprint was first observed in the banking system.' ;
    rdfs:domain ind:DeviceFingerprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fraudCaseCount rdf:type rdf:Property ;
    rdfs:label 'Fraud Case Count' ;
    rdfs:comment 'Total number of confirmed fraud cases associated with this device fingerprint.' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fraudTypology rdf:type rdf:Property ;
    rdfs:label 'Fraud Typology' ;
    rdfs:comment 'Primary fraud typology associated with this device (e.g., account takeover, card-not-present fraud, synthetic identity fraud, wire fraud). [ENUM-REF-CANDIDATE: account_takeover|card_not_present|synthetic_identity|wire_fraud|check_fraud|phishing|social_engineering|insider_fraud — promote to reference product]' ;
    rdfs:domain ind:DeviceFingerprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geolocationCity rdf:type rdf:Property ;
    rdfs:label 'Geolocation City' ;
    rdfs:comment 'City name derived from IP geolocation or device GPS coordinates.' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:javascriptEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Javascript Enabled Flag' ;
    rdfs:comment 'Indicates whether JavaScript is enabled on the device browser. Disabled JavaScript may indicate bot activity or fraud evasion.' ;
    rdfs:domain ind:DeviceFingerprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastFraudAlertTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Fraud Alert Timestamp' ;
    rdfs:comment 'Date and time when the most recent fraud alert was triggered for activity from this device.' ;
    rdfs:domain ind:DeviceFingerprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastSeenTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Seen Timestamp' ;
    rdfs:comment 'Date and time when this device fingerprint was most recently observed in an active session or transaction.' ;
    rdfs:domain ind:DeviceFingerprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:proxyVpnIndicator rdf:type rdf:Property ;
    rdfs:label 'Proxy Vpn Indicator' ;
    rdfs:comment 'Flag indicating whether the device is connecting through a proxy server or VPN, which may indicate location masking or fraud.' ;
    rdfs:domain ind:DeviceFingerprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riskScoreTimestamp rdf:type rdf:Property ;
    rdfs:label 'Risk Score Timestamp' ;
    rdfs:comment 'Date and time when the fraud risk score was last calculated or updated.' ;
    rdfs:domain ind:DeviceFingerprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rootedJailbrokenIndicator rdf:type rdf:Property ;
    rdfs:label 'Rooted Jailbroken Indicator' ;
    rdfs:comment 'Flag indicating whether the mobile device has been rooted (Android) or jailbroken (iOS), which increases fraud risk by bypassing security controls.' ;
    rdfs:domain ind:DeviceFingerprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:screenResolution rdf:type rdf:Property ;
    rdfs:label 'Screen Resolution' ;
    rdfs:comment 'Screen resolution of the device in pixels (e.g., 1920x1080, 2560x1440) used as part of device fingerprinting.' ;
    rdfs:domain ind:DeviceFingerprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timezoneOffset rdf:type rdf:Property ;
    rdfs:label 'Timezone Offset' ;
    rdfs:comment 'Timezone offset from UTC reported by the device (e.g., -05:00, +01:00) used to detect location spoofing.' ;
    rdfs:domain ind:DeviceFingerprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:torNetworkIndicator rdf:type rdf:Property ;
    rdfs:label 'Tor Network Indicator' ;
    rdfs:comment 'Flag indicating whether the device is connecting through the TOR anonymity network, a high-risk indicator for fraud.' ;
    rdfs:domain ind:DeviceFingerprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:userAgentString rdf:type rdf:Property ;
    rdfs:label 'User Agent String' ;
    rdfs:comment 'Full HTTP user agent string provided by the browser or application, containing detailed device and software information.' ;
    rdfs:domain ind:DeviceFingerprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:velocity24hTransactionCount rdf:type rdf:Property ;
    rdfs:label 'Velocity 24h Transaction Count' ;
    rdfs:comment 'Number of transactions initiated from this device in the last 24 hours. Used for velocity-based fraud detection rules.' ;
    rdfs:domain ind:DeviceFingerprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:velocity7dLoginCount rdf:type rdf:Property ;
    rdfs:label 'Velocity 7d Login Count' ;
    rdfs:comment 'Number of login attempts from this device in the last 7 days. High counts may indicate credential stuffing or brute force attacks.' ;
    rdfs:domain ind:DeviceFingerprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transactionChannelId rdf:type rdf:Property ;
    rdfs:label 'Transaction Channel Id' ;
    rdfs:comment 'Foreign key linking to channel.channel. Business justification: Fraud alerts capture the channel where suspicious transactions occurred for pattern analysis and channel-specific fraud detection tuning. Essential for fraud operations teams analyzing fraud by channe' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:triggeringInteractionId rdf:type rdf:Property ;
    rdfs:label 'Triggering Interaction Id' ;
    rdfs:comment 'Foreign key linking to channel.interaction. Business justification: Fraud alerts are triggered by specific interactions (ATM withdrawal, wire transfer, mobile deposit). Linking enables interaction replay for investigations, employee review (insider fraud detection), f' ;
    rdfs:domain ind:FraudAlert ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Interaction .

ind:cardNumberLastFour rdf:type rdf:Property ;
    rdfs:label 'Card Number Last Four' ;
    rdfs:comment 'Last four digits of the payment card number involved in the alert, used for identification without exposing full PCI data.' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerContactTimestamp rdf:type rdf:Property ;
    rdfs:label 'Customer Contact Timestamp' ;
    rdfs:comment 'Date and time when the customer was contacted regarding the fraud alert.' ;
    rdfs:domain ind:FraudAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:customerContactedFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Contacted Flag' ;
    rdfs:comment 'Boolean indicator of whether the customer was contacted during the alert investigation for verification or additional information.' ;
    rdfs:domain ind:FraudAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:detectionMethod rdf:type rdf:Property ;
    rdfs:label 'Detection Method' ;
    rdfs:comment 'The detection mechanism or source that generated the fraud alert, indicating whether it was triggered by automated rules, ML models, behavioral analytics, or external sources.' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionCode rdf:type rdf:Property ;
    rdfs:label 'Disposition Code' ;
    rdfs:comment 'Final outcome classification assigned by the analyst after investigation, indicating whether the alert represents genuine fraud, a false positive, or requires further action.' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalatedToCaseId rdf:type rdf:Property ;
    rdfs:label 'Escalated To Case Id' ;
    rdfs:comment 'Identifier of the fraud case created when this alert was escalated for formal investigation, chargeback, or law enforcement referral.' ;
    rdfs:domain ind:FraudAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:falsePositiveReason rdf:type rdf:Property ;
    rdfs:label 'False Positive Reason' ;
    rdfs:comment 'Structured reason or free-text explanation documenting why the alert was classified as a false positive, used for rule tuning and model retraining.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Review Completed Timestamp' ;
    rdfs:comment 'Date and time when the fraud analyst completed the investigation and assigned a final disposition to the alert.' ;
    rdfs:domain ind:FraudAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reviewStartedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Review Started Timestamp' ;
    rdfs:comment 'Date and time when the fraud analyst began reviewing the alert, marking the transition from new to under review status.' ;
    rdfs:domain ind:FraudAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:claimId rdf:type rdf:Property ;
    rdfs:label 'Claim Id' ;
    rdfs:comment 'Unique identifier for the fraud claim record. Primary key.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:claimDepositAccountId rdf:type rdf:Property ;
    rdfs:label 'Claim Deposit Account Id' ;
    rdfs:comment 'Identifier of the account associated with the fraud claim.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DepositAccount .

ind:claimProvisionalCreditAccountDepositAccountId rdf:type rdf:Property ;
    rdfs:label 'Claim Provisional Credit Account Deposit Account Id' ;
    rdfs:comment 'Identifier of the account to which provisional credit was posted.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DepositAccount .

ind:claimedInteractionId rdf:type rdf:Property ;
    rdfs:label 'Claimed Interaction Id' ;
    rdfs:comment 'Foreign key linking to channel.interaction. Business justification: Customer fraud claims reference specific interactions. Linking enables claim validation (did transaction occur as claimed?), provisional credit calculation (Reg E 10-day rule), dispute resolution, and' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Interaction .

ind:fraudChargebackId rdf:type rdf:Property ;
    rdfs:label 'Fraud Chargeback Id' ;
    rdfs:comment 'External case identifier for the chargeback filed with the card network or payment processor.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Chargeback .

ind:intakeContactCenterId rdf:type rdf:Property ;
    rdfs:label 'Intake Contact Center Id' ;
    rdfs:comment 'Foreign key linking to channel.contact_center. Business justification: Customer fraud claims received via contact centers require linkage for Reg E compliance (claim receipt timestamp verification from call logs), call recording retention (legal hold for disputes), dispu' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContactCenter .

ind:chargebackInitiated rdf:type rdf:Property ;
    rdfs:label 'Chargeback Initiated' ;
    rdfs:comment 'Indicates whether a chargeback was initiated with the card network or merchant acquirer as part of the claim resolution process.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:claimNumber rdf:type rdf:Property ;
    rdfs:label 'Claim Number' ;
    rdfs:comment 'Externally visible unique claim reference number assigned at intake for customer and regulatory tracking.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimStatus rdf:type rdf:Property ;
    rdfs:label 'Claim Status' ;
    rdfs:comment 'Current lifecycle status of the fraud claim in the investigation and resolution workflow. [ENUM-REF-CANDIDATE: received|under_investigation|pending_documentation|approved|denied|closed|withdrawn — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimType rdf:type rdf:Property ;
    rdfs:label 'Claim Type' ;
    rdfs:comment 'Classification of the fraud claim based on the nature of the fraudulent activity reported by the customer.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimedAmount rdf:type rdf:Property ;
    rdfs:label 'Claimed Amount' ;
    rdfs:comment 'Total monetary amount claimed by the customer as fraudulent or disputed, in the account currency.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerAttestationReceived rdf:type rdf:Property ;
    rdfs:label 'Customer Attestation Received' ;
    rdfs:comment 'Indicates whether the customer has provided a signed attestation or affidavit affirming the fraudulent nature of the transactions.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Date' ;
    rdfs:comment 'Date the customer was notified of the claim resolution outcome.' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:finalCreditConfirmationDate rdf:type rdf:Property ;
    rdfs:label 'Final Credit Confirmation Date' ;
    rdfs:comment 'Date the provisional credit was confirmed as permanent following successful claim resolution.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:finalCreditConfirmed rdf:type rdf:Property ;
    rdfs:label 'Final Credit Confirmed' ;
    rdfs:comment 'Indicates whether provisional credit has been converted to permanent credit following claim approval.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:investigationCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Investigation Completion Date' ;
    rdfs:comment 'Date the fraud investigation was completed and a determination was made.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lawEnforcementCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Law Enforcement Case Number' ;
    rdfs:comment 'Case number assigned by the law enforcement agency for tracking the criminal investigation.' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:provisionalCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Provisional Credit Amount' ;
    rdfs:comment 'Amount of provisional credit issued to the customer pending investigation outcome, as required by consumer protection regulations.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:provisionalCreditIssuedDate rdf:type rdf:Property ;
    rdfs:label 'Provisional Credit Issued Date' ;
    rdfs:comment 'Date provisional credit was posted to the customer account, must comply with Regulation E 10-business-day rule or Regulation Z 5-business-day rule.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:provisionalCreditReversalDate rdf:type rdf:Property ;
    rdfs:label 'Provisional Credit Reversal Date' ;
    rdfs:comment 'Date provisional credit was reversed from the customer account, typically when the claim is denied or investigation concludes the transaction was authorized.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:provisionalCreditReversalReason rdf:type rdf:Property ;
    rdfs:label 'Provisional Credit Reversal Reason' ;
    rdfs:comment 'Business reason for reversing provisional credit, such as claim denial, customer withdrawal, or determination that transaction was authorized.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptDate rdf:type rdf:Property ;
    rdfs:label 'Receipt Date' ;
    rdfs:comment 'Date the fraud claim was received from the customer, marking the start of regulatory timelines for provisional credit and investigation.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:receiptTimestamp rdf:type rdf:Property ;
    rdfs:label 'Receipt Timestamp' ;
    rdfs:comment 'Precise timestamp when the fraud claim was logged into the system, used for SLA tracking and audit trails.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recoveryDate rdf:type rdf:Property ;
    rdfs:label 'Recovery Date' ;
    rdfs:comment 'Date recovery funds were received and posted.' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:resolutionCode rdf:type rdf:Property ;
    rdfs:label 'Resolution Code' ;
    rdfs:comment 'Final disposition code indicating the outcome of the fraud claim investigation.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionNotes rdf:type rdf:Property ;
    rdfs:label 'Resolution Notes' ;
    rdfs:comment 'Detailed narrative explanation of the investigation findings and resolution rationale, used for audit and quality assurance.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sarBsaIdentifier rdf:type rdf:Property ;
    rdfs:label 'Sar Bsa Identifier' ;
    rdfs:comment 'FinCEN BSA identifier assigned to the filed SAR.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceId rdf:type rdf:Property ;
    rdfs:label 'Evidence Id' ;
    rdfs:comment 'Unique identifier for the fraud evidence item. Primary key for the fraud evidence entity.' ;
    rdfs:domain ind:Evidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:evidenceEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Evidence Employee Id' ;
    rdfs:comment 'Reference to the fraud analyst or investigator who collected or secured this evidence item.' ;
    rdfs:domain ind:Evidence ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:evidenceUpdatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Evidence Updated By User Employee Id' ;
    rdfs:comment 'Reference to the user or analyst who last updated this fraud evidence record.' ;
    rdfs:domain ind:Evidence ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:admissibilityClassification rdf:type rdf:Property ;
    rdfs:label 'Admissibility Classification' ;
    rdfs:comment 'Legal admissibility classification of the evidence item for use in legal proceedings, regulatory examinations, or law enforcement referrals. Indicates whether the evidence meets evidentiary standards and chain of custody requirements.' ;
    rdfs:domain ind:Evidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:archivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Archived Timestamp' ;
    rdfs:comment 'The date and time when the evidence item was moved to long-term archival storage.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:chainOfCustodyStatus rdf:type rdf:Property ;
    rdfs:label 'Chain Of Custody Status' ;
    rdfs:comment 'Current lifecycle status of the evidence item within the chain of custody process. Tracks whether the evidence has been collected, secured in storage, transferred to another party, archived for long-term retention, or destroyed per retention policy.' ;
    rdfs:domain ind:Evidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Collection Timestamp' ;
    rdfs:comment 'The date and time when the evidence item was collected or extracted from the source system. Represents the principal business event timestamp for evidence capture.' ;
    rdfs:domain ind:Evidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:containsPiiFlag rdf:type rdf:Property ;
    rdfs:label 'Contains Pii Flag' ;
    rdfs:comment 'Indicates whether the evidence item contains personally identifiable information (PII) subject to privacy regulations such as GDPR, CCPA, or GLBA.' ;
    rdfs:domain ind:Evidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:destroyedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Destroyed Timestamp' ;
    rdfs:comment 'The date and time when the evidence item was destroyed per retention policy and legal requirements.' ;
    rdfs:domain ind:Evidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:destructionMethod rdf:type rdf:Property ;
    rdfs:label 'Destruction Method' ;
    rdfs:comment 'The method used to destroy the evidence item. Includes secure deletion (for digital files), shredding (for paper documents), degaussing (for magnetic media), or incineration.' ;
    rdfs:domain ind:Evidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceDescription rdf:type rdf:Property ;
    rdfs:label 'Evidence Description' ;
    rdfs:comment 'Detailed textual description of the evidence item, including its content, relevance to the fraud case, and any notable characteristics or findings.' ;
    rdfs:domain ind:Evidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceType rdf:type rdf:Property ;
    rdfs:label 'Evidence Type' ;
    rdfs:comment 'Classification of the evidence item by its nature and format. Includes transaction log extract, device fingerprint record, IP geolocation data, call recording, surveillance footage, document image, network traffic log, customer correspondence, witness statement, and third-party verification response.' ;
    rdfs:domain ind:Evidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileName rdf:type rdf:Property ;
    rdfs:label 'File Name' ;
    rdfs:comment 'The original or assigned file name of the evidence artifact, including file extension if applicable.' ;
    rdfs:domain ind:Evidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hashAlgorithm rdf:type rdf:Property ;
    rdfs:label 'Hash Algorithm' ;
    rdfs:comment 'The cryptographic hash algorithm used to generate the hash value for evidence integrity verification.' ;
    rdfs:domain ind:Evidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hashValue rdf:type rdf:Property ;
    rdfs:label 'Hash Value' ;
    rdfs:comment 'Cryptographic hash (e.g., SHA-256) of the evidence file to ensure integrity and detect tampering. Used to verify that the evidence has not been altered since collection.' ;
    rdfs:domain ind:Evidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:internalAuditReference rdf:type rdf:Property ;
    rdfs:label 'Internal Audit Reference' ;
    rdfs:comment 'Reference identifier for the internal audit review or control testing for which this evidence item was produced or is relevant.' ;
    rdfs:domain ind:Evidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lawEnforcementSharedFlag rdf:type rdf:Property ;
    rdfs:label 'Law Enforcement Shared Flag' ;
    rdfs:comment 'Indicates whether this evidence item has been shared with law enforcement agencies as part of a criminal investigation or Suspicious Activity Report (SAR) filing.' ;
    rdfs:domain ind:Evidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Legal Hold Flag' ;
    rdfs:comment 'Indicates whether the evidence item is subject to a legal hold order, preventing its destruction or alteration pending litigation, regulatory examination, or law enforcement investigation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalHoldReference rdf:type rdf:Property ;
    rdfs:label 'Legal Hold Reference' ;
    rdfs:comment 'Reference identifier for the legal hold order or case that requires preservation of this evidence item.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relevanceScore rdf:type rdf:Property ;
    rdfs:label 'Relevance Score' ;
    rdfs:comment 'A numerical score (0.00 to 100.00) indicating the relevance or importance of this evidence item to the fraud case investigation. Higher scores indicate more critical evidence.' ;
    rdfs:domain ind:Evidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retentionPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Retention Period Days' ;
    rdfs:comment 'The number of days the evidence item must be retained per the banks evidence retention policy, regulatory requirements, and legal hold obligations. Drives evidence archival and destruction schedules.' ;
    rdfs:domain ind:Evidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:secureStorageReference rdf:type rdf:Property ;
    rdfs:label 'Secure Storage Reference' ;
    rdfs:comment 'Reference identifier or URI pointing to the secure storage location where the evidence file or artifact is stored. May reference document management system, secure file share, or evidence vault.' ;
    rdfs:domain ind:Evidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferMethod rdf:type rdf:Property ;
    rdfs:label 'Transfer Method' ;
    rdfs:comment 'The method used to transfer the evidence item to another party. Includes secure email, encrypted file transfer, physical media (USB, CD), secure portal, or in-person handoff.' ;
    rdfs:domain ind:Evidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferRecipient rdf:type rdf:Property ;
    rdfs:label 'Transfer Recipient' ;
    rdfs:comment 'The name or identifier of the party to whom the evidence item was transferred.' ;
    rdfs:domain ind:Evidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transfer Timestamp' ;
    rdfs:comment 'The date and time when the evidence item was transferred to another party, such as law enforcement, legal counsel, or regulatory authority.' ;
    rdfs:domain ind:Evidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:transactionCountryId rdf:type rdf:Property ;
    rdfs:label 'Transaction Country Id' ;
    rdfs:comment 'Foreign key linking to reference.country. Business justification: Incidents track transaction location for cross-border fraud pattern analysis, jurisdiction determination, and country-level risk reporting. Core fraud investigation and reporting requirement. New FK r' ;
    rdfs:domain ind:FraudIncident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:chargebackDate rdf:type rdf:Property ;
    rdfs:label 'Chargeback Date' ;
    rdfs:comment 'Date when the chargeback was filed for this fraud incident, if applicable.' ;
    rdfs:domain ind:FraudIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:chargebackFlag rdf:type rdf:Property ;
    rdfs:label 'Chargeback Flag' ;
    rdfs:comment 'Indicates whether a chargeback was initiated for this fraud incident (True) or not (False).' ;
    rdfs:domain ind:FraudIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerReportedFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Reported Flag' ;
    rdfs:comment 'Indicates whether the fraud incident was reported by the customer (True) or detected by internal systems (False).' ;
    rdfs:domain ind:FraudIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incidentDescription rdf:type rdf:Property ;
    rdfs:label 'Incident Description' ;
    rdfs:comment 'Detailed narrative description of the fraudulent event, including circumstances, methods used, and any relevant context for investigation.' ;
    rdfs:domain ind:FraudIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentStatus rdf:type rdf:Property ;
    rdfs:label 'Incident Status' ;
    rdfs:comment 'Current lifecycle status of the fraud incident within the investigation workflow.' ;
    rdfs:domain ind:FraudIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Incident Timestamp' ;
    rdfs:comment 'Date and time when the fraudulent event occurred or was first detected. Represents the real-world event time of the fraudulent act.' ;
    rdfs:domain ind:FraudIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:investigationCloseDate rdf:type rdf:Property ;
    rdfs:label 'Investigation Close Date' ;
    rdfs:comment 'Date when the investigation of this fraud incident was completed and closed.' ;
    rdfs:domain ind:FraudIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lawEnforcementNotifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Law Enforcement Notified Flag' ;
    rdfs:comment 'Indicates whether law enforcement authorities were notified about this fraud incident (True) or not (False).' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transactionLocation rdf:type rdf:Property ;
    rdfs:label 'Transaction Location' ;
    rdfs:comment 'Geographic location where the fraudulent transaction occurred (city, state, country) or IP address for online transactions.' ;
    rdfs:domain ind:FraudIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lossId rdf:type rdf:Property ;
    rdfs:label 'Loss Id' ;
    rdfs:comment 'Unique identifier for the fraud loss ledger record. Primary key.' ;
    rdfs:domain ind:Loss ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:baselEventTypeCode rdf:type rdf:Property ;
    rdfs:label 'Basel Event Type Code' ;
    rdfs:comment 'Basel II/III operational risk event type code (e.g., ET1 for Internal Fraud, ET2 for External Fraud) used for regulatory capital calculation and reporting.' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ccarLossEventFlag rdf:type rdf:Property ;
    rdfs:label 'Ccar Loss Event Flag' ;
    rdfs:comment 'Indicates whether this fraud loss event is material enough to be included in CCAR stress testing and capital planning submissions.' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:chargebackReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Chargeback Reference Number' ;
    rdfs:comment 'Reference number for any chargeback initiated to recover the fraud loss from merchants or card networks.' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventNumber rdf:type rdf:Property ;
    rdfs:label 'Event Number' ;
    rdfs:comment 'Business-facing unique identifier for the loss event, used for tracking and reporting purposes.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glPostingReference rdf:type rdf:Property ;
    rdfs:label 'Gl Posting Reference' ;
    rdfs:comment 'Reference number or identifier for the general ledger journal entry that recorded this fraud loss.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossLossAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Loss Amount' ;
    rdfs:comment 'The total confirmed financial loss amount before any recoveries or offsets.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceClaimNumber rdf:type rdf:Property ;
    rdfs:label 'Insurance Claim Number' ;
    rdfs:comment 'Reference number for any insurance claim filed to recover the fraud loss.' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceRecoveryAmount rdf:type rdf:Property ;
    rdfs:label 'Insurance Recovery Amount' ;
    rdfs:comment 'The amount recovered specifically through insurance claims, if applicable.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:legalCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Legal Case Number' ;
    rdfs:comment 'Reference number for any legal proceedings or litigation related to the fraud loss recovery.' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lossCategory rdf:type rdf:Property ;
    rdfs:label 'Loss Category' ;
    rdfs:comment 'Classification of the fraud loss by type or origin, aligned with operational risk taxonomy.' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lossDate rdf:type rdf:Property ;
    rdfs:label 'Loss Date' ;
    rdfs:comment 'The date when the fraud loss event occurred or was realized.' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lossDescription rdf:type rdf:Property ;
    rdfs:label 'Loss Description' ;
    rdfs:comment 'Detailed narrative description of the fraud loss event, including circumstances, impact, and any relevant context.' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lossStatus rdf:type rdf:Property ;
    rdfs:label 'Loss Status' ;
    rdfs:comment 'Current status of the fraud loss in the recovery and accounting lifecycle.' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netLossAmount rdf:type rdf:Property ;
    rdfs:label 'Net Loss Amount' ;
    rdfs:comment 'The net financial loss after deducting all recoveries from the gross loss amount (gross_loss_amount minus recovery_amount).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recoveryMethod rdf:type rdf:Property ;
    rdfs:label 'Recovery Method' ;
    rdfs:comment 'The primary method used to recover funds from the fraud loss event.' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recoveryNotes rdf:type rdf:Property ;
    rdfs:label 'Recovery Notes' ;
    rdfs:comment 'Free-text notes documenting recovery efforts, outcomes, and any challenges encountered during the recovery process.' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:writeOffApprovalAuthority rdf:type rdf:Property ;
    rdfs:label 'Write Off Approval Authority' ;
    rdfs:comment 'The name or title of the authority who approved the write-off of the unrecovered fraud loss.' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:writeOffDate rdf:type rdf:Property ;
    rdfs:label 'Write Off Date' ;
    rdfs:comment 'The date when the unrecovered portion of the fraud loss was written off as uncollectible.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rulePerformanceId rdf:type rdf:Property ;
    rdfs:label 'Rule Performance Id' ;
    rdfs:comment 'Unique identifier for the fraud rule performance measurement record.' ;
    rdfs:domain ind:RulePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryRuleEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Rule Employee Id' ;
    rdfs:comment 'Identifier of the fraud analyst or data scientist who performed the rule tuning.' ;
    rdfs:domain ind:RulePerformance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:alertReviewTimeAvgMinutes rdf:type rdf:Property ;
    rdfs:label 'Alert Review Time Avg Minutes' ;
    rdfs:comment 'Average time in minutes required for analysts to review and disposition alerts from this rule.' ;
    rdfs:domain ind:RulePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageFraudLossPerAlert rdf:type rdf:Property ;
    rdfs:label 'Average Fraud Loss Per Alert' ;
    rdfs:comment 'Mean fraud loss amount per true positive alert generated by this rule.' ;
    rdfs:domain ind:RulePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentThresholdValue rdf:type rdf:Property ;
    rdfs:label 'Current Threshold Value' ;
    rdfs:comment 'The threshold value after tuning adjustment was applied.' ;
    rdfs:domain ind:RulePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:detectionRate rdf:type rdf:Property ;
    rdfs:label 'Detection Rate' ;
    rdfs:comment 'Overall effectiveness of the rule in identifying fraud, expressed as a percentage of total fraud cases detected.' ;
    rdfs:domain ind:RulePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:effectivenessScore rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Score' ;
    rdfs:comment 'Composite score measuring overall rule effectiveness, balancing detection rate and false positive rate.' ;
    rdfs:domain ind:RulePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:falseNegativeCount rdf:type rdf:Property ;
    rdfs:label 'False Negative Count' ;
    rdfs:comment 'Number of actual fraud cases that the rule failed to detect.' ;
    rdfs:domain ind:RulePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:falsePositiveCount rdf:type rdf:Property ;
    rdfs:label 'False Positive Count' ;
    rdfs:comment 'Number of alerts that were determined to be legitimate activity, not fraud.' ;
    rdfs:domain ind:RulePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:measurementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Measurement Timestamp' ;
    rdfs:comment 'Timestamp when the performance metrics were calculated and recorded.' ;
    rdfs:domain ind:RulePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:precision rdf:type rdf:Property ;
    rdfs:label 'Precision' ;
    rdfs:comment 'Proportion of alerts that were actual fraud cases. Calculated as true positives divided by total alerts generated.' ;
    rdfs:domain ind:RulePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:previousThresholdValue rdf:type rdf:Property ;
    rdfs:label 'Previous Threshold Value' ;
    rdfs:comment 'The threshold value before tuning adjustment was applied.' ;
    rdfs:domain ind:RulePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sarEscalationRate rdf:type rdf:Property ;
    rdfs:label 'Sar Escalation Rate' ;
    rdfs:comment 'Proportion of alerts that resulted in Suspicious Activity Report filings to FinCEN.' ;
    rdfs:domain ind:RulePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalFraudLossDetected rdf:type rdf:Property ;
    rdfs:label 'Total Fraud Loss Detected' ;
    rdfs:comment 'Total monetary value of fraud losses identified by this rule during the measurement period.' ;
    rdfs:domain ind:RulePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trueNegativeCount rdf:type rdf:Property ;
    rdfs:label 'True Negative Count' ;
    rdfs:comment 'Number of transactions correctly identified as non-fraudulent by the rule.' ;
    rdfs:domain ind:RulePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:truePositiveCount rdf:type rdf:Property ;
    rdfs:label 'True Positive Count' ;
    rdfs:comment 'Number of alerts that were confirmed as actual fraud cases.' ;
    rdfs:domain ind:RulePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tuningActionTaken rdf:type rdf:Property ;
    rdfs:label 'Tuning Action Taken' ;
    rdfs:comment 'Type of tuning adjustment made to the rule based on performance analysis.' ;
    rdfs:domain ind:RulePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tuningDate rdf:type rdf:Property ;
    rdfs:label 'Tuning Date' ;
    rdfs:comment 'Date when the rule was tuned or adjusted based on performance metrics.' ;
    rdfs:domain ind:RulePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:subjectId rdf:type rdf:Property ;
    rdfs:label 'Subject Id' ;
    rdfs:comment 'Unique identifier for the fraud subject entity. Primary key.' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Subject .

ind:associatedAccountNumbers rdf:type rdf:Property ;
    rdfs:label 'Associated Account Numbers' ;
    rdfs:comment 'Comma-separated list of bank account numbers associated with the fraud subject including mule accounts and compromised accounts.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:associatedDeviceIds rdf:type rdf:Property ;
    rdfs:label 'Associated Device Ids' ;
    rdfs:comment 'Comma-separated list of device identifiers such as IMEI, MAC addresses, or device fingerprints linked to the fraud subject.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:associatedIpAddresses rdf:type rdf:Property ;
    rdfs:label 'Associated Ip Addresses' ;
    rdfs:comment 'Comma-separated list of IP addresses used by the fraud subject during fraudulent activities.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:driversLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Drivers License Number' ;
    rdfs:comment 'Drivers license number of the fraud subject used for identity verification.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstIdentifiedDate rdf:type rdf:Property ;
    rdfs:label 'First Identified Date' ;
    rdfs:comment 'Date when the fraud subject was first identified in the fraud management system.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:firstName rdf:type rdf:Property ;
    rdfs:label 'First Name' ;
    rdfs:comment 'First name or given name of the fraud subject.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:knownAliases rdf:type rdf:Property ;
    rdfs:label 'Known Aliases' ;
    rdfs:comment 'Comma-separated list of known aliases, alternate names, or pseudonyms used by the fraud subject.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastName rdf:type rdf:Property ;
    rdfs:label 'Last Name' ;
    rdfs:comment 'Last name or surname of the fraud subject.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lawEnforcementReferralDate rdf:type rdf:Property ;
    rdfs:label 'Law Enforcement Referral Date' ;
    rdfs:comment 'Date when the fraud subject was referred to law enforcement.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:middleName rdf:type rdf:Property ;
    rdfs:label 'Middle Name' ;
    rdfs:comment 'Middle name or initial of the fraud subject if available.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorFraudCaseCount rdf:type rdf:Property ;
    rdfs:label 'Prior Fraud Case Count' ;
    rdfs:comment 'Number of prior fraud cases in which this subject has been identified or implicated.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:riskTier rdf:type rdf:Property ;
    rdfs:label 'Risk Tier' ;
    rdfs:comment 'Risk tier classification of the fraud subject based on risk score and threat assessment.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectStatus rdf:type rdf:Property ;
    rdfs:label 'Subject Status' ;
    rdfs:comment 'Current status of the fraud subject in the fraud management system indicating their investigation or monitoring state.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectType rdf:type rdf:Property ;
    rdfs:label 'Subject Type' ;
    rdfs:comment 'Classification of the fraud subject indicating their relationship to the bank: internal employee, external third party, customer, organized fraud ring member, mule account holder, or unknown.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalConfirmedLossAmount rdf:type rdf:Property ;
    rdfs:label 'Total Confirmed Loss Amount' ;
    rdfs:comment 'Cumulative confirmed financial loss across all fraud cases involving this subject.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalEstimatedLossAmount rdf:type rdf:Property ;
    rdfs:label 'Total Estimated Loss Amount' ;
    rdfs:comment 'Cumulative estimated financial loss across all fraud cases involving this subject.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:watchlistStatus rdf:type rdf:Property ;
    rdfs:label 'Watchlist Status' ;
    rdfs:comment 'Indicates whether the fraud subject is on any internal or external watchlist including law enforcement, industry fraud databases, or sanctions lists.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attackVector rdf:type rdf:Property ;
    rdfs:label 'Attack Vector' ;
    rdfs:comment 'Primary method or technique used by fraudsters to execute this typology (e.g., phishing, social engineering, malware, credential stuffing, SIM swap, insider collusion).' ;
    rdfs:domain ind:Typology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageLossAmount rdf:type rdf:Property ;
    rdfs:label 'Average Loss Amount' ;
    rdfs:comment 'Mean financial loss per incident for this fraud typology based on historical case data. Used for risk quantification and capital allocation under operational risk frameworks.' ;
    rdfs:domain ind:Typology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chargebackEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Chargeback Eligible Flag' ;
    rdfs:comment 'Indicates whether this fraud typology is eligible for chargeback recovery through card network dispute processes (applicable primarily to card fraud typologies).' ;
    rdfs:domain ind:Typology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crossBorderIndicator rdf:type rdf:Property ;
    rdfs:label 'Cross Border Indicator' ;
    rdfs:comment 'Indicates whether this fraud typology typically involves cross-border transactions or international actors, requiring coordination with foreign law enforcement or financial intelligence units.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerReimbursementPolicy rdf:type rdf:Property ;
    rdfs:label 'Customer Reimbursement Policy' ;
    rdfs:comment 'Standard policy for customer reimbursement when this fraud typology occurs. Reflects regulatory requirements (e.g., Regulation E for unauthorized electronic transfers) and bank policy.' ;
    rdfs:domain ind:Typology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionDifficultyScore rdf:type rdf:Property ;
    rdfs:label 'Detection Difficulty Score' ;
    rdfs:comment 'Numeric score (1-10) representing the difficulty of detecting this fraud typology, where 1 is easily detected and 10 is extremely difficult. Used for control effectiveness assessment and resource allocation.' ;
    rdfs:domain ind:Typology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:detectionMethodPrimary rdf:type rdf:Property ;
    rdfs:label 'Detection Method Primary' ;
    rdfs:comment 'Most effective detection method or control for identifying this fraud typology (e.g., transaction monitoring rule, machine learning model, customer report, manual review, third-party alert).' ;
    rdfs:domain ind:Typology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionMethodSecondary rdf:type rdf:Property ;
    rdfs:label 'Detection Method Secondary' ;
    rdfs:comment 'Alternative or supplementary detection method used to identify this fraud typology. Supports layered defense strategy.' ;
    rdfs:domain ind:Typology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentVolume12m rdf:type rdf:Property ;
    rdfs:label 'Incident Volume 12m' ;
    rdfs:comment 'Total number of confirmed fraud incidents of this typology in the trailing 12 months. Key performance indicator for fraud risk monitoring.' ;
    rdfs:domain ind:Typology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:industryPrevalenceRank rdf:type rdf:Property ;
    rdfs:label 'Industry Prevalence Rank' ;
    rdfs:comment 'Ranking of this fraud typology by prevalence across the banking industry (1 = most common). Based on industry reports and peer benchmarking.' ;
    rdfs:domain ind:Typology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:insuranceCoverageFlag rdf:type rdf:Property ;
    rdfs:label 'Insurance Coverage Flag' ;
    rdfs:comment 'Indicates whether losses from this fraud typology are covered under the banks fidelity bond, cyber insurance, or other insurance policies.' ;
    rdfs:domain ind:Typology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lawEnforcementReferralRecommendedFlag rdf:type rdf:Property ;
    rdfs:label 'Law Enforcement Referral Recommended Flag' ;
    rdfs:comment 'Indicates whether incidents of this fraud typology should be routinely referred to law enforcement based on severity, organized crime indicators, or regulatory expectations.' ;
    rdfs:domain ind:Typology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maximumObservedLoss rdf:type rdf:Property ;
    rdfs:label 'Maximum Observed Loss' ;
    rdfs:comment 'Largest single loss amount recorded for this fraud typology. Used for tail risk assessment and stress testing.' ;
    rdfs:domain ind:Typology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:medianLossAmount rdf:type rdf:Property ;
    rdfs:label 'Median Loss Amount' ;
    rdfs:comment 'Median financial loss per incident for this fraud typology. Provides a more robust central tendency measure when loss distributions are skewed.' ;
    rdfs:domain ind:Typology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:organizedCrimeIndicator rdf:type rdf:Property ;
    rdfs:label 'Organized Crime Indicator' ;
    rdfs:comment 'Indicates whether this fraud typology is commonly associated with organized fraud rings or criminal enterprises rather than individual opportunistic actors.' ;
    rdfs:domain ind:Typology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preventionControlPrimary rdf:type rdf:Property ;
    rdfs:label 'Prevention Control Primary' ;
    rdfs:comment 'Most effective preventive control or countermeasure for this fraud typology (e.g., multi-factor authentication, velocity limits, device fingerprinting, customer education, enhanced due diligence).' ;
    rdfs:domain ind:Typology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preventionControlSecondary rdf:type rdf:Property ;
    rdfs:label 'Prevention Control Secondary' ;
    rdfs:comment 'Supplementary preventive control providing defense-in-depth against this fraud typology.' ;
    rdfs:domain ind:Typology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recoveryRatePercent rdf:type rdf:Property ;
    rdfs:label 'Recovery Rate Percent' ;
    rdfs:comment 'Historical percentage of losses recovered through chargeback, insurance, legal action, or other means for this fraud typology. Used for net loss forecasting.' ;
    rdfs:domain ind:Typology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:riskSeverityTier rdf:type rdf:Property ;
    rdfs:label 'Risk Severity Tier' ;
    rdfs:comment 'Enterprise risk classification tier for this fraud typology based on potential financial impact, reputational damage, and regulatory exposure.' ;
    rdfs:domain ind:Typology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sarFilingThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Sar Filing Threshold Amount' ;
    rdfs:comment 'Minimum loss amount that triggers mandatory SAR filing for this fraud typology. Typically $5,000 for most fraud types per FinCEN guidance, but may vary by typology.' ;
    rdfs:domain ind:Typology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sophisticationLevel rdf:type rdf:Property ;
    rdfs:label 'Sophistication Level' ;
    rdfs:comment 'Assessment of the technical and operational sophistication required by fraudsters to execute this typology. Informs threat intelligence and control design.' ;
    rdfs:domain ind:Typology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetChannel rdf:type rdf:Property ;
    rdfs:label 'Target Channel' ;
    rdfs:comment 'Primary banking channel or touchpoint targeted by this fraud typology (e.g., online banking, mobile app, ATM, branch, call center, wire transfer system).' ;
    rdfs:domain ind:Typology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetProductLine rdf:type rdf:Property ;
    rdfs:label 'Target Product Line' ;
    rdfs:comment 'Banking product or service line most commonly targeted by this fraud typology (e.g., deposit accounts, credit cards, commercial lending, wealth management, payment services).' ;
    rdfs:domain ind:Typology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalLossAmount12m rdf:type rdf:Property ;
    rdfs:label 'Total Loss Amount 12m' ;
    rdfs:comment 'Aggregate confirmed loss amount for this fraud typology in the trailing 12 months. Used for operational risk capital calculation and management reporting.' ;
    rdfs:domain ind:Typology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trendDirection rdf:type rdf:Property ;
    rdfs:label 'Trend Direction' ;
    rdfs:comment 'Current trend direction for incident volume and loss amounts for this fraud typology based on recent historical analysis. Used for strategic planning and resource allocation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typologyCategory rdf:type rdf:Property ;
    rdfs:label 'Typology Category' ;
    rdfs:comment 'High-level classification grouping of the fraud typology for strategic analysis and reporting. [ENUM-REF-CANDIDATE: card_fraud|account_fraud|wire_fraud|ach_fraud|check_fraud|identity_theft|internal_fraud|cyber_fraud|loan_fraud|deposit_fraud — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Typology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typologyCode rdf:type rdf:Property ;
    rdfs:label 'Typology Code' ;
    rdfs:comment 'Standardized short code identifying the fraud typology (e.g., ACH-FRAUD, CARD-CNP, WIRE-BEC). Used for system integration and reporting.' ;
    rdfs:domain ind:Typology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typologyDescription rdf:type rdf:Property ;
    rdfs:label 'Typology Description' ;
    rdfs:comment 'Comprehensive business description of the fraud typology including typical modus operandi, victim profile, and distinguishing characteristics. Used for investigator training and case classification.' ;
    rdfs:domain ind:Typology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typologyName rdf:type rdf:Property ;
    rdfs:label 'Typology Name' ;
    rdfs:comment 'Full business name of the fraud typology (e.g., Account Takeover, Business Email Compromise, Card Not Present Fraud).' ;
    rdfs:domain ind:Typology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typologyStatus rdf:type rdf:Property ;
    rdfs:label 'Typology Status' ;
    rdfs:comment 'Current lifecycle status of this fraud typology classification in the banks taxonomy. Deprecated typologies are retained for historical analysis but not used for new cases.' ;
    rdfs:domain ind:Typology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudWatchlistId rdf:type rdf:Property ;
    rdfs:label 'Fraud Watchlist Id' ;
    rdfs:comment 'Unique identifier for the fraud watchlist entry.' ;
    rdfs:domain ind:FraudWatchlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fraudSubjectId rdf:type rdf:Property ;
    rdfs:label 'Fraud Subject Id' ;
    rdfs:comment 'Foreign key linking to fraud.subject. Business justification: A watchlist entry can be for a specific fraud subject (individual or entity under investigation). N:1 relationship. No bidirectional conflict (subject does not have fraud_watchlist_id FK back). Watchl' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Subject .

ind:originatingCaseId rdf:type rdf:Property ;
    rdfs:label 'Originating Case Id' ;
    rdfs:comment 'Reference to the fraud case investigation that resulted in this watchlist entry being created.' ;
    rdfs:domain ind:FraudWatchlist ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Case .

ind:primaryFraudEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Fraud Employee Id' ;
    rdfs:comment 'Identifier of the fraud analyst or system user who created this watchlist entry.' ;
    rdfs:domain ind:FraudWatchlist ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryFraudUpdatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Fraud Updated By User Employee Id' ;
    rdfs:comment 'Identifier of the user or system process that last updated this watchlist record.' ;
    rdfs:domain ind:FraudWatchlist ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actionTier rdf:type rdf:Property ;
    rdfs:label 'Action Tier' ;
    rdfs:comment 'Operational action to be taken when this watchlist entry is matched: monitor only (log and alert), enhanced authentication required (step-up verification), transaction restrict (limit transaction types or amounts), or hard block (prevent all activity).' ;
    rdfs:domain ind:FraudWatchlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryDate rdf:type rdf:Property ;
    rdfs:label 'Entry Date' ;
    rdfs:comment 'Date when the entity was added to the fraud watchlist.' ;
    rdfs:domain ind:FraudWatchlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:entryNumber rdf:type rdf:Property ;
    rdfs:label 'Entry Number' ;
    rdfs:comment 'Business-facing unique identifier for the watchlist entry, formatted as WL- followed by 10 digits.' ;
    rdfs:domain ind:FraudWatchlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryType rdf:type rdf:Property ;
    rdfs:label 'Entry Type' ;
    rdfs:comment 'Type of entity being watchlisted: customer (individual or corporate party), account number, device fingerprint, merchant ID, IP address range, or BIN (Bank Identification Number) range.' ;
    rdfs:domain ind:FraudWatchlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industrySharingFlag rdf:type rdf:Property ;
    rdfs:label 'Industry Sharing Flag' ;
    rdfs:comment 'Indicates whether this watchlist entry has been shared with industry fraud consortiums or information sharing networks.' ;
    rdfs:domain ind:FraudWatchlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastMatchTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Match Timestamp' ;
    rdfs:comment 'Timestamp of the most recent transaction or event that matched this watchlist entry during screening.' ;
    rdfs:domain ind:FraudWatchlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:matchCount rdf:type rdf:Property ;
    rdfs:label 'Match Count' ;
    rdfs:comment 'Number of times this watchlist entry has been matched during real-time transaction screening or account opening risk assessment since it was added.' ;
    rdfs:domain ind:FraudWatchlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:removalDate rdf:type rdf:Property ;
    rdfs:label 'Removal Date' ;
    rdfs:comment 'Date when the watchlist entry was removed from active status.' ;
    rdfs:domain ind:FraudWatchlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:removalReason rdf:type rdf:Property ;
    rdfs:label 'Removal Reason' ;
    rdfs:comment 'Explanation for why the watchlist entry was removed or expired, including false positive determination, case closure, or time-based expiration.' ;
    rdfs:domain ind:FraudWatchlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severityScore rdf:type rdf:Property ;
    rdfs:label 'Severity Score' ;
    rdfs:comment 'Numeric score (1-100) representing the severity and risk level of the fraud associated with this watchlist entry, with higher scores indicating greater risk.' ;
    rdfs:domain ind:FraudWatchlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sharingNetwork rdf:type rdf:Property ;
    rdfs:label 'Sharing Network' ;
    rdfs:comment 'Name of the fraud information sharing network or consortium where this watchlist entry was shared or received from (e.g., FS-ISAC, regional banking fraud networks).' ;
    rdfs:domain ind:FraudWatchlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:watchlistedValue rdf:type rdf:Property ;
    rdfs:label 'Watchlisted Value' ;
    rdfs:comment 'The actual value being watchlisted (e.g., customer ID, account number, device hash, merchant identifier, IP range CIDR, BIN range). Format varies by entry_type.' ;
    rdfs:domain ind:FraudWatchlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:investigationId rdf:type rdf:Property ;
    rdfs:label 'Investigation Id' ;
    rdfs:comment 'Primary key for investigation' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:evidenceInteractionId rdf:type rdf:Property ;
    rdfs:label 'Evidence Interaction Id' ;
    rdfs:comment 'Foreign key linking to channel.interaction. Business justification: Fraud investigations collect interaction records as evidence. Linking enables audit trail reconstruction, regulatory exam support (demonstrating transaction monitoring controls), litigation evidence p' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Interaction .

ind:evidenceSessionId rdf:type rdf:Property ;
    rdfs:label 'Evidence Session Id' ;
    rdfs:comment 'Foreign key linking to channel.session. Business justification: Fraud investigations collect session data as evidence. Linking enables chain-of-custody tracking, legal hold management, courtroom evidence presentation, regulatory exam support, and forensic timeline' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Session .

ind:investigationAssignedInvestigatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Investigation Assigned Investigator Employee Id' ;
    rdfs:comment 'Employee identifier of the fraud investigator currently assigned to this investigation. Links to the Human Capital Management system employee master.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:investigationLastModifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Investigation Last Modified By Employee Id' ;
    rdfs:comment 'Employee identifier of the user who last modified the investigation record. Links to the Human Capital Management system employee master.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:previousInvestigationId rdf:type rdf:Property ;
    rdfs:label 'Previous Investigation Id' ;
    rdfs:comment 'Reference to the preceding investigation phase in a multi-phase investigation workflow. Null for initial investigation phase.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Investigation .

ind:evidenceItemsCount rdf:type rdf:Property ;
    rdfs:label 'Evidence Items Count' ;
    rdfs:comment 'Total number of evidence items collected and catalogued during this investigation (e.g., transaction records, device logs, interview transcripts, surveillance footage).' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:evidenceSummary rdf:type rdf:Property ;
    rdfs:label 'Evidence Summary' ;
    rdfs:comment 'High-level summary of key evidence gathered during the investigation. Used for case review and escalation briefings.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingsNarrative rdf:type rdf:Property ;
    rdfs:label 'Findings Narrative' ;
    rdfs:comment 'Detailed narrative of investigation findings, analysis, and conclusions. Forms the basis for disposition recommendations and SAR (Suspicious Activity Report) narratives.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudLossAmount rdf:type rdf:Property ;
    rdfs:label 'Fraud Loss Amount' ;
    rdfs:comment 'Total monetary loss attributed to the fraud as determined by the investigation. Expressed in the banks base currency.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fraudLossCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Fraud Loss Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the fraud loss amount.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interviewConductedFlag rdf:type rdf:Property ;
    rdfs:label 'Interview Conducted Flag' ;
    rdfs:comment 'Indicates whether a formal customer or witness interview was conducted as part of this investigation.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interviewNotes rdf:type rdf:Property ;
    rdfs:label 'Interview Notes' ;
    rdfs:comment 'Summary notes from customer or witness interviews conducted during the investigation. May include key statements, admissions, or denials.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationNumber rdf:type rdf:Property ;
    rdfs:label 'Investigation Number' ;
    rdfs:comment 'Business-facing unique investigation identifier used for tracking and reporting. Typically system-generated with prefix INV- followed by numeric sequence.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationStatus rdf:type rdf:Property ;
    rdfs:label 'Investigation Status' ;
    rdfs:comment 'Current operational status of the investigation within its phase. Indicates whether the investigation is actively being worked, pending review, escalated, or completed.' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:methodology rdf:type rdf:Property ;
    rdfs:label 'Methodology' ;
    rdfs:comment 'Primary investigative approach or technique applied during this investigation phase. May include transaction pattern analysis, device fingerprinting, customer interviews, video surveillance review, or third-party data correlation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:multiPhaseInvestigationFlag rdf:type rdf:Property ;
    rdfs:label 'Multi Phase Investigation Flag' ;
    rdfs:comment 'Indicates whether this investigation is part of a multi-phase investigation requiring sequential stages with different investigators or specialized skill sets.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:phase rdf:type rdf:Property ;
    rdfs:label 'Phase' ;
    rdfs:comment 'Current phase of the investigation workflow. Tracks progression from initial review through deep investigation, potential legal referral, SAR (Suspicious Activity Report) escalation, or closure.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendedDisposition rdf:type rdf:Property ;
    rdfs:label 'Recommended Disposition' ;
    rdfs:comment 'Investigators recommended outcome or disposition for the case based on investigation findings. Determines next steps including SAR filing, legal action, or case closure.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:team rdf:type rdf:Property ;
    rdfs:label 'Team' ;
    rdfs:comment 'Name or code of the specialized fraud investigation team handling this case (e.g., Card Fraud Unit, Wire Fraud Unit, AML Investigation Team).' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lawEnforcementReferralId rdf:type rdf:Property ;
    rdfs:label 'Law Enforcement Referral Id' ;
    rdfs:comment 'Unique identifier for the law enforcement referral record.' ;
    rdfs:domain ind:LawEnforcementReferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryLawBankLiaisonEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Law Bank Liaison Employee Id' ;
    rdfs:comment 'Employee identifier of the bank liaison responsible for coordinating this referral.' ;
    rdfs:domain ind:LawEnforcementReferral ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:acknowledgmentReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Received Date' ;
    rdfs:comment 'Date when acknowledgment of receipt was received from the law enforcement agency.' ;
    rdfs:domain ind:LawEnforcementReferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:agencyCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Agency Case Number' ;
    rdfs:comment 'Case number or reference identifier assigned by the receiving law enforcement agency.' ;
    rdfs:domain ind:LawEnforcementReferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyContactEmail rdf:type rdf:Property ;
    rdfs:label 'Agency Contact Email' ;
    rdfs:comment 'Email address of the law enforcement contact for this referral.' ;
    rdfs:domain ind:LawEnforcementReferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyContactName rdf:type rdf:Property ;
    rdfs:label 'Agency Contact Name' ;
    rdfs:comment 'Name of the law enforcement officer or agent who is the primary contact for this referral.' ;
    rdfs:domain ind:LawEnforcementReferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyContactPhone rdf:type rdf:Property ;
    rdfs:label 'Agency Contact Phone' ;
    rdfs:comment 'Phone number of the law enforcement contact for this referral.' ;
    rdfs:domain ind:LawEnforcementReferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankLiaisonEmail rdf:type rdf:Property ;
    rdfs:label 'Bank Liaison Email' ;
    rdfs:comment 'Email address of the bank liaison for law enforcement coordination.' ;
    rdfs:domain ind:LawEnforcementReferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankLiaisonName rdf:type rdf:Property ;
    rdfs:label 'Bank Liaison Name' ;
    rdfs:comment 'Name of the bank employee serving as the primary liaison for this law enforcement referral.' ;
    rdfs:domain ind:LawEnforcementReferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankLiaisonPhone rdf:type rdf:Property ;
    rdfs:label 'Bank Liaison Phone' ;
    rdfs:comment 'Phone number of the bank liaison for law enforcement coordination.' ;
    rdfs:domain ind:LawEnforcementReferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedDate rdf:type rdf:Property ;
    rdfs:label 'Closed Date' ;
    rdfs:comment 'Date when the law enforcement referral was formally closed.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evidencePackageReference rdf:type rdf:Property ;
    rdfs:label 'Evidence Package Reference' ;
    rdfs:comment 'Reference identifier for the evidence package or documentation bundle submitted with this referral.' ;
    rdfs:domain ind:LawEnforcementReferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceSubmissionMethod rdf:type rdf:Property ;
    rdfs:label 'Evidence Submission Method' ;
    rdfs:comment 'Method used to transmit evidence and documentation to the law enforcement agency.' ;
    rdfs:domain ind:LawEnforcementReferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationOutcome rdf:type rdf:Property ;
    rdfs:label 'Investigation Outcome' ;
    rdfs:comment 'Final outcome of the law enforcement investigation resulting from this referral. [ENUM-REF-CANDIDATE: arrest_made|charges_filed|case_declined|investigation_ongoing|case_closed_no_action|prosecution_successful|prosecution_unsuccessful|restitution_ordered|plea_agreement|trial_verdict — promote to reference product]' ;
    rdfs:domain ind:LawEnforcementReferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationStatusUpdate rdf:type rdf:Property ;
    rdfs:label 'Investigation Status Update' ;
    rdfs:comment 'Latest status update received from law enforcement regarding their investigation.' ;
    rdfs:domain ind:LawEnforcementReferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalObligationFlag rdf:type rdf:Property ;
    rdfs:label 'Legal Obligation Flag' ;
    rdfs:comment 'Indicates whether this referral is made under a legal or regulatory obligation (True) or is voluntary (False).' ;
    rdfs:domain ind:LawEnforcementReferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:prosecutionInitiatedFlag rdf:type rdf:Property ;
    rdfs:label 'Prosecution Initiated Flag' ;
    rdfs:comment 'Indicates whether criminal prosecution was initiated as a result of this referral.' ;
    rdfs:domain ind:LawEnforcementReferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receivingAgencyName rdf:type rdf:Property ;
    rdfs:label 'Receiving Agency Name' ;
    rdfs:comment 'Name of the law enforcement agency receiving the referral (e.g., FBI, Secret Service, local police department).' ;
    rdfs:domain ind:LawEnforcementReferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingAgencyType rdf:type rdf:Property ;
    rdfs:label 'Receiving Agency Type' ;
    rdfs:comment 'Classification of the law enforcement agency by jurisdictional level.' ;
    rdfs:domain ind:LawEnforcementReferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralDate rdf:type rdf:Property ;
    rdfs:label 'Referral Date' ;
    rdfs:comment 'Date when the referral was formally submitted to the law enforcement agency.' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:referralNumber rdf:type rdf:Property ;
    rdfs:label 'Referral Number' ;
    rdfs:comment 'Business identifier for the law enforcement referral, used for external communication and tracking.' ;
    rdfs:domain ind:LawEnforcementReferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralPriority rdf:type rdf:Property ;
    rdfs:label 'Referral Priority' ;
    rdfs:comment 'Priority level assigned to this law enforcement referral based on severity and urgency.' ;
    rdfs:domain ind:LawEnforcementReferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralReason rdf:type rdf:Property ;
    rdfs:label 'Referral Reason' ;
    rdfs:comment 'Detailed explanation of why this case is being referred to law enforcement.' ;
    rdfs:domain ind:LawEnforcementReferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralStatus rdf:type rdf:Property ;
    rdfs:label 'Referral Status' ;
    rdfs:comment 'Current lifecycle status of the law enforcement referral.' ;
    rdfs:domain ind:LawEnforcementReferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralTimestamp rdf:type rdf:Property ;
    rdfs:label 'Referral Timestamp' ;
    rdfs:comment 'Precise timestamp when the referral was submitted to the law enforcement agency.' ;
    rdfs:domain ind:LawEnforcementReferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:referralType rdf:type rdf:Property ;
    rdfs:label 'Referral Type' ;
    rdfs:comment 'Classification of the type of law enforcement referral being made.' ;
    rdfs:domain ind:LawEnforcementReferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restitutionAmount rdf:type rdf:Property ;
    rdfs:label 'Restitution Amount' ;
    rdfs:comment 'Amount of restitution ordered by the court as a result of prosecution stemming from this referral.' ;
    rdfs:domain ind:LawEnforcementReferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:restitutionReceivedAmount rdf:type rdf:Property ;
    rdfs:label 'Restitution Received Amount' ;
    rdfs:comment 'Amount of court-ordered restitution actually received by the bank.' ;
    rdfs:domain ind:LawEnforcementReferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:subpoenaNumber rdf:type rdf:Property ;
    rdfs:label 'Subpoena Number' ;
    rdfs:comment 'Official number or identifier of the subpoena if this referral is in response to a subpoena.' ;
    rdfs:domain ind:LawEnforcementReferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subpoenaReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Subpoena Received Date' ;
    rdfs:comment 'Date when the subpoena was received by the bank.' ;
    rdfs:domain ind:LawEnforcementReferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:subpoenaReceivedFlag rdf:type rdf:Property ;
    rdfs:label 'Subpoena Received Flag' ;
    rdfs:comment 'Indicates whether this referral was triggered by receipt of a subpoena from law enforcement.' ;
    rdfs:domain ind:LawEnforcementReferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lossRecoveryId rdf:type rdf:Property ;
    rdfs:label 'Loss Recovery Id' ;
    rdfs:comment 'Unique identifier for the loss recovery record. Primary key for the loss recovery entity.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LossRecovery .

ind:lossDiscoveryDate rdf:type rdf:Property ;
    rdfs:label 'Loss Discovery Date' ;
    rdfs:comment 'The date when the fraud loss was first discovered or detected by the institution.' ;
    rdfs:domain ind:LossRecovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lossEventNumber rdf:type rdf:Property ;
    rdfs:label 'Loss Event Number' ;
    rdfs:comment 'Business-readable unique identifier for the loss event, typically formatted as business-line prefix, year, and sequence number.' ;
    rdfs:domain ind:LossRecovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recoveryStatus rdf:type rdf:Property ;
    rdfs:label 'Recovery Status' ;
    rdfs:comment 'Current status of recovery efforts for this loss event. Tracks the lifecycle from initial pursuit through final disposition.' ;
    rdfs:domain ind:LossRecovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkLinkId rdf:type rdf:Property ;
    rdfs:label 'Network Link Id' ;
    rdfs:comment 'Primary key for network_link' ;
    rdfs:domain ind:NetworkLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceFraudCaseId rdf:type rdf:Property ;
    rdfs:label 'Source Fraud Case Id' ;
    rdfs:comment 'Identifier of the primary fraud case that led to the discovery of this network link. Links the relationship to the originating investigation.' ;
    rdfs:domain ind:NetworkLink ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Case .

ind:sourceSubjectId rdf:type rdf:Property ;
    rdfs:label 'Source Subject Id' ;
    rdfs:comment 'Identifier of the originating fraud subject, account, device, or entity in the network relationship. References the source node in the fraud network graph.' ;
    rdfs:domain ind:NetworkLink ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Subject .

ind:targetSubjectId rdf:type rdf:Property ;
    rdfs:label 'Target Subject Id' ;
    rdfs:comment 'Identifier of the destination fraud subject, account, device, or entity in the network relationship. References the target node in the fraud network graph.' ;
    rdfs:domain ind:NetworkLink ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Subject .

ind:bidirectionalFlag rdf:type rdf:Property ;
    rdfs:label 'Bidirectional Flag' ;
    rdfs:comment 'Indicates whether the network link represents a bidirectional relationship (true) or a unidirectional relationship (false). Bidirectional links suggest mutual coordination.' ;
    rdfs:domain ind:NetworkLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:confirmationDate rdf:type rdf:Property ;
    rdfs:label 'Confirmation Date' ;
    rdfs:comment 'Date when the network link was validated and confirmed by an analyst as a legitimate fraud relationship.' ;
    rdfs:domain ind:NetworkLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:discoveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Discovery Timestamp' ;
    rdfs:comment 'Precise timestamp when the network link was first identified, including time-of-day for audit trail and temporal analysis purposes.' ;
    rdfs:domain ind:NetworkLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:firstObservedDate rdf:type rdf:Property ;
    rdfs:label 'First Observed Date' ;
    rdfs:comment 'Earliest date when the relationship between the linked subjects was first observed in transaction or behavioral data, prior to formal discovery.' ;
    rdfs:domain ind:NetworkLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:graphVisualizationMetadata rdf:type rdf:Property ;
    rdfs:label 'Graph Visualization Metadata' ;
    rdfs:comment 'JSON or XML metadata used by graph analytics platforms for network topology visualization, including node positioning, edge styling, and clustering information.' ;
    rdfs:domain ind:NetworkLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationPriority rdf:type rdf:Property ;
    rdfs:label 'Investigation Priority' ;
    rdfs:comment 'Priority level assigned to the investigation of this network link based on risk score, potential loss exposure, and regulatory urgency.' ;
    rdfs:domain ind:NetworkLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastObservedDate rdf:type rdf:Property ;
    rdfs:label 'Last Observed Date' ;
    rdfs:comment 'Most recent date when the relationship between the linked subjects was observed in transaction or behavioral data, used to assess ongoing activity.' ;
    rdfs:domain ind:NetworkLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:linkEvidenceDescription rdf:type rdf:Property ;
    rdfs:label 'Link Evidence Description' ;
    rdfs:comment 'Detailed narrative describing the specific evidence supporting the network link, including data points, patterns, and investigative findings used for SAR narratives and law enforcement referrals.' ;
    rdfs:domain ind:NetworkLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Link Expiration Date' ;
    rdfs:comment 'Date when the network link is scheduled to expire or be archived if no further activity is observed. Used for data retention and case closure workflows.' ;
    rdfs:domain ind:NetworkLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:linkStatus rdf:type rdf:Property ;
    rdfs:label 'Link Status' ;
    rdfs:comment 'Current lifecycle status of the network link indicating whether the relationship is actively monitored, confirmed, or has been resolved.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkStrengthScore rdf:type rdf:Property ;
    rdfs:label 'Link Strength Score' ;
    rdfs:comment 'Quantitative measure of the confidence and strength of the network relationship, typically ranging from 0.00 to 100.00. Higher scores indicate stronger evidence of coordinated fraud activity.' ;
    rdfs:domain ind:NetworkLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:linkType rdf:type rdf:Property ;
    rdfs:label 'Link Type' ;
    rdfs:comment 'Classification of the relationship type between fraud subjects indicating the nature of the connection. [ENUM-REF-CANDIDATE: shared_device_fingerprint|shared_ip_address|shared_physical_address|shared_phone_number|common_beneficiary_account|mule_account_network|shared_employer|velocity_pattern_match|shared_email_domain|common_transaction_pattern — promote to reference product]' ;
    rdfs:domain ind:NetworkLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkDepthLevel rdf:type rdf:Property ;
    rdfs:label 'Network Depth Level' ;
    rdfs:comment 'Degree of separation from the primary fraud subject in the network graph. Level 1 indicates direct connection, higher levels indicate indirect relationships through intermediaries.' ;
    rdfs:domain ind:NetworkLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:observationFrequency rdf:type rdf:Property ;
    rdfs:label 'Observation Frequency' ;
    rdfs:comment 'Number of times the relationship pattern has been observed across transactions, interactions, or events. Higher frequency indicates stronger coordination.' ;
    rdfs:domain ind:NetworkLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sarIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Sar Included Flag' ;
    rdfs:comment 'Indicates whether this network link was included in a Suspicious Activity Report (SAR) filing to FinCEN. Used for regulatory compliance tracking.' ;
    rdfs:domain ind:NetworkLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sharedAttributeValue rdf:type rdf:Property ;
    rdfs:label 'Shared Attribute Value' ;
    rdfs:comment 'The specific shared data element that establishes the link (e.g., IP address, device fingerprint hash, physical address, phone number). Stored in hashed or masked format for privacy.' ;
    rdfs:domain ind:NetworkLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amendedSarSarFilingId rdf:type rdf:Property ;
    rdfs:label 'Amended Sar Sar Filing Id' ;
    rdfs:comment 'Reference to the original SAR filing that this record amends, if amendment_flag is true.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SarFiling .

ind:primarySarEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Sar Employee Id' ;
    rdfs:comment 'Identifier of the fraud analyst or compliance officer who prepared the SAR filing.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiarySarApprovedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Sar Approved By User Employee Id' ;
    rdfs:comment 'Identifier of the authorized officer who gave final approval for the SAR filing submission to FinCEN.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:activityDescription rdf:type rdf:Property ;
    rdfs:label 'Activity Description' ;
    rdfs:comment 'Detailed narrative description of the suspicious activity, including facts, patterns, and rationale for filing the SAR. This is the core investigative summary.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingInstitutionContactName rdf:type rdf:Property ;
    rdfs:label 'Filing Institution Contact Name' ;
    rdfs:comment 'Name of the individual at the filing institution who can be contacted regarding this SAR.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingInstitutionContactPhone rdf:type rdf:Property ;
    rdfs:label 'Filing Institution Contact Phone' ;
    rdfs:comment 'Phone number of the filing institution contact person for follow-up inquiries.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingInstitutionName rdf:type rdf:Property ;
    rdfs:label 'Filing Institution Name' ;
    rdfs:comment 'Legal name of the financial institution filing the SAR with FinCEN.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingInstitutionTin rdf:type rdf:Property ;
    rdfs:label 'Filing Institution Tin' ;
    rdfs:comment 'Employer Identification Number (EIN) of the filing financial institution.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fincenAcknowledgmentDate rdf:type rdf:Property ;
    rdfs:label 'Fincen Acknowledgment Date' ;
    rdfs:comment 'Date when FinCEN acknowledged receipt and acceptance of the SAR filing.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fincenBsaReference rdf:type rdf:Property ;
    rdfs:label 'Fincen Bsa Reference' ;
    rdfs:comment 'Unique identifier assigned by FinCEN upon successful submission and acknowledgment of the SAR filing.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lawEnforcementAgencyName rdf:type rdf:Property ;
    rdfs:label 'Law Enforcement Agency Name' ;
    rdfs:comment 'Name of the law enforcement agency contacted or involved in the investigation of this suspicious activity.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lawEnforcementContactDate rdf:type rdf:Property ;
    rdfs:label 'Law Enforcement Contact Date' ;
    rdfs:comment 'Date when law enforcement was contacted regarding this suspicious activity, if applicable.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priorSarReference rdf:type rdf:Property ;
    rdfs:label 'Prior Sar Reference' ;
    rdfs:comment 'Reference to any prior SAR filings related to the same subject or activity, enabling continuity tracking.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sarNumber rdf:type rdf:Property ;
    rdfs:label 'Sar Number' ;
    rdfs:comment 'Business identifier for the SAR filing, typically assigned by the financial institution\'s SAR management system.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sarType rdf:type rdf:Property ;
    rdfs:label 'Sar Type' ;
    rdfs:comment 'Classification of the SAR based on the primary suspicious activity driver. This entity focuses on fraud-originated SARs distinct from compliance AML SARs.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectAddress rdf:type rdf:Property ;
    rdfs:label 'Subject Address' ;
    rdfs:comment 'Full address of the subject party as known to the financial institution at the time of filing.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectEmail rdf:type rdf:Property ;
    rdfs:label 'Subject Email' ;
    rdfs:comment 'Email address of the subject party if available and relevant to the suspicious activity.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectName rdf:type rdf:Property ;
    rdfs:label 'Subject Name' ;
    rdfs:comment 'Full legal name of the individual or entity who is the subject of the SAR filing.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectPhone rdf:type rdf:Property ;
    rdfs:label 'Subject Phone' ;
    rdfs:comment 'Primary contact phone number for the subject party.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectTin rdf:type rdf:Property ;
    rdfs:label 'Subject Tin' ;
    rdfs:comment 'Tax identification number (SSN, EIN, or ITIN) of the subject party, as required by FinCEN SAR reporting.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suspiciousActivityEndDate rdf:type rdf:Property ;
    rdfs:label 'Suspicious Activity End Date' ;
    rdfs:comment 'Date when the suspicious activity being reported ended or was last observed. Nullable for ongoing activity.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:suspiciousActivityStartDate rdf:type rdf:Property ;
    rdfs:label 'Suspicious Activity Start Date' ;
    rdfs:comment 'Date when the suspicious activity being reported first began or was first detected.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:suspiciousActivityTypeCode rdf:type rdf:Property ;
    rdfs:label 'Suspicious Activity Type Code' ;
    rdfs:comment 'FinCEN-defined code(s) categorizing the type of suspicious activity. Multiple codes may be concatenated or stored as delimited list. [ENUM-REF-CANDIDATE: fraud_card|fraud_ach|fraud_wire|fraud_check|fraud_identity_theft|fraud_account_takeover|fraud_elder_financial_exploitation|fraud_mortgage|fraud_consumer_loan|fraud_commercial_loan|fraud_securities|fraud_insurance|fraud_other — promote to reference product]' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalSuspiciousAmount rdf:type rdf:Property ;
    rdfs:label 'Total Suspicious Amount' ;
    rdfs:comment 'Aggregate monetary value of all transactions or activity deemed suspicious and reported in this SAR.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:withdrawalReason rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Reason' ;
    rdfs:comment 'Explanation for why a SAR filing was withdrawn, if applicable. Populated only when filing_status is withdrawn.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Benefit Enrollment Id' ;
    rdfs:comment 'Unique identifier for the benefit enrollment record. Primary key for this entity.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:benefitPlanId rdf:type rdf:Property ;
    rdfs:label 'Benefit Plan Id' ;
    rdfs:comment 'Unique identifier of the benefit plan in which the employee is enrolled. Links to the benefit plan master record.' ;
    rdfs:domain ind:Hr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BenefitPlan .

ind:acaReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Aca Reporting Flag' ;
    rdfs:comment 'Indicates whether this enrollment must be included in ACA Form 1095-C reporting. True if the enrollment is subject to ACA reporting requirements (e.g., health insurance coverage), False otherwise.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:beneficiaryDesignationFlag rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Designation Flag' ;
    rdfs:comment 'Indicates whether the employee has designated beneficiaries for this benefit enrollment (applicable for life insurance, retirement plans, etc.). True if beneficiaries have been designated, False otherwise.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:carrierMemberNumber rdf:type rdf:Property ;
    rdfs:label 'Carrier Member Number' ;
    rdfs:comment 'The unique member identifier assigned by the insurance carrier to the employee for this benefit enrollment. Used for claims processing and coordination with the carrier.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierPolicyNumber rdf:type rdf:Property ;
    rdfs:label 'Carrier Policy Number' ;
    rdfs:comment 'The insurance carrier\'s policy or contract number under which this enrollment is covered. Used for coordination with external insurance carriers and claims processing.' ;
    rdfs:domain ind:Hr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cobraEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Cobra Eligible Flag' ;
    rdfs:comment 'Indicates whether this enrollment is eligible for COBRA continuation coverage in the event of a qualifying event (e.g., termination of employment, reduction in hours). True if COBRA-eligible, False otherwise.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contributionFrequency rdf:type rdf:Property ;
    rdfs:label 'Contribution Frequency' ;
    rdfs:comment 'The frequency at which employee and employer contributions are deducted and paid. Aligns with the organization\'s payroll cycle.' ;
    rdfs:domain ind:Hr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageTier rdf:type rdf:Property ;
    rdfs:label 'Coverage Tier' ;
    rdfs:comment 'The level of coverage elected by the employee, indicating who is covered under the benefit plan. Employee only covers the employee; employee and spouse covers employee and spouse/domestic partner; employee and children covers employee and dependent children; employee and family covers employee, spouse, and children.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dependentCount rdf:type rdf:Property ;
    rdfs:label 'Dependent Count' ;
    rdfs:comment 'The number of dependents (spouse, children, or other qualified dependents) covered under this enrollment. Zero if coverage tier is employee only.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:employeeContributionAmount rdf:type rdf:Property ;
    rdfs:label 'Employee Contribution Amount' ;
    rdfs:comment 'The per-pay-period dollar amount deducted from the employee\'s paycheck to fund this benefit enrollment. Represents the employee\'s share of the premium or cost.' ;
    rdfs:domain ind:Hr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:employerContributionAmount rdf:type rdf:Property ;
    rdfs:label 'Employer Contribution Amount' ;
    rdfs:comment 'The per-pay-period dollar amount contributed by the employer toward this benefit enrollment. Represents the employer\'s share of the premium or cost.' ;
    rdfs:domain ind:Hr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enrollmentConfirmationSentDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment Confirmation Sent Date' ;
    rdfs:comment 'The date on which the enrollment confirmation notice was sent to the employee. Null if confirmation has not yet been sent.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enrollmentConfirmationSentFlag rdf:type rdf:Property ;
    rdfs:label 'Enrollment Confirmation Sent Flag' ;
    rdfs:comment 'Indicates whether an enrollment confirmation notice has been sent to the employee. True if confirmation has been sent, False otherwise. Used for tracking communication compliance.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:enrollmentEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment Effective Date' ;
    rdfs:comment 'The date on which the benefit coverage begins for the employee. This is the start date of the enrollment period and determines when benefits become available.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enrollmentEndDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment End Date' ;
    rdfs:comment 'The date on which the benefit coverage ends for the employee. Null if the enrollment is currently active and has no scheduled termination date.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enrollmentMethod rdf:type rdf:Property ;
    rdfs:label 'Enrollment Method' ;
    rdfs:comment 'The channel or method through which the employee completed the enrollment. Online portal indicates self-service web enrollment; paper form indicates manual form submission; phone indicates enrollment via call center; benefits counselor indicates in-person or virtual counselor-assisted enrollment; automatic indicates system-generated enrollment (e.g., auto-enrollment in retirement plans).' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentNumber rdf:type rdf:Property ;
    rdfs:label 'Enrollment Number' ;
    rdfs:comment 'Business-facing unique enrollment confirmation number provided to the employee upon successful enrollment. Used for reference in benefits inquiries and claims.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentSource rdf:type rdf:Property ;
    rdfs:label 'Enrollment Source' ;
    rdfs:comment 'The triggering event or process that initiated this enrollment. Open enrollment refers to the annual enrollment period; new hire refers to initial enrollment upon joining; life event refers to qualifying life events (marriage, birth, adoption); qualifying event refers to COBRA or other special enrollment rights; administrative correction refers to employer-initiated adjustments.' ;
    rdfs:domain ind:Hr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentStatus rdf:type rdf:Property ;
    rdfs:label 'Enrollment Status' ;
    rdfs:comment 'Current lifecycle status of the benefit enrollment. Active indicates the enrollment is in force; pending indicates awaiting approval or effective date; terminated indicates coverage has ended; waived indicates employee declined coverage; suspended indicates temporary hold; cancelled indicates enrollment was voided before becoming active.' ;
    rdfs:domain ind:Hr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Enrollment Timestamp' ;
    rdfs:comment 'The date and time when the employee submitted the enrollment election. Represents the business event timestamp of the enrollment action.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:evidenceOfInsurabilityRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Evidence Of Insurability Required Flag' ;
    rdfs:comment 'Indicates whether the employee is required to provide Evidence of Insurability (EOI) for this enrollment, typically for supplemental life insurance or disability coverage above guaranteed issue limits. True if EOI is required, False otherwise.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:evidenceOfInsurabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Evidence Of Insurability Status' ;
    rdfs:comment 'The status of the Evidence of Insurability (EOI) review process, if required. Not required if EOI is not needed; pending if awaiting carrier review; approved if carrier approved coverage; denied if carrier denied coverage.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualifyingEventDate rdf:type rdf:Property ;
    rdfs:label 'Qualifying Event Date' ;
    rdfs:comment 'The date of the qualifying life event that triggered this enrollment or change, if applicable. Examples include marriage, birth, adoption, divorce, or loss of other coverage. Null if the enrollment was not triggered by a qualifying event.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualifyingEventType rdf:type rdf:Property ;
    rdfs:label 'Qualifying Event Type' ;
    rdfs:comment 'The type of qualifying life event that triggered this enrollment or change, if applicable. Null if the enrollment was not triggered by a qualifying event. [ENUM-REF-CANDIDATE: marriage|birth|adoption|divorce|death|loss_of_coverage|employment_change — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordUpdatedBy rdf:type rdf:Property ;
    rdfs:label 'Record Updated By' ;
    rdfs:comment 'The user identifier or system process that last modified this enrollment record. Used for audit trail and SOX compliance.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalPremiumAmount rdf:type rdf:Property ;
    rdfs:label 'Total Premium Amount' ;
    rdfs:comment 'The total per-pay-period cost of the benefit enrollment, equal to the sum of employee and employer contributions. Used for benefits cost allocation and General Ledger (GL) posting.' ;
    rdfs:domain ind:Hr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waiverStatus rdf:type rdf:Property ;
    rdfs:label 'Waiver Status' ;
    rdfs:comment 'Indicates whether the employee has explicitly waived (declined) coverage for this benefit plan. True if waived, False if enrolled. Required for ACA reporting and ERISA compliance.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualContributionLimit rdf:type rdf:Property ;
    rdfs:label 'Annual Contribution Limit' ;
    rdfs:comment 'Maximum amount an employee can contribute to this plan in a calendar year. Applicable to FSA, HSA, 401k, and other contribution-based plans.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carrierName rdf:type rdf:Property ;
    rdfs:label 'Carrier Name' ;
    rdfs:comment 'Name of the insurance carrier or third-party administrator providing the benefit plan (e.g., \'Aetna\', \'Blue Cross Blue Shield\', \'Fidelity\').' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coinsurancePercentage rdf:type rdf:Property ;
    rdfs:label 'Coinsurance Percentage' ;
    rdfs:comment 'Percentage of covered service costs the employee pays after meeting the deductible (e.g., 20.00 for 20% coinsurance). Null if plan uses copays.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:copayAmount rdf:type rdf:Property ;
    rdfs:label 'Copay Amount' ;
    rdfs:comment 'Fixed dollar amount the employee pays for covered services (e.g., doctor visit, prescription). Null if plan uses coinsurance instead.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coverageMultipleOfSalary rdf:type rdf:Property ;
    rdfs:label 'Coverage Multiple Of Salary' ;
    rdfs:comment 'Coverage amount expressed as a multiple of employee annual salary (e.g., 2.00 for 2x salary life insurance). Null if coverage is fixed amount.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coverageTierStructure rdf:type rdf:Property ;
    rdfs:label 'Coverage Tier Structure' ;
    rdfs:comment 'Defines how coverage levels are structured: employee only, employee plus spouse, employee plus children, employee plus family, tiered (multiple levels), or composite (single rate for all).' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveEndDate rdf:type rdf:Property ;
    rdfs:label 'Effective End Date' ;
    rdfs:comment 'Date when this benefit plan is no longer available for new enrollments or coverage ends. Null for ongoing plans.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Effective Start Date' ;
    rdfs:comment 'Date when this benefit plan becomes available for employee enrollment and coverage begins. Plan activation date.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eligibilityRuleDescription rdf:type rdf:Property ;
    rdfs:label 'Eligibility Rule Description' ;
    rdfs:comment 'Textual description of eligibility criteria for this plan (e.g., \'Full-time employees with 90 days of service\', \'All regular employees\', \'Executive level and above\').' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeContributionPercentage rdf:type rdf:Property ;
    rdfs:label 'Employee Contribution Percentage' ;
    rdfs:comment 'Percentage of total premium cost the employee contributes (e.g., 20.00 for 20%). Null if contribution is fixed dollar amount.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:employerContributionPercentage rdf:type rdf:Property ;
    rdfs:label 'Employer Contribution Percentage' ;
    rdfs:comment 'Percentage of total premium cost the employer contributes (e.g., 80.00 for 80%). Null if contribution is fixed dollar amount.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:employerMatchLimit rdf:type rdf:Property ;
    rdfs:label 'Employer Match Limit' ;
    rdfs:comment 'Maximum dollar amount or percentage of salary the employer will match for retirement plan contributions. Null if no match or non-retirement plan.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:employerMatchPercentage rdf:type rdf:Property ;
    rdfs:label 'Employer Match Percentage' ;
    rdfs:comment 'Percentage of employee contributions the employer matches for retirement plans (e.g., 50.00 for 50% match up to a limit). Null for non-retirement plans.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:erisaPlanNumber rdf:type rdf:Property ;
    rdfs:label 'Erisa Plan Number' ;
    rdfs:comment 'Three-digit plan number assigned for ERISA reporting purposes. Required for Form 5500 filing for qualifying benefit plans.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAcaCompliant rdf:type rdf:Property ;
    rdfs:label 'Is Aca Compliant' ;
    rdfs:comment 'Indicates whether this health plan meets Affordable Care Act (ACA) minimum essential coverage and affordability requirements.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCobraEligible rdf:type rdf:Property ;
    rdfs:label 'Is Cobra Eligible' ;
    rdfs:comment 'Indicates whether this benefit plan is eligible for COBRA continuation coverage after employment termination. True for most health, dental, and vision plans.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:openEnrollmentEndDate rdf:type rdf:Property ;
    rdfs:label 'Open Enrollment End Date' ;
    rdfs:comment 'Date when the annual open enrollment period ends for this benefit plan. Last day employees can make benefit elections for the upcoming plan year.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:openEnrollmentStartDate rdf:type rdf:Property ;
    rdfs:label 'Open Enrollment Start Date' ;
    rdfs:comment 'Date when the annual open enrollment period begins for this benefit plan. Employees can enroll, change, or cancel coverage during this window.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:outOfPocketMaximum rdf:type rdf:Property ;
    rdfs:label 'Out Of Pocket Maximum' ;
    rdfs:comment 'Maximum amount an employee pays in a plan year for covered services before insurance pays 100%. Applicable to health insurance plans.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planAdministratorContact rdf:type rdf:Property ;
    rdfs:label 'Plan Administrator Contact' ;
    rdfs:comment 'Contact information (email or phone) for the plan administrator. Used for employee inquiries and regulatory communication.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planAdministratorName rdf:type rdf:Property ;
    rdfs:label 'Plan Administrator Name' ;
    rdfs:comment 'Name of the individual or department responsible for administering this benefit plan within the organization.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planCode rdf:type rdf:Property ;
    rdfs:label 'Plan Code' ;
    rdfs:comment 'Unique alphanumeric code identifying the benefit plan in external systems and communications. Used for plan enrollment and payroll integration.' ;
    rdfs:domain ind:Hr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Plan Document Url' ;
    rdfs:comment 'URL or file path to the official plan document, summary plan description (SPD), or benefits guide for employee reference.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planSubtype rdf:type rdf:Property ;
    rdfs:label 'Plan Subtype' ;
    rdfs:comment 'Detailed classification within the plan type (e.g., for health: PPO, HMO, EPO, HDHP; for retirement: 401k Traditional, 401k Roth, Defined Benefit Pension).' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planYearEndDate rdf:type rdf:Property ;
    rdfs:label 'Plan Year End Date' ;
    rdfs:comment 'Last day of the plan year for this benefit. After this date, a new plan year begins with reset deductibles and limits.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planYearStartDate rdf:type rdf:Property ;
    rdfs:label 'Plan Year Start Date' ;
    rdfs:comment 'First day of the plan year for this benefit. Defines the 12-month period for coverage, deductibles, and out-of-pocket maximums.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:summaryPlanDescriptionUrl rdf:type rdf:Property ;
    rdfs:label 'Summary Plan Description Url' ;
    rdfs:comment 'URL or file path to the Summary Plan Description (SPD) document required by ERISA for employee benefit plans.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vestingScheduleDescription rdf:type rdf:Property ;
    rdfs:label 'Vesting Schedule Description' ;
    rdfs:comment 'Description of the vesting schedule for employer contributions to retirement plans (e.g., \'Immediate\', \'3-year cliff\', \'5-year graded\'). Null for non-retirement plans.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waitingPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Waiting Period Days' ;
    rdfs:comment 'Number of days an employee must wait after hire date before becoming eligible for this benefit plan. Zero indicates immediate eligibility.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:candidateId rdf:type rdf:Property ;
    rdfs:label 'Candidate Id' ;
    rdfs:comment 'Unique identifier for the candidate record. Primary key for the candidate entity.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:candidateEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Candidate Employee Id' ;
    rdfs:comment 'Reference to the recruiter or talent acquisition specialist assigned to manage this candidate\'s application.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:candidateHiringManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Candidate Hiring Manager Employee Id' ;
    rdfs:comment 'Reference to the hiring manager responsible for the final hiring decision for this candidate.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:candidateReferralEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Candidate Referral Employee Id' ;
    rdfs:comment 'Reference to the employee who referred this candidate, if applicable, for employee referral program tracking.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:requisitionId rdf:type rdf:Property ;
    rdfs:label 'Requisition Id' ;
    rdfs:comment 'Reference to the job requisition for which this candidate applied.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JobRequisition .

ind:actualHireDate rdf:type rdf:Property ;
    rdfs:label 'Actual Hire Date' ;
    rdfs:comment 'The actual date on which the candidate was hired and became an employee.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:applicationStage rdf:type rdf:Property ;
    rdfs:label 'Application Stage' ;
    rdfs:comment 'The specific stage or phase within the recruiting process that the candidate has reached. [ENUM-REF-CANDIDATE: applied|phone_screen|first_interview|second_interview|final_interview|offer_extended|offer_accepted|onboarding — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backgroundCheckCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Background Check Completion Date' ;
    rdfs:comment 'The date on which the background check process was completed.' ;
    rdfs:domain ind:Hr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:backgroundCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Background Check Status' ;
    rdfs:comment 'Current status of the regulatory background check process including criminal history, employment verification, and education verification.' ;
    rdfs:domain ind:Hr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:candidateNumber rdf:type rdf:Property ;
    rdfs:label 'Candidate Number' ;
    rdfs:comment 'Human-readable business identifier assigned to the candidate for tracking and reference purposes across recruiting systems.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentToContact rdf:type rdf:Property ;
    rdfs:label 'Consent To Contact' ;
    rdfs:comment 'Indicates whether the candidate has provided consent to be contacted for future opportunities, supporting GDPR and privacy compliance.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currentEmployer rdf:type rdf:Property ;
    rdfs:label 'Current Employer' ;
    rdfs:comment 'Name of the organization where the candidate is currently employed, if applicable.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentJobTitle rdf:type rdf:Property ;
    rdfs:label 'Current Job Title' ;
    rdfs:comment 'The candidate\'s current job title or role at their present employer.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:degreeField rdf:type rdf:Property ;
    rdfs:label 'Degree Field' ;
    rdfs:comment 'The primary field or major of the candidate\'s highest degree.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Disability Status' ;
    rdfs:comment 'Self-identified disability status of the candidate for Section 503 compliance and diversity hiring tracking.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eeoEthnicity rdf:type rdf:Property ;
    rdfs:label 'Eeo Ethnicity' ;
    rdfs:comment 'Self-identified ethnicity or race of the candidate for EEO and OFCCP compliance reporting and adverse impact analysis.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eeoGender rdf:type rdf:Property ;
    rdfs:label 'Eeo Gender' ;
    rdfs:comment 'Self-identified gender of the candidate for EEO and OFCCP compliance reporting purposes.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:highestEducationLevel rdf:type rdf:Property ;
    rdfs:label 'Highest Education Level' ;
    rdfs:comment 'The highest level of formal education attained by the candidate.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isInternalCandidate rdf:type rdf:Property ;
    rdfs:label 'Is Internal Candidate' ;
    rdfs:comment 'Indicates whether the candidate is a current employee applying for an internal transfer or promotion.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ofacScreeningDate rdf:type rdf:Property ;
    rdfs:label 'Ofac Screening Date' ;
    rdfs:comment 'The date on which OFAC sanctions screening was performed for the candidate.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ofacScreeningStatus rdf:type rdf:Property ;
    rdfs:label 'Ofac Screening Status' ;
    rdfs:comment 'Status of OFAC sanctions screening to ensure compliance with anti-money laundering and counter-terrorism financing regulations.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerAcceptedDate rdf:type rdf:Property ;
    rdfs:label 'Offer Accepted Date' ;
    rdfs:comment 'The date on which the candidate formally accepted the employment offer.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:offerCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Offer Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the offer salary amount.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerExtendedDate rdf:type rdf:Property ;
    rdfs:label 'Offer Extended Date' ;
    rdfs:comment 'The date on which a formal employment offer was extended to the candidate.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:offerSalaryAmount rdf:type rdf:Property ;
    rdfs:label 'Offer Salary Amount' ;
    rdfs:comment 'The base salary amount offered to the candidate in the employment offer.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resumeDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Resume Document Url' ;
    rdfs:comment 'Storage location or URL reference to the candidate\'s resume or curriculum vitae document.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceChannel rdf:type rdf:Property ;
    rdfs:label 'Source Channel' ;
    rdfs:comment 'The sourcing channel through which the candidate was identified or applied, used for recruiting effectiveness analysis and cost-per-hire tracking.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetStartDate rdf:type rdf:Property ;
    rdfs:label 'Target Start Date' ;
    rdfs:comment 'The anticipated or agreed-upon start date for the candidate if hired.' ;
    rdfs:domain ind:Hr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:timeToFillDays rdf:type rdf:Property ;
    rdfs:label 'Time To Fill Days' ;
    rdfs:comment 'Number of days from application date to hire date, used for recruiting efficiency metrics and service level agreement (SLA) tracking.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:veteranStatus rdf:type rdf:Property ;
    rdfs:label 'Veteran Status' ;
    rdfs:comment 'Self-identified veteran status of the candidate for OFCCP compliance and diversity hiring tracking.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compensationEventId rdf:type rdf:Property ;
    rdfs:label 'Compensation Event Id' ;
    rdfs:comment 'Unique identifier for the compensation event record.' ;
    rdfs:domain ind:CompensationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:equityInstrumentId rdf:type rdf:Property ;
    rdfs:label 'Equity Instrument Id' ;
    rdfs:comment 'Foreign key linking to security.instrument. Business justification: Stock-based compensation (options, RSUs, performance shares) is core to banking compensation, especially for material risk takers. Links compensation events to specific equity instruments (typically b' ;
    rdfs:domain ind:CompensationEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Instrument .

ind:primaryCompensationEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Compensation Employee Id' ;
    rdfs:comment 'Reference to the employee receiving the compensation change.' ;
    rdfs:domain ind:CompensationEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:annualReviewCycleYear rdf:type rdf:Property ;
    rdfs:label 'Annual Review Cycle Year' ;
    rdfs:comment 'The calendar year of the annual compensation review cycle to which this event belongs.' ;
    rdfs:domain ind:CompensationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvalLevel rdf:type rdf:Property ;
    rdfs:label 'Approval Level' ;
    rdfs:comment 'The organizational level required to approve this compensation event based on materiality and policy thresholds.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bonusAwardAmount rdf:type rdf:Property ;
    rdfs:label 'Bonus Award Amount' ;
    rdfs:comment 'The monetary value of a discretionary or performance-based bonus awarded in this event, in the specified currency.' ;
    rdfs:domain ind:CompensationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:changeReasonCode rdf:type rdf:Property ;
    rdfs:label 'Change Reason Code' ;
    rdfs:comment 'Standardized code indicating the business reason for the compensation change (e.g., annual review, market adjustment, role change).' ;
    rdfs:domain ind:CompensationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Change Reason Description' ;
    rdfs:comment 'Detailed narrative explanation of the business rationale for the compensation change.' ;
    rdfs:domain ind:CompensationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compaRatio rdf:type rdf:Property ;
    rdfs:label 'Compa Ratio' ;
    rdfs:comment 'The ratio of the employee\'s new base salary to the pay range midpoint, expressed as a percentage, indicating position within the salary band.' ;
    rdfs:domain ind:CompensationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deferredCompensationAmount rdf:type rdf:Property ;
    rdfs:label 'Deferred Compensation Amount' ;
    rdfs:comment 'The amount of compensation deferred to future periods as part of this event, in the specified currency.' ;
    rdfs:domain ind:CompensationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eventEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Event Effective Date' ;
    rdfs:comment 'The date on which the compensation change becomes effective for payroll and financial reporting purposes.' ;
    rdfs:domain ind:CompensationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:materialRiskTakerFlag rdf:type rdf:Property ;
    rdfs:label 'Material Risk Taker Flag' ;
    rdfs:comment 'Indicates whether the employee is classified as a Material Risk Taker under EBA/PRA remuneration regulations, requiring enhanced disclosure and deferral rules.' ;
    rdfs:domain ind:Hr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:newBaseSalary rdf:type rdf:Property ;
    rdfs:label 'New Base Salary' ;
    rdfs:comment 'The employee\'s base salary amount after this compensation event, in the specified currency.' ;
    rdfs:domain ind:CompensationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:newLtiValue rdf:type rdf:Property ;
    rdfs:label 'New Lti Value' ;
    rdfs:comment 'The value of the employee\'s long-term incentive award after this event, in the specified currency.' ;
    rdfs:domain ind:CompensationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:newTargetBonusPct rdf:type rdf:Property ;
    rdfs:label 'New Target Bonus Pct' ;
    rdfs:comment 'The employee\'s target short-term incentive bonus as a percentage of base salary after this event.' ;
    rdfs:domain ind:CompensationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payRangeMaximum rdf:type rdf:Property ;
    rdfs:label 'Pay Range Maximum' ;
    rdfs:comment 'The maximum salary value for the assigned salary grade, in the specified currency.' ;
    rdfs:domain ind:CompensationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payRangeMidpoint rdf:type rdf:Property ;
    rdfs:label 'Pay Range Midpoint' ;
    rdfs:comment 'The midpoint salary value for the assigned salary grade, in the specified currency.' ;
    rdfs:domain ind:CompensationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payRangeMinimum rdf:type rdf:Property ;
    rdfs:label 'Pay Range Minimum' ;
    rdfs:comment 'The minimum salary value for the assigned salary grade, in the specified currency.' ;
    rdfs:domain ind:CompensationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorBaseSalary rdf:type rdf:Property ;
    rdfs:label 'Prior Base Salary' ;
    rdfs:comment 'The employee\'s base salary amount before this compensation event, in the specified currency.' ;
    rdfs:domain ind:CompensationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorLtiValue rdf:type rdf:Property ;
    rdfs:label 'Prior Lti Value' ;
    rdfs:comment 'The value of the employee\'s long-term incentive award before this event, in the specified currency.' ;
    rdfs:domain ind:CompensationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorTargetBonusPct rdf:type rdf:Property ;
    rdfs:label 'Prior Target Bonus Pct' ;
    rdfs:comment 'The employee\'s target short-term incentive bonus as a percentage of base salary before this event.' ;
    rdfs:domain ind:CompensationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Processed Timestamp' ;
    rdfs:comment 'The date and time when the compensation event was processed into payroll and financial systems.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rarocLinkedFlag rdf:type rdf:Property ;
    rdfs:label 'Raroc Linked Flag' ;
    rdfs:comment 'Indicates whether this compensation event is linked to RAROC-based performance metrics for incentive calculation.' ;
    rdfs:domain ind:CompensationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:salaryGradeCode rdf:type rdf:Property ;
    rdfs:label 'Salary Grade Code' ;
    rdfs:comment 'The salary grade or band assigned to the employee after this compensation event.' ;
    rdfs:domain ind:CompensationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockOptionGrantQuantity rdf:type rdf:Property ;
    rdfs:label 'Stock Option Grant Quantity' ;
    rdfs:comment 'The number of stock options granted to the employee in this compensation event.' ;
    rdfs:domain ind:CompensationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stockOptionStrikePrice rdf:type rdf:Property ;
    rdfs:label 'Stock Option Strike Price' ;
    rdfs:comment 'The exercise price per share for stock options granted in this event, in the specified currency.' ;
    rdfs:domain ind:CompensationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hrPositionId rdf:type rdf:Property ;
    rdfs:label 'Hr Position Id' ;
    rdfs:comment 'Foreign key linking to hr.hr_position. Business justification: Employees are assigned to authorized positions. The hr_position table is the SSOT for position title, job code, job family, job level, and organizational placement. Adding this FK allows normalization' ;
    rdfs:domain ind:Hr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HrPosition .

ind:contractGoverningJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Contract Governing Jurisdiction' ;
    rdfs:comment 'Legal jurisdiction whose laws govern the employment contract (e.g., State of New York, England and Wales). Determines applicable labor regulations and dispute resolution venue.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractNoticePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Contract Notice Period Days' ;
    rdfs:comment 'Number of days of notice required by either party to terminate the employment contract. Varies by jurisdiction and seniority level.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractedHoursPerWeek rdf:type rdf:Property ;
    rdfs:label 'Contracted Hours Per Week' ;
    rdfs:comment 'Standard number of hours per week the employee is contracted to work. Used for FTE (Full-Time Equivalent) calculations and overtime determination.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:departmentName rdf:type rdf:Property ;
    rdfs:label 'Department Name' ;
    rdfs:comment 'Name of the organizational department or unit to which the employee is assigned.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:divisionName rdf:type rdf:Property ;
    rdfs:label 'Division Name' ;
    rdfs:comment 'Name of the business division or line of business (LOB) to which the employee belongs (e.g., Retail Banking, Investment Banking, Wealth Management).' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeNumber rdf:type rdf:Property ;
    rdfs:label 'Employee Number' ;
    rdfs:comment 'Human-readable unique employee identifier assigned by HR system. Used for payroll, timekeeping, and external reporting. Aligned with Workday/SAP SuccessFactors Employee ID field.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employmentBasis rdf:type rdf:Property ;
    rdfs:label 'Employment Basis' ;
    rdfs:comment 'Full-time or part-time classification of the employee. Impacts benefit eligibility, FMLA qualification, and regulatory headcount calculations.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employmentType rdf:type rdf:Property ;
    rdfs:label 'Employment Type' ;
    rdfs:comment 'Classification of the employment contract type. Determines benefit eligibility, regulatory reporting treatment, and labor law compliance requirements.' ;
    rdfs:domain ind:Hr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flsaClassification rdf:type rdf:Property ;
    rdfs:label 'Flsa Classification' ;
    rdfs:comment 'Classification under FLSA determining overtime eligibility. Exempt employees are not eligible for overtime pay; non-exempt employees are.' ;
    rdfs:domain ind:Hr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fmlaEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Fmla Eligible Flag' ;
    rdfs:comment 'Indicates whether the employee meets FMLA eligibility criteria (12 months tenure, 1,250 hours worked, worksite with 50+ employees within 75 miles).' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobFamily rdf:type rdf:Property ;
    rdfs:label 'Job Family' ;
    rdfs:comment 'Broad occupational category grouping similar roles (e.g., Technology, Risk Management, Investment Banking). Used for talent management and succession planning.' ;
    rdfs:domain ind:Hr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobLevel rdf:type rdf:Property ;
    rdfs:label 'Job Level' ;
    rdfs:comment 'Hierarchical level or grade of the position within the organization\'s job architecture (e.g., Analyst, Associate, Vice President, Managing Director).' ;
    rdfs:domain ind:Hr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalEntityCode rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Code' ;
    rdfs:comment 'Code identifying the legal entity that employs the individual. Critical for regulatory reporting, tax compliance, and legal liability determination.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalFirstName rdf:type rdf:Property ;
    rdfs:label 'Legal First Name' ;
    rdfs:comment 'Employee\'s legal first name as it appears on government-issued identification. Used for regulatory reporting, payroll tax forms, and compliance documentation.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalLastName rdf:type rdf:Property ;
    rdfs:label 'Legal Last Name' ;
    rdfs:comment 'Employee\'s legal last name (surname) as it appears on government-issued identification. Used for regulatory reporting and payroll compliance.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalMiddleName rdf:type rdf:Property ;
    rdfs:label 'Legal Middle Name' ;
    rdfs:comment 'Employee\'s legal middle name or initial as it appears on government-issued identification.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mobilePhoneNumber rdf:type rdf:Property ;
    rdfs:label 'Mobile Phone Number' ;
    rdfs:comment 'Personal or corporate mobile phone number for emergency contact and business communication.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalHireDate rdf:type rdf:Property ;
    rdfs:label 'Original Hire Date' ;
    rdfs:comment 'Original date of hire if employee was rehired after a break in service. Used for benefit vesting and seniority calculations that recognize prior service.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preferredName rdf:type rdf:Property ;
    rdfs:label 'Preferred Name' ;
    rdfs:comment 'Name the employee prefers to be called in day-to-day business interactions. May differ from legal name.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ptoAccrualRateHoursPerMonth rdf:type rdf:Property ;
    rdfs:label 'Pto Accrual Rate Hours Per Month' ;
    rdfs:comment 'Rate at which the employee accrues PTO hours each month. Typically varies by tenure and job level.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ptoBalanceHours rdf:type rdf:Property ;
    rdfs:label 'Pto Balance Hours' ;
    rdfs:comment 'Current balance of accrued but unused paid time off hours available to the employee. Updated with each accrual and usage transaction.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryHeadcountFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Headcount Flag' ;
    rdfs:comment 'Indicates whether this employee is included in regulatory headcount reporting to FDIC, Federal Reserve, and other banking regulators. Excludes contractors and certain temporary workers.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rehireEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Rehire Eligibility Flag' ;
    rdfs:comment 'Indicates whether the employee is eligible for rehire based on termination circumstances and performance history.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:soxCriticalRoleFlag rdf:type rdf:Property ;
    rdfs:label 'Sox Critical Role Flag' ;
    rdfs:comment 'Indicates whether the employee holds a role subject to SOX HR control requirements (e.g., financial reporting, IT general controls, access provisioning). Triggers enhanced background checks and segregation of duties reviews.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workCountryCode rdf:type rdf:Property ;
    rdfs:label 'Work Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for the country where the employee primarily works. Determines applicable labor laws and tax jurisdiction.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workLocationCode rdf:type rdf:Property ;
    rdfs:label 'Work Location Code' ;
    rdfs:comment 'Code identifying the primary physical work location or office where the employee is based. Used for space planning and emergency response.' ;
    rdfs:domain ind:Hr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workPhoneNumber rdf:type rdf:Property ;
    rdfs:label 'Work Phone Number' ;
    rdfs:comment 'Primary business phone number for the employee, including extension if applicable.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeRelationCaseId rdf:type rdf:Property ;
    rdfs:label 'Employee Relation Case Id' ;
    rdfs:comment 'Unique identifier for the employee relations case record. Primary key for the employee relation case entity.' ;
    rdfs:domain ind:EmployeeRelationCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Employee Id' ;
    rdfs:comment 'Identifier of the employee who is the subject of this employee relations case.' ;
    rdfs:domain ind:EmployeeRelationCase ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Modified By User Employee Id' ;
    rdfs:comment 'System user identifier of the person who last modified this case record, supporting audit trail and accountability requirements.' ;
    rdfs:domain ind:EmployeeRelationCase ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:allegationSummary rdf:type rdf:Property ;
    rdfs:label 'Allegation Summary' ;
    rdfs:comment 'Detailed narrative summary of the allegations, complaints, or issues that triggered the employee relations case, including key facts and circumstances reported.' ;
    rdfs:domain ind:EmployeeRelationCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appealFiledDate rdf:type rdf:Property ;
    rdfs:label 'Appeal Filed Date' ;
    rdfs:comment 'Date when the employee formally filed an appeal challenging the case findings or disciplinary action.' ;
    rdfs:domain ind:EmployeeRelationCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:appealResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Appeal Resolution Date' ;
    rdfs:comment 'Date when the appeal was formally resolved with a final decision rendered.' ;
    rdfs:domain ind:EmployeeRelationCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:appealStatus rdf:type rdf:Property ;
    rdfs:label 'Appeal Status' ;
    rdfs:comment 'Status of any employee appeal filed against the investigation findings or disciplinary action taken.' ;
    rdfs:domain ind:EmployeeRelationCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseCloseDate rdf:type rdf:Property ;
    rdfs:label 'Case Close Date' ;
    rdfs:comment 'Date when the employee relations case was formally closed after investigation and resolution actions were completed.' ;
    rdfs:domain ind:EmployeeRelationCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:caseOpenDate rdf:type rdf:Property ;
    rdfs:label 'Case Open Date' ;
    rdfs:comment 'Date when the employee relations case was formally opened and investigation commenced.' ;
    rdfs:domain ind:EmployeeRelationCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:casePriority rdf:type rdf:Property ;
    rdfs:label 'Case Priority' ;
    rdfs:comment 'Priority level assigned to the case based on severity, regulatory implications, and potential business impact.' ;
    rdfs:domain ind:EmployeeRelationCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeAcknowledgementDate rdf:type rdf:Property ;
    rdfs:label 'Employee Acknowledgement Date' ;
    rdfs:comment 'Date when the employee formally acknowledged the case findings and resolution actions through signature or electronic confirmation.' ;
    rdfs:domain ind:Hr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:employeeAcknowledgementStatus rdf:type rdf:Property ;
    rdfs:label 'Employee Acknowledgement Status' ;
    rdfs:comment 'Status indicating whether the employee has formally acknowledged receipt and understanding of the investigation findings and resolution actions.' ;
    rdfs:domain ind:EmployeeRelationCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ethicsHotlineFlag rdf:type rdf:Property ;
    rdfs:label 'Ethics Hotline Flag' ;
    rdfs:comment 'Indicator of whether this case was reported through the corporate ethics hotline or anonymous reporting channel.' ;
    rdfs:domain ind:EmployeeRelationCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:investigationFindings rdf:type rdf:Property ;
    rdfs:label 'Investigation Findings' ;
    rdfs:comment 'Comprehensive summary of the investigation findings, conclusions, and determinations made by the investigator based on evidence gathered and interviews conducted.' ;
    rdfs:domain ind:EmployeeRelationCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:litigationRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Litigation Risk Flag' ;
    rdfs:comment 'Indicator of whether this case presents potential employment litigation risk requiring legal department involvement and special handling.' ;
    rdfs:domain ind:EmployeeRelationCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pipInitiatedFlag rdf:type rdf:Property ;
    rdfs:label 'Pip Initiated Flag' ;
    rdfs:comment 'Indicator of whether a formal Performance Improvement Plan was initiated as part of the case resolution.' ;
    rdfs:domain ind:EmployeeRelationCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retaliationClaimFlag rdf:type rdf:Property ;
    rdfs:label 'Retaliation Claim Flag' ;
    rdfs:comment 'Indicator of whether the case involves allegations of retaliation against an employee for protected activity such as whistleblowing or filing a complaint.' ;
    rdfs:domain ind:EmployeeRelationCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seniorManagerRegimeFlag rdf:type rdf:Property ;
    rdfs:label 'Senior Manager Regime Flag' ;
    rdfs:comment 'Indicator of whether this case involves a senior manager subject to Financial Conduct Authority (FCA) and Prudential Regulation Authority (PRA) Senior Managers and Certification Regime (SMCR) fitness and propriety requirements.' ;
    rdfs:domain ind:EmployeeRelationCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:suspensionEndDate rdf:type rdf:Property ;
    rdfs:label 'Suspension End Date' ;
    rdfs:comment 'Date when employee suspension concluded and the employee was eligible to return to work.' ;
    rdfs:domain ind:EmployeeRelationCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:suspensionStartDate rdf:type rdf:Property ;
    rdfs:label 'Suspension Start Date' ;
    rdfs:comment 'Date when employee suspension commenced as a disciplinary action resulting from the case investigation.' ;
    rdfs:domain ind:EmployeeRelationCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:terminationForCauseFlag rdf:type rdf:Property ;
    rdfs:label 'Termination For Cause Flag' ;
    rdfs:comment 'Indicator of whether the case resulted in termination of employment for cause, which has implications for severance, unemployment benefits, and regulatory reporting.' ;
    rdfs:domain ind:EmployeeRelationCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:whistleblowerFlag rdf:type rdf:Property ;
    rdfs:label 'Whistleblower Flag' ;
    rdfs:comment 'Indicator of whether this case originated from a whistleblower complaint, requiring special protections under Sarbanes-Oxley (SOX) Act and Dodd-Frank whistleblower provisions.' ;
    rdfs:domain ind:EmployeeRelationCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobProfileId rdf:type rdf:Property ;
    rdfs:label 'Job Profile Id' ;
    rdfs:comment 'Reference to the standardized job profile that defines the role template, competencies, and classification for this position.' ;
    rdfs:domain ind:Hr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JobProfile .

ind:locationId rdf:type rdf:Property ;
    rdfs:label 'Location Id' ;
    rdfs:comment 'Reference to the primary work location or office where this position is based.' ;
    rdfs:domain ind:Hr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkLocation .

ind:reportingPositionHrPositionId rdf:type rdf:Property ;
    rdfs:label 'Reporting Position Hr Position Id' ;
    rdfs:comment 'Reference to the supervisory position to which this position reports, establishing the organizational reporting line.' ;
    rdfs:domain ind:HrPosition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HrPosition .

ind:budgetApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Budget Approval Date' ;
    rdfs:comment 'The date on which the budget for this position was approved by the Asset-Liability Committee (ALCO) or finance leadership.' ;
    rdfs:domain ind:HrPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ccarStressScenarioFlag rdf:type rdf:Property ;
    rdfs:label 'Ccar Stress Scenario Flag' ;
    rdfs:comment 'Indicates whether this position is included in CCAR/DFAST headcount stress testing scenarios for regulatory capital planning.' ;
    rdfs:domain ind:Hr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:competencyProfile rdf:type rdf:Property ;
    rdfs:label 'Competency Profile' ;
    rdfs:comment 'Reference to the competency framework or skill profile associated with this position, defining required technical and behavioral competencies.' ;
    rdfs:domain ind:HrPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalRoleFlag rdf:type rdf:Property ;
    rdfs:label 'Critical Role Flag' ;
    rdfs:comment 'Indicates whether this position is designated as business-critical for operational resilience and succession planning purposes.' ;
    rdfs:domain ind:HrPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:filledDate rdf:type rdf:Property ;
    rdfs:label 'Filled Date' ;
    rdfs:comment 'The date on which this position was most recently filled by an employee assignment. Null if currently vacant.' ;
    rdfs:domain ind:HrPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fteAuthorization rdf:type rdf:Property ;
    rdfs:label 'Fte Authorization' ;
    rdfs:comment 'The authorized full-time equivalent allocation for this position, typically 1.00 for full-time, 0.50 for half-time, etc. Used in workforce planning and headcount reporting.' ;
    rdfs:domain ind:HrPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gradeBand rdf:type rdf:Property ;
    rdfs:label 'Grade Band' ;
    rdfs:comment 'The compensation grade or band assigned to this position, determining the salary range and benefits eligibility.' ;
    rdfs:domain ind:HrPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:justification rdf:type rdf:Property ;
    rdfs:label 'Justification' ;
    rdfs:comment 'Business rationale or justification for the creation or continuation of this position, used for budget approval and workforce planning.' ;
    rdfs:domain ind:Hr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User' ;
    rdfs:comment 'The user identifier of the HR professional or system administrator who most recently modified this position record.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumEducationLevel rdf:type rdf:Property ;
    rdfs:label 'Minimum Education Level' ;
    rdfs:comment 'The minimum educational qualification required for this position as defined in the job profile.' ;
    rdfs:domain ind:Hr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionCode rdf:type rdf:Property ;
    rdfs:label 'Position Code' ;
    rdfs:comment 'Business identifier for the position, typically used in workforce planning and organizational charts. Unique across the enterprise.' ;
    rdfs:domain ind:HrPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionStatus rdf:type rdf:Property ;
    rdfs:label 'Position Status' ;
    rdfs:comment 'Current lifecycle status of the position indicating whether it is available for hiring, currently occupied, temporarily frozen, or permanently closed.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryRoleFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Role Flag' ;
    rdfs:comment 'Indicates whether this position has regulatory significance requiring special reporting, such as senior management functions under Federal Reserve or OCC oversight.' ;
    rdfs:domain ind:HrPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remoteEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Remote Eligible Flag' ;
    rdfs:comment 'Indicates whether this position is eligible for remote or hybrid work arrangements per organizational policy.' ;
    rdfs:domain ind:HrPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiredCertifications rdf:type rdf:Property ;
    rdfs:label 'Required Certifications' ;
    rdfs:comment 'List of professional certifications or licenses required for this position, such as CFA, CPA, Series 7, or other industry-specific credentials.' ;
    rdfs:domain ind:Hr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:successionPlanFlag rdf:type rdf:Property ;
    rdfs:label 'Succession Plan Flag' ;
    rdfs:comment 'Indicates whether this position has an active succession plan in place, identifying potential internal candidates for future filling.' ;
    rdfs:domain ind:HrPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetFillDate rdf:type rdf:Property ;
    rdfs:label 'Target Fill Date' ;
    rdfs:comment 'The planned or target date by which this open position should be filled, used for workforce planning and recruitment tracking.' ;
    rdfs:domain ind:HrPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:travelRequirementPct rdf:type rdf:Property ;
    rdfs:label 'Travel Requirement Pct' ;
    rdfs:comment 'The expected percentage of time this position requires business travel, used for workforce planning and candidate expectations.' ;
    rdfs:domain ind:HrPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unionEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Union Eligible Flag' ;
    rdfs:comment 'Indicates whether this position is eligible for union membership or covered by collective bargaining agreements.' ;
    rdfs:domain ind:HrPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vacancyPostedDate rdf:type rdf:Property ;
    rdfs:label 'Vacancy Posted Date' ;
    rdfs:comment 'The date on which this position was posted as a vacancy for recruitment, if currently open.' ;
    rdfs:domain ind:HrPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:yearsExperienceRequired rdf:type rdf:Property ;
    rdfs:label 'Years Experience Required' ;
    rdfs:comment 'The minimum number of years of relevant professional experience required for this position.' ;
    rdfs:domain ind:HrPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:learningEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Learning Enrollment Id' ;
    rdfs:comment 'Unique identifier for the learning enrollment record. Primary key for the learning enrollment entity.' ;
    rdfs:domain ind:LearningEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:courseId rdf:type rdf:Property ;
    rdfs:label 'Course Id' ;
    rdfs:comment 'Unique identifier of the training course or learning program. Links to the course catalog in the learning management system.' ;
    rdfs:domain ind:LearningEnrollment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LearningCourse .

ind:primaryLearningEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Learning Employee Id' ;
    rdfs:comment 'Unique identifier of the employee enrolled in the training program. Links to the employee master record in the Human Capital Management (HCM) system.' ;
    rdfs:domain ind:LearningEnrollment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryLearningModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Learning Modified By User Employee Id' ;
    rdfs:comment 'Identifier of the user or system process that last modified the learning enrollment record. Used for audit trail and accountability.' ;
    rdfs:domain ind:LearningEnrollment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:attemptsCount rdf:type rdf:Property ;
    rdfs:label 'Attempts Count' ;
    rdfs:comment 'Number of times the employee has attempted the course assessment or examination. Used to track retake activity and identify employees requiring additional support.' ;
    rdfs:domain ind:LearningEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certificationEarned rdf:type rdf:Property ;
    rdfs:label 'Certification Earned' ;
    rdfs:comment 'Name or title of the certification, credential, or designation earned upon successful completion of the training course. Null if no certification is awarded.' ;
    rdfs:domain ind:LearningEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Certification Expiration Date' ;
    rdfs:comment 'Date on which the certification or credential expires and must be renewed. Used for compliance tracking and to trigger renewal notifications.' ;
    rdfs:domain ind:LearningEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationNumber rdf:type rdf:Property ;
    rdfs:label 'Certification Number' ;
    rdfs:comment 'Unique identifier or certificate number issued for the certification earned. Used for verification and audit purposes.' ;
    rdfs:domain ind:LearningEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Amount' ;
    rdfs:comment 'Total cost incurred for the employee\'s enrollment in the training course, including tuition, materials, and any associated fees. Used for training budget management and cost allocation.' ;
    rdfs:domain ind:LearningEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Cost Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the training cost amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:LearningEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseCode rdf:type rdf:Property ;
    rdfs:label 'Course Code' ;
    rdfs:comment 'Business-readable code or identifier for the training course, used for reporting and reference purposes.' ;
    rdfs:domain ind:Hr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseName rdf:type rdf:Property ;
    rdfs:label 'Course Name' ;
    rdfs:comment 'Full name or title of the training course or learning program.' ;
    rdfs:domain ind:LearningEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseType rdf:type rdf:Property ;
    rdfs:label 'Course Type' ;
    rdfs:comment 'Classification of the training course by its primary purpose. Regulatory/mandatory courses include Anti-Money Laundering (AML), Bank Secrecy Act (BSA), Know Your Customer (KYC), Sarbanes-Oxley Act (SOX), and Financial Industry Regulatory Authority (FINRA) continuing education requirements.' ;
    rdfs:domain ind:Hr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpeCreditsAwarded rdf:type rdf:Property ;
    rdfs:label 'Cpe Credits Awarded' ;
    rdfs:comment 'Number of Continuing Professional Education (CPE) or Continuing Education (CE) credits awarded upon successful completion of the training course. Used for professional licensing and regulatory compliance.' ;
    rdfs:domain ind:LearningEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditType rdf:type rdf:Property ;
    rdfs:label 'Credit Type' ;
    rdfs:comment 'Type of continuing education credit awarded. CPE refers to Continuing Professional Education, CE to Continuing Education, CLE to Continuing Legal Education, CME to Continuing Medical Education, FINRA Regulatory to FINRA Regulatory Element, and FINRA Firm to FINRA Firm Element. [ENUM-REF-CANDIDATE: cpe|ce|cle|cme|finra_regulatory|finra_firm|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LearningEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment Date' ;
    rdfs:comment 'Date on which the employee was enrolled in the training course. Represents the official registration date for the learning program.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:jobRole rdf:type rdf:Property ;
    rdfs:label 'Job Role' ;
    rdfs:comment 'Job role or position title of the employee at the time of enrollment. Used to analyze training participation by role and ensure role-specific training requirements are met.' ;
    rdfs:domain ind:LearningEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mandatoryFlag rdf:type rdf:Property ;
    rdfs:label 'Mandatory Flag' ;
    rdfs:comment 'Indicates whether the training course is mandatory for the employee based on their role, regulatory requirements, or organizational policy. True indicates mandatory training, False indicates elective training.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:providerName rdf:type rdf:Property ;
    rdfs:label 'Provider Name' ;
    rdfs:comment 'Name of the organization or vendor providing the training course. May be internal (bank learning and development department) or external (third-party training provider).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalDueDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Due Date' ;
    rdfs:comment 'Date by which the employee must complete renewal training or recertification to maintain compliance. Used for proactive compliance management.' ;
    rdfs:domain ind:LearningEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Completion Date' ;
    rdfs:comment 'Target or expected date by which the employee should complete the training course. Used for compliance tracking and deadline management.' ;
    rdfs:domain ind:LearningEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledStartDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Date' ;
    rdfs:comment 'Planned or scheduled date for the employee to begin the training course. May differ from enrollment date for courses with future start dates.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseCertificationId rdf:type rdf:Property ;
    rdfs:label 'License Certification Id' ;
    rdfs:comment 'Unique identifier for the employee professional license or regulatory certification record. Primary key for the license_certification product.' ;
    rdfs:domain ind:LicenseCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:createdByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Created By User Employee Id' ;
    rdfs:comment 'User identifier of the HR system user or automated process that created this license or certification record. Used for audit trail and data governance.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:lastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User Employee Id' ;
    rdfs:comment 'User identifier of the HR system user or automated process that most recently modified this license or certification record. Used for audit trail and data governance.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:continuingEducationComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Continuing Education Compliance Status' ;
    rdfs:comment 'Assessment of whether the employee is on track to meet continuing education requirements for this license or certification. Compliant indicates requirements are met or on track. At Risk indicates the employee is behind schedule but still within the renewal window. Non-Compliant indicates requirements are not met and the credential is at risk. Not Applicable indicates no CE requirements exist for this credential.' ;
    rdfs:domain ind:LicenseCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:continuingEducationHoursCompleted rdf:type rdf:Property ;
    rdfs:label 'Continuing Education Hours Completed' ;
    rdfs:comment 'Number of continuing education or professional development hours the employee has completed toward the current renewal cycle requirement. Expressed as decimal hours (e.g., 18.50 hours).' ;
    rdfs:domain ind:LicenseCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:continuingEducationHoursRequired rdf:type rdf:Property ;
    rdfs:label 'Continuing Education Hours Required' ;
    rdfs:comment 'Total number of continuing education or professional development hours required by the issuing authority to maintain or renew this license or certification during the current renewal cycle. Expressed as decimal hours (e.g., 24.00 hours).' ;
    rdfs:domain ind:LicenseCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fitnessProprietyReviewDate rdf:type rdf:Property ;
    rdfs:label 'Fitness Propriety Review Date' ;
    rdfs:comment 'Most recent date on which the employee\'s fitness and propriety assessment was conducted in relation to this license or certification, as required by OCC, PRA, or other banking regulators. Nullable if no review has been conducted. Follows yyyy-MM-dd format.' ;
    rdfs:domain ind:LicenseCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fitnessProprietyStatus rdf:type rdf:Property ;
    rdfs:label 'Fitness Propriety Status' ;
    rdfs:comment 'Outcome of the most recent fitness and propriety assessment for the employee in relation to this license or certification. Approved indicates the employee meets all regulatory fitness standards. Pending indicates review is in progress. Conditional indicates approval with restrictions or monitoring requirements. Denied indicates the employee does not meet fitness standards. Not Applicable indicates no fitness review is required for this credential.' ;
    rdfs:domain ind:LicenseCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseNumber rdf:type rdf:Property ;
    rdfs:label 'License Number' ;
    rdfs:comment 'Unique alphanumeric identifier assigned by the issuing authority or regulatory body for this license or certification. May include FINRA CRD number, state license number, or professional certification ID.' ;
    rdfs:domain ind:LicenseCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseStatus rdf:type rdf:Property ;
    rdfs:label 'License Status' ;
    rdfs:comment 'Current lifecycle status of the license or certification. Active indicates the credential is valid and in good standing. Expired indicates the credential has passed its expiration date and requires renewal. Suspended indicates temporary restriction by the issuing authority. Revoked indicates permanent cancellation. Pending indicates application or renewal is in process. Inactive indicates the employee is not currently using this credential in their role.' ;
    rdfs:domain ind:LicenseCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseType rdf:type rdf:Property ;
    rdfs:label 'License Type' ;
    rdfs:comment 'Classification of the professional license or regulatory certification. Common types include FINRA Series 7 (General Securities Representative), Series 63 (Uniform Securities Agent State Law), Series 65 (Investment Adviser Representative), CFA (Chartered Financial Analyst), CPA (Certified Public Accountant), FRM (Financial Risk Manager), PMP (Project Management Professional), CAIA (Chartered Alternative Investment Analyst), CIPM (Certificate in Investment Performance Measurement). [ENUM-REF-CANDIDATE: finra_series_7|finra_series_63|finra_series_65|finra_series_24|finra_series_66|finra_series_79|finra_series_82|cfa_level_1|cfa_level_2|cfa_level_3|cpa|frm_part_1|frm_part_2|pmp|caia|cipm|cams|cfp|cima — promote to reference product]' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextRenewalDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Renewal Due Date' ;
    rdfs:comment 'Target date by which the employee must complete renewal requirements to maintain active status. Used for proactive compliance monitoring and workforce planning. Follows yyyy-MM-dd format.' ;
    rdfs:domain ind:LicenseCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:professionalDevelopmentPlanFlag rdf:type rdf:Property ;
    rdfs:label 'Professional Development Plan Flag' ;
    rdfs:comment 'Boolean indicator of whether this license or certification is part of a formal professional development or career progression plan for the employee. True indicates the credential is linked to a development plan. False indicates it is not part of a formal plan.' ;
    rdfs:domain ind:LicenseCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryBodyNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Body Notification Date' ;
    rdfs:comment 'Date on which the regulatory body or internal compliance department was notified of this license or certification status. Nullable if notification has not occurred or is not required. Follows yyyy-MM-dd format.' ;
    rdfs:domain ind:LicenseCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryBodyNotificationStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Body Notification Status' ;
    rdfs:comment 'Indicates whether the appropriate regulatory body or compliance department has been notified of this license or certification status. Notified indicates successful notification. Pending Notification indicates notification is required but not yet completed. Not Required indicates no notification obligation exists. Failed indicates notification attempt was unsuccessful and requires follow-up.' ;
    rdfs:domain ind:LicenseCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalStatus rdf:type rdf:Property ;
    rdfs:label 'Renewal Status' ;
    rdfs:comment 'Current state of the renewal process for this license or certification. Current indicates no renewal action is required at this time. Renewal Required indicates the credential is approaching expiration and renewal must be initiated. Renewal In Progress indicates the employee has started the renewal process. Overdue indicates the renewal deadline has passed. Not Applicable indicates the credential does not require periodic renewal.' ;
    rdfs:domain ind:LicenseCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredForRoleFlag rdf:type rdf:Property ;
    rdfs:label 'Required For Role Flag' ;
    rdfs:comment 'Boolean indicator of whether this license or certification is mandatory for the employee\'s current job role or position. True indicates the credential is a regulatory or business requirement for the role. False indicates the credential is elective or supplementary.' ;
    rdfs:domain ind:LicenseCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:successionPlanningFlag rdf:type rdf:Property ;
    rdfs:label 'Succession Planning Flag' ;
    rdfs:comment 'Boolean indicator of whether this license or certification is a requirement or consideration for succession planning and talent pipeline development. True indicates the credential is relevant to succession planning. False indicates it is not a succession planning factor.' ;
    rdfs:domain ind:Hr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:onboardingEventId rdf:type rdf:Property ;
    rdfs:label 'Onboarding Event Id' ;
    rdfs:comment 'Unique identifier for the onboarding or offboarding event record. Primary key for the onboarding event entity.' ;
    rdfs:domain ind:OnboardingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryOnboardingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Onboarding Employee Id' ;
    rdfs:comment 'Identifier of the employee undergoing onboarding or offboarding. Links to the employee master record.' ;
    rdfs:domain ind:OnboardingEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accessRevocationDate rdf:type rdf:Property ;
    rdfs:label 'Access Revocation Date' ;
    rdfs:comment 'Date when all system access and entitlements were revoked for the departing employee. Must occur on or before separation date per SOX controls. Null for onboarding events.' ;
    rdfs:domain ind:OnboardingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accessRevocationStatus rdf:type rdf:Property ;
    rdfs:label 'Access Revocation Status' ;
    rdfs:comment 'Status of access revocation milestone (offboarding only): not applicable (onboarding event), in progress (revocation underway), revoked (access removed), or verified (revocation confirmed by security team). Critical for SOX ITGC and information security compliance.' ;
    rdfs:domain ind:OnboardingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceTrainingCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Compliance Training Completion Date' ;
    rdfs:comment 'Date when all mandatory compliance training courses were completed. Required for regulatory reporting and audit evidence.' ;
    rdfs:domain ind:OnboardingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceTrainingStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Training Status' ;
    rdfs:comment 'Status of mandatory compliance training completion milestone: not started, in progress, completed (all required courses finished), or overdue (past due date). Includes Anti-Money Laundering (AML), Know Your Customer (KYC), Bank Secrecy Act (BSA), and ethics training required for banking employees.' ;
    rdfs:domain ind:OnboardingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeStartDate rdf:type rdf:Property ;
    rdfs:label 'Employee Start Date' ;
    rdfs:comment 'Official start date or hire date for the employee (for onboarding events) or the effective date of transfer (for transfer onboarding). Represents the date the employee begins their role.' ;
    rdfs:domain ind:OnboardingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:entitlementAccessReviewDate rdf:type rdf:Property ;
    rdfs:label 'Entitlement Access Review Date' ;
    rdfs:comment 'Date when the entitlement access review was completed and documented. Required for SOX audit evidence and quarterly access certification.' ;
    rdfs:domain ind:OnboardingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:entitlementAccessReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Entitlement Access Review Status' ;
    rdfs:comment 'Status of entitlement access review milestone: not started, in progress, completed (access validated and approved), or failed (access violations identified). Required for SOX user access reviews and segregation of duties testing.' ;
    rdfs:domain ind:OnboardingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentIssuanceDate rdf:type rdf:Property ;
    rdfs:label 'Equipment Issuance Date' ;
    rdfs:comment 'Date when equipment was issued to the employee (for onboarding) or returned by the employee (for offboarding). Used for asset tracking and inventory management.' ;
    rdfs:domain ind:OnboardingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:equipmentIssuanceStatus rdf:type rdf:Property ;
    rdfs:label 'Equipment Issuance Status' ;
    rdfs:comment 'Status of equipment issuance or return milestone: not started, in progress, issued (equipment provided to employee), or returned (equipment collected during offboarding). Includes laptops, mobile devices, access badges, and other company property.' ;
    rdfs:domain ind:OnboardingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventStartDate rdf:type rdf:Property ;
    rdfs:label 'Event Start Date' ;
    rdfs:comment 'Date when the onboarding or offboarding event was initiated or formally commenced. Represents the beginning of the lifecycle process.' ;
    rdfs:domain ind:OnboardingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exitInterviewDate rdf:type rdf:Property ;
    rdfs:label 'Exit Interview Date' ;
    rdfs:comment 'Date when the exit interview was conducted. Null for onboarding events or if exit interview was not completed.' ;
    rdfs:domain ind:OnboardingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exitInterviewStatus rdf:type rdf:Property ;
    rdfs:label 'Exit Interview Status' ;
    rdfs:comment 'Status of exit interview milestone (offboarding only): not applicable (onboarding event), scheduled, completed, declined (employee refused), or waived (not required). Used for retention analytics and organizational feedback.' ;
    rdfs:domain ind:OnboardingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finraRegistrationDate rdf:type rdf:Property ;
    rdfs:label 'Finra Registration Date' ;
    rdfs:comment 'Date when FINRA registration was approved or submitted. Null if not applicable to the employee role.' ;
    rdfs:domain ind:OnboardingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:finraRegistrationStatus rdf:type rdf:Property ;
    rdfs:label 'Finra Registration Status' ;
    rdfs:comment 'Status of FINRA registration initiation milestone (for registered representatives and broker-dealer employees): not applicable (non-registered role), initiated, submitted (application filed), approved (registration granted), or rejected. Required for investment banking and securities trading roles.' ;
    rdfs:domain ind:OnboardingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:i9VerificationDate rdf:type rdf:Property ;
    rdfs:label 'I9 Verification Date' ;
    rdfs:comment 'Date when the I-9 employment eligibility verification was completed. Must be within three business days of hire date per USCIS regulations.' ;
    rdfs:domain ind:OnboardingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:i9VerificationStatus rdf:type rdf:Property ;
    rdfs:label 'I9 Verification Status' ;
    rdfs:comment 'Status of the I-9 employment eligibility verification milestone (U.S. only): not started, in progress, verified (compliant), expired (requires reverification), or failed (ineligible). Required for U.S. labor law compliance.' ;
    rdfs:domain ind:OnboardingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:occFitnessProprietyReviewDate rdf:type rdf:Property ;
    rdfs:label 'Occ Fitness Propriety Review Date' ;
    rdfs:comment 'Date when the OCC fitness and propriety review was completed. Null if not applicable to the employee role.' ;
    rdfs:domain ind:OnboardingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:occFitnessProprietyStatus rdf:type rdf:Property ;
    rdfs:label 'Occ Fitness Propriety Status' ;
    rdfs:comment 'Status of OCC fitness and propriety onboarding check (for senior management and material risk taker roles): not applicable (non-covered role), in progress, cleared (approved), or flagged (requires additional review). Required for executive officers, directors, and key control function roles in federally chartered banks.' ;
    rdfs:domain ind:OnboardingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryClearanceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Clearance Required Flag' ;
    rdfs:comment 'Indicates whether the role requires regulatory clearance or approval before the employee can begin work (e.g., FINRA registration, OCC fitness and propriety approval, Federal Reserve Board approval for bank holding company officers). True if regulatory clearance required, false otherwise.' ;
    rdfs:domain ind:OnboardingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:separationDate rdf:type rdf:Property ;
    rdfs:label 'Separation Date' ;
    rdfs:comment 'Official last working day or termination date for the employee (for offboarding events). Null for onboarding events.' ;
    rdfs:domain ind:OnboardingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:soxDay1ControlStatus rdf:type rdf:Property ;
    rdfs:label 'Sox Day1 Control Status' ;
    rdfs:comment 'Status of SOX Day-1 control testing for new hire onboarding: not applicable (offboarding or non-SOX role), passed (controls effective), failed (control deficiency identified), or pending (testing in progress). Validates that access provisioning, segregation of duties, and background checks were completed before system access was granted.' ;
    rdfs:domain ind:OnboardingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxDay1ControlTestDate rdf:type rdf:Property ;
    rdfs:label 'Sox Day1 Control Test Date' ;
    rdfs:comment 'Date when SOX Day-1 control testing was performed and documented. Required for SOX compliance audit trails.' ;
    rdfs:domain ind:OnboardingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:systemAccessProvisioningDate rdf:type rdf:Property ;
    rdfs:label 'System Access Provisioning Date' ;
    rdfs:comment 'Date when system access and entitlements were provisioned or revoked. Used for SOX Day-1 control testing and access review audit trails.' ;
    rdfs:domain ind:OnboardingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:systemAccessProvisioningStatus rdf:type rdf:Property ;
    rdfs:label 'System Access Provisioning Status' ;
    rdfs:comment 'Status of system access and entitlement provisioning milestone: not started, in progress, provisioned (access granted), or revoked (access removed for offboarding). Critical for SOX IT General Controls (ITGC) and segregation of duties.' ;
    rdfs:domain ind:OnboardingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Target Completion Date' ;
    rdfs:comment 'Planned or target date by which all onboarding or offboarding milestones should be completed. Used for Service Level Agreement (SLA) tracking and workforce planning.' ;
    rdfs:domain ind:OnboardingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:parentOrgUnitId rdf:type rdf:Property ;
    rdfs:label 'Parent Org Unit Id' ;
    rdfs:comment 'Reference to the parent organizational unit in the hierarchy. Null for top-level entities. Enables multi-level org hierarchy traversal for management reporting and cost allocation.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:alcoReporting rdf:type rdf:Property ;
    rdfs:label 'Alco Reporting' ;
    rdfs:comment 'Indicates whether this unit is included in ALCO reporting for asset-liability management and liquidity risk monitoring.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:budgetAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Amount' ;
    rdfs:comment 'Annual operating budget allocated to the organizational unit in the base currency. Used for financial planning and variance analysis.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Budget Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the budget amount.' ;
    rdfs:domain ind:Hr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactEmail rdf:type rdf:Property ;
    rdfs:label 'Contact Email' ;
    rdfs:comment 'Primary email address for organizational unit inquiries and official communications.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPhone rdf:type rdf:Property ;
    rdfs:label 'Contact Phone' ;
    rdfs:comment 'Primary phone number for organizational unit contact.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:establishmentDate rdf:type rdf:Property ;
    rdfs:label 'Establishment Date' ;
    rdfs:comment 'Date when the organizational unit was originally established or incorporated.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:glCostCenterCode rdf:type rdf:Property ;
    rdfs:label 'Gl Cost Center Code' ;
    rdfs:comment 'General Ledger cost center code for financial accounting and Funds Transfer Pricing (FTP) allocation. Links organizational unit to GL hierarchy.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headcountFte rdf:type rdf:Property ;
    rdfs:label 'Headcount Fte' ;
    rdfs:comment 'Current full-time equivalent headcount allocated to this organizational unit. Used for workforce planning and regulatory headcount reporting.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hierarchyPath rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Path' ;
    rdfs:comment 'Materialized path representing the full lineage from root to this unit (e.g., /1/5/23/). Enables efficient ancestor and descendant queries.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isProfitCenter rdf:type rdf:Property ;
    rdfs:label 'Is Profit Center' ;
    rdfs:comment 'Indicates whether this organizational unit is designated as a profit center for financial performance measurement and P&L attribution.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRegulatoryEntity rdf:type rdf:Property ;
    rdfs:label 'Is Regulatory Entity' ;
    rdfs:comment 'Indicates whether this unit is a separately regulated legal entity requiring independent regulatory reporting (CCAR, DFAST, Basel III).' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lei rdf:type rdf:Property ;
    rdfs:label 'Lei' ;
    rdfs:comment 'ISO 17442 Legal Entity Identifier for regulatory reporting. Required for legal entities engaged in financial transactions. Used in CCAR, DFAST, and Basel III reporting.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orgUnitDescription rdf:type rdf:Property ;
    rdfs:label 'Org Unit Description' ;
    rdfs:comment 'Detailed description of the organizational unit\'s purpose, responsibilities, and scope of operations.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:region rdf:type rdf:Property ;
    rdfs:label 'Region' ;
    rdfs:comment 'Geographic region classification for management reporting and regional performance analysis.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorySegment rdf:type rdf:Property ;
    rdfs:label 'Regulatory Segment' ;
    rdfs:comment 'Regulatory classification for capital adequacy and risk-weighted asset (RWA) calculation under Basel III framework.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxScope rdf:type rdf:Property ;
    rdfs:label 'Sox Scope' ;
    rdfs:comment 'Indicates whether this organizational unit is within the scope of SOX 404 internal controls testing and certification.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unitCode rdf:type rdf:Property ;
    rdfs:label 'Unit Code' ;
    rdfs:comment 'Business identifier code for the organizational unit. Used in external reporting and system integrations.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitName rdf:type rdf:Property ;
    rdfs:label 'Unit Name' ;
    rdfs:comment 'Full legal or business name of the organizational unit.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitShortName rdf:type rdf:Property ;
    rdfs:label 'Unit Short Name' ;
    rdfs:comment 'Abbreviated name or acronym for the organizational unit used in reports and displays.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitStatus rdf:type rdf:Property ;
    rdfs:label 'Unit Status' ;
    rdfs:comment 'Current operational status of the organizational unit in its lifecycle.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitType rdf:type rdf:Property ;
    rdfs:label 'Unit Type' ;
    rdfs:comment 'Classification of the organizational unit within the hierarchy structure. Determines reporting and governance requirements.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payrollRecordId rdf:type rdf:Property ;
    rdfs:label 'Payroll Record Id' ;
    rdfs:comment 'Unique identifier for the payroll record. Primary key for this entity.' ;
    rdfs:domain ind:Hr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PayrollRecord .

ind:payrollRunId rdf:type rdf:Property ;
    rdfs:label 'Payroll Run Id' ;
    rdfs:comment 'Reference to the payroll batch run that generated this record. Used for grouping all payroll records processed in the same cycle.' ;
    rdfs:domain ind:Hr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PayrollRun .

ind:allowanceAmount rdf:type rdf:Property ;
    rdfs:label 'Allowance Amount' ;
    rdfs:comment 'Total allowances paid during this pay period, such as housing, transportation, or meal allowances.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bankAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Bank Account Number' ;
    rdfs:comment 'Employee bank account number for direct deposit. Encrypted and restricted access for payroll processing only.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankAccountType rdf:type rdf:Property ;
    rdfs:label 'Bank Account Type' ;
    rdfs:comment 'Type of bank account for direct deposit (checking or savings).' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankRoutingNumber rdf:type rdf:Property ;
    rdfs:label 'Bank Routing Number' ;
    rdfs:comment 'Nine-digit ABA routing number identifying the financial institution for direct deposit.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseSalaryAmount rdf:type rdf:Property ;
    rdfs:label 'Base Salary Amount' ;
    rdfs:comment 'The base salary or regular wages earned during the pay period, excluding overtime, bonuses, and other supplemental pay.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bonusAmount rdf:type rdf:Property ;
    rdfs:label 'Bonus Amount' ;
    rdfs:comment 'Discretionary or performance-based bonus paid during this pay period.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dentalInsurancePremium rdf:type rdf:Property ;
    rdfs:label 'Dental Insurance Premium' ;
    rdfs:comment 'Employee portion of dental insurance premium deducted from gross pay.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:federalIncomeTaxWithheld rdf:type rdf:Property ;
    rdfs:label 'Federal Income Tax Withheld' ;
    rdfs:comment 'Amount of federal income tax withheld from gross pay based on employee W-4 elections.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fsaContribution rdf:type rdf:Property ;
    rdfs:label 'Fsa Contribution' ;
    rdfs:comment 'Employee pre-tax contribution to Flexible Spending Account (FSA) for healthcare or dependent care expenses.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:garnishmentAmount rdf:type rdf:Property ;
    rdfs:label 'Garnishment Amount' ;
    rdfs:comment 'Court-ordered wage garnishment deducted from net pay for child support, tax levies, or other legal obligations.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossPayAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Pay Amount' ;
    rdfs:comment 'Total gross pay before any deductions, including base salary, overtime, bonuses, commissions, and allowances.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:healthInsurancePremium rdf:type rdf:Property ;
    rdfs:label 'Health Insurance Premium' ;
    rdfs:comment 'Employee portion of health insurance premium deducted from gross pay, typically pre-tax under Section 125 cafeteria plan.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hsaContribution rdf:type rdf:Property ;
    rdfs:label 'Hsa Contribution' ;
    rdfs:comment 'Employee pre-tax contribution to Health Savings Account (HSA) deducted from gross pay.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loanRepaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Loan Repayment Amount' ;
    rdfs:comment 'Employee loan repayment deducted from net pay for company-issued loans or advances.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:localIncomeTaxWithheld rdf:type rdf:Property ;
    rdfs:label 'Local Income Tax Withheld' ;
    rdfs:comment 'Amount of local or municipal income tax withheld from gross pay, if applicable.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:medicareTaxWithheld rdf:type rdf:Property ;
    rdfs:label 'Medicare Tax Withheld' ;
    rdfs:comment 'Amount of Medicare tax (FICA) withheld from gross pay, calculated as 1.45% of all wages, plus additional 0.9% for high earners.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netPayAmount rdf:type rdf:Property ;
    rdfs:label 'Net Pay Amount' ;
    rdfs:comment 'Final take-home pay after all pre-tax deductions, tax withholdings, and post-tax deductions. This is the amount disbursed to the employee.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otherPosttaxDeductions rdf:type rdf:Property ;
    rdfs:label 'Other Posttax Deductions' ;
    rdfs:comment 'Sum of all other post-tax deductions not otherwise categorized, such as union dues, charitable contributions, or Roth 401k.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otherPretaxDeductions rdf:type rdf:Property ;
    rdfs:label 'Other Pretax Deductions' ;
    rdfs:comment 'Sum of all other pre-tax deductions not otherwise categorized, such as commuter benefits or supplemental insurance.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overtimeAmount rdf:type rdf:Property ;
    rdfs:label 'Overtime Amount' ;
    rdfs:comment 'Total overtime pay earned during the pay period, typically calculated at 1.5x or 2x the regular hourly rate.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overtimeHours rdf:type rdf:Property ;
    rdfs:label 'Overtime Hours' ;
    rdfs:comment 'Total number of overtime hours worked during the pay period.' ;
    rdfs:domain ind:Hr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payFrequency rdf:type rdf:Property ;
    rdfs:label 'Pay Frequency' ;
    rdfs:comment 'The frequency at which the employee is paid (weekly, bi-weekly, semi-monthly, monthly).' ;
    rdfs:domain ind:Hr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Pay Period End Date' ;
    rdfs:comment 'The last day of the pay period covered by this payroll record.' ;
    rdfs:domain ind:Hr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:payPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Pay Period Start Date' ;
    rdfs:comment 'The first day of the pay period covered by this payroll record.' ;
    rdfs:domain ind:Hr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:payrollStatus rdf:type rdf:Property ;
    rdfs:label 'Payroll Status' ;
    rdfs:comment 'Current processing status of this payroll record in the payroll lifecycle.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retirementContributionPretax rdf:type rdf:Property ;
    rdfs:label 'Retirement Contribution Pretax' ;
    rdfs:comment 'Employee pre-tax contribution to retirement plan (401k, 403b) deducted from gross pay before tax calculation.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:socialSecurityTaxWithheld rdf:type rdf:Property ;
    rdfs:label 'Social Security Tax Withheld' ;
    rdfs:comment 'Amount of Social Security tax (FICA) withheld from gross pay, calculated as 6.2% of wages up to the annual wage base limit.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stateIncomeTaxWithheld rdf:type rdf:Property ;
    rdfs:label 'State Income Tax Withheld' ;
    rdfs:comment 'Amount of state income tax withheld from gross pay based on state tax regulations and employee elections.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPosttaxDeductions rdf:type rdf:Property ;
    rdfs:label 'Total Posttax Deductions' ;
    rdfs:comment 'Sum of all post-tax deductions including garnishments, loan repayments, and other voluntary deductions.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPretaxDeductions rdf:type rdf:Property ;
    rdfs:label 'Total Pretax Deductions' ;
    rdfs:comment 'Sum of all pre-tax deductions including retirement, health insurance, HSA, FSA, and other pre-tax benefits.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalTaxWithheld rdf:type rdf:Property ;
    rdfs:label 'Total Tax Withheld' ;
    rdfs:comment 'Sum of all tax withholdings including federal, state, local, Social Security, and Medicare taxes.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:visionInsurancePremium rdf:type rdf:Property ;
    rdfs:label 'Vision Insurance Premium' ;
    rdfs:comment 'Employee portion of vision insurance premium deducted from gross pay.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceReviewId rdf:type rdf:Property ;
    rdfs:label 'Performance Review Id' ;
    rdfs:comment 'Unique identifier for the performance review record.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryPerformanceEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Performance Employee Id' ;
    rdfs:comment 'Identifier of the employee being reviewed.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:reviewCycleId rdf:type rdf:Property ;
    rdfs:label 'Review Cycle Id' ;
    rdfs:comment 'Identifier of the review cycle or period (e.g., annual, mid-year, quarterly).' ;
    rdfs:domain ind:Hr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReviewCycle .

ind:balancedScorecardAlignment rdf:type rdf:Property ;
    rdfs:label 'Balanced Scorecard Alignment' ;
    rdfs:comment 'Primary balanced scorecard perspective that this review\'s goals align with.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bonusEligible rdf:type rdf:Property ;
    rdfs:label 'Bonus Eligible' ;
    rdfs:comment 'Indicates whether the employee is eligible for a performance-based bonus.' ;
    rdfs:domain ind:Hr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bonusPercentage rdf:type rdf:Property ;
    rdfs:label 'Bonus Percentage' ;
    rdfs:comment 'Recommended or approved bonus percentage based on performance rating and goal achievement.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calibrationDate rdf:type rdf:Property ;
    rdfs:label 'Calibration Date' ;
    rdfs:comment 'Date when the calibration session was completed for this review.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:calibrationStatus rdf:type rdf:Property ;
    rdfs:label 'Calibration Status' ;
    rdfs:comment 'Status of the calibration process to ensure rating consistency across the organization.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competencyRatingScore rdf:type rdf:Property ;
    rdfs:label 'Competency Rating Score' ;
    rdfs:comment 'Weighted average score of all competency assessments for the review period.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:developmentPlanCreated rdf:type rdf:Property ;
    rdfs:label 'Development Plan Created' ;
    rdfs:comment 'Indicates whether a development plan was created as part of this review.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:employeeSelfAssessment rdf:type rdf:Property ;
    rdfs:label 'Employee Self Assessment' ;
    rdfs:comment 'Self-assessment narrative provided by the employee regarding their performance.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goalAchievementScore rdf:type rdf:Property ;
    rdfs:label 'Goal Achievement Score' ;
    rdfs:comment 'Weighted average score of all individual goal achievements for the review period.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:highPotentialFlag rdf:type rdf:Property ;
    rdfs:label 'High Potential Flag' ;
    rdfs:comment 'Indicates whether the employee has been identified as high potential talent.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hrApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Hr Approval Date' ;
    rdfs:comment 'Date when the Human Resources department approved the performance review.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:managerComments rdf:type rdf:Property ;
    rdfs:label 'Manager Comments' ;
    rdfs:comment 'Narrative comments and feedback provided by the reviewing manager.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meritIncreaseEligible rdf:type rdf:Property ;
    rdfs:label 'Merit Increase Eligible' ;
    rdfs:comment 'Indicates whether the employee is eligible for a merit-based salary increase based on this review.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:meritIncreasePercentage rdf:type rdf:Property ;
    rdfs:label 'Merit Increase Percentage' ;
    rdfs:comment 'Recommended or approved merit increase percentage based on performance rating.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:organizationalObjectiveLinkage rdf:type rdf:Property ;
    rdfs:label 'Organizational Objective Linkage' ;
    rdfs:comment 'Description of how the employee\'s goals cascade from and support organizational strategic objectives.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallRating rdf:type rdf:Property ;
    rdfs:label 'Overall Rating' ;
    rdfs:comment 'Final overall performance rating assigned to the employee for the review period.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallRatingScore rdf:type rdf:Property ;
    rdfs:label 'Overall Rating Score' ;
    rdfs:comment 'Numeric score corresponding to the overall performance rating (e.g., 1.0 to 5.0 scale).' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pipInitiated rdf:type rdf:Property ;
    rdfs:label 'Pip Initiated' ;
    rdfs:comment 'Indicates whether a Performance Improvement Plan was initiated as a result of this review.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preCalibrationRating rdf:type rdf:Property ;
    rdfs:label 'Pre Calibration Rating' ;
    rdfs:comment 'Initial performance rating assigned before calibration adjustments.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rarocLinkedGoalFlag rdf:type rdf:Property ;
    rdfs:label 'Raroc Linked Goal Flag' ;
    rdfs:comment 'Indicates whether any of the employee\'s performance goals are linked to Risk-Adjusted Return on Capital (RAROC) metrics for incentive alignment.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewerSignatureDate rdf:type rdf:Property ;
    rdfs:label 'Reviewer Signature Date' ;
    rdfs:comment 'Date when the reviewing manager signed off on the performance review.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryDisclosureId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Disclosure Id' ;
    rdfs:comment 'Unique identifier for the regulatory disclosure record. Primary key.' ;
    rdfs:domain ind:RegulatoryDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalDisclosureRegulatoryDisclosureId rdf:type rdf:Property ;
    rdfs:label 'Original Disclosure Regulatory Disclosure Id' ;
    rdfs:comment 'Reference to the original regulatory disclosure record that this submission amends or corrects. Null if this is an original filing.' ;
    rdfs:domain ind:RegulatoryDisclosure ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryDisclosure .

ind:primaryRegulatoryEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Regulatory Employee Id' ;
    rdfs:comment 'Reference to the employee subject of this regulatory disclosure, if applicable to individual-level disclosures such as Material Risk Taker remuneration or FINRA U4/U5 filings.' ;
    rdfs:domain ind:RegulatoryDisclosure ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryRegulatoryPreparerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Regulatory Preparer Employee Id' ;
    rdfs:comment 'Reference to the employee who prepared or compiled the regulatory disclosure. Typically a Human Resources (HR) analyst, compliance officer, or regulatory reporting specialist.' ;
    rdfs:domain ind:RegulatoryDisclosure ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:attestationStatement rdf:type rdf:Property ;
    rdfs:label 'Attestation Statement' ;
    rdfs:comment 'The formal attestation or certification statement provided by the attesting officer, affirming the accuracy and completeness of the disclosure.' ;
    rdfs:domain ind:RegulatoryDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityClassification rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Classification' ;
    rdfs:comment 'The data classification level assigned to this disclosure record. Determines access controls and handling procedures. Aligns with organizational data classification policy.' ;
    rdfs:domain ind:RegulatoryDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclosureCategory rdf:type rdf:Property ;
    rdfs:label 'Disclosure Category' ;
    rdfs:comment 'High-level categorization of the disclosure subject matter. Groups disclosures by thematic area for reporting and compliance tracking purposes.' ;
    rdfs:domain ind:RegulatoryDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclosureDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Disclosure Document Url' ;
    rdfs:comment 'Reference URL or file path to the formal disclosure document or report submitted to the regulatory body. May point to document management system or secure file repository.' ;
    rdfs:domain ind:RegulatoryDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclosureType rdf:type rdf:Property ;
    rdfs:label 'Disclosure Type' ;
    rdfs:comment 'Type of regulatory disclosure being filed. Includes Equal Employment Opportunity (EEO-1), Veterans Employment (VETS-4212), Affordable Care Act (ACA) 1095-C, Material Risk Taker remuneration under CRD IV/EBA guidelines, Senior Manager Certification under regulatory regimes, and Financial Industry Regulatory Authority (FINRA) U4/U5 filings.' ;
    rdfs:domain ind:RegulatoryDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalEligibleDate rdf:type rdf:Property ;
    rdfs:label 'Disposal Eligible Date' ;
    rdfs:comment 'The date on which this disclosure record becomes eligible for disposal or archival per records retention policy. Format: yyyy-MM-dd. Calculated as submission_date plus retention_period_years.' ;
    rdfs:domain ind:RegulatoryDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:internalControlTestDate rdf:type rdf:Property ;
    rdfs:label 'Internal Control Test Date' ;
    rdfs:comment 'The date on which internal controls over the disclosure process were last tested. Format: yyyy-MM-dd. Relevant for SOX compliance and internal audit.' ;
    rdfs:domain ind:RegulatoryDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:internalControlTestResult rdf:type rdf:Property ;
    rdfs:label 'Internal Control Test Result' ;
    rdfs:comment 'The outcome of the most recent internal control test over the disclosure process. Used for SOX compliance and audit reporting.' ;
    rdfs:domain ind:RegulatoryDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorComments rdf:type rdf:Property ;
    rdfs:label 'Regulator Comments' ;
    rdfs:comment 'Comments, feedback, or findings provided by the regulatory body in response to the disclosure. May include requests for clarification, additional information, or corrective actions.' ;
    rdfs:domain ind:RegulatoryDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorResponseDate rdf:type rdf:Property ;
    rdfs:label 'Regulator Response Date' ;
    rdfs:comment 'The date on which the regulatory body provided a formal response, acceptance, or rejection of the disclosure. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:RegulatoryDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:submissionStatus rdf:type rdf:Property ;
    rdfs:label 'Submission Status' ;
    rdfs:comment 'Current lifecycle status of the regulatory disclosure submission. Tracks progression from draft through regulatory acceptance or rejection. [ENUM-REF-CANDIDATE: Draft|Pending Review|Submitted|Accepted|Rejected|Amended|Withdrawn — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RegulatoryDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:successionPlanId rdf:type rdf:Property ;
    rdfs:label 'Succession Plan Id' ;
    rdfs:comment 'Unique identifier for the succession planning record. Primary key.' ;
    rdfs:domain ind:SuccessionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primarySuccessionSuccessorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Succession Successor Employee Id' ;
    rdfs:comment 'Reference to the primary identified successor employee for the target position.' ;
    rdfs:domain ind:SuccessionPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternarySuccessionEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Succession Employee Id' ;
    rdfs:comment 'Identifier of the system user or HR professional who originally created the succession plan record.' ;
    rdfs:domain ind:SuccessionPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quinarySuccessionLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quinary Succession Last Modified By User Employee Id' ;
    rdfs:comment 'Identifier of the system user who most recently modified the succession plan record.' ;
    rdfs:domain ind:SuccessionPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiarySuccessionIncumbentEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Succession Incumbent Employee Id' ;
    rdfs:comment 'Reference to the current employee occupying the target position for which succession is being planned.' ;
    rdfs:domain ind:SuccessionPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:alcoReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Alco Reporting Flag' ;
    rdfs:comment 'Indicator whether this succession plan is reported to the Asset-Liability Committee due to the positions impact on balance sheet management or liquidity risk.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:boardReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Board Reporting Flag' ;
    rdfs:comment 'Indicator whether this succession plan is subject to board-level reporting and oversight, typically for executive or critical roles.' ;
    rdfs:domain ind:Hr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:criticalPositionFlag rdf:type rdf:Property ;
    rdfs:label 'Critical Position Flag' ;
    rdfs:comment 'Indicator whether the target position is classified as business-critical, requiring heightened succession planning rigor and board oversight.' ;
    rdfs:domain ind:Hr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:developmentPlanDescription rdf:type rdf:Property ;
    rdfs:label 'Development Plan Description' ;
    rdfs:comment 'Detailed narrative describing the development actions, training programs, stretch assignments, and experiences required to prepare the successor for the target role.' ;
    rdfs:domain ind:SuccessionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:developmentPlanStatus rdf:type rdf:Property ;
    rdfs:label 'Development Plan Status' ;
    rdfs:comment 'Current execution status of the development plan activities for the identified successor.' ;
    rdfs:domain ind:SuccessionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incumbentExpectedDepartureDate rdf:type rdf:Property ;
    rdfs:label 'Incumbent Expected Departure Date' ;
    rdfs:comment 'Anticipated date when the current incumbent is expected to vacate the position due to retirement, promotion, or other transition.' ;
    rdfs:domain ind:SuccessionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:keyPersonRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Key Person Risk Flag' ;
    rdfs:comment 'Indicator whether the position represents a key person risk where departure or unavailability would materially impact business operations or strategic objectives.' ;
    rdfs:domain ind:Hr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:planEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Plan Effective Date' ;
    rdfs:comment 'Date when the succession plan becomes active and enters into force for governance and reporting purposes.' ;
    rdfs:domain ind:Hr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planEndDate rdf:type rdf:Property ;
    rdfs:label 'Plan End Date' ;
    rdfs:comment 'Date when the succession plan is scheduled to conclude or be superseded, typically aligned with the transition completion or plan refresh cycle.' ;
    rdfs:domain ind:Hr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:readinessAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Readiness Assessment Date' ;
    rdfs:comment 'Date when the successor readiness level was last assessed or reviewed by management.' ;
    rdfs:domain ind:SuccessionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:readinessLevel rdf:type rdf:Property ;
    rdfs:label 'Readiness Level' ;
    rdfs:comment 'Assessment of how soon the identified successor will be ready to assume the target role, based on skills, experience, and development progress.' ;
    rdfs:domain ind:SuccessionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionRiskRating rdf:type rdf:Property ;
    rdfs:label 'Retention Risk Rating' ;
    rdfs:comment 'Assessment of the risk that the current incumbent or identified successor may leave the organization, requiring accelerated succession planning.' ;
    rdfs:domain ind:Hr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:successionPoolTier rdf:type rdf:Property ;
    rdfs:label 'Succession Pool Tier' ;
    rdfs:comment 'Classification tier indicating the successors position within the broader talent pool and their priority for development investment.' ;
    rdfs:domain ind:Hr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetTransitionDate rdf:type rdf:Property ;
    rdfs:label 'Target Transition Date' ;
    rdfs:comment 'Planned date by which the successor should be ready to assume the target role, aligning with business continuity requirements.' ;
    rdfs:domain ind:SuccessionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:timeAttendanceId rdf:type rdf:Property ;
    rdfs:label 'Time Attendance Id' ;
    rdfs:comment 'Unique identifier for the time and attendance record. Primary key for this entity.' ;
    rdfs:domain ind:TimeAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryTimeEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Time Employee Id' ;
    rdfs:comment 'Identifier of the employee to whom this time and attendance record belongs. Links to the employee master data.' ;
    rdfs:domain ind:TimeAttendance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:absenceHours rdf:type rdf:Property ;
    rdfs:label 'Absence Hours' ;
    rdfs:comment 'Number of hours recorded as absence or leave for this time entry, deducted from available leave balances.' ;
    rdfs:domain ind:TimeAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:absenceTypeCode rdf:type rdf:Property ;
    rdfs:label 'Absence Type Code' ;
    rdfs:comment 'Code identifying the type of absence when the time entry represents leave or absence (e.g., sick leave, vacation, personal leave, FMLA).' ;
    rdfs:domain ind:TimeAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activityCode rdf:type rdf:Property ;
    rdfs:label 'Activity Code' ;
    rdfs:comment 'Code identifying the specific activity or task performed during the work period, used for detailed labor analytics and productivity tracking.' ;
    rdfs:domain ind:TimeAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breakHours rdf:type rdf:Property ;
    rdfs:label 'Break Hours' ;
    rdfs:comment 'Total duration of breaks taken during the work period, which may be paid or unpaid depending on policy and jurisdiction.' ;
    rdfs:domain ind:TimeAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clockInTimestamp rdf:type rdf:Property ;
    rdfs:label 'Clock In Timestamp' ;
    rdfs:comment 'Precise date and time when the employee clocked in or started their work period, captured from time clock or system entry.' ;
    rdfs:domain ind:TimeAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:clockOutTimestamp rdf:type rdf:Property ;
    rdfs:label 'Clock Out Timestamp' ;
    rdfs:comment 'Precise date and time when the employee clocked out or ended their work period, captured from time clock or system entry.' ;
    rdfs:domain ind:TimeAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:doubleTimeHours rdf:type rdf:Property ;
    rdfs:label 'Double Time Hours' ;
    rdfs:comment 'Number of hours worked that qualify for double-time premium pay, typically for work on holidays or beyond a certain overtime threshold.' ;
    rdfs:domain ind:TimeAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:earlyDepartureFlag rdf:type rdf:Property ;
    rdfs:label 'Early Departure Flag' ;
    rdfs:comment 'Indicator of whether the employee departed early relative to their scheduled end time, used for attendance policy enforcement.' ;
    rdfs:domain ind:TimeAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:flsaOvertimeEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Flsa Overtime Eligible Flag' ;
    rdfs:comment 'Indicator of whether the employee is eligible for FLSA overtime premium pay for hours worked beyond the standard threshold.' ;
    rdfs:domain ind:TimeAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lateArrivalFlag rdf:type rdf:Property ;
    rdfs:label 'Late Arrival Flag' ;
    rdfs:comment 'Indicator of whether the employee arrived late relative to their scheduled start time, used for attendance policy enforcement.' ;
    rdfs:domain ind:TimeAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paidTimeOffHours rdf:type rdf:Property ;
    rdfs:label 'Paid Time Off Hours' ;
    rdfs:comment 'Number of paid time off hours used for this time entry, drawn from the employee\'s PTO balance.' ;
    rdfs:domain ind:TimeAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payrollProcessingDate rdf:type rdf:Property ;
    rdfs:label 'Payroll Processing Date' ;
    rdfs:comment 'Date when this time entry was processed through payroll and included in employee compensation calculations.' ;
    rdfs:domain ind:TimeAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:projectCode rdf:type rdf:Property ;
    rdfs:label 'Project Code' ;
    rdfs:comment 'Project or work order code to which the time should be charged, enabling project-based time tracking and cost allocation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regularHours rdf:type rdf:Property ;
    rdfs:label 'Regular Hours' ;
    rdfs:comment 'Number of regular work hours recorded for this time entry, typically within standard contracted hours and not subject to overtime premium.' ;
    rdfs:domain ind:TimeAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shiftCode rdf:type rdf:Property ;
    rdfs:label 'Shift Code' ;
    rdfs:comment 'Code identifying the scheduled shift or work schedule pattern for this time entry (e.g., day shift, night shift, rotating schedule).' ;
    rdfs:domain ind:TimeAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeEntryNumber rdf:type rdf:Property ;
    rdfs:label 'Time Entry Number' ;
    rdfs:comment 'Business identifier for the time entry record, typically system-generated or user-assigned for tracking and reference purposes.' ;
    rdfs:domain ind:TimeAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeEntrySource rdf:type rdf:Property ;
    rdfs:label 'Time Entry Source' ;
    rdfs:comment 'Source system or method through which the time entry was captured (time clock, manual entry, mobile app, etc.).' ;
    rdfs:domain ind:TimeAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeEntryStatus rdf:type rdf:Property ;
    rdfs:label 'Time Entry Status' ;
    rdfs:comment 'Current lifecycle status of the time entry record indicating its position in the approval and processing workflow.' ;
    rdfs:domain ind:TimeAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeEntryType rdf:type rdf:Property ;
    rdfs:label 'Time Entry Type' ;
    rdfs:comment 'Classification of the time entry indicating the nature of hours worked or absence recorded (regular hours, overtime, leave, etc.).' ;
    rdfs:domain ind:TimeAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalHoursWorked rdf:type rdf:Property ;
    rdfs:label 'Total Hours Worked' ;
    rdfs:comment 'Total number of hours worked for this time entry, calculated as the sum of regular, overtime, and double-time hours.' ;
    rdfs:domain ind:TimeAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unpaidLeaveHours rdf:type rdf:Property ;
    rdfs:label 'Unpaid Leave Hours' ;
    rdfs:comment 'Number of unpaid leave hours recorded for this time entry, not compensated and not deducted from paid leave balances.' ;
    rdfs:domain ind:TimeAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workDate rdf:type rdf:Property ;
    rdfs:label 'Work Date' ;
    rdfs:comment 'The calendar date on which the work hours or attendance event occurred. Primary business event date for time tracking.' ;
    rdfs:domain ind:TimeAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:workforcePlanId rdf:type rdf:Property ;
    rdfs:label 'Workforce Plan Id' ;
    rdfs:comment 'Unique identifier for the workforce and succession planning record.' ;
    rdfs:domain ind:WorkforcePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryWorkforceSuccessorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Workforce Successor Employee Id' ;
    rdfs:comment 'Reference to the designated successor candidate employee for succession planning.' ;
    rdfs:domain ind:WorkforcePlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assumedAttritionCount rdf:type rdf:Property ;
    rdfs:label 'Assumed Attrition Count' ;
    rdfs:comment 'Assumed number of employee departures (voluntary and involuntary) during the planning period.' ;
    rdfs:domain ind:WorkforcePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assumedAttritionRatePct rdf:type rdf:Property ;
    rdfs:label 'Assumed Attrition Rate Pct' ;
    rdfs:comment 'Assumed voluntary and involuntary attrition rate as a percentage for the planning period.' ;
    rdfs:domain ind:WorkforcePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetEnvelopeAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Envelope Amount' ;
    rdfs:comment 'Total budget allocation for workforce costs (salaries, benefits, hiring) for this plan in the specified currency.' ;
    rdfs:domain ind:WorkforcePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentHeadcountSupply rdf:type rdf:Property ;
    rdfs:label 'Current Headcount Supply' ;
    rdfs:comment 'Current available headcount supply in Full-Time Equivalent (FTE) at the start of the planning period.' ;
    rdfs:domain ind:WorkforcePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:developmentActionPlan rdf:type rdf:Property ;
    rdfs:label 'Development Action Plan' ;
    rdfs:comment 'Summary of planned development actions, training, rotations, or experiences required to prepare the successor for the role.' ;
    rdfs:domain ind:WorkforcePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headcountGap rdf:type rdf:Property ;
    rdfs:label 'Headcount Gap' ;
    rdfs:comment 'Calculated gap between projected demand and current supply (demand minus supply) in Full-Time Equivalent (FTE).' ;
    rdfs:domain ind:WorkforcePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedHiringActions rdf:type rdf:Property ;
    rdfs:label 'Planned Hiring Actions' ;
    rdfs:comment 'Number of planned external hiring actions to address the workforce gap.' ;
    rdfs:domain ind:WorkforcePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedInternalMoves rdf:type rdf:Property ;
    rdfs:label 'Planned Internal Moves' ;
    rdfs:comment 'Number of planned internal transfers or promotions to address the workforce gap.' ;
    rdfs:domain ind:WorkforcePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:planningHorizon rdf:type rdf:Property ;
    rdfs:label 'Planning Horizon' ;
    rdfs:comment 'Time horizon for the workforce plan: short-term (0-1 year), medium-term (1-3 years), or long-term (3-5 years).' ;
    rdfs:domain ind:WorkforcePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectedHeadcountDemand rdf:type rdf:Property ;
    rdfs:label 'Projected Headcount Demand' ;
    rdfs:comment 'Forecasted headcount demand in Full-Time Equivalent (FTE) for the planning period and scenario.' ;
    rdfs:domain ind:WorkforcePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:readinessHorizon rdf:type rdf:Property ;
    rdfs:label 'Readiness Horizon' ;
    rdfs:comment 'Time horizon for successor readiness: ready now, ready in 1-2 years, ready in 3-5 years, or not ready.' ;
    rdfs:domain ind:WorkforcePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Coverage Assignment Id' ;
    rdfs:comment 'Unique surrogate identifier for each investment banking coverage assignment record in the Silver Layer lakehouse. Primary key for this entity.' ;
    rdfs:domain ind:Investment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CoverageAssignment .

ind:clientMandateId rdf:type rdf:Property ;
    rdfs:label 'Client Mandate Id' ;
    rdfs:comment 'Foreign key linking to wealth.client_mandate. Business justification: Coverage bankers in investment banking coordinate with wealth management mandates for the same client, ensuring holistic relationship management. Real business process: cross-LOB client coverage coord' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClientMandate .

ind:primaryCoverageEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Coverage Employee Id' ;
    rdfs:comment 'Identifier of the investment banking coverage banker (relationship manager or sector specialist) assigned to the client. Links to the banker/employee master record.' ;
    rdfs:domain ind:CoverageAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryCoverageApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Coverage Approved By Employee Id' ;
    rdfs:comment 'Identifier of the senior officer (e.g., Head of Coverage, Group Head) who approved this coverage assignment. Supports governance, audit trail, and segregation of duties requirements under SOX.' ;
    rdfs:domain ind:CoverageAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:bankerTitle rdf:type rdf:Property ;
    rdfs:label 'Banker Title' ;
    rdfs:comment 'The seniority title of the assigned coverage banker at the time of assignment (e.g., Analyst, Associate, Vice President, Director, Managing Director). Relevant for deal origination credit allocation and client relationship governance.' ;
    rdfs:domain ind:CoverageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientTier rdf:type rdf:Property ;
    rdfs:label 'Client Tier' ;
    rdfs:comment 'Strategic tier classification of the client within the IB coverage model, reflecting the client\'s revenue potential and strategic importance to the bank (e.g., Tier 1 = top global corporates, Tier 3 = emerging/developing relationships).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageNotes rdf:type rdf:Property ;
    rdfs:label 'Coverage Notes' ;
    rdfs:comment 'Free-text notes recorded by the coverage banker or coverage manager regarding the client relationship, strategic priorities, or special circumstances of this assignment. Contains sensitive business development information.' ;
    rdfs:domain ind:CoverageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageOffice rdf:type rdf:Property ;
    rdfs:label 'Coverage Office' ;
    rdfs:comment 'The physical office or booking center from which the coverage banker operates (e.g., New York, London, Hong Kong). Used for regulatory jurisdiction assignment and internal cost allocation.' ;
    rdfs:domain ind:CoverageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageRole rdf:type rdf:Property ;
    rdfs:label 'Coverage Role' ;
    rdfs:comment 'The functional role of the assigned banker in the client coverage model. Primary bankers own the overall relationship; secondary bankers provide support; sector and product specialists contribute domain expertise. [ENUM-REF-CANDIDATE: primary|secondary|sector_specialist|product_specialist|co_coverage|advisory — promote to reference product]' ;
    rdfs:domain ind:CoverageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageTeamName rdf:type rdf:Property ;
    rdfs:label 'Coverage Team Name' ;
    rdfs:comment 'Name of the investment banking coverage team or group responsible for this assignment (e.g., \'Global TMT Coverage\', \'Healthcare Investment Banking\'). Supports team-level performance reporting and deal pipeline management.' ;
    rdfs:domain ind:CoverageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveUntilDate rdf:type rdf:Property ;
    rdfs:label 'Effective Until Date' ;
    rdfs:comment 'The date on which the coverage assignment is scheduled to end or was terminated. Null for open-ended assignments. Used for historical coverage analysis and transition planning.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:geographyCountryCode rdf:type rdf:Property ;
    rdfs:label 'Geography Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the primary country of the client entity for this coverage assignment. Used for regulatory jurisdiction mapping and cross-border compliance.' ;
    rdfs:domain ind:CoverageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isLeadCoverage rdf:type rdf:Property ;
    rdfs:label 'Is Lead Coverage' ;
    rdfs:comment 'Flag indicating whether this banker is the designated lead coverage officer for the client relationship. Only one banker per client should have this flag set to True at any given time. Drives primary accountability and escalation routing.' ;
    rdfs:domain ind:CoverageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSectorSpecialist rdf:type rdf:Property ;
    rdfs:label 'Is Sector Specialist' ;
    rdfs:comment 'Flag indicating whether the assigned banker is acting in a sector specialist capacity rather than a generalist relationship management role. Sector specialists provide deep industry expertise and are typically engaged on specific transaction types.' ;
    rdfs:domain ind:CoverageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kycExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Kyc Expiry Date' ;
    rdfs:comment 'The date on which the client\'s KYC documentation expires and must be renewed. Coverage bankers are alerted prior to this date to initiate KYC refresh. Supports AML compliance and regulatory reporting.' ;
    rdfs:domain ind:CoverageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastClientInteractionDate rdf:type rdf:Property ;
    rdfs:label 'Last Client Interaction Date' ;
    rdfs:comment 'The most recent date on which the coverage banker had a documented interaction with the client (meeting, call, pitch presentation). Used for CRM activity monitoring and relationship health assessment.' ;
    rdfs:domain ind:CoverageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lobName rdf:type rdf:Property ;
    rdfs:label 'Lob Name' ;
    rdfs:comment 'The investment banking Line of Business (LOB) associated with this coverage assignment, indicating the primary product focus area (e.g., M&A Advisory, Equity Capital Markets (ECM), Debt Capital Markets (DCM), Leveraged Finance, Syndicated Lending). [ENUM-REF-CANDIDATE: M&A_advisory|ECM|DCM|leveraged_finance|syndicated_lending|restructuring|corporate_finance — promote to reference product]' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mandateCount rdf:type rdf:Property ;
    rdfs:label 'Mandate Count' ;
    rdfs:comment 'The number of active IB mandates (M&A, IPO, DCM, etc.) currently associated with this coverage assignment at the time of record. Provides a snapshot of deal pipeline depth for this banker-client relationship.' ;
    rdfs:domain ind:CoverageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originationCreditPct rdf:type rdf:Property ;
    rdfs:label 'Origination Credit Pct' ;
    rdfs:comment 'The percentage of deal origination credit allocated to this banker for revenue attribution purposes. Multiple bankers may share credit across a single client relationship; percentages across all active assignments for a client should sum to 100. Used in RAROC and banker performance measurement.' ;
    rdfs:domain ind:CoverageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pitchBookCount rdf:type rdf:Property ;
    rdfs:label 'Pitch Book Count' ;
    rdfs:comment 'The number of pitch books or marketing presentations delivered to this client under this coverage assignment. Tracks business development activity intensity and supports pipeline conversion analysis.' ;
    rdfs:domain ind:CoverageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:relationshipSinceDate rdf:type rdf:Property ;
    rdfs:label 'Relationship Since Date' ;
    rdfs:comment 'The date on which the bank first established a formal investment banking relationship with this client entity. Distinct from the coverage assignment effective date; reflects the longevity of the overall client relationship.' ;
    rdfs:domain ind:CoverageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revenueAttributionPct rdf:type rdf:Property ;
    rdfs:label 'Revenue Attribution Pct' ;
    rdfs:comment 'The percentage of total client-generated IB revenue attributed to this specific coverage assignment. Distinct from origination_credit_pct as it may reflect ongoing relationship management credit rather than deal origination credit alone.' ;
    rdfs:domain ind:CoverageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sectorName rdf:type rdf:Property ;
    rdfs:label 'Sector Name' ;
    rdfs:comment 'Human-readable name of the industry sector under which this coverage assignment is classified (e.g., TMT, Healthcare, Energy, Financials, Industrials). Aligns with GICS sector taxonomy. [ENUM-REF-CANDIDATE: TMT|healthcare|energy|financials|industrials|consumer|real_estate|utilities|materials — promote to reference product]' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subSectorName rdf:type rdf:Property ;
    rdfs:label 'Sub Sector Name' ;
    rdfs:comment 'More granular sub-sector classification within the primary sector (e.g., within TMT: Software, Semiconductors, Media; within Healthcare: Pharma, MedTech, Biotech). Supports specialist banker routing and deal origination attribution.' ;
    rdfs:domain ind:CoverageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealId rdf:type rdf:Property ;
    rdfs:label 'Deal Id' ;
    rdfs:comment 'Unique surrogate identifier for the investment banking deal or transaction mandate. Primary key for the deal entity, referenced by all downstream investment domain entities including mandate, valuation, offering, syndication, tombstone, and fee arrangement.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Deal .

ind:originationChannelId rdf:type rdf:Property ;
    rdfs:label 'Origination Channel Id' ;
    rdfs:comment 'Foreign key linking to channel.channel. Business justification: Investment deals are originated through specific banking channels (branch, digital, RM). Deal capture systems track origination channel for revenue attribution, channel profitability analysis, and reg' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:pipelineStageId rdf:type rdf:Property ;
    rdfs:label 'Pipeline Stage Id' ;
    rdfs:comment 'Foreign key linking to investment.pipeline_stage. Business justification: Deal has stage (STRING) attribute that references pipeline stages. Adding FK to pipeline_stage allows retrieval of full stage metadata (stage_name, probability_weighting_pct, average_duration_days, et' ;
    rdfs:domain ind:Investment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PipelineStage .

ind:targetIndustryCodeId rdf:type rdf:Property ;
    rdfs:label 'Target Industry Code Id' ;
    rdfs:comment 'Foreign key linking to reference.industry_code. Business justification: Industry classification drives sector concentration limits, credit portfolio segmentation, CECL modeling, and league table rankings. Target_industry_sector is denormalized industry name.' ;
    rdfs:domain ind:Deal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IndustryCode .

ind:teamLeadEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Team Lead Employee Id' ;
    rdfs:comment 'Identifier of the senior banker or managing director designated as the execution team lead for the deal. May differ from the coverage banker; responsible for day-to-day deal execution and client management during the transaction.' ;
    rdfs:domain ind:Deal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualClosingDate rdf:type rdf:Property ;
    rdfs:label 'Actual Closing Date' ;
    rdfs:comment 'The actual date on which the transaction legally closed and was completed. Populated upon deal closure; used for revenue recognition, tombstone generation, and post-deal performance analysis.' ;
    rdfs:domain ind:Deal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:announcementDate rdf:type rdf:Property ;
    rdfs:label 'Announcement Date' ;
    rdfs:comment 'The date on which the transaction was publicly announced to the market. Relevant for M&A and ECM transactions; triggers regulatory disclosure obligations and market impact analysis.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complexity rdf:type rdf:Property ;
    rdfs:label 'Complexity' ;
    rdfs:comment 'Qualitative assessment of the deal\'s structural and execution complexity, used for resource allocation, staffing decisions, and risk committee escalation thresholds. Assessed at origination and updated as deal structure evolves.' ;
    rdfs:domain ind:Deal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealCode rdf:type rdf:Property ;
    rdfs:label 'Deal Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier assigned to the deal at origination, used in pitch books, mandate letters, and client communications. Typically follows the investment bank\'s internal deal numbering convention (e.g., IB-2024-00123).' ;
    rdfs:domain ind:Deal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealDescription rdf:type rdf:Property ;
    rdfs:label 'Deal Description' ;
    rdfs:comment 'Free-text narrative description of the deal structure, strategic rationale, and key transaction terms. Used in pitch books, deal committee memos, and tombstone records. Contains sensitive deal information subject to information barrier controls.' ;
    rdfs:domain ind:Deal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealName rdf:type rdf:Property ;
    rdfs:label 'Deal Name' ;
    rdfs:comment 'Human-readable name or working title of the deal, often referencing the target company or project codename (e.g., \'Project Falcon — Acquisition of XYZ Corp\'). Used in internal pipeline reporting and pitch book headers.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealStatus rdf:type rdf:Property ;
    rdfs:label 'Deal Status' ;
    rdfs:comment 'Current operational status of the deal record. ACTIVE indicates the deal is in progress; CLOSED_WON indicates successful completion; CLOSED_LOST or WITHDRAWN indicates the deal did not proceed. Used for pipeline management and revenue forecasting.' ;
    rdfs:domain ind:Deal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealType rdf:type rdf:Property ;
    rdfs:label 'Deal Type' ;
    rdfs:comment 'Classification of the investment banking transaction by strategic category. Drives workflow, fee structure, and regulatory treatment. [ENUM-REF-CANDIDATE: M&A_BUY_SIDE|M&A_SELL_SIDE|ECM|DCM|LBO|RESTRUCTURING|SYNDICATED_LENDING|LEVERAGED_FINANCE|PROJECT_FINANCE|SPIN_OFF — promote to reference product]' ;
    rdfs:domain ind:Deal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedClosingDate rdf:type rdf:Property ;
    rdfs:label 'Expected Closing Date' ;
    rdfs:comment 'Projected date on which the transaction is expected to close or complete. Used for pipeline probability weighting, revenue forecasting, and resource scheduling. Updated as deal progresses through execution stages.' ;
    rdfs:domain ind:Deal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expectedFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Expected Fee Amount' ;
    rdfs:comment 'The estimated total advisory or underwriting fee expected to be earned upon deal completion, expressed in the deal currency. Used for revenue pipeline forecasting, banker incentive compensation, and ALCO revenue planning.' ;
    rdfs:domain ind:Deal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feeRateBps rdf:type rdf:Property ;
    rdfs:label 'Fee Rate Bps' ;
    rdfs:comment 'The advisory or underwriting fee expressed as a rate in basis points (BPS) of the deal size or enterprise value. Standard investment banking fee metric; used for benchmarking against market comparables and mandate negotiation.' ;
    rdfs:domain ind:Investment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isCrossBorder rdf:type rdf:Property ;
    rdfs:label 'Is Cross Border' ;
    rdfs:comment 'Flag indicating whether the transaction involves parties or assets in more than one country. Triggers additional regulatory review, FATCA/CRS reporting obligations, and cross-border M&A regulatory approval tracking.' ;
    rdfs:domain ind:Investment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPublicCompany rdf:type rdf:Property ;
    rdfs:label 'Is Public Company' ;
    rdfs:comment 'Flag indicating whether the target or issuer is a publicly listed company. Determines applicability of SEC disclosure requirements, public M&A rules (e.g., Williams Act), and public company audit standards.' ;
    rdfs:domain ind:Deal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lobCode rdf:type rdf:Property ;
    rdfs:label 'Lob Code' ;
    rdfs:comment 'Code identifying the investment banking line of business responsible for the deal (e.g., M&A Advisory, Equity Capital Markets, Debt Capital Markets, Leveraged Finance, Restructuring). Used for P&L attribution and management reporting.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mandateDate rdf:type rdf:Property ;
    rdfs:label 'Mandate Date' ;
    rdfs:comment 'The date on which the client formally awarded the mandate to the bank, typically evidenced by a signed engagement letter or mandate agreement. Triggers formal deal execution resourcing and fee accrual commencement.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originationDate rdf:type rdf:Property ;
    rdfs:label 'Origination Date' ;
    rdfs:comment 'The date on which the deal opportunity was first identified and entered into the pipeline system. Marks the start of the deal lifecycle and is used for pipeline aging analysis and banker performance attribution.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pipelineProbabilityPct rdf:type rdf:Property ;
    rdfs:label 'Pipeline Probability Pct' ;
    rdfs:comment 'Estimated probability (0.00–100.00%) that the deal will successfully close, assigned by the coverage banker and reviewed by deal committee. Used to compute probability-weighted revenue in pipeline forecasting and ALCO reporting.' ;
    rdfs:domain ind:Deal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pitchDate rdf:type rdf:Property ;
    rdfs:label 'Pitch Date' ;
    rdfs:comment 'The date on which the formal pitch or proposal was presented to the client. Marks the transition from origination to active pursuit; used for pipeline conversion rate analysis and banker activity tracking.' ;
    rdfs:domain ind:Deal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pricingDate rdf:type rdf:Property ;
    rdfs:label 'Pricing Date' ;
    rdfs:comment 'The date on which the transaction was priced (applicable to ECM and DCM transactions). For IPOs and bond issuances, this is the date the final offer price or coupon is set; triggers T+1 or T+2 settlement obligations.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rationale rdf:type rdf:Property ;
    rdfs:label 'Rationale' ;
    rdfs:comment 'Summary of the strategic rationale for the transaction from the client\'s perspective (e.g., market expansion, synergy realization, capital structure optimization). Used in deal committee presentations and regulatory filings.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictedListFlag rdf:type rdf:Property ;
    rdfs:label 'Restricted List Flag' ;
    rdfs:comment 'Indicates whether the deal has triggered placement of the target or issuer on the bank\'s restricted trading list, preventing proprietary trading and research publication. Enforces information barrier compliance.' ;
    rdfs:domain ind:Deal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:size rdf:type rdf:Property ;
    rdfs:label 'Size' ;
    rdfs:comment 'The total transaction size or notional value of the deal (e.g., total equity raised for ECM, total debt issued for DCM, total consideration for M&A). Distinct from enterprise value; represents the actual capital markets transaction amount.' ;
    rdfs:domain ind:Deal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceSystemDealRef rdf:type rdf:Property ;
    rdfs:label 'Source System Deal Ref' ;
    rdfs:comment 'The deal identifier as recorded in the originating system of record (e.g., Murex deal ID, Loan IQ deal number, or internal CRM opportunity ID). Enables lineage tracing and reconciliation between the lakehouse silver layer and operational systems.' ;
    rdfs:domain ind:Deal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCompanyName rdf:type rdf:Property ;
    rdfs:label 'Target Company Name' ;
    rdfs:comment 'Legal name of the target company in M&A transactions, or the issuer name in ECM/DCM transactions. Used in tombstone records, regulatory filings, and deal marketing materials.' ;
    rdfs:domain ind:Investment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCountryCode rdf:type rdf:Property ;
    rdfs:label 'Target Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the target company\'s or issuer\'s primary jurisdiction of incorporation. Used for cross-border deal classification, regulatory jurisdiction determination, and geographic pipeline reporting.' ;
    rdfs:domain ind:Deal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetEnterpriseValue rdf:type rdf:Property ;
    rdfs:label 'Target Enterprise Value' ;
    rdfs:comment 'The estimated total enterprise value of the target company or transaction, expressed in the deal currency. Used as the primary sizing metric for M&A transactions, LBO analysis, and DCF valuation benchmarking. Basis for fee calculation in many mandate structures.' ;
    rdfs:domain ind:Deal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dealDocumentId rdf:type rdf:Property ;
    rdfs:label 'Deal Document Id' ;
    rdfs:comment 'Unique identifier for the investment banking deal document record. Primary key for the deal document registry.' ;
    rdfs:domain ind:DealDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capitalMarketsOfferingId rdf:type rdf:Property ;
    rdfs:label 'Capital Markets Offering Id' ;
    rdfs:comment 'Foreign key linking to investment.offering. Business justification: Deal documents include offering-specific documents (prospectus, offering memorandum, pricing supplement, etc.). While deal_document has deal_id, one deal can have multiple offerings, each with its own' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Offering .

ind:governingLawJurisdictionId rdf:type rdf:Property ;
    rdfs:label 'Governing Law Jurisdiction Id' ;
    rdfs:comment 'Foreign key linking to reference.jurisdiction. Business justification: Governing law jurisdiction determines document enforceability, legal review requirements, and dispute resolution framework for investment banking transaction documents.' ;
    rdfs:domain ind:Investment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Jurisdiction .

ind:parentDocumentDealDocumentId rdf:type rdf:Property ;
    rdfs:label 'Parent Document Deal Document Id' ;
    rdfs:comment 'Reference to the parent or predecessor document that this document supersedes, amends, or relates to, establishing document lineage.' ;
    rdfs:domain ind:DealDocument ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DealDocument .

ind:amendmentNumber rdf:type rdf:Property ;
    rdfs:label 'Amendment Number' ;
    rdfs:comment 'Sequential number indicating which amendment this document represents to the original agreement or document, starting from 1 for the first amendment.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:authorDepartment rdf:type rdf:Property ;
    rdfs:label 'Author Department' ;
    rdfs:comment 'Department or line of business within the bank responsible for creating the document, such as Investment Banking, Legal, or Compliance.' ;
    rdfs:domain ind:DealDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankSignatoryName rdf:type rdf:Property ;
    rdfs:label 'Bank Signatory Name' ;
    rdfs:comment 'Name of the individual authorized to sign the document on behalf of the bank, typically a senior banker or authorized officer.' ;
    rdfs:domain ind:Investment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankSignatoryTitle rdf:type rdf:Property ;
    rdfs:label 'Bank Signatory Title' ;
    rdfs:comment 'Job title or role of the bank signatory, establishing their authority to bind the bank to the document terms.' ;
    rdfs:domain ind:DealDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterpartySignatoryName rdf:type rdf:Property ;
    rdfs:label 'Counterparty Signatory Name' ;
    rdfs:comment 'Name of the individual authorized to sign the document on behalf of the counterparty or client entity.' ;
    rdfs:domain ind:DealDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterpartySignatoryTitle rdf:type rdf:Property ;
    rdfs:label 'Counterparty Signatory Title' ;
    rdfs:comment 'Job title or role of the counterparty signatory, establishing their authority to bind the counterparty entity.' ;
    rdfs:domain ind:DealDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentCategory rdf:type rdf:Property ;
    rdfs:label 'Document Category' ;
    rdfs:comment 'High-level categorization of the document by transaction phase, indicating when in the deal lifecycle the document is relevant.' ;
    rdfs:domain ind:DealDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileSizeKb rdf:type rdf:Property ;
    rdfs:label 'File Size Kb' ;
    rdfs:comment 'Size of the document file in kilobytes, used for storage management and transmission planning.' ;
    rdfs:domain ind:DealDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isExecuted rdf:type rdf:Property ;
    rdfs:label 'Is Executed' ;
    rdfs:comment 'Indicates whether the document has been formally executed by all required parties, making it legally binding.' ;
    rdfs:domain ind:DealDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMaterialChange rdf:type rdf:Property ;
    rdfs:label 'Is Material Change' ;
    rdfs:comment 'Indicates whether the document represents a material change to the deal terms that requires disclosure or regulatory notification.' ;
    rdfs:domain ind:DealDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:keywords rdf:type rdf:Property ;
    rdfs:label 'Keywords' ;
    rdfs:comment 'Comma-separated list of keywords or tags associated with the document, enabling search and categorization within the document management system.' ;
    rdfs:domain ind:DealDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leagueTableEligible rdf:type rdf:Property ;
    rdfs:label 'League Table Eligible' ;
    rdfs:comment 'Indicates whether the document and associated deal qualify for submission to league table ranking providers such as Bloomberg or Dealogic.' ;
    rdfs:domain ind:Investment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pageCount rdf:type rdf:Property ;
    rdfs:label 'Page Count' ;
    rdfs:comment 'Total number of pages in the document, relevant for physical printing and review planning.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:retentionClassification rdf:type rdf:Property ;
    rdfs:label 'Retention Classification' ;
    rdfs:comment 'Document retention category determining the minimum period the document must be retained per regulatory and internal policy requirements.' ;
    rdfs:domain ind:DealDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tombstoneEligible rdf:type rdf:Property ;
    rdfs:label 'Tombstone Eligible' ;
    rdfs:comment 'Indicates whether the document and associated deal are eligible for inclusion in league table tombstone advertisements and marketing materials.' ;
    rdfs:domain ind:Investment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dealParticipantId rdf:type rdf:Property ;
    rdfs:label 'Deal Participant Id' ;
    rdfs:comment 'Unique surrogate identifier for each deal participant record in the investment banking deal association entity. Primary key for the deal_participant table.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DealParticipant .

ind:primaryDealPartyId rdf:type rdf:Property ;
    rdfs:label 'Primary Deal Party Id' ;
    rdfs:comment 'Reference to the institution or counterparty entity representing the participating organization (e.g., client, co-advisor, legal counsel, auditor, regulator).' ;
    rdfs:domain ind:DealParticipant ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:agreedFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Agreed Fee Amount' ;
    rdfs:comment 'Contractually agreed fee amount payable to or by this participant for their role in the deal, expressed in the deal currency. For success fees, this represents the agreed percentage or fixed amount at deal close.' ;
    rdfs:domain ind:Investment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conflictCheckDate rdf:type rdf:Property ;
    rdfs:label 'Conflict Check Date' ;
    rdfs:comment 'Date on which the conflict of interest screening was last performed or updated for this participant. Used to ensure checks are current and within required review cycles.' ;
    rdfs:domain ind:Investment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conflictCheckNotes rdf:type rdf:Property ;
    rdfs:label 'Conflict Check Notes' ;
    rdfs:comment 'Free-text notes documenting the outcome of the conflict of interest review, including nature of any identified conflict, waiver rationale, or escalation details. Maintained for regulatory audit trail purposes.' ;
    rdfs:domain ind:DealParticipant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conflictCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Conflict Check Status' ;
    rdfs:comment 'Status of the conflict of interest screening performed for this participant relative to the deal. Values: pending (check not yet initiated), cleared (no conflict found), conflict_identified (potential conflict detected), waived (conflict acknowledged and waived with appropriate approvals), escalated (referred to compliance committee).' ;
    rdfs:domain ind:Investment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealTeamLead rdf:type rdf:Property ;
    rdfs:label 'Deal Team Lead' ;
    rdfs:comment 'Indicates whether this participant is designated as the lead institution or lead advisor for their role in the deal (e.g., lead left bookrunner, lead financial advisor). True = lead; False = co-participant or supporting role.' ;
    rdfs:domain ind:DealParticipant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:engagementLetterDate rdf:type rdf:Property ;
    rdfs:label 'Engagement Letter Date' ;
    rdfs:comment 'Date on which the formal engagement letter was signed between the bank and this participant, establishing the legal basis for the advisory or service relationship within the deal.' ;
    rdfs:domain ind:DealParticipant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:feeArrangementType rdf:type rdf:Property ;
    rdfs:label 'Fee Arrangement Type' ;
    rdfs:comment 'Type of fee arrangement agreed with this participant: retainer (periodic fixed fee), success_fee (contingent on deal close), hourly (time-based billing), fixed (lump sum), or no_fee (pro bono or regulatory participant). Drives revenue recognition and deal economics.' ;
    rdfs:domain ind:Investment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeBasisPoints rdf:type rdf:Property ;
    rdfs:label 'Fee Basis Points' ;
    rdfs:comment 'Fee expressed in basis points (BPS) as a proportion of the total deal value, applicable for success fees and underwriting fees in capital markets transactions. One basis point equals 0.01%.' ;
    rdfs:domain ind:DealParticipant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:informationBarrierGroup rdf:type rdf:Property ;
    rdfs:label 'Information Barrier Group' ;
    rdfs:comment 'Identifier of the information barrier (Chinese Wall) group to which this participant has been assigned, controlling access to material non-public information (MNPI) about the deal. Used for insider trading prevention and regulatory compliance.' ;
    rdfs:domain ind:DealParticipant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:institutionType rdf:type rdf:Property ;
    rdfs:label 'Institution Type' ;
    rdfs:comment 'Classification of the type of institution participating in the deal: investment_bank, commercial_bank, law_firm, accounting_firm, regulator, private_equity, or hedge_fund. Supports deal team composition analysis and conflict screening. [ENUM-REF-CANDIDATE: investment_bank|commercial_bank|law_firm|accounting_firm|regulator|private_equity|hedge_fund — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leagueTableCredit rdf:type rdf:Property ;
    rdfs:label 'League Table Credit' ;
    rdfs:comment 'Indicates whether this participant is eligible to receive league table credit for this deal in industry rankings (e.g., Bloomberg, Dealogic, Thomson Reuters). True = eligible for credit; False = excluded from league table attribution.' ;
    rdfs:domain ind:Investment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mandateLetterRef rdf:type rdf:Property ;
    rdfs:label 'Mandate Letter Ref' ;
    rdfs:comment 'Reference number or identifier of the mandate letter or engagement letter governing this participant\'s involvement in the deal. Links to the formal contractual document establishing scope, fees, and obligations.' ;
    rdfs:domain ind:DealParticipant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ndaExecuted rdf:type rdf:Property ;
    rdfs:label 'Nda Executed' ;
    rdfs:comment 'Indicates whether a Non-Disclosure Agreement (NDA) has been executed with this participant prior to sharing confidential deal information. True = NDA in place; False = NDA not yet executed.' ;
    rdfs:domain ind:Investment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ndaExecutionDate rdf:type rdf:Property ;
    rdfs:label 'Nda Execution Date' ;
    rdfs:comment 'Date on which the Non-Disclosure Agreement (NDA) was formally executed between the bank and this deal participant. Null if NDA has not been executed.' ;
    rdfs:domain ind:Investment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:participantCategory rdf:type rdf:Property ;
    rdfs:label 'Participant Category' ;
    rdfs:comment 'High-level classification grouping participant roles into: principal (client, target, acquirer), advisor (financial advisor, legal counsel, auditor, co-advisor), regulatory (regulator, compliance body), or support (escrow agent, trustee, paying agent).' ;
    rdfs:domain ind:DealParticipant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:participantRefNumber rdf:type rdf:Property ;
    rdfs:label 'Participant Ref Number' ;
    rdfs:comment 'Externally-known alphanumeric reference number assigned to this participant engagement within the deal, used in mandate letters, pitch books, and tombstone records for cross-system identification.' ;
    rdfs:domain ind:DealParticipant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:participantRole rdf:type rdf:Property ;
    rdfs:label 'Participant Role' ;
    rdfs:comment 'Functional role of the participant in the investment banking deal. Common roles include: client, target, acquirer, co-advisor, financial advisor, legal counsel, auditor, underwriter, syndicate member, regulator, escrow agent, trustee, fairness opinion provider. [ENUM-REF-CANDIDATE: client|target|acquirer|co_advisor|financial_advisor|legal_counsel|auditor|underwriter|syndicate_member|regulator|escrow_agent|trustee|fairness_opinion_provider — promote to reference product]' ;
    rdfs:domain ind:Investment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:participantSide rdf:type rdf:Property ;
    rdfs:label 'Participant Side' ;
    rdfs:comment 'Indicates which side of the transaction the participant represents: buy_side (acquirer/investor), sell_side (target/issuer), neutral (independent advisor, auditor, fairness opinion), or regulatory (governing body). Critical for conflict of interest screening.' ;
    rdfs:domain ind:Investment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:participantStatus rdf:type rdf:Property ;
    rdfs:label 'Participant Status' ;
    rdfs:comment 'Current lifecycle status of the participant\'s engagement in the deal: active (currently engaged), withdrawn (voluntarily exited), terminated (engagement ended by counterparty), completed (deal closed with participant fulfilling role), suspended (engagement paused pending resolution).' ;
    rdfs:domain ind:Investment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Status' ;
    rdfs:comment 'Current status of any required regulatory approval for this participant\'s deal involvement: not_required, pending (application submitted), approved (clearance received), rejected (approval denied), or conditional (approved with conditions).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:syndicateRank rdf:type rdf:Property ;
    rdfs:label 'Syndicate Rank' ;
    rdfs:comment 'Numeric ranking of this participant within the deal syndicate or advisory group, where 1 indicates the lead/senior position. Used for tombstone ordering, fee allocation, and league table credit attribution in capital markets transactions.' ;
    rdfs:domain ind:Investment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tombstoneCreditLine rdf:type rdf:Property ;
    rdfs:label 'Tombstone Credit Line' ;
    rdfs:comment 'The exact credit line text to be used for this participant in the deal tombstone advertisement, specifying the institution name and role as it should appear in the published announcement.' ;
    rdfs:domain ind:DealParticipant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wallCrossDate rdf:type rdf:Property ;
    rdfs:label 'Wall Cross Date' ;
    rdfs:comment 'Date on which this participant was formally \'wall-crossed\' — i.e., brought over the information barrier and made aware of material non-public information (MNPI) about the deal. Critical for insider trading compliance and information barrier management.' ;
    rdfs:domain ind:DealParticipant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:feeArrangementId rdf:type rdf:Property ;
    rdfs:label 'Fee Arrangement Id' ;
    rdfs:comment 'Unique surrogate identifier for the fee arrangement record in the investment banking mandate fee management system. Primary key for this entity.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FeeArrangement .

ind:investmentMandateId rdf:type rdf:Property ;
    rdfs:label 'Investment Mandate Id' ;
    rdfs:comment 'Reference to the investment banking mandate (M&A, IPO, DCF advisory, debt/equity capital markets) to which this fee arrangement belongs.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InvestmentMandate .

ind:primaryFeeEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Fee Employee Id' ;
    rdfs:comment 'Reference to the lead investment banker (Managing Director or Director) responsible for originating and managing the mandate. Used for banker compensation, league table credit, and performance attribution.' ;
    rdfs:domain ind:FeeArrangement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:bankFeeSharePct rdf:type rdf:Property ;
    rdfs:label 'Bank Fee Share Pct' ;
    rdfs:comment 'The percentage of the total fee retained by this bank after co-advisor fee sharing. Equals 100% minus co_advisor_fee_sharing_pct for simple two-party splits, or the bank\'s specific allocation in multi-party syndicates.' ;
    rdfs:domain ind:FeeArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:breakFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Break Fee Amount' ;
    rdfs:comment 'The contractual fee payable to the bank if the deal is terminated by the client before completion. Compensates the bank for work performed and opportunity cost.' ;
    rdfs:domain ind:FeeArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coAdvisorFeeSharingPct rdf:type rdf:Property ;
    rdfs:label 'Co Advisor Fee Sharing Pct' ;
    rdfs:comment 'The percentage of the total fee to be shared with co-advisors or syndicate members on the mandate. Used for fee split calculations and revenue attribution in multi-bank advisory or underwriting syndicates.' ;
    rdfs:domain ind:FeeArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dealValueBasis rdf:type rdf:Property ;
    rdfs:label 'Deal Value Basis' ;
    rdfs:comment 'The transaction or deal value (e.g., enterprise value, equity value, issuance proceeds) used as the basis for computing percentage-based fees. Critical for success fee and underwriting spread calculations.' ;
    rdfs:domain ind:FeeArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeDescription rdf:type rdf:Property ;
    rdfs:label 'Dispute Description' ;
    rdfs:comment 'Description of the fee dispute raised by the client, including the disputed amount and grounds for dispute. Populated when payment_status is \'disputed\'. Used for legal and collections management.' ;
    rdfs:domain ind:FeeArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementLetterRef rdf:type rdf:Property ;
    rdfs:label 'Engagement Letter Ref' ;
    rdfs:comment 'The document reference number of the signed engagement letter or mandate agreement that governs this fee arrangement. Used for legal and compliance audit trail.' ;
    rdfs:domain ind:FeeArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeBasis rdf:type rdf:Property ;
    rdfs:label 'Fee Basis' ;
    rdfs:comment 'The computational basis on which the fee is calculated. Fixed: flat dollar amount; Percentage: applied to transaction value or deal size; Tiered: percentage varies by deal size bracket; Blended: combination of fixed and percentage; Minimum Plus Percentage: floor amount plus variable component.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeType rdf:type rdf:Property ;
    rdfs:label 'Fee Type' ;
    rdfs:comment 'Classification of the fee by its commercial nature within the investment banking mandate. Retainer: periodic engagement fee; Success Fee: contingent on deal close; Underwriting Spread: difference between issue price and proceeds; Advisory Fee: M&A or capital markets advisory; Break Fee: payable on deal termination; Tail Fee: post-termination success fee within tail period.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeWaiverReason rdf:type rdf:Property ;
    rdfs:label 'Fee Waiver Reason' ;
    rdfs:comment 'Free-text description of the business reason for waiving or reducing the contractual fee, required for management approval and audit trail when payment_status is \'waived\'. Null when no waiver applies.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoicedAmount rdf:type rdf:Property ;
    rdfs:label 'Invoiced Amount' ;
    rdfs:comment 'The total fee amount invoiced to the client under this arrangement. May differ from fee_amount due to adjustments, credits, or partial invoicing.' ;
    rdfs:domain ind:FeeArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Fee Amount' ;
    rdfs:comment 'The contractual floor fee amount guaranteed to the bank regardless of deal size or outcome, applicable for tiered or minimum-plus-percentage fee basis arrangements.' ;
    rdfs:domain ind:Investment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentDueDate rdf:type rdf:Property ;
    rdfs:label 'Payment Due Date' ;
    rdfs:comment 'The contractual date by which the client must remit payment for the invoiced fee. Used for AR aging, collections management, and overdue fee tracking.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:receivedAmount rdf:type rdf:Property ;
    rdfs:label 'Received Amount' ;
    rdfs:comment 'The total fee amount actually received from the client as of the most recent payment event. Used for cash reconciliation, outstanding receivables tracking, and revenue recognition confirmation.' ;
    rdfs:domain ind:FeeArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reconciliationReference rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Reference' ;
    rdfs:comment 'The payment or wire transfer reference number used to match the received fee payment to the invoice in the GL/AR system. Supports finance reconciliation and audit trail requirements.' ;
    rdfs:domain ind:FeeArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retainerAmount rdf:type rdf:Property ;
    rdfs:label 'Retainer Amount' ;
    rdfs:comment 'The periodic retainer fee amount payable by the client during the engagement period, typically monthly or quarterly. May be credited against the success fee upon deal close.' ;
    rdfs:domain ind:FeeArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retainerCreditable rdf:type rdf:Property ;
    rdfs:label 'Retainer Creditable' ;
    rdfs:comment 'Indicates whether retainer payments made during the engagement are creditable (offset) against the success fee upon deal completion. True = retainer amounts reduce the success fee payable.' ;
    rdfs:domain ind:FeeArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retainerFrequency rdf:type rdf:Property ;
    rdfs:label 'Retainer Frequency' ;
    rdfs:comment 'The frequency at which retainer fee payments are due from the client during the engagement period.' ;
    rdfs:domain ind:FeeArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRecognitionMethod rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Method' ;
    rdfs:comment 'The accounting method applied to recognize revenue from this fee arrangement per IFRS 15 / ASC 606. Point in Time: recognized at deal close; Over Time: recognized ratably over engagement period; Milestone Based: recognized upon achievement of defined milestones; Contingent: deferred until contingency resolved.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tailPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Tail Period Months' ;
    rdfs:comment 'The number of months following termination or expiry of the mandate during which the bank retains the right to a success fee if the client completes a transaction with a party introduced by the bank.' ;
    rdfs:domain ind:Investment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:investmentRegulatoryFilingId rdf:type rdf:Property ;
    rdfs:label 'Investment Regulatory Filing Id' ;
    rdfs:comment 'Unique surrogate identifier for each regulatory filing record submitted in connection with an investment banking transaction. Serves as the primary key for this entity.' ;
    rdfs:domain ind:InvestmentRegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentFilingInvestmentRegulatoryFilingId rdf:type rdf:Property ;
    rdfs:label 'Parent Filing Investment Regulatory Filing Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the original filing record when this record represents an amendment or supplement. Null for original filings. Enables reconstruction of the full amendment chain for a given regulatory submission.' ;
    rdfs:domain ind:InvestmentRegulatoryFiling ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InvestmentRegulatoryFiling .

ind:cik rdf:type rdf:Property ;
    rdfs:label 'Cik' ;
    rdfs:comment 'The SEC Central Index Key assigned to the issuer in the EDGAR filing system. Uniquely identifies the filer in the SEC\'s electronic disclosure database. Applicable to SEC filings only.' ;
    rdfs:domain ind:InvestmentRegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityTreatmentFlag rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Treatment Flag' ;
    rdfs:comment 'Indicates whether the bank or issuer has requested confidential treatment for certain portions of the filing under applicable securities law (True = confidential treatment requested). Common for trade secrets, pricing terms, and material contracts.' ;
    rdfs:domain ind:InvestmentRegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fatcaApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Fatca Applicable Flag' ;
    rdfs:comment 'Indicates whether the filing or associated transaction has FATCA withholding and reporting implications (True = FATCA applicable). Relevant for cross-border securities offerings involving US persons or US-source income.' ;
    rdfs:domain ind:InvestmentRegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:filingCategory rdf:type rdf:Property ;
    rdfs:label 'Filing Category' ;
    rdfs:comment 'Broad category grouping the filing by its regulatory purpose. Used for portfolio-level compliance tracking and regulatory reporting dashboards across the investment banking division. [ENUM-REF-CANDIDATE: equity_capital_markets|debt_capital_markets|M&A|antitrust|periodic_disclosure|current_report|beneficial_ownership — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InvestmentRegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingFeeUsd rdf:type rdf:Property ;
    rdfs:label 'Filing Fee Usd' ;
    rdfs:comment 'The regulatory filing fee paid to the regulatory body in connection with this submission, expressed in US dollars. Calculated based on the offering size or transaction value per the applicable fee schedule (e.g., SEC Section 6(b) fee).' ;
    rdfs:domain ind:InvestmentRegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastCommentResponseDate rdf:type rdf:Property ;
    rdfs:label 'Last Comment Response Date' ;
    rdfs:comment 'The date on which the most recent response to a regulatory comment letter was submitted. Used to track the responsiveness of the issuer and legal counsel during the regulatory review process.' ;
    rdfs:domain ind:InvestmentRegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:listingExchange rdf:type rdf:Property ;
    rdfs:label 'Listing Exchange' ;
    rdfs:comment 'The securities exchange or trading venue on which the issuer\'s securities are proposed to be listed or are already listed in connection with this filing (e.g., NYSE, NASDAQ, LSE, Euronext). Relevant for equity capital markets and listing-related filings.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialChangeDescription rdf:type rdf:Property ;
    rdfs:label 'Material Change Description' ;
    rdfs:comment 'Narrative description of the material change(s) disclosed in this filing or amendment. Populated only when material_change_flag is True. Supports regulatory audit trails and investor communication records.' ;
    rdfs:domain ind:InvestmentRegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialChangeFlag rdf:type rdf:Property ;
    rdfs:label 'Material Change Flag' ;
    rdfs:comment 'Indicates whether this filing or amendment contains a material change to previously disclosed information (True = material change present). Triggers enhanced review workflows and investor notification obligations under securities law.' ;
    rdfs:domain ind:InvestmentRegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:offeringCurrency rdf:type rdf:Property ;
    rdfs:label 'Offering Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the currency in which the offering or transaction is denominated (e.g., USD, EUR, GBP). Required for multi-currency deal reporting and FX conversion in consolidated analytics.' ;
    rdfs:domain ind:InvestmentRegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offeringSizeUsd rdf:type rdf:Property ;
    rdfs:label 'Offering Size Usd' ;
    rdfs:comment 'The total gross proceeds of the capital markets transaction associated with this filing, expressed in US dollars. For M&A filings, represents the total deal value. Used for fee calculation, regulatory threshold checks (e.g., HSR filing thresholds), and deal league table reporting.' ;
    rdfs:domain ind:InvestmentRegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prospectusType rdf:type rdf:Property ;
    rdfs:label 'Prospectus Type' ;
    rdfs:comment 'For equity and debt capital markets filings, specifies the type of prospectus document (e.g., base prospectus for shelf registration, preliminary prospectus (red herring), final prospectus, supplementary prospectus). Null for non-prospectus filings such as HSR or 8-K.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReviewDeadline rdf:type rdf:Property ;
    rdfs:label 'Regulatory Review Deadline' ;
    rdfs:comment 'The statutory or regulatory deadline by which the regulatory body must complete its review and issue a decision on the filing (e.g., SEC 30-day review period for S-1, HSR 30-day initial waiting period). Critical for deal timeline management.' ;
    rdfs:domain ind:InvestmentRegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sarbanesOxleyApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Sarbanes Oxley Applicable Flag' ;
    rdfs:comment 'Indicates whether the filing is subject to Sarbanes-Oxley Act certification requirements (True = SOX applicable). Relevant for annual and quarterly reports filed by US public companies requiring CEO/CFO certifications under SOX Sections 302 and 906.' ;
    rdfs:domain ind:InvestmentRegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:secCommentLetterCount rdf:type rdf:Property ;
    rdfs:label 'Sec Comment Letter Count' ;
    rdfs:comment 'Number of comment letters received from the SEC Division of Corporation Finance during the review of this filing. A higher count indicates more extensive regulatory scrutiny and may signal deal execution risk.' ;
    rdfs:domain ind:InvestmentRegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tombstoneEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Tombstone Eligible Flag' ;
    rdfs:comment 'Indicates whether the transaction associated with this filing qualifies for inclusion in the bank\'s tombstone advertisement and deal league table records upon successful completion (True = eligible). Used for marketing and competitive positioning analytics.' ;
    rdfs:domain ind:Investment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:underwriterRole rdf:type rdf:Property ;
    rdfs:label 'Underwriter Role' ;
    rdfs:comment 'The bank\'s role in the transaction associated with this filing (e.g., sole bookrunner, joint bookrunner, co-manager, financial advisor). Determines the bank\'s regulatory obligations and disclosure requirements in the filing.' ;
    rdfs:domain ind:InvestmentRegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investmentValuationId rdf:type rdf:Property ;
    rdfs:label 'Investment Valuation Id' ;
    rdfs:comment 'Unique surrogate identifier for each investment valuation or fairness opinion record in the investment banking advisory platform. Primary key for the investment_valuation data product.' ;
    rdfs:domain ind:InvestmentValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvalCommitteeId rdf:type rdf:Property ;
    rdfs:label 'Approval Committee Id' ;
    rdfs:comment 'Reference to the internal investment committee or fairness opinion committee responsible for approving and signing off on this valuation. Supports governance and audit trail requirements.' ;
    rdfs:domain ind:Investment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ApprovalCommittee .

ind:targetCountryId rdf:type rdf:Property ;
    rdfs:label 'Target Country Id' ;
    rdfs:comment 'Foreign key linking to reference.country. Business justification: Target country determines country risk premium in WACC calculation, sovereign credit rating impact, and regulatory approval timeline for valuation scenarios.' ;
    rdfs:domain ind:Investment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:transactionStructureId rdf:type rdf:Property ;
    rdfs:label 'Transaction Structure Id' ;
    rdfs:comment 'Foreign key linking to investment.transaction_structure. Business justification: Valuations and fairness opinions are performed to support specific transaction structures (e.g., DCF valuation for a proposed merger structure). While investment_valuation has deal_id, one deal can ha' ;
    rdfs:domain ind:Investment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TransactionStructure .

ind:boardPresentationDate rdf:type rdf:Property ;
    rdfs:label 'Board Presentation Date' ;
    rdfs:comment 'Date on which the valuation analysis or fairness opinion was formally presented to the client\'s board of directors. Required for fairness opinion compliance documentation and proxy statement disclosure. Distinct from the valuation date.' ;
    rdfs:domain ind:InvestmentValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enterpriseValueHigh rdf:type rdf:Property ;
    rdfs:label 'Enterprise Value High' ;
    rdfs:comment 'Upper bound of the enterprise value range derived from the valuation analysis, expressed in the deal currency. The EV range reflects sensitivity analysis across key assumptions such as WACC and terminal growth rate.' ;
    rdfs:domain ind:InvestmentValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enterpriseValueLow rdf:type rdf:Property ;
    rdfs:label 'Enterprise Value Low' ;
    rdfs:comment 'Lower bound of the enterprise value range derived from the valuation analysis, expressed in the deal currency. Enterprise Value represents the total value of the business including debt and excluding cash. Used for deal pricing and fairness opinion conclusions.' ;
    rdfs:domain ind:InvestmentValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:equityValueHigh rdf:type rdf:Property ;
    rdfs:label 'Equity Value High' ;
    rdfs:comment 'Upper bound of the implied equity value range, calculated by deducting net debt from the enterprise value high. Used in conjunction with shares outstanding to derive implied per-share value ranges for board presentations and proxy filings.' ;
    rdfs:domain ind:InvestmentValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:equityValueLow rdf:type rdf:Property ;
    rdfs:label 'Equity Value Low' ;
    rdfs:comment 'Lower bound of the implied equity value range, calculated by deducting net debt from the enterprise value low. Represents the value attributable to equity holders and is used to derive implied share price ranges for M&A and IPO pricing.' ;
    rdfs:domain ind:InvestmentValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evEbitdaMultipleHigh rdf:type rdf:Property ;
    rdfs:label 'Ev Ebitda Multiple High' ;
    rdfs:comment 'Upper bound of the implied EV/EBITDA multiple derived from the valuation range. Together with the low multiple, defines the EV/EBITDA range used in board presentations, fairness opinion analyses, and investment committee materials.' ;
    rdfs:domain ind:InvestmentValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evEbitdaMultipleLow rdf:type rdf:Property ;
    rdfs:label 'Ev Ebitda Multiple Low' ;
    rdfs:comment 'Lower bound of the implied EV/EBITDA multiple derived from the valuation range, calculated as enterprise value low divided by the target company\'s EBITDA. Used to benchmark the valuation against comparable company trading multiples and precedent transaction multiples.' ;
    rdfs:domain ind:InvestmentValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastPeriodYears rdf:type rdf:Property ;
    rdfs:label 'Forecast Period Years' ;
    rdfs:comment 'Number of years in the explicit cash flow forecast period used in the DCF or LBO model. Typically 5 to 10 years for investment banking valuations. Determines the horizon over which detailed financial projections are modeled before applying the terminal value.' ;
    rdfs:domain ind:InvestmentValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:impliedSharePriceHigh rdf:type rdf:Property ;
    rdfs:label 'Implied Share Price High' ;
    rdfs:comment 'Upper bound of the implied per-share equity value derived from the equity value high divided by fully diluted shares outstanding. Together with the low, defines the implied share price range disclosed in fairness opinion proxy materials.' ;
    rdfs:domain ind:InvestmentValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impliedSharePriceLow rdf:type rdf:Property ;
    rdfs:label 'Implied Share Price Low' ;
    rdfs:comment 'Lower bound of the implied per-share equity value derived from the equity value low divided by fully diluted shares outstanding. Used in fairness opinion analyses to compare the implied price range against the proposed transaction consideration.' ;
    rdfs:domain ind:InvestmentValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isFairnessOpinion rdf:type rdf:Property ;
    rdfs:label 'Is Fairness Opinion' ;
    rdfs:comment 'Indicates whether this valuation record constitutes a formal fairness opinion (True) or an internal valuation analysis (False). Fairness opinions carry additional regulatory obligations under SEC Rule 14a-9 and FINRA Rule 5150, including board presentation and proxy disclosure requirements.' ;
    rdfs:domain ind:InvestmentValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ltmEbitda rdf:type rdf:Property ;
    rdfs:label 'Ltm Ebitda' ;
    rdfs:comment 'Earnings Before Interest, Taxes, Depreciation, and Amortization (EBITDA) for the last twelve months (LTM) period used as the primary financial metric in the valuation analysis. Denominator for EV/EBITDA multiple calculations and key input to DCF normalization.' ;
    rdfs:domain ind:InvestmentValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:materialRelationshipDisclosure rdf:type rdf:Property ;
    rdfs:label 'Material Relationship Disclosure' ;
    rdfs:comment 'Narrative description of any material relationships between the investment bank and the parties to the transaction that must be disclosed in the fairness opinion letter or proxy statement, as required by FINRA Rule 5150. Includes prior advisory mandates, lending relationships, and equity holdings.' ;
    rdfs:domain ind:InvestmentValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelFileReference rdf:type rdf:Property ;
    rdfs:label 'Model File Reference' ;
    rdfs:comment 'Document management system reference or file path to the underlying financial model (Excel/Python workbook) supporting this valuation. Enables auditors and reviewers to trace the valuation conclusion back to the source model and assumptions.' ;
    rdfs:domain ind:InvestmentValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netDebt rdf:type rdf:Property ;
    rdfs:label 'Net Debt' ;
    rdfs:comment 'Total financial debt less cash and cash equivalents of the target company as of the valuation date, used to bridge from enterprise value to equity value. A negative net debt (net cash) position increases equity value relative to enterprise value.' ;
    rdfs:domain ind:InvestmentValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:opinionConclusion rdf:type rdf:Property ;
    rdfs:label 'Opinion Conclusion' ;
    rdfs:comment 'The formal conclusion of the fairness or solvency opinion as rendered by the investment bank. Applicable when is_fairness_opinion is True. The conclusion is disclosed in the proxy statement or offering document and is subject to SEC and FINRA scrutiny.' ;
    rdfs:domain ind:InvestmentValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opinionType rdf:type rdf:Property ;
    rdfs:label 'Opinion Type' ;
    rdfs:comment 'Classification of the formal opinion rendered, applicable when is_fairness_opinion is True. Fairness opinions address whether consideration is fair from a financial point of view; solvency opinions address the target\'s ability to meet obligations post-transaction; valuation opinions provide a point estimate of value; adequacy opinions address whether consideration is adequate.' ;
    rdfs:domain ind:InvestmentValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:peMultipleHigh rdf:type rdf:Property ;
    rdfs:label 'Pe Multiple High' ;
    rdfs:comment 'Upper bound of the implied Price-to-Earnings (P/E) multiple derived from the equity value range. Together with the low multiple, defines the P/E range used in fairness opinion analyses and investment committee presentations.' ;
    rdfs:domain ind:InvestmentValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:peMultipleLow rdf:type rdf:Property ;
    rdfs:label 'Pe Multiple Low' ;
    rdfs:comment 'Lower bound of the implied Price-to-Earnings (P/E) multiple derived from the equity value range divided by the target company\'s net income. Used as a cross-check valuation metric, particularly relevant for IPO pricing and public M&A transactions.' ;
    rdfs:domain ind:InvestmentValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:secondaryMethodology rdf:type rdf:Property ;
    rdfs:label 'Secondary Methodology' ;
    rdfs:comment 'Secondary or cross-check valuation methodology used to triangulate the primary valuation result. Investment banking practice typically employs multiple methodologies to establish a valuation range. [ENUM-REF-CANDIDATE: DCF|LBO|comparable_company|precedent_transaction|sum_of_parts|NAV|dividend_discount|asset_based — promote to reference product]' ;
    rdfs:domain ind:InvestmentValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sharesOutstanding rdf:type rdf:Property ;
    rdfs:label 'Shares Outstanding' ;
    rdfs:comment 'Fully diluted shares outstanding of the target company as of the valuation date, including common shares, in-the-money options, warrants, and convertible securities on a treasury stock method basis. Used to derive implied per-share equity value.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminalGrowthRate rdf:type rdf:Property ;
    rdfs:label 'Terminal Growth Rate' ;
    rdfs:comment 'Perpetuity growth rate applied in the DCF terminal value calculation, expressed as a decimal (e.g., 0.025 for 2.5%). Represents the assumed long-term sustainable growth rate of the target company\'s free cash flows beyond the explicit forecast period.' ;
    rdfs:domain ind:InvestmentValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wacc rdf:type rdf:Property ;
    rdfs:label 'Wacc' ;
    rdfs:comment 'Weighted Average Cost of Capital expressed as a decimal (e.g., 0.085 for 8.5%) used as the discount rate in DCF valuation. Reflects the blended cost of equity and debt financing, adjusted for the target company\'s capital structure and risk profile.' ;
    rdfs:domain ind:InvestmentValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:investmentInvestorOrderId rdf:type rdf:Property ;
    rdfs:label 'Investment Investor Order Id' ;
    rdfs:comment 'Unique surrogate identifier for each investor order record in the bookbuilding order book. Primary key for the investor_order data product.' ;
    rdfs:domain ind:InvestmentInvestorOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:investorGeographyCountryId rdf:type rdf:Property ;
    rdfs:label 'Investor Geography Country Id' ;
    rdfs:comment 'Foreign key linking to reference.country. Business justification: Investor geography required for Reg S/144A eligibility determination, geographic allocation analysis, and cross-border securities offering compliance.' ;
    rdfs:domain ind:InvestmentInvestorOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:allocationAmount rdf:type rdf:Property ;
    rdfs:label 'Allocation Amount' ;
    rdfs:comment 'Total monetary value of the allocation received by the investor, calculated as allocation_size multiplied by allocation_price. Represents the investor\'s financial commitment to the transaction. Used for settlement, fee calculation, and regulatory reporting.' ;
    rdfs:domain ind:InvestmentInvestorOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationPrice rdf:type rdf:Property ;
    rdfs:label 'Allocation Price' ;
    rdfs:comment 'The final deal price per share or per unit at which the investor\'s allocation was confirmed. Typically the IPO offer price or bond issue price. Used for settlement and P&L attribution.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationSize rdf:type rdf:Property ;
    rdfs:label 'Allocation Size' ;
    rdfs:comment 'The number of shares or face value amount actually allocated to the investor following the bookrunner\'s allocation decision at deal pricing. Zero if the order was not filled. Compared against order_size to determine fill ratio.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demandMultiple rdf:type rdf:Property ;
    rdfs:label 'Demand Multiple' ;
    rdfs:comment 'Ratio of the investor\'s order size to the investor\'s expected or target allocation, indicating the degree of oversubscription at the individual investor level. Used by the bookrunner to assess investor conviction and calibrate allocation decisions.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:greenshoeEligible rdf:type rdf:Property ;
    rdfs:label 'Greenshoe Eligible' ;
    rdfs:comment 'Indicates whether this investor order is eligible to be filled from the overallotment (greenshoe) option, allowing the bookrunner to allocate up to 15% additional shares beyond the base offering size to cover excess demand.' ;
    rdfs:domain ind:InvestmentInvestorOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:investorName rdf:type rdf:Property ;
    rdfs:label 'Investor Name' ;
    rdfs:comment 'Legal name of the investor or institution placing the order. Used for order book management, allocation decisions, and regulatory reporting. May represent an institutional fund, asset manager, or individual investor.' ;
    rdfs:domain ind:InvestmentInvestorOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investorTier rdf:type rdf:Property ;
    rdfs:label 'Investor Tier' ;
    rdfs:comment 'Classification of the investor by tier, which influences allocation priority and deal economics. \'anchor\' investors commit pre-IPO with lock-up; \'cornerstone\' investors receive guaranteed allocations; \'institutional\' covers qualified institutional buyers (QIBs); \'retail\' covers individual investors; \'strategic\' covers corporate or government investors with strategic interest.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAnchorInvestor rdf:type rdf:Property ;
    rdfs:label 'Is Anchor Investor' ;
    rdfs:comment 'Indicates whether this investor has been designated as an anchor investor for the transaction, committing to a pre-IPO allocation with a lock-up period. Anchor investors receive guaranteed allocations in exchange for early commitment and price support.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCoveredShort rdf:type rdf:Property ;
    rdfs:label 'Is Covered Short' ;
    rdfs:comment 'Indicates whether the investor\'s order includes a covered short sale component, typically associated with the greenshoe/overallotment option exercise. Relevant for stabilization and price support analysis post-IPO.' ;
    rdfs:domain ind:InvestmentInvestorOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lockUpPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Lock Up Period Days' ;
    rdfs:comment 'Number of calendar days the investor is contractually restricted from selling the allocated securities following the deal closing date. Applicable primarily to anchor and cornerstone investors. Zero or null if no lock-up applies.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:orderAmendmentCount rdf:type rdf:Property ;
    rdfs:label 'Order Amendment Count' ;
    rdfs:comment 'Number of times the investor has amended this order during the bookbuilding period (e.g., size increases, price limit changes). Tracks investor conviction and demand evolution. Used for bookbuilding analytics and investor behavior analysis.' ;
    rdfs:domain ind:InvestmentInvestorOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:orderChannel rdf:type rdf:Property ;
    rdfs:label 'Order Channel' ;
    rdfs:comment 'The channel through which the investor submitted the order to the bookrunner. \'electronic\' covers order management system portals; \'voice\' covers telephone orders; \'email\' covers written email instructions; \'roadshow\' covers orders placed during investor roadshow meetings; \'bloomberg\' covers Bloomberg order management system submissions.' ;
    rdfs:domain ind:InvestmentInvestorOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderCurrency rdf:type rdf:Property ;
    rdfs:label 'Order Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code in which the investor order is denominated (e.g., USD, EUR, GBP). Required for FX conversion and cross-border deal management.' ;
    rdfs:domain ind:InvestmentInvestorOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderNotes rdf:type rdf:Property ;
    rdfs:label 'Order Notes' ;
    rdfs:comment 'Free-text field capturing additional instructions, conditions, or commentary provided by the investor or the sales coverage team regarding this order. May include special allocation requests, investment rationale, or bookrunner observations.' ;
    rdfs:domain ind:InvestmentInvestorOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderReference rdf:type rdf:Property ;
    rdfs:label 'Order Reference' ;
    rdfs:comment 'Externally-known alphanumeric reference number assigned to this investor order, used for communication between the bookrunner and the investor during the bookbuilding process. Corresponds to the order ticket number in the Trading and Order Management System (e.g., Murex/Calypso).' ;
    rdfs:domain ind:InvestmentInvestorOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderSize rdf:type rdf:Property ;
    rdfs:label 'Order Size' ;
    rdfs:comment 'The total number of shares (for ECM) or face value amount (for DCM) that the investor has requested in this order. Represents the gross demand submitted by the investor before any allocation decision.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceCurrency rdf:type rdf:Property ;
    rdfs:label 'Price Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code in which the price limit is expressed. May differ from order_currency in cross-border transactions where the security is priced in a different currency than the order denomination.' ;
    rdfs:domain ind:InvestmentInvestorOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceLimit rdf:type rdf:Property ;
    rdfs:label 'Price Limit' ;
    rdfs:comment 'The maximum price per share or per unit that the investor is willing to pay for a limit order. Null for strike orders where the investor accepts the final deal price. Used by the bookrunner to determine price sensitivity and construct the demand curve.' ;
    rdfs:domain ind:InvestmentInvestorOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryCategory rdf:type rdf:Property ;
    rdfs:label 'Regulatory Category' ;
    rdfs:comment 'Regulatory classification of the investor order under applicable securities law. \'qib\' = Qualified Institutional Buyer under SEC Rule 144A; \'reg_s\' = offshore investor under SEC Regulation S; \'retail\' = retail investor under applicable prospectus rules; \'employee\' = employee share plan participant; \'directed\' = directed share program recipient.' ;
    rdfs:domain ind:InvestmentInvestorOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stepPrice1 rdf:type rdf:Property ;
    rdfs:label 'Step Price 1' ;
    rdfs:comment 'First price level for a step order, representing the price at which the investor commits to the quantity specified in step_size_1. Applicable only for order_type = \'step\'. Null for non-step orders.' ;
    rdfs:domain ind:InvestmentInvestorOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stepPrice2 rdf:type rdf:Property ;
    rdfs:label 'Step Price 2' ;
    rdfs:comment 'Second price level for a step order, representing the price at which the investor commits to the quantity specified in step_size_2. Null for non-step orders or step orders with only one tier.' ;
    rdfs:domain ind:InvestmentInvestorOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stepSize1 rdf:type rdf:Property ;
    rdfs:label 'Step Size 1' ;
    rdfs:comment 'Quantity (shares or face value) the investor will take at step_price_1 in a step order. Represents the first tier of a tiered demand schedule. Null for non-step orders.' ;
    rdfs:domain ind:InvestmentInvestorOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stepSize2 rdf:type rdf:Property ;
    rdfs:label 'Step Size 2' ;
    rdfs:comment 'Quantity (shares or face value) the investor will take at step_price_2 in a step order. Represents the second tier of a tiered demand schedule. Null for non-step orders.' ;
    rdfs:domain ind:InvestmentInvestorOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leagueTableId rdf:type rdf:Property ;
    rdfs:label 'League Table Id' ;
    rdfs:comment 'Unique identifier for the league table ranking record. Primary key.' ;
    rdfs:domain ind:LeagueTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acceptedCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Accepted Credit Amount' ;
    rdfs:comment 'The final transaction value credit accepted and published by the league table provider after any disputes or adjustments. This is the official credit amount that counts toward the ranking.' ;
    rdfs:domain ind:LeagueTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acceptedCreditCurrency rdf:type rdf:Property ;
    rdfs:label 'Accepted Credit Currency' ;
    rdfs:comment 'The currency in which the accepted credit amount is denominated, using ISO 4217 three-letter currency codes. [ENUM-REF-CANDIDATE: USD|EUR|GBP|JPY|CNY|CHF|AUD|CAD|HKD|SGD — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LeagueTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankRole rdf:type rdf:Property ;
    rdfs:label 'Bank Role' ;
    rdfs:comment 'The specific role the bank played in the transaction that generated the league table credit. Roles vary by product type and include bookrunner, lead manager, financial advisor, lead arranger, and co-arranger positions. [ENUM-REF-CANDIDATE: Sole Bookrunner|Joint Bookrunner|Lead Manager|Co-Manager|Financial Advisor|Lead Arranger|Co-Arranger — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Investment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookrunnerAllocationPct rdf:type rdf:Property ;
    rdfs:label 'Bookrunner Allocation Pct' ;
    rdfs:comment 'The percentage of the transaction value allocated to the bank as bookrunner or lead arranger. Used when credit methodology is pro rata or role-based.' ;
    rdfs:domain ind:Investment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clientName rdf:type rdf:Property ;
    rdfs:label 'Client Name' ;
    rdfs:comment 'The name of the client or issuer for whom the bank provided investment banking services in the transaction. May be confidential depending on engagement terms.' ;
    rdfs:domain ind:Investment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coAdvisorCount rdf:type rdf:Property ;
    rdfs:label 'Co Advisor Count' ;
    rdfs:comment 'The total number of other financial institutions that shared advisory or underwriting roles on the transaction. Used to understand competitive intensity and credit sharing.' ;
    rdfs:domain ind:LeagueTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:creditMethodology rdf:type rdf:Property ;
    rdfs:label 'Credit Methodology' ;
    rdfs:comment 'The methodology used by the ranking provider to allocate credit for transactions. Common methods include full credit (each participant gets full deal value), equal credit (deal value split equally), pro rata (credit based on participation percentage), or bookrunner-only credit.' ;
    rdfs:domain ind:Investment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossBorderFlag rdf:type rdf:Property ;
    rdfs:label 'Cross Border Flag' ;
    rdfs:comment 'Indicates whether the transaction involved parties or assets from multiple countries. True for cross-border transactions, false for domestic transactions.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dealCount rdf:type rdf:Property ;
    rdfs:label 'Deal Count' ;
    rdfs:comment 'The total number of transactions or deals completed by the bank during the ranking period that contributed to the league table credit.' ;
    rdfs:domain ind:LeagueTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dealVolumeAmount rdf:type rdf:Property ;
    rdfs:label 'Deal Volume Amount' ;
    rdfs:comment 'The total transaction value or volume of deals completed by the bank during the ranking period. Represents the aggregate dollar value of all transactions that contributed to the league table credit.' ;
    rdfs:domain ind:LeagueTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dealVolumeCurrency rdf:type rdf:Property ;
    rdfs:label 'Deal Volume Currency' ;
    rdfs:comment 'The currency in which the deal volume amount is denominated. Typically reported in major currencies using ISO 4217 three-letter currency codes. [ENUM-REF-CANDIDATE: USD|EUR|GBP|JPY|CNY|CHF|AUD|CAD|HKD|SGD — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LeagueTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeStatus rdf:type rdf:Property ;
    rdfs:label 'Dispute Status' ;
    rdfs:comment 'Indicates whether the bank or another party has filed a dispute regarding the credit allocation or ranking, and the current status of that dispute resolution process.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Fee Revenue Amount' ;
    rdfs:comment 'The total fee revenue earned by the bank from the transaction that contributed to this league table ranking. Confidential financial information used for internal performance measurement.' ;
    rdfs:domain ind:LeagueTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feeRevenueCurrency rdf:type rdf:Property ;
    rdfs:label 'Fee Revenue Currency' ;
    rdfs:comment 'The currency in which the fee revenue was earned and recorded, using ISO 4217 three-letter currency codes. [ENUM-REF-CANDIDATE: USD|EUR|GBP|JPY|CNY|CHF|AUD|CAD|HKD|SGD — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LeagueTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketSharePct rdf:type rdf:Property ;
    rdfs:label 'Market Share Pct' ;
    rdfs:comment 'The banks percentage share of the total market volume for the specified product, geography, and period. Calculated as the banks deal volume divided by total market volume.' ;
    rdfs:domain ind:LeagueTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:previousRankPosition rdf:type rdf:Property ;
    rdfs:label 'Previous Rank Position' ;
    rdfs:comment 'The banks rank position in the previous comparable period. Used to track movement and trends in competitive positioning.' ;
    rdfs:domain ind:LeagueTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rankPosition rdf:type rdf:Property ;
    rdfs:label 'Rank Position' ;
    rdfs:comment 'The numerical rank position of the bank in the league table for the specified product, geography, and period. Lower numbers indicate higher rankings (1 is the top position).' ;
    rdfs:domain ind:LeagueTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rankingPeriod rdf:type rdf:Property ;
    rdfs:label 'Ranking Period' ;
    rdfs:comment 'The time period for which the league table ranking applies. Can be quarterly, semi-annual, annual, year-to-date, or month-to-date. [ENUM-REF-CANDIDATE: Q1|Q2|Q3|Q4|H1|H2|Annual|YTD|MTD — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Investment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rankingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Ranking Period End Date' ;
    rdfs:comment 'The end date of the period covered by this league table ranking.' ;
    rdfs:domain ind:Investment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rankingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Ranking Period Start Date' ;
    rdfs:comment 'The start date of the period covered by this league table ranking.' ;
    rdfs:domain ind:Investment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rankingSource rdf:type rdf:Property ;
    rdfs:label 'Ranking Source' ;
    rdfs:comment 'The third-party provider or publication that publishes the league table ranking. Common sources include Bloomberg, Dealogic, Refinitiv, and other financial data providers.' ;
    rdfs:domain ind:LeagueTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rankingStatus rdf:type rdf:Property ;
    rdfs:label 'Ranking Status' ;
    rdfs:comment 'The current status of the league table ranking record. Indicates whether the ranking is final and published, provisional pending verification, under review, subject to dispute, withdrawn, or corrected after initial publication.' ;
    rdfs:domain ind:LeagueTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:walletSharePct rdf:type rdf:Property ;
    rdfs:label 'Wallet Share Pct' ;
    rdfs:comment 'The banks share of total fees or revenue generated in the market for the specified product and period. Represents the banks portion of the total fee pool.' ;
    rdfs:domain ind:LeagueTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:engagementChannelId rdf:type rdf:Property ;
    rdfs:label 'Engagement Channel Id' ;
    rdfs:comment 'Foreign key linking to channel.channel. Business justification: Client mandates for advisory services are signed through specific channels. MiFID II and Dodd-Frank require tracking client engagement channel for suitability and best execution compliance. Mandate ma' ;
    rdfs:domain ind:InvestmentMandate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:clientSignatoryName rdf:type rdf:Property ;
    rdfs:label 'Client Signatory Name' ;
    rdfs:comment 'Full name of the authorized client representative who executed the mandate letter on behalf of the client entity. Required for legal enforceability and Know Your Customer (KYC) documentation.' ;
    rdfs:domain ind:InvestmentMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientSignatoryTitle rdf:type rdf:Property ;
    rdfs:label 'Client Signatory Title' ;
    rdfs:comment 'Job title or designation of the client signatory (e.g., Chief Financial Officer, Managing Director) confirming their authority to bind the client entity under the mandate.' ;
    rdfs:domain ind:InvestmentMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealSizeCurrency rdf:type rdf:Property ;
    rdfs:label 'Deal Size Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the estimated or target transaction size. Used for fee calculation, pipeline reporting, and capital markets analytics.' ;
    rdfs:domain ind:Investment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeResolutionMechanism rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Mechanism' ;
    rdfs:comment 'Contractually agreed mechanism for resolving disputes arising under the mandate agreement (e.g., litigation in courts, arbitration under ICC/LCIA rules, mediation).' ;
    rdfs:domain ind:InvestmentMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedDealSize rdf:type rdf:Property ;
    rdfs:label 'Estimated Deal Size' ;
    rdfs:comment 'Estimated gross transaction value or deal size as agreed at mandate signing. Used for pipeline valuation, fee estimation, and Discounted Cash Flow (DCF) modelling. Expressed in deal_size_currency.' ;
    rdfs:domain ind:Investment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exclusivityEndDate rdf:type rdf:Property ;
    rdfs:label 'Exclusivity End Date' ;
    rdfs:comment 'End date of the exclusivity period. After this date, the client may engage competing advisors unless the mandate is renewed or the exclusivity is extended.' ;
    rdfs:domain ind:InvestmentMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exclusivityStartDate rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Start Date' ;
    rdfs:comment 'Start date of the exclusivity period during which the client is contractually restricted from engaging other advisors for the same transaction.' ;
    rdfs:domain ind:InvestmentMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:governingLawState rdf:type rdf:Property ;
    rdfs:label 'Governing Law State' ;
    rdfs:comment 'State or province within the governing law jurisdiction (e.g., New York, England and Wales) where sub-national law applies. Relevant for US and federal jurisdictions.' ;
    rdfs:domain ind:InvestmentMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industrySectorCode rdf:type rdf:Property ;
    rdfs:label 'Industry Sector Code' ;
    rdfs:comment 'Four-digit Standard Industrial Classification (SIC) or Global Industry Classification Standard (GICS) code representing the client\'s primary industry sector. Used for sector-based pipeline analytics and coverage team assignment.' ;
    rdfs:domain ind:InvestmentMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investmentMandateStatus rdf:type rdf:Property ;
    rdfs:label 'Investment Mandate Status' ;
    rdfs:comment 'Current lifecycle state of the mandate agreement. Drives pipeline reporting, fee accrual eligibility, and deal team resource allocation. Valid states: draft (under negotiation), active (signed and in force), suspended (temporarily paused), terminated (cancelled before completion), completed (transaction closed), lapsed (exclusivity expired without execution).' ;
    rdfs:domain ind:InvestmentMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isExclusive rdf:type rdf:Property ;
    rdfs:label 'Is Exclusive' ;
    rdfs:comment 'Indicates whether the mandate grants the bank exclusive advisory rights for the transaction, preventing the client from engaging competing advisors during the exclusivity period.' ;
    rdfs:domain ind:InvestmentMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:letterDate rdf:type rdf:Property ;
    rdfs:label 'Letter Date' ;
    rdfs:comment 'Date on which the mandate letter was formally signed and executed by both the bank and the client. This is the principal business event date establishing the contractual engagement.' ;
    rdfs:domain ind:InvestmentMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pitchBookReference rdf:type rdf:Property ;
    rdfs:label 'Pitch Book Reference' ;
    rdfs:comment 'Document management system reference or identifier for the pitch book or information memorandum presented to the client prior to mandate award. Supports audit trail and deal origination tracking.' ;
    rdfs:domain ind:InvestmentMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reference rdf:type rdf:Property ;
    rdfs:label 'Reference' ;
    rdfs:comment 'Externally-known alphanumeric reference code assigned to the mandate, used in client correspondence, pitch books, and regulatory filings. Format: LOB-MND-YYYY-NNNNNNNN.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retainerFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Retainer Fee Amount' ;
    rdfs:comment 'Fixed upfront or periodic retainer fee payable by the client to the bank upon mandate signing, independent of transaction completion. Expressed in deal_size_currency.' ;
    rdfs:domain ind:InvestmentMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:successFeeBps rdf:type rdf:Property ;
    rdfs:label 'Success Fee Bps' ;
    rdfs:comment 'Contingent success fee expressed in Basis Points (BPS) of the final transaction value, payable upon successful completion of the mandated transaction. Drives revenue recognition and Profit and Loss (PnL) attribution.' ;
    rdfs:domain ind:InvestmentMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:terminationRights rdf:type rdf:Property ;
    rdfs:label 'Termination Rights' ;
    rdfs:comment 'Description of the contractual termination rights available to either party, including notice periods, termination for convenience clauses, material adverse change (MAC) provisions, and tail fee obligations upon termination.' ;
    rdfs:domain ind:InvestmentMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offeringId rdf:type rdf:Property ;
    rdfs:label 'Offering Id' ;
    rdfs:comment 'Primary key for offering' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:marketCenterId rdf:type rdf:Property ;
    rdfs:label 'Market Center Id' ;
    rdfs:comment 'Foreign key linking to reference.market_center. Business justification: Exchange code links to market_center for listing venue identification, trading surveillance, best execution reporting (MiFID II), and market data distribution.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MarketCenter .

ind:primaryDistributionChannelId rdf:type rdf:Property ;
    rdfs:label 'Primary Distribution Channel Id' ;
    rdfs:comment 'Foreign key linking to channel.channel. Business justification: Capital markets offerings are distributed through channels - retail tranches via branches/digital, institutional via RM networks. Syndicate desks track primary distribution channel for allocation deci' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:referenceInstrumentClassificationId rdf:type rdf:Property ;
    rdfs:label 'Reference Instrument Classification Id' ;
    rdfs:comment 'Foreign key linking to reference.instrument_classification. Business justification: Offering type classification drives regulatory treatment, FRTB book assignment, and investor eligibility determination for capital markets offerings.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InstrumentClassification .

ind:bookrunnerName rdf:type rdf:Property ;
    rdfs:label 'Bookrunner Name' ;
    rdfs:comment 'Name of the lead bookrunner (global coordinator) investment bank responsible for managing the bookbuilding process, allocating securities to investors, and stabilizing the aftermarket. For syndicated offerings, this is the primary bookrunner.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:couponRate rdf:type rdf:Property ;
    rdfs:label 'Coupon Rate' ;
    rdfs:comment 'Annual interest rate (coupon) expressed as a percentage of par value for debt offerings (investment grade bonds, high yield bonds, convertible bonds). Null for equity offerings. Key pricing term for DCM transactions.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketSegment rdf:type rdf:Property ;
    rdfs:label 'Market Segment' ;
    rdfs:comment 'Identifies whether the offering belongs to Equity Capital Markets (ECM) or Debt Capital Markets (DCM), leveraged finance, or structured finance. Drives divisional P&L attribution and regulatory reporting classification.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerPrice rdf:type rdf:Property ;
    rdfs:label 'Offer Price' ;
    rdfs:comment 'Final price per share or per unit at which securities are offered to investors, set at pricing date. For debt offerings, expressed as a percentage of par value (e.g., 99.50). Central pricing fact for the ECM/DCM transaction.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:offeringNumber rdf:type rdf:Property ;
    rdfs:label 'Offering Number' ;
    rdfs:comment 'Externally-known alphanumeric reference code assigned by the investment banking division to uniquely identify this offering across deal management, regulatory filing, and syndication systems (e.g., ECM-2024-00123).' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offeringStatus rdf:type rdf:Property ;
    rdfs:label 'Offering Status' ;
    rdfs:comment 'Current lifecycle state of the capital markets offering, tracking progression from deal pipeline through regulatory filing, investor roadshow, pricing, and final closing or withdrawal. [ENUM-REF-CANDIDATE: pipeline|mandated|filed|roadshow|priced|closed|withdrawn|postponed — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallotmentAmount rdf:type rdf:Property ;
    rdfs:label 'Overallotment Amount' ;
    rdfs:comment 'Additional securities amount available under the overallotment (greenshoe) option, typically up to 15% of the base offering size. Exercisable by the stabilizing manager to cover excess demand and support post-listing price stability.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceRangeHigh rdf:type rdf:Property ;
    rdfs:label 'Price Range High' ;
    rdfs:comment 'Upper bound of the indicative price range communicated to investors during the roadshow and bookbuilding process, prior to final pricing. Used in preliminary prospectus and investor marketing materials.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceRangeLow rdf:type rdf:Property ;
    rdfs:label 'Price Range Low' ;
    rdfs:comment 'Lower bound of the indicative price range communicated to investors during the roadshow and bookbuilding process, prior to final pricing. Used in preliminary prospectus and investor marketing materials.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regSEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Reg S Eligible Flag' ;
    rdfs:comment 'Indicates whether the offering is eligible for distribution to non-US investors under SEC Regulation S (offshore transactions), enabling international tranche distribution without full SEC registration.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryFilingType rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Type' ;
    rdfs:comment 'Type of regulatory registration or prospectus filing submitted to the relevant securities regulator (e.g., SEC Form S-1 for US domestic IPO, F-1 for foreign private issuer, prospectus for EU/UK offerings). Drives compliance workflow and filing deadline tracking. [ENUM-REF-CANDIDATE: S-1|F-1|S-3|S-11|424B|prospectus|listing_particulars|none — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roadshowEndDate rdf:type rdf:Property ;
    rdfs:label 'Roadshow End Date' ;
    rdfs:comment 'Date on which the investor roadshow and bookbuilding process concluded, immediately preceding the pricing date. Used to measure roadshow duration and investor engagement analytics.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:roadshowStartDate rdf:type rdf:Property ;
    rdfs:label 'Roadshow Start Date' ;
    rdfs:comment 'Date on which the investor roadshow and bookbuilding process commenced. Marks the beginning of formal investor marketing and demand generation for the offering.' ;
    rdfs:domain ind:Investment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rule144aEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Rule 144a Eligible Flag' ;
    rdfs:comment 'Indicates whether the offering qualifies for resale to Qualified Institutional Buyers (QIBs) under SEC Rule 144A, enabling a private placement tranche alongside or instead of a registered public offering.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sharesOffered rdf:type rdf:Property ;
    rdfs:label 'Shares Offered' ;
    rdfs:comment 'Total number of shares or units offered in the transaction (base offering, excluding overallotment). Applicable to equity offerings (IPO, follow-on, rights issue). For debt offerings, represents face value units.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sizeAmount rdf:type rdf:Property ;
    rdfs:label 'Size Amount' ;
    rdfs:comment 'Total gross proceeds targeted to be raised in the offering, expressed in the offering currency. Represents the base deal size before any overallotment (greenshoe) exercise. Core monetary fact for ECM/DCM transaction records.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stabilizationFlag rdf:type rdf:Property ;
    rdfs:label 'Stabilization Flag' ;
    rdfs:comment 'Indicates whether the stabilizing manager is authorized to conduct post-listing price stabilization activities (e.g., greenshoe exercise, open market purchases) to support the offering price in the secondary market.' ;
    rdfs:domain ind:Investment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:syndicateSize rdf:type rdf:Property ;
    rdfs:label 'Syndicate Size' ;
    rdfs:comment 'Total number of investment banks participating in the underwriting syndicate for this offering, including bookrunners, co-managers, and selling group members. Indicates deal complexity and distribution breadth.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tombstonePublishedFlag rdf:type rdf:Property ;
    rdfs:label 'Tombstone Published Flag' ;
    rdfs:comment 'Indicates whether the tombstone announcement (deal announcement advertisement) has been published following successful closing of the offering. Tombstones serve as the official public record of completed capital markets transactions.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalProceedsAmount rdf:type rdf:Property ;
    rdfs:label 'Total Proceeds Amount' ;
    rdfs:comment 'Actual total gross proceeds raised at closing, including any overallotment option exercised. Represents the final deal size and is the primary monetary outcome metric for the offering.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:underwritingDiscountBps rdf:type rdf:Property ;
    rdfs:label 'Underwriting Discount Bps' ;
    rdfs:comment 'Gross underwriting spread expressed in basis points (BPS) as a percentage of total offering proceeds. Represents the total fee paid to the underwriting syndicate, covering management fee, underwriting fee, and selling concession.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:underwritingFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Underwriting Fee Amount' ;
    rdfs:comment 'Absolute monetary value of the gross underwriting fee payable to the underwriting syndicate, derived from the underwriting discount applied to total proceeds. Key revenue metric for investment banking P&L attribution.' ;
    rdfs:domain ind:Investment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:useOfProceeds rdf:type rdf:Property ;
    rdfs:label 'Use Of Proceeds' ;
    rdfs:comment 'Narrative description of how the issuer intends to deploy the capital raised from the offering (e.g., debt repayment, capital expenditure, working capital, acquisitions). Required disclosure in the prospectus under SEC Regulation S-K Item 504.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPipelineEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Pipeline Employee Id' ;
    rdfs:comment 'Identifier of the user who created this pipeline stage definition in the system.' ;
    rdfs:domain ind:PipelineStage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryPredecessorStagePipelineStageId rdf:type rdf:Property ;
    rdfs:label 'Primary Predecessor Stage Pipeline Stage Id' ;
    rdfs:comment 'Reference to the pipeline stage that typically precedes this stage in the standard deal progression workflow.' ;
    rdfs:domain ind:PipelineStage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PipelineStage .

ind:amlScreeningRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Aml Screening Required Flag' ;
    rdfs:comment 'Indicates whether Anti-Money Laundering screening and sanctions checks must be performed at this stage.' ;
    rdfs:domain ind:PipelineStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvalCommitteeType rdf:type rdf:Property ;
    rdfs:label 'Approval Committee Type' ;
    rdfs:comment 'Type of committee responsible for approving deals at this stage, if approval is required.' ;
    rdfs:domain ind:PipelineStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageDurationDays rdf:type rdf:Property ;
    rdfs:label 'Average Duration Days' ;
    rdfs:comment 'Typical number of days a deal remains in this stage based on historical data, used for timeline planning and bottleneck identification.' ;
    rdfs:domain ind:PipelineStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clientNotificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Client Notification Required Flag' ;
    rdfs:comment 'Indicates whether formal notification to the client is required when a deal transitions to this stage.' ;
    rdfs:domain ind:PipelineStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conflictCheckRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Conflict Check Required Flag' ;
    rdfs:comment 'Indicates whether a formal conflict of interest check must be completed before a deal can enter or progress through this stage.' ;
    rdfs:domain ind:PipelineStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dealTypeApplicability rdf:type rdf:Property ;
    rdfs:label 'Deal Type Applicability' ;
    rdfs:comment 'Comma-separated list of deal types for which this stage is relevant (e.g., IPO, M&A, Debt Issuance, Equity Offering).' ;
    rdfs:domain ind:PipelineStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:displayOrder rdf:type rdf:Property ;
    rdfs:label 'Display Order' ;
    rdfs:comment 'Numeric value controlling the presentation order of stages in user interfaces and reports, allowing for custom sorting independent of sequence number.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:entryCriteria rdf:type rdf:Property ;
    rdfs:label 'Entry Criteria' ;
    rdfs:comment 'Business conditions and requirements that must be met for a deal to enter this stage.' ;
    rdfs:domain ind:PipelineStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exitCriteria rdf:type rdf:Property ;
    rdfs:label 'Exit Criteria' ;
    rdfs:comment 'Business conditions and requirements that must be met for a deal to progress from this stage to the next.' ;
    rdfs:domain ind:PipelineStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyDeliverables rdf:type rdf:Property ;
    rdfs:label 'Key Deliverables' ;
    rdfs:comment 'Primary work products and documentation that must be completed during this stage (e.g., pitch book, valuation model, due diligence report).' ;
    rdfs:domain ind:PipelineStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kycRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Kyc Required Flag' ;
    rdfs:comment 'Indicates whether Know Your Customer due diligence must be completed at this stage to comply with anti-money laundering regulations.' ;
    rdfs:domain ind:PipelineStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minimumApprovalLevel rdf:type rdf:Property ;
    rdfs:label 'Minimum Approval Level' ;
    rdfs:comment 'Minimum seniority level of approver required for deals at this stage, ensuring appropriate oversight based on deal complexity and risk.' ;
    rdfs:domain ind:PipelineStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:probabilityWeightingPct rdf:type rdf:Property ;
    rdfs:label 'Probability Weighting Pct' ;
    rdfs:comment 'Statistical probability percentage that a deal in this stage will successfully close, used for pipeline revenue forecasting and weighted deal value calculations.' ;
    rdfs:domain ind:PipelineStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueRecognitionTriggerFlag rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Trigger Flag' ;
    rdfs:comment 'Indicates whether reaching this stage triggers revenue recognition events under applicable accounting standards.' ;
    rdfs:domain ind:PipelineStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rwaCalculationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Rwa Calculation Required Flag' ;
    rdfs:comment 'Indicates whether Risk-Weighted Assets must be calculated for deals at this stage for regulatory capital purposes.' ;
    rdfs:domain ind:PipelineStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Sequence Number' ;
    rdfs:comment 'Ordinal position of this stage in the standard deal pipeline progression, used for sorting and workflow automation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stageCategory rdf:type rdf:Property ;
    rdfs:label 'Stage Category' ;
    rdfs:comment 'High-level categorization of the pipeline stage grouping similar stages together for strategic analysis and reporting.' ;
    rdfs:domain ind:PipelineStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stageCode rdf:type rdf:Property ;
    rdfs:label 'Stage Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the pipeline stage for system integration and reporting purposes.' ;
    rdfs:domain ind:PipelineStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stageColorCode rdf:type rdf:Property ;
    rdfs:label 'Stage Color Code' ;
    rdfs:comment 'Hexadecimal color code used for visual representation of this stage in dashboards and pipeline visualizations.' ;
    rdfs:domain ind:PipelineStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stageDescription rdf:type rdf:Property ;
    rdfs:label 'Stage Description' ;
    rdfs:comment 'Detailed description of the activities, milestones, and deliverables associated with this pipeline stage.' ;
    rdfs:domain ind:PipelineStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stageIconReference rdf:type rdf:Property ;
    rdfs:label 'Stage Icon Reference' ;
    rdfs:comment 'Reference identifier or path to the icon image used to represent this stage in user interfaces.' ;
    rdfs:domain ind:PipelineStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stageName rdf:type rdf:Property ;
    rdfs:label 'Stage Name' ;
    rdfs:comment 'Human-readable name of the deal pipeline stage (e.g., Origination, Pitch, Mandate, Due Diligence, Execution, Closing).' ;
    rdfs:domain ind:PipelineStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stageStatus rdf:type rdf:Property ;
    rdfs:label 'Stage Status' ;
    rdfs:comment 'Current operational status of the pipeline stage indicating whether it is actively used in deal workflows.' ;
    rdfs:domain ind:PipelineStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pitchBookId rdf:type rdf:Property ;
    rdfs:label 'Pitch Book Id' ;
    rdfs:comment 'Unique identifier for the investment banking pitch book record. Primary key for this entity.' ;
    rdfs:domain ind:PitchBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:investmentProposalId rdf:type rdf:Property ;
    rdfs:label 'Investment Proposal Id' ;
    rdfs:comment 'Foreign key linking to wealth.investment_proposal. Business justification: Investment banking pitch books for HNW clients often inform or are informed by wealth management investment proposals. Real business process: coordinated client presentation across investment banking ' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InvestmentProposal .

ind:presentationChannelId rdf:type rdf:Property ;
    rdfs:label 'Presentation Channel Id' ;
    rdfs:comment 'Foreign key linking to channel.channel. Business justification: Pitch books are presented through specific channels (in-person branch meetings, digital platforms, video banking). Investment banking CRM systems track presentation channel for conversion analysis, ch' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:competitiveSituation rdf:type rdf:Property ;
    rdfs:label 'Competitive Situation' ;
    rdfs:comment 'Classification of the competitive dynamics for the mandate, indicating whether the bank is competing against other advisors and the selection process type.' ;
    rdfs:domain ind:PitchBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentVersion rdf:type rdf:Property ;
    rdfs:label 'Document Version' ;
    rdfs:comment 'Version identifier for the pitch book document, tracking iterations and revisions throughout the preparation and approval process.' ;
    rdfs:domain ind:PitchBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Fee Amount' ;
    rdfs:comment 'The projected advisory or underwriting fee amount that the bank expects to earn if the mandate is won, used for pipeline revenue forecasting.' ;
    rdfs:domain ind:PitchBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:filePath rdf:type rdf:Property ;
    rdfs:label 'File Path' ;
    rdfs:comment 'The network or cloud storage location where the pitch book document file is stored for retrieval and archival purposes.' ;
    rdfs:domain ind:PitchBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ndaRequired rdf:type rdf:Property ;
    rdfs:label 'Nda Required' ;
    rdfs:comment 'Indicates whether a signed non-disclosure agreement is required before the pitch book can be shared with the client or third parties.' ;
    rdfs:domain ind:PitchBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:outcomeDate rdf:type rdf:Property ;
    rdfs:label 'Outcome Date' ;
    rdfs:comment 'The date on which the client communicated their decision regarding the mandate award, marking the conclusion of the pitch process.' ;
    rdfs:domain ind:PitchBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pitchOutcome rdf:type rdf:Property ;
    rdfs:label 'Pitch Outcome' ;
    rdfs:comment 'The final result of the pitch effort, indicating whether the bank successfully secured the advisory mandate or underwriting role.' ;
    rdfs:domain ind:PitchBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pitchStatus rdf:type rdf:Property ;
    rdfs:label 'Pitch Status' ;
    rdfs:comment 'Current lifecycle status of the pitch book in the deal origination workflow, tracking progression from creation through outcome. [ENUM-REF-CANDIDATE: Draft|Under Review|Approved|Presented|Won|Lost|Withdrawn — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PitchBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pitchType rdf:type rdf:Property ;
    rdfs:label 'Pitch Type' ;
    rdfs:comment 'The category of investment banking service being pitched. Classifies the nature of the proposed engagement. [ENUM-REF-CANDIDATE: M&A Advisory|IPO Underwriting|Debt Capital Markets|Equity Capital Markets|Restructuring Advisory|Fairness Opinion|Valuation Services|Strategic Advisory|Leveraged Finance|Private Placement — promote to reference product]' ;
    rdfs:domain ind:PitchBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:precedentList rdf:type rdf:Property ;
    rdfs:label 'Precedent List' ;
    rdfs:comment 'Comma-separated list or summary of key precedent transactions cited in the pitch book for valuation and market positioning analysis.' ;
    rdfs:domain ind:PitchBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:precedentTransactionCount rdf:type rdf:Property ;
    rdfs:label 'Precedent Transaction Count' ;
    rdfs:comment 'The number of comparable precedent transactions referenced in the pitch book to demonstrate market context and valuation benchmarks.' ;
    rdfs:domain ind:PitchBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:presentationDate rdf:type rdf:Property ;
    rdfs:label 'Presentation Date' ;
    rdfs:comment 'The date on which the pitch book was formally presented to the client or prospect. Key milestone in the deal origination timeline.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:subSector rdf:type rdf:Property ;
    rdfs:label 'Sub Sector' ;
    rdfs:comment 'The granular sub-sector classification within the primary industry sector, enabling more precise precedent analysis and competitive positioning.' ;
    rdfs:domain ind:PitchBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetClientName rdf:type rdf:Property ;
    rdfs:label 'Target Client Name' ;
    rdfs:comment 'The legal or trading name of the client organization being pitched. May differ from the client master record if pitching to a subsidiary or division.' ;
    rdfs:domain ind:PitchBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationMethodology rdf:type rdf:Property ;
    rdfs:label 'Valuation Methodology' ;
    rdfs:comment 'The primary valuation approach or methodology presented in the pitch book to support transaction pricing and fairness analysis.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:winProbabilityPct rdf:type rdf:Property ;
    rdfs:label 'Win Probability Pct' ;
    rdfs:comment 'The estimated probability of winning the mandate based on competitive positioning, client relationship strength, and market intelligence, expressed as a percentage.' ;
    rdfs:domain ind:PitchBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:investmentSyndicationId rdf:type rdf:Property ;
    rdfs:label 'Investment Syndication Id' ;
    rdfs:comment 'Unique surrogate identifier for the syndicated lending or capital markets syndication record. Primary key for the syndication master entity.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InvestmentSyndication .

ind:investorFundId rdf:type rdf:Property ;
    rdfs:label 'Investor Fund Id' ;
    rdfs:comment 'Foreign key linking to asset.fund. Business justification: Institutional funds are major participants in syndicated loan and debt markets as lenders/investors. Real business process: syndication book-building, investor allocation management, and relationship ' ;
    rdfs:domain ind:InvestmentSyndication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fund .

ind:liquidityPositionId rdf:type rdf:Property ;
    rdfs:label 'Liquidity Position Id' ;
    rdfs:comment 'Foreign key linking to treasury.liquidity_position. Business justification: Syndicated facilities impact bank liquidity positions through commitment drawdowns and funding requirements. Business process: liquidity risk management tracks syndication exposures in LCR/NSFR regula' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LiquidityPosition .

ind:marketingChannelId rdf:type rdf:Property ;
    rdfs:label 'Marketing Channel Id' ;
    rdfs:comment 'Foreign key linking to channel.channel. Business justification: Loan syndications are marketed through specific channels - institutional sales desks, digital loan platforms (LoanIQ, SyndTrak), RM networks. Syndicate desks track marketing channel for lender reach a' ;
    rdfs:domain ind:InvestmentSyndication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:actualSelldownAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Selldown Amount' ;
    rdfs:comment 'The amount actually distributed to third-party lenders at close of syndication. May differ from target_selldown_amount due to market conditions, pricing flex, or investor demand shortfall.' ;
    rdfs:domain ind:InvestmentSyndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:arrangementFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Arrangement Fee Amount' ;
    rdfs:comment 'The total arrangement fee earned by the bank for structuring and executing the syndication, expressed in deal currency. Recognized as fee income upon close per IFRS 15 / FASB ASC 606.' ;
    rdfs:domain ind:Investment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bankHoldAmount rdf:type rdf:Property ;
    rdfs:label 'Bank Hold Amount' ;
    rdfs:comment 'The portion of the total facility that the arranging bank intends to retain on its own balance sheet after syndication. Reflects the bank\'s final hold position and drives RWA and capital consumption calculations.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bookrunnerRole rdf:type rdf:Property ;
    rdfs:label 'Bookrunner Role' ;
    rdfs:comment 'The bank\'s role in the syndication as bookrunner or arranger: sole_bookrunner, joint_bookrunner, co_bookrunner, mandated_lead_arranger (MLA), or lead_arranger. Determines fee entitlement and decision-making authority in the syndicate.' ;
    rdfs:domain ind:InvestmentSyndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closeDate rdf:type rdf:Property ;
    rdfs:label 'Close Date' ;
    rdfs:comment 'The date on which the syndication was formally closed and the credit agreement was executed with the final lender group. Corresponds to the effective date of the facility.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coArrangerList rdf:type rdf:Property ;
    rdfs:label 'Co Arranger List' ;
    rdfs:comment 'Comma-separated list of co-arranger bank names or BIC codes participating in the syndication alongside the bookrunner. Captures the arranger group composition for tombstone records, fee sharing, and regulatory reporting.' ;
    rdfs:domain ind:InvestmentSyndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentDeadline rdf:type rdf:Property ;
    rdfs:label 'Commitment Deadline' ;
    rdfs:comment 'The deadline by which prospective lenders must submit their commitments during the bookbuilding phase. Drives the syndication desk\'s investor outreach timeline.' ;
    rdfs:domain ind:InvestmentSyndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentationStandard rdf:type rdf:Property ;
    rdfs:label 'Documentation Standard' ;
    rdfs:comment 'The market documentation standard used for the syndicated loan agreement: LMA (Loan Market Association — EMEA), LSTA (Loan Syndication and Trading Association — US), APLMA (Asia Pacific), or bespoke. Governs transferability, voting thresholds, and secondary market conventions.' ;
    rdfs:domain ind:InvestmentSyndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esgFlag rdf:type rdf:Property ;
    rdfs:label 'Esg Flag' ;
    rdfs:comment 'Indicates whether the syndicated facility is structured as an ESG-linked loan or sustainability-linked loan (SLL), where pricing is tied to the borrower\'s ESG performance targets. Supports green finance reporting and investor ESG mandates.' ;
    rdfs:domain ind:InvestmentSyndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:flexAmountBps rdf:type rdf:Property ;
    rdfs:label 'Flex Amount Bps' ;
    rdfs:comment 'The magnitude of the pricing flex applied, expressed in basis points. Positive value indicates widening; negative value indicates tightening. Captures the delta between initial price talk and final pricing.' ;
    rdfs:domain ind:InvestmentSyndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lenderCount rdf:type rdf:Property ;
    rdfs:label 'Lender Count' ;
    rdfs:comment 'The total number of lenders in the final syndicate at close. Indicates syndication breadth and diversification of the lender group; used in post-deal analytics and tombstone records.' ;
    rdfs:domain ind:InvestmentSyndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:leveragedLoanFlag rdf:type rdf:Property ;
    rdfs:label 'Leveraged Loan Flag' ;
    rdfs:comment 'Indicates whether the syndicated facility meets the OCC/Fed/FDIC definition of a leveraged loan (typically total debt/EBITDA > 4x or borrower rated below investment grade). Triggers enhanced regulatory scrutiny and reporting under interagency leveraged lending guidance.' ;
    rdfs:domain ind:InvestmentSyndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:oidBps rdf:type rdf:Property ;
    rdfs:label 'Oid Bps' ;
    rdfs:comment 'The original issue discount expressed in basis points, representing the upfront discount to par at which the loan is issued to lenders. Common in leveraged loan syndications; impacts lender yield and borrower all-in cost.' ;
    rdfs:domain ind:InvestmentSyndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oversubscriptionAmount rdf:type rdf:Property ;
    rdfs:label 'Oversubscription Amount' ;
    rdfs:comment 'The amount by which investor commitments exceeded the target syndication amount during bookbuilding. A positive value indicates strong market demand; used for pricing flex decisions and greenshoe allocation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricingFlexType rdf:type rdf:Property ;
    rdfs:label 'Pricing Flex Type' ;
    rdfs:comment 'Indicates the direction of pricing flex applied during bookbuilding: tightened (spread reduced due to oversubscription), held (no change), flexed_wider (spread increased due to weak demand), oid_added, oid_increased, or structure_changed. Key indicator of market reception.' ;
    rdfs:domain ind:InvestmentSyndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purposeCode rdf:type rdf:Property ;
    rdfs:label 'Purpose Code' ;
    rdfs:comment 'The stated purpose of the syndicated facility: acquisition_finance, leveraged_buyout (LBO), refinancing, general_corporate, capital_expenditure (capex), or working_capital. Used for regulatory classification, OCC leveraged lending identification, and portfolio analytics.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:syndicationStatus rdf:type rdf:Property ;
    rdfs:label 'Syndication Status' ;
    rdfs:comment 'Current lifecycle state of the syndication process: mandate_awarded (bank selected as arranger), launched (syndication formally opened to market), bookbuilding (collecting lender commitments), priced (spread and terms finalized), closed (facility fully allocated), withdrawn (deal pulled from market), failed (insufficient demand). [ENUM-REF-CANDIDATE: mandate_awarded|launched|bookbuilding|priced|closed|withdrawn|failed|post_close — promote to reference product]' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:syndicationType rdf:type rdf:Property ;
    rdfs:label 'Syndication Type' ;
    rdfs:comment 'Classification of the syndication structure: primary_syndication (initial distribution to lender group), secondary_sell_down (post-close transfer of hold), club_deal (small bilateral group), best_efforts (no underwriting commitment), underwritten (bank commits full amount). [ENUM-REF-CANDIDATE: primary_syndication|secondary_sell_down|club_deal|best_efforts|underwritten|participation — promote to reference product]' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetSelldownAmount rdf:type rdf:Property ;
    rdfs:label 'Target Selldown Amount' ;
    rdfs:comment 'The target amount the bank aims to distribute to third-party lenders through the syndication process. Equals total_facility_amount minus bank_hold_amount at deal inception; may be revised during bookbuilding.' ;
    rdfs:domain ind:InvestmentSyndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tenorMonths rdf:type rdf:Property ;
    rdfs:label 'Tenor Months' ;
    rdfs:comment 'The contractual tenor of the syndicated facility expressed in months from the close date to final maturity. Key parameter for duration risk, regulatory capital, and investor suitability assessment.' ;
    rdfs:domain ind:InvestmentSyndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalFacilityAmount rdf:type rdf:Property ;
    rdfs:label 'Total Facility Amount' ;
    rdfs:comment 'Gross size of the syndicated credit facility or capital markets transaction in the deal currency. Represents the full commitment amount before any sell-down or hold reduction.' ;
    rdfs:domain ind:InvestmentSyndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:upfrontFeeBps rdf:type rdf:Property ;
    rdfs:label 'Upfront Fee Bps' ;
    rdfs:comment 'The upfront participation fee paid to lenders expressed in basis points of their commitment. Incentivizes early commitment during bookbuilding and is a key component of lender all-in yield.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:syndicationAllocationId rdf:type rdf:Property ;
    rdfs:label 'Syndication Allocation Id' ;
    rdfs:comment 'Unique surrogate identifier for each syndication allocation line-item record in the silver layer lakehouse. Primary key for this transactional line entity.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SyndicationAllocation .

ind:trancheId rdf:type rdf:Property ;
    rdfs:label 'Tranche Id' ;
    rdfs:comment 'Reference to the specific tranche of the syndicated facility being allocated (e.g., Term Loan A, Term Loan B, Revolving Credit Facility). A syndication may have multiple tranches with separate allocation books.' ;
    rdfs:domain ind:Investment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Tranche .

ind:allocatedAmount rdf:type rdf:Property ;
    rdfs:label 'Allocated Amount' ;
    rdfs:comment 'The principal monetary amount of the syndicated loan or bond tranche allocated to this participant institution. Represents the participant\'s share of the total facility commitment in the deal currency.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationDate rdf:type rdf:Property ;
    rdfs:label 'Allocation Date' ;
    rdfs:comment 'The business date on which the syndication desk formally allocated this tranche amount to the participant institution. Marks the principal real-world event time for this allocation line-item.' ;
    rdfs:domain ind:SyndicationAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allocationReference rdf:type rdf:Property ;
    rdfs:label 'Allocation Reference' ;
    rdfs:comment 'Externally-known business identifier for this allocation line, as generated by the Loan IQ syndication module or the syndication desk. Used in participant confirmation notices, participation agreements, and settlement instructions.' ;
    rdfs:domain ind:SyndicationAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationType rdf:type rdf:Property ;
    rdfs:label 'Allocation Type' ;
    rdfs:comment 'Classifies whether this allocation is part of the primary syndication (initial distribution), a secondary sell-down (post-close transfer of risk), a formal loan transfer, or a sub-participation arrangement. Determines accounting treatment and regulatory capital impact.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookingEntityCode rdf:type rdf:Property ;
    rdfs:label 'Booking Entity Code' ;
    rdfs:comment 'The legal entity code of the bank\'s booking entity that holds this allocation on its balance sheet. Critical for regulatory capital reporting, FATCA/CRS entity-level reporting, and intercompany reconciliation in multi-entity banking groups.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentDate rdf:type rdf:Property ;
    rdfs:label 'Commitment Date' ;
    rdfs:comment 'The date on which the participant institution submitted its commitment (firm or soft) to participate in the syndication. Precedes the allocation date and is used to track the book-building timeline.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:commitmentType rdf:type rdf:Property ;
    rdfs:label 'Commitment Type' ;
    rdfs:comment 'Nature of the participant\'s commitment to the allocation. Firm commitments are legally binding; soft commitments are indicative and subject to withdrawal; sub-underwrite and underwrite indicate risk-taking obligations; best_efforts indicates no guaranteed take-down.' ;
    rdfs:domain ind:Investment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeSharePct rdf:type rdf:Property ;
    rdfs:label 'Fee Share Pct' ;
    rdfs:comment 'The participant\'s proportional share of total syndication fees expressed as a decimal percentage. Used to calculate the participant\'s entitlement to arrangement, participation, and agency fees distributed from the fee pool.' ;
    rdfs:domain ind:SyndicationAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:instrumentType rdf:type rdf:Property ;
    rdfs:label 'Instrument Type' ;
    rdfs:comment 'The type of debt instrument being allocated to the participant. Determines the applicable documentation standard (LMA/LSTA), interest calculation convention, and regulatory capital treatment under Basel III.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interestSpreadBps rdf:type rdf:Property ;
    rdfs:label 'Interest Spread Bps' ;
    rdfs:comment 'The credit spread in basis points (BPS) over the reference rate (e.g., SOFR, EURIBOR) applicable to this participant\'s allocation. Determines the participant\'s interest income on the allocated commitment.' ;
    rdfs:domain ind:SyndicationAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isAgentBank rdf:type rdf:Property ;
    rdfs:label 'Is Agent Bank' ;
    rdfs:comment 'Indicates whether the participant institution is also acting as the facility agent or security agent for the syndicated loan. The agent bank administers payments, waivers, and amendments on behalf of the lender group.' ;
    rdfs:domain ind:SyndicationAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLeadArranger rdf:type rdf:Property ;
    rdfs:label 'Is Lead Arranger' ;
    rdfs:comment 'Indicates whether the participant institution is acting as lead arranger or bookrunner for this syndication. Lead arrangers have additional obligations including book-building, documentation, and agent responsibilities.' ;
    rdfs:domain ind:SyndicationAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lgdPct rdf:type rdf:Property ;
    rdfs:label 'Lgd Pct' ;
    rdfs:comment 'The loss given default (LGD) estimate for this allocation expressed as a decimal percentage of the exposure at default (EAD). Used in ECL provisioning under IFRS 9/CECL and regulatory capital calculations under the IRB approach.' ;
    rdfs:domain ind:SyndicationAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:participationAgreementRef rdf:type rdf:Property ;
    rdfs:label 'Participation Agreement Ref' ;
    rdfs:comment 'Reference number or identifier of the executed participation agreement between the arranger and the participant institution governing the terms of this allocation. Used for legal documentation reconciliation.' ;
    rdfs:domain ind:SyndicationAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:participationFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Participation Fee Amount' ;
    rdfs:comment 'Fee paid to the participant institution for joining the syndication, typically expressed as basis points (BPS) on the allocated commitment. Distinct from the arrangement fee paid to the lead arranger.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:participationPct rdf:type rdf:Property ;
    rdfs:label 'Participation Pct' ;
    rdfs:comment 'The participant institution\'s pro-rata share of the total syndicated facility expressed as a decimal percentage (e.g., 0.125000 = 12.5%). Used to calculate pro-rata distributions of interest, fees, and principal repayments.' ;
    rdfs:domain ind:SyndicationAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pdRating rdf:type rdf:Property ;
    rdfs:label 'Pd Rating' ;
    rdfs:comment 'The probability of default (PD) assigned to the participant or the underlying borrower for this allocation, expressed as a decimal (e.g., 0.005 = 0.5%). Used in ECL calculations under IFRS 9/CECL and IRB capital models.' ;
    rdfs:domain ind:SyndicationAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryCapitalApproach rdf:type rdf:Property ;
    rdfs:label 'Regulatory Capital Approach' ;
    rdfs:comment 'The Basel III regulatory capital approach applied to this allocation for RWA calculation: Standardized Approach (SA), Foundation Internal Ratings-Based (IRB), or Advanced IRB. Determines the methodology used in CCAR/DFAST stress testing submissions.' ;
    rdfs:domain ind:SyndicationAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:syndicationMarket rdf:type rdf:Property ;
    rdfs:label 'Syndication Market' ;
    rdfs:comment 'The market segment classification of the syndicated facility. Investment grade and leveraged loans have different documentation standards, pricing conventions, and regulatory capital treatments. Used for portfolio segmentation and regulatory reporting.' ;
    rdfs:domain ind:SyndicationAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:underwriteAmount rdf:type rdf:Property ;
    rdfs:label 'Underwrite Amount' ;
    rdfs:comment 'The amount of the facility that the participant has underwritten (i.e., committed to take onto its own balance sheet if the syndication is not fully subscribed). May differ from the final allocated amount after sell-down.' ;
    rdfs:domain ind:SyndicationAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tombstoneId rdf:type rdf:Property ;
    rdfs:label 'Tombstone Id' ;
    rdfs:comment 'Unique surrogate identifier for the tombstone record representing a completed investment banking transaction commemorative record.' ;
    rdfs:domain ind:Tombstone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dealValueLocalCurrencyId rdf:type rdf:Property ;
    rdfs:label 'Deal Value Local Currency Id' ;
    rdfs:comment 'Foreign key linking to reference.currency. Business justification: Local currency required for tombstone publication, league table credit calculation, and deal value reporting in both local and USD terms.' ;
    rdfs:domain ind:Tombstone ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:publicationChannelId rdf:type rdf:Property ;
    rdfs:label 'Publication Channel Id' ;
    rdfs:comment 'Foreign key linking to channel.channel. Business justification: Tombstone publication and client approval occurs through specific channels (email via digital, physical presentation at branch, RM delivery). Marketing and compliance teams track publication channel f' ;
    rdfs:domain ind:Tombstone ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:acceptedCreditAmountUsd rdf:type rdf:Property ;
    rdfs:label 'Accepted Credit Amount Usd' ;
    rdfs:comment 'The USD credit amount formally accepted by the league table provider after review and any dispute resolution. May differ from the claimed credit_amount_usd if the provider applies a different methodology or partially accepts the submission.' ;
    rdfs:domain ind:Tombstone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:advisoryFeeUsd rdf:type rdf:Property ;
    rdfs:label 'Advisory Fee Usd' ;
    rdfs:comment 'Total advisory or underwriting fee earned by the bank on the transaction, expressed in USD. Used for revenue recognition, profitability analysis, and fee benchmarking. Classified as confidential as it represents commercially sensitive deal economics.' ;
    rdfs:domain ind:Tombstone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coAdvisorNames rdf:type rdf:Property ;
    rdfs:label 'Co Advisor Names' ;
    rdfs:comment 'Comma-separated list of co-advisors, co-managers, or joint bookrunners participating in the transaction alongside the bank. Used for competitive intelligence, league table credit sharing analysis, and tombstone advertisement content.' ;
    rdfs:domain ind:Tombstone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageBankerName rdf:type rdf:Property ;
    rdfs:label 'Coverage Banker Name' ;
    rdfs:comment 'Full name of the senior investment banker or managing director responsible for the client relationship and transaction execution. Used for deal attribution, performance management, and pitch book preparation.' ;
    rdfs:domain ind:Tombstone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditAmountUsd rdf:type rdf:Property ;
    rdfs:label 'Credit Amount Usd' ;
    rdfs:comment 'The USD dollar amount of league table credit claimed by the bank for this transaction submission. Calculated based on the credit methodology (e.g., full deal value for sole advisor, pro-rata share for joint bookrunners). This is the primary metric used to determine league table rankings.' ;
    rdfs:domain ind:Tombstone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dealValueLocal rdf:type rdf:Property ;
    rdfs:label 'Deal Value Local' ;
    rdfs:comment 'Total transaction value expressed in the original deal currency (local currency) before conversion to USD. Used for regional league table submissions and local market reporting.' ;
    rdfs:domain ind:Tombstone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dealValueUsd rdf:type rdf:Property ;
    rdfs:label 'Deal Value Usd' ;
    rdfs:comment 'Total transaction value in US dollars as reported for league table credit purposes. For M&A, this is the enterprise value or equity value of the target. For ECM/DCM, this is the total proceeds raised. For syndicated loans, this is the total facility size. Used as the primary monetary measure for competitive positioning and market share analysis.' ;
    rdfs:domain ind:Tombstone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fxRateToUsd rdf:type rdf:Property ;
    rdfs:label 'Fx Rate To Usd' ;
    rdfs:comment 'Exchange rate applied to convert the deal value from local currency to USD at the time of closing, used for standardized league table credit calculations across currencies.' ;
    rdfs:domain ind:Tombstone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isTombstoneClientApproved rdf:type rdf:Property ;
    rdfs:label 'Is Tombstone Client Approved' ;
    rdfs:comment 'Indicates whether the client has formally approved the tombstone advertisement content and publication (True) or approval is still pending (False). Client approval is required before tombstone publication per standard investment banking practice and FINRA communications rules.' ;
    rdfs:domain ind:Tombstone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leagueTableProductCategory rdf:type rdf:Property ;
    rdfs:label 'League Table Product Category' ;
    rdfs:comment 'Product category under which the transaction is submitted for league table credit. M&A = Mergers and Acquisitions advisory; ECM = Equity Capital Markets; DCM = Debt Capital Markets; Loans = Syndicated Lending. A single transaction may be submitted under multiple categories.' ;
    rdfs:domain ind:Tombstone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leagueTableProvider rdf:type rdf:Property ;
    rdfs:label 'League Table Provider' ;
    rdfs:comment 'Name of the league table data provider to which this credit submission is made. Each provider has distinct credit methodologies and product category definitions. Dealogic, Bloomberg, and Refinitiv (LSEG) are the primary providers used for investment banking competitive positioning.' ;
    rdfs:domain ind:Tombstone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberOfCoAdvisors rdf:type rdf:Property ;
    rdfs:label 'Number Of Co Advisors' ;
    rdfs:comment 'Total count of co-advisors or joint bookrunners on the transaction. Used to determine pro-rata league table credit allocation methodology when credit is shared equally among all bookrunners.' ;
    rdfs:domain ind:Tombstone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:publicationStatus rdf:type rdf:Property ;
    rdfs:label 'Publication Status' ;
    rdfs:comment 'Current publication lifecycle status of the tombstone advertisement. \'draft\' = tombstone content being prepared; \'approved\' = client and internal sign-off obtained; \'published\' = tombstone publicly released in marketing materials; \'suppressed\' = publication withheld at client request; \'archived\' = historical record retained for deal track record.' ;
    rdfs:domain ind:Tombstone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCountry rdf:type rdf:Property ;
    rdfs:label 'Target Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the target company\'s or issuer\'s country of incorporation or primary operations. Used for geographic league table submissions (e.g., EMEA M&A, Asia-Pacific ECM) and cross-border transaction analysis.' ;
    rdfs:domain ind:Tombstone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tombstoneDescription rdf:type rdf:Property ;
    rdfs:label 'Tombstone Description' ;
    rdfs:comment 'Full narrative text of the tombstone advertisement as approved for publication, describing the transaction, the bank\'s role, and the deal highlights. Used in pitch books, marketing materials, and deal track record databases.' ;
    rdfs:domain ind:Tombstone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionName rdf:type rdf:Property ;
    rdfs:label 'Transaction Name' ;
    rdfs:comment 'Official marketing name or title of the completed investment banking transaction as it appears on the tombstone advertisement (e.g., \'Acquisition of XYZ Corp by ABC Inc\').' ;
    rdfs:domain ind:Tombstone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualCloseDate rdf:type rdf:Property ;
    rdfs:label 'Actual Close Date' ;
    rdfs:comment 'Actual date on which the transaction closed and legal title or consideration was transferred. Null until the transaction is completed. Used for fee billing and tombstone records.' ;
    rdfs:domain ind:TransactionStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:advisoryFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Advisory Fee Amount' ;
    rdfs:comment 'Total investment banking advisory fee earned or expected for this transaction structure, including retainer, announcement fee, and success fee components. Used for revenue recognition and league table credit.' ;
    rdfs:domain ind:TransactionStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:breakupFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Breakup Fee Amount' ;
    rdfs:comment 'Termination or breakup fee payable by the target or acquirer if the transaction is terminated under specified conditions. Typically 1-4% of deal value; disclosed in merger agreement and proxy statement.' ;
    rdfs:domain ind:TransactionStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cashConsiderationAmount rdf:type rdf:Property ;
    rdfs:label 'Cash Consideration Amount' ;
    rdfs:comment 'Cash portion of the total consideration payable to target shareholders or security holders. Used in mixed-consideration deal structuring and tax analysis.' ;
    rdfs:domain ind:TransactionStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confidentialityAgreementDate rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Agreement Date' ;
    rdfs:comment 'Date on which the non-disclosure agreement (NDA) or confidentiality agreement was executed between the parties. Establishes the start of the restricted information-sharing period and wall-crossing obligations.' ;
    rdfs:domain ind:TransactionStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:considerationType rdf:type rdf:Property ;
    rdfs:label 'Consideration Type' ;
    rdfs:comment 'Form of consideration offered in the transaction (e.g., cash, stock, mixed cash-and-stock, debt assumption, or earnout). Critical for M&A valuation, tax structuring, and shareholder approval requirements.' ;
    rdfs:domain ind:TransactionStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dcfEnterpriseValue rdf:type rdf:Property ;
    rdfs:label 'Dcf Enterprise Value' ;
    rdfs:comment 'Intrinsic enterprise value derived from the DCF valuation model underpinning the transaction structure. Represents the present value of projected free cash flows discounted at the WACC.' ;
    rdfs:domain ind:TransactionStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dealValueAmount rdf:type rdf:Property ;
    rdfs:label 'Deal Value Amount' ;
    rdfs:comment 'Gross enterprise value or total deal consideration amount as agreed in the transaction structure. Represents the headline deal size used in pitch books, tombstones, and league table reporting.' ;
    rdfs:domain ind:TransactionStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dealValueCurrency rdf:type rdf:Property ;
    rdfs:label 'Deal Value Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the deal value amount (e.g., USD, EUR, GBP). Required for FX conversion in cross-border M&A and multi-currency capital markets transactions.' ;
    rdfs:domain ind:TransactionStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:debtAssumedAmount rdf:type rdf:Property ;
    rdfs:label 'Debt Assumed Amount' ;
    rdfs:comment 'Total net debt assumed or refinanced as part of the transaction structure. Used in the enterprise-to-equity value bridge and leverage ratio calculations.' ;
    rdfs:domain ind:TransactionStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:equityValueAmount rdf:type rdf:Property ;
    rdfs:label 'Equity Value Amount' ;
    rdfs:comment 'Equity value (market capitalisation or offer price times diluted shares) component of the transaction structure. Distinct from enterprise value; used in DCF valuation bridge and per-share consideration calculations.' ;
    rdfs:domain ind:TransactionStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exchangeRatio rdf:type rdf:Property ;
    rdfs:label 'Exchange Ratio' ;
    rdfs:comment 'Number of acquirer shares offered per target share in a stock-for-stock or mixed-consideration transaction. Null for cash-only deals. Used in merger proxy statements and SEC Form S-4 filings.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedCloseDate rdf:type rdf:Property ;
    rdfs:label 'Expected Close Date' ;
    rdfs:comment 'Anticipated date on which the transaction is expected to close and consideration is transferred. Used for deal pipeline forecasting and fee recognition scheduling.' ;
    rdfs:domain ind:TransactionStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fairnessOpinionRequired rdf:type rdf:Property ;
    rdfs:label 'Fairness Opinion Required' ;
    rdfs:comment 'Indicates whether the board of directors requires a fairness opinion from an independent financial advisor to support the transaction. Typically required for related-party transactions and large public M&A.' ;
    rdfs:domain ind:TransactionStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:financingMixDebtPct rdf:type rdf:Property ;
    rdfs:label 'Financing Mix Debt Pct' ;
    rdfs:comment 'Percentage of total transaction financing sourced from debt instruments (senior secured, mezzanine, high-yield bonds). Used in leverage ratio analysis and pro forma capital structure modelling.' ;
    rdfs:domain ind:TransactionStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financingMixEquityPct rdf:type rdf:Property ;
    rdfs:label 'Financing Mix Equity Pct' ;
    rdfs:comment 'Percentage of total transaction financing sourced from equity (sponsor equity, management rollover, public equity issuance). Complements debt percentage to form the full financing mix.' ;
    rdfs:domain ind:TransactionStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leadArrangerRole rdf:type rdf:Property ;
    rdfs:label 'Lead Arranger Role' ;
    rdfs:comment 'Role of the bank in this transaction structure (e.g., sole bookrunner, joint bookrunner, lead-left, financial advisor). Determines league table credit allocation and fee entitlement.' ;
    rdfs:domain ind:TransactionStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leverageRatio rdf:type rdf:Property ;
    rdfs:label 'Leverage Ratio' ;
    rdfs:comment 'Pro forma leverage ratio expressed as total debt divided by EBITDA at transaction close. Key credit metric used by rating agencies, lenders, and regulators to assess transaction risk. Aligns with Basel III leverage ratio monitoring.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:offerPremiumPct rdf:type rdf:Property ;
    rdfs:label 'Offer Premium Pct' ;
    rdfs:comment 'Percentage premium offered over the target\'s unaffected share price (typically 30-day VWAP prior to announcement). Key M&A valuation metric used in fairness opinions and board presentations.' ;
    rdfs:domain ind:TransactionStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proFormaCet1Ratio rdf:type rdf:Property ;
    rdfs:label 'Pro Forma Cet1 Ratio' ;
    rdfs:comment 'Pro forma CET1 capital ratio post-transaction, reflecting the impact of the deal on the acquirer\'s regulatory capital position. Required for bank M&A regulatory approval submissions to the Fed, OCC, and FDIC.' ;
    rdfs:domain ind:TransactionStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryApprovalBodies rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Bodies' ;
    rdfs:comment 'Comma-separated list of regulatory bodies whose approval is required for this transaction (e.g., \'Fed, OCC, DOJ, EC\'). Drives compliance workflow and deal timeline planning.' ;
    rdfs:domain ind:TransactionStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shareholderApprovalRequired rdf:type rdf:Property ;
    rdfs:label 'Shareholder Approval Required' ;
    rdfs:comment 'Indicates whether the transaction requires shareholder or bondholder approval (e.g., merger vote, rights issue prospectus approval). Triggers proxy statement and SEC Schedule 14A filing obligations.' ;
    rdfs:domain ind:TransactionStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stockConsiderationAmount rdf:type rdf:Property ;
    rdfs:label 'Stock Consideration Amount' ;
    rdfs:comment 'Equity (stock) portion of the total consideration, valued at the exchange ratio applied to the acquirer\'s share price. Used in share-for-share merger structuring and dilution analysis.' ;
    rdfs:domain ind:TransactionStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:structuralConditionType rdf:type rdf:Property ;
    rdfs:label 'Structural Condition Type' ;
    rdfs:comment 'Primary structural condition or protective mechanism embedded in the transaction agreement (e.g., MAC clause, financing condition, no-shop provision, breakup fee). [ENUM-REF-CANDIDATE: material_adverse_change|regulatory_condition|financing_condition|no_shop|go_shop|breakup_fee|other — promote to reference product]' ;
    rdfs:domain ind:TransactionStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:structureName rdf:type rdf:Property ;
    rdfs:label 'Structure Name' ;
    rdfs:comment 'Human-readable name or working title for the transaction structure (e.g., \'Project Falcon — Leveraged Buyout Structure\'). Treated as confidential pre-announcement deal information.' ;
    rdfs:domain ind:TransactionStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:structureReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Structure Reference Code' ;
    rdfs:comment 'Externally-known alphanumeric reference code assigned to this transaction structure, used in pitch books, mandate letters, and regulatory filings (e.g., IB-2024-ACQX001).' ;
    rdfs:domain ind:TransactionStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:structureStatus rdf:type rdf:Property ;
    rdfs:label 'Structure Status' ;
    rdfs:comment 'Current lifecycle status of the transaction structure from initial drafting through execution or termination. Drives workflow routing and deal pipeline reporting.' ;
    rdfs:domain ind:TransactionStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:structureType rdf:type rdf:Property ;
    rdfs:label 'Structure Type' ;
    rdfs:comment 'Classification of the investment banking transaction structure type. Drives applicable regulatory approvals, valuation methodology, and capital markets execution approach. [ENUM-REF-CANDIDATE: merger|acquisition|carve_out|spin_off|ipo|follow_on|rights_issue|bond_issuance|syndicated_loan|leveraged_buyout — promote to reference product]' ;
    rdfs:domain ind:TransactionStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:syndicationRequired rdf:type rdf:Property ;
    rdfs:label 'Syndication Required' ;
    rdfs:comment 'Indicates whether the financing component of this transaction requires syndication to a group of lenders or underwriters (e.g., syndicated loan, bond roadshow). Triggers syndicate desk involvement.' ;
    rdfs:domain ind:TransactionStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waccRate rdf:type rdf:Property ;
    rdfs:label 'Wacc Rate' ;
    rdfs:comment 'Weighted average cost of capital rate used as the discount rate in the DCF valuation model for this transaction structure. Expressed as a decimal (e.g., 0.0850 = 8.50%).' ;
    rdfs:domain ind:TransactionStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:underwritingId rdf:type rdf:Property ;
    rdfs:label 'Underwriting Id' ;
    rdfs:comment 'Primary key for underwriting' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Underwriting .

ind:anchorInvestorFundId rdf:type rdf:Property ;
    rdfs:label 'Anchor Investor Fund Id' ;
    rdfs:comment 'Foreign key linking to asset.fund. Business justification: Institutional funds are cornerstone investors in underwritten equity and debt offerings, often receiving anchor allocations. Real business process: pre-marketing to anchor investors, allocation manage' ;
    rdfs:domain ind:Underwriting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fund .

ind:bookingBranchId rdf:type rdf:Property ;
    rdfs:label 'Booking Branch Id' ;
    rdfs:comment 'Foreign key linking to channel.branch. Business justification: Underwriting commitments for municipal bonds, regional offerings, or private placements are booked through specific branch locations (regional/community banking underwriting desks). Required for branc' ;
    rdfs:domain ind:Underwriting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Branch .

ind:agreementDate rdf:type rdf:Property ;
    rdfs:label 'Agreement Date' ;
    rdfs:comment 'The date on which the formal underwriting agreement between the bank (and co-underwriters) and the issuer was executed. This is the legally binding contract governing the terms of the underwriting commitment.' ;
    rdfs:domain ind:Underwriting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bankAllocationPct rdf:type rdf:Property ;
    rdfs:label 'Bank Allocation Pct' ;
    rdfs:comment 'The percentage of the total offering size allocated to this bank as its underwriting commitment share within the syndicate. Determines the bank\'s proportional fee entitlement and risk exposure.' ;
    rdfs:domain ind:Underwriting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bookRunnerFlag rdf:type rdf:Property ;
    rdfs:label 'Book Runner Flag' ;
    rdfs:comment 'Indicates whether the bank is acting as a bookrunner (lead or joint) for this offering, responsible for managing the order book during the book-building process. True if the bank has bookrunner responsibilities; False for co-manager or selling group roles.' ;
    rdfs:domain ind:Underwriting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commitmentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Commitment Reference Number' ;
    rdfs:comment 'Externally-known alphanumeric reference number assigned to this underwriting commitment, used in mandate letters, syndicate agreements, and regulatory filings. Format: LOB-UW-YYYY-NNNNNN.' ;
    rdfs:domain ind:Underwriting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentStatus rdf:type rdf:Property ;
    rdfs:label 'Commitment Status' ;
    rdfs:comment 'Current lifecycle state of the underwriting commitment. Mandated: bank has received the mandate; Active: commitment is live during the offering period; Priced: pricing has been set; Closed: transaction has settled; Withdrawn: issuer withdrew the offering; Terminated: commitment cancelled prior to pricing.' ;
    rdfs:domain ind:Underwriting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedFeeRevenue rdf:type rdf:Property ;
    rdfs:label 'Expected Fee Revenue' ;
    rdfs:comment 'The bank\'s expected gross fee revenue from this underwriting commitment, calculated as the bank\'s allocated underwriting spread applied to its committed underwriting amount. Used for revenue forecasting, deal profitability analysis, and RAROC (Risk-Adjusted Return on Capital) calculations.' ;
    rdfs:domain ind:Underwriting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feeBps rdf:type rdf:Property ;
    rdfs:label 'Fee Bps' ;
    rdfs:comment 'The portion of the underwriting spread allocated as the underwriting fee, expressed in basis points. Compensates syndicate members for bearing the underwriting risk during the offering period.' ;
    rdfs:domain ind:Underwriting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:greenshoeOptionAmount rdf:type rdf:Property ;
    rdfs:label 'Greenshoe Option Amount' ;
    rdfs:comment 'The maximum additional amount (in base currency) that the underwriters may purchase from the issuer under the over-allotment (greenshoe) option, typically up to 15% of the base offering size. Exercised to stabilize the aftermarket price. Named after the Green Shoe Manufacturing Company, the first company to use this mechanism.' ;
    rdfs:domain ind:Underwriting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:greenshoeOptionFlag rdf:type rdf:Property ;
    rdfs:label 'Greenshoe Option Flag' ;
    rdfs:comment 'Indicates whether an over-allotment (greenshoe) option has been granted to the underwriters in this transaction. True if a greenshoe option exists; False if no over-allotment option is included.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leagueTableEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'League Table Eligible Flag' ;
    rdfs:comment 'Indicates whether this transaction qualifies for inclusion in investment banking league table rankings (e.g., Bloomberg, Dealogic, Thomson Reuters). Transactions may be excluded due to size thresholds, role limitations, or issuer type restrictions.' ;
    rdfs:domain ind:Underwriting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:managementFeeBps rdf:type rdf:Property ;
    rdfs:label 'Management Fee Bps' ;
    rdfs:comment 'The portion of the underwriting spread allocated as the management fee, expressed in basis points. Compensates the lead manager(s) for structuring, due diligence, and transaction management responsibilities.' ;
    rdfs:domain ind:Underwriting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mandateLetterDate rdf:type rdf:Property ;
    rdfs:label 'Mandate Letter Date' ;
    rdfs:comment 'The date on which the issuer formally awarded the underwriting mandate to the bank via a signed mandate letter. Precedes the commitment date and marks the formal engagement of the bank as underwriter.' ;
    rdfs:domain ind:Underwriting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:offeringPrice rdf:type rdf:Property ;
    rdfs:label 'Offering Price' ;
    rdfs:comment 'The final public offering price per unit (share or bond face value) at which securities are sold to investors. For equity, expressed as price per share; for debt, expressed as a percentage of par value. Determined at pricing date.' ;
    rdfs:domain ind:Underwriting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:offeringSize rdf:type rdf:Property ;
    rdfs:label 'Offering Size' ;
    rdfs:comment 'The total gross proceeds of the offering at the offering price, representing the full transaction size including any greenshoe option if exercised. Distinct from underwritten_amount which reflects only the bank\'s committed portion.' ;
    rdfs:domain ind:Underwriting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:offeringType rdf:type rdf:Property ;
    rdfs:label 'Offering Type' ;
    rdfs:comment 'Classification of the securities offering structure. IPO (Initial Public Offering) is the first public sale; follow-on is a subsequent equity offering; 144A is a private placement to qualified institutional buyers; Reg S covers offshore offerings. [ENUM-REF-CANDIDATE: ipo|follow_on|secondary|rights_offering|private_placement|144a|reg_s|block_trade — promote to reference product]' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secFileNumber rdf:type rdf:Property ;
    rdfs:label 'Sec File Number' ;
    rdfs:comment 'The Securities and Exchange Commission (SEC) file number assigned to the registration statement for this offering (e.g., 333-XXXXXX for Securities Act registrations). Used for regulatory tracking and EDGAR cross-referencing.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sellingConcessionBps rdf:type rdf:Property ;
    rdfs:label 'Selling Concession Bps' ;
    rdfs:comment 'The portion of the underwriting spread allocated as the selling concession, expressed in basis points. Paid to dealers and selling group members for distributing securities to end investors.' ;
    rdfs:domain ind:Underwriting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:syndicateRole rdf:type rdf:Property ;
    rdfs:label 'Syndicate Role' ;
    rdfs:comment 'The bank\'s role within the underwriting syndicate. Lead bookrunner has primary responsibility for book building and allocation; joint bookrunner shares that responsibility; co-manager has a smaller participation; selling group members distribute but do not underwrite. Determines fee economics and regulatory obligations.' ;
    rdfs:domain ind:Underwriting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tombstoneFlag rdf:type rdf:Property ;
    rdfs:label 'Tombstone Flag' ;
    rdfs:comment 'Indicates whether a tombstone advertisement has been published for this completed transaction. Tombstones are formal announcements of completed capital markets transactions and serve as marketing credentials for the bank\'s league table rankings.' ;
    rdfs:domain ind:Underwriting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:underwrittenAmount rdf:type rdf:Property ;
    rdfs:label 'Underwritten Amount' ;
    rdfs:comment 'The gross principal amount (in base currency) that the bank has committed to underwrite for this transaction. For firm commitment deals, this represents the bank\'s maximum financial exposure prior to distribution. Key input for RWA (Risk-Weighted Assets) and capital charge calculations under Basel III.' ;
    rdfs:domain ind:Underwriting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:alt5AccountingRecordUpdatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Alt5 Accounting Record Updated By User Employee Id' ;
    rdfs:comment 'Reference to the user who last updated this accounting period record. Supports audit trail and accountability.' ;
    rdfs:domain ind:AccountingPeriod ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryAccountingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Accounting Employee Id' ;
    rdfs:comment 'Reference to the user who opened the accounting period. Supports audit trail and SOX compliance for period status changes.' ;
    rdfs:domain ind:AccountingPeriod ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryAccountingSoxCertifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Accounting Sox Certified By User Employee Id' ;
    rdfs:comment 'Reference to the user who certified the period for SOX compliance. Supports audit trail and accountability.' ;
    rdfs:domain ind:AccountingPeriod ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quinaryAccountingRecordCreatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quinary Accounting Record Created By User Employee Id' ;
    rdfs:comment 'Reference to the user who created this accounting period record. Supports audit trail and accountability.' ;
    rdfs:domain ind:AccountingPeriod ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:setId rdf:type rdf:Property ;
    rdfs:label 'Set Id' ;
    rdfs:comment 'Reference to the general ledger or ledger set to which this accounting period belongs. Links to the primary or secondary ledger in multi-ledger environments (e.g., statutory, management, tax ledgers).' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Set .

ind:tertiaryAccountingPermanentlyClosedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Accounting Permanently Closed By User Employee Id' ;
    rdfs:comment 'Reference to the user who permanently closed the accounting period. Supports audit trail and SOX compliance for period status changes.' ;
    rdfs:domain ind:AccountingPeriod ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accountingPeriodDescription rdf:type rdf:Property ;
    rdfs:label 'Accounting Period Description' ;
    rdfs:comment 'Free-text description or notes about the accounting period. May include special instructions, closing notes, or period-specific context.' ;
    rdfs:domain ind:AccountingPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentPeriodFlag rdf:type rdf:Property ;
    rdfs:label 'Adjustment Period Flag' ;
    rdfs:comment 'Indicates whether this is an adjustment period (True) or a standard operating period (False). Adjustment periods (e.g., Period 13, Period 14) are used for year-end closing entries and do not correspond to calendar months.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:budgetPeriodFlag rdf:type rdf:Property ;
    rdfs:label 'Budget Period Flag' ;
    rdfs:comment 'Indicates whether this period is used for budgeting and planning (True) or is actuals-only (False). Supports budget vs. actual variance analysis.' ;
    rdfs:domain ind:AccountingPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:closeSequence rdf:type rdf:Property ;
    rdfs:label 'Close Sequence' ;
    rdfs:comment 'Defines the order in which periods should be closed in a multi-period close process. Lower numbers close first. Supports controlled, sequential period-end closing workflows.' ;
    rdfs:domain ind:AccountingPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:consolidationFlag rdf:type rdf:Property ;
    rdfs:label 'Consolidation Flag' ;
    rdfs:comment 'Indicates whether this period is used for consolidation reporting (True) or is a subsidiary-only period (False). Supports multi-entity consolidation workflows.' ;
    rdfs:domain ind:AccountingPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:intercompanyEliminationFlag rdf:type rdf:Property ;
    rdfs:label 'Intercompany Elimination Flag' ;
    rdfs:comment 'Indicates whether intercompany eliminations have been processed for this period (True) or not (False). Supports consolidated financial statement preparation.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:openedDate rdf:type rdf:Property ;
    rdfs:label 'Opened Date' ;
    rdfs:comment 'The date on which the accounting period was opened for posting. Supports audit trail and period lifecycle tracking.' ;
    rdfs:domain ind:AccountingPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodName rdf:type rdf:Property ;
    rdfs:label 'Period Name' ;
    rdfs:comment 'Human-readable name of the accounting period, typically in the format \'MMM-YY\' (e.g., \'JAN-24\', \'FEB-24\') or \'Period 1\', \'Period 2\'. Used for display and reporting purposes.' ;
    rdfs:domain ind:AccountingPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodNumber rdf:type rdf:Property ;
    rdfs:label 'Period Number' ;
    rdfs:comment 'Sequential numeric identifier of the period within the fiscal year (e.g., 1 for January, 2 for February, 13 for year-end adjustment period). Supports ordering and period arithmetic.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:periodStatus rdf:type rdf:Property ;
    rdfs:label 'Period Status' ;
    rdfs:comment 'Current lifecycle status of the accounting period. Controls whether journal entries can be posted. \'future_enterable\' allows posting to future periods; \'open\' allows normal posting; \'closed\' prevents posting but can be reopened; \'permanently_closed\' locks the period for SOX compliance; \'never_opened\' indicates the period has not yet been activated.' ;
    rdfs:domain ind:AccountingPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodType rdf:type rdf:Property ;
    rdfs:label 'Period Type' ;
    rdfs:comment 'Classification of the accounting period. \'standard\' for regular monthly periods; \'adjustment\' for mid-year or quarterly adjustment periods; \'year_end\' for annual closing and adjustment entries; \'opening\' for the initial period when opening balances are recorded.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permanentlyClosedDate rdf:type rdf:Property ;
    rdfs:label 'Permanently Closed Date' ;
    rdfs:comment 'The date on which the accounting period was permanently closed and locked for SOX compliance. Once permanently closed, the period cannot be reopened. Null if not permanently closed.' ;
    rdfs:domain ind:AccountingPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quarterNumber rdf:type rdf:Property ;
    rdfs:label 'Quarter Number' ;
    rdfs:comment 'The fiscal quarter to which this period belongs (1, 2, 3, or 4). Supports quarterly reporting and SEC 10-Q filing requirements.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reportingFlag rdf:type rdf:Property ;
    rdfs:label 'Reporting Flag' ;
    rdfs:comment 'Indicates whether this period is included in external financial reporting (True) or is for internal management purposes only (False). Supports GAAP and IFRS reporting requirements.' ;
    rdfs:domain ind:AccountingPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:soxCertificationDate rdf:type rdf:Property ;
    rdfs:label 'Sox Certification Date' ;
    rdfs:comment 'The date on which the period was certified for SOX compliance. Null if not yet certified. Supports audit trail and compliance reporting.' ;
    rdfs:domain ind:AccountingPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:soxCertificationFlag rdf:type rdf:Property ;
    rdfs:label 'Sox Certification Flag' ;
    rdfs:comment 'Indicates whether the period has been certified for SOX compliance (True) or not (False). Supports internal control attestation and audit requirements.' ;
    rdfs:domain ind:AccountingPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:yearEndFlag rdf:type rdf:Property ;
    rdfs:label 'Year End Flag' ;
    rdfs:comment 'Indicates whether this period is the final period of the fiscal year (True) or not (False). Used to trigger year-end closing processes, retained earnings rollover, and annual financial statement preparation.' ;
    rdfs:domain ind:AccountingPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:chartOfAccountsId rdf:type rdf:Property ;
    rdfs:label 'Chart Of Accounts Id' ;
    rdfs:comment 'Unique identifier for the general ledger account in the chart of accounts master registry.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ChartOfAccounts .

ind:accountCurrencyId rdf:type rdf:Property ;
    rdfs:label 'Account Currency Id' ;
    rdfs:comment 'Foreign key linking to reference.currency. Business justification: Chart of accounts must specify native currency for each account to support multi-currency GL operations, currency-specific reporting, and FX revaluation processes required in global banking operations' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:gaapClassificationReportingCodeId rdf:type rdf:Property ;
    rdfs:label 'Gaap Classification Reporting Code Id' ;
    rdfs:comment 'Foreign key linking to reference.reporting_code. Business justification: Chart of accounts maps to GAAP reporting codes for regulatory filing; this link enables automated financial statement preparation and US GAAP compliance reporting.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReportingCode .

ind:accountCode rdf:type rdf:Property ;
    rdfs:label 'Account Code' ;
    rdfs:comment 'The unique alphanumeric code identifying the general ledger account. This is the externally-known business identifier used in all journal entries and financial reports. Typically follows a hierarchical numbering scheme (e.g., 1000-1999 for assets, 2000-2999 for liabilities).' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountDescription rdf:type rdf:Property ;
    rdfs:label 'Account Description' ;
    rdfs:comment 'A detailed description of the purpose, usage guidelines, and business rules for this account. Provides additional context beyond the account name for users posting journal entries and for auditors reviewing account activity.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountLevel rdf:type rdf:Property ;
    rdfs:label 'Account Level' ;
    rdfs:comment 'The level of this account in the chart of accounts hierarchy (e.g., 1 for top-level summary accounts, 2 for sub-categories, 3 for detail accounts). Used for drill-down reporting and financial statement presentation at different levels of detail.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountSubtype rdf:type rdf:Property ;
    rdfs:label 'Account Subtype' ;
    rdfs:comment 'A more granular classification within the account type (e.g., \'current asset\', \'fixed asset\', \'current liability\', \'long-term liability\', \'operating revenue\', \'non-operating revenue\', \'operating expense\', \'non-operating expense\'). Used for detailed financial statement presentation and analysis.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alternateAccountCode rdf:type rdf:Property ;
    rdfs:label 'Alternate Account Code' ;
    rdfs:comment 'An alternate or legacy account code used for cross-reference purposes during system migrations, mergers and acquisitions (M&A), or for mapping to external reporting frameworks. Allows historical data to be linked to the current chart of accounts structure.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationGroup rdf:type rdf:Property ;
    rdfs:label 'Consolidation Group' ;
    rdfs:comment 'The consolidation grouping code used for multi-entity financial consolidation and elimination of intercompany transactions. Identifies which legal entities or business units this account applies to and how it should be treated in consolidated financial statements.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialStatementCategory rdf:type rdf:Property ;
    rdfs:label 'Financial Statement Category' ;
    rdfs:comment 'Identifies the primary financial statement where this account is reported (balance sheet for assets/liabilities/equity, income statement for revenue/expenses, cash flow statement for cash movements, statement of changes in equity for equity movements).' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialStatementLineItem rdf:type rdf:Property ;
    rdfs:label 'Financial Statement Line Item' ;
    rdfs:comment 'The specific line item or caption on the financial statement where this account balance is aggregated and presented (e.g., \'Cash and Cash Equivalents\', \'Property Plant and Equipment\', \'Interest Income\', \'Salaries and Benefits\'). Maps the detailed GL account to the published financial statement presentation.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalArea rdf:type rdf:Property ;
    rdfs:label 'Functional Area' ;
    rdfs:comment 'The functional area or business process this account supports (e.g., \'Commercial Lending\', \'Investment Banking\', \'Treasury\', \'Risk Management\', \'Operations\', \'Technology\'). Used for functional cost allocation and activity-based costing.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ifrsClassification rdf:type rdf:Property ;
    rdfs:label 'Ifrs Classification' ;
    rdfs:comment 'The classification of this account under IFRS accounting standards, including specific IAS/IFRS standard references where applicable (e.g., \'IAS 16 - Property Plant and Equipment\', \'IFRS 9 - Financial Instruments\', \'IFRS 15 - Revenue from Contracts with Customers\'). Used for international statutory reporting and consolidation.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intercompanyFlag rdf:type rdf:Property ;
    rdfs:label 'Intercompany Flag' ;
    rdfs:comment 'Indicates whether this account is used for intercompany transactions between legal entities within the consolidated group. Intercompany accounts are subject to elimination entries during financial consolidation to remove intra-group transactions.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:normalBalance rdf:type rdf:Property ;
    rdfs:label 'Normal Balance' ;
    rdfs:comment 'Indicates whether the account normally carries a debit or credit balance. Asset and expense accounts have debit normal balances; liability, equity, and revenue accounts have credit normal balances. Used for validation of journal entries and trial balance preparation.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentAccountCode rdf:type rdf:Property ;
    rdfs:label 'Parent Account Code' ;
    rdfs:comment 'The account code of the parent account in a hierarchical chart of accounts structure. Used for roll-up reporting and financial statement aggregation. Null for top-level accounts.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Posting Allowed Flag' ;
    rdfs:comment 'Indicates whether direct manual journal entries are allowed to this account, or whether it is a control/summary account that only receives automated postings from subledgers. Control accounts typically have this flag set to false to prevent manual posting errors.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:profitCenterCode rdf:type rdf:Property ;
    rdfs:label 'Profit Center Code' ;
    rdfs:comment 'The default profit center or business unit associated with this account for segment reporting and profitability analysis. Used for line of business (LOB) reporting and RAROC calculations.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Required Flag' ;
    rdfs:comment 'Indicates whether this account requires periodic reconciliation to external statements or subledger systems (e.g., bank statements, loan subledger, securities positions). Accounts flagged for reconciliation are subject to monthly close procedures and variance investigation.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riskWeightedAssetCategory rdf:type rdf:Property ;
    rdfs:label 'Risk Weighted Asset Category' ;
    rdfs:comment 'The Basel III risk-weighted asset category for this account, used in capital adequacy calculations (e.g., \'credit risk - corporate exposures\', \'credit risk - retail exposures\', \'market risk\', \'operational risk\'). Determines the risk weighting applied for Common Equity Tier 1 (CET1) ratio calculations.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statisticalAccountFlag rdf:type rdf:Property ;
    rdfs:label 'Statistical Account Flag' ;
    rdfs:comment 'Indicates whether this is a statistical (non-monetary) account used to track quantities, headcount, or other non-financial metrics for management reporting and ratio analysis (e.g., number of employees, number of accounts, transaction volumes). Statistical accounts do not appear in financial statements but support KPI calculations.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:subledgerSource rdf:type rdf:Property ;
    rdfs:label 'Subledger Source' ;
    rdfs:comment 'The name of the subledger system that feeds detailed transactions into this GL account (e.g., \'Loan Origination System\', \'Trading System\', \'Accounts Payable\', \'Accounts Receivable\', \'Fixed Assets\'). Used for subledger-to-GL reconciliation and drill-down analysis.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxLineMapping rdf:type rdf:Property ;
    rdfs:label 'Tax Line Mapping' ;
    rdfs:comment 'The mapping of this account to specific lines on corporate tax returns (e.g., IRS Form 1120 line references, state tax return schedules). Used for tax provision calculation, deferred tax accounting, and tax compliance reporting.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationRunId rdf:type rdf:Property ;
    rdfs:label 'Consolidation Run Id' ;
    rdfs:comment 'Unique identifier for the consolidation run execution record.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConsolidationRun .

ind:consolidationGroupId rdf:type rdf:Property ;
    rdfs:label 'Consolidation Group Id' ;
    rdfs:comment 'Identifier of the consolidation group or reporting entity scope for which this run was executed.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConsolidationGroup .

ind:functionalCurrencyId rdf:type rdf:Property ;
    rdfs:label 'Functional Currency Id' ;
    rdfs:comment 'Foreign key linking to reference.currency. Business justification: Consolidation runs aggregate in a functional currency; this link enables multi-entity consolidation, currency translation processing, and IFRS-compliant consolidated financial statement preparation.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:primaryConsolidationEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Consolidation Employee Id' ;
    rdfs:comment 'Identifier of the user who approved the consolidation run, if approval was required and granted.' ;
    rdfs:domain ind:ConsolidationRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:consolidationAdjustmentsCount rdf:type rdf:Property ;
    rdfs:label 'Consolidation Adjustments Count' ;
    rdfs:comment 'Number of manual or automated consolidation adjustment journal entries posted during this run.' ;
    rdfs:domain ind:ConsolidationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:consolidationEngineVersion rdf:type rdf:Property ;
    rdfs:label 'Consolidation Engine Version' ;
    rdfs:comment 'Version identifier of the consolidation software or engine used to execute this run.' ;
    rdfs:domain ind:ConsolidationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationMethod rdf:type rdf:Property ;
    rdfs:label 'Consolidation Method' ;
    rdfs:comment 'Method applied for consolidation: full consolidation, proportionate consolidation, equity method, or cost method.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currencyTranslationAdjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Currency Translation Adjustment Amount' ;
    rdfs:comment 'Total currency translation adjustment amount arising from translating foreign subsidiary financial statements into presentation currency.' ;
    rdfs:domain ind:ConsolidationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:entitiesIncludedCount rdf:type rdf:Property ;
    rdfs:label 'Entities Included Count' ;
    rdfs:comment 'Number of legal entities or subsidiaries included in the consolidation scope for this run.' ;
    rdfs:domain ind:ConsolidationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:goodwillAdjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Goodwill Adjustment Amount' ;
    rdfs:comment 'Total goodwill adjustments applied during consolidation, including impairment or acquisition-related adjustments.' ;
    rdfs:domain ind:ConsolidationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:intercompanyEliminationsAmount rdf:type rdf:Property ;
    rdfs:label 'Intercompany Eliminations Amount' ;
    rdfs:comment 'Total monetary value of intercompany eliminations applied during consolidation, in presentation currency.' ;
    rdfs:domain ind:ConsolidationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:intercompanyEliminationsAppliedFlag rdf:type rdf:Property ;
    rdfs:label 'Intercompany Eliminations Applied Flag' ;
    rdfs:comment 'Indicates whether intercompany transactions and balances were eliminated during this consolidation run.' ;
    rdfs:domain ind:ConsolidationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minorityInterestAmount rdf:type rdf:Property ;
    rdfs:label 'Minority Interest Amount' ;
    rdfs:comment 'Total non-controlling interest (minority interest) calculated and recognized in consolidated equity for this run.' ;
    rdfs:domain ind:ConsolidationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netIncomeConsolidated rdf:type rdf:Property ;
    rdfs:label 'Net Income Consolidated' ;
    rdfs:comment 'Consolidated net income for the reporting period after all eliminations and adjustments, in presentation currency.' ;
    rdfs:domain ind:ConsolidationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:presentationCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Presentation Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which consolidated financial statements are presented.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorySubmissionFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Flag' ;
    rdfs:comment 'Indicates whether this consolidation run is intended for regulatory submission (e.g., FR Y-9C, Basel III reporting).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatorySubmissionType rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Type' ;
    rdfs:comment 'Type of regulatory submission this consolidation supports (e.g., FR Y-9C, CCAR, DFAST, Basel III Pillar 3).' ;
    rdfs:domain ind:ConsolidationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingStandard rdf:type rdf:Property ;
    rdfs:label 'Reporting Standard' ;
    rdfs:comment 'Accounting standard applied for this consolidation run (IFRS, US GAAP, local GAAP, regulatory, or management reporting).' ;
    rdfs:domain ind:ConsolidationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Run Duration Seconds' ;
    rdfs:comment 'Total processing time for the consolidation run measured in seconds.' ;
    rdfs:domain ind:ConsolidationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:runEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Run End Timestamp' ;
    rdfs:comment 'Date and time when the consolidation run processing was completed or terminated.' ;
    rdfs:domain ind:ConsolidationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:runMode rdf:type rdf:Property ;
    rdfs:label 'Run Mode' ;
    rdfs:comment 'Execution mode of the consolidation run: manual, scheduled, or automated.' ;
    rdfs:domain ind:ConsolidationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Run Start Timestamp' ;
    rdfs:comment 'Date and time when the consolidation run processing was initiated.' ;
    rdfs:domain ind:ConsolidationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:runStatus rdf:type rdf:Property ;
    rdfs:label 'Run Status' ;
    rdfs:comment 'Current lifecycle status of the consolidation run: initiated, in progress, completed, approved, rejected, or failed.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runType rdf:type rdf:Property ;
    rdfs:label 'Run Type' ;
    rdfs:comment 'Type of consolidation run: preliminary, final, restatement, forecast, or budget consolidation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalAssetsConsolidated rdf:type rdf:Property ;
    rdfs:label 'Total Assets Consolidated' ;
    rdfs:comment 'Total consolidated assets after all eliminations, adjustments, and translations, in presentation currency.' ;
    rdfs:domain ind:ConsolidationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalEquityConsolidated rdf:type rdf:Property ;
    rdfs:label 'Total Equity Consolidated' ;
    rdfs:comment 'Total consolidated equity including non-controlling interest, after all consolidation adjustments, in presentation currency.' ;
    rdfs:domain ind:ConsolidationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalLiabilitiesConsolidated rdf:type rdf:Property ;
    rdfs:label 'Total Liabilities Consolidated' ;
    rdfs:comment 'Total consolidated liabilities after all eliminations, adjustments, and translations, in presentation currency.' ;
    rdfs:domain ind:ConsolidationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validationErrorsCount rdf:type rdf:Property ;
    rdfs:label 'Validation Errors Count' ;
    rdfs:comment 'Number of validation errors or exceptions identified during post-consolidation validation.' ;
    rdfs:domain ind:ConsolidationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:budgetCurrencyId rdf:type rdf:Property ;
    rdfs:label 'Budget Currency Id' ;
    rdfs:comment 'Foreign key linking to reference.currency. Business justification: Cost center budgets are set in specific currencies; this link enables budget vs. actual reporting in correct currency, budget translation for consolidation, and multi-currency budget management.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:parentCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Parent Cost Center Id' ;
    rdfs:comment 'Identifier of the parent cost center in the organizational hierarchy. Null for top-level units. Enables hierarchical roll-up of costs and revenues.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:quaternaryCostResponsibleManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Cost Responsible Manager Employee Id' ;
    rdfs:comment 'FK to hr.employee' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryCostLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Cost Last Modified By User Employee Id' ;
    rdfs:comment 'User ID of the person who last modified this cost center record. Used for audit trail and SOX compliance.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:baselBusinessLine rdf:type rdf:Property ;
    rdfs:label 'Basel Business Line' ;
    rdfs:comment 'Basel III standardized business line classification for operational risk capital calculation. Maps cost center to one of eight Basel business lines. [ENUM-REF-CANDIDATE: corporate_finance|trading_sales|retail_banking|commercial_banking|payment_settlement|agency_services|asset_management|retail_brokerage — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costAllocationMethod rdf:type rdf:Property ;
    rdfs:label 'Cost Allocation Method' ;
    rdfs:comment 'Method used to allocate shared or indirect costs to this cost center. Direct assigns costs directly incurred; step-down cascades from service units; reciprocal accounts for mutual services; activity-based uses cost drivers. [ENUM-REF-CANDIDATE: direct|step_down|reciprocal|activity_based|headcount|square_footage|custom — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterDescription rdf:type rdf:Property ;
    rdfs:label 'Cost Center Description' ;
    rdfs:comment 'Detailed business description of the cost center\'s purpose, scope, and responsibilities.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterName rdf:type rdf:Property ;
    rdfs:label 'Cost Center Name' ;
    rdfs:comment 'Full business name of the cost center organizational unit.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterStatus rdf:type rdf:Property ;
    rdfs:label 'Cost Center Status' ;
    rdfs:comment 'Current lifecycle status of the cost center. Active units participate in financial transactions; inactive/closed units are historical.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterType rdf:type rdf:Property ;
    rdfs:label 'Cost Center Type' ;
    rdfs:comment 'Classification of the organizational unit by financial responsibility: cost center (expense only), revenue center (revenue only), profit center (P&L responsibility), investment center (ROI responsibility), shared service (allocated costs), or support unit (overhead).' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ftpRateAssignmentMethod rdf:type rdf:Property ;
    rdfs:label 'Ftp Rate Assignment Method' ;
    rdfs:comment 'Method used to assign FTP rates to this cost center for internal profitability measurement. Matched maturity assigns rates based on asset/liability duration; pooled uses average rates; market-based uses external benchmarks.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ftpRatePercent rdf:type rdf:Property ;
    rdfs:label 'Ftp Rate Percent' ;
    rdfs:comment 'Current FTP rate assigned to this cost center, expressed as an annual percentage. Used to calculate Net Interest Income (NII) and Net Interest Margin (NIM) at the cost center level.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:glAccountRangeEnd rdf:type rdf:Property ;
    rdfs:label 'Gl Account Range End' ;
    rdfs:comment 'Ending GL account number in the range assigned to this cost center. Used to filter GL transactions by cost center.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccountRangeStart rdf:type rdf:Property ;
    rdfs:label 'Gl Account Range Start' ;
    rdfs:comment 'Starting GL account number in the range assigned to this cost center. Used to filter GL transactions by cost center.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ifrs8ReportableSegmentFlag rdf:type rdf:Property ;
    rdfs:label 'Ifrs8 Reportable Segment Flag' ;
    rdfs:comment 'Indicates whether this cost center is part of an IFRS 8 reportable operating segment that must be disclosed in external financial statements.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revenueAllocationMethod rdf:type rdf:Property ;
    rdfs:label 'Revenue Allocation Method' ;
    rdfs:comment 'Method used to allocate revenues to this cost center. Direct allocation assigns revenues directly generated; activity-based uses cost drivers; headcount uses employee count; revenue driver uses business-specific metrics.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxControlScopeFlag rdf:type rdf:Property ;
    rdfs:label 'Sox Control Scope Flag' ;
    rdfs:comment 'Indicates whether this cost center is in scope for SOX Section 404 internal control testing and documentation.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transferPricingMethod rdf:type rdf:Property ;
    rdfs:label 'Transfer Pricing Method' ;
    rdfs:comment 'Method used for intercompany or inter-unit transfer pricing when this cost center transacts with other units. Cost-plus adds markup to cost; market price uses external benchmarks; negotiated uses agreed rates.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialCloseTaskId rdf:type rdf:Property ;
    rdfs:label 'Financial Close Task Id' ;
    rdfs:comment 'Unique identifier for the financial close task within the period-end close checklist.' ;
    rdfs:domain ind:FinancialCloseTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:alt5FinancialLastModifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Alt5 Financial Last Modified By Employee Id' ;
    rdfs:comment 'Reference to the user who last modified this close task record, establishing accountability for changes.' ;
    rdfs:domain ind:FinancialCloseTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryFinancialEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Financial Employee Id' ;
    rdfs:comment 'Reference to the employee or user responsible for completing this close task, establishing clear ownership and accountability.' ;
    rdfs:domain ind:FinancialCloseTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryFinancialTaskApproverEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Financial Task Approver Employee Id' ;
    rdfs:comment 'Reference to the employee with authority to approve and sign off on the completed task, typically a manager or controller.' ;
    rdfs:domain ind:FinancialCloseTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quinaryFinancialWaiverApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quinary Financial Waiver Approved By Employee Id' ;
    rdfs:comment 'Reference to the senior manager or controller who approved the waiver of this close task, establishing accountability for exceptions.' ;
    rdfs:domain ind:FinancialCloseTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:taskTemplateId rdf:type rdf:Property ;
    rdfs:label 'Task Template Id' ;
    rdfs:comment 'Reference to the master task template from which this instance was created, enabling standardization and version control of close procedures.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TaskTemplate .

ind:tertiaryFinancialTaskReviewerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Financial Task Reviewer Employee Id' ;
    rdfs:comment 'Reference to the employee responsible for reviewing the completed task before final approval, supporting segregation of duties.' ;
    rdfs:domain ind:FinancialCloseTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualEffortHours rdf:type rdf:Property ;
    rdfs:label 'Actual Effort Hours' ;
    rdfs:comment 'Actual number of hours spent completing this close task, used for performance analysis and future estimation refinement.' ;
    rdfs:domain ind:FinancialCloseTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Start Timestamp' ;
    rdfs:comment 'The actual date and time when work on this close task was initiated, used for cycle time analysis and performance tracking.' ;
    rdfs:domain ind:FinancialCloseTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:blockingIssueDescription rdf:type rdf:Property ;
    rdfs:label 'Blocking Issue Description' ;
    rdfs:comment 'Description of any issue or dependency that is preventing this close task from being completed, used for escalation and resolution tracking.' ;
    rdfs:domain ind:FinancialCloseTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Completion Timestamp' ;
    rdfs:comment 'The date and time when this close task was marked as completed by the task owner or preparer.' ;
    rdfs:domain ind:FinancialCloseTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:estimatedEffortHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Effort Hours' ;
    rdfs:comment 'Estimated number of hours required to complete this close task, used for capacity planning and resource allocation.' ;
    rdfs:domain ind:FinancialCloseTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evidenceDocumentIds rdf:type rdf:Property ;
    rdfs:label 'Evidence Document Ids' ;
    rdfs:comment 'Comma-separated list of document IDs representing supporting evidence attachments (reconciliations, approvals, analysis) for this close task.' ;
    rdfs:domain ind:FinancialCloseTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Evidence Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether documentary evidence of task completion must be attached for audit and compliance purposes.' ;
    rdfs:domain ind:FinancialCloseTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:financialCloseTaskStatus rdf:type rdf:Property ;
    rdfs:label 'Financial Close Task Status' ;
    rdfs:comment 'Current status of the close task in its lifecycle: not started, in progress, completed, overdue, waived (approved exception), or blocked (awaiting dependency).' ;
    rdfs:domain ind:FinancialCloseTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isKeyControl rdf:type rdf:Property ;
    rdfs:label 'Is Key Control' ;
    rdfs:comment 'Boolean flag indicating whether this close task represents a key control for SOX compliance (True) or a supporting control (False).' ;
    rdfs:domain ind:FinancialCloseTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRecurring rdf:type rdf:Property ;
    rdfs:label 'Is Recurring' ;
    rdfs:comment 'Boolean flag indicating whether this close task recurs every period (True) or is a one-time task (False), supporting task template management.' ;
    rdfs:domain ind:FinancialCloseTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:predecessorTaskIds rdf:type rdf:Property ;
    rdfs:label 'Predecessor Task Ids' ;
    rdfs:comment 'Comma-separated list of financial_close_task_id values representing tasks that must be completed before this task can begin, establishing task dependencies.' ;
    rdfs:domain ind:FinancialCloseTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskCode rdf:type rdf:Property ;
    rdfs:label 'Task Code' ;
    rdfs:comment 'Unique business identifier or code assigned to the close task for reference and tracking purposes (e.g., JE-001, RECON-GL-001).' ;
    rdfs:domain ind:FinancialCloseTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskDescription rdf:type rdf:Property ;
    rdfs:label 'Task Description' ;
    rdfs:comment 'Detailed description of the close task including specific activities, scope, and deliverables required for completion.' ;
    rdfs:domain ind:FinancialCloseTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskName rdf:type rdf:Property ;
    rdfs:label 'Task Name' ;
    rdfs:comment 'Short descriptive name of the financial close task (e.g., Post Accrual Journal Entries, Reconcile Cash Accounts).' ;
    rdfs:domain ind:FinancialCloseTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskType rdf:type rdf:Property ;
    rdfs:label 'Task Type' ;
    rdfs:comment 'Classification of the close task by activity type: journal posting, reconciliation, accrual review, approval, sign-off, or flux analysis.' ;
    rdfs:domain ind:FinancialCloseTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverApprovalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Waiver Approval Timestamp' ;
    rdfs:comment 'The date and time when the waiver for this close task was formally approved by authorized management.' ;
    rdfs:domain ind:FinancialCloseTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:parentAccountGlAccountId rdf:type rdf:Property ;
    rdfs:label 'Parent Account Gl Account Id' ;
    rdfs:comment 'Reference to the parent account in the account hierarchy. Enables roll-up reporting and hierarchical financial analysis.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:profitCenterId rdf:type rdf:Property ;
    rdfs:label 'Profit Center Id' ;
    rdfs:comment 'Reference to the profit center for internal profitability analysis. Used for segment reporting and management decision-making.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProfitCenter .

ind:regulatoryReportingCodeId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Code Id' ;
    rdfs:comment 'Foreign key linking to reference.reporting_code. Business justification: GL accounts are tagged with regulatory reporting codes for automated regulatory report generation; this link enables Basel III, CCAR, DFAST, and other prudential reporting.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReportingCode .

ind:accountCategory rdf:type rdf:Property ;
    rdfs:label 'Account Category' ;
    rdfs:comment 'Sub-classification within the account type (e.g., current asset, fixed asset, operating expense, cost of goods sold). Used for financial statement line item grouping and regulatory reporting.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountHierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Account Hierarchy Level' ;
    rdfs:comment 'The level of this account in the chart of accounts hierarchy (1=top level, increasing for detail accounts). Used for reporting aggregation and drill-down.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountSubcategory rdf:type rdf:Property ;
    rdfs:label 'Account Subcategory' ;
    rdfs:comment 'Granular classification within the account category for detailed financial analysis and management reporting (e.g., trade receivables, employee receivables, intercompany receivables).' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetControlFlag rdf:type rdf:Property ;
    rdfs:label 'Budget Control Flag' ;
    rdfs:comment 'Indicates whether postings to this account are subject to budget availability checking. Prevents overspending and enforces fiscal discipline.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:naturalBalance rdf:type rdf:Property ;
    rdfs:label 'Natural Balance' ;
    rdfs:comment 'The normal balance side for this account: debit for assets and expenses, credit for liabilities, equity, and revenue. Used for balance validation and error detection.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationFrequency rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Frequency' ;
    rdfs:comment 'The required frequency for account reconciliation: daily for high-volume transaction accounts, monthly for standard accounts, quarterly for low-activity accounts.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revaluationFlag rdf:type rdf:Property ;
    rdfs:label 'Revaluation Flag' ;
    rdfs:comment 'Indicates whether this account is subject to foreign exchange revaluation or fair value remeasurement at period end. Applies to foreign currency accounts and financial instruments.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxAccountFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Account Flag' ;
    rdfs:comment 'Indicates whether this account is used for tax-related transactions (VAT, sales tax, withholding tax). Subject to specific tax reporting and compliance requirements.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:thirdPartyControlFlag rdf:type rdf:Property ;
    rdfs:label 'Third Party Control Flag' ;
    rdfs:comment 'Indicates whether this account is a control account for a subledger (AP, AR, fixed assets). Balance must reconcile to subledger detail.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:intercompanyEliminationId rdf:type rdf:Property ;
    rdfs:label 'Intercompany Elimination Id' ;
    rdfs:comment 'Unique identifier for the intercompany elimination record.' ;
    rdfs:domain ind:IntercompanyElimination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eliminationPeriodAccountingPeriodId rdf:type rdf:Property ;
    rdfs:label 'Elimination Period Accounting Period Id' ;
    rdfs:comment 'Foreign key linking to ledger.accounting_period. Business justification: intercompany_elimination stores elimination_period as STRING but should FK to accounting_period. Eliminations are processed for specific accounting periods during consolidation. Using descriptive FK n' ;
    rdfs:domain ind:IntercompanyElimination ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccountingPeriod .

ind:intercompanyTransactionId rdf:type rdf:Property ;
    rdfs:label 'Intercompany Transaction Id' ;
    rdfs:comment 'Reference to the underlying intercompany transaction being eliminated.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IntercompanyTransaction .

ind:originatingLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Originating Legal Entity Id' ;
    rdfs:comment 'Legal entity that initiated the intercompany transaction.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:primaryIntercompanyCounterpartyLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Primary Intercompany Counterparty Legal Entity Id' ;
    rdfs:comment 'Legal entity that is the counterparty to the intercompany transaction.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:primaryIntercompanyEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Intercompany Employee Id' ;
    rdfs:comment 'User ID of the person who approved the elimination entry.' ;
    rdfs:domain ind:IntercompanyElimination ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryIntercompanyLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Intercompany Last Modified By User Employee Id' ;
    rdfs:comment 'User ID of the person who last modified the elimination record.' ;
    rdfs:domain ind:IntercompanyElimination ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accountingStandard rdf:type rdf:Property ;
    rdfs:label 'Accounting Standard' ;
    rdfs:comment 'Accounting standard under which the elimination is recorded (IFRS, US GAAP, or local GAAP).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterpartyGlAccountCode rdf:type rdf:Property ;
    rdfs:label 'Counterparty Gl Account Code' ;
    rdfs:comment 'General ledger account code on the counterparty entity\'s books.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eliminationAmount rdf:type rdf:Property ;
    rdfs:label 'Elimination Amount' ;
    rdfs:comment 'Amount of the elimination entry in functional currency.' ;
    rdfs:domain ind:IntercompanyElimination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eliminationGlAccountCode rdf:type rdf:Property ;
    rdfs:label 'Elimination Gl Account Code' ;
    rdfs:comment 'General ledger account code used for the consolidation elimination entry.' ;
    rdfs:domain ind:IntercompanyElimination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eliminationMethod rdf:type rdf:Property ;
    rdfs:label 'Elimination Method' ;
    rdfs:comment 'Method used for consolidation elimination: full consolidation, proportional consolidation, equity method, or no elimination.' ;
    rdfs:domain ind:IntercompanyElimination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eliminationReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Elimination Reference Number' ;
    rdfs:comment 'Business identifier for the elimination entry, typically the journal entry number in the consolidation system.' ;
    rdfs:domain ind:IntercompanyElimination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eliminationStatus rdf:type rdf:Property ;
    rdfs:label 'Elimination Status' ;
    rdfs:comment 'Current status of the elimination entry in the consolidation workflow.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Functional Currency Amount' ;
    rdfs:comment 'Transaction amount converted to functional currency for consolidation purposes.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:functionalCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Functional Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code of the reporting entity\'s functional currency.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nettingAgreementReference rdf:type rdf:Property ;
    rdfs:label 'Netting Agreement Reference' ;
    rdfs:comment 'Reference to the intercompany netting agreement governing this transaction, if applicable.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originatingGlAccountCode rdf:type rdf:Property ;
    rdfs:label 'Originating Gl Account Code' ;
    rdfs:comment 'General ledger account code on the originating entity\'s books.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxControlReference rdf:type rdf:Property ;
    rdfs:label 'Sox Control Reference' ;
    rdfs:comment 'Reference to the SOX financial control that governs this elimination entry.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferPricingDocumentationReference rdf:type rdf:Property ;
    rdfs:label 'Transfer Pricing Documentation Reference' ;
    rdfs:comment 'Reference to transfer pricing documentation supporting the intercompany transaction pricing.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eliminationJournalEntryId rdf:type rdf:Property ;
    rdfs:label 'Elimination Journal Entry Id' ;
    rdfs:comment 'Identifier of the consolidation journal entry that eliminated this intercompany transaction during the financial close process.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntry .

ind:matchedTransactionId rdf:type rdf:Property ;
    rdfs:label 'Matched Transaction Id' ;
    rdfs:comment 'Identifier of the corresponding intercompany transaction record in the counterparty legal entity that matches this transaction for reconciliation purposes.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IntercompanyTransaction .

ind:reversedTransactionIntercompanyTransactionId rdf:type rdf:Property ;
    rdfs:label 'Reversed Transaction Intercompany Transaction Id' ;
    rdfs:comment 'Identifier of the original intercompany transaction that this record reverses, if applicable.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IntercompanyTransaction .

ind:taxJurisdictionCountryId rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction Country Id' ;
    rdfs:comment 'Foreign key linking to reference.country. Business justification: Intercompany transactions are subject to specific tax jurisdictions for withholding tax and transfer pricing compliance; this link enables accurate tax calculation and regulatory reporting.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:businessUnitCode rdf:type rdf:Property ;
    rdfs:label 'Business Unit Code' ;
    rdfs:comment 'Code identifying the business unit or division within the originating legal entity responsible for the intercompany transaction.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eliminationPeriod rdf:type rdf:Property ;
    rdfs:label 'Elimination Period' ;
    rdfs:comment 'The fiscal period in which the intercompany transaction was or will be eliminated during the consolidation process.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intercompanyTransactionDescription rdf:type rdf:Property ;
    rdfs:label 'Intercompany Transaction Description' ;
    rdfs:comment 'Detailed textual description of the intercompany transaction, including business purpose and context.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Reference Number' ;
    rdfs:comment 'Reference number of the payment transaction used to settle the intercompany obligation, if applicable.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productLineCode rdf:type rdf:Property ;
    rdfs:label 'Product Line Code' ;
    rdfs:comment 'Code identifying the product line or service category associated with the intercompany transaction for profitability analysis.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Source System Transaction Reference' ;
    rdfs:comment 'The unique transaction identifier from the originating source system, used for traceability and reconciliation.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryJournalEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Journal Employee Id' ;
    rdfs:comment 'User ID or employee identifier of the person who prepared or created the journal entry, supporting SOX segregation of duties controls.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryJournalLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Primary Journal Legal Entity Id' ;
    rdfs:comment 'Reference to the legal entity (subsidiary, branch, operating company) to which this journal entry belongs for consolidation and statutory reporting.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:recurringTemplateId rdf:type rdf:Property ;
    rdfs:label 'Recurring Template Id' ;
    rdfs:comment 'Reference to the recurring journal entry template from which this entry was generated, if applicable. Null for non-recurring entries.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RecurringTemplate .

ind:reversedJournalEntryId rdf:type rdf:Property ;
    rdfs:label 'Reversed Journal Entry Id' ;
    rdfs:comment 'Reference to the original journal entry that this entry reverses, establishing the reversal relationship for audit trail. Null if not a reversal.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntry .

ind:adjustmentIndicator rdf:type rdf:Property ;
    rdfs:label 'Adjustment Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this journal entry is a period-end or year-end adjustment (true) or a regular operational entry (false), supporting financial close process tracking.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:batchName rdf:type rdf:Property ;
    rdfs:label 'Batch Name' ;
    rdfs:comment 'Descriptive name of the batch or import run that created this journal entry, for operational tracking and troubleshooting.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalTotalCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Functional Total Credit Amount' ;
    rdfs:comment 'Total credit amount translated into the functional currency of the legal entity using the applicable exchange rate at accounting date.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:functionalTotalDebitAmount rdf:type rdf:Property ;
    rdfs:label 'Functional Total Debit Amount' ;
    rdfs:comment 'Total debit amount translated into the functional currency of the legal entity using the applicable exchange rate at accounting date.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:intercompanyIndicator rdf:type rdf:Property ;
    rdfs:label 'Intercompany Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this journal entry represents an intercompany transaction requiring elimination during consolidation (true) or is a single-entity transaction (false).' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:journalCategory rdf:type rdf:Property ;
    rdfs:label 'Journal Category' ;
    rdfs:comment 'User-defined or system-assigned category for grouping and reporting journal entries (e.g., payroll, depreciation, revenue recognition, tax provision, consolidation).' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:journalEntryDescription rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Description' ;
    rdfs:comment 'Free-text narrative description of the business purpose and nature of the journal entry, supporting audit trail and user understanding.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:journalNumber rdf:type rdf:Property ;
    rdfs:label 'Journal Number' ;
    rdfs:comment 'Business-facing unique journal entry number assigned by the GL system or user, used for external reference and audit trail.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:journalSource rdf:type rdf:Property ;
    rdfs:label 'Journal Source' ;
    rdfs:comment 'Origin or type of journal entry indicating how it was created: manual entry by user, automated posting from subledger (AP/AR/FA), intercompany elimination, period-end accrual, foreign exchange or fair value revaluation, reversal of prior entry, recurring template-based entry, account reclassification, top-side consolidation adjustment, or statistical (non-monetary) entry. [ENUM-REF-CANDIDATE: manual|subledger|intercompany|accrual|revaluation|reversal|recurring|reclassification|top_side_adjustment|statistical — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingStatus rdf:type rdf:Property ;
    rdfs:label 'Posting Status' ;
    rdfs:comment 'Current posting status of the journal entry in the general ledger: unposted (not yet affecting GL balances), posted (committed to GL), reversed (original entry reversed by a subsequent entry), or voided (cancelled before posting).' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statisticalIndicator rdf:type rdf:Property ;
    rdfs:label 'Statistical Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this journal entry is statistical (non-monetary, used for ratio calculations and management reporting) rather than a financial accounting entry.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:subledgerSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Subledger Source System' ;
    rdfs:comment 'Name or code of the upstream subledger system (AP, AR, FA, Payroll, etc.) that originated this journal entry, supporting data lineage and reconciliation.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subledgerTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Subledger Transaction Reference' ;
    rdfs:comment 'Unique transaction identifier from the source subledger system, enabling drill-back and reconciliation between GL and subledger.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Total Credit Amount' ;
    rdfs:comment 'Sum of all credit line amounts in the journal entry, expressed in the entry currency. Must equal total_debit_amount for a balanced entry.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDebitAmount rdf:type rdf:Property ;
    rdfs:label 'Total Debit Amount' ;
    rdfs:comment 'Sum of all debit line amounts in the journal entry, expressed in the entry currency. Must equal total_credit_amount for a balanced entry.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:journalEntryLineId rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Line Id' ;
    rdfs:comment 'Unique identifier for the journal entry line. Primary key for atomic GL postings.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:enteredCurrencyId rdf:type rdf:Property ;
    rdfs:label 'Entered Currency Id' ;
    rdfs:comment 'Foreign key linking to reference.currency. Business justification: Individual journal lines may be entered in currencies different from header; this link supports multi-currency transaction processing, line-level FX calculation, and detailed currency reporting in ban' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:reversedLineJournalEntryLineId rdf:type rdf:Property ;
    rdfs:label 'Reversed Line Journal Entry Line Id' ;
    rdfs:comment 'Reference to the original journal entry line being reversed. Maintains audit trail for reversing entries.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntryLine .

ind:businessSegmentCode rdf:type rdf:Property ;
    rdfs:label 'Business Segment Code' ;
    rdfs:comment 'Business segment or division code for segment reporting. Supports IFRS 8 and regulatory segment disclosures.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Amount' ;
    rdfs:comment 'Credit amount in functional currency. Represents increases to liability, equity, and revenue accounts or decreases to asset and expense accounts.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:debitAmount rdf:type rdf:Property ;
    rdfs:label 'Debit Amount' ;
    rdfs:comment 'Debit amount in functional currency. Represents increases to asset and expense accounts or decreases to liability, equity, and revenue accounts.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enteredAmount rdf:type rdf:Property ;
    rdfs:label 'Entered Amount' ;
    rdfs:comment 'Transaction amount in the original entered currency before conversion to functional currency. Supports multi-currency operations and FX analysis.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exchangeRateType rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate Type' ;
    rdfs:comment 'Type of exchange rate used for currency conversion. Supports different rate types for various accounting treatments.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intercompanyEntityCode rdf:type rdf:Property ;
    rdfs:label 'Intercompany Entity Code' ;
    rdfs:comment 'Legal entity or intercompany counterparty code for consolidation and intercompany eliminations. Critical for group-level IFRS/GAAP consolidation.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineDescription rdf:type rdf:Property ;
    rdfs:label 'Line Description' ;
    rdfs:comment 'Detailed description of the journal entry line. Provides business context and audit trail for the posting.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineNumber rdf:type rdf:Property ;
    rdfs:label 'Line Number' ;
    rdfs:comment 'Sequential line number within the journal entry. Establishes ordering for audit trail and display purposes.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:statisticalAmount rdf:type rdf:Property ;
    rdfs:label 'Statistical Amount' ;
    rdfs:comment 'Non-monetary statistical amount for allocation or reporting purposes. Supports headcount, square footage, or other allocation bases.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:statisticalUnit rdf:type rdf:Property ;
    rdfs:label 'Statistical Unit' ;
    rdfs:comment 'Unit of measure for the statistical amount. Examples include headcount, square meters, or transaction count.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subledgerReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Subledger Reference Code' ;
    rdfs:comment 'Reference identifier to the originating subledger transaction. Enables drill-back to source documents for audit and reconciliation.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subledgerType rdf:type rdf:Property ;
    rdfs:label 'Subledger Type' ;
    rdfs:comment 'Type of subledger that originated this posting. Links GL to operational systems such as AP, AR, loan origination, or trading platforms. [ENUM-REF-CANDIDATE: accounts_payable|accounts_receivable|fixed_assets|cash_management|loan|deposit|securities|none — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCode rdf:type rdf:Property ;
    rdfs:label 'Tax Code' ;
    rdfs:comment 'Tax code for VAT, GST, or other tax treatment. Supports tax reporting and compliance with FATCA and CRS requirements.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ledgerBudgetId rdf:type rdf:Property ;
    rdfs:label 'Ledger Budget Id' ;
    rdfs:comment 'Unique identifier for the budget record. Primary key.' ;
    rdfs:domain ind:LedgerBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryLedgerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Ledger Employee Id' ;
    rdfs:comment 'Identifier of the user who approved this budget record.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryLedgerLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Ledger Last Modified By User Employee Id' ;
    rdfs:comment 'Identifier of the user who last modified this budget record.' ;
    rdfs:domain ind:LedgerBudget ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Amount' ;
    rdfs:comment 'Actual amount spent or earned against this budget for variance tracking.' ;
    rdfs:domain ind:LedgerBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationDriver rdf:type rdf:Property ;
    rdfs:label 'Allocation Driver' ;
    rdfs:comment 'The business driver or metric used as the basis for budget allocation (e.g., headcount, revenue, square footage).' ;
    rdfs:domain ind:LedgerBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationMethod rdf:type rdf:Property ;
    rdfs:label 'Allocation Method' ;
    rdfs:comment 'Method used to allocate the budget across cost centers or profit centers.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetCategory rdf:type rdf:Property ;
    rdfs:label 'Budget Category' ;
    rdfs:comment 'High-level financial statement category for the budget (revenue, expense, asset, liability).' ;
    rdfs:domain ind:LedgerBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetType rdf:type rdf:Property ;
    rdfs:label 'Budget Type' ;
    rdfs:comment 'Classification of the budget type (operating expense, capital expenditure, project-based, strategic initiative).' ;
    rdfs:domain ind:LedgerBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastAmount rdf:type rdf:Property ;
    rdfs:label 'Forecast Amount' ;
    rdfs:comment 'Updated forecast amount for the period based on current trends and projections.' ;
    rdfs:domain ind:LedgerBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lockFlag rdf:type rdf:Property ;
    rdfs:label 'Lock Flag' ;
    rdfs:comment 'Indicates whether this budget record is locked and cannot be modified.' ;
    rdfs:domain ind:LedgerBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lockedDate rdf:type rdf:Property ;
    rdfs:label 'Locked Date' ;
    rdfs:comment 'Date on which the budget was locked for changes.' ;
    rdfs:domain ind:LedgerBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priorYearActualAmount rdf:type rdf:Property ;
    rdfs:label 'Prior Year Actual Amount' ;
    rdfs:comment 'Actual amount from the same period in the prior fiscal year for comparative analysis.' ;
    rdfs:domain ind:LedgerBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scenario rdf:type rdf:Property ;
    rdfs:label 'Scenario' ;
    rdfs:comment 'Scenario classification for the budget (base case, optimistic, pessimistic, stress scenario).' ;
    rdfs:domain ind:LedgerBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountingCalendarId rdf:type rdf:Property ;
    rdfs:label 'Accounting Calendar Id' ;
    rdfs:comment 'Reference to the fiscal calendar defining the period structure (months, quarters, years) used for financial reporting and period close processes in this ledger.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccountingCalendar .

ind:averageBalanceProcessingFlag rdf:type rdf:Property ;
    rdfs:label 'Average Balance Processing Flag' ;
    rdfs:comment 'Indicates whether this ledger set maintains daily average balance calculations for balance sheet accounts, required for Net Interest Margin (NIM) and Funds Transfer Pricing (FTP) analytics in banking.' ;
    rdfs:domain ind:Set ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:budgetControlEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Budget Control Enabled Flag' ;
    rdfs:comment 'Indicates whether budgetary control and funds checking are enforced for transactions posted to this ledger set, preventing overspending against approved budgets.' ;
    rdfs:domain ind:Set ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ceclCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Cecl Compliant Flag' ;
    rdfs:comment 'Indicates whether this ledger set applies FASB ASC 326 Current Expected Credit Losses (CECL) methodology for estimating lifetime credit losses on financial instruments.' ;
    rdfs:domain ind:Set ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:encumbranceAccountingFlag rdf:type rdf:Property ;
    rdfs:label 'Encumbrance Accounting Flag' ;
    rdfs:comment 'Indicates whether this ledger set records purchase orders and commitments as encumbrances, reserving budget funds before actual expenditure occurs.' ;
    rdfs:domain ind:Set ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:firstPostedPeriod rdf:type rdf:Property ;
    rdfs:label 'First Posted Period' ;
    rdfs:comment 'The earliest accounting period in which transactions were posted to this ledger set, establishing the beginning of the financial history.' ;
    rdfs:domain ind:Set ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ifrs9CompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Ifrs 9 Compliant Flag' ;
    rdfs:comment 'Indicates whether this ledger set applies IFRS 9 Financial Instruments standard for classification, measurement, and Expected Credit Loss (ECL) impairment of financial assets.' ;
    rdfs:domain ind:Set ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:journalApprovalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Journal Approval Required Flag' ;
    rdfs:comment 'Indicates whether manual journal entries posted to this ledger set require supervisory approval before posting, supporting Sarbanes-Oxley Act (SOX) internal control requirements.' ;
    rdfs:domain ind:Set ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:latestClosedPeriod rdf:type rdf:Property ;
    rdfs:label 'Latest Closed Period' ;
    rdfs:comment 'The most recent accounting period that has completed the period close process, including all reconciliations, adjustments, and financial statement generation.' ;
    rdfs:domain ind:Set ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:latestOpenedPeriod rdf:type rdf:Property ;
    rdfs:label 'Latest Opened Period' ;
    rdfs:comment 'The most recent accounting period that has been opened for transaction posting in this ledger set. Subsequent periods remain closed until explicitly opened.' ;
    rdfs:domain ind:Set ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ledgerName rdf:type rdf:Property ;
    rdfs:label 'Ledger Name' ;
    rdfs:comment 'Business name of the ledger set used for identification and reporting purposes within the financial system.' ;
    rdfs:domain ind:Set ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ledgerShortName rdf:type rdf:Property ;
    rdfs:label 'Ledger Short Name' ;
    rdfs:comment 'Abbreviated name or code for the ledger set used in system displays and reports.' ;
    rdfs:domain ind:Set ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ledgerStatus rdf:type rdf:Property ;
    rdfs:label 'Ledger Status' ;
    rdfs:comment 'Current operational status of the ledger set indicating whether it is available for transaction posting and financial reporting.' ;
    rdfs:domain ind:Set ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ledgerType rdf:type rdf:Property ;
    rdfs:label 'Ledger Type' ;
    rdfs:comment 'Classification of the ledger set indicating its purpose within the financial accounting architecture. Primary ledgers represent the official books of record; secondary ledgers enable parallel accounting under different standards; reporting ledgers support management reporting; adjustment ledgers track post-close adjustments; simulation ledgers support scenario planning; consolidation ledgers aggregate multiple legal entities.' ;
    rdfs:domain ind:Set ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodCloseToleranceAmount rdf:type rdf:Property ;
    rdfs:label 'Period Close Tolerance Amount' ;
    rdfs:comment 'The maximum out-of-balance amount permitted during period close reconciliation before the close process is blocked. Supports financial close controls and accuracy requirements.' ;
    rdfs:domain ind:Set ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retainedEarningsAccount rdf:type rdf:Property ;
    rdfs:label 'Retained Earnings Account' ;
    rdfs:comment 'The general ledger account code designated to receive net income or loss transfers during the year-end close process for this ledger set.' ;
    rdfs:domain ind:Set ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revaluationMethod rdf:type rdf:Property ;
    rdfs:label 'Revaluation Method' ;
    rdfs:comment 'The frequency and method for revaluing foreign currency balances to reflect current exchange rates. Period-end revaluation occurs at month close; daily revaluation supports mark-to-market trading book requirements.' ;
    rdfs:domain ind:Set ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentValueSecurityEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Segment Value Security Enabled Flag' ;
    rdfs:comment 'Indicates whether data-level security rules restrict user access to specific chart of accounts segment values (e.g., cost centers, business units) within this ledger set.' ;
    rdfs:domain ind:Set ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:setDescription rdf:type rdf:Property ;
    rdfs:label 'Set Description' ;
    rdfs:comment 'Detailed business description of the ledger set purpose, scope, and usage within the financial accounting architecture.' ;
    rdfs:domain ind:Set ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxControlLedgerFlag rdf:type rdf:Property ;
    rdfs:label 'Sox Control Ledger Flag' ;
    rdfs:comment 'Indicates whether this ledger set is subject to Sarbanes-Oxley Act Section 404 internal control testing and audit requirements for financial reporting accuracy.' ;
    rdfs:domain ind:Set ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:subledgerAccountingMethod rdf:type rdf:Property ;
    rdfs:label 'Subledger Accounting Method' ;
    rdfs:comment 'The accounting basis and recognition method applied when subledger transactions (AP, AR, FA, etc.) are transferred to the general ledger. Defines timing of revenue and expense recognition.' ;
    rdfs:domain ind:Set ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suspenseAccount rdf:type rdf:Property ;
    rdfs:label 'Suspense Account' ;
    rdfs:comment 'The general ledger account code used to temporarily hold unbalanced or unidentified transactions pending investigation and reclassification.' ;
    rdfs:domain ind:Set ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:translationMethod rdf:type rdf:Property ;
    rdfs:label 'Translation Method' ;
    rdfs:comment 'The method used to translate foreign currency balances into the reporting currency for consolidation. Current rate method translates all assets and liabilities at the closing rate; temporal method uses historical rates for non-monetary items.' ;
    rdfs:domain ind:Set ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ledgerSoxControlId rdf:type rdf:Property ;
    rdfs:label 'Ledger Sox Control Id' ;
    rdfs:comment 'Unique identifier for the SOX internal control over financial reporting (ICFR) record within the ledger domain.' ;
    rdfs:domain ind:LedgerSoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quaternaryLedgerCreatedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Ledger Created By Employee Id' ;
    rdfs:comment 'Identifier of the employee who initially created this control record.' ;
    rdfs:domain ind:LedgerSoxControl ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quinaryLedgerControlOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quinary Ledger Control Owner Employee Id' ;
    rdfs:comment 'FK to hr.employee' ;
    rdfs:domain ind:LedgerSoxControl ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryLedgerLastUpdatedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Ledger Last Updated By Employee Id' ;
    rdfs:comment 'Identifier of the employee who most recently modified this control record.' ;
    rdfs:domain ind:LedgerSoxControl ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:controlDocumentationLink rdf:type rdf:Property ;
    rdfs:label 'Control Documentation Link' ;
    rdfs:comment 'URL or file path to the detailed control documentation, including process narratives, flowcharts, and control matrices.' ;
    rdfs:domain ind:LedgerSoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Control Effective Date' ;
    rdfs:comment 'The date when this control was first implemented and became operational.' ;
    rdfs:domain ind:LedgerSoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:controlName rdf:type rdf:Property ;
    rdfs:label 'Control Name' ;
    rdfs:comment 'Short descriptive name of the control activity (e.g., Journal Entry Approval, Bank Reconciliation Review).' ;
    rdfs:domain ind:LedgerSoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlRetirementDate rdf:type rdf:Property ;
    rdfs:label 'Control Retirement Date' ;
    rdfs:comment 'The date when this control was retired or decommissioned, if applicable.' ;
    rdfs:domain ind:LedgerSoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:externalAuditorReference rdf:type rdf:Property ;
    rdfs:label 'External Auditor Reference' ;
    rdfs:comment 'Reference number or identifier used by the external auditor (e.g., Big Four firm) to track this control in their audit workpapers and PCAOB inspection documentation.' ;
    rdfs:domain ind:LedgerSoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glProcessArea rdf:type rdf:Property ;
    rdfs:label 'Gl Process Area' ;
    rdfs:comment 'The specific general ledger process or sub-ledger area this control applies to (e.g., Journal Entries, Accounts Payable, Accounts Receivable, Fixed Assets, Intercompany Eliminations, Financial Close, Consolidation).' ;
    rdfs:domain ind:LedgerSoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itDependentIndicator rdf:type rdf:Property ;
    rdfs:label 'It Dependent Indicator' ;
    rdfs:comment 'Flag indicating whether this control relies on IT general controls (ITGC) or automated system controls for its effectiveness.' ;
    rdfs:domain ind:LedgerSoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastTestResult rdf:type rdf:Property ;
    rdfs:label 'Last Test Result' ;
    rdfs:comment 'The outcome of the most recent control test: effective (operating as designed), deficiency (minor issue), significant deficiency (important enough to merit attention), material weakness (reasonable possibility of material misstatement), or not tested.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskAssertion rdf:type rdf:Property ;
    rdfs:label 'Risk Assertion' ;
    rdfs:comment 'The financial statement assertion this control addresses: completeness (all transactions recorded), accuracy (amounts correct), existence (assets/liabilities exist), valuation (proper measurement), presentation (proper classification and disclosure), or rights and obligations (entity has legal claim).' ;
    rdfs:domain ind:LedgerSoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopingDecision rdf:type rdf:Property ;
    rdfs:label 'Scoping Decision' ;
    rdfs:comment 'Indicates whether this control is in scope for SOX 404 testing (in scope), excluded from testing (out of scope), or currently being evaluated for inclusion (under evaluation).' ;
    rdfs:domain ind:LedgerSoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopingRationale rdf:type rdf:Property ;
    rdfs:label 'Scoping Rationale' ;
    rdfs:comment 'Business justification for the scoping decision, including materiality considerations, risk assessment, and process significance.' ;
    rdfs:domain ind:LedgerSoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testExceptionsCount rdf:type rdf:Property ;
    rdfs:label 'Test Exceptions Count' ;
    rdfs:comment 'The number of exceptions or deviations identified during the most recent control test.' ;
    rdfs:domain ind:LedgerSoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:testSampleSize rdf:type rdf:Property ;
    rdfs:label 'Test Sample Size' ;
    rdfs:comment 'The number of control instances or transactions tested during the most recent control effectiveness test.' ;
    rdfs:domain ind:LedgerSoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:testingFrequency rdf:type rdf:Property ;
    rdfs:label 'Testing Frequency' ;
    rdfs:comment 'How often the control is tested for effectiveness by internal audit or external auditors.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testingMethod rdf:type rdf:Property ;
    rdfs:label 'Testing Method' ;
    rdfs:comment 'The audit procedure used to test control effectiveness: inquiry (asking personnel), observation (watching control execution), inspection (examining documentation), reperformance (auditor executes control), or walkthrough (tracing transaction through process).' ;
    rdfs:domain ind:LedgerSoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Parent Legal Entity Id' ;
    rdfs:comment 'Foreign key reference to the immediate parent legal entity within the banking group hierarchy. Null for the ultimate parent entity. Used for consolidation, intercompany eliminations, and organizational reporting.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:primaryUltimateParentLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Primary Ultimate Parent Legal Entity Id' ;
    rdfs:comment 'Foreign key reference to the top-level parent legal entity (holding company) of the entire banking group. Used for ultimate consolidation and group-level regulatory reporting.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:ccarDfastEntityFlag rdf:type rdf:Property ;
    rdfs:label 'Ccar Dfast Entity Flag' ;
    rdfs:comment 'Boolean flag indicating whether this legal entity is included in the scope of Federal Reserve CCAR or DFAST stress testing submissions. True = included in stress testing; False = excluded.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:countryOfDomicile rdf:type rdf:Property ;
    rdfs:label 'Country Of Domicile' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the country where the legal entity has its principal place of business or tax residence. May differ from country of incorporation for tax planning structures.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crsReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Crs Reporting Flag' ;
    rdfs:comment 'Boolean flag indicating whether this legal entity is required to report financial account information under the OECD Common Reporting Standard (CRS) for automatic exchange of information. True = CRS reporting required; False = not a reporting financial institution.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dissolutionDate rdf:type rdf:Property ;
    rdfs:label 'Dissolution Date' ;
    rdfs:comment 'Date on which the legal entity was officially dissolved, liquidated, or deregistered. Null for active entities. Used for historical record-keeping and final reporting.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:externalAuditorName rdf:type rdf:Property ;
    rdfs:label 'External Auditor Name' ;
    rdfs:comment 'Name of the external audit firm responsible for auditing the legal entity statutory financial statements. Used for audit coordination and SOX compliance tracking.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYearEndMonth rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year End Month' ;
    rdfs:comment 'Month (1-12) in which the legal entity closes its fiscal year for statutory financial reporting. Used to align consolidation schedules and regulatory reporting deadlines. Example: 12 = December year-end.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:jurisdictionOfIncorporation rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Of Incorporation' ;
    rdfs:comment 'Legal jurisdiction (state, province, or country) where the entity is incorporated or registered. Determines applicable corporate law, tax regime, and regulatory oversight.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAuditOpinionDate rdf:type rdf:Property ;
    rdfs:label 'Last Audit Opinion Date' ;
    rdfs:comment 'Date of the most recent external audit opinion issued for the legal entity statutory financial statements. Used to track audit currency and compliance status.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastAuditOpinionType rdf:type rdf:Property ;
    rdfs:label 'Last Audit Opinion Type' ;
    rdfs:comment 'Type of audit opinion issued in the most recent external audit. UNQUALIFIED = clean opinion; QUALIFIED = opinion with exceptions; ADVERSE = financial statements materially misstated; DISCLAIMER = auditor unable to form opinion.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalEntityStatus rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Status' ;
    rdfs:comment 'Current operational status of the legal entity. ACTIVE = operating and transacting; INACTIVE = temporarily not operating but still registered; DORMANT = no activity for extended period; LIQUIDATION = in process of winding down; DISSOLVED = legally terminated.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryRegulator rdf:type rdf:Property ;
    rdfs:label 'Primary Regulator' ;
    rdfs:comment 'Name of the primary regulatory authority with supervisory oversight over this legal entity. Examples: Federal Reserve, OCC, FCA, ECB, FINRA, SEC. Used for regulatory reporting routing and compliance tracking.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Registered Address Line1' ;
    rdfs:comment 'First line of the legal entity registered office address as filed with the corporate registry. Used for legal correspondence and regulatory filings.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Registered Address Line2' ;
    rdfs:comment 'Second line of the legal entity registered office address (suite, floor, building name). Optional field for additional address detail.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportingEntityFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Entity Flag' ;
    rdfs:comment 'Boolean flag indicating whether this legal entity is required to file standalone regulatory reports (e.g., Call Reports, FR Y-9C, COREP, FINREP). True = files reports; False = consolidated into parent reporting.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Status' ;
    rdfs:comment 'Indicates whether the legal entity is subject to prudential regulation and supervision by a banking, securities, or insurance regulator. REGULATED = subject to capital, liquidity, and conduct rules; NON_REGULATED = not subject to financial services regulation; EXEMPT = exempt from certain requirements; PENDING = application for regulatory status in progress.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentProfitCenterId rdf:type rdf:Property ;
    rdfs:label 'Parent Profit Center Id' ;
    rdfs:comment 'FK to ledger.profit_center' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProfitCenter .

ind:alternateProfitCenterCode rdf:type rdf:Property ;
    rdfs:label 'Alternate Profit Center Code' ;
    rdfs:comment 'Secondary or legacy profit center code used for cross-system mapping, migration tracking, or external reporting. Supports integration with legacy systems and external partners.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ftpRateAssignment rdf:type rdf:Property ;
    rdfs:label 'Ftp Rate Assignment' ;
    rdfs:comment 'The FTP methodology assigned to this profit center for internal pricing of funds. Matched maturity assigns rates based on asset/liability duration. Pooled and blended methods use average rates. Critical for accurate profitability measurement in banking.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ifrsSegmentFlag rdf:type rdf:Property ;
    rdfs:label 'Ifrs Segment Flag' ;
    rdfs:comment 'Indicates whether this profit center represents a reportable operating segment under IFRS 8. True for segments that meet the quantitative thresholds or are otherwise disclosed separately in financial statements.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lobClassification rdf:type rdf:Property ;
    rdfs:label 'Lob Classification' ;
    rdfs:comment 'The primary line of business classification for this profit center, aligning with the bank\'s strategic business segments and regulatory reporting requirements. [ENUM-REF-CANDIDATE: retail_banking|commercial_banking|investment_banking|wealth_management|treasury|capital_markets|asset_management|corporate_trust|payment_services|other — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterDescription rdf:type rdf:Property ;
    rdfs:label 'Profit Center Description' ;
    rdfs:comment 'Detailed textual description of the profit center\'s business purpose, scope of operations, and strategic objectives. Provides context for financial analysis and reporting.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterName rdf:type rdf:Property ;
    rdfs:label 'Profit Center Name' ;
    rdfs:comment 'The full business name or title of the profit center, used for display and reporting purposes.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterStatus rdf:type rdf:Property ;
    rdfs:label 'Profit Center Status' ;
    rdfs:comment 'Current lifecycle status of the profit center. Active profit centers are operational and accumulate PnL. Inactive or closed profit centers are no longer operational but retained for historical reporting.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterType rdf:type rdf:Property ;
    rdfs:label 'Profit Center Type' ;
    rdfs:comment 'Classification of the profit center by organizational dimension. Indicates whether the profit center represents a banking segment (retail, commercial, investment banking), product line (loans, deposits, trading), geographic region, business unit, legal entity, or functional area.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rarocTargetRate rdf:type rdf:Property ;
    rdfs:label 'Raroc Target Rate' ;
    rdfs:comment 'The target RAROC rate (expressed as a decimal, e.g., 0.1500 for 15%) set for this profit center. Used to evaluate whether the profit center is generating adequate returns relative to the economic capital allocated to it.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportingCurrency rdf:type rdf:Property ;
    rdfs:label 'Reporting Currency' ;
    rdfs:comment 'The currency in which this profit center\'s results are reported for consolidation and group reporting purposes, using ISO 4217 three-letter currency code. May differ from functional currency for foreign operations.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rwaCategory rdf:type rdf:Property ;
    rdfs:label 'Rwa Category' ;
    rdfs:comment 'The primary risk category for RWA calculation and capital allocation. Determines how this profit center\'s activities contribute to the bank\'s total risk-weighted assets under Basel III.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subledgerId rdf:type rdf:Property ;
    rdfs:label 'Subledger Id' ;
    rdfs:comment 'Unique identifier for the subledger configuration and reconciliation record.' ;
    rdfs:domain ind:Subledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:controlGlAccountId rdf:type rdf:Property ;
    rdfs:label 'Control Gl Account Id' ;
    rdfs:comment 'FK to ledger.gl_account' ;
    rdfs:domain ind:Subledger ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:reviewerUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Reviewer User Employee Id' ;
    rdfs:comment 'User identifier of the individual who reviewed the subledger reconciliation.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:subledgerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Subledger Employee Id' ;
    rdfs:comment 'User identifier of the individual who prepared the subledger reconciliation.' ;
    rdfs:domain ind:Subledger ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:subledgerReconciliationId rdf:type rdf:Property ;
    rdfs:label 'Subledger Reconciliation Id' ;
    rdfs:comment 'Unique identifier for the period-end reconciliation execution run linking subledger balances to General Ledger (GL) posted balances.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SubledgerReconciliation .

ind:activeFlag rdf:type rdf:Property ;
    rdfs:label 'Active Flag' ;
    rdfs:comment 'Indicates whether this subledger configuration is currently active (True) or has been decommissioned (False).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:autoReconciliationFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Reconciliation Flag' ;
    rdfs:comment 'Indicates whether the reconciliation was performed automatically by the system (True) or required manual intervention (False).' ;
    rdfs:domain ind:Subledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:balanceAmount rdf:type rdf:Property ;
    rdfs:label 'Balance Amount' ;
    rdfs:comment 'Aggregate balance amount from the subledger module for the reconciliation period, in the reporting currency.' ;
    rdfs:domain ind:Subledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:glPostedBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Gl Posted Balance Amount' ;
    rdfs:comment 'Posted balance amount in the General Ledger (GL) for the corresponding control account and period, in the reporting currency.' ;
    rdfs:domain ind:Subledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:glTransferMethod rdf:type rdf:Property ;
    rdfs:label 'Gl Transfer Method' ;
    rdfs:comment 'Method by which subledger balances are transferred to the General Ledger (batch, real-time, scheduled, manual).' ;
    rdfs:domain ind:Subledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingFrequency rdf:type rdf:Property ;
    rdfs:label 'Posting Frequency' ;
    rdfs:comment 'Frequency at which subledger transactions are posted to the General Ledger (daily, weekly, monthly, quarterly, on-demand).' ;
    rdfs:domain ind:Subledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionActions rdf:type rdf:Property ;
    rdfs:label 'Resolution Actions' ;
    rdfs:comment 'Documented actions taken to resolve any reconciliation exceptions or variances (e.g., journal entry posted, transaction reclassified, timing difference noted).' ;
    rdfs:domain ind:Subledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subledgerCode rdf:type rdf:Property ;
    rdfs:label 'Subledger Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the subledger module within the General Ledger (GL) system.' ;
    rdfs:domain ind:Subledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subledgerName rdf:type rdf:Property ;
    rdfs:label 'Subledger Name' ;
    rdfs:comment 'Business name of the subledger module (e.g., Accounts Payable, Fixed Assets, Loan Subledger).' ;
    rdfs:domain ind:Subledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceRootCause rdf:type rdf:Property ;
    rdfs:label 'Variance Root Cause' ;
    rdfs:comment 'Documented root cause explanation for any variance between subledger and General Ledger (GL) balances (e.g., timing difference, posting error, unrecorded transaction).' ;
    rdfs:domain ind:Subledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primarySubledgerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Subledger Employee Id' ;
    rdfs:comment 'Identifier of the individual who prepared the reconciliation. Required for SOX segregation of duties controls.' ;
    rdfs:domain ind:SubledgerReconciliation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:glBalance rdf:type rdf:Property ;
    rdfs:label 'Gl Balance' ;
    rdfs:comment 'The total balance from the general ledger for the specified period and account range. Represents the GL system balance to be reconciled.' ;
    rdfs:domain ind:SubledgerReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:glSystemName rdf:type rdf:Property ;
    rdfs:label 'Gl System Name' ;
    rdfs:comment 'Name of the general ledger system from which the GL balance was extracted. Used for data lineage and system integration monitoring.' ;
    rdfs:domain ind:SubledgerReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isMaterialVariance rdf:type rdf:Property ;
    rdfs:label 'Is Material Variance' ;
    rdfs:comment 'Boolean flag indicating whether the variance exceeds the materiality threshold and requires escalation. Used for exception reporting and control monitoring.' ;
    rdfs:domain ind:SubledgerReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reconciliationMethod rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Method' ;
    rdfs:comment 'The method used to perform the reconciliation. Indicates the level of automation and manual intervention required.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationNotes rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Notes' ;
    rdfs:comment 'Additional notes or comments related to the reconciliation process, including special circumstances, assumptions, or follow-up actions required.' ;
    rdfs:domain ind:SubledgerReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationNumber rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Number' ;
    rdfs:comment 'Business-facing unique identifier for the reconciliation run, typically formatted as a human-readable reference number for audit trail and SOX control evidence.' ;
    rdfs:domain ind:SubledgerReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresJournalEntry rdf:type rdf:Property ;
    rdfs:label 'Requires Journal Entry' ;
    rdfs:comment 'Boolean flag indicating whether a correcting journal entry is required to resolve the variance. Used for workflow routing and period-end close tracking.' ;
    rdfs:domain ind:SubledgerReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:soxControlEvidenceReference rdf:type rdf:Property ;
    rdfs:label 'Sox Control Evidence Reference' ;
    rdfs:comment 'Reference to the supporting documentation or evidence repository for this reconciliation. Used by internal and external auditors for SOX testing.' ;
    rdfs:domain ind:SubledgerReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subledgerBalance rdf:type rdf:Property ;
    rdfs:label 'Subledger Balance' ;
    rdfs:comment 'The total balance from the subledger system for the specified period and account range. Represents the source system balance to be reconciled.' ;
    rdfs:domain ind:SubledgerReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceExplanation rdf:type rdf:Property ;
    rdfs:label 'Variance Explanation' ;
    rdfs:comment 'Detailed explanation of the identified variance, including root cause analysis and supporting documentation references. Required for SOX control evidence.' ;
    rdfs:domain ind:SubledgerReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxProvisionId rdf:type rdf:Property ;
    rdfs:label 'Tax Provision Id' ;
    rdfs:comment 'Unique identifier for the tax provision record. Primary key.' ;
    rdfs:domain ind:TaxProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryTaxEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Tax Employee Id' ;
    rdfs:comment 'Identifier of the user who prepared the tax provision calculation.' ;
    rdfs:domain ind:TaxProvision ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:auditEvidenceReference rdf:type rdf:Property ;
    rdfs:label 'Audit Evidence Reference' ;
    rdfs:comment 'Reference identifier for audit documentation and supporting evidence for the tax provision.' ;
    rdfs:domain ind:TaxProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentTaxExpenseAmount rdf:type rdf:Property ;
    rdfs:label 'Current Tax Expense Amount' ;
    rdfs:comment 'Current period tax expense based on taxable income and applicable tax rates.' ;
    rdfs:domain ind:TaxProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deferredTaxAssetAmount rdf:type rdf:Property ;
    rdfs:label 'Deferred Tax Asset Amount' ;
    rdfs:comment 'Cumulative deferred tax asset balance arising from deductible temporary differences and tax loss carryforwards.' ;
    rdfs:domain ind:TaxProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deferredTaxExpenseAmount rdf:type rdf:Property ;
    rdfs:label 'Deferred Tax Expense Amount' ;
    rdfs:comment 'Deferred tax expense or benefit arising from temporary differences between book and tax basis.' ;
    rdfs:domain ind:TaxProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deferredTaxLiabilityAmount rdf:type rdf:Property ;
    rdfs:label 'Deferred Tax Liability Amount' ;
    rdfs:comment 'Cumulative deferred tax liability balance arising from taxable temporary differences.' ;
    rdfs:domain ind:TaxProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:effectiveTaxRatePercent rdf:type rdf:Property ;
    rdfs:label 'Effective Tax Rate Percent' ;
    rdfs:comment 'Effective tax rate calculated as total tax expense divided by pretax income, expressed as a percentage.' ;
    rdfs:domain ind:TaxProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netDeferredTaxPositionAmount rdf:type rdf:Property ;
    rdfs:label 'Net Deferred Tax Position Amount' ;
    rdfs:comment 'Net deferred tax position calculated as deferred tax assets minus deferred tax liabilities.' ;
    rdfs:domain ind:TaxProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:permanentDifferenceAmount rdf:type rdf:Property ;
    rdfs:label 'Permanent Difference Amount' ;
    rdfs:comment 'Total permanent differences between book income and taxable income that will never reverse.' ;
    rdfs:domain ind:TaxProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pretaxIncomeAmount rdf:type rdf:Property ;
    rdfs:label 'Pretax Income Amount' ;
    rdfs:comment 'Income before tax expense for the period, used as the basis for tax provision calculation.' ;
    rdfs:domain ind:TaxProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:provisionDate rdf:type rdf:Property ;
    rdfs:label 'Provision Date' ;
    rdfs:comment 'Date on which the tax provision calculation was performed.' ;
    rdfs:domain ind:TaxProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:provisionReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Provision Reference Number' ;
    rdfs:comment 'Business-assigned unique reference number for the tax provision calculation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:provisionStatus rdf:type rdf:Property ;
    rdfs:label 'Provision Status' ;
    rdfs:comment 'Current lifecycle status of the tax provision record.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:provisionType rdf:type rdf:Property ;
    rdfs:label 'Provision Type' ;
    rdfs:comment 'Classification of the tax provision calculation type.' ;
    rdfs:domain ind:TaxProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateReconciliationAmount rdf:type rdf:Property ;
    rdfs:label 'Rate Reconciliation Amount' ;
    rdfs:comment 'Total reconciling amount between statutory tax expense and actual tax expense, representing permanent differences and rate adjustments.' ;
    rdfs:domain ind:TaxProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:statutoryTaxRatePercent rdf:type rdf:Property ;
    rdfs:label 'Statutory Tax Rate Percent' ;
    rdfs:comment 'Statutory corporate income tax rate applicable to the legal entity\'s jurisdiction.' ;
    rdfs:domain ind:TaxProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxCreditCarryforwardAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Credit Carryforward Amount' ;
    rdfs:comment 'Cumulative tax credits available to offset future tax liabilities.' ;
    rdfs:domain ind:TaxProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxLossCarryforwardAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Loss Carryforward Amount' ;
    rdfs:comment 'Cumulative tax loss carryforwards available to offset future taxable income.' ;
    rdfs:domain ind:TaxProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temporaryDifferenceAmount rdf:type rdf:Property ;
    rdfs:label 'Temporary Difference Amount' ;
    rdfs:comment 'Total temporary differences between book basis and tax basis of assets and liabilities that will reverse in future periods.' ;
    rdfs:domain ind:TaxProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalTaxExpenseAmount rdf:type rdf:Property ;
    rdfs:label 'Total Tax Expense Amount' ;
    rdfs:comment 'Total income tax expense for the period, sum of current and deferred tax expense.' ;
    rdfs:domain ind:TaxProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unrecognizedTaxBenefitAmount rdf:type rdf:Property ;
    rdfs:label 'Unrecognized Tax Benefit Amount' ;
    rdfs:comment 'Amount of tax benefit from uncertain tax positions that does not meet the recognition threshold under FIN 48 / IFRIC 23.' ;
    rdfs:domain ind:TaxProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valuationAllowanceAmount rdf:type rdf:Property ;
    rdfs:label 'Valuation Allowance Amount' ;
    rdfs:comment 'Valuation allowance established to reduce deferred tax assets to the amount that is more likely than not to be realized.' ;
    rdfs:domain ind:TaxProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trialBalanceId rdf:type rdf:Property ;
    rdfs:label 'Trial Balance Id' ;
    rdfs:comment 'Unique identifier for the trial balance record. Primary key for this entity.' ;
    rdfs:domain ind:TrialBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adjustmentFlag rdf:type rdf:Property ;
    rdfs:label 'Adjustment Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether this trial balance line includes post-close adjustments, reclassifications, or audit adjustments. Supports SOX audit trail requirements.' ;
    rdfs:domain ind:TrialBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:balanceType rdf:type rdf:Property ;
    rdfs:label 'Balance Type' ;
    rdfs:comment 'Classification of the trial balance record indicating whether it represents actual posted transactions, budgeted amounts, forecasted amounts, adjusted balances, restated balances for prior period corrections, or pro forma balances for scenario analysis.' ;
    rdfs:domain ind:TrialBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closingBalanceCredit rdf:type rdf:Property ;
    rdfs:label 'Closing Balance Credit' ;
    rdfs:comment 'Ending credit balance for this GL account at the end of the accounting period. Calculated as opening balance plus period activity. Forms the basis for financial statement preparation.' ;
    rdfs:domain ind:TrialBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:closingBalanceDebit rdf:type rdf:Property ;
    rdfs:label 'Closing Balance Debit' ;
    rdfs:comment 'Ending debit balance for this GL account at the end of the accounting period. Calculated as opening balance plus period activity. Forms the basis for financial statement preparation.' ;
    rdfs:domain ind:TrialBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eliminationFlag rdf:type rdf:Property ;
    rdfs:label 'Elimination Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether this trial balance line has been marked for elimination in the consolidation process. Used to remove intercompany balances and transactions.' ;
    rdfs:domain ind:TrialBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:extractionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Extraction Timestamp' ;
    rdfs:comment 'Timestamp when this trial balance record was extracted from the source system and loaded into the data lakehouse. Supports data lineage and freshness tracking.' ;
    rdfs:domain ind:TrialBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:functionalClosingBalanceCredit rdf:type rdf:Property ;
    rdfs:label 'Functional Closing Balance Credit' ;
    rdfs:comment 'Closing credit balance converted to the functional currency of the legal entity. Used for consolidated financial statements and regulatory reporting.' ;
    rdfs:domain ind:TrialBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:functionalClosingBalanceDebit rdf:type rdf:Property ;
    rdfs:label 'Functional Closing Balance Debit' ;
    rdfs:comment 'Closing debit balance converted to the functional currency of the legal entity. Used for consolidated financial statements and regulatory reporting.' ;
    rdfs:domain ind:TrialBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:functionalOpeningBalanceCredit rdf:type rdf:Property ;
    rdfs:label 'Functional Opening Balance Credit' ;
    rdfs:comment 'Opening credit balance converted to the functional currency of the legal entity using the appropriate exchange rate. Used for consolidation and group reporting.' ;
    rdfs:domain ind:TrialBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:functionalOpeningBalanceDebit rdf:type rdf:Property ;
    rdfs:label 'Functional Opening Balance Debit' ;
    rdfs:comment 'Opening debit balance converted to the functional currency of the legal entity using the appropriate exchange rate. Used for consolidation and group reporting.' ;
    rdfs:domain ind:TrialBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:functionalPeriodCreditActivity rdf:type rdf:Property ;
    rdfs:label 'Functional Period Credit Activity' ;
    rdfs:comment 'Period credit activity converted to the functional currency of the legal entity. Supports multi-currency consolidation and reporting under IFRS/GAAP.' ;
    rdfs:domain ind:TrialBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:functionalPeriodDebitActivity rdf:type rdf:Property ;
    rdfs:label 'Functional Period Debit Activity' ;
    rdfs:comment 'Period debit activity converted to the functional currency of the legal entity. Supports multi-currency consolidation and reporting under IFRS/GAAP.' ;
    rdfs:domain ind:TrialBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:openingBalanceCredit rdf:type rdf:Property ;
    rdfs:label 'Opening Balance Credit' ;
    rdfs:comment 'Credit balance brought forward from the prior accounting period for this GL account. Represents the beginning balance for the current period.' ;
    rdfs:domain ind:TrialBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:openingBalanceDebit rdf:type rdf:Property ;
    rdfs:label 'Opening Balance Debit' ;
    rdfs:comment 'Debit balance brought forward from the prior accounting period for this GL account. Represents the beginning balance for the current period.' ;
    rdfs:domain ind:TrialBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:periodCreditActivity rdf:type rdf:Property ;
    rdfs:label 'Period Credit Activity' ;
    rdfs:comment 'Total credit transactions posted to this GL account during the current accounting period. Includes journal entries from all subledgers and manual adjustments.' ;
    rdfs:domain ind:TrialBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:periodDebitActivity rdf:type rdf:Property ;
    rdfs:label 'Period Debit Activity' ;
    rdfs:comment 'Total debit transactions posted to this GL account during the current accounting period. Includes journal entries from all subledgers and manual adjustments.' ;
    rdfs:domain ind:TrialBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reconciledBy rdf:type rdf:Property ;
    rdfs:label 'Reconciled By' ;
    rdfs:comment 'User ID or name of the individual who performed the account reconciliation. Supports segregation of duties and audit trail requirements under SOX.' ;
    rdfs:domain ind:TrialBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amortizationScheduleId rdf:type rdf:Property ;
    rdfs:label 'Amortization Schedule Id' ;
    rdfs:comment 'Unique identifier for each amortization schedule entry. Primary key for the amortization schedule product.' ;
    rdfs:domain ind:AmortizationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accrualDays rdf:type rdf:Property ;
    rdfs:label 'Accrual Days' ;
    rdfs:comment 'Number of days in the interest accrual period for this installment. Calculated based on the day count convention specified in the loan agreement (e.g., 30/360, Actual/365, Actual/Actual).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualInterestAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Interest Amount' ;
    rdfs:comment 'Actual interest amount applied from the received payment. May differ from scheduled interest due to payment timing, rate changes, or payment allocation rules.' ;
    rdfs:domain ind:AmortizationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Payment Amount' ;
    rdfs:comment 'Actual total amount received for this installment. May differ from scheduled amount due to partial payments, prepayments, or payment shortfalls. Null if no payment has been received.' ;
    rdfs:domain ind:AmortizationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Actual Payment Date' ;
    rdfs:comment 'Actual date on which the payment was received and applied to the loan. Null if payment has not yet been received. Used to calculate days past due and assess payment performance.' ;
    rdfs:domain ind:AmortizationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualPrincipalAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Principal Amount' ;
    rdfs:comment 'Actual principal reduction amount applied from the received payment. May differ from scheduled principal due to payment allocation rules, prepayments, or shortfalls.' ;
    rdfs:domain ind:AmortizationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amortizationType rdf:type rdf:Property ;
    rdfs:label 'Amortization Type' ;
    rdfs:comment 'Type of amortization method used for this schedule. Level payment maintains constant total payments; level principal maintains constant principal payments; bullet has principal due at maturity; balloon has a large final payment; custom follows a non-standard pattern.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beginningBalance rdf:type rdf:Property ;
    rdfs:label 'Beginning Balance' ;
    rdfs:comment 'Outstanding principal balance at the start of this payment period, before the current installment is applied. Represents the loan balance carried forward from the previous period.' ;
    rdfs:domain ind:AmortizationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daysPastDue rdf:type rdf:Property ;
    rdfs:label 'Days Past Due' ;
    rdfs:comment 'Number of days this payment is overdue, calculated as the difference between current date (or actual payment date) and the due date. Zero or null if payment is current or paid on time. Critical metric for delinquency tracking and credit risk assessment.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:endingBalance rdf:type rdf:Property ;
    rdfs:label 'Ending Balance' ;
    rdfs:comment 'Outstanding principal balance remaining after this scheduled payment is applied. Calculated as beginning balance minus scheduled principal amount. Becomes the beginning balance for the next period.' ;
    rdfs:domain ind:AmortizationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:installmentNumber rdf:type rdf:Property ;
    rdfs:label 'Installment Number' ;
    rdfs:comment 'Sequential number of this payment installment within the loan\'s repayment schedule. Starts at 1 for the first payment and increments for each subsequent scheduled payment.' ;
    rdfs:domain ind:AmortizationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isFinalPayment rdf:type rdf:Property ;
    rdfs:label 'Is Final Payment' ;
    rdfs:comment 'Indicates whether this is the final scheduled payment for the loan. True for the last installment that brings the ending balance to zero. Used to identify loan maturity and schedule completion.' ;
    rdfs:domain ind:AmortizationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRestructured rdf:type rdf:Property ;
    rdfs:label 'Is Restructured' ;
    rdfs:comment 'Indicates whether this installment is part of a restructured payment schedule. True if the loan has been modified after origination due to borrower hardship, forbearance, or other restructuring events. Critical for regulatory reporting and credit risk classification.' ;
    rdfs:domain ind:AmortizationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lateFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Late Fee Amount' ;
    rdfs:comment 'Late payment fee assessed for this installment if payment was received after the due date. Calculated according to the loan agreement\'s late fee provisions. Null if payment was on time or no late fee was assessed.' ;
    rdfs:domain ind:AmortizationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prepaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Prepayment Amount' ;
    rdfs:comment 'Additional principal amount paid beyond the scheduled principal for this installment. Represents voluntary prepayments that reduce the outstanding balance faster than scheduled. Null if no prepayment occurred.' ;
    rdfs:domain ind:AmortizationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:restructureDate rdf:type rdf:Property ;
    rdfs:label 'Restructure Date' ;
    rdfs:comment 'Date on which the loan restructuring became effective, if applicable. Null for non-restructured installments. Used to track troubled debt restructuring (TDR) events and assess credit quality.' ;
    rdfs:domain ind:AmortizationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduleGenerationDate rdf:type rdf:Property ;
    rdfs:label 'Schedule Generation Date' ;
    rdfs:comment 'Date on which this version of the amortization schedule was generated or regenerated. Updated whenever the schedule is recalculated due to loan modifications or rate changes.' ;
    rdfs:domain ind:AmortizationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduleVersion rdf:type rdf:Property ;
    rdfs:label 'Schedule Version' ;
    rdfs:comment 'Version number of this amortization schedule. Increments each time the schedule is regenerated due to loan modifications, restructuring, rate resets, or payment plan changes. Version 1 is the original schedule at loan origination.' ;
    rdfs:domain ind:AmortizationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scheduledFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Scheduled Fee Amount' ;
    rdfs:comment 'Any contractually scheduled fees or charges included in this installment, such as servicing fees, insurance premiums, or other recurring charges.' ;
    rdfs:domain ind:AmortizationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduledInterestAmount rdf:type rdf:Property ;
    rdfs:label 'Scheduled Interest Amount' ;
    rdfs:comment 'Contractually scheduled interest charge for this payment period. Calculated based on the beginning balance, interest rate, and accrual period. Represents the cost of borrowing for this period.' ;
    rdfs:domain ind:AmortizationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduledPrincipalAmount rdf:type rdf:Property ;
    rdfs:label 'Scheduled Principal Amount' ;
    rdfs:comment 'Contractually scheduled principal reduction amount for this installment. This portion of the payment reduces the outstanding loan balance.' ;
    rdfs:domain ind:AmortizationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Total Payment Amount' ;
    rdfs:comment 'Total amount due for this installment, calculated as the sum of scheduled principal, interest, and fees. This is the amount the borrower is contractually obligated to pay on the due date.' ;
    rdfs:domain ind:AmortizationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bankGuaranteeId rdf:type rdf:Property ;
    rdfs:label 'Bank Guarantee Id' ;
    rdfs:comment 'Unique identifier for the bank guarantee record. Primary key for the bank guarantee entity.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BankGuarantee .

ind:beneficiaryCounterpartyRatingId rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Counterparty Rating Id' ;
    rdfs:comment 'Foreign key linking to risk.counterparty_rating. Business justification: Bank guarantee issuance requires beneficiary credit assessment to evaluate claim probability. Beneficiary creditworthiness affects guarantee pricing, ECL provisioning, and regulatory capital calculati' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CounterpartyRating .

ind:beneficiaryId rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Id' ;
    rdfs:comment 'Reference to the party in whose favor the bank guarantee is issued. The party entitled to make a claim under the guarantee.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Beneficiary .

ind:issuanceChannelId rdf:type rdf:Property ;
    rdfs:label 'Issuance Channel Id' ;
    rdfs:comment 'Foreign key linking to channel.channel. Business justification: Bank guarantees issued via channels. Essential for contingent liability tracking by channel, trade services performance analytics, and channel capacity planning for guarantee issuance in trade finance' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:issuingOfficerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Issuing Officer Employee Id' ;
    rdfs:comment 'Foreign key linking to hr.employee. Business justification: Bank guarantee issuance requires documented officer approval for URDG 758 compliance, credit risk management, and regulatory capital reporting. Business process: credit approval documentation, claim a' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:autoExtensionFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Extension Flag' ;
    rdfs:comment 'Indicates whether the guarantee contains an automatic extension clause. True if the guarantee automatically extends unless the issuing bank provides notice of non-renewal.' ;
    rdfs:domain ind:BankGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:claimDocumentsReceived rdf:type rdf:Property ;
    rdfs:label 'Claim Documents Received' ;
    rdfs:comment 'Description of documents submitted with the claim (e.g., \'Demand letter, Beneficiary certificate, Invoice copies\'). Null if no claim has been made.' ;
    rdfs:domain ind:BankGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Claim Period Days' ;
    rdfs:comment 'Number of days after expiry date during which claims may still be presented, if specified in the guarantee terms. Null if no extended claim period applies.' ;
    rdfs:domain ind:BankGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:claimReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Claim Receipt Date' ;
    rdfs:comment 'Date on which a claim demand was received from the beneficiary. Null if no claim has been made.' ;
    rdfs:domain ind:BankGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:claimSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Claim Sequence Number' ;
    rdfs:comment 'Sequential number of the claim against this guarantee. Null if no claim has been made. Increments with each new claim (supports multiple claims against a single guarantee).' ;
    rdfs:domain ind:BankGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:claimantIdentity rdf:type rdf:Property ;
    rdfs:label 'Claimant Identity' ;
    rdfs:comment 'Name and identification details of the party presenting the claim. Typically the beneficiary or an authorized representative. Null if no claim has been made.' ;
    rdfs:domain ind:BankGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collateralRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Collateral Required Flag' ;
    rdfs:comment 'Indicates whether the applicant is required to provide collateral to secure the bank\'s exposure under the guarantee. True if collateral is required.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commissionRateBps rdf:type rdf:Property ;
    rdfs:label 'Commission Rate Bps' ;
    rdfs:comment 'Annual commission rate charged on the outstanding guarantee amount, expressed in basis points (1 bps = 0.01%).' ;
    rdfs:domain ind:BankGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:counterGuaranteeingBankBic rdf:type rdf:Property ;
    rdfs:label 'Counter Guaranteeing Bank Bic' ;
    rdfs:comment 'SWIFT BIC of the bank providing a counter-guarantee (guarantee backing another guarantee). Applicable only for counter-guarantee arrangements. Null if not a counter-guarantee.' ;
    rdfs:domain ind:BankGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demandIndicator rdf:type rdf:Property ;
    rdfs:label 'Demand Indicator' ;
    rdfs:comment 'Indicates whether the guarantee is payable on first demand (on-demand) or requires proof of default or other conditions (conditional).' ;
    rdfs:domain ind:BankGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eclProvisionAmount rdf:type rdf:Property ;
    rdfs:label 'Ecl Provision Amount' ;
    rdfs:comment 'Expected credit loss provision amount calculated for this guarantee under IFRS 9 or CECL accounting standards.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:guaranteeAmount rdf:type rdf:Property ;
    rdfs:label 'Guarantee Amount' ;
    rdfs:comment 'Face value amount of the bank guarantee. The maximum amount that can be claimed by the beneficiary under the guarantee terms.' ;
    rdfs:domain ind:BankGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:guaranteeCurrency rdf:type rdf:Property ;
    rdfs:label 'Guarantee Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code in which the guarantee amount is denominated.' ;
    rdfs:domain ind:BankGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guaranteeReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Guarantee Reference Number' ;
    rdfs:comment 'Externally-known unique reference number assigned to the bank guarantee or standby letter of credit. Used for identification in correspondence and SWIFT messaging.' ;
    rdfs:domain ind:BankGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guaranteeStatus rdf:type rdf:Property ;
    rdfs:label 'Guarantee Status' ;
    rdfs:comment 'Current lifecycle status of the bank guarantee: draft (being prepared), issued (sent to beneficiary), active (in force), extended (maturity extended), reduced (amount reduced), claimed (demand received), expired (past expiry date), cancelled (terminated before expiry), or released (obligations fulfilled). [ENUM-REF-CANDIDATE: draft|issued|active|extended|reduced|claimed|expired|cancelled|released — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guaranteeType rdf:type rdf:Property ;
    rdfs:label 'Guarantee Type' ;
    rdfs:comment 'Classification of the guarantee instrument: bid bond (tender guarantee), performance bond, advance payment guarantee, retention money guarantee, financial guarantee, standby letter of credit (LC), or counter-guarantee. [ENUM-REF-CANDIDATE: bid_bond|performance_bond|advance_payment_guarantee|retention_money_guarantee|financial_guarantee|standby_lc|counter_guarantee — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ifrs9Stage rdf:type rdf:Property ;
    rdfs:label 'Ifrs9 Stage' ;
    rdfs:comment 'IFRS 9 impairment stage classification: stage_1 (performing, 12-month ECL), stage_2 (significant increase in credit risk, lifetime ECL), or stage_3 (credit-impaired, lifetime ECL).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuanceFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Issuance Fee Amount' ;
    rdfs:comment 'Fee charged by the issuing bank for issuing the guarantee. Typically a percentage of the guarantee amount.' ;
    rdfs:domain ind:BankGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:issuanceFeeCurrency rdf:type rdf:Property ;
    rdfs:label 'Issuance Fee Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code in which the issuance fee is denominated.' ;
    rdfs:domain ind:BankGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingBankBic rdf:type rdf:Property ;
    rdfs:label 'Issuing Bank Bic' ;
    rdfs:comment 'SWIFT Bank Identifier Code (BIC) of the bank issuing the guarantee. 8 or 11 character ISO 9362 code.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentAmount rdf:type rdf:Property ;
    rdfs:label 'Payment Amount' ;
    rdfs:comment 'Actual amount paid to the beneficiary in settlement of the claim. May differ from claimed amount if partial payment was made. Null if claim was rejected or not yet paid.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentDecision rdf:type rdf:Property ;
    rdfs:label 'Payment Decision' ;
    rdfs:comment 'Bank\'s decision on the claim: honour (pay the claim), reject (refuse payment with reasons), or extend_or_pay (offer extension in lieu of payment). Null if decision not yet made.' ;
    rdfs:domain ind:BankGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reductionSchedule rdf:type rdf:Property ;
    rdfs:label 'Reduction Schedule' ;
    rdfs:comment 'Description of the schedule by which the guarantee amount reduces over time (e.g., \'Reduce by 10% quarterly\', \'Reduce to 50% after 6 months\'). Null if no reduction schedule applies.' ;
    rdfs:domain ind:BankGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Rejection Notification Date' ;
    rdfs:comment 'Date on which the beneficiary was notified of the claim rejection. Must be within the timeline specified in URDG 758. Null if claim was honoured or not yet decided.' ;
    rdfs:domain ind:BankGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:residualGuaranteeBalance rdf:type rdf:Property ;
    rdfs:label 'Residual Guarantee Balance' ;
    rdfs:comment 'Remaining guarantee amount available after claim payment or reduction. Equals original guarantee amount minus cumulative payments and reductions.' ;
    rdfs:domain ind:BankGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:riskWeightPercent rdf:type rdf:Property ;
    rdfs:label 'Risk Weight Percent' ;
    rdfs:comment 'Risk weight percentage applied to the guarantee exposure for regulatory capital calculation under Basel III framework.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:underlyingContractReference rdf:type rdf:Property ;
    rdfs:label 'Underlying Contract Reference' ;
    rdfs:comment 'Reference number or description of the underlying commercial contract or transaction that the guarantee secures (e.g., construction contract, supply agreement).' ;
    rdfs:domain ind:BankGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:urdgComplianceAssessment rdf:type rdf:Property ;
    rdfs:label 'Urdg Compliance Assessment' ;
    rdfs:comment 'Assessment result of whether the claim complies with URDG 758 Article 20 requirements (complying presentation). Null if no claim has been made.' ;
    rdfs:domain ind:BankGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billOfLadingId rdf:type rdf:Property ;
    rdfs:label 'Bill Of Lading Id' ;
    rdfs:comment 'Unique identifier for the bill of lading record. Primary key.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:documentaryCollectionId rdf:type rdf:Property ;
    rdfs:label 'Documentary Collection Id' ;
    rdfs:comment 'Foreign key linking to loan.documentary_collection. Business justification: Bills of Lading are also used in Documentary Collections (D/P and D/A) under URC 522. The B/L is a key document in the collection set. One B/L belongs to one documentary collection (1:N from documenta' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DocumentaryCollection .

ind:forfaitingId rdf:type rdf:Property ;
    rdfs:label 'Forfaiting Id' ;
    rdfs:comment 'Foreign key linking to loan.forfaiting. Business justification: Bills of Lading can be part of the underlying documentation for forfaiting transactions where the bank purchases trade receivables. The B/L evidences the shipment of goods underlying the receivable. O' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Forfaiting .

ind:freightCurrencyId rdf:type rdf:Property ;
    rdfs:label 'Freight Currency Id' ;
    rdfs:comment 'Foreign key linking to reference.currency. Business justification: Bills of lading with freight charges in currencies require currency metadata (rounding, minor unit) for freight cost calculation, document examination (LC compliance), and accounting (trade finance co' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:tradeFinanceTransactionId rdf:type rdf:Property ;
    rdfs:label 'Trade Finance Transaction Id' ;
    rdfs:comment 'Reference to the parent trade finance transaction (letter of credit, documentary collection, or bank guarantee) that this bill of lading supports.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TradeFinanceTransaction .

ind:blNumber rdf:type rdf:Property ;
    rdfs:label 'Bl Number' ;
    rdfs:comment 'Unique externally-known bill of lading reference number issued by the carrier. Primary business identifier for the transport document.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blStatus rdf:type rdf:Property ;
    rdfs:label 'Bl Status' ;
    rdfs:comment 'Current lifecycle status of the bill of lading in the trade finance workflow.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blType rdf:type rdf:Property ;
    rdfs:label 'Bl Type' ;
    rdfs:comment 'Classification of the bill of lading document type. Determines negotiability and title transfer characteristics. [ENUM-REF-CANDIDATE: straight|order|bearer|sea_waybill|multimodal|house|master|charter_party — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierScacCode rdf:type rdf:Property ;
    rdfs:label 'Carrier Scac Code' ;
    rdfs:comment 'Four-letter unique identifier assigned to transportation companies by the National Motor Freight Traffic Association (NMFTA).' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clausesRemarks rdf:type rdf:Property ;
    rdfs:label 'Clauses Remarks' ;
    rdfs:comment 'Any clauses, notations, or remarks added by the carrier regarding the condition of goods, packaging, or special handling instructions.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cleanBlFlag rdf:type rdf:Property ;
    rdfs:label 'Clean Bl Flag' ;
    rdfs:comment 'Indicates whether the bill of lading is clean (no clauses noting defects or damage to goods or packaging). True = clean, False = claused/foul.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:collateralFlag rdf:type rdf:Property ;
    rdfs:label 'Collateral Flag' ;
    rdfs:comment 'Indicates whether this bill of lading is pledged as collateral for a trade finance facility. True = pledged as collateral.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:collateralValueAmount rdf:type rdf:Property ;
    rdfs:label 'Collateral Value Amount' ;
    rdfs:comment 'Assessed value of the goods represented by this bill of lading for collateral management purposes.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collateralValueCurrency rdf:type rdf:Property ;
    rdfs:label 'Collateral Value Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the collateral value amount.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consigneeAddress rdf:type rdf:Property ;
    rdfs:label 'Consignee Address' ;
    rdfs:comment 'Complete address of the consignee including street, city, state/province, postal code, and country.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consigneeName rdf:type rdf:Property ;
    rdfs:label 'Consignee Name' ;
    rdfs:comment 'Full legal name of the party to whom the goods are consigned (importer/receiver). For order B/Ls, may be \'To Order\' or \'To Order of [Bank Name]\'.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerNumbers rdf:type rdf:Property ;
    rdfs:label 'Container Numbers' ;
    rdfs:comment 'Comma-separated list of container identification numbers (ISO 6346 format) used for this shipment.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endorsementChain rdf:type rdf:Property ;
    rdfs:label 'Endorsement Chain' ;
    rdfs:comment 'Chronological record of all endorsements made on the bill of lading for order B/Ls. Critical for tracking title transfer and collateral perfection.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightAmount rdf:type rdf:Property ;
    rdfs:label 'Freight Amount' ;
    rdfs:comment 'Total freight charges for the shipment.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightCurrency rdf:type rdf:Property ;
    rdfs:label 'Freight Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for freight charges.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightTerms rdf:type rdf:Property ;
    rdfs:label 'Freight Terms' ;
    rdfs:comment 'Payment terms for freight charges. Prepaid means shipper pays; collect means consignee pays at destination.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsDescription rdf:type rdf:Property ;
    rdfs:label 'Goods Description' ;
    rdfs:comment 'Detailed description of the goods being shipped including commodity type, quantity, and specifications. Must match letter of credit terms.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossWeight rdf:type rdf:Property ;
    rdfs:label 'Gross Weight' ;
    rdfs:comment 'Total weight of the shipment including packaging and containers.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hsCode rdf:type rdf:Property ;
    rdfs:label 'Hs Code' ;
    rdfs:comment 'International standardized system of names and numbers to classify traded products for customs and tariff purposes.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notifyPartyAddress rdf:type rdf:Property ;
    rdfs:label 'Notify Party Address' ;
    rdfs:comment 'Complete address of the notify party including street, city, state/province, postal code, and country.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notifyPartyName rdf:type rdf:Property ;
    rdfs:label 'Notify Party Name' ;
    rdfs:comment 'Full legal name of the party to be notified upon arrival of goods at destination port. Often the importer or customs broker.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberOfPackages rdf:type rdf:Property ;
    rdfs:label 'Number Of Packages' ;
    rdfs:comment 'Total count of packages, cartons, pallets, or other shipping units in the shipment.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:onBoardDate rdf:type rdf:Property ;
    rdfs:label 'On Board Date' ;
    rdfs:comment 'Date when goods were loaded on board the vessel. Critical for letter of credit compliance and title transfer timing.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originalBlCount rdf:type rdf:Property ;
    rdfs:label 'Original Bl Count' ;
    rdfs:comment 'Number of original signed bill of lading copies issued. Typically 3 originals are issued; surrender of one original releases the goods.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:packageType rdf:type rdf:Property ;
    rdfs:label 'Package Type' ;
    rdfs:comment 'Type of packaging used for the goods (e.g., cartons, pallets, drums, containers, bags).' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:placeOfDelivery rdf:type rdf:Property ;
    rdfs:label 'Place Of Delivery' ;
    rdfs:comment 'Final destination location where the carrier delivers the goods to the consignee. Relevant for multimodal transport.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:placeOfReceipt rdf:type rdf:Property ;
    rdfs:label 'Place Of Receipt' ;
    rdfs:comment 'Location where the carrier takes custody of the goods from the shipper. Relevant for multimodal transport.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portOfDischargeCode rdf:type rdf:Property ;
    rdfs:label 'Port Of Discharge Code' ;
    rdfs:comment 'Five-letter UN/LOCODE identifying the port where goods are unloaded from the vessel.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portOfDischargeName rdf:type rdf:Property ;
    rdfs:label 'Port Of Discharge Name' ;
    rdfs:comment 'Full name of the port where goods are unloaded from the vessel.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portOfLoadingCode rdf:type rdf:Property ;
    rdfs:label 'Port Of Loading Code' ;
    rdfs:comment 'Five-letter UN/LOCODE identifying the port where goods are loaded onto the vessel.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portOfLoadingName rdf:type rdf:Property ;
    rdfs:label 'Port Of Loading Name' ;
    rdfs:comment 'Full name of the port where goods are loaded onto the vessel.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipperAddress rdf:type rdf:Property ;
    rdfs:label 'Shipper Address' ;
    rdfs:comment 'Complete address of the shipper including street, city, state/province, postal code, and country.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipperName rdf:type rdf:Property ;
    rdfs:label 'Shipper Name' ;
    rdfs:comment 'Full legal name of the party shipping the goods (exporter/consignor). The party from whom the goods originate.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surrenderedDate rdf:type rdf:Property ;
    rdfs:label 'Surrendered Date' ;
    rdfs:comment 'Date when the original bill of lading was surrendered to the carrier for release of goods.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:vesselName rdf:type rdf:Property ;
    rdfs:label 'Vessel Name' ;
    rdfs:comment 'Name of the ocean vessel, aircraft, or other transport vehicle carrying the goods.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volume rdf:type rdf:Property ;
    rdfs:label 'Volume' ;
    rdfs:comment 'Total volume or cubic measurement of the shipment.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeUnit rdf:type rdf:Property ;
    rdfs:label 'Volume Unit' ;
    rdfs:comment 'Unit of measurement for volume (cubic meters, cubic feet, or liters).' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:voyageNumber rdf:type rdf:Property ;
    rdfs:label 'Voyage Number' ;
    rdfs:comment 'Unique identifier for the specific voyage or flight number of the transport vehicle.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightUnit rdf:type rdf:Property ;
    rdfs:label 'Weight Unit' ;
    rdfs:comment 'Unit of measurement for the gross weight (kilograms, pounds, metric tons, or tons).' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collateralLinkId rdf:type rdf:Property ;
    rdfs:label 'Collateral Link Id' ;
    rdfs:comment 'Unique identifier for the collateral link record. Primary key for the association between a loan facility and pledged collateral asset.' ;
    rdfs:domain ind:CollateralLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:securityInstrumentId rdf:type rdf:Property ;
    rdfs:label 'Security Instrument Id' ;
    rdfs:comment 'Foreign key linking to security.instrument. Business justification: Collateral_link already has collateral_asset_id (physical/real assets). Securities pledged as collateral require separate instrument reference for market-based valuation, haircut application, and marg' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Instrument .

ind:crossCollateralizationFlag rdf:type rdf:Property ;
    rdfs:label 'Cross Collateralization Flag' ;
    rdfs:comment 'Indicates whether this collateral secures multiple loan facilities under a cross-collateralization agreement. True means the collateral is pledged to secure more than one loan obligation.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crossDefaultFlag rdf:type rdf:Property ;
    rdfs:label 'Cross Default Flag' ;
    rdfs:comment 'Indicates whether a default on this loan triggers default provisions on other loans secured by the same collateral. True means cross-default provisions are in effect.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currentCollateralValueAmount rdf:type rdf:Property ;
    rdfs:label 'Current Collateral Value Amount' ;
    rdfs:comment 'The most recent market or appraised value of the pledged collateral. Updated periodically based on revaluation frequency requirements and market conditions.' ;
    rdfs:domain ind:CollateralLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentLtvRatio rdf:type rdf:Property ;
    rdfs:label 'Current Ltv Ratio' ;
    rdfs:comment 'The current ratio of the outstanding loan balance to the current collateral value. Expressed as a decimal. Monitored for covenant compliance and risk management. Rising LTV indicates deteriorating collateral coverage.' ;
    rdfs:domain ind:CollateralLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentValueAsOfDate rdf:type rdf:Property ;
    rdfs:label 'Current Value As Of Date' ;
    rdfs:comment 'The date on which the current collateral value was determined. Indicates the valuation date for the most recent appraisal or market assessment.' ;
    rdfs:domain ind:CollateralLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eligibleCollateralValueAmount rdf:type rdf:Property ;
    rdfs:label 'Eligible Collateral Value Amount' ;
    rdfs:comment 'The collateral value after applying regulatory haircuts and eligibility criteria. Used for Risk-Weighted Assets (RWA) calculation and regulatory capital reporting under Basel III.' ;
    rdfs:domain ind:CollateralLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Insurance Expiration Date' ;
    rdfs:comment 'The date on which the collateral insurance policy expires. Monitored to ensure continuous coverage and covenant compliance.' ;
    rdfs:domain ind:CollateralLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:insurancePolicyNumber rdf:type rdf:Property ;
    rdfs:label 'Insurance Policy Number' ;
    rdfs:comment 'The policy number for the insurance coverage on the pledged collateral. Used to verify insurance compliance and file claims in the event of loss or damage.' ;
    rdfs:domain ind:CollateralLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Insurance Required Flag' ;
    rdfs:comment 'Indicates whether the loan agreement requires the borrower to maintain insurance coverage on the pledged collateral. True means insurance is mandatory to protect the lenders security interest.' ;
    rdfs:domain ind:CollateralLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastRevaluationDate rdf:type rdf:Property ;
    rdfs:label 'Last Revaluation Date' ;
    rdfs:comment 'The date of the most recent collateral revaluation. Used to monitor compliance with revaluation frequency requirements and identify stale valuations.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lenderLossPayeeFlag rdf:type rdf:Property ;
    rdfs:label 'Lender Loss Payee Flag' ;
    rdfs:comment 'Indicates whether the lender is named as loss payee on the collateral insurance policy. True means insurance proceeds will be paid to the lender to protect the security interest.' ;
    rdfs:domain ind:CollateralLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:linkEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Link Effective Date' ;
    rdfs:comment 'The date on which the collateral was pledged to secure the loan. Marks the beginning of the collateral relationship and the start of lien priority.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:linkReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Link Reference Number' ;
    rdfs:comment 'Business-facing reference number for the collateral link relationship. Used in loan documentation and collateral agreements.' ;
    rdfs:domain ind:CollateralLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkTerminationDate rdf:type rdf:Property ;
    rdfs:label 'Link Termination Date' ;
    rdfs:comment 'The date on which the collateral lien was released or the collateral relationship ended. Occurs upon loan payoff, collateral substitution, or lien release.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ltvRatioAtOrigination rdf:type rdf:Property ;
    rdfs:label 'Ltv Ratio At Origination' ;
    rdfs:comment 'The ratio of the loan amount to the pledged collateral value at the time of loan origination. Expressed as a decimal (e.g., 0.8000 represents 80%). Key credit risk metric used in underwriting decisions.' ;
    rdfs:domain ind:CollateralLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marginCallThresholdPercentage rdf:type rdf:Property ;
    rdfs:label 'Margin Call Threshold Percentage' ;
    rdfs:comment 'The Loan-to-Value (LTV) ratio threshold that triggers a margin call requiring the borrower to pledge additional collateral or pay down the loan. Expressed as a decimal (e.g., 0.8500 represents 85% LTV threshold).' ;
    rdfs:domain ind:CollateralLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextRevaluationDate rdf:type rdf:Property ;
    rdfs:label 'Next Revaluation Date' ;
    rdfs:comment 'The date on which the next collateral revaluation is scheduled or required. Used for operational planning and compliance monitoring.' ;
    rdfs:domain ind:CollateralLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:perfectionJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Perfection Jurisdiction' ;
    rdfs:comment 'Three-letter ISO country code indicating the jurisdiction where the security interest was perfected. Determines applicable legal framework and enforcement procedures.' ;
    rdfs:domain ind:CollateralLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pledgedValueAmount rdf:type rdf:Property ;
    rdfs:label 'Pledged Value Amount' ;
    rdfs:comment 'The monetary value of the collateral pledged at the time of loan origination. Represents the initial collateral valuation used for underwriting and Loan-to-Value (LTV) calculation.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pledgedValueCurrency rdf:type rdf:Property ;
    rdfs:label 'Pledged Value Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the pledged value amount. Indicates the currency in which the collateral was valued at origination.' ;
    rdfs:domain ind:CollateralLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revaluationFrequency rdf:type rdf:Property ;
    rdfs:label 'Revaluation Frequency' ;
    rdfs:comment 'The required frequency for revaluing the pledged collateral. Determined by loan agreement terms, collateral type, and regulatory requirements. Event-driven revaluations occur upon material changes.' ;
    rdfs:domain ind:CollateralLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uccExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Ucc Expiration Date' ;
    rdfs:comment 'The date on which the UCC-1 financing statement expires. Typically five years from filing date. Requires continuation statement to maintain perfection beyond expiration.' ;
    rdfs:domain ind:CollateralLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:uccFilingNumber rdf:type rdf:Property ;
    rdfs:label 'Ucc Filing Number' ;
    rdfs:comment 'The official filing number assigned by the Secretary of State or other filing office for the UCC-1 financing statement. Used to search and verify the perfected security interest.' ;
    rdfs:domain ind:CollateralLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceCheckId rdf:type rdf:Property ;
    rdfs:label 'Compliance Check Id' ;
    rdfs:comment 'Primary key for compliance_check' ;
    rdfs:domain ind:ComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:documentPresentationId rdf:type rdf:Property ;
    rdfs:label 'Document Presentation Id' ;
    rdfs:comment 'Reference to the specific document presentation event that triggered this compliance examination.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DocumentPresentation .

ind:advisingBankBic rdf:type rdf:Property ;
    rdfs:label 'Advising Bank Bic' ;
    rdfs:comment 'SWIFT Bank Identifier Code (BIC) of the advising or confirming bank that is examining the documents on behalf of the issuing bank.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicantName rdf:type rdf:Property ;
    rdfs:label 'Applicant Name' ;
    rdfs:comment 'Name of the applicant (importer or buyer) who requested the issuance of the letter of credit or guarantee.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceResult rdf:type rdf:Property ;
    rdfs:label 'Compliance Result' ;
    rdfs:comment 'Overall outcome of the compliance examination: compliant (documents conform to terms and conditions), discrepant (one or more discrepancies identified), conditional (compliant subject to issuer waiver), pending_review (examination incomplete), waived (discrepancies waived by applicant or issuing bank).' ;
    rdfs:domain ind:ComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditCurrency rdf:type rdf:Property ;
    rdfs:label 'Credit Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code of the underlying trade finance instrument (e.g., USD, EUR, GBP, JPY).' ;
    rdfs:domain ind:ComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discrepancyCodes rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Codes' ;
    rdfs:comment 'Comma-separated list of standardized discrepancy codes identified during examination (e.g., D01 for late presentation, D02 for document inconsistency, D03 for missing document, D04 for expired credit). Codes align with ICC ISBP 745 and internal trade finance standards.' ;
    rdfs:domain ind:ComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discrepancyCount rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Count' ;
    rdfs:comment 'Total number of discrepancies identified during the examination. Zero indicates compliant presentation.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:discrepancyDescriptions rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Descriptions' ;
    rdfs:comment 'Detailed narrative descriptions of each discrepancy identified, providing business context for the compliance failure. Multiple discrepancies are separated by semicolons.' ;
    rdfs:domain ind:ComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentCount rdf:type rdf:Property ;
    rdfs:label 'Document Count' ;
    rdfs:comment 'Total number of individual documents included in the presentation being examined.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:examinationCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Examination Completion Date' ;
    rdfs:comment 'Date on which the compliance examination was finalized and the result communicated to the presenting bank or beneficiary.' ;
    rdfs:domain ind:ComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:examinationDate rdf:type rdf:Property ;
    rdfs:label 'Examination Date' ;
    rdfs:comment 'The calendar date on which the compliance examination was performed.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:examinationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Examination Timestamp' ;
    rdfs:comment 'Precise date and time when the compliance examination was initiated, used for turnaround time calculation against the 5-banking-day UCP 600 standard.' ;
    rdfs:domain ind:ComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:examinationTurnaroundBankingDays rdf:type rdf:Property ;
    rdfs:label 'Examination Turnaround Banking Days' ;
    rdfs:comment 'Total elapsed time in banking days from document presentation receipt to examination completion. UCP 600 Article 14(b) mandates a maximum of 5 banking days for examination.' ;
    rdfs:domain ind:ComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:examinationTurnaroundHours rdf:type rdf:Property ;
    rdfs:label 'Examination Turnaround Hours' ;
    rdfs:comment 'Total elapsed time in hours from document presentation receipt to examination completion, measured against the UCP 600 5-banking-day standard (maximum 120 banking hours).' ;
    rdfs:domain ind:ComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:examinerName rdf:type rdf:Property ;
    rdfs:label 'Examiner Name' ;
    rdfs:comment 'Full name of the examiner who conducted the compliance check, for audit trail and accountability purposes.' ;
    rdfs:domain ind:ComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:examinerNotes rdf:type rdf:Property ;
    rdfs:label 'Examiner Notes' ;
    rdfs:comment 'Free-text notes and observations recorded by the examiner during the compliance check, providing additional context for audit and quality review.' ;
    rdfs:domain ind:ComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:presentationReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Presentation Receipt Date' ;
    rdfs:comment 'Date on which the document presentation was received by the examining bank, marking the start of the 5-banking-day examination period.' ;
    rdfs:domain ind:ComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ruleSetFramework rdf:type rdf:Property ;
    rdfs:label 'Rule Set Framework' ;
    rdfs:comment 'The International Chamber of Commerce (ICC) rule set framework applied for this examination (UCP 600 for documentary credits, eUCP v2.0 for electronic presentation, ISBP 745 for standard banking practice, URDG 758 for demand guarantees, URC 522 for collections, ISP98 for standby letters of credit, URR 725 for bank-to-bank reimbursements).' ;
    rdfs:domain ind:ComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleSetVersion rdf:type rdf:Property ;
    rdfs:label 'Rule Set Version' ;
    rdfs:comment 'Specific version identifier of the ICC rule set applied (e.g., UCP 600 2007 Revision, eUCP Version 2.0, URDG 758 2010 Revision), ensuring compliance examination is performed against the correct regulatory version.' ;
    rdfs:domain ind:ComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Waiver Approval Status' ;
    rdfs:comment 'Current status of the waiver request: pending (awaiting response), approved (applicant/issuer accepted discrepancies), rejected (applicant/issuer refused waiver), expired (no response within allowed timeframe), not_applicable (no waiver requested).' ;
    rdfs:domain ind:ComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverRequestDate rdf:type rdf:Property ;
    rdfs:label 'Waiver Request Date' ;
    rdfs:comment 'Date on which the waiver request was sent to the applicant or issuing bank for discrepancy acceptance.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:waiverRequestFlag rdf:type rdf:Property ;
    rdfs:label 'Waiver Request Flag' ;
    rdfs:comment 'Indicates whether a waiver request was submitted to the applicant or issuing bank to accept the discrepant presentation despite identified discrepancies.' ;
    rdfs:domain ind:ComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:covenantId rdf:type rdf:Property ;
    rdfs:label 'Covenant Id' ;
    rdfs:comment 'Unique identifier for the covenant record. Primary key.' ;
    rdfs:domain ind:Covenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:packageId rdf:type rdf:Property ;
    rdfs:label 'Package Id' ;
    rdfs:comment 'Identifier linking this covenant to a standard covenant package or template used across multiple facilities, enabling consistent covenant management and benchmarking.' ;
    rdfs:domain ind:Covenant ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CovenantPackage .

ind:breachConsequence rdf:type rdf:Property ;
    rdfs:label 'Breach Consequence' ;
    rdfs:comment 'Description of the consequences if the covenant is breached, such as event of default, increased interest rate, mandatory prepayment, or requirement for additional collateral.' ;
    rdfs:domain ind:Covenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:covenantCategory rdf:type rdf:Property ;
    rdfs:label 'Covenant Category' ;
    rdfs:comment 'Detailed sub-classification of the covenant within its type, such as leverage ratio, interest coverage, debt service coverage, capital expenditure limit, dividend restriction, or asset sale restriction.' ;
    rdfs:domain ind:Covenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:covenantDescription rdf:type rdf:Property ;
    rdfs:label 'Covenant Description' ;
    rdfs:comment 'Detailed textual description of the covenant terms, conditions, and requirements as documented in the credit agreement.' ;
    rdfs:domain ind:Covenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:covenantName rdf:type rdf:Property ;
    rdfs:label 'Covenant Name' ;
    rdfs:comment 'Human-readable name or title of the covenant as stated in the credit agreement documentation.' ;
    rdfs:domain ind:Covenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:covenantStatus rdf:type rdf:Property ;
    rdfs:label 'Covenant Status' ;
    rdfs:comment 'Current lifecycle status of the covenant indicating whether it is actively monitored, temporarily suspended, waived, terminated, in breach, or breach has been cured.' ;
    rdfs:domain ind:Covenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:covenantType rdf:type rdf:Property ;
    rdfs:label 'Covenant Type' ;
    rdfs:comment 'Classification of the covenant based on its nature: financial (ratio-based), affirmative (actions required), negative (restrictions), reporting (disclosure obligations), or information (notification requirements).' ;
    rdfs:domain ind:Covenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cureMechanism rdf:type rdf:Property ;
    rdfs:label 'Cure Mechanism' ;
    rdfs:comment 'Description of the permitted cure mechanism, such as equity contribution, asset sale proceeds application, or other remediation methods allowed under the credit agreement.' ;
    rdfs:domain ind:Covenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cureProvisionFlag rdf:type rdf:Property ;
    rdfs:label 'Cure Provision Flag' ;
    rdfs:comment 'Indicates whether the credit agreement includes a cure provision allowing the borrower to remedy a covenant breach through equity injection or other specified actions.' ;
    rdfs:domain ind:Covenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataClassification rdf:type rdf:Property ;
    rdfs:label 'Data Classification' ;
    rdfs:comment 'Classification level of this covenant record based on sensitivity, typically confidential due to commercial lending terms and borrower financial information.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialStatementSource rdf:type rdf:Property ;
    rdfs:label 'Financial Statement Source' ;
    rdfs:comment 'Type of financial statements required for covenant testing, such as audited annual statements, unaudited quarterly statements, management-certified financials, or regulatory filings.' ;
    rdfs:domain ind:Covenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialityClassification rdf:type rdf:Property ;
    rdfs:label 'Materiality Classification' ;
    rdfs:comment 'Risk-based classification of the covenants importance to credit risk management, with critical covenants triggering immediate escalation upon breach.' ;
    rdfs:domain ind:Covenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementBasis rdf:type rdf:Property ;
    rdfs:label 'Measurement Basis' ;
    rdfs:comment 'Accounting or calculation methodology used to measure covenant compliance, including definitions of terms like EBITDA, net debt, or tangible net worth as specified in the credit agreement.' ;
    rdfs:domain ind:Covenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementFrequency rdf:type rdf:Property ;
    rdfs:label 'Measurement Frequency' ;
    rdfs:comment 'Frequency at which covenant compliance must be tested and reported, such as quarterly for financial covenants or event-driven for negative covenants.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingDeadlineDays rdf:type rdf:Property ;
    rdfs:label 'Reporting Deadline Days' ;
    rdfs:comment 'Number of days after the measurement period end by which the borrower must report covenant compliance results to the lender, typically 30-45 days for quarterly financial covenants.' ;
    rdfs:domain ind:Covenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responsibleParty rdf:type rdf:Property ;
    rdfs:label 'Responsible Party' ;
    rdfs:comment 'Entity responsible for maintaining compliance with this covenant, which may be the borrower, a guarantor, parent company, or specific subsidiary.' ;
    rdfs:domain ind:Covenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testingLevel rdf:type rdf:Property ;
    rdfs:label 'Testing Level' ;
    rdfs:comment 'Organizational level at which covenant compliance is measured, such as consolidated group, standalone borrower, guarantor group, or restricted subsidiary group.' ;
    rdfs:domain ind:Covenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Waiver Effective Date' ;
    rdfs:comment 'Date from which the covenant waiver becomes effective. Null if no waiver has been granted.' ;
    rdfs:domain ind:Covenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:waiverExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Waiver Expiration Date' ;
    rdfs:comment 'Date on which the covenant waiver expires and normal compliance obligations resume. Null for permanent waivers or if no waiver has been granted.' ;
    rdfs:domain ind:Covenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditApplicationId rdf:type rdf:Property ;
    rdfs:label 'Credit Application Id' ;
    rdfs:comment 'Unique identifier for the credit application record. Primary key for the credit application entity.' ;
    rdfs:domain ind:CreditApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:collateralInstrumentId rdf:type rdf:Property ;
    rdfs:label 'Collateral Instrument Id' ;
    rdfs:comment 'Foreign key linking to security.instrument. Business justification: Credit applications offering securities as collateral (bonds, equities, portfolios) require instrument identification for underwriting, valuation, and eligibility assessment. Standard input for securi' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Instrument .

ind:collateralManagedPortfolioId rdf:type rdf:Property ;
    rdfs:label 'Collateral Managed Portfolio Id' ;
    rdfs:comment 'Foreign key linking to wealth.managed_portfolio. Business justification: High-net-worth credit applications reference managed portfolios for collateral evaluation and income verification. Underwriting process pulls portfolio statements to assess liquid net worth, verify in' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ManagedPortfolio .

ind:primaryCreditPartyId rdf:type rdf:Property ;
    rdfs:label 'Primary Credit Party Id' ;
    rdfs:comment 'Reference to the primary applicant (customer or corporate entity) submitting the credit application.' ;
    rdfs:domain ind:CreditApplication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:suitabilityAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Suitability Assessment Id' ;
    rdfs:comment 'Foreign key linking to wealth.suitability_assessment. Business justification: Private banking credit underwriting references existing suitability assessments to verify client financial profile, risk tolerance, net worth, and debt service capacity. Regulatory requirement for res' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SuitabilityAssessment .

ind:annualRevenue rdf:type rdf:Property ;
    rdfs:label 'Annual Revenue' ;
    rdfs:comment 'Applicant\'s reported annual revenue from the most recent financial statements, used for debt service coverage and creditworthiness assessment.' ;
    rdfs:domain ind:CreditApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:applicationChannel rdf:type rdf:Property ;
    rdfs:label 'Application Channel' ;
    rdfs:comment 'Channel through which the credit application was submitted: branch, online portal, mobile app, phone, broker, or direct sales team.' ;
    rdfs:domain ind:CreditApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationNumber rdf:type rdf:Property ;
    rdfs:label 'Application Number' ;
    rdfs:comment 'Externally-visible unique business identifier for the credit application, used in customer communications and regulatory reporting.' ;
    rdfs:domain ind:CreditApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationSubmittedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Application Submitted Timestamp' ;
    rdfs:comment 'Date and time when the credit application was formally submitted by the applicant or on behalf of the applicant.' ;
    rdfs:domain ind:CreditApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:approvedAmount rdf:type rdf:Property ;
    rdfs:label 'Approved Amount' ;
    rdfs:comment 'Principal amount of credit approved by underwriting, which may differ from the requested amount. Nullable for declined or pending applications.' ;
    rdfs:domain ind:CreditApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedInterestRate rdf:type rdf:Property ;
    rdfs:label 'Approved Interest Rate' ;
    rdfs:comment 'Annual interest rate approved for the credit facility, expressed as a decimal (e.g., 0.0575 for 5.75%). Nullable for declined or pending applications.' ;
    rdfs:domain ind:CreditApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedTermMonths rdf:type rdf:Property ;
    rdfs:label 'Approved Term Months' ;
    rdfs:comment 'Duration of the approved credit facility in months, which may differ from the requested term. Nullable for declined or pending applications.' ;
    rdfs:domain ind:CreditApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:collateralOffered rdf:type rdf:Property ;
    rdfs:label 'Collateral Offered' ;
    rdfs:comment 'Indicates whether the application includes collateral: fully secured, unsecured, or partially secured.' ;
    rdfs:domain ind:CreditApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionsPrecedent rdf:type rdf:Property ;
    rdfs:label 'Conditions Precedent' ;
    rdfs:comment 'List of conditions that must be satisfied before loan disbursement, such as additional documentation, insurance requirements, or legal opinions. Nullable for declined applications.' ;
    rdfs:domain ind:CreditApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditCommitteeApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Credit Committee Approval Date' ;
    rdfs:comment 'Date when the credit committee formally approved the application, if committee approval was required. Nullable for applications within analyst authority or declined applications.' ;
    rdfs:domain ind:CreditApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:declineReason rdf:type rdf:Property ;
    rdfs:label 'Decline Reason' ;
    rdfs:comment 'Detailed explanation for declined applications, including specific credit policy violations, insufficient collateral, adverse credit history, or regulatory restrictions. Nullable for approved applications.' ;
    rdfs:domain ind:CreditApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dscr rdf:type rdf:Property ;
    rdfs:label 'Dscr' ;
    rdfs:comment 'Debt Service Coverage Ratio calculated as net operating income divided by total debt service obligations, indicating the applicant\'s ability to service debt.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financialStatementDate rdf:type rdf:Property ;
    rdfs:label 'Financial Statement Date' ;
    rdfs:comment 'Date of the most recent financial statements submitted by the applicant as part of the credit application package.' ;
    rdfs:domain ind:CreditApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:kycCompleted rdf:type rdf:Property ;
    rdfs:label 'Kyc Completed' ;
    rdfs:comment 'Indicates whether Know Your Customer due diligence has been completed for the applicant, required for regulatory compliance.' ;
    rdfs:domain ind:CreditApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loanPurpose rdf:type rdf:Property ;
    rdfs:label 'Loan Purpose' ;
    rdfs:comment 'Detailed description of the intended use of borrowed funds, such as working capital, capital expenditure, acquisition, real estate purchase, debt consolidation, or trade finance.' ;
    rdfs:domain ind:CreditApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pipelineStage rdf:type rdf:Property ;
    rdfs:label 'Pipeline Stage' ;
    rdfs:comment 'Current stage of the application in the credit origination pipeline, used for funnel analytics and conversion tracking. [ENUM-REF-CANDIDATE: prospect|application|underwriting|approval|documentation|closing|funded|declined — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CreditApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedCurrency rdf:type rdf:Property ;
    rdfs:label 'Requested Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the requested credit amount.' ;
    rdfs:domain ind:CreditApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedTermMonths rdf:type rdf:Property ;
    rdfs:label 'Requested Term Months' ;
    rdfs:comment 'Duration of the requested credit facility expressed in months. Nullable for revolving facilities without fixed maturity.' ;
    rdfs:domain ind:CreditApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalAssets rdf:type rdf:Property ;
    rdfs:label 'Total Assets' ;
    rdfs:comment 'Applicant\'s total assets as reported in the most recent financial statements, used for balance sheet strength assessment.' ;
    rdfs:domain ind:CreditApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:underwritingDecision rdf:type rdf:Property ;
    rdfs:label 'Underwriting Decision' ;
    rdfs:comment 'Final underwriting decision rendered by the credit analyst or credit committee: approved, declined, referred to senior committee, conditional approval pending additional requirements, or withdrawn by applicant.' ;
    rdfs:domain ind:CreditApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditReviewId rdf:type rdf:Property ;
    rdfs:label 'Credit Review Id' ;
    rdfs:comment 'Unique identifier for the credit review record. Primary key for the credit review entity.' ;
    rdfs:domain ind:CreditReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:collateralInvestorAccountId rdf:type rdf:Property ;
    rdfs:label 'Collateral Investor Account Id' ;
    rdfs:comment 'Foreign key linking to asset.investor_account. Business justification: Ongoing credit monitoring: when loans are collateralized by fund holdings, periodic credit reviews assess the investor_account\'s current NAV, concentration risk, and liquidity. This link supports coll' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InvestorAccount .

ind:collateralRevaluationFlag rdf:type rdf:Property ;
    rdfs:label 'Collateral Revaluation Flag' ;
    rdfs:comment 'Indicates whether collateral supporting the facility was revalued as part of this credit review. True if revaluation was performed; false if existing valuations were deemed current.' ;
    rdfs:domain ind:CreditReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:covenantComplianceSummary rdf:type rdf:Property ;
    rdfs:label 'Covenant Compliance Summary' ;
    rdfs:comment 'Summary assessment of the borrower\'s compliance with financial and non-financial covenants. Compliant indicates all covenants met; minor_breach indicates technical violations with no material impact; material_breach indicates significant covenant violations; waived indicates breaches that have been formally waived by the lender; not_applicable indicates no covenants in place.' ;
    rdfs:domain ind:CreditReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditCommitteeDate rdf:type rdf:Property ;
    rdfs:label 'Credit Committee Date' ;
    rdfs:comment 'The date on which the credit committee formally reviewed and approved the credit review findings. Represents the official sign-off timestamp for governance and audit purposes.' ;
    rdfs:domain ind:CreditReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditCommitteeDecision rdf:type rdf:Property ;
    rdfs:label 'Credit Committee Decision' ;
    rdfs:comment 'Final decision rendered by the credit committee on the review findings and recommended action. Approved indicates acceptance of recommendations; approved_with_conditions indicates acceptance subject to specific requirements; rejected indicates committee disagreement; deferred indicates decision postponed; referred indicates escalation to higher authority.' ;
    rdfs:domain ind:CreditReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eclAmount rdf:type rdf:Property ;
    rdfs:label 'Ecl Amount' ;
    rdfs:comment 'The Expected Credit Loss (ECL) provision amount calculated for this facility based on the updated PD, LGD, and EAD estimates from this credit review. Represents the present value of expected credit losses over the relevant time horizon.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financialPerformanceAssessment rdf:type rdf:Property ;
    rdfs:label 'Financial Performance Assessment' ;
    rdfs:comment 'Qualitative assessment of the borrower\'s financial performance since the last review. Considers revenue trends, profitability, cash flow generation, leverage ratios, and liquidity position.' ;
    rdfs:domain ind:CreditReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industryOutlook rdf:type rdf:Property ;
    rdfs:label 'Industry Outlook' ;
    rdfs:comment 'Assessment of the borrower\'s industry sector outlook and its impact on credit risk. Positive indicates favorable industry trends; stable indicates steady conditions; cautious indicates emerging headwinds; negative indicates sector deterioration; distressed indicates severe industry stress.' ;
    rdfs:domain ind:CreditReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nplFlag rdf:type rdf:Property ;
    rdfs:label 'Npl Flag' ;
    rdfs:comment 'Indicates whether the loan is classified as non-performing based on this credit review. True if the loan is 90+ days past due or otherwise impaired; false if performing.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:previousInternalRating rdf:type rdf:Property ;
    rdfs:label 'Previous Internal Rating' ;
    rdfs:comment 'The internal risk rating assigned to the borrower prior to this credit review. Used to track rating migration and credit quality trends.' ;
    rdfs:domain ind:CreditReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousLgd rdf:type rdf:Property ;
    rdfs:label 'Previous Lgd' ;
    rdfs:comment 'The Loss Given Default (LGD) estimate assigned to the facility prior to this review, expressed as a decimal (e.g., 0.45 for 45%). LGD represents the expected loss severity in the event of default, net of collateral recovery.' ;
    rdfs:domain ind:CreditReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:previousPd rdf:type rdf:Property ;
    rdfs:label 'Previous Pd' ;
    rdfs:comment 'The Probability of Default (PD) estimate assigned to the borrower prior to this review, expressed as a decimal (e.g., 0.025 for 2.5%). PD represents the likelihood of default over a one-year horizon under the IRB approach.' ;
    rdfs:domain ind:CreditReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reviewComments rdf:type rdf:Property ;
    rdfs:label 'Review Comments' ;
    rdfs:comment 'Free-text field capturing key observations, concerns, mitigating factors, and qualitative insights from the credit review. Provides narrative context to support the quantitative assessment and rating decision.' ;
    rdfs:domain ind:CreditReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stageClassification rdf:type rdf:Property ;
    rdfs:label 'Stage Classification' ;
    rdfs:comment 'IFRS 9 impairment stage classification assigned as a result of this credit review. Stage 1 indicates no significant increase in credit risk (12-month ECL); Stage 2 indicates significant increase in credit risk (lifetime ECL); Stage 3 indicates credit-impaired (lifetime ECL with interest revenue on net carrying amount).' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disbursementId rdf:type rdf:Property ;
    rdfs:label 'Disbursement Id' ;
    rdfs:comment 'Unique identifier for the loan disbursement event. Primary key.' ;
    rdfs:domain ind:Disbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:drawdownId rdf:type rdf:Property ;
    rdfs:label 'Drawdown Id' ;
    rdfs:comment 'Reference to the facility drawdown event that triggered this disbursement. Nullable for non-facility loans.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Drawdown .

ind:nostroAccountId rdf:type rdf:Property ;
    rdfs:label 'Nostro Account Id' ;
    rdfs:comment 'Foreign key linking to treasury.nostro_account. Business justification: Loan disbursements settle through nostro accounts for payment execution, nostro reconciliation, and cash management. Standard banking operations link disbursements to specific nostro accounts for sett' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NostroAccount .

ind:approvalAuthorityLevel rdf:type rdf:Property ;
    rdfs:label 'Approval Authority Level' ;
    rdfs:comment 'Level of authority required for disbursement approval (e.g., branch manager, credit committee, senior management).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionsPrecedentChecklist rdf:type rdf:Property ;
    rdfs:label 'Conditions Precedent Checklist' ;
    rdfs:comment 'Comma-separated list or description of specific conditions precedent that were verified before disbursement.' ;
    rdfs:domain ind:Disbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionsPrecedentSatisfiedFlag rdf:type rdf:Property ;
    rdfs:label 'Conditions Precedent Satisfied Flag' ;
    rdfs:comment 'Indicates whether all conditions precedent required for disbursement have been satisfied (e.g., documentation, collateral perfection, insurance).' ;
    rdfs:domain ind:Disbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:destinationAccountName rdf:type rdf:Property ;
    rdfs:label 'Destination Account Name' ;
    rdfs:comment 'Name of the account holder for the destination account receiving funds.' ;
    rdfs:domain ind:Disbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationBankBic rdf:type rdf:Property ;
    rdfs:label 'Destination Bank Bic' ;
    rdfs:comment 'SWIFT BIC code of the destination bank receiving the disbursement. Applicable for wire transfers and international payments.' ;
    rdfs:domain ind:Disbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationBankName rdf:type rdf:Property ;
    rdfs:label 'Destination Bank Name' ;
    rdfs:comment 'Name of the financial institution where the destination account is held.' ;
    rdfs:domain ind:Disbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationRoutingNumber rdf:type rdf:Property ;
    rdfs:label 'Destination Routing Number' ;
    rdfs:comment 'Routing or sort code for the destination bank. Used for domestic transfers (e.g., ABA routing number in US, sort code in UK).' ;
    rdfs:domain ind:Disbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disbursementDate rdf:type rdf:Property ;
    rdfs:label 'Disbursement Date' ;
    rdfs:comment 'Business date on which the disbursement was initiated or authorized.' ;
    rdfs:domain ind:Disbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disbursementMethod rdf:type rdf:Property ;
    rdfs:label 'Disbursement Method' ;
    rdfs:comment 'Payment mechanism used to transfer funds to the borrower (e.g., wire transfer, ACH, RTGS, check).' ;
    rdfs:domain ind:Disbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disbursementStatus rdf:type rdf:Property ;
    rdfs:label 'Disbursement Status' ;
    rdfs:comment 'Current lifecycle status of the disbursement transaction indicating processing state. [ENUM-REF-CANDIDATE: pending|approved|in_progress|completed|failed|cancelled|reversed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Disbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disbursementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Disbursement Timestamp' ;
    rdfs:comment 'Precise date and time when the disbursement transaction was executed in the system.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:exchangeRateDate rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate Date' ;
    rdfs:comment 'Date on which the exchange rate was determined for currency conversion.' ;
    rdfs:domain ind:Disbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:netDisbursementAmount rdf:type rdf:Property ;
    rdfs:label 'Net Disbursement Amount' ;
    rdfs:comment 'Net amount received by the borrower after deducting fees and charges from the gross disbursement amount.' ;
    rdfs:domain ind:Disbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partialDisbursementFlag rdf:type rdf:Property ;
    rdfs:label 'Partial Disbursement Flag' ;
    rdfs:comment 'Indicates whether this disbursement represents a partial release of the total approved loan amount.' ;
    rdfs:domain ind:Disbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:handlingOfficerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Handling Officer Employee Id' ;
    rdfs:comment 'Foreign key linking to hr.employee. Business justification: Documentary collections require handling officer attribution for operational accountability, dispute resolution, and URC 522 compliance. Business process: document examination, payment processing, dis' ;
    rdfs:domain ind:DocumentaryCollection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryDocumentaryDrawerPartyId rdf:type rdf:Property ;
    rdfs:label 'Primary Documentary Drawer Party Id' ;
    rdfs:comment 'Identifier of the drawer (exporter/seller) who is the principal in the collection and who instructs the remitting bank to collect payment from the drawee.' ;
    rdfs:domain ind:DocumentaryCollection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:tertiaryDocumentaryCaseOfNeedPartyId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Documentary Case Of Need Party Id' ;
    rdfs:comment 'Identifier of the case-of-need party (referee in case of need) who may be contacted for instructions if the drawee refuses payment or acceptance. Optional field per URC 522.' ;
    rdfs:domain ind:DocumentaryCollection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:tradeFacilityId rdf:type rdf:Property ;
    rdfs:label 'Trade Facility Id' ;
    rdfs:comment 'Foreign key linking to loan.trade_facility. Business justification: Documentary collections are processed under trade finance facilities. The collection amount may draw against the facility limit (especially for D/A - documents against acceptance). Business justificat' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TradeFacility .

ind:caseOfNeedInstructions rdf:type rdf:Property ;
    rdfs:label 'Case Of Need Instructions' ;
    rdfs:comment 'Specific instructions to be followed if the drawee dishonours the collection, including contact details and authority of the case-of-need party.' ;
    rdfs:domain ind:DocumentaryCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargesAllocation rdf:type rdf:Property ;
    rdfs:label 'Charges Allocation' ;
    rdfs:comment 'Party responsible for paying collection charges: drawer (exporter), drawee (importer), or shared between both parties.' ;
    rdfs:domain ind:DocumentaryCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargesAmount rdf:type rdf:Property ;
    rdfs:label 'Charges Amount' ;
    rdfs:comment 'Total bank charges and fees associated with the collection. May be for account of drawer, drawee, or split per collection instructions.' ;
    rdfs:domain ind:DocumentaryCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chargesCurrency rdf:type rdf:Property ;
    rdfs:label 'Charges Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the charges amount.' ;
    rdfs:domain ind:DocumentaryCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectingBankBic rdf:type rdf:Property ;
    rdfs:label 'Collecting Bank Bic' ;
    rdfs:comment 'SWIFT Bank Identifier Code (BIC) of the collecting bank (presenting bank) that presents documents to the drawee. 8 or 11 character ISO 9362 format.' ;
    rdfs:domain ind:DocumentaryCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionAmount rdf:type rdf:Property ;
    rdfs:label 'Collection Amount' ;
    rdfs:comment 'Principal amount to be collected from the drawee. Represents the invoice value or bill amount.' ;
    rdfs:domain ind:DocumentaryCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collectionCurrency rdf:type rdf:Property ;
    rdfs:label 'Collection Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the collection amount.' ;
    rdfs:domain ind:DocumentaryCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Collection Reference Number' ;
    rdfs:comment 'Externally-known unique reference number assigned to this documentary collection by the remitting bank. Used for tracking and correspondence under URC 522.' ;
    rdfs:domain ind:DocumentaryCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionStatus rdf:type rdf:Property ;
    rdfs:label 'Collection Status' ;
    rdfs:comment 'Current lifecycle status of the documentary collection: lodged (received by remitting bank), presented (documents presented to drawee), accepted (drawee accepted documents), paid (payment received), dishonoured (drawee refused), returned (documents returned to drawer), cancelled (collection cancelled). [ENUM-REF-CANDIDATE: lodged|presented|accepted|paid|dishonoured|returned|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DocumentaryCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionType rdf:type rdf:Property ;
    rdfs:label 'Collection Type' ;
    rdfs:comment 'Type of documentary collection: Documents Against Payment (D/P), Documents Against Acceptance (D/A), or Clean Collection (financial documents only without commercial documents).' ;
    rdfs:domain ind:DocumentaryCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryInstructions rdf:type rdf:Property ;
    rdfs:label 'Delivery Instructions' ;
    rdfs:comment 'Instructions for when the collecting bank should release documents to the drawee: against payment (D/P), against acceptance (D/A), or without payment (exceptional cases).' ;
    rdfs:domain ind:DocumentaryCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dishonourReason rdf:type rdf:Property ;
    rdfs:label 'Dishonour Reason' ;
    rdfs:comment 'Reason provided by the drawee or collecting bank for non-payment or non-acceptance of the collection (e.g., discrepancies in documents, insufficient funds, goods not as described). Populated only if collection status is dishonoured.' ;
    rdfs:domain ind:DocumentaryCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentSetDescription rdf:type rdf:Property ;
    rdfs:label 'Document Set Description' ;
    rdfs:comment 'Detailed description of the commercial and financial documents included in the collection (e.g., bill of exchange, commercial invoice, bill of lading, insurance certificate, certificate of origin, packing list).' ;
    rdfs:domain ind:DocumentaryCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:draweeName rdf:type rdf:Property ;
    rdfs:label 'Drawee Name' ;
    rdfs:comment 'Full legal name of the drawee (importer/buyer) to whom the documents are to be presented.' ;
    rdfs:domain ind:DocumentaryCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drawerName rdf:type rdf:Property ;
    rdfs:label 'Drawer Name' ;
    rdfs:comment 'Full legal name of the drawer (exporter/seller) as it appears on the collection documents.' ;
    rdfs:domain ind:DocumentaryCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberOfDocuments rdf:type rdf:Property ;
    rdfs:label 'Number Of Documents' ;
    rdfs:comment 'Total count of individual documents included in the collection package.' ;
    rdfs:domain ind:DocumentaryCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:partialPaymentAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Partial Payment Allowed Flag' ;
    rdfs:comment 'Indicates whether the drawer permits the collecting bank to accept partial payment from the drawee. True if partial payment is allowed, false otherwise.' ;
    rdfs:domain ind:DocumentaryCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:protestInstructions rdf:type rdf:Property ;
    rdfs:label 'Protest Instructions' ;
    rdfs:comment 'Instructions from the drawer regarding whether to protest non-payment or non-acceptance. Protest is a formal notarial act evidencing dishonour.' ;
    rdfs:domain ind:DocumentaryCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remittingBankBic rdf:type rdf:Property ;
    rdfs:label 'Remitting Bank Bic' ;
    rdfs:comment 'SWIFT Bank Identifier Code (BIC) of the remitting bank that received the collection instruction from the drawer. 8 or 11 character ISO 9362 format.' ;
    rdfs:domain ind:DocumentaryCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnDate rdf:type rdf:Property ;
    rdfs:label 'Return Date' ;
    rdfs:comment 'Date when the documents were returned to the remitting bank or drawer following dishonour or cancellation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shipmentDate rdf:type rdf:Property ;
    rdfs:label 'Shipment Date' ;
    rdfs:comment 'Date of shipment of goods as evidenced by the transport document (bill of lading, airway bill, etc.). Relevant for calculating tenor in shipment-date-based collections.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tenorBasis rdf:type rdf:Property ;
    rdfs:label 'Tenor Basis' ;
    rdfs:comment 'Basis from which the tenor period is calculated: sight (immediate payment), date of acceptance, date of bill, or date of shipment.' ;
    rdfs:domain ind:DocumentaryCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tenorDays rdf:type rdf:Property ;
    rdfs:label 'Tenor Days' ;
    rdfs:comment 'Number of days from presentation or acceptance until payment is due. Applicable for usance/time collections (D/A). Zero or null for sight collections (D/P).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:underlyingTradeReference rdf:type rdf:Property ;
    rdfs:label 'Underlying Trade Reference' ;
    rdfs:comment 'Reference number of the underlying trade transaction, purchase order, or sales contract that this documentary collection supports.' ;
    rdfs:domain ind:DocumentaryCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availableCommitmentAmount rdf:type rdf:Property ;
    rdfs:label 'Available Commitment Amount' ;
    rdfs:comment 'The remaining undrawn commitment amount available under the facility after this drawdown. Calculated as facility limit minus total outstanding drawdowns.' ;
    rdfs:domain ind:Drawdown ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:benchmarkRate rdf:type rdf:Property ;
    rdfs:label 'Benchmark Rate' ;
    rdfs:comment 'The reference benchmark rate used for floating-rate drawdowns: SOFR (Secured Overnight Financing Rate), LIBOR (legacy), EURIBOR, SONIA, ESTR, PRIME, or BASE rate.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentUtilizationPct rdf:type rdf:Property ;
    rdfs:label 'Commitment Utilization Pct' ;
    rdfs:comment 'The percentage of the total facility commitment utilized after this drawdown, calculated as (total outstanding + this drawdown) / facility limit * 100. Used for covenant monitoring.' ;
    rdfs:domain ind:Drawdown ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:drawdownDate rdf:type rdf:Property ;
    rdfs:label 'Drawdown Date' ;
    rdfs:comment 'The business date on which the borrower requested or executed the drawdown. This is the transaction date for accounting and interest accrual purposes.' ;
    rdfs:domain ind:Drawdown ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:drawdownStatus rdf:type rdf:Property ;
    rdfs:label 'Drawdown Status' ;
    rdfs:comment 'Current lifecycle status of the drawdown transaction: pending (awaiting approval), approved (authorized), disbursed (funds sent), settled (funds received), failed (payment failed), cancelled (voided), or reversed (unwound). [ENUM-REF-CANDIDATE: pending|approved|disbursed|settled|failed|cancelled|reversed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Drawdown ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drawdownType rdf:type rdf:Property ;
    rdfs:label 'Drawdown Type' ;
    rdfs:comment 'Classification of the drawdown event: scheduled (pre-agreed), unscheduled (ad-hoc), revolving (under revolving facility), term (under term loan), swing_line (short-term bridge), or overdraft (emergency).' ;
    rdfs:domain ind:Drawdown ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundingAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Funding Account Number' ;
    rdfs:comment 'The internal general ledger or nostro account number from which the drawdown funds were disbursed. Used for reconciliation and funds transfer pricing (FTP).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interestPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Interest Period Days' ;
    rdfs:comment 'The number of days in the interest period for this drawdown (e.g., 30, 90, 180). Determines the frequency of interest rate resets for floating-rate drawdowns.' ;
    rdfs:domain ind:Drawdown ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:interestRateType rdf:type rdf:Property ;
    rdfs:label 'Interest Rate Type' ;
    rdfs:comment 'Type of interest rate applicable to this drawdown: fixed (locked rate), floating (benchmark + spread), variable (adjustable), or zero (non-interest bearing).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loanToValueRatio rdf:type rdf:Property ;
    rdfs:label 'Loan To Value Ratio' ;
    rdfs:comment 'The ratio of the total outstanding loan amount (including this drawdown) to the appraised value of the collateral, expressed as a percentage. Key covenant metric for secured facilities.' ;
    rdfs:domain ind:Drawdown ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:repaymentType rdf:type rdf:Property ;
    rdfs:label 'Repayment Type' ;
    rdfs:comment 'The repayment structure for this drawdown: bullet (single payment at maturity), amortizing (scheduled installments), revolving (flexible repayment and re-draw), or on_demand (callable).' ;
    rdfs:domain ind:Drawdown ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskWeightPct rdf:type rdf:Property ;
    rdfs:label 'Risk Weight Pct' ;
    rdfs:comment 'The Basel III risk weight percentage applied to this drawdown exposure for Risk-Weighted Assets (RWA) calculation. Varies by borrower credit rating and collateral.' ;
    rdfs:domain ind:Drawdown ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:syndicationFlag rdf:type rdf:Property ;
    rdfs:label 'Syndication Flag' ;
    rdfs:comment 'Indicates whether this drawdown is part of a syndicated loan facility with multiple lender participants. True if syndicated, false if bilateral.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tradeFinanceReference rdf:type rdf:Property ;
    rdfs:label 'Trade Finance Reference' ;
    rdfs:comment 'Reference to the underlying trade finance instrument if this drawdown is linked to a letter of credit, documentary collection, or bill of lading. Used for UCP 600 compliance.' ;
    rdfs:domain ind:Drawdown ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityBorrowerPartyId rdf:type rdf:Property ;
    rdfs:label 'Facility Borrower Party Id' ;
    rdfs:comment 'FK to customer.party.party_id — MUST-HAVE: Cannot query loan facilities by borrower without this link. Fundamental for credit portfolio management, regulatory reporting (CCAR/DFAST), and customer 360 views.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:facilityPartyId rdf:type rdf:Property ;
    rdfs:label 'Facility Party Id' ;
    rdfs:comment 'Reference to the primary borrowing entity (customer or counterparty) obligated under this credit facility. Used for KYC/AML linkage, credit exposure aggregation, and regulatory reporting.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:trustAccountId rdf:type rdf:Property ;
    rdfs:label 'Trust Account Id' ;
    rdfs:comment 'Foreign key linking to wealth.trust_account. Business justification: Trust accounts hold credit facilities as trust assets (mortgages on trust property, lines of credit for trust liquidity). Fiduciary lending requires tracking facility obligations at trust level for tr' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TrustAccount .

ind:underlyingSecurityInstrumentId rdf:type rdf:Property ;
    rdfs:label 'Underlying Security Instrument Id' ;
    rdfs:comment 'Foreign key linking to security.instrument. Business justification: Securities-backed credit facilities (margin lending, portfolio-based lines) require tracking the underlying security collateral. Core private banking and wealth management product. Supports collateral' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Instrument .

ind:agentBankFlag rdf:type rdf:Property ;
    rdfs:label 'Agent Bank Flag' ;
    rdfs:comment 'Indicates whether the bank acts as the administrative agent for this syndicated facility, responsible for coordinating drawdowns, payments, and covenant compliance on behalf of the lending syndicate.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allInRate rdf:type rdf:Property ;
    rdfs:label 'All In Rate' ;
    rdfs:comment 'Total effective interest rate applicable to the facility, combining the reference rate benchmark and the credit spread. Expressed as a decimal (e.g., 0.065 = 6.5%). Used for interest accrual, income recognition, and borrower billing.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:committedAmount rdf:type rdf:Property ;
    rdfs:label 'Committed Amount' ;
    rdfs:comment 'Total committed credit limit approved for the facility, representing the maximum exposure the bank has contractually agreed to extend. Used in RWA (Risk-Weighted Assets) calculation and EAD (Exposure at Default) estimation under Basel IRB/SA approaches.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:covenantBreachFlag rdf:type rdf:Property ;
    rdfs:label 'Covenant Breach Flag' ;
    rdfs:comment 'Indicates whether the borrower is currently in breach of one or more financial or non-financial covenants attached to the facility. A covenant breach may constitute an event of default or trigger accelerated repayment provisions.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:drawnAmount rdf:type rdf:Property ;
    rdfs:label 'Drawn Amount' ;
    rdfs:comment 'Outstanding principal balance currently drawn and outstanding under the facility. Represents the bank\'s actual on-balance-sheet credit exposure. Key input for ECL (Expected Credit Loss) provisioning under IFRS 9 and CECL.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:facilityName rdf:type rdf:Property ;
    rdfs:label 'Facility Name' ;
    rdfs:comment 'Human-readable descriptive name of the credit facility as recorded in the Loan Origination System, typically reflecting the borrower name and facility type (e.g., \'Acme Corp — 5-Year Revolving Credit Facility\').' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityStatus rdf:type rdf:Property ;
    rdfs:label 'Facility Status' ;
    rdfs:comment 'Current lifecycle state of the credit facility. Drives downstream processing, provisioning, and regulatory classification. \'defaulted\' triggers NPL (Non-Performing Loan) reporting; \'written_off\' indicates full credit loss recognition under CECL/IFRS 9.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstDrawdownDate rdf:type rdf:Property ;
    rdfs:label 'First Drawdown Date' ;
    rdfs:comment 'Date of the first utilization or drawdown under the facility. Marks the transition from commitment to active exposure and is used for interest accrual commencement and IFRS 9 initial recognition of financial asset.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:interestRateBasis rdf:type rdf:Property ;
    rdfs:label 'Interest Rate Basis' ;
    rdfs:comment 'Reference rate benchmark underpinning the facility\'s floating interest rate (e.g., SOFR — Secured Overnight Financing Rate, EURIBOR). Reflects LIBOR transition requirements per ARRC/ISDA fallback protocols. Fixed-rate facilities carry \'fixed\' designation. [ENUM-REF-CANDIDATE: SOFR|LIBOR|EURIBOR|SONIA|fixed|prime|CDOR — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interestRateSpreadBps rdf:type rdf:Property ;
    rdfs:label 'Interest Rate Spread Bps' ;
    rdfs:comment 'Credit spread above the reference rate benchmark expressed in BPS (Basis Points), representing the bank\'s risk-adjusted margin on the facility. Key input for NIM (Net Interest Margin) and NII (Net Interest Income) reporting and FTP (Funds Transfer Pricing).' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loanPurposeCode rdf:type rdf:Property ;
    rdfs:label 'Loan Purpose Code' ;
    rdfs:comment 'Standardized code classifying the intended use of proceeds for the credit facility (e.g., working capital, capital expenditure, acquisition finance, real estate purchase). Required for HMDA, CRA, and Call Report regulatory filings. [ENUM-REF-CANDIDATE: working_capital|capex|acquisition|real_estate|trade_finance|refinancing|general_corporate|consumer_personal — promote to reference product]' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originatingBranchCode rdf:type rdf:Property ;
    rdfs:label 'Originating Branch Code' ;
    rdfs:comment 'Code identifying the bank branch or business unit that originated the credit facility. Used for geographic concentration analysis, CRA (Community Reinvestment Act) reporting, and LOB (Line of Business) profitability attribution.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repaymentFrequency rdf:type rdf:Property ;
    rdfs:label 'Repayment Frequency' ;
    rdfs:comment 'Scheduled frequency of principal and/or interest repayment installments under the facility. Drives cash flow projection for ALM (Asset-Liability Management), liquidity gap analysis, and NSFR (Net Stable Funding Ratio) bucketing.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:syndicatedFlag rdf:type rdf:Property ;
    rdfs:label 'Syndicated Flag' ;
    rdfs:comment 'Indicates whether the facility is part of a syndicated loan arrangement involving multiple lender participants. Syndicated facilities require agent bank coordination, participation tracking, and specific regulatory reporting under OCC Shared National Credit (SNC) program.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:undrawnAmount rdf:type rdf:Property ;
    rdfs:label 'Undrawn Amount' ;
    rdfs:comment 'Available but unutilized portion of the committed facility (committed_amount minus drawn_amount). Attracts a credit conversion factor (CCF) for off-balance-sheet RWA calculation under Basel III standardized and IRB approaches.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accrualFrequency rdf:type rdf:Property ;
    rdfs:label 'Accrual Frequency' ;
    rdfs:comment 'Periodicity at which the fee accrues and is recognized for revenue purposes. One-time fees are charged once at a specific event; recurring fees accrue at the specified interval throughout the loan lifecycle.' ;
    rdfs:domain ind:LoanFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Amendment Sequence Number' ;
    rdfs:comment 'Sequential counter tracking the number of amendments made to this fee schedule. Starts at zero for the original fee schedule; incremented by one for each amendment. Supports audit trail and version control for fee schedule changes.' ;
    rdfs:domain ind:LoanFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicabilityCondition rdf:type rdf:Property ;
    rdfs:label 'Applicability Condition' ;
    rdfs:comment 'Business rule or contractual condition that must be satisfied for the fee to apply. Examples: \'Undrawn balance exceeds $1M\', \'Payment overdue by more than 30 days\', \'Amendment requires lender consent\'. Free-text field capturing the conditional logic from the loan agreement.' ;
    rdfs:domain ind:LoanFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingFrequency rdf:type rdf:Property ;
    rdfs:label 'Billing Frequency' ;
    rdfs:comment 'Periodicity at which the fee is invoiced to the borrower. May differ from accrual frequency; for example, a fee may accrue daily but be billed quarterly. On-demand billing applies to event-driven fees such as amendments or prepayments.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculationBasis rdf:type rdf:Property ;
    rdfs:label 'Calculation Basis' ;
    rdfs:comment 'Method used to compute the fee amount. Flat amount is a fixed dollar value; percentage of facility applies to the total committed amount; percentage of undrawn applies only to the unused portion of a revolving facility; percentage of outstanding applies to the current loan balance; tiered uses different rates for different balance ranges.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeRate rdf:type rdf:Property ;
    rdfs:label 'Fee Rate' ;
    rdfs:comment 'Percentage rate applied when calculation basis is percentage-based. Expressed as a decimal (e.g., 0.015000 represents 1.5% or 150 basis points). Null when calculation basis is flat amount.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feeStatus rdf:type rdf:Property ;
    rdfs:label 'Fee Status' ;
    rdfs:comment 'Current lifecycle state of the fee schedule. Active fees are currently accruing and billable; inactive fees are defined but not currently applicable; suspended fees are temporarily paused; waived fees have been forgiven by credit decision; cancelled fees are permanently terminated.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAccrualDate rdf:type rdf:Property ;
    rdfs:label 'Last Accrual Date' ;
    rdfs:comment 'Most recent date on which fee accrual was calculated and recorded. Used to track the current position in the accrual cycle and prevent duplicate accruals. Updated by the nightly accrual batch process.' ;
    rdfs:domain ind:LoanFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:latePaymentPenaltyRate rdf:type rdf:Property ;
    rdfs:label 'Late Payment Penalty Rate' ;
    rdfs:comment 'Percentage rate applied to overdue fee amounts to calculate late payment charges. Expressed as a decimal. Null if no late payment penalty applies to this fee type. Typically specified in the loan agreement default provisions.' ;
    rdfs:domain ind:LoanFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextBillingDate rdf:type rdf:Property ;
    rdfs:label 'Next Billing Date' ;
    rdfs:comment 'Scheduled date for the next fee invoice to be generated and sent to the borrower. Updated after each billing cycle. Null for one-time fees that have already been billed or for inactive fee schedules.' ;
    rdfs:domain ind:LoanFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:outstandingReceivableAmount rdf:type rdf:Property ;
    rdfs:label 'Outstanding Receivable Amount' ;
    rdfs:comment 'Current unpaid fee balance (total billed amount minus total paid amount). Represents the borrower\'s outstanding fee obligation. Monitored for credit risk and collections purposes.' ;
    rdfs:domain ind:LoanFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:syndicationAllocationMethod rdf:type rdf:Property ;
    rdfs:label 'Syndication Allocation Method' ;
    rdfs:comment 'Method for distributing fee revenue among syndicate members in syndicated loan facilities. Pro rata allocates based on each lender\'s participation percentage; lead arranger only assigns the full fee to the lead; agent only assigns to the administrative agent; custom follows a specific allocation schedule defined in the syndication agreement.' ;
    rdfs:domain ind:LoanFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxTreatmentCode rdf:type rdf:Property ;
    rdfs:label 'Tax Treatment Code' ;
    rdfs:comment 'Tax classification of the fee for income tax and withholding purposes. Taxable fees are subject to standard income tax; tax exempt fees are excluded from taxable income; withholding required indicates cross-border fees subject to withholding tax per tax treaty; VAT applicable indicates fees subject to value-added tax in applicable jurisdictions.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalAccruedAmount rdf:type rdf:Property ;
    rdfs:label 'Total Accrued Amount' ;
    rdfs:comment 'Cumulative fee amount accrued to date but not yet billed. Represents the unbilled revenue recognized on the balance sheet. Reset to zero after each billing cycle when accrued amounts are transferred to billed amounts.' ;
    rdfs:domain ind:LoanFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalBilledAmount rdf:type rdf:Property ;
    rdfs:label 'Total Billed Amount' ;
    rdfs:comment 'Cumulative fee amount invoiced to the borrower since fee schedule inception. Includes both paid and unpaid invoices. Used for revenue reporting and reconciliation with accounts receivable.' ;
    rdfs:domain ind:LoanFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPaidAmount rdf:type rdf:Property ;
    rdfs:label 'Total Paid Amount' ;
    rdfs:comment 'Cumulative fee amount received from the borrower since fee schedule inception. Used to calculate outstanding receivables (total billed minus total paid) and to track payment compliance.' ;
    rdfs:domain ind:LoanFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waiverAuthority rdf:type rdf:Property ;
    rdfs:label 'Waiver Authority' ;
    rdfs:comment 'Role or committee authorized to waive or reduce this fee. Examples: \'Chief Credit Officer\', \'Loan Committee\', \'Relationship Manager up to $5,000\'. Supports governance and audit trail for fee waivers.' ;
    rdfs:domain ind:LoanFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:faceValueCurrencyId rdf:type rdf:Property ;
    rdfs:label 'Face Value Currency Id' ;
    rdfs:comment 'Foreign key linking to reference.currency. Business justification: Forfaiting transactions denominated in currencies require currency metadata (convertibility, settlement lag) for pricing (discount rate calculation), settlement, and regulatory reporting (cross-border' ;
    rdfs:domain ind:Forfaiting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:forfaitingAvalProviderPartyId rdf:type rdf:Property ;
    rdfs:label 'Forfaiting Aval Provider Party Id' ;
    rdfs:comment 'Identifier of the bank or financial institution providing the aval (guarantee) on the underlying instrument, if applicable.' ;
    rdfs:domain ind:Forfaiting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:forfaitingGuarantorPartyId rdf:type rdf:Property ;
    rdfs:label 'Forfaiting Guarantor Party Id' ;
    rdfs:comment 'Identifier of any third-party guarantor providing credit enhancement for the underlying trade receivable.' ;
    rdfs:domain ind:Forfaiting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:forfaitingImporterPartyId rdf:type rdf:Property ;
    rdfs:label 'Forfaiting Importer Party Id' ;
    rdfs:comment 'Identifier of the importer who is the ultimate obligor on the underlying trade instrument.' ;
    rdfs:domain ind:Forfaiting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:forfaitingPartyId rdf:type rdf:Property ;
    rdfs:label 'Forfaiting Party Id' ;
    rdfs:comment 'Identifier of the exporter selling the trade receivables to the bank on a without-recourse basis.' ;
    rdfs:domain ind:Forfaiting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:importerCounterpartyRatingId rdf:type rdf:Property ;
    rdfs:label 'Importer Counterparty Rating Id' ;
    rdfs:comment 'Foreign key linking to risk.counterparty_rating. Business justification: Forfaiting credit decisions require importer credit rating assessment. Without-recourse forfaiting transfers credit risk, requiring formal rating. Pd/lgd/ead are denormalized rating parameters that sh' ;
    rdfs:domain ind:Forfaiting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CounterpartyRating .

ind:importerCountryId rdf:type rdf:Property ;
    rdfs:label 'Importer Country Id' ;
    rdfs:comment 'Foreign key linking to reference.country. Business justification: Forfaiting exposed to importer country risk requires country risk ratings, sovereign ratings, sanctions flags for pricing (country risk premium), credit decisioning (aval provider assessment), and reg' ;
    rdfs:domain ind:Forfaiting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:investmentPortfolioId rdf:type rdf:Property ;
    rdfs:label 'Investment Portfolio Id' ;
    rdfs:comment 'Foreign key linking to treasury.investment_portfolio. Business justification: Forfaiting transactions (purchased trade receivables) are held in treasury investment portfolios for investment portfolio management, yield optimization, and liquidity management.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InvestmentPortfolio .

ind:traderEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Trader Employee Id' ;
    rdfs:comment 'Foreign key linking to hr.employee. Business justification: Forfaiting transactions require trader attribution for P&L allocation, trading book risk limits, front-office controls, and compensation calculation. relationship_manager_id targets channel domain. Bu' ;
    rdfs:domain ind:Forfaiting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:countryRiskClassification rdf:type rdf:Property ;
    rdfs:label 'Country Risk Classification' ;
    rdfs:comment 'The country risk rating or classification for the importer\'s country, used in pricing and risk assessment.' ;
    rdfs:domain ind:Forfaiting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountBasis rdf:type rdf:Property ;
    rdfs:label 'Discount Basis' ;
    rdfs:comment 'The basis for calculating the discount rate (fixed rate, LIBOR plus spread, SOFR plus spread, or EURIBOR plus spread).' ;
    rdfs:domain ind:Forfaiting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountRate rdf:type rdf:Property ;
    rdfs:label 'Discount Rate' ;
    rdfs:comment 'The annual discount rate applied to calculate the purchase price from the face value, reflecting credit risk, country risk, and time value of money.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exporterCountryCode rdf:type rdf:Property ;
    rdfs:label 'Exporter Country Code' ;
    rdfs:comment 'Three-letter ISO 3166 country code for the exporter\'s domicile.' ;
    rdfs:domain ind:Forfaiting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:faceValueCurrency rdf:type rdf:Property ;
    rdfs:label 'Face Value Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the face value of the underlying instrument.' ;
    rdfs:domain ind:Forfaiting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ifrs9StageClassification rdf:type rdf:Property ;
    rdfs:label 'Ifrs9 Stage Classification' ;
    rdfs:comment 'The IFRS 9 impairment stage classification (Stage 1: performing, Stage 2: significant increase in credit risk, Stage 3: credit-impaired).' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTerms rdf:type rdf:Property ;
    rdfs:label 'Payment Terms' ;
    rdfs:comment 'Description of the payment terms and schedule for the underlying trade receivable.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchasePriceAmount rdf:type rdf:Property ;
    rdfs:label 'Purchase Price Amount' ;
    rdfs:comment 'The discounted amount paid by the bank to the exporter for purchasing the trade receivable without recourse.' ;
    rdfs:domain ind:Forfaiting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:purchasePriceCurrency rdf:type rdf:Property ;
    rdfs:label 'Purchase Price Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the purchase price paid to the exporter.' ;
    rdfs:domain ind:Forfaiting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskParticipationPercentage rdf:type rdf:Property ;
    rdfs:label 'Risk Participation Percentage' ;
    rdfs:comment 'The percentage of risk retained by the bank if the forfaiting transaction involves risk sharing or syndication.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:secondaryMarketSaleFlag rdf:type rdf:Property ;
    rdfs:label 'Secondary Market Sale Flag' ;
    rdfs:comment 'Indicates whether the forfaiting asset has been sold in the secondary market to another forfaiter or investor.' ;
    rdfs:domain ind:Forfaiting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:secondarySaleDate rdf:type rdf:Property ;
    rdfs:label 'Secondary Sale Date' ;
    rdfs:comment 'The date on which the forfaiting asset was sold to another party in the secondary market, if applicable.' ;
    rdfs:domain ind:Forfaiting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:secondarySalePriceAmount rdf:type rdf:Property ;
    rdfs:label 'Secondary Sale Price Amount' ;
    rdfs:comment 'The price at which the forfaiting asset was sold in the secondary market.' ;
    rdfs:domain ind:Forfaiting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:underlyingInstrumentReference rdf:type rdf:Property ;
    rdfs:label 'Underlying Instrument Reference' ;
    rdfs:comment 'Reference number or identifier of the underlying trade instrument (LC number, promissory note number, bill of exchange number).' ;
    rdfs:domain ind:Forfaiting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:underlyingInstrumentType rdf:type rdf:Property ;
    rdfs:label 'Underlying Instrument Type' ;
    rdfs:comment 'Type of trade finance instrument being forfaited (promissory note, bill of exchange, deferred payment letter of credit, usance draft, or aval).' ;
    rdfs:domain ind:Forfaiting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withoutRecourseFlag rdf:type rdf:Property ;
    rdfs:label 'Without Recourse Flag' ;
    rdfs:comment 'Confirms that the forfaiting transaction is without recourse to the exporter, meaning the bank assumes all credit and political risk.' ;
    rdfs:domain ind:Forfaiting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:guaranteeId rdf:type rdf:Property ;
    rdfs:label 'Guarantee Id' ;
    rdfs:comment 'Unique identifier for the loan guarantee record. Primary key for the guarantee entity.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Guarantee .

ind:coverageCurrencyId rdf:type rdf:Property ;
    rdfs:label 'Coverage Currency Id' ;
    rdfs:comment 'Foreign key linking to reference.currency. Business justification: Guarantees with coverage in currencies require currency metadata (rounding, minor unit) for enforceability assessment, call processing, capital relief calculation (RWA reduction), and regulatory repor' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:guaranteeGuarantorPartyId rdf:type rdf:Property ;
    rdfs:label 'Guarantee Guarantor Party Id' ;
    rdfs:comment 'FK to customer.party' ;
    rdfs:domain ind:Guarantee ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:guaranteePartyId rdf:type rdf:Property ;
    rdfs:label 'Guarantee Party Id' ;
    rdfs:comment 'Reference to the party providing the guarantee. May be an individual, corporation, or government entity.' ;
    rdfs:domain ind:Guarantee ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:guarantorCounterpartyRatingId rdf:type rdf:Property ;
    rdfs:label 'Guarantor Counterparty Rating Id' ;
    rdfs:comment 'Foreign key linking to risk.counterparty_rating. Business justification: Guarantee credit risk mitigation depends on guarantor creditworthiness. Regulatory capital relief calculations require guarantor ratings. Guarantor_credit_rating/internal_rating/pd/lgd are denormalize' ;
    rdfs:domain ind:Guarantee ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CounterpartyRating .

ind:callAmount rdf:type rdf:Property ;
    rdfs:label 'Call Amount' ;
    rdfs:comment 'Monetary amount demanded from the guarantor upon calling the guarantee. May be less than the full coverage amount depending on the outstanding loan balance and guarantee terms.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capitalReliefAmount rdf:type rdf:Property ;
    rdfs:label 'Capital Relief Amount' ;
    rdfs:comment 'Reduction in Risk-Weighted Assets (RWA) achieved through the guarantee. Calculated based on the difference between the borrower\'s and guarantor\'s risk weights.' ;
    rdfs:domain ind:Guarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:crossDefaultClauseFlag rdf:type rdf:Property ;
    rdfs:label 'Cross Default Clause Flag' ;
    rdfs:comment 'Indicates whether the guarantee includes a cross-default provision that triggers the guarantee if the borrower defaults on other obligations. Strengthens credit risk mitigation.' ;
    rdfs:domain ind:Guarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:documentationType rdf:type rdf:Property ;
    rdfs:label 'Documentation Type' ;
    rdfs:comment 'Legal form of the guarantee documentation. Determines the legal framework, enforceability standards, and regulatory capital treatment.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eclAdjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Ecl Adjustment Amount' ;
    rdfs:comment 'Reduction in Expected Credit Loss provision due to the guarantee. Calculated based on the guarantor\'s creditworthiness and coverage amount under IFRS 9 or CECL.' ;
    rdfs:domain ind:Guarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enforceabilityOpinionDate rdf:type rdf:Property ;
    rdfs:label 'Enforceability Opinion Date' ;
    rdfs:comment 'Date of the most recent legal opinion confirming the enforceability of the guarantee. Basel III requires periodic legal review of credit risk mitigation instruments.' ;
    rdfs:domain ind:Guarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enforceabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Enforceability Status' ;
    rdfs:comment 'Legal assessment of whether the guarantee can be enforced in the relevant jurisdiction. Only enforceable guarantees qualify for regulatory capital relief under Basel III.' ;
    rdfs:domain ind:Guarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guarantorType rdf:type rdf:Property ;
    rdfs:label 'Guarantor Type' ;
    rdfs:comment 'Classification of the guarantor entity. Determines credit risk treatment, regulatory capital calculation, and enforceability considerations. [ENUM-REF-CANDIDATE: personal|corporate|government|bank|insurance_company|parent_company|third_party — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Guarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalDocumentationReference rdf:type rdf:Property ;
    rdfs:label 'Legal Documentation Reference' ;
    rdfs:comment 'Reference to the physical or electronic location of the executed guarantee document. Required for audit, regulatory examination, and enforceability verification.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentReceivedAmount rdf:type rdf:Property ;
    rdfs:label 'Payment Received Amount' ;
    rdfs:comment 'Actual monetary amount received from the guarantor. Used to calculate recovery rates and reduce net credit losses.' ;
    rdfs:domain ind:Guarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rwaAfterGuarantee rdf:type rdf:Property ;
    rdfs:label 'Rwa After Guarantee' ;
    rdfs:comment 'Risk-Weighted Assets of the loan exposure after applying the guarantee credit risk mitigation. Reflects the substitution of the guarantor\'s risk weight.' ;
    rdfs:domain ind:Guarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rwaBeforeGuarantee rdf:type rdf:Property ;
    rdfs:label 'Rwa Before Guarantee' ;
    rdfs:comment 'Risk-Weighted Assets of the loan exposure before applying the guarantee credit risk mitigation. Used to calculate the capital relief benefit.' ;
    rdfs:domain ind:Guarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceId rdf:type rdf:Property ;
    rdfs:label 'Insurance Id' ;
    rdfs:comment 'Unique identifier for the insurance policy record associated with a loan facility. Primary key for the insurance product.' ;
    rdfs:domain ind:Insurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:forcePlacedDate rdf:type rdf:Property ;
    rdfs:label 'Force Placed Date' ;
    rdfs:comment 'Date on which lender-placed insurance coverage was initiated due to borrower failure to maintain required coverage. Used for cost allocation and regulatory reporting.' ;
    rdfs:domain ind:Insurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:forcePlacedFlag rdf:type rdf:Property ;
    rdfs:label 'Force Placed Flag' ;
    rdfs:comment 'Indicates whether insurance was obtained by the lender on behalf of the borrower due to lapse or non-compliance with insurance requirements. Force-placed insurance is typically more expensive and may be charged back to borrower.' ;
    rdfs:domain ind:Insurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastClaimDate rdf:type rdf:Property ;
    rdfs:label 'Last Claim Date' ;
    rdfs:comment 'Date of the most recent claim filed against this policy. Used for risk assessment and underwriting review.' ;
    rdfs:domain ind:Insurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:premiumCurrency rdf:type rdf:Property ;
    rdfs:label 'Premium Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the premium amount. Typically matches loan currency but may differ for cross-border transactions.' ;
    rdfs:domain ind:Insurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:premiumPaymentMethod rdf:type rdf:Property ;
    rdfs:label 'Premium Payment Method' ;
    rdfs:comment 'Mechanism by which insurance premiums are paid. Borrower-paid indicates direct payment by borrower; lender-paid indicates bank advances premium; escrowed indicates premium collected with loan payment; financed indicates premium added to loan balance.' ;
    rdfs:domain ind:Insurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredByLenderFlag rdf:type rdf:Property ;
    rdfs:label 'Required By Lender Flag' ;
    rdfs:comment 'Indicates whether insurance is mandated by the lending institution as a condition of loan approval. True for required coverage; false for optional or borrower-elected coverage.' ;
    rdfs:domain ind:Insurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:expiryCountryId rdf:type rdf:Property ;
    rdfs:label 'Expiry Country Id' ;
    rdfs:comment 'Foreign key linking to reference.country. Business justification: LCs specify expiry place (country) requiring country business day conventions, holiday calendars, and regulatory rules (UCP 600 Article 3) for expiry date calculation and presentation deadline determi' ;
    rdfs:domain ind:Lc ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:applicableRules rdf:type rdf:Property ;
    rdfs:label 'Applicable Rules' ;
    rdfs:comment 'ICC rules governing this Letter of Credit. UCP 600: Uniform Customs and Practice for Documentary Credits. eUCP: electronic presentation supplement. ISP98: International Standby Practices. URDG 758: Uniform Rules for Demand Guarantees.' ;
    rdfs:domain ind:Lc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availableAmount rdf:type rdf:Property ;
    rdfs:label 'Available Amount' ;
    rdfs:comment 'Current remaining credit amount available for drawing under the Letter of Credit after accounting for any utilizations, amendments, or expirations.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confirmingBankBic rdf:type rdf:Property ;
    rdfs:label 'Confirming Bank Bic' ;
    rdfs:comment 'SWIFT BIC code of the bank that adds its confirmation to the Letter of Credit, thereby undertaking to honor complying presentations in addition to the issuing bank.' ;
    rdfs:domain ind:Lc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expiryPlace rdf:type rdf:Property ;
    rdfs:label 'Expiry Place' ;
    rdfs:comment 'Geographic location (city and country) where the Letter of Credit expires and documents must be presented. Typically the counters of the nominated bank or issuing bank.' ;
    rdfs:domain ind:Lc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incoterm rdf:type rdf:Property ;
    rdfs:label 'Incoterm' ;
    rdfs:comment 'ICC Incoterms rule defining the division of costs, risks, and responsibilities between buyer and seller in the international sale of goods. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Lc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:latestShipmentDate rdf:type rdf:Property ;
    rdfs:label 'Latest Shipment Date' ;
    rdfs:comment 'Last date by which shipment of goods must occur as stipulated in the Letter of Credit terms. Critical for compliance with transport document requirements.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lcNumber rdf:type rdf:Property ;
    rdfs:label 'Lc Number' ;
    rdfs:comment 'Externally-known unique reference number assigned to the Letter of Credit by the issuing bank. This is the business identifier used in SWIFT messages and trade documentation.' ;
    rdfs:domain ind:Lc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lcStatus rdf:type rdf:Property ;
    rdfs:label 'Lc Status' ;
    rdfs:comment 'Current lifecycle status of the Letter of Credit. Draft: being prepared. Issued: sent to advising bank. Advised: communicated to beneficiary. Confirmed: confirmed by another bank. Amended: modified after issuance. Utilized: drawings made. Expired: validity period ended. Cancelled: terminated before expiry. [ENUM-REF-CANDIDATE: draft|issued|advised|confirmed|amended|utilized|expired|cancelled — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Lc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lcType rdf:type rdf:Property ;
    rdfs:label 'Lc Type' ;
    rdfs:comment 'Classification of the Letter of Credit based on payment terms and transferability. Sight: payable on presentation. Usance: payable at a future date. Deferred Payment: payment deferred without draft. Acceptance: draft accepted for future payment. Standby: guarantee instrument. Transferable: can be transferred to secondary beneficiary.' ;
    rdfs:domain ind:Lc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partialShipmentAllowed rdf:type rdf:Property ;
    rdfs:label 'Partial Shipment Allowed' ;
    rdfs:comment 'Indicates whether the beneficiary is permitted to ship goods in multiple installments. True if partial shipments are allowed, False if prohibited.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:portOfDischarge rdf:type rdf:Property ;
    rdfs:label 'Port Of Discharge' ;
    rdfs:comment 'Name and country of the port or place where goods are unloaded from the vessel or transport mode at the destination.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portOfLoading rdf:type rdf:Property ;
    rdfs:label 'Port Of Loading' ;
    rdfs:comment 'Name and country of the port or place where goods are loaded onto the vessel or transport mode for shipment to the destination.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:presentationPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Presentation Period Days' ;
    rdfs:comment 'Number of days after shipment date within which documents must be presented to the nominated bank. Defaults to 21 days per UCP 600 Article 14(c) if not specified.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reimbursementBankBic rdf:type rdf:Property ;
    rdfs:label 'Reimbursement Bank Bic' ;
    rdfs:comment 'SWIFT BIC code of the bank authorized to reimburse the nominated or confirming bank upon receipt of complying documents.' ;
    rdfs:domain ind:Lc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reimbursementInstructions rdf:type rdf:Property ;
    rdfs:label 'Reimbursement Instructions' ;
    rdfs:comment 'Detailed instructions specifying how the nominated or confirming bank should claim reimbursement from the issuing or reimbursing bank, including account details and SWIFT message requirements.' ;
    rdfs:domain ind:Lc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revolvingFlag rdf:type rdf:Property ;
    rdfs:label 'Revolving Flag' ;
    rdfs:comment 'Indicates whether this is a revolving Letter of Credit that automatically reinstates its value after each drawing, allowing multiple shipments under a single LC.' ;
    rdfs:domain ind:Lc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revolvingFrequency rdf:type rdf:Property ;
    rdfs:label 'Revolving Frequency' ;
    rdfs:comment 'For revolving LCs, the period at which the credit amount reinstates. Applicable only when revolving_flag is True.' ;
    rdfs:domain ind:Lc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialConditions rdf:type rdf:Property ;
    rdfs:label 'Special Conditions' ;
    rdfs:comment 'Additional terms, conditions, or documentary requirements specific to this Letter of Credit beyond standard UCP 600 provisions. May include inspection certificates, insurance requirements, or specific document clauses.' ;
    rdfs:domain ind:Lc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tolerancePercentage rdf:type rdf:Property ;
    rdfs:label 'Tolerance Percentage' ;
    rdfs:comment 'Permitted variance (plus or minus) in the LC amount and quantity, typically 10% unless otherwise specified. Allows for minor discrepancies in commercial invoices.' ;
    rdfs:domain ind:Lc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transferableFlag rdf:type rdf:Property ;
    rdfs:label 'Transferable Flag' ;
    rdfs:comment 'Indicates whether the beneficiary has the right to transfer all or part of the Letter of Credit to one or more second beneficiaries. Must be explicitly stated as transferable.' ;
    rdfs:domain ind:Lc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transhipmentAllowed rdf:type rdf:Property ;
    rdfs:label 'Transhipment Allowed' ;
    rdfs:comment 'Indicates whether goods may be transferred from one vessel to another during transit. True if transhipment is permitted, False if prohibited.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Unit Of Measure' ;
    rdfs:comment 'Standard unit in which the quantity is expressed (e.g., metric tons, pieces, liters, barrels, containers).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utilizedAmount rdf:type rdf:Property ;
    rdfs:label 'Utilized Amount' ;
    rdfs:comment 'Cumulative amount that has been drawn or claimed against the Letter of Credit through complying presentations and payments.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lcDrawingId rdf:type rdf:Property ;
    rdfs:label 'Lc Drawing Id' ;
    rdfs:comment 'Unique identifier for the LC drawing or amendment transaction record.' ;
    rdfs:domain ind:LcDrawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:correspondentBankId rdf:type rdf:Property ;
    rdfs:label 'Correspondent Bank Id' ;
    rdfs:comment 'Identifier of the nominated bank that negotiated the drawing. Applicable when transaction_type is drawing and negotiation_flag is true.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CorrespondentBank .

ind:primaryLcEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Lc Employee Id' ;
    rdfs:comment 'Identifier of the user or system that created this transaction record.' ;
    rdfs:domain ind:LcDrawing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:amendedFieldName rdf:type rdf:Property ;
    rdfs:label 'Amended Field Name' ;
    rdfs:comment 'Name of the LC field being amended (e.g., lc_amount, expiry_date, document_requirements). Applicable when transaction_type is amendment.' ;
    rdfs:domain ind:LcDrawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Amendment Compliance Flag' ;
    rdfs:comment 'Indicator of whether the amendment complies with UCP 600 and internal bank policies. Applicable when transaction_type is amendment.' ;
    rdfs:domain ind:LcDrawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:amendmentRequestDate rdf:type rdf:Property ;
    rdfs:label 'Amendment Request Date' ;
    rdfs:comment 'Date on which the amendment was formally requested by the applicant or issuing bank. Applicable when transaction_type is amendment.' ;
    rdfs:domain ind:LcDrawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:amendmentType rdf:type rdf:Property ;
    rdfs:label 'Amendment Type' ;
    rdfs:comment 'Classification of the amendment action when transaction_type is amendment. Specifies the nature of the change being requested.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availableBalanceAfterTransaction rdf:type rdf:Property ;
    rdfs:label 'Available Balance After Transaction' ;
    rdfs:comment 'Remaining available balance on the LC after this drawing or amendment is processed.' ;
    rdfs:domain ind:LcDrawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:beneficiaryAcceptanceDate rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Acceptance Date' ;
    rdfs:comment 'Date on which the beneficiary formally accepted or rejected the amendment. Applicable when transaction_type is amendment.' ;
    rdfs:domain ind:LcDrawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:beneficiaryAcceptanceStatus rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Acceptance Status' ;
    rdfs:comment 'Status indicating whether the beneficiary has accepted, rejected, or not yet responded to the amendment per UCP 600 Article 10. Applicable when transaction_type is amendment.' ;
    rdfs:domain ind:LcDrawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discrepancyCode rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Code' ;
    rdfs:comment 'Standardized code classifying the type of discrepancy (e.g., late presentation, missing document, inconsistent data). Applicable when transaction_type is drawing.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discrepancyDescription rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Description' ;
    rdfs:comment 'Detailed description of any discrepancies found in the presented documents, following ISBP 745 standards. Applicable when transaction_type is drawing and discrepancy_flag is true.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discrepancyFlag rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Flag' ;
    rdfs:comment 'Indicator of whether discrepancies were identified in the presented documents per ISBP 745 examination standards. Applicable when transaction_type is drawing.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:documentSetReference rdf:type rdf:Property ;
    rdfs:label 'Document Set Reference' ;
    rdfs:comment 'Reference identifier for the set of documents presented with the drawing (e.g., bill of lading, commercial invoice, certificate of origin). Applicable when transaction_type is drawing.' ;
    rdfs:domain ind:LcDrawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drawingAmount rdf:type rdf:Property ;
    rdfs:label 'Drawing Amount' ;
    rdfs:comment 'Monetary value of the drawing being claimed by the beneficiary. Applicable when transaction_type is drawing.' ;
    rdfs:domain ind:LcDrawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:drawingCurrency rdf:type rdf:Property ;
    rdfs:label 'Drawing Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the drawing amount. Applicable when transaction_type is drawing.' ;
    rdfs:domain ind:LcDrawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:honourDecision rdf:type rdf:Property ;
    rdfs:label 'Honour Decision' ;
    rdfs:comment 'Decision by the issuing or nominated bank to honour or dishonour the drawing based on document examination. Applicable when transaction_type is drawing.' ;
    rdfs:domain ind:LcDrawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:honourDecisionDate rdf:type rdf:Property ;
    rdfs:label 'Honour Decision Date' ;
    rdfs:comment 'Date on which the honour or dishonour decision was made by the bank. Applicable when transaction_type is drawing.' ;
    rdfs:domain ind:LcDrawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:issuingBankApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Issuing Bank Approval Date' ;
    rdfs:comment 'Date on which the issuing bank approved and issued the amendment. Applicable when transaction_type is amendment.' ;
    rdfs:domain ind:LcDrawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:negotiationFlag rdf:type rdf:Property ;
    rdfs:label 'Negotiation Flag' ;
    rdfs:comment 'Indicator of whether the drawing was negotiated by a nominated bank before presentation to the issuing bank. Applicable when transaction_type is drawing.' ;
    rdfs:domain ind:LcDrawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:newValue rdf:type rdf:Property ;
    rdfs:label 'New Value' ;
    rdfs:comment 'Updated value of the amended field after the amendment. Stored as string to accommodate various data types. Applicable when transaction_type is amendment.' ;
    rdfs:domain ind:LcDrawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partialDrawingFlag rdf:type rdf:Property ;
    rdfs:label 'Partial Drawing Flag' ;
    rdfs:comment 'Indicator of whether this drawing represents a partial utilization of the LC available balance. Applicable when transaction_type is drawing.' ;
    rdfs:domain ind:LcDrawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorValue rdf:type rdf:Property ;
    rdfs:label 'Prior Value' ;
    rdfs:comment 'Original value of the amended field before the amendment. Stored as string to accommodate various data types. Applicable when transaction_type is amendment.' ;
    rdfs:domain ind:LcDrawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waiverResponseDate rdf:type rdf:Property ;
    rdfs:label 'Waiver Response Date' ;
    rdfs:comment 'Date on which the applicant responded to the waiver request. Applicable when transaction_type is drawing.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lenderParticipationId rdf:type rdf:Property ;
    rdfs:label 'Lender Participation Id' ;
    rdfs:comment 'Unique identifier for the lender participation record in the syndicated loan facility.' ;
    rdfs:domain ind:LenderParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:loanSyndicationId rdf:type rdf:Property ;
    rdfs:label 'Loan Syndication Id' ;
    rdfs:comment 'Reference to the parent syndicated loan facility in which this lender participates.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LoanSyndication .

ind:primaryLenderPartyId rdf:type rdf:Property ;
    rdfs:label 'Primary Lender Party Id' ;
    rdfs:comment 'Reference to the financial institution participating as a lender in the syndicated facility.' ;
    rdfs:domain ind:LenderParticipation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:collateralAllocationPercentage rdf:type rdf:Property ;
    rdfs:label 'Collateral Allocation Percentage' ;
    rdfs:comment 'Lender\'s pro-rata share of collateral securing the syndicated facility, expressed as decimal (e.g., 0.1250 for 12.50%), used for recovery calculations in default scenarios.' ;
    rdfs:domain ind:LenderParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commitmentAmount rdf:type rdf:Property ;
    rdfs:label 'Commitment Amount' ;
    rdfs:comment 'Total committed capital amount that the lender has agreed to provide to the syndicated facility, representing the maximum exposure.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commitmentFeeRate rdf:type rdf:Property ;
    rdfs:label 'Commitment Fee Rate' ;
    rdfs:comment 'Annual fee rate charged on the unfunded commitment portion, expressed as decimal percentage (e.g., 0.0050 for 0.50% or 50 basis points).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fundedAmount rdf:type rdf:Property ;
    rdfs:label 'Funded Amount' ;
    rdfs:comment 'Actual amount of capital that the lender has disbursed or drawn down from their commitment to date.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Last Payment Date' ;
    rdfs:comment 'Date of the most recent principal or interest payment received by the lender on this participation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextPaymentDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Payment Due Date' ;
    rdfs:comment 'Date on which the next scheduled principal or interest payment is due to the lender.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:participationRole rdf:type rdf:Property ;
    rdfs:label 'Participation Role' ;
    rdfs:comment 'Functional role of the lender in the syndicate structure: lead arranger (organizes syndicate), bookrunner (manages allocation), agent (administrative duties), co-agent (supporting agent), participant (passive lender), or underwriter (guarantees placement).' ;
    rdfs:domain ind:LenderParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:participationStatus rdf:type rdf:Property ;
    rdfs:label 'Participation Status' ;
    rdfs:comment 'Current lifecycle status of the lender participation: active (operational), pending (awaiting settlement), settled (funds transferred), terminated (participation ended), defaulted (borrower default), or transferred (sold to another lender).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:participationType rdf:type rdf:Property ;
    rdfs:label 'Participation Type' ;
    rdfs:comment 'Classification of the lender\'s participation structure: primary syndication member, sub-participation (unfunded risk transfer), assignment (funded transfer with borrower consent), novation (full replacement), risk participation (credit risk transfer only), or funded participation (capital commitment).' ;
    rdfs:domain ind:LenderParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proRataSharePercentage rdf:type rdf:Property ;
    rdfs:label 'Pro Rata Share Percentage' ;
    rdfs:comment 'Lender\'s proportional ownership percentage of the total syndicated facility, used for fee distribution and payment allocation calculations. Expressed as decimal (e.g., 0.1250 for 12.50%).' ;
    rdfs:domain ind:LenderParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:syndicationTier rdf:type rdf:Property ;
    rdfs:label 'Syndication Tier' ;
    rdfs:comment 'Seniority tier of the lender\'s participation in the capital structure: senior (first lien priority), mezzanine (second lien), subordinated (unsecured), or junior (lowest priority).' ;
    rdfs:domain ind:LenderParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferPremiumDiscount rdf:type rdf:Property ;
    rdfs:label 'Transfer Premium Discount' ;
    rdfs:comment 'Difference between transfer price and par value of the participation, representing premium (positive) or discount (negative) paid in secondary market transaction.' ;
    rdfs:domain ind:LenderParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transferPrice rdf:type rdf:Property ;
    rdfs:label 'Transfer Price' ;
    rdfs:comment 'Purchase price paid by the lender when acquiring the participation through secondary market assignment or sub-participation, may differ from par value.' ;
    rdfs:domain ind:LenderParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unfundedCommitment rdf:type rdf:Property ;
    rdfs:label 'Unfunded Commitment' ;
    rdfs:comment 'Remaining undrawn portion of the lender\'s commitment, calculated as commitment_amount minus funded_amount, representing contingent exposure.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:votingRightsFlag rdf:type rdf:Property ;
    rdfs:label 'Voting Rights Flag' ;
    rdfs:comment 'Indicates whether the lender retains voting rights on material amendments, waivers, and consents under the credit agreement. True if voting rights are held, false if waived or transferred.' ;
    rdfs:domain ind:LenderParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:accruedFees rdf:type rdf:Property ;
    rdfs:label 'Accrued Fees' ;
    rdfs:comment 'Fees accrued but not yet paid, including late fees, servicing fees, and other charges.' ;
    rdfs:domain ind:LoanAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chargeOffAmount rdf:type rdf:Property ;
    rdfs:label 'Charge Off Amount' ;
    rdfs:comment 'Total amount charged off including principal, interest, and fees. Used for loss reporting and recovery tracking.' ;
    rdfs:domain ind:LoanAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chargeOffDate rdf:type rdf:Property ;
    rdfs:label 'Charge Off Date' ;
    rdfs:comment 'Date when the loan was charged off as a loss. Triggers removal from performing assets and loss recognition.' ;
    rdfs:domain ind:LoanAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cureDate rdf:type rdf:Property ;
    rdfs:label 'Cure Date' ;
    rdfs:comment 'Date when a previously delinquent or non-performing loan returned to current status. Used for NPL lifecycle tracking.' ;
    rdfs:domain ind:LoanAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:currentInterestRate rdf:type rdf:Property ;
    rdfs:label 'Current Interest Rate' ;
    rdfs:comment 'Current annual interest rate applied to the loan account, expressed as a decimal (e.g., 0.05250 for 5.25%).' ;
    rdfs:domain ind:LoanAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:delinquencyBucket rdf:type rdf:Property ;
    rdfs:label 'Delinquency Bucket' ;
    rdfs:comment 'Days past due classification bucket. Used for aging analysis, collection prioritization, and regulatory reporting.' ;
    rdfs:domain ind:LoanAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstPaymentDate rdf:type rdf:Property ;
    rdfs:label 'First Payment Date' ;
    rdfs:comment 'Date when the first scheduled payment was or will be due. Used for amortization schedule calculations.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:forbearanceEndDate rdf:type rdf:Property ;
    rdfs:label 'Forbearance End Date' ;
    rdfs:comment 'Scheduled date when forbearance or modification period ends. Null if not under forbearance.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:forbearanceFlag rdf:type rdf:Property ;
    rdfs:label 'Forbearance Flag' ;
    rdfs:comment 'Indicates whether the loan is under forbearance or modification due to borrower hardship. Impacts regulatory reporting.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:forbearanceStartDate rdf:type rdf:Property ;
    rdfs:label 'Forbearance Start Date' ;
    rdfs:comment 'Date when forbearance or modification period began. Null if not under forbearance.' ;
    rdfs:domain ind:LoanAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:loanType rdf:type rdf:Property ;
    rdfs:label 'Loan Type' ;
    rdfs:comment 'Classification of the loan product type. Determines amortization rules, covenant requirements, and regulatory treatment.' ;
    rdfs:domain ind:LoanAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nplClassification rdf:type rdf:Property ;
    rdfs:label 'Npl Classification' ;
    rdfs:comment 'Regulatory classification of credit quality for non-performing loans. Drives provisioning requirements under CECL and IFRS 9.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nplClassificationDate rdf:type rdf:Property ;
    rdfs:label 'Npl Classification Date' ;
    rdfs:comment 'Date when the loan was first classified as non-performing. Triggers regulatory reporting and provisioning requirements.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nplTriggerEvent rdf:type rdf:Property ;
    rdfs:label 'Npl Trigger Event' ;
    rdfs:comment 'Event that caused the loan to be classified as non-performing. Used for root cause analysis and loss mitigation.' ;
    rdfs:domain ind:LoanAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalLoanAmount rdf:type rdf:Property ;
    rdfs:label 'Original Loan Amount' ;
    rdfs:comment 'Principal amount disbursed at loan origination. Used for LTV (Loan-to-Value) and amortization calculations.' ;
    rdfs:domain ind:LoanAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outstandingPrincipalBalance rdf:type rdf:Property ;
    rdfs:label 'Outstanding Principal Balance' ;
    rdfs:comment 'Current principal amount outstanding on the loan account. Excludes accrued interest and fees.' ;
    rdfs:domain ind:LoanAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateResetDate rdf:type rdf:Property ;
    rdfs:label 'Rate Reset Date' ;
    rdfs:comment 'Next scheduled date when the interest rate will be recalculated for floating rate loans.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryClassificationBasis rdf:type rdf:Property ;
    rdfs:label 'Regulatory Classification Basis' ;
    rdfs:comment 'Regulatory framework used for loan classification and provisioning. Determines reporting requirements.' ;
    rdfs:domain ind:LoanAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalExposure rdf:type rdf:Property ;
    rdfs:label 'Total Exposure' ;
    rdfs:comment 'Total amount owed by the borrower including principal, accrued interest, and fees. Used for EAD (Exposure at Default) calculations.' ;
    rdfs:domain ind:LoanAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:watchListDate rdf:type rdf:Property ;
    rdfs:label 'Watch List Date' ;
    rdfs:comment 'Date when the loan was added to the credit watch list. Null if not on watch list.' ;
    rdfs:domain ind:LoanAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:loanEclProvisionId rdf:type rdf:Property ;
    rdfs:label 'Loan Ecl Provision Id' ;
    rdfs:comment 'Unique identifier for the expected credit loss provision record.' ;
    rdfs:domain ind:LoanEclProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountingFramework rdf:type rdf:Property ;
    rdfs:label 'Accounting Framework' ;
    rdfs:comment 'The accounting standard under which this provision is calculated (IFRS 9, CECL/ASC 326, or Local GAAP).' ;
    rdfs:domain ind:LoanEclProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditImpairedIndicator rdf:type rdf:Property ;
    rdfs:label 'Credit Impaired Indicator' ;
    rdfs:comment 'Boolean flag indicating whether the loan is credit-impaired (Stage 3 under IFRS 9 or NPL status).' ;
    rdfs:domain ind:LoanEclProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cumulativeProvisionAmount rdf:type rdf:Property ;
    rdfs:label 'Cumulative Provision Amount' ;
    rdfs:comment 'The total accumulated provision balance for this loan as of the reporting date.' ;
    rdfs:domain ind:LoanEclProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ead rdf:type rdf:Property ;
    rdfs:label 'Ead' ;
    rdfs:comment 'The total value of the loan exposure at the time of default, including drawn and undrawn committed amounts.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eclModelCode rdf:type rdf:Property ;
    rdfs:label 'Ecl Model Code' ;
    rdfs:comment 'Identifier of the ECL calculation model or methodology used (e.g., PD/LGD/EAD model, vintage analysis, roll-rate model).' ;
    rdfs:domain ind:LoanEclProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forbearanceIndicator rdf:type rdf:Property ;
    rdfs:label 'Forbearance Indicator' ;
    rdfs:comment 'Boolean flag indicating whether the loan is under forbearance or modification due to borrower financial difficulty.' ;
    rdfs:domain ind:LoanEclProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lgd rdf:type rdf:Property ;
    rdfs:label 'Lgd' ;
    rdfs:comment 'The estimated percentage of exposure that will be lost if the borrower defaults, expressed as a decimal (e.g., 0.45 = 45%).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pd rdf:type rdf:Property ;
    rdfs:label 'Pd' ;
    rdfs:comment 'The probability that the borrower will default over the relevant time horizon (12-month or lifetime), expressed as a decimal (e.g., 0.025 = 2.5%).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:previousStageClassification rdf:type rdf:Property ;
    rdfs:label 'Previous Stage Classification' ;
    rdfs:comment 'The credit risk stage classification in the prior reporting period, used to track stage migrations.' ;
    rdfs:domain ind:LoanEclProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:provisionAmount rdf:type rdf:Property ;
    rdfs:label 'Provision Amount' ;
    rdfs:comment 'The calculated expected credit loss provision amount for this loan at the reporting date.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:provisionCurrency rdf:type rdf:Property ;
    rdfs:label 'Provision Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the provision amount.' ;
    rdfs:domain ind:LoanEclProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:provisionMovementAmount rdf:type rdf:Property ;
    rdfs:label 'Provision Movement Amount' ;
    rdfs:comment 'The net change in provision amount for this period (positive for increases, negative for releases).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:provisionMovementType rdf:type rdf:Property ;
    rdfs:label 'Provision Movement Type' ;
    rdfs:comment 'The type of movement in the provision balance: New (initial provision), Increase (additional provision), Decrease (partial release), Release (full release), Write-Off (charge-off against provision), Transfer (stage migration).' ;
    rdfs:domain ind:LoanEclProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:provisionNumber rdf:type rdf:Property ;
    rdfs:label 'Provision Number' ;
    rdfs:comment 'Business identifier for the provision record, used for external reporting and audit trails.' ;
    rdfs:domain ind:LoanEclProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recoveryRate rdf:type rdf:Property ;
    rdfs:label 'Recovery Rate' ;
    rdfs:comment 'The expected recovery rate in the event of default, expressed as a decimal (1 - LGD).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryReportingIndicator rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this provision record is included in regulatory capital and stress testing reports (Basel III, CCAR, DFAST).' ;
    rdfs:domain ind:LoanEclProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportingPeriodDate rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Date' ;
    rdfs:comment 'The financial reporting period end date for which this ECL provision is calculated (e.g., quarter-end, year-end).' ;
    rdfs:domain ind:LoanEclProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scenarioWeight rdf:type rdf:Property ;
    rdfs:label 'Scenario Weight' ;
    rdfs:comment 'The probability weight assigned to this macroeconomic scenario in the weighted-average ECL calculation, expressed as a decimal (e.g., 0.60 = 60%).' ;
    rdfs:domain ind:LoanEclProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:significantIncreaseIndicator rdf:type rdf:Property ;
    rdfs:label 'Significant Increase Indicator' ;
    rdfs:comment 'Boolean flag indicating whether there has been a significant increase in credit risk since initial recognition (triggers Stage 2 under IFRS 9).' ;
    rdfs:domain ind:LoanEclProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stageMigrationDate rdf:type rdf:Property ;
    rdfs:label 'Stage Migration Date' ;
    rdfs:comment 'The date when the loan migrated to the current stage classification, if applicable.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:timeToDefaultMonths rdf:type rdf:Property ;
    rdfs:label 'Time To Default Months' ;
    rdfs:comment 'The estimated time horizon in months over which the default probability is measured (12 for Stage 1, lifetime for Stage 2/3).' ;
    rdfs:domain ind:LoanEclProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryLoanPartyId rdf:type rdf:Property ;
    rdfs:label 'Primary Loan Party Id' ;
    rdfs:comment 'Reference to the financial institution serving as lead arranger responsible for structuring the syndication, marketing to potential lenders, and coordinating the syndicate formation.' ;
    rdfs:domain ind:LoanSyndication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:allocationMethodology rdf:type rdf:Property ;
    rdfs:label 'Allocation Methodology' ;
    rdfs:comment 'Method used by lead arrangers to allocate participations when syndication is oversubscribed. First come first served honors commitment timing; relationship based favors key bank relationships; pro rata scale reduces all commitments proportionally; tiered priority uses commitment size tiers.' ;
    rdfs:domain ind:LoanSyndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arrangerFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Arranger Fee Amount' ;
    rdfs:comment 'Total fee paid to lead arranger(s) for structuring and syndicating the loan. Separate from upfront fees paid to all lenders. Confidential commercial term.' ;
    rdfs:domain ind:LoanSyndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:borrowerConsentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Borrower Consent Required Flag' ;
    rdfs:comment 'Indicates whether borrower consent is required for lender assignments or participations. True means borrower has approval rights over syndicate composition changes; false allows free transferability subject only to credit criteria.' ;
    rdfs:domain ind:LoanSyndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commitmentDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Commitment Deadline Date' ;
    rdfs:comment 'Final date by which prospective lenders must submit binding commitments to participate in the syndication. After this date, allocations are finalized and late commitments are not accepted.' ;
    rdfs:domain ind:LoanSyndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:confidentialityTier rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Tier' ;
    rdfs:comment 'Level of confidentiality assigned to syndication information. Public allows broad distribution; private restricts to committed lenders; highly confidential limits to lead arrangers and named parties only.' ;
    rdfs:domain ind:LoanSyndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finalPricingSpreadBps rdf:type rdf:Property ;
    rdfs:label 'Final Pricing Spread Bps' ;
    rdfs:comment 'Final agreed pricing spread over the reference rate in basis points at syndication close. May differ from original spread if market flex was exercised. Represents the actual pricing achieved in the market.' ;
    rdfs:domain ind:LoanSyndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:flexExercisedFlag rdf:type rdf:Property ;
    rdfs:label 'Flex Exercised Flag' ;
    rdfs:comment 'Indicates whether the lead arrangers exercised market flex provisions to modify loan terms during syndication. True indicates terms were adjusted from initial launch parameters to achieve full placement.' ;
    rdfs:domain ind:LoanSyndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:greenLoanFlag rdf:type rdf:Property ;
    rdfs:label 'Green Loan Flag' ;
    rdfs:comment 'Indicates whether the syndicated loan qualifies as a green loan under Loan Market Association Green Loan Principles, with proceeds dedicated to environmentally beneficial projects and subject to sustainability reporting requirements.' ;
    rdfs:domain ind:LoanSyndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lenderMeetingDate rdf:type rdf:Property ;
    rdfs:label 'Lender Meeting Date' ;
    rdfs:comment 'Date of the formal lender presentation or bank meeting where the borrower and lead arrangers presented the credit opportunity to prospective syndicate participants. Key milestone in the marketing process.' ;
    rdfs:domain ind:LoanSyndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:marketFlexProvision rdf:type rdf:Property ;
    rdfs:label 'Market Flex Provision' ;
    rdfs:comment 'Type of flexibility granted to lead arrangers to adjust loan terms if market conditions require changes to achieve successful syndication. Pricing flex allows rate adjustments; structure flex allows covenant or maturity changes; full flex allows both; none means terms are locked.' ;
    rdfs:domain ind:LoanSyndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumHoldAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Hold Amount' ;
    rdfs:comment 'Minimum commitment amount that the lead arranger has contractually agreed to retain. Demonstrates skin in the game and alignment with syndicate lenders.' ;
    rdfs:domain ind:LoanSyndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:numberOfLenders rdf:type rdf:Property ;
    rdfs:label 'Number Of Lenders' ;
    rdfs:comment 'Total count of financial institutions participating in the syndicate as lenders. Includes lead arrangers, co-arrangers, and participating lenders at all commitment tiers.' ;
    rdfs:domain ind:LoanSyndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalPricingSpreadBps rdf:type rdf:Property ;
    rdfs:label 'Original Pricing Spread Bps' ;
    rdfs:comment 'Initial pricing spread over the reference rate (SOFR, LIBOR, etc.) in basis points at syndication launch. Used to track pricing flex if terms were adjusted during marketing.' ;
    rdfs:domain ind:LoanSyndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:oversubscriptionFlag rdf:type rdf:Property ;
    rdfs:label 'Oversubscription Flag' ;
    rdfs:comment 'Indicates whether the syndication received commitments exceeding the target amount, requiring allocation scaling. True indicates strong market demand and potential for improved pricing terms.' ;
    rdfs:domain ind:LoanSyndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:proRataSharingFlag rdf:type rdf:Property ;
    rdfs:label 'Pro Rata Sharing Flag' ;
    rdfs:comment 'Indicates whether all syndicate lenders share pro rata in payments, collateral, and recoveries based on their commitment percentages. True enforces equal treatment; false allows priority structures.' ;
    rdfs:domain ind:LoanSyndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recordSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Record Source System' ;
    rdfs:comment 'Name of the operational system that originated this syndication record (e.g., Finastra Fusion Loan IQ, Murex, custom syndication platform). Used for data lineage and reconciliation across enterprise systems.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryHoldLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Regulatory Hold Limit Amount' ;
    rdfs:comment 'Maximum amount that the lead arranger is permitted to retain on its own balance sheet under regulatory large exposure limits. Drives minimum syndication distribution requirements.' ;
    rdfs:domain ind:LoanSyndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sustainabilityLinkedFlag rdf:type rdf:Property ;
    rdfs:label 'Sustainability Linked Flag' ;
    rdfs:comment 'Indicates whether the loan includes sustainability-linked pricing mechanisms where the interest margin adjusts based on the borrower\'s achievement of predefined Environmental, Social, and Governance (ESG) performance targets.' ;
    rdfs:domain ind:LoanSyndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalSyndicatedAmount rdf:type rdf:Property ;
    rdfs:label 'Total Syndicated Amount' ;
    rdfs:comment 'Total facility amount being syndicated across all participating lenders. Represents the aggregate commitment that will be distributed among syndicate members.' ;
    rdfs:domain ind:LoanSyndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transferRestrictionType rdf:type rdf:Property ;
    rdfs:label 'Transfer Restriction Type' ;
    rdfs:comment 'Classification of restrictions on secondary market transfers of syndicate participations. Freely transferable allows unrestricted assignment; consent required needs borrower or agent approval; restricted list limits transfers to approved institutions; prohibited blocks all transfers.' ;
    rdfs:domain ind:LoanSyndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:votingThresholdPct rdf:type rdf:Property ;
    rdfs:label 'Voting Threshold Pct' ;
    rdfs:comment 'Percentage of syndicate lender commitments required to approve material amendments or waivers to the loan agreement. Typically 50%, 66.67%, or 100% depending on the action type.' ;
    rdfs:domain ind:LoanSyndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modificationId rdf:type rdf:Property ;
    rdfs:label 'Modification Id' ;
    rdfs:comment 'Primary key for modification' ;
    rdfs:domain ind:Modification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvingAuthority rdf:type rdf:Property ;
    rdfs:label 'Approving Authority' ;
    rdfs:comment 'The name or title of the credit authority (individual, committee, or board) that approved this modification.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvingAuthorityLevel rdf:type rdf:Property ;
    rdfs:label 'Approving Authority Level' ;
    rdfs:comment 'The hierarchical level of the approving authority. Indicates the escalation tier required for this modification based on risk and materiality.' ;
    rdfs:domain ind:Modification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ceclStageAfter rdf:type rdf:Property ;
    rdfs:label 'Cecl Stage After' ;
    rdfs:comment 'The CECL impairment stage classification of the loan after the modification is applied. Used to track stage migration resulting from the modification.' ;
    rdfs:domain ind:Modification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ceclStageBefore rdf:type rdf:Property ;
    rdfs:label 'Cecl Stage Before' ;
    rdfs:comment 'The CECL impairment stage classification of the loan immediately prior to the modification (Stage 1: performing, Stage 2: underperforming, Stage 3: credit-impaired).' ;
    rdfs:domain ind:Modification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collateralAdjustmentFlag rdf:type rdf:Property ;
    rdfs:label 'Collateral Adjustment Flag' ;
    rdfs:comment 'Indicates whether this modification involved changes to collateral requirements, pledges, or Loan-to-Value (LTV) ratios. True if collateral terms were adjusted.' ;
    rdfs:domain ind:Modification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:covenantWaiverFlag rdf:type rdf:Property ;
    rdfs:label 'Covenant Waiver Flag' ;
    rdfs:comment 'Indicates whether this modification includes a waiver of one or more financial or operational covenants. True if covenants were waived.' ;
    rdfs:domain ind:Modification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gainLossAmount rdf:type rdf:Property ;
    rdfs:label 'Gain Loss Amount' ;
    rdfs:comment 'The accounting gain or loss recognized as a result of the modification, calculated as the difference between the present value of the original and modified cash flows. Positive for gain, negative for loss.' ;
    rdfs:domain ind:Modification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isRegulatoryReportable rdf:type rdf:Property ;
    rdfs:label 'Is Regulatory Reportable' ;
    rdfs:comment 'Indicates whether this modification must be reported to regulatory authorities (e.g., OCC, Fed, FDIC) under applicable reporting frameworks.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTdr rdf:type rdf:Property ;
    rdfs:label 'Is Tdr' ;
    rdfs:comment 'Indicates whether this modification qualifies as a Troubled Debt Restructuring under CECL and regulatory guidance. True if the borrower is experiencing financial difficulty and the lender granted a concession.' ;
    rdfs:domain ind:Modification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:modificationDate rdf:type rdf:Property ;
    rdfs:label 'Modification Date' ;
    rdfs:comment 'The date on which the modification terms become effective and binding. This is the principal business event timestamp for the modification.' ;
    rdfs:domain ind:Modification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:modificationNumber rdf:type rdf:Property ;
    rdfs:label 'Modification Number' ;
    rdfs:comment 'Business-facing unique reference number assigned to this modification for tracking and reporting purposes.' ;
    rdfs:domain ind:Modification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modificationStatus rdf:type rdf:Property ;
    rdfs:label 'Modification Status' ;
    rdfs:comment 'Current lifecycle state of the modification request. Tracks the approval and execution workflow.' ;
    rdfs:domain ind:Modification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modificationType rdf:type rdf:Property ;
    rdfs:label 'Modification Type' ;
    rdfs:comment 'Classification of the modification action taken. Determines the nature of the amendment to the original loan terms.' ;
    rdfs:domain ind:Modification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedInterestRate rdf:type rdf:Property ;
    rdfs:label 'Modified Interest Rate' ;
    rdfs:comment 'The new interest rate applicable to the loan after this modification, expressed as a decimal. Null if rate was not changed.' ;
    rdfs:domain ind:Modification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modifiedMaturityDate rdf:type rdf:Property ;
    rdfs:label 'Modified Maturity Date' ;
    rdfs:comment 'The new maturity date of the loan after this modification is applied. Null if maturity was not changed.' ;
    rdfs:domain ind:Modification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:modifiedPrincipalAmount rdf:type rdf:Property ;
    rdfs:label 'Modified Principal Amount' ;
    rdfs:comment 'The principal balance after applying any forgiveness, capitalization, or other principal adjustments. Null if principal was not changed.' ;
    rdfs:domain ind:Modification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nplStatusAfter rdf:type rdf:Property ;
    rdfs:label 'Npl Status After' ;
    rdfs:comment 'The credit quality classification of the loan after modification. Tracks whether the modification successfully cured the NPL status.' ;
    rdfs:domain ind:Modification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nplStatusBefore rdf:type rdf:Property ;
    rdfs:label 'Npl Status Before' ;
    rdfs:comment 'The credit quality classification of the loan prior to modification. Used to assess whether the modification is part of NPL workout management.' ;
    rdfs:domain ind:Modification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalInterestRate rdf:type rdf:Property ;
    rdfs:label 'Original Interest Rate' ;
    rdfs:comment 'The interest rate applicable to the loan prior to this modification, expressed as a decimal (e.g., 0.0525 for 5.25%).' ;
    rdfs:domain ind:Modification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalMaturityDate rdf:type rdf:Property ;
    rdfs:label 'Original Maturity Date' ;
    rdfs:comment 'The maturity date of the loan prior to this modification. Retained for historical comparison and regulatory reporting.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originalPrincipalAmount rdf:type rdf:Property ;
    rdfs:label 'Original Principal Amount' ;
    rdfs:comment 'The outstanding principal balance of the loan at the time of modification request.' ;
    rdfs:domain ind:Modification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentDeferralMonths rdf:type rdf:Property ;
    rdfs:label 'Payment Deferral Months' ;
    rdfs:comment 'The number of months for which scheduled payments are deferred. Zero if no deferral was granted.' ;
    rdfs:domain ind:Modification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:principalForgivenessAmount rdf:type rdf:Property ;
    rdfs:label 'Principal Forgiveness Amount' ;
    rdfs:comment 'The amount of principal forgiven or written down as part of this modification. Zero if no forgiveness occurred.' ;
    rdfs:domain ind:Modification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricingId rdf:type rdf:Property ;
    rdfs:label 'Pricing Id' ;
    rdfs:comment 'Unique identifier for the loan pricing record. Primary key for the pricing entity.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pricingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Pricing Employee Id' ;
    rdfs:comment 'Identifier of the user who approved this pricing structure.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:pricingModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Pricing Modified By User Employee Id' ;
    rdfs:comment 'Identifier of the user who last modified this pricing record.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:benchmarkRateCode rdf:type rdf:Property ;
    rdfs:label 'Benchmark Rate Code' ;
    rdfs:comment 'Code identifying the reference benchmark rate for floating-rate loans (e.g., SOFR, LIBOR, Prime, EURIBOR, Fed Funds). Null for fixed-rate loans.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capRate rdf:type rdf:Property ;
    rdfs:label 'Cap Rate' ;
    rdfs:comment 'The maximum interest rate that can be charged on the loan, providing borrower protection against rate increases. Expressed as a decimal. Null if no cap applies.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:defaultRate rdf:type rdf:Property ;
    rdfs:label 'Default Rate' ;
    rdfs:comment 'The penalty interest rate applied when the borrower is in default or breach of loan covenants. Expressed as a decimal. Null if no default rate provision exists.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:defaultSpreadBps rdf:type rdf:Property ;
    rdfs:label 'Default Spread Bps' ;
    rdfs:comment 'Additional spread in basis points added to the standard rate upon default or covenant breach. Null if no default spread applies.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:floorRate rdf:type rdf:Property ;
    rdfs:label 'Floor Rate' ;
    rdfs:comment 'The minimum interest rate that can be charged on the loan, regardless of how low the benchmark rate falls. Expressed as a decimal. Null if no floor applies.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lgdAtPricing rdf:type rdf:Property ;
    rdfs:label 'Lgd At Pricing' ;
    rdfs:comment 'The estimated loss given default (LGD) at the time of pricing, expressed as a decimal (e.g., 0.4500 for 45%). Used for expected loss calculation in pricing models.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marginRate rdf:type rdf:Property ;
    rdfs:label 'Margin Rate' ;
    rdfs:comment 'Additional margin or adjustment rate applied on top of the base rate and spread, often used for risk-based pricing adjustments. Expressed as a decimal.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modelCode rdf:type rdf:Property ;
    rdfs:label 'Model Code' ;
    rdfs:comment 'Code identifying the pricing model or methodology used to determine the rate structure (e.g., cost-plus, risk-based, relationship, competitive).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextRepricingDate rdf:type rdf:Property ;
    rdfs:label 'Next Repricing Date' ;
    rdfs:comment 'The next scheduled date on which the interest rate will be recalculated or reset based on the repricing frequency.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pdAtPricing rdf:type rdf:Property ;
    rdfs:label 'Pd At Pricing' ;
    rdfs:comment 'The estimated probability of default (PD) for the borrower at the time of pricing, expressed as a decimal (e.g., 0.0250 for 2.50%). Used for risk-based pricing validation.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prepaymentPenaltyRate rdf:type rdf:Property ;
    rdfs:label 'Prepayment Penalty Rate' ;
    rdfs:comment 'The penalty rate or fee percentage charged when the borrower prepays the loan before maturity. Expressed as a decimal. Null if no prepayment penalty applies.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricingStatus rdf:type rdf:Property ;
    rdfs:label 'Pricing Status' ;
    rdfs:comment 'Current lifecycle status of the pricing record: active (currently in effect), inactive (not in use), pending (approved but not yet effective), superseded (replaced by newer pricing), or expired (past expiration date).' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingType rdf:type rdf:Property ;
    rdfs:label 'Pricing Type' ;
    rdfs:comment 'Classification of the interest rate structure: fixed (constant rate), floating (variable rate tied to benchmark), hybrid (combination of fixed and floating periods), tiered (rate varies by balance or utilization), step-up (rate increases over time), or step-down (rate decreases over time).' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rarocAtPricing rdf:type rdf:Property ;
    rdfs:label 'Raroc At Pricing' ;
    rdfs:comment 'The calculated risk-adjusted return on capital (RAROC) at the time of pricing, expressed as a decimal. Used to validate that pricing meets minimum return hurdles.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateLockExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Rate Lock Expiration Date' ;
    rdfs:comment 'The date on which a rate lock expires if the loan has not closed. Null if no rate lock is in effect.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rateLockFlag rdf:type rdf:Property ;
    rdfs:label 'Rate Lock Flag' ;
    rdfs:comment 'Indicates whether the interest rate is locked (true) or subject to change before loan closing (false). Commonly used during loan origination period.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:relationshipDiscountBps rdf:type rdf:Property ;
    rdfs:label 'Relationship Discount Bps' ;
    rdfs:comment 'Discount in basis points granted based on the overall banking relationship value. Null if no relationship discount applies.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:repricingFrequency rdf:type rdf:Property ;
    rdfs:label 'Repricing Frequency' ;
    rdfs:comment 'The frequency at which the interest rate is recalculated or reset for floating-rate loans. For fixed-rate loans, this is typically \'at_maturity\'. [ENUM-REF-CANDIDATE: daily|weekly|monthly|quarterly|semi_annually|annually|at_maturity|on_demand — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskRatingAtPricing rdf:type rdf:Property ;
    rdfs:label 'Risk Rating At Pricing' ;
    rdfs:comment 'The internal credit risk rating of the borrower or facility at the time this pricing was established. Used for risk-adjusted pricing analysis.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repaymentId rdf:type rdf:Property ;
    rdfs:label 'Repayment Id' ;
    rdfs:comment 'Unique identifier for the loan repayment transaction. Primary key for the repayment data product.' ;
    rdfs:domain ind:Repayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceAccountDepositAccountId rdf:type rdf:Property ;
    rdfs:label 'Source Account Deposit Account Id' ;
    rdfs:comment 'Foreign key linking to account.deposit_account. Business justification: Direct operational requirement: loan repayments are debited from specific customer deposit accounts. Existing source_account_number is denormalized string; proper FK enables automated ACH/direct debit' ;
    rdfs:domain ind:Repayment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DepositAccount .

ind:outstandingBalanceAfterPayment rdf:type rdf:Property ;
    rdfs:label 'Outstanding Balance After Payment' ;
    rdfs:comment 'Remaining principal balance on the loan immediately after this repayment is applied. Critical for Exposure at Default (EAD) and credit risk calculations.' ;
    rdfs:domain ind:Repayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentProcessorCode rdf:type rdf:Property ;
    rdfs:label 'Payment Processor Code' ;
    rdfs:comment 'Identifier of the payment processing system or hub that handled this transaction. References systems such as ACI Worldwide or Volante payment platforms.' ;
    rdfs:domain ind:Repayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTimeliness rdf:type rdf:Property ;
    rdfs:label 'Payment Timeliness' ;
    rdfs:comment 'Classification of whether the payment was received on-time, early, or late relative to the scheduled_payment_date. Critical for Non-Performing Loan (NPL) classification and delinquency tracking.' ;
    rdfs:domain ind:Repayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentType rdf:type rdf:Property ;
    rdfs:label 'Payment Type' ;
    rdfs:comment 'Classification of the repayment transaction type. Scheduled indicates a regular installment; prepayment indicates early principal reduction; partial indicates less than scheduled amount; balloon indicates large lump-sum; final indicates loan payoff.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyInterestAmount rdf:type rdf:Property ;
    rdfs:label 'Penalty Interest Amount' ;
    rdfs:comment 'Portion of the payment allocated to penalty interest charges for late payment or covenant breach. Tracked separately for regulatory reporting.' ;
    rdfs:domain ind:Repayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prepaymentFlag rdf:type rdf:Property ;
    rdfs:label 'Prepayment Flag' ;
    rdfs:comment 'Indicates whether this repayment includes a prepayment component (principal paid ahead of schedule). True if prepayment occurred; false otherwise.' ;
    rdfs:domain ind:Repayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:principalAmount rdf:type rdf:Property ;
    rdfs:label 'Principal Amount' ;
    rdfs:comment 'Portion of the payment allocated to reduce the outstanding principal balance of the loan. Core component for amortization tracking.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduledPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Payment Date' ;
    rdfs:comment 'The originally scheduled due date for this repayment installment per the loan amortization schedule. Used to determine if payment is on-time, early, or late.' ;
    rdfs:domain ind:Repayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceBankBic rdf:type rdf:Property ;
    rdfs:label 'Source Bank Bic' ;
    rdfs:comment 'Bank Identifier Code (BIC) or SWIFT code of the financial institution from which the payment originated. Required for cross-border payments.' ;
    rdfs:domain ind:Repayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sanctionsScreeningId rdf:type rdf:Property ;
    rdfs:label 'Sanctions Screening Id' ;
    rdfs:comment 'Primary key for sanctions_screening' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:analystReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Analyst Review Status' ;
    rdfs:comment 'Current status of the analyst review process for potential or confirmed matches. Tracks the workflow state of the screening alert.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockedFundsAmount rdf:type rdf:Property ;
    rdfs:label 'Blocked Funds Amount' ;
    rdfs:comment 'Monetary value of funds or assets blocked as a result of the sanctions screening. Populated only when a transaction is blocked.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:blockedFundsCurrency rdf:type rdf:Property ;
    rdfs:label 'Blocked Funds Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the blocked funds amount.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:falsePositiveFlag rdf:type rdf:Property ;
    rdfs:label 'False Positive Flag' ;
    rdfs:comment 'Indicates whether the screening alert was determined to be a false positive after analyst review. Used for system tuning and reporting.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:matchResult rdf:type rdf:Property ;
    rdfs:label 'Match Result' ;
    rdfs:comment 'Outcome of the sanctions screening indicating whether the entity was cleared, flagged as a potential match, or confirmed as a match against sanctions lists.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchedListEntry rdf:type rdf:Property ;
    rdfs:label 'Matched List Entry' ;
    rdfs:comment 'Name or identifier of the sanctions list entry that matched the screened entity. Populated only when a potential or confirmed match is identified.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchedListSource rdf:type rdf:Property ;
    rdfs:label 'Matched List Source' ;
    rdfs:comment 'Source of the sanctions list that produced the match. Identifies the governing body or jurisdiction of the matched entry.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ofacNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Ofac Notification Date' ;
    rdfs:comment 'Date when OFAC was notified of the sanctions screening event. Required for blocked transactions and confirmed matches.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ofacNotificationFlag rdf:type rdf:Property ;
    rdfs:label 'Ofac Notification Flag' ;
    rdfs:comment 'Indicates whether OFAC was directly notified of a confirmed sanctions match or blocked transaction as required by OFAC regulations.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overrideTimestamp rdf:type rdf:Property ;
    rdfs:label 'Override Timestamp' ;
    rdfs:comment 'Date and time when the override was authorized and applied.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sarFilingReference rdf:type rdf:Property ;
    rdfs:label 'Sar Filing Reference' ;
    rdfs:comment 'Reference number of the Suspicious Activity Report filed with FinCEN as a result of this sanctions screening event. Populated only when a SAR is filed.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screenedEntityIdentifier rdf:type rdf:Property ;
    rdfs:label 'Screened Entity Identifier' ;
    rdfs:comment 'Unique identifier for the screened entity such as IMO number for vessels, tax ID for companies, or passport number for individuals.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningAlgorithmVersion rdf:type rdf:Property ;
    rdfs:label 'Screening Algorithm Version' ;
    rdfs:comment 'Version of the screening algorithm or matching logic used by the sanctions screening system. Important for audit and quality assurance.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningListApplied rdf:type rdf:Property ;
    rdfs:label 'Screening List Applied' ;
    rdfs:comment 'Comma-separated list of sanctions lists applied during screening. May include OFAC SDN, UN Security Council, EU Sanctions, HMT Sanctions, and other jurisdictional lists.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningListVersion rdf:type rdf:Property ;
    rdfs:label 'Screening List Version' ;
    rdfs:comment 'Version or effective date of the sanctions lists used during screening. Critical for audit trail and demonstrating use of current lists.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Screening Reference Number' ;
    rdfs:comment 'Business identifier for the sanctions screening event, used for audit trail and regulatory reporting.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionBlockedFlag rdf:type rdf:Property ;
    rdfs:label 'Transaction Blocked Flag' ;
    rdfs:comment 'Indicates whether the trade finance transaction was blocked as a result of the sanctions screening. Blocked transactions must be reported to OFAC.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supplyChainProgramId rdf:type rdf:Property ;
    rdfs:label 'Supply Chain Program Id' ;
    rdfs:comment 'Unique identifier for the supply chain finance program. Primary key.' ;
    rdfs:domain ind:SupplyChainProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:anchorCounterpartyRatingId rdf:type rdf:Property ;
    rdfs:label 'Anchor Counterparty Rating Id' ;
    rdfs:comment 'Foreign key linking to risk.counterparty_rating. Business justification: Supply chain finance program approval and credit limits depend on anchor buyer creditworthiness. Internal_risk_rating/pd/lgd/ead are denormalized rating outputs that should be sourced from counterpart' ;
    rdfs:domain ind:SupplyChainProgram ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CounterpartyRating .

ind:primarySupplyPartyId rdf:type rdf:Property ;
    rdfs:label 'Primary Supply Party Id' ;
    rdfs:comment 'Identifier of the anchor buyer (corporate customer) who establishes the program and whose payables are financed. The anchor buyer is the creditworthy entity whose payment obligation underpins the program.' ;
    rdfs:domain ind:SupplyChainProgram ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:approvedCreditLimit rdf:type rdf:Property ;
    rdfs:label 'Approved Credit Limit' ;
    rdfs:comment 'Maximum aggregate financing amount approved for the supply chain finance program across all suppliers and invoices. Represents the bank\'s total exposure limit to the program.' ;
    rdfs:domain ind:SupplyChainProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:autoApprovalThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Auto Approval Threshold Amount' ;
    rdfs:comment 'Maximum invoice amount that can be automatically approved for financing without manual credit review. Invoices exceeding this threshold require additional approval.' ;
    rdfs:domain ind:SupplyChainProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:availableCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Available Credit Amount' ;
    rdfs:comment 'Remaining financing capacity available under the program, calculated as approved_credit_limit minus current_utilization_amount.' ;
    rdfs:domain ind:SupplyChainProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dilutionReservePercentage rdf:type rdf:Property ;
    rdfs:label 'Dilution Reserve Percentage' ;
    rdfs:comment 'Percentage of invoice value withheld as a reserve to cover potential dilution events such as returns, disputes, discounts, or credits that reduce the collectible amount. Expressed as a percentage (e.g., 5.00 for 5%).' ;
    rdfs:domain ind:SupplyChainProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discountRateBasis rdf:type rdf:Property ;
    rdfs:label 'Discount Rate Basis' ;
    rdfs:comment 'Methodology for calculating the discount rate applied to early payment financing. SOFR (Secured Overnight Financing Rate) spread, EURIBOR (Euro Interbank Offered Rate) spread, LIBOR (London Interbank Offered Rate) spread for legacy programs, or fixed rate option.' ;
    rdfs:domain ind:SupplyChainProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountRateSpreadBps rdf:type rdf:Property ;
    rdfs:label 'Discount Rate Spread Bps' ;
    rdfs:comment 'Spread in basis points (BPS) added to the benchmark rate (SOFR, EURIBOR, LIBOR) to determine the total discount rate charged for early payment financing. One basis point equals 0.01%.' ;
    rdfs:domain ind:SupplyChainProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eligibleSupplierCriteria rdf:type rdf:Property ;
    rdfs:label 'Eligible Supplier Criteria' ;
    rdfs:comment 'Business rules and requirements that suppliers must meet to participate in the supply chain finance program, including credit rating thresholds, geographic restrictions, industry classifications, and compliance requirements.' ;
    rdfs:domain ind:SupplyChainProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fixedDiscountRate rdf:type rdf:Property ;
    rdfs:label 'Fixed Discount Rate' ;
    rdfs:comment 'Fixed annual percentage rate applied when discount_rate_basis is set to fixed_rate. Expressed as a decimal (e.g., 0.0350 for 3.50%).' ;
    rdfs:domain ind:SupplyChainProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastCreditReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Credit Review Date' ;
    rdfs:comment 'Date of the most recent credit review conducted for the supply chain finance program, including assessment of anchor buyer creditworthiness and program risk parameters.' ;
    rdfs:domain ind:SupplyChainProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maximumTenorDays rdf:type rdf:Property ;
    rdfs:label 'Maximum Tenor Days' ;
    rdfs:comment 'Maximum number of days between invoice financing date and maturity date that the program will accept. Defines the upper bound of the eligible financing period.' ;
    rdfs:domain ind:SupplyChainProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumTenorDays rdf:type rdf:Property ;
    rdfs:label 'Minimum Tenor Days' ;
    rdfs:comment 'Minimum number of days between invoice financing date and maturity date that the program will accept. Defines the lower bound of the eligible financing period.' ;
    rdfs:domain ind:SupplyChainProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextCreditReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Credit Review Date' ;
    rdfs:comment 'Scheduled date for the next periodic credit review of the supply chain finance program. Review frequency is determined by internal risk rating and regulatory requirements.' ;
    rdfs:domain ind:SupplyChainProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:programCurrency rdf:type rdf:Property ;
    rdfs:label 'Program Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code in which the supply chain finance program operates and invoices are denominated.' ;
    rdfs:domain ind:SupplyChainProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programDocumentationReference rdf:type rdf:Property ;
    rdfs:label 'Program Documentation Reference' ;
    rdfs:comment 'Reference identifier or location of the legal documentation governing the supply chain finance program, including master agreements, terms and conditions, and operational procedures.' ;
    rdfs:domain ind:SupplyChainProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Program Reference Number' ;
    rdfs:comment 'Externally-known unique business identifier for the supply chain finance program, used in communications with anchor buyers and suppliers.' ;
    rdfs:domain ind:SupplyChainProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programStartDate rdf:type rdf:Property ;
    rdfs:label 'Program Start Date' ;
    rdfs:comment 'Effective date when the supply chain finance program became operational and began accepting invoice submissions for financing.' ;
    rdfs:domain ind:SupplyChainProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:supplierOnboardingStatus rdf:type rdf:Property ;
    rdfs:label 'Supplier Onboarding Status' ;
    rdfs:comment 'Current state of supplier enrollment into the program. Open programs accept new supplier applications; restricted programs require anchor buyer pre-approval; closed programs do not accept new suppliers.' ;
    rdfs:domain ind:SupplyChainProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalSuppliersEnrolled rdf:type rdf:Property ;
    rdfs:label 'Total Suppliers Enrolled' ;
    rdfs:comment 'Count of unique suppliers currently enrolled and active in the supply chain finance program.' ;
    rdfs:domain ind:SupplyChainProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tradeDocumentId rdf:type rdf:Property ;
    rdfs:label 'Trade Document Id' ;
    rdfs:comment 'Unique identifier for the trade finance document record. Primary key.' ;
    rdfs:domain ind:TradeDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryTradeEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Trade Employee Id' ;
    rdfs:comment 'Identifier of the bank officer or trade finance specialist who examined the document for compliance. Used for accountability and audit trail.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:compliantFlag rdf:type rdf:Property ;
    rdfs:label 'Compliant Flag' ;
    rdfs:comment 'Indicates whether the document is compliant with the terms and conditions of the LC or guarantee. True if no discrepancies exist, false if discrepancies are present.' ;
    rdfs:domain ind:TradeDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:documentAmount rdf:type rdf:Property ;
    rdfs:label 'Document Amount' ;
    rdfs:comment 'Monetary amount stated on the document. Applicable to commercial invoices, drafts, bills of exchange, and insurance certificates. Must not exceed LC amount.' ;
    rdfs:domain ind:TradeDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:documentHash rdf:type rdf:Property ;
    rdfs:label 'Document Hash' ;
    rdfs:comment 'Cryptographic hash of the document content for integrity verification. Used to detect tampering or alteration of electronic documents.' ;
    rdfs:domain ind:TradeDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:electronicDocumentFlag rdf:type rdf:Property ;
    rdfs:label 'Electronic Document Flag' ;
    rdfs:comment 'Indicates whether the document is presented in electronic form under eUCP rules. True for electronic presentation, false for paper documents.' ;
    rdfs:domain ind:TradeDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuerName rdf:type rdf:Property ;
    rdfs:label 'Issuer Name' ;
    rdfs:comment 'Name of the party or institution that issued the trade document. May be a carrier, inspection agency, chamber of commerce, insurance company, or beneficiary.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberOfOriginals rdf:type rdf:Property ;
    rdfs:label 'Number Of Originals' ;
    rdfs:comment 'Count of original documents presented when multiple originals are issued. Common for bills of lading issued in sets of three originals.' ;
    rdfs:domain ind:TradeDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalFlag rdf:type rdf:Property ;
    rdfs:label 'Original Flag' ;
    rdfs:comment 'Indicates whether the document is an original as required by LC terms. True if original, false if copy. Critical for documents like bills of lading where originals are required.' ;
    rdfs:domain ind:TradeDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receivedDate rdf:type rdf:Property ;
    rdfs:label 'Received Date' ;
    rdfs:comment 'Date on which the document was received by the examining bank or presenting party. Marks the start of the examination period under UCP 600 Article 14.' ;
    rdfs:domain ind:TradeDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:storageLocation rdf:type rdf:Property ;
    rdfs:label 'Storage Location' ;
    rdfs:comment 'Physical or electronic storage location reference for the document. May be vault location, document management system path, or cloud storage URI.' ;
    rdfs:domain ind:TradeDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Storage Reference Code' ;
    rdfs:comment 'Unique identifier or key used to retrieve the document from the storage system. Links to document management or imaging system.' ;
    rdfs:domain ind:TradeDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverDate rdf:type rdf:Property ;
    rdfs:label 'Waiver Date' ;
    rdfs:comment 'Date on which the applicant granted waiver of discrepancies and authorized the bank to proceed with payment or acceptance.' ;
    rdfs:domain ind:TradeDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tradeEventId rdf:type rdf:Property ;
    rdfs:label 'Trade Event Id' ;
    rdfs:comment 'Unique identifier for the trade finance event record. Primary key for the trade event log.' ;
    rdfs:domain ind:TradeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:linkedEventTradeEventId rdf:type rdf:Property ;
    rdfs:label 'Linked Event Trade Event Id' ;
    rdfs:comment 'Reference to a related or parent trade finance event, enabling event chain tracking for amendments, waivers, and multi-step processes.' ;
    rdfs:domain ind:TradeEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TradeEvent .

ind:tradeFinanceInstrumentId rdf:type rdf:Property ;
    rdfs:label 'Trade Finance Instrument Id' ;
    rdfs:comment 'Reference to the underlying trade finance instrument (letter of credit, guarantee, collection, supply chain finance, forfaiting) that this event pertains to.' ;
    rdfs:domain ind:TradeEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Instrument .

ind:triggeringPartyId rdf:type rdf:Property ;
    rdfs:label 'Triggering Party Id' ;
    rdfs:comment 'Reference to the party (bank, customer, beneficiary, correspondent) that initiated or triggered this trade finance event.' ;
    rdfs:domain ind:TradeEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:acknowledgementStatus rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Status' ;
    rdfs:comment 'The status of the SWIFT message acknowledgement, indicating whether the message was successfully received and acknowledged by the counterparty.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acknowledgementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Timestamp' ;
    rdfs:comment 'The date and time when the SWIFT message acknowledgement was received from the counterparty institution.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:complianceReviewRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Review Required Flag' ;
    rdfs:comment 'Indicates whether this event requires additional compliance review by the banks trade finance compliance team before processing can continue.' ;
    rdfs:domain ind:TradeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discrepancyDetails rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Details' ;
    rdfs:comment 'Detailed description of any discrepancies identified during document examination, including specific document defects and non-compliance with credit terms.' ;
    rdfs:domain ind:TradeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentReferenceNumbers rdf:type rdf:Property ;
    rdfs:label 'Document Reference Numbers' ;
    rdfs:comment 'Comma-separated list of document reference numbers associated with this event, such as bill of lading numbers, invoice numbers, or certificate numbers presented or examined.' ;
    rdfs:domain ind:TradeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:examinationResult rdf:type rdf:Property ;
    rdfs:label 'Examination Result' ;
    rdfs:comment 'The outcome of the document examination process for presentation events, indicating whether documents comply with letter of credit terms or contain discrepancies.' ;
    rdfs:domain ind:TradeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalReference rdf:type rdf:Property ;
    rdfs:label 'External Reference' ;
    rdfs:comment 'External reference number or identifier provided by the counterparty or customer, used for cross-referencing with external systems and correspondence.' ;
    rdfs:domain ind:TradeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:messageDirection rdf:type rdf:Property ;
    rdfs:label 'Message Direction' ;
    rdfs:comment 'Indicates whether the SWIFT message associated with this event was received by the bank (inbound) or sent by the bank (outbound).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingChannel rdf:type rdf:Property ;
    rdfs:label 'Processing Channel' ;
    rdfs:comment 'The communication channel or platform through which this trade finance event was processed and communicated between parties.' ;
    rdfs:domain ind:TradeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiverBic rdf:type rdf:Property ;
    rdfs:label 'Receiver Bic' ;
    rdfs:comment 'The Bank Identifier Code of the financial institution that received the SWIFT message associated with this event. 8 or 11 character ISO 9362 format.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:senderBic rdf:type rdf:Property ;
    rdfs:label 'Sender Bic' ;
    rdfs:comment 'The Bank Identifier Code of the financial institution that sent the SWIFT message associated with this event. 8 or 11 character ISO 9362 format.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transmissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transmission Timestamp' ;
    rdfs:comment 'The date and time when the SWIFT message was transmitted through the SWIFT network. Distinct from the business event timestamp.' ;
    rdfs:domain ind:TradeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:triggeringPartyRole rdf:type rdf:Property ;
    rdfs:label 'Triggering Party Role' ;
    rdfs:comment 'The functional role of the party that triggered this event within the trade finance transaction lifecycle. [ENUM-REF-CANDIDATE: issuing_bank|advising_bank|confirming_bank|applicant|beneficiary|nominated_bank|reimbursing_bank|presenting_bank|examiner — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TradeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:covenantPackageId rdf:type rdf:Property ;
    rdfs:label 'Covenant Package Id' ;
    rdfs:comment 'Reference to the set of financial and operational covenants applicable to this trade finance facility.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CovenantPackage .

ind:collateralReference rdf:type rdf:Property ;
    rdfs:label 'Collateral Reference' ;
    rdfs:comment 'Reference identifier linking to the collateral record(s) pledged to secure this facility.' ;
    rdfs:domain ind:TradeFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfRisk rdf:type rdf:Property ;
    rdfs:label 'Country Of Risk' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code representing the primary country risk exposure for this facility, typically the borrowers domicile or primary operating country.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ecaInsuranceCoverPercent rdf:type rdf:Property ;
    rdfs:label 'Eca Insurance Cover Percent' ;
    rdfs:comment 'Percentage of facility exposure covered by ECA insurance or guarantee, typically ranging from 85% to 95% for political and commercial risk.' ;
    rdfs:domain ind:TradeFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ecaReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Eca Reference Number' ;
    rdfs:comment 'Reference number for Export Credit Agency insurance or guarantee backing this facility, if applicable to ECA-backed facilities.' ;
    rdfs:domain ind:TradeFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityTenorMonths rdf:type rdf:Property ;
    rdfs:label 'Facility Tenor Months' ;
    rdfs:comment 'Duration of the facility commitment period expressed in months from origination to maturity.' ;
    rdfs:domain ind:TradeFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:limitCurrency rdf:type rdf:Property ;
    rdfs:label 'Limit Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the approved facility limit.' ;
    rdfs:domain ind:TradeFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marginRequirementPercent rdf:type rdf:Property ;
    rdfs:label 'Margin Requirement Percent' ;
    rdfs:comment 'Percentage of cash margin or security deposit required from the client as a percentage of each utilization under the facility.' ;
    rdfs:domain ind:TradeFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sublimitFinancingAmount rdf:type rdf:Property ;
    rdfs:label 'Sublimit Financing Amount' ;
    rdfs:comment 'Sublimit allocation within the facility specifically for trade financing products (pre-shipment, post-shipment, import loans), if applicable.' ;
    rdfs:domain ind:TradeFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sublimitGuaranteeAmount rdf:type rdf:Property ;
    rdfs:label 'Sublimit Guarantee Amount' ;
    rdfs:comment 'Sublimit allocation within the facility specifically for bank guarantee issuances, if applicable.' ;
    rdfs:domain ind:TradeFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sublimitLcAmount rdf:type rdf:Property ;
    rdfs:label 'Sublimit Lc Amount' ;
    rdfs:comment 'Sublimit allocation within the facility specifically for Letter of Credit issuances, if applicable.' ;
    rdfs:domain ind:TradeFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tradeSettlementId rdf:type rdf:Property ;
    rdfs:label 'Trade Settlement Id' ;
    rdfs:comment 'Unique identifier for the trade settlement transaction. Primary key for the trade settlement record.' ;
    rdfs:domain ind:TradeSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicantAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Applicant Account Number' ;
    rdfs:comment 'The account number from which settlement funds are debited or to which charges are posted.' ;
    rdfs:domain ind:TradeSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficiaryBankBic rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Bank Bic' ;
    rdfs:comment 'The SWIFT Bank Identifier Code of the beneficiarys bank where the settlement funds are to be credited.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Billing Period End Date' ;
    rdfs:comment 'The end date of the billing period for recurring fees such as commitment fees or per diem charges. Null for one-time charges.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Billing Period Start Date' ;
    rdfs:comment 'The start date of the billing period for recurring fees such as commitment fees or per diem charges. Null for one-time charges.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:chargeBasis rdf:type rdf:Property ;
    rdfs:label 'Charge Basis' ;
    rdfs:comment 'Method by which the fee or commission is calculated. Flat indicates a fixed amount regardless of transaction size, percentage indicates a rate applied to the principal amount, per diem indicates a daily charge, tiered indicates different rates for different amount bands, minimum indicates a floor charge, maximum indicates a ceiling charge, and sliding scale indicates a progressive rate structure. [ENUM-REF-CANDIDATE: flat|percentage|per_diem|tiered|minimum|maximum|sliding_scale — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TradeSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeRate rdf:type rdf:Property ;
    rdfs:label 'Charge Rate' ;
    rdfs:comment 'The percentage rate or basis points applied when charge basis is percentage or per diem. Expressed as a decimal (e.g., 0.015 for 1.5% or 150 basis points).' ;
    rdfs:domain ind:TradeSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chargeType rdf:type rdf:Property ;
    rdfs:label 'Charge Type' ;
    rdfs:comment 'Specific type of fee or commission being charged for trade finance services. Issuance commission covers letter of credit or guarantee issuance, advising fee covers notification services, confirmation fee covers payment undertaking by confirming bank, amendment fee covers modification charges, discrepancy fee covers document examination when discrepancies are found, acceptance commission covers acceptance of time drafts, negotiation fee covers document negotiation services, guarantee commission covers bank guarantee issuance, handling charge covers administrative processing, SWIFT charge covers messaging costs, courier fee covers physical document delivery, document examination fee covers compliance review, reimbursement fee covers correspondent bank payment processing, transfer fee covers beneficiary change charges, cancellation fee covers early termination, extension fee covers maturity date extension, utilization fee covers facility drawdown, commitment fee covers undrawn facility availability, arrangement fee covers facility structuring, and agency fee covers agent bank services in syndicated trade finance. [ENUM-REF-CANDIDATE: issuance_commission|advising_fee|confirmation_fee|amendment_fee|discrepancy_fee|acceptance_commission|negotiation_fee|guarantee_commission|handling_charge|swift_charge|courier_fee|document_examination_fee|reimbursement_fee|transfer_fee|cancellation_fee|extension_fee|utilization_fee|commitment_fee|arrangement_fee|agency_fee — 20 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TradeSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correspondentBankBic rdf:type rdf:Property ;
    rdfs:label 'Correspondent Bank Bic' ;
    rdfs:comment 'The SWIFT Bank Identifier Code of the correspondent bank through which the settlement is routed. Eight or eleven character code conforming to ISO 9362 standard.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fxRateDate rdf:type rdf:Property ;
    rdfs:label 'Fx Rate Date' ;
    rdfs:comment 'The date on which the foreign exchange rate was determined or fixed for this settlement. Null if no currency conversion occurred.' ;
    rdfs:domain ind:TradeSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nostroVostroAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Nostro Vostro Account Number' ;
    rdfs:comment 'The correspondent banking account number used for settlement. Nostro refers to the banks account held at a correspondent bank, vostro refers to a correspondent banks account held at this bank.' ;
    rdfs:domain ind:TradeSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalAmount rdf:type rdf:Property ;
    rdfs:label 'Original Amount' ;
    rdfs:comment 'The monetary amount in the original currency before foreign exchange conversion. Null if no currency conversion occurred.' ;
    rdfs:domain ind:TradeSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalCurrency rdf:type rdf:Property ;
    rdfs:label 'Original Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code of the original trade finance obligation before any foreign exchange conversion. Null if no currency conversion occurred.' ;
    rdfs:domain ind:TradeSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentDirection rdf:type rdf:Property ;
    rdfs:label 'Payment Direction' ;
    rdfs:comment 'Indicates whether the settlement represents funds flowing into the bank (inbound) or out of the bank (outbound) from the banks perspective.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementCurrency rdf:type rdf:Property ;
    rdfs:label 'Settlement Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code in which the settlement is denominated and executed.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementLineType rdf:type rdf:Property ;
    rdfs:label 'Settlement Line Type' ;
    rdfs:comment 'Classification of the settlement line indicating the nature of the financial obligation being settled. Principal represents the core trade finance amount, fee covers service charges, commission covers intermediary compensation, reimbursement covers correspondent bank payments, interest covers financing charges, penalty covers late payment charges, discount covers early payment discounts, advance covers upfront payments, repayment covers loan principal returns, claim payment covers guarantee claim settlements, and forfaiting proceeds cover discounted receivable purchases. [ENUM-REF-CANDIDATE: principal|fee|commission|reimbursement|interest|penalty|discount|advance|repayment|claim_payment|forfaiting_proceeds — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TradeSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Settlement Reference Number' ;
    rdfs:comment 'Externally visible unique reference number for this settlement transaction, used for reconciliation and customer communication.' ;
    rdfs:domain ind:TradeSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeUtilizationId rdf:type rdf:Property ;
    rdfs:label 'Trade Utilization Id' ;
    rdfs:comment 'Unique identifier for the trade utilization transaction. Primary key for this entity.' ;
    rdfs:domain ind:TradeUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryTradePartyId rdf:type rdf:Property ;
    rdfs:label 'Primary Trade Party Id' ;
    rdfs:comment 'Reference to the borrower or counterparty utilizing the trade finance facility.' ;
    rdfs:domain ind:TradeUtilization ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:facilityHeadroomAfterUtilization rdf:type rdf:Property ;
    rdfs:label 'Facility Headroom After Utilization' ;
    rdfs:comment 'The remaining available commitment amount on the parent facility after this utilization is applied, used for real-time exposure tracking.' ;
    rdfs:domain ind:TradeUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:instrumentReference rdf:type rdf:Property ;
    rdfs:label 'Instrument Reference' ;
    rdfs:comment 'Reference to the underlying trade finance instrument such as LC number, guarantee number, or SCF invoice reference that this utilization is associated with.' ;
    rdfs:domain ind:TradeUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outstandingBalance rdf:type rdf:Property ;
    rdfs:label 'Outstanding Balance' ;
    rdfs:comment 'The current outstanding principal balance of this trade utilization after accounting for any repayments or settlements.' ;
    rdfs:domain ind:TradeUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productType rdf:type rdf:Property ;
    rdfs:label 'Product Type' ;
    rdfs:comment 'The specific trade finance product type utilized in this transaction: letter of credit (LC), bank guarantee, trade loan, supply chain finance (SCF) payables finance, SCF receivables discounting, or forfaiting.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repaymentStatus rdf:type rdf:Property ;
    rdfs:label 'Repayment Status' ;
    rdfs:comment 'Current repayment status of this trade utilization indicating whether it is outstanding, partially repaid, fully repaid, defaulted, written off, or restructured.' ;
    rdfs:domain ind:TradeUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scfApprovedAmount rdf:type rdf:Property ;
    rdfs:label 'Scf Approved Amount' ;
    rdfs:comment 'For SCF transactions, the amount approved for financing which may be less than the invoice amount due to credit limits or haircuts.' ;
    rdfs:domain ind:TradeUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scfEarlyPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Scf Early Payment Date' ;
    rdfs:comment 'For SCF transactions, the date on which early payment was made to the supplier under the SCF program.' ;
    rdfs:domain ind:TradeUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scfInvoiceAmount rdf:type rdf:Property ;
    rdfs:label 'Scf Invoice Amount' ;
    rdfs:comment 'For SCF transactions, the total face value amount of the invoice being financed.' ;
    rdfs:domain ind:TradeUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scfInvoiceReference rdf:type rdf:Property ;
    rdfs:label 'Scf Invoice Reference' ;
    rdfs:comment 'For SCF transactions, the reference number of the underlying invoice being financed or discounted.' ;
    rdfs:domain ind:TradeUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ucp600ComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Ucp 600 Compliance Flag' ;
    rdfs:comment 'Boolean indicator of whether this letter of credit utilization complies with UCP 600 rules for documentary credits.' ;
    rdfs:domain ind:TradeUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:urdg758ComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Urdg 758 Compliance Flag' ;
    rdfs:comment 'Boolean indicator of whether this bank guarantee utilization complies with URDG 758 rules for demand guarantees.' ;
    rdfs:domain ind:TradeUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:utilizationDate rdf:type rdf:Property ;
    rdfs:label 'Utilization Date' ;
    rdfs:comment 'The business date on which the trade finance facility was utilized or drawn down.' ;
    rdfs:domain ind:TradeUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:utilizationReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Utilization Reference Number' ;
    rdfs:comment 'Externally-known unique reference number for this trade utilization transaction, used for operational tracking and customer communication.' ;
    rdfs:domain ind:TradeUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:writeOffId rdf:type rdf:Property ;
    rdfs:label 'Write Off Id' ;
    rdfs:comment 'Unique identifier for the write-off event. Primary key for the write-off record.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryWriteEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Write Employee Id' ;
    rdfs:comment 'The system user ID or employee ID of the individual who approved the write-off, for audit trail purposes.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:chargeOffReasonCode rdf:type rdf:Property ;
    rdfs:label 'Charge Off Reason Code' ;
    rdfs:comment 'The primary reason for the charge-off: bankruptcy filing, borrower deceased, fraud, deemed uncollectable, statute of limitations expired, or other.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeOffReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Charge Off Reason Description' ;
    rdfs:comment 'Free-text narrative providing additional context and details about the reason for the charge-off.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collateralLiquidationFlag rdf:type rdf:Property ;
    rdfs:label 'Collateral Liquidation Flag' ;
    rdfs:comment 'Indicates whether collateral was liquidated prior to or as part of the write-off process (True) or not (False).' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:collateralLiquidationProceeds rdf:type rdf:Property ;
    rdfs:label 'Collateral Liquidation Proceeds' ;
    rdfs:comment 'The net proceeds received from liquidation of collateral prior to write-off, applied to reduce the write-off amount.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cumulativeRecoveryToDate rdf:type rdf:Property ;
    rdfs:label 'Cumulative Recovery To Date' ;
    rdfs:comment 'The total amount recovered from all sources (borrower payments, collateral liquidation, guarantor calls, debt sales) since the write-off date, updated with each recovery event.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daysPastDueAtWriteOff rdf:type rdf:Property ;
    rdfs:label 'Days Past Due At Write Off' ;
    rdfs:comment 'The number of days the loan was past due at the time of write-off, used for delinquency analysis and LGD modeling.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:debtSaleDate rdf:type rdf:Property ;
    rdfs:label 'Debt Sale Date' ;
    rdfs:comment 'The date on which the charged-off debt was sold to a third-party debt buyer, if applicable.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:debtSaleFlag rdf:type rdf:Property ;
    rdfs:label 'Debt Sale Flag' ;
    rdfs:comment 'Indicates whether the charged-off debt was sold to a third-party debt buyer (True) or retained for internal collection (False).' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:debtSaleProceeds rdf:type rdf:Property ;
    rdfs:label 'Debt Sale Proceeds' ;
    rdfs:comment 'The amount received from the sale of the charged-off debt to a third-party buyer, recorded as a recovery.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eadAtDefault rdf:type rdf:Property ;
    rdfs:label 'Ead At Default' ;
    rdfs:comment 'The total exposure at the time of default, used as the denominator in LGD calculation. Typically equals the total outstanding balance at default.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eclReserveReleasedAmount rdf:type rdf:Property ;
    rdfs:label 'Ecl Reserve Released Amount' ;
    rdfs:comment 'The amount of ECL (Expected Credit Loss) or ALLL (Allowance for Loan and Lease Losses) reserve released upon write-off, reducing the reserve balance.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feesWrittenOffAmount rdf:type rdf:Property ;
    rdfs:label 'Fees Written Off Amount' ;
    rdfs:comment 'The unpaid fees (late fees, penalty fees, servicing fees) that were charged off at the time of write-off.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:guarantorCallFlag rdf:type rdf:Property ;
    rdfs:label 'Guarantor Call Flag' ;
    rdfs:comment 'Indicates whether a guarantor was called upon for payment prior to or as part of the write-off process (True) or not (False).' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:guarantorRecoveryAmount rdf:type rdf:Property ;
    rdfs:label 'Guarantor Recovery Amount' ;
    rdfs:comment 'The amount recovered from guarantor(s) prior to write-off, applied to reduce the write-off amount.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interestWrittenOffAmount rdf:type rdf:Property ;
    rdfs:label 'Interest Written Off Amount' ;
    rdfs:comment 'The accrued but unpaid interest that was charged off at the time of write-off.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lgdRate rdf:type rdf:Property ;
    rdfs:label 'Lgd Rate' ;
    rdfs:comment 'The calculated Loss Given Default rate for this write-off: net loss after recovery divided by exposure at default (EAD). Expressed as a decimal (e.g., 0.4500 for 45%).' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netChargeOffAmount rdf:type rdf:Property ;
    rdfs:label 'Net Charge Off Amount' ;
    rdfs:comment 'The net loss recognized after applying reserve release: total write-off amount minus ECL reserve released. This is the P&L impact of the charge-off.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netLossAfterRecovery rdf:type rdf:Property ;
    rdfs:label 'Net Loss After Recovery' ;
    rdfs:comment 'The net loss remaining after all recoveries: total write-off amount minus cumulative recovery to date. Used for final LGD calculation.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:principalWrittenOffAmount rdf:type rdf:Property ;
    rdfs:label 'Principal Written Off Amount' ;
    rdfs:comment 'The outstanding principal balance of the loan that was charged off at the time of write-off.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recoveryPursuitStatus rdf:type rdf:Property ;
    rdfs:label 'Recovery Pursuit Status' ;
    rdfs:comment 'Current status of post-charge-off recovery efforts: active pursuit, suspended, closed with no recovery, closed with partial recovery, or closed with full recovery.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryClassificationAtWriteOff rdf:type rdf:Property ;
    rdfs:label 'Regulatory Classification At Write Off' ;
    rdfs:comment 'The regulatory asset classification of the loan at the time of write-off per OCC/FDIC guidelines: substandard, doubtful, or loss.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalWriteOffAmount rdf:type rdf:Property ;
    rdfs:label 'Total Write Off Amount' ;
    rdfs:comment 'The total amount written off, including principal, interest, and fees. Sum of all written-off components.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:writeOffNumber rdf:type rdf:Property ;
    rdfs:label 'Write Off Number' ;
    rdfs:comment 'Externally visible business identifier for the write-off transaction, used for audit trails and regulatory reporting.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:writeOffStatus rdf:type rdf:Property ;
    rdfs:label 'Write Off Status' ;
    rdfs:comment 'Current lifecycle status of the write-off record: pending approval, approved by credit committee, posted to general ledger, reversed due to error or recovery, or closed after final settlement.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:writeOffType rdf:type rdf:Property ;
    rdfs:label 'Write Off Type' ;
    rdfs:comment 'Classification of the write-off event: full charge-off (entire balance), partial charge-off (portion of balance), technical write-off (accounting treatment without legal discharge), or regulatory write-off (mandated by regulator).' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankCountryId rdf:type rdf:Property ;
    rdfs:label 'Bank Country Id' ;
    rdfs:comment 'Foreign key linking to reference.country. Business justification: Beneficiary bank country drives payment routing (SWIFT vs local rails), sanctions screening (OFAC, EU), correspondent bank selection, and regulatory reporting (FFIEC 009 cross-border). Bank_country_co' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:codeListId rdf:type rdf:Property ;
    rdfs:label 'Code List Id' ;
    rdfs:comment 'Foreign key linking to reference.code_list. Business justification: Default purpose code per beneficiary streamlines recurring payment processing (e.g., SUPP for all supplier beneficiaries). Code_list provides regulatory reporting category and AML risk indicator for b' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CodeList .

ind:registeredPartyId rdf:type rdf:Property ;
    rdfs:label 'Registered Party Id' ;
    rdfs:comment 'Foreign key linking to customer.party. Business justification: When beneficiary is existing customer, party link enables streamlined KYC (reuse existing due diligence), enhanced sanctions screening (leverage customer risk rating), and simplified beneficiary regis' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line1' ;
    rdfs:comment 'Primary address line of the beneficiary (street address, building number). Required for compliance and verification purposes.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line2' ;
    rdfs:comment 'Secondary address line of the beneficiary (suite, apartment, additional location details).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Bank Address Line1' ;
    rdfs:comment 'Primary address line of the beneficiary\'s bank or branch (street address, building number).' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Bank Address Line2' ;
    rdfs:comment 'Secondary address line of the beneficiary\'s bank or branch (suite, floor, additional location details).' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankBranchName rdf:type rdf:Property ;
    rdfs:label 'Bank Branch Name' ;
    rdfs:comment 'Name or identifier of the specific branch where the beneficiary account is held, if applicable.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankCity rdf:type rdf:Property ;
    rdfs:label 'Bank City' ;
    rdfs:comment 'City where the beneficiary\'s bank or branch is located.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankName rdf:type rdf:Property ;
    rdfs:label 'Bank Name' ;
    rdfs:comment 'Full name of the financial institution holding the beneficiary\'s account.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankPostalCode rdf:type rdf:Property ;
    rdfs:label 'Bank Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the beneficiary\'s bank or branch location.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankStateProvince rdf:type rdf:Property ;
    rdfs:label 'Bank State Province' ;
    rdfs:comment 'State, province, or region where the beneficiary\'s bank or branch is located.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficiaryStatus rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Status' ;
    rdfs:comment 'Current lifecycle status of the beneficiary record. Active beneficiaries can receive payments; suspended or blocked beneficiaries cannot.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bicSwiftCode rdf:type rdf:Property ;
    rdfs:label 'Bic Swift Code' ;
    rdfs:comment 'BIC/SWIFT code identifying the beneficiary\'s bank for international wire transfers and SWIFT messaging. 8 or 11 character alphanumeric code.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intermediaryBankBic rdf:type rdf:Property ;
    rdfs:label 'Intermediary Bank Bic' ;
    rdfs:comment 'BIC/SWIFT code of the intermediary (correspondent) bank used to route payments to the beneficiary bank, if required.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intermediaryBankName rdf:type rdf:Property ;
    rdfs:label 'Intermediary Bank Name' ;
    rdfs:comment 'Name of the intermediary (correspondent) bank, if required for payment routing.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intermediaryBankRequired rdf:type rdf:Property ;
    rdfs:label 'Intermediary Bank Required' ;
    rdfs:comment 'Indicates whether an intermediary (correspondent) bank is required to route payments to this beneficiary. True for certain cross-border payments.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:routingCode rdf:type rdf:Property ;
    rdfs:label 'Routing Code' ;
    rdfs:comment 'Domestic routing code for the beneficiary\'s bank (e.g., ABA routing number, UK sort code, Australian BSB). Format varies by country.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingCodeType rdf:type rdf:Property ;
    rdfs:label 'Routing Code Type' ;
    rdfs:comment 'Type of domestic routing code used for the beneficiary bank: ABA (US), Sort Code (UK), BSB (Australia), IFSC (India), CLABE (Mexico), Transit Number (Canada), or other branch code. [ENUM-REF-CANDIDATE: aba|sort_code|bsb|ifsc|clabe|transit|branch_code — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:merchantCountryId rdf:type rdf:Property ;
    rdfs:label 'Merchant Country Id' ;
    rdfs:comment 'Foreign key linking to reference.country. Business justification: Merchant country determines interchange rates, fraud velocity rules, 3DS requirements (PSD2 SCA), and cross-border transaction fees. Country master provides sanctions status, AML risk rating, and regu' ;
    rdfs:domain ind:CardTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:acquirerBic rdf:type rdf:Property ;
    rdfs:label 'Acquirer Bic' ;
    rdfs:comment 'SWIFT BIC code of the acquiring bank that processed the merchant transaction.' ;
    rdfs:domain ind:CardTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:avsResultCode rdf:type rdf:Property ;
    rdfs:label 'Avs Result Code' ;
    rdfs:comment 'Result code from address verification system comparing billing address with issuer records.' ;
    rdfs:domain ind:CardTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingAmount rdf:type rdf:Property ;
    rdfs:label 'Billing Amount' ;
    rdfs:comment 'Amount billed to the cardholder in the card account currency after foreign exchange conversion if applicable.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingCurrency rdf:type rdf:Property ;
    rdfs:label 'Billing Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the billing amount (card account currency).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardPresentFlag rdf:type rdf:Property ;
    rdfs:label 'Card Present Flag' ;
    rdfs:comment 'Indicates whether the physical card was present at the time of transaction (True) or not present for card-not-present transactions (False).' ;
    rdfs:domain ind:CardTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cardToken rdf:type rdf:Property ;
    rdfs:label 'Card Token' ;
    rdfs:comment 'Tokenized representation of the card number used for secure processing without exposing actual PAN.' ;
    rdfs:domain ind:CardTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardholderPresentFlag rdf:type rdf:Property ;
    rdfs:label 'Cardholder Present Flag' ;
    rdfs:comment 'Indicates whether the cardholder was physically present at the point of sale (True) or not (False).' ;
    rdfs:domain ind:CardTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cvvResultCode rdf:type rdf:Property ;
    rdfs:label 'Cvv Result Code' ;
    rdfs:comment 'Result of CVV verification: M=Match, N=No Match, P=Not Processed, S=Should be present, U=Unsupported.' ;
    rdfs:domain ind:CardTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declineReasonCode rdf:type rdf:Property ;
    rdfs:label 'Decline Reason Code' ;
    rdfs:comment 'Code indicating the reason for transaction decline if authorization was not approved (e.g., insufficient funds, invalid card, suspected fraud).' ;
    rdfs:domain ind:CardTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuerBic rdf:type rdf:Property ;
    rdfs:label 'Issuer Bic' ;
    rdfs:comment 'SWIFT BIC code of the card issuing bank.' ;
    rdfs:domain ind:CardTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maskedPan rdf:type rdf:Property ;
    rdfs:label 'Masked Pan' ;
    rdfs:comment 'Masked card number showing first 6 and last 4 digits with middle digits obscured for security. Format: 123456******7890.' ;
    rdfs:domain ind:CardTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:merchantCity rdf:type rdf:Property ;
    rdfs:label 'Merchant City' ;
    rdfs:comment 'City where the merchant is located or where the transaction occurred.' ;
    rdfs:domain ind:CardTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Network Reference Number' ;
    rdfs:comment 'Unique reference number assigned by the card network for tracking and reconciliation across the payment lifecycle.' ;
    rdfs:domain ind:CardTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:posEntryMode rdf:type rdf:Property ;
    rdfs:label 'Pos Entry Mode' ;
    rdfs:comment 'Method by which the card data was entered at the point of sale: chip, swipe, contactless, manual entry, e-commerce, or mobile wallet.' ;
    rdfs:domain ind:CardTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retrievalReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Retrieval Reference Number' ;
    rdfs:comment 'Reference number used to retrieve transaction details from the card network or processor.' ;
    rdfs:domain ind:CardTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:threeDSecureFlag rdf:type rdf:Property ;
    rdfs:label 'Three D Secure Flag' ;
    rdfs:comment 'Indicates whether 3D Secure authentication was used for this transaction (True) or not (False).' ;
    rdfs:domain ind:CardTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clearingRecordId rdf:type rdf:Property ;
    rdfs:label 'Clearing Record Id' ;
    rdfs:comment 'Unique identifier for the clearing record. Primary key for the clearing record entity.' ;
    rdfs:domain ind:ClearingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clearingCurrencyId rdf:type rdf:Property ;
    rdfs:label 'Clearing Currency Id' ;
    rdfs:comment 'Foreign key linking to reference.currency. Business justification: Clearing house settlement requires currency master for netting calculations, liquidity reserve requirements, and settlement finality rules. Clearing_currency_code denormalized text replaced by FK for ' ;
    rdfs:domain ind:ClearingRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:clearingConfirmationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Clearing Confirmation Timestamp' ;
    rdfs:comment 'Timestamp when the clearing house confirmed acceptance or rejection of the clearing submission. Marks the completion of the clearing validation phase.' ;
    rdfs:domain ind:ClearingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:clearingCycleIdentifier rdf:type rdf:Property ;
    rdfs:label 'Clearing Cycle Identifier' ;
    rdfs:comment 'Identifier of the specific clearing cycle or batch window in which this clearing record was processed. Clearing houses typically operate multiple cycles per day.' ;
    rdfs:domain ind:ClearingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Clearing Fee Amount' ;
    rdfs:comment 'Fee charged by the clearing house for processing this clearing record. May be a flat fee per transaction or a percentage of the cleared amount.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clearingHouseIdentifier rdf:type rdf:Property ;
    rdfs:label 'Clearing House Identifier' ;
    rdfs:comment 'Identifier of the clearing house or payment system operator that processed this clearing record. Examples include ACH operator, CHIPS (Clearing House Interbank Payments System), Fedwire, CHAPS (Clearing House Automated Payment System), TARGET2 (Trans-European Automated Real-time Gross Settlement Express Transfer System), CLS (Continuous Linked Settlement), SEPA, BACS. [ENUM-REF-CANDIDATE: ACH|CHIPS|FEDWIRE|CHAPS|TARGET2|CLS|SEPA|BACS|SWIFT|OTHER — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingMessageType rdf:type rdf:Property ;
    rdfs:label 'Clearing Message Type' ;
    rdfs:comment 'Type of clearing message or instruction format used. Examples include SWIFT MT message types (MT103, MT202), ISO 20022 message types (pacs.008, pacs.009), or proprietary clearing formats.' ;
    rdfs:domain ind:ClearingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingParticipantIdentifier rdf:type rdf:Property ;
    rdfs:label 'Clearing Participant Identifier' ;
    rdfs:comment 'Unique identifier of the financial institution participating in the clearing process. May be a BIC (Bank Identifier Code), ABA routing number, or clearing house member identifier.' ;
    rdfs:domain ind:ClearingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Clearing Reference Number' ;
    rdfs:comment 'Unique reference number assigned by the clearing house to identify this clearing submission. Business identifier for external reconciliation and inquiry.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingStatus rdf:type rdf:Property ;
    rdfs:label 'Clearing Status' ;
    rdfs:comment 'Current lifecycle status of the clearing record. Indicates whether the clearing submission has been accepted, rejected, is pending processing, or has progressed to settlement.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingSubmissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Clearing Submission Timestamp' ;
    rdfs:comment 'Timestamp when the payment instruction or batch was submitted to the clearing house for processing. Represents the business event time of clearing initiation.' ;
    rdfs:domain ind:ClearingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:collateralRequirementAmount rdf:type rdf:Property ;
    rdfs:label 'Collateral Requirement Amount' ;
    rdfs:comment 'Amount of collateral required to be posted to the clearing house to cover settlement risk exposure. Common in securities clearing and derivatives clearing.' ;
    rdfs:domain ind:ClearingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:counterpartyParticipantIdentifier rdf:type rdf:Property ;
    rdfs:label 'Counterparty Participant Identifier' ;
    rdfs:comment 'Identifier of the counterparty financial institution on the other side of the clearing transaction. Used in bilateral netting and settlement reconciliation.' ;
    rdfs:domain ind:ClearingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:foreignExchangeRate rdf:type rdf:Property ;
    rdfs:label 'Foreign Exchange Rate' ;
    rdfs:comment 'Exchange rate applied for cross-currency clearing and settlement, particularly relevant for CLS (Continuous Linked Settlement) FX transactions. Represents the rate at which one currency is converted to another.' ;
    rdfs:domain ind:ClearingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossClearingAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Clearing Amount' ;
    rdfs:comment 'Total gross amount of all payment instructions included in this clearing record before any netting or offsetting. Represents the sum of all individual payment values submitted.' ;
    rdfs:domain ind:ClearingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:liquidityReserveRequirementAmount rdf:type rdf:Property ;
    rdfs:label 'Liquidity Reserve Requirement Amount' ;
    rdfs:comment 'Amount of liquidity reserves that must be maintained to cover this clearing obligation. Relevant for regulatory liquidity management and LCR (Liquidity Coverage Ratio) calculations.' ;
    rdfs:domain ind:ClearingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:multilateralNettingPosition rdf:type rdf:Property ;
    rdfs:label 'Multilateral Netting Position' ;
    rdfs:comment 'Indicates whether the institution is a net payer (owes funds), net receiver (receives funds), or neutral (no net obligation) after multilateral netting across all participants in the clearing cycle.' ;
    rdfs:domain ind:ClearingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netSettlementObligationAmount rdf:type rdf:Property ;
    rdfs:label 'Net Settlement Obligation Amount' ;
    rdfs:comment 'Net settlement obligation amount after multilateral or bilateral netting has been applied by the clearing house. This is the actual amount that must be funded or will be received in the settlement phase.' ;
    rdfs:domain ind:ClearingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nettingGroupIdentifier rdf:type rdf:Property ;
    rdfs:label 'Netting Group Identifier' ;
    rdfs:comment 'Identifier of the netting group or pool to which this clearing record belongs. Used in multilateral netting arrangements where participants are grouped for offset calculation.' ;
    rdfs:domain ind:ClearingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nostroVostroIndicator rdf:type rdf:Property ;
    rdfs:label 'Nostro Vostro Indicator' ;
    rdfs:comment 'Indicates whether the settlement account is a nostro account (our account held at another bank), vostro account (their account held at our bank), or an internal account. Critical for correspondent banking reconciliation.' ;
    rdfs:domain ind:ClearingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentInstructionCount rdf:type rdf:Property ;
    rdfs:label 'Payment Instruction Count' ;
    rdfs:comment 'Number of individual payment instructions included in this clearing record. Relevant for batch clearing submissions where multiple payments are cleared together.' ;
    rdfs:domain ind:ClearingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priorityIndicator rdf:type rdf:Property ;
    rdfs:label 'Priority Indicator' ;
    rdfs:comment 'Priority level assigned to this clearing record. High-priority payments may be processed in earlier clearing cycles or given preferential treatment in settlement queues.' ;
    rdfs:domain ind:ClearingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementRiskExposureAmount rdf:type rdf:Property ;
    rdfs:label 'Settlement Risk Exposure Amount' ;
    rdfs:comment 'Calculated settlement risk exposure amount representing the potential loss if the counterparty fails to settle. Used for credit risk management and regulatory capital calculations.' ;
    rdfs:domain ind:ClearingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementWindowIdentifier rdf:type rdf:Property ;
    rdfs:label 'Settlement Window Identifier' ;
    rdfs:comment 'Identifier of the specific settlement window or time slot in which final settlement is scheduled. Clearing houses may operate multiple settlement windows throughout the day.' ;
    rdfs:domain ind:ClearingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correspondentCountryId rdf:type rdf:Property ;
    rdfs:label 'Correspondent Country Id' ;
    rdfs:comment 'Foreign key linking to reference.country. Business justification: Correspondent bank country determines sanctions screening requirements (OFAC, EU), regulatory approval needs (Fed Reserve approval for US correspondents), and settlement risk limits. Country master pr' ;
    rdfs:domain ind:CorrespondentBank ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:contactName rdf:type rdf:Property ;
    rdfs:label 'Contact Name' ;
    rdfs:comment 'Name of the primary relationship manager or contact person at the correspondent bank for operational matters.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correspondentCity rdf:type rdf:Property ;
    rdfs:label 'Correspondent City' ;
    rdfs:comment 'City where the correspondent bank\'s primary office or headquarters is located.' ;
    rdfs:domain ind:CorrespondentBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correspondentName rdf:type rdf:Property ;
    rdfs:label 'Correspondent Name' ;
    rdfs:comment 'Full legal name of the correspondent banking institution as registered with regulatory authorities.' ;
    rdfs:domain ind:CorrespondentBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Amount' ;
    rdfs:comment 'Maximum credit exposure limit approved for transactions with this correspondent bank, denominated in primary currency.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cutoffTimeUtc rdf:type rdf:Property ;
    rdfs:label 'Cutoff Time Utc' ;
    rdfs:comment 'Daily cutoff time in UTC (HH:MM format) for submitting payment instructions to meet same-day settlement through this correspondent.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dailyTransactionLimit rdf:type rdf:Property ;
    rdfs:label 'Daily Transaction Limit' ;
    rdfs:comment 'Maximum aggregate transaction amount permitted per business day through this correspondent relationship, denominated in primary currency.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feeStructureCode rdf:type rdf:Property ;
    rdfs:label 'Fee Structure Code' ;
    rdfs:comment 'Code identifying the fee structure and pricing schedule applicable to transactions processed through this correspondent relationship.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gpiEnabled rdf:type rdf:Property ;
    rdfs:label 'Gpi Enabled' ;
    rdfs:comment 'Indicates whether this correspondent bank supports SWIFT Global Payments Innovation (gpi) for enhanced payment tracking and transparency.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nostroAccountIban rdf:type rdf:Property ;
    rdfs:label 'Nostro Account Iban' ;
    rdfs:comment 'International Bank Account Number (IBAN) of the nostro account held at the correspondent bank, if applicable.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nostroAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Nostro Account Number' ;
    rdfs:comment 'Account number of our institution\'s nostro account held at the correspondent bank for settlement purposes.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentRailTypes rdf:type rdf:Property ;
    rdfs:label 'Payment Rail Types' ;
    rdfs:comment 'Comma-separated list of payment rail types supported through this correspondent (e.g., SWIFT, RTGS, ACH, SEPA, TARGET2, CHAPS).' ;
    rdfs:domain ind:CorrespondentBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredIntermediaryBic rdf:type rdf:Property ;
    rdfs:label 'Preferred Intermediary Bic' ;
    rdfs:comment 'SWIFT BIC of the preferred intermediary bank to use when routing payments through this correspondent, if applicable.' ;
    rdfs:domain ind:CorrespondentBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryCurrency rdf:type rdf:Property ;
    rdfs:label 'Primary Currency' ;
    rdfs:comment 'Primary ISO 4217 three-letter currency code used for settlement with this correspondent bank.' ;
    rdfs:domain ind:CorrespondentBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipType rdf:type rdf:Property ;
    rdfs:label 'Relationship Type' ;
    rdfs:comment 'Type of correspondent banking relationship: nostro (our account with them), vostro (their account with us), bilateral (reciprocal), or unilateral (one-way).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceLevelAgreementReference rdf:type rdf:Property ;
    rdfs:label 'Service Level Agreement Reference' ;
    rdfs:comment 'Reference identifier for the Service Level Agreement (SLA) governing operational performance and service standards with this correspondent.' ;
    rdfs:domain ind:CorrespondentBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementCycle rdf:type rdf:Property ;
    rdfs:label 'Settlement Cycle' ;
    rdfs:comment 'Standard settlement cycle for transactions: T0 (same day), T1 (trade date plus one day), T2 (trade date plus two days).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportedCurrencies rdf:type rdf:Property ;
    rdfs:label 'Supported Currencies' ;
    rdfs:comment 'Comma-separated list of ISO 4217 three-letter currency codes that can be processed through this correspondent relationship (e.g., USD,EUR,GBP,JPY).' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:swiftMessageTypes rdf:type rdf:Property ;
    rdfs:label 'Swift Message Types' ;
    rdfs:comment 'Comma-separated list of SWIFT message types (MT codes) supported for this correspondent relationship (e.g., MT103, MT202, MT910).' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vostroAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Vostro Account Number' ;
    rdfs:comment 'Account number of the correspondent bank\'s vostro account held at our institution for reciprocal settlement.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fxTransactionId rdf:type rdf:Property ;
    rdfs:label 'Fx Transaction Id' ;
    rdfs:comment 'Unique identifier for the foreign exchange transaction record.' ;
    rdfs:domain ind:FxTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hedgedSecurityInstrumentId rdf:type rdf:Property ;
    rdfs:label 'Hedged Security Instrument Id' ;
    rdfs:comment 'Foreign key linking to security.instrument. Business justification: FX transactions hedging currency risk on foreign securities positions need instrument linkage for hedge accounting, effectiveness testing, and portfolio risk reporting. Role-prefixed because FX transa' ;
    rdfs:domain ind:FxTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Instrument .

ind:productTypeId rdf:type rdf:Property ;
    rdfs:label 'Product Type Id' ;
    rdfs:comment 'Foreign key linking to reference.product_type. Business justification: FX transactions classified by product type (spot, forward, swap, NDF) for risk weighting (Basel III market risk), accounting treatment (IAS 39/IFRS 9 hedge accounting), and regulatory capital calculat' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductType .

ind:regulatoryReportingJurisdictionId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Jurisdiction Id' ;
    rdfs:comment 'Foreign key linking to reference.jurisdiction. Business justification: FX transactions reported to specific jurisdictions (CFTC for US persons, ESMA for EU entities, ASIC for Australian). Jurisdiction master provides reporting taxonomy, submission method, and regulatory ' ;
    rdfs:domain ind:FxTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Jurisdiction .

ind:vostroAccountId rdf:type rdf:Property ;
    rdfs:label 'Vostro Account Id' ;
    rdfs:comment 'Reference to the vostro account (their account held at our bank) used for settlement of this FX transaction.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NostroAccount .

ind:baseCurrencySettlementAccount rdf:type rdf:Property ;
    rdfs:label 'Base Currency Settlement Account' ;
    rdfs:comment 'Account number or identifier for the nostro/vostro account used to settle the base currency leg of the FX transaction.' ;
    rdfs:domain ind:FxTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookingEntity rdf:type rdf:Property ;
    rdfs:label 'Booking Entity' ;
    rdfs:comment 'Legal entity or branch of the institution that booked this FX transaction on its balance sheet.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buySellIndicator rdf:type rdf:Property ;
    rdfs:label 'Buy Sell Indicator' ;
    rdfs:comment 'Indicates whether the institution is buying or selling the base currency in this FX transaction.' ;
    rdfs:domain ind:FxTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterpartyBic rdf:type rdf:Property ;
    rdfs:label 'Counterparty Bic' ;
    rdfs:comment 'SWIFT BIC code of the counterparty bank or financial institution.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currencyPair rdf:type rdf:Property ;
    rdfs:label 'Currency Pair' ;
    rdfs:comment 'Standard representation of the currency pair being traded (e.g., USD/EUR, GBP/JPY).' ;
    rdfs:domain ind:FxTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealRate rdf:type rdf:Property ;
    rdfs:label 'Deal Rate' ;
    rdfs:comment 'The agreed exchange rate at which the base currency is converted to the quote currency for this transaction.' ;
    rdfs:domain ind:FxTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dealReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Deal Reference Number' ;
    rdfs:comment 'Externally-known unique reference number assigned to this FX deal by the trading system or counterparty.' ;
    rdfs:domain ind:FxTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealTimestamp rdf:type rdf:Property ;
    rdfs:label 'Deal Timestamp' ;
    rdfs:comment 'Date and time when the FX deal was executed or agreed upon between parties.' ;
    rdfs:domain ind:FxTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fixingDate rdf:type rdf:Property ;
    rdfs:label 'Fixing Date' ;
    rdfs:comment 'The date on which the final exchange rate is determined for non-deliverable forwards (NDF) or other rate-fixing products.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fixingRate rdf:type rdf:Property ;
    rdfs:label 'Fixing Rate' ;
    rdfs:comment 'The official exchange rate determined on the fixing date, used to calculate settlement amounts for NDF transactions.' ;
    rdfs:domain ind:FxTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forwardPoints rdf:type rdf:Property ;
    rdfs:label 'Forward Points' ;
    rdfs:comment 'The adjustment in basis points applied to the spot rate to calculate the forward rate for forward or swap transactions.' ;
    rdfs:domain ind:FxTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:profitCenter rdf:type rdf:Property ;
    rdfs:label 'Profit Center' ;
    rdfs:comment 'Profit center or cost center code to which the profit and loss from this FX transaction is attributed.' ;
    rdfs:domain ind:FxTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quoteCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Quote Currency Amount' ;
    rdfs:comment 'The equivalent amount in the quote currency calculated using the deal rate.' ;
    rdfs:domain ind:FxTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quoteCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Quote Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter code for the quote currency in the FX pair (e.g., EUR in USD/EUR).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quoteCurrencySettlementAccount rdf:type rdf:Property ;
    rdfs:label 'Quote Currency Settlement Account' ;
    rdfs:comment 'Account number or identifier for the nostro/vostro account used to settle the quote currency leg of the FX transaction.' ;
    rdfs:domain ind:FxTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spotRateReference rdf:type rdf:Property ;
    rdfs:label 'Spot Rate Reference' ;
    rdfs:comment 'The prevailing spot exchange rate at the time of deal execution, used as reference for forward pricing.' ;
    rdfs:domain ind:FxTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:swiftUetr rdf:type rdf:Property ;
    rdfs:label 'Swift Uetr' ;
    rdfs:comment 'Unique end-to-end transaction reference assigned by SWIFT for tracking this FX transaction across the payment chain.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradingDesk rdf:type rdf:Property ;
    rdfs:label 'Trading Desk' ;
    rdfs:comment 'Name or code of the trading desk or business unit responsible for executing this FX transaction.' ;
    rdfs:domain ind:FxTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentChannelId rdf:type rdf:Property ;
    rdfs:label 'Payment Channel Id' ;
    rdfs:comment 'Foreign key linking to payment.payment_channel. Business justification: payment_batch has payment_rail which should reference payment_channel. Each batch is submitted via a specific payment channel/rail. This is a standard N:1 relationship. payment_rail can be kept for de' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentChannel .

ind:receivingInstitutionLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Receiving Institution Legal Entity Id' ;
    rdfs:comment 'Bank Identifier Code (BIC) or routing number of the financial institution receiving the payment batch for settlement.' ;
    rdfs:domain ind:Batch ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:settlementCountryId rdf:type rdf:Property ;
    rdfs:label 'Settlement Country Id' ;
    rdfs:comment 'Foreign key linking to reference.country. Business justification: Batch settlement country determines clearing house (e.g., US ACH, UK BACS), holiday calendar for settlement date calculation, and regulatory reporting regime. Country master provides business day conv' ;
    rdfs:domain ind:Batch ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:batchDescription rdf:type rdf:Property ;
    rdfs:label 'Batch Description' ;
    rdfs:comment 'Free-text description providing additional context about the batch contents or purpose.' ;
    rdfs:domain ind:Batch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchStatus rdf:type rdf:Property ;
    rdfs:label 'Batch Status' ;
    rdfs:comment 'Current lifecycle status of the payment batch. DRAFT indicates batch is being assembled, SUBMITTED indicates batch sent to payment hub, PROCESSING indicates batch is being validated and routed, CLEARED indicates batch has passed clearing window, SETTLED indicates funds have been transferred, REJECTED indicates batch failed validation, CANCELLED indicates batch was withdrawn before settlement. [ENUM-REF-CANDIDATE: DRAFT|SUBMITTED|PROCESSING|CLEARED|SETTLED|REJECTED|CANCELLED — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Batch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchType rdf:type rdf:Property ;
    rdfs:label 'Batch Type' ;
    rdfs:comment 'Indicates whether the batch contains only credit transfers, only debit transfers, or a mix of both transaction types.' ;
    rdfs:domain ind:Batch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Clearing Timestamp' ;
    rdfs:comment 'Date and time when the batch successfully passed through the clearing process and was accepted by the receiving institution.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:clearingWindow rdf:type rdf:Property ;
    rdfs:label 'Clearing Window' ;
    rdfs:comment 'The designated clearing cycle or time window during which the batch is scheduled to be processed by the payment rail.' ;
    rdfs:domain ind:Batch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyEntryDescription rdf:type rdf:Property ;
    rdfs:label 'Company Entry Description' ;
    rdfs:comment 'Description that will appear on beneficiary bank statements for all payments in this batch, typically identifying the originating company.' ;
    rdfs:domain ind:Batch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discretionaryData rdf:type rdf:Property ;
    rdfs:label 'Discretionary Data' ;
    rdfs:comment 'Optional field for originator-specific information or internal reference data that accompanies the batch through the payment system.' ;
    rdfs:domain ind:Batch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isTestBatch rdf:type rdf:Property ;
    rdfs:label 'Is Test Batch' ;
    rdfs:comment 'Boolean flag indicating whether this is a test batch used for system validation and not intended for actual fund transfer (True) or a production batch (False).' ;
    rdfs:domain ind:Batch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originatorAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Originator Account Number' ;
    rdfs:comment 'Account number or International Bank Account Number (IBAN) from which funds will be debited for credit batches or to which funds will be credited for debit batches.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentRail rdf:type rdf:Property ;
    rdfs:label 'Payment Rail' ;
    rdfs:comment 'The payment network or clearing system through which the batch is processed (ACH for Automated Clearing House, WIRE for wire transfer, RTGS for Real-Time Gross Settlement, SWIFT for Society for Worldwide Interbank Financial Telecommunication, SEPA for Single Euro Payments Area, FEDWIRE for Federal Reserve Wire Network).' ;
    rdfs:domain ind:Batch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalItemCount rdf:type rdf:Property ;
    rdfs:label 'Total Item Count' ;
    rdfs:comment 'Total number of individual payment instructions included in this batch.' ;
    rdfs:domain ind:Batch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:validationErrorCode rdf:type rdf:Property ;
    rdfs:label 'Validation Error Code' ;
    rdfs:comment 'Standardized error code indicating the reason for validation failure or rejection, if applicable.' ;
    rdfs:domain ind:Batch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationErrorMessage rdf:type rdf:Property ;
    rdfs:label 'Validation Error Message' ;
    rdfs:comment 'Human-readable description of the validation error or rejection reason.' ;
    rdfs:domain ind:Batch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryCurrencyId rdf:type rdf:Property ;
    rdfs:label 'Primary Currency Id' ;
    rdfs:comment 'Foreign key linking to reference.currency. Business justification: Payment channels optimized for specific currency (e.g., SEPA for EUR, CHAPS for GBP). Currency master provides settlement cycle, cutoff times, and liquidity requirements for channel capacity planning ' ;
    rdfs:domain ind:PaymentChannel ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:amlScreeningRequired rdf:type rdf:Property ;
    rdfs:label 'Aml Screening Required' ;
    rdfs:comment 'Indicates whether payments through this channel must undergo mandatory Anti-Money Laundering screening before processing.' ;
    rdfs:domain ind:PaymentChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:batchProcessingSupported rdf:type rdf:Property ;
    rdfs:label 'Batch Processing Supported' ;
    rdfs:comment 'Indicates whether the payment channel supports batch file submission for multiple payment instructions in a single transmission.' ;
    rdfs:domain ind:PaymentChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:chargeBearerDefault rdf:type rdf:Property ;
    rdfs:label 'Charge Bearer Default' ;
    rdfs:comment 'Default charge bearer code for the channel indicating who pays transaction fees: OUR (originator pays all), BEN (beneficiary pays all), SHA (shared between parties).' ;
    rdfs:domain ind:PaymentChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossBorderEnabled rdf:type rdf:Property ;
    rdfs:label 'Cross Border Enabled' ;
    rdfs:comment 'Indicates whether the payment channel supports cross-border international payments (True) or is limited to domestic transactions (False).' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cutoffTime rdf:type rdf:Property ;
    rdfs:label 'Cutoff Time' ;
    rdfs:comment 'Daily deadline for submitting payments to be included in the current settlement cycle, expressed in HH:MM format in the operating timezone.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intermediaryBankAllowed rdf:type rdf:Property ;
    rdfs:label 'Intermediary Bank Allowed' ;
    rdfs:comment 'Indicates whether the payment channel supports routing through intermediary correspondent banks for indirect settlement.' ;
    rdfs:domain ind:PaymentChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maximumTransactionAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Transaction Amount' ;
    rdfs:comment 'The maximum payment amount that can be processed through this channel in a single transaction, expressed in the primary currency.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumTransactionAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Transaction Amount' ;
    rdfs:comment 'The minimum payment amount that can be processed through this channel, expressed in the primary currency.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:networkOperator rdf:type rdf:Property ;
    rdfs:label 'Network Operator' ;
    rdfs:comment 'The organization or entity that operates and governs the payment network or rail (e.g., Federal Reserve, SWIFT, The Clearing House, NACHA, Visa, Mastercard).' ;
    rdfs:domain ind:PaymentChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nostroAccountRequired rdf:type rdf:Property ;
    rdfs:label 'Nostro Account Required' ;
    rdfs:comment 'Indicates whether payments through this channel require the use of nostro accounts (our account held at correspondent banks) for settlement.' ;
    rdfs:domain ind:PaymentChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operatingHoursEnd rdf:type rdf:Property ;
    rdfs:label 'Operating Hours End' ;
    rdfs:comment 'Daily end time when the payment channel closes for transaction submission, expressed in HH:MM format in the channels operating timezone.' ;
    rdfs:domain ind:PaymentChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingHoursStart rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Start' ;
    rdfs:comment 'Daily start time when the payment channel opens for transaction submission, expressed in HH:MM format in the channels operating timezone.' ;
    rdfs:domain ind:PaymentChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingTimezone rdf:type rdf:Property ;
    rdfs:label 'Operating Timezone' ;
    rdfs:comment 'Timezone in which the payment channel operates and cutoff times are defined (e.g., EST, UTC, CET).' ;
    rdfs:domain ind:PaymentChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityLevelsSupported rdf:type rdf:Property ;
    rdfs:label 'Priority Levels Supported' ;
    rdfs:comment 'Comma-separated list of payment priority levels supported by this channel (e.g., normal, urgent, high, express) for expedited processing.' ;
    rdfs:domain ind:PaymentChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnWindowDays rdf:type rdf:Property ;
    rdfs:label 'Return Window Days' ;
    rdfs:comment 'The number of business days within which a payment processed through this channel can be returned or reversed by the receiving institution.' ;
    rdfs:domain ind:PaymentChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sanctionsScreeningRequired rdf:type rdf:Property ;
    rdfs:label 'Sanctions Screening Required' ;
    rdfs:comment 'Indicates whether payments through this channel must undergo mandatory sanctions screening against OFAC and other watchlists before processing.' ;
    rdfs:domain ind:PaymentChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:settlementModel rdf:type rdf:Property ;
    rdfs:label 'Settlement Model' ;
    rdfs:comment 'Settlement methodology used by the channel: gross settlement (transaction-by-transaction) or net settlement (aggregated positions).' ;
    rdfs:domain ind:PaymentChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTargetCompletionMinutes rdf:type rdf:Property ;
    rdfs:label 'Sla Target Completion Minutes' ;
    rdfs:comment 'The target time in minutes from payment submission to settlement confirmation as defined in the channels service level agreement.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:standardFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Standard Fee Amount' ;
    rdfs:comment 'The standard per-transaction fee charged for processing payments through this channel, expressed in the primary currency.' ;
    rdfs:domain ind:PaymentChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vostroAccountRequired rdf:type rdf:Property ;
    rdfs:label 'Vostro Account Required' ;
    rdfs:comment 'Indicates whether payments through this channel require the use of vostro accounts (their account held at our bank) for settlement.' ;
    rdfs:domain ind:PaymentChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exceptionId rdf:type rdf:Property ;
    rdfs:label 'Exception Id' ;
    rdfs:comment 'Unique identifier for the payment exception record. Primary key.' ;
    rdfs:domain ind:Exception ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:correctingJournalEntryId rdf:type rdf:Property ;
    rdfs:label 'Correcting Journal Entry Id' ;
    rdfs:comment 'Foreign key linking to ledger.journal_entry. Business justification: Payment exceptions requiring financial correction generate adjusting journal entries. Role-prefixed to distinguish from original transaction JEs. Required for error correction audit trail and SOX comp' ;
    rdfs:domain ind:Exception ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntry .

ind:exceptionEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Exception Employee Id' ;
    rdfs:comment 'Identifier of the operations staff member or analyst currently assigned to resolve this exception.' ;
    rdfs:domain ind:Exception ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:exceptionResolvedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Exception Resolved By User Employee Id' ;
    rdfs:comment 'Identifier of the operations staff member who completed the resolution of this exception.' ;
    rdfs:domain ind:Exception ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:originatingBankingChannelId rdf:type rdf:Property ;
    rdfs:label 'Originating Banking Channel Id' ;
    rdfs:comment 'Foreign key linking to channel.channel. Business justification: Payment exceptions require channel attribution for root cause analysis by channel, SLA breach monitoring, operational improvement initiatives, and channel-specific error rate tracking. Essential for c' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:paymentCurrencyId rdf:type rdf:Property ;
    rdfs:label 'Payment Currency Id' ;
    rdfs:comment 'Foreign key linking to reference.currency. Business justification: Exception reporting and financial impact analysis aggregate by currency. Currency master provides convertibility status for exception resolution routing and regulatory reporting thresholds (SAR filing' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:assignedQueue rdf:type rdf:Property ;
    rdfs:label 'Assigned Queue' ;
    rdfs:comment 'Name or identifier of the operations queue or team to which this exception has been assigned for resolution.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionSystem rdf:type rdf:Property ;
    rdfs:label 'Detection System' ;
    rdfs:comment 'Name or identifier of the system or module that detected and raised the exception (e.g., payment hub, screening engine, settlement system).' ;
    rdfs:domain ind:Exception ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxRetryLimit rdf:type rdf:Property ;
    rdfs:label 'Max Retry Limit' ;
    rdfs:comment 'Maximum number of retry attempts allowed for this exception type before requiring manual intervention or cancellation.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paymentRailType rdf:type rdf:Property ;
    rdfs:label 'Payment Rail Type' ;
    rdfs:comment 'Payment rail or network through which the payment was being processed when the exception occurred. [ENUM-REF-CANDIDATE: ACH|WIRE|RTGS|SWIFT|SEPA|FASTER_PAYMENTS|FEDWIRE|CHIPS|TARGET2|BACS|CHAPS|RTP|CARD_NETWORK|INTERNAL_TRANSFER — 14 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Reference' ;
    rdfs:comment 'Reference number or identifier of any regulatory report filed in connection with this exception (e.g., SAR, CTR reference).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionActionCode rdf:type rdf:Property ;
    rdfs:label 'Resolution Action Code' ;
    rdfs:comment 'Standardized code indicating the corrective action taken or planned to resolve the exception. [ENUM-REF-CANDIDATE: MANUAL_REPAIR|RESUBMIT|CANCEL|RETURN_TO_ORIGINATOR|ROUTE_ALTERNATE|CONTACT_BENEFICIARY|CONTACT_CORRESPONDENT|OVERRIDE_SCREENING|ESCALATE|AWAIT_FUNDS|AMEND_INSTRUCTION|SPLIT_PAYMENT|MERGE_PAYMENT|NO_ACTION_REQUIRED — 14 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Exception ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resubmissionEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Resubmission Eligible Flag' ;
    rdfs:comment 'Indicator of whether the payment instruction can be automatically or manually resubmitted after exception resolution (true = eligible, false = not eligible).' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaActualMinutes rdf:type rdf:Property ;
    rdfs:label 'Sla Actual Minutes' ;
    rdfs:comment 'Actual elapsed time in minutes from exception detection to resolution, used for SLA compliance measurement.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paymentFeeId rdf:type rdf:Property ;
    rdfs:label 'Payment Fee Id' ;
    rdfs:comment 'Unique identifier for the payment fee record. Primary key.' ;
    rdfs:domain ind:PaymentFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:creditorAccountId rdf:type rdf:Property ;
    rdfs:label 'Creditor Account Id' ;
    rdfs:comment 'Reference to the internal general ledger or fee income account to which this fee is credited.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DepositAccount .

ind:basisAmount rdf:type rdf:Property ;
    rdfs:label 'Basis Amount' ;
    rdfs:comment 'The transaction amount or notional value on which the fee calculation is based, in the transaction currency.' ;
    rdfs:domain ind:PaymentFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:basisCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Basis Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code of the fee_basis_amount.' ;
    rdfs:domain ind:PaymentFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Billing Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code in which the customer is billed for this fee (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:PaymentFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingEntityBic rdf:type rdf:Property ;
    rdfs:label 'Billing Entity Bic' ;
    rdfs:comment 'SWIFT Bank Identifier Code (BIC) of the institution charging this fee, if applicable.' ;
    rdfs:domain ind:PaymentFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingEntityName rdf:type rdf:Property ;
    rdfs:label 'Billing Entity Name' ;
    rdfs:comment 'Name of the institution or entity that is charging this fee.' ;
    rdfs:domain ind:PaymentFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeBearerCode rdf:type rdf:Property ;
    rdfs:label 'Charge Bearer Code' ;
    rdfs:comment 'Indicates who bears the fee: OUR (originator pays all fees), BEN (beneficiary pays all fees), SHA (shared - each party pays their own bank\'s fees).' ;
    rdfs:domain ind:PaymentFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeCategory rdf:type rdf:Property ;
    rdfs:label 'Fee Category' ;
    rdfs:comment 'High-level categorization of the fee: TRANSACTION (per-transaction charge), SERVICE (service-level fee), INTERMEDIARY (third-party bank fee), REGULATORY (compliance or reporting fee), PENALTY (late or exception fee).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratePercentage rdf:type rdf:Property ;
    rdfs:label 'Rate Percentage' ;
    rdfs:comment 'The percentage rate applied to the transaction amount to calculate the fee, if fee_calculation_method is PERCENTAGE or TIERED. Expressed as a decimal (e.g., 0.015 for 1.5%).' ;
    rdfs:domain ind:PaymentFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reversalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reversal Timestamp' ;
    rdfs:comment 'Date and time when the fee was reversed, in ISO 8601 format.' ;
    rdfs:domain ind:PaymentFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:taxApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Applicable Flag' ;
    rdfs:comment 'Indicates whether this fee is subject to taxation (e.g., VAT, GST, sales tax). True if tax applies, False otherwise.' ;
    rdfs:domain ind:PaymentFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:beneficiaryAccountId rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Account Id' ;
    rdfs:comment 'Identifier of the account to which the payment is being credited (payee account).' ;
    rdfs:domain ind:Instruction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DepositAccount .

ind:beneficiaryCountryId rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Country Id' ;
    rdfs:comment 'Foreign key linking to reference.country. Business justification: Beneficiary country drives sanctions screening (OFAC country-based sanctions), cross-border reporting (FFIEC 009), routing decisions (local rails vs correspondent), and AML risk scoring. Country maste' ;
    rdfs:domain ind:Instruction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:instructionApprovedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Instruction Approved By User Employee Id' ;
    rdfs:comment 'Identifier of the user who approved this payment instruction for processing.' ;
    rdfs:domain ind:Instruction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:instructionEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Instruction Employee Id' ;
    rdfs:comment 'Identifier of the user or system that submitted this payment instruction.' ;
    rdfs:domain ind:Instruction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:intermediaryCorrespondentBankId rdf:type rdf:Property ;
    rdfs:label 'Intermediary Correspondent Bank Id' ;
    rdfs:comment 'Foreign key linking to payment.correspondent_bank. Business justification: payment_instruction has intermediary_bank_bic which should reference correspondent_bank. For cross-border payments, an intermediary correspondent bank is often required. This is a standard N:1 lookup ' ;
    rdfs:domain ind:Instruction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CorrespondentBank .

ind:originatorPartyId rdf:type rdf:Property ;
    rdfs:label 'Originator Party Id' ;
    rdfs:comment 'Foreign key linking to customer.party. Business justification: Payment origination tracking requires linking instruction to customer party for AML transaction monitoring, customer payment history reporting, and regulatory audit trails. Originator_name is denormal' ;
    rdfs:domain ind:Instruction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:paymentMandateId rdf:type rdf:Property ;
    rdfs:label 'Payment Mandate Id' ;
    rdfs:comment 'Foreign key linking to payment.payment_mandate. Business justification: For direct debit and recurring payments, the payment_instruction should reference the standing payment_mandate that authorizes it. This is a standard N:1 relationship where many payment instructions a' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentMandate .

ind:settlementCurrencyId rdf:type rdf:Property ;
    rdfs:label 'Settlement Currency Id' ;
    rdfs:comment 'Foreign key linking to reference.currency. Business justification: Settlement currency validation against ISO 4217 master required for SWIFT message generation, nostro/vostro account selection, regulatory reporting (FFIEC 009, 031). Payment_currency denormalized text' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:clearingSystemReference rdf:type rdf:Property ;
    rdfs:label 'Clearing System Reference' ;
    rdfs:comment 'Reference number assigned by the clearing system (e.g., ACH, RTGS) during payment processing.' ;
    rdfs:domain ind:Instruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instructionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Instruction Timestamp' ;
    rdfs:comment 'The date and time when the payment instruction was created or initiated by the originator.' ;
    rdfs:domain ind:Instruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:netSettlementAmount rdf:type rdf:Property ;
    rdfs:label 'Net Settlement Amount' ;
    rdfs:comment 'Net amount settled after deducting fees and charges from the gross payment amount.' ;
    rdfs:domain ind:Instruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentPriority rdf:type rdf:Property ;
    rdfs:label 'Payment Priority' ;
    rdfs:comment 'Priority level assigned to the payment instruction for processing sequence (Normal, High, Urgent).' ;
    rdfs:domain ind:Instruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remittanceInformation rdf:type rdf:Property ;
    rdfs:label 'Remittance Information' ;
    rdfs:comment 'Unstructured or structured information provided by the originator to identify the payment to the beneficiary (e.g., invoice number, reference).' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditorBeneficiaryId rdf:type rdf:Property ;
    rdfs:label 'Creditor Beneficiary Id' ;
    rdfs:comment 'Foreign key linking to payment.beneficiary. Business justification: payment_mandate has creditor_name and creditor_account_id. The creditor in a direct debit mandate is a beneficiary in the payment domain. This should be normalized to a FK to beneficiary.beneficiary_i' ;
    rdfs:domain ind:PaymentMandate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Beneficiary .

ind:debtorPartyId rdf:type rdf:Property ;
    rdfs:label 'Debtor Party Id' ;
    rdfs:comment 'Foreign key linking to customer.party. Business justification: Direct debit mandates require party-level authorization tracking for regulatory compliance (SEPA, NACHA rules), dispute resolution, and customer consent management. Debtor_name is denormalized party d' ;
    rdfs:domain ind:PaymentMandate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:primaryPaymentEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Payment Employee Id' ;
    rdfs:comment 'Identifier of the user or system process that created the mandate record. Used for audit trail and accountability.' ;
    rdfs:domain ind:PaymentMandate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:amendmentDate rdf:type rdf:Property ;
    rdfs:label 'Amendment Date' ;
    rdfs:comment 'Date of the most recent amendment to the mandate terms. Null if mandate has never been amended.' ;
    rdfs:domain ind:PaymentMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authorizationReference rdf:type rdf:Property ;
    rdfs:label 'Authorization Reference' ;
    rdfs:comment 'Reference number or identifier for the authorization event or document. Used for audit trail and dispute resolution.' ;
    rdfs:domain ind:PaymentMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionFrequency rdf:type rdf:Property ;
    rdfs:label 'Collection Frequency' ;
    rdfs:comment 'Expected frequency of payment collections under this mandate. ONCE for one-time mandates, ADHOC for variable timing, or regular intervals for recurring mandates. [ENUM-REF-CANDIDATE: ONCE|DAILY|WEEKLY|MONTHLY|QUARTERLY|ANNUALLY|ADHOC — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PaymentMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Amount' ;
    rdfs:comment 'Maximum amount that can be collected in a single transaction under this mandate. Null indicates no limit. Used for debtor protection and validation of collection requests.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextScheduledCollectionDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Collection Date' ;
    rdfs:comment 'Date of the next planned payment collection under this mandate. Used for recurring mandate scheduling and debtor notification.' ;
    rdfs:domain ind:PaymentMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sequenceType rdf:type rdf:Property ;
    rdfs:label 'Sequence Type' ;
    rdfs:comment 'Indicates the position of the collection in the mandate lifecycle. FIRST for initial collection, RECURRING for subsequent collections, FINAL for last collection, ONEOFF for single-use mandates, REPRESENTMENT for retry after return.' ;
    rdfs:domain ind:PaymentMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatureDate rdf:type rdf:Property ;
    rdfs:label 'Signature Date' ;
    rdfs:comment 'Date on which the debtor signed or authorized the mandate. Used to determine mandate validity and for dispute resolution. Must precede first collection date.' ;
    rdfs:domain ind:PaymentMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reconciliationId rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Id' ;
    rdfs:comment 'Unique identifier for the payment reconciliation record. Primary key for the payment reconciliation entity.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reconciliationEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Employee Id' ;
    rdfs:comment 'Identifier of the user or analyst who completed the resolution of reconciliation breaks.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:reconciliationPerformedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Performed By User Employee Id' ;
    rdfs:comment 'Identifier of the user or analyst who initiated or performed the reconciliation activity.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:breakItemCount rdf:type rdf:Property ;
    rdfs:label 'Break Item Count' ;
    rdfs:comment 'The total number of reconciliation break items identified, including discrepancies in amounts, dates, or missing transactions.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cardNetworkName rdf:type rdf:Property ;
    rdfs:label 'Card Network Name' ;
    rdfs:comment 'The name of the card network providing settlement files for card transaction reconciliation.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalStatementReference rdf:type rdf:Property ;
    rdfs:label 'External Statement Reference' ;
    rdfs:comment 'The reference number or identifier of the external statement, confirmation file, or settlement report being reconciled.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchedAmount rdf:type rdf:Property ;
    rdfs:label 'Matched Amount' ;
    rdfs:comment 'The aggregate monetary value of payments that were successfully matched between internal and external records.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:matchedPaymentCount rdf:type rdf:Property ;
    rdfs:label 'Matched Payment Count' ;
    rdfs:comment 'The number of payment transactions that were successfully matched between internal records and external confirmations.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:matchingRuleSet rdf:type rdf:Property ;
    rdfs:label 'Matching Rule Set' ;
    rdfs:comment 'The identifier or name of the rule set or algorithm used to match internal payment records with external confirmations.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Timestamp' ;
    rdfs:comment 'The precise date and time when the reconciliation process was executed.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reconciliationType rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Type' ;
    rdfs:comment 'The category of reconciliation being performed, indicating the source of external records being matched against internal payment records.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaActualHours rdf:type rdf:Property ;
    rdfs:label 'Sla Actual Hours' ;
    rdfs:comment 'The actual number of hours taken to complete the reconciliation process from initiation to resolution.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaTargetHours rdf:type rdf:Property ;
    rdfs:label 'Sla Target Hours' ;
    rdfs:comment 'The target number of hours within which the reconciliation process should be completed according to service level agreements.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:toleranceThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Tolerance Threshold Amount' ;
    rdfs:comment 'The maximum acceptable variance in monetary amounts for a match to be considered successful during reconciliation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPaymentCount rdf:type rdf:Property ;
    rdfs:label 'Total Payment Count' ;
    rdfs:comment 'The total number of payment transactions included in the reconciliation scope.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalReconciledAmount rdf:type rdf:Property ;
    rdfs:label 'Total Reconciled Amount' ;
    rdfs:comment 'The aggregate monetary value of all payments included in the reconciliation scope.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unmatchedAmount rdf:type rdf:Property ;
    rdfs:label 'Unmatched Amount' ;
    rdfs:comment 'The aggregate monetary value of payments that could not be matched, representing the financial exposure of reconciliation breaks.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unmatchedPaymentCount rdf:type rdf:Property ;
    rdfs:label 'Unmatched Payment Count' ;
    rdfs:comment 'The number of payment transactions that could not be matched between internal records and external confirmations, representing reconciliation breaks.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:returnId rdf:type rdf:Property ;
    rdfs:label 'Return Id' ;
    rdfs:comment 'Unique identifier for the payment return record. Primary key for the payment return entity.' ;
    rdfs:domain ind:Return ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:receivingBankCorrespondentBankId rdf:type rdf:Property ;
    rdfs:label 'Receiving Bank Correspondent Bank Id' ;
    rdfs:comment 'Identifier of the financial institution that received the original payment and is initiating the return. May be ABA routing number, SWIFT BIC, or internal bank identifier.' ;
    rdfs:domain ind:Return ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CorrespondentBank .

ind:returnCorrespondentBankId rdf:type rdf:Property ;
    rdfs:label 'Return Correspondent Bank Id' ;
    rdfs:comment 'Identifier of the financial institution that originated the payment being returned. May be ABA routing number, SWIFT BIC, or internal bank identifier.' ;
    rdfs:domain ind:Return ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CorrespondentBank .

ind:addendaInformation rdf:type rdf:Property ;
    rdfs:label 'Addenda Information' ;
    rdfs:comment 'Additional free-form information or notes provided with the return, such as detailed explanation of the return reason or instructions for resubmission.' ;
    rdfs:domain ind:Return ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingHouseName rdf:type rdf:Property ;
    rdfs:label 'Clearing House Name' ;
    rdfs:comment 'Name of the clearing house or payment network through which the return was processed (e.g., Federal Reserve ACH, The Clearing House, SWIFT, local RTGS system).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingHouseReference rdf:type rdf:Property ;
    rdfs:label 'Clearing House Reference' ;
    rdfs:comment 'Unique reference number assigned by the clearing house to this return transaction for tracking and reconciliation purposes.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contestedReturnFlag rdf:type rdf:Property ;
    rdfs:label 'Contested Return Flag' ;
    rdfs:comment 'Indicates whether the return has been contested or disputed by the originating bank.' ;
    rdfs:domain ind:Return ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dishonoredReturnFlag rdf:type rdf:Property ;
    rdfs:label 'Dishonored Return Flag' ;
    rdfs:comment 'Indicates whether this is a dishonored return (return of a return), which occurs when the originating bank contests the return.' ;
    rdfs:domain ind:Return ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fraudIndicatorFlag rdf:type rdf:Property ;
    rdfs:label 'Fraud Indicator Flag' ;
    rdfs:comment 'Indicates whether the return is associated with suspected fraudulent activity or unauthorized transactions.' ;
    rdfs:domain ind:Return ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originalPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Original Payment Date' ;
    rdfs:comment 'Business date of the original payment transaction that is being returned.' ;
    rdfs:domain ind:Return ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originalPaymentReference rdf:type rdf:Property ;
    rdfs:label 'Original Payment Reference' ;
    rdfs:comment 'Business reference number or transaction identifier of the original payment being returned.' ;
    rdfs:domain ind:Return ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resubmissionCount rdf:type rdf:Property ;
    rdfs:label 'Resubmission Count' ;
    rdfs:comment 'Number of times this payment has been resubmitted after previous returns. NACHA rules limit resubmissions to two attempts for certain return codes.' ;
    rdfs:domain ind:Return ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:returnStatus rdf:type rdf:Property ;
    rdfs:label 'Return Status' ;
    rdfs:comment 'Current lifecycle status of the return transaction indicating its processing state.' ;
    rdfs:domain ind:Return ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnTimestamp rdf:type rdf:Property ;
    rdfs:label 'Return Timestamp' ;
    rdfs:comment 'Precise date and time when the return transaction was created or received in the payment processing system.' ;
    rdfs:domain ind:Return ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:returnType rdf:type rdf:Property ;
    rdfs:label 'Return Type' ;
    rdfs:comment 'Classification of the return transaction based on the payment rail or system through which it was processed.' ;
    rdfs:domain ind:Return ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:windowDays rdf:type rdf:Property ;
    rdfs:label 'Window Days' ;
    rdfs:comment 'Number of days from the original payment date within which the return was initiated. Different return reason codes have different allowable return windows (e.g., 2 banking days for R01, 60 days for unauthorized debits).' ;
    rdfs:domain ind:Return ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:routingId rdf:type rdf:Property ;
    rdfs:label 'Routing Id' ;
    rdfs:comment 'Unique identifier for the payment routing rule. Primary key for the payment routing configuration.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:destinationCountryId rdf:type rdf:Property ;
    rdfs:label 'Destination Country Id' ;
    rdfs:comment 'Foreign key linking to reference.country. Business justification: Routing rules vary by destination country for cost optimization (local rails vs SWIFT), speed (RTGS availability), and regulatory compliance (sanctions screening, reporting thresholds). Country master' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:destinationCurrencyId rdf:type rdf:Property ;
    rdfs:label 'Destination Currency Id' ;
    rdfs:comment 'Foreign key linking to reference.currency. Business justification: Routing optimized per currency based on nostro liquidity, correspondent bank relationships, and clearing costs. Currency master provides convertibility status, restrictions, and settlement lag for rou' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:fallbackRoutingRuleRoutingId rdf:type rdf:Property ;
    rdfs:label 'Fallback Routing Rule Routing Id' ;
    rdfs:comment 'Identifier of an alternative routing rule to use if this primary routing path fails or is unavailable.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Routing .

ind:routingApprovedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Routing Approved By User Employee Id' ;
    rdfs:comment 'User identifier of the approver who authorized this routing rule for production use.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:routingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Routing Employee Id' ;
    rdfs:comment 'User identifier of the person or system that last modified this routing rule, for audit and accountability.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:amlMonitoringLevel rdf:type rdf:Property ;
    rdfs:label 'Aml Monitoring Level' ;
    rdfs:comment 'Level of AML transaction monitoring applied to payments using this routing path, based on risk assessment.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Approval Threshold Amount' ;
    rdfs:comment 'Payment amount threshold above which manual approval or additional authorization is required before routing.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costBasisPoints rdf:type rdf:Property ;
    rdfs:label 'Cost Basis Points' ;
    rdfs:comment 'Cost of using this routing path expressed in basis points (BPS) of the payment amount. Used for cost-optimized routing decisions.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cutoffTimeLocal rdf:type rdf:Property ;
    rdfs:label 'Cutoff Time Local' ;
    rdfs:comment 'Daily cut-off time in local time zone (HH:MM:SS format) by which payment instructions must be received to be included in the current settlement cycle.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cutoffTimezone rdf:type rdf:Property ;
    rdfs:label 'Cutoff Timezone' ;
    rdfs:comment 'Time zone identifier for the cut-off time (e.g., EST, GMT, CET) to ensure accurate cross-border timing.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dailyAggregateLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Daily Aggregate Limit Amount' ;
    rdfs:comment 'Maximum cumulative amount allowed per day through this routing path. Used for liquidity management and risk control.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:engineVersion rdf:type rdf:Property ;
    rdfs:label 'Engine Version' ;
    rdfs:comment 'Version identifier of the payment routing engine configuration that created or last modified this rule.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liquidityReserveRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Liquidity Reserve Requirement Flag' ;
    rdfs:comment 'Indicates whether this routing path requires pre-funded liquidity reserves to be maintained for settlement assurance.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentRailCode rdf:type rdf:Property ;
    rdfs:label 'Payment Rail Code' ;
    rdfs:comment 'The payment rail or network through which the payment is routed. Determines the clearing and settlement infrastructure used. [ENUM-REF-CANDIDATE: ACH|WIRE|RTGS|SWIFT|CARD|SEPA|FASTER_PAYMENTS|TARGET2 — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:railSettlementModel rdf:type rdf:Property ;
    rdfs:label 'Rail Settlement Model' ;
    rdfs:comment 'Settlement model used by the payment rail: gross settlement (transaction-by-transaction) or net settlement (batch netting).' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sanctionsScreeningRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Sanctions Screening Required Flag' ;
    rdfs:comment 'Indicates whether payments routed via this path must undergo OFAC and sanctions screening before execution.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:settlementCycleCode rdf:type rdf:Property ;
    rdfs:label 'Settlement Cycle Code' ;
    rdfs:comment 'Settlement cycle indicating when funds are finalized. T+0 is same-day, T+1 is next business day, real-time is immediate.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:singleTransactionLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Single Transaction Limit Amount' ;
    rdfs:comment 'Maximum amount allowed for a single payment transaction through this routing path. Enforces per-transaction risk controls.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:speedMinutes rdf:type rdf:Property ;
    rdfs:label 'Speed Minutes' ;
    rdfs:comment 'Expected end-to-end processing time in minutes for payments routed via this path, used for speed-optimized routing.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:velocityLimitCount rdf:type rdf:Property ;
    rdfs:label 'Velocity Limit Count' ;
    rdfs:comment 'Maximum number of payments allowed through this routing path within the velocity window. Used for risk management and fraud prevention.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:velocityWindowMinutes rdf:type rdf:Property ;
    rdfs:label 'Velocity Window Minutes' ;
    rdfs:comment 'Time window in minutes over which the velocity limit count is enforced. Supports sliding-window velocity checks.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sanctionScreeningId rdf:type rdf:Property ;
    rdfs:label 'Sanction Screening Id' ;
    rdfs:comment 'Unique identifier for the payment sanction screening record.' ;
    rdfs:domain ind:SanctionScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:analystDecision rdf:type rdf:Property ;
    rdfs:label 'Analyst Decision' ;
    rdfs:comment 'Final decision made by the AML analyst after reviewing the sanctions alert: approve payment, reject payment, mark as false positive, or escalate to Money Laundering Reporting Officer (MLRO).' ;
    rdfs:domain ind:SanctionScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analystReviewRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Analyst Review Required Flag' ;
    rdfs:comment 'Indicates whether the screening result requires manual review by an Anti-Money Laundering (AML) analyst due to potential match or high-risk indicators.' ;
    rdfs:domain ind:SanctionScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:autoDecisionFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Decision Flag' ;
    rdfs:comment 'Indicates whether the screening decision was made automatically by the system (true) or required manual analyst review (false).' ;
    rdfs:domain ind:SanctionScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:matchedField rdf:type rdf:Property ;
    rdfs:label 'Matched Field' ;
    rdfs:comment 'Specific field in the payment instruction that triggered the sanctions match: name, address, identifier, account number, Bank Identifier Code (BIC), or International Bank Account Number (IBAN).' ;
    rdfs:domain ind:SanctionScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchedPartyRole rdf:type rdf:Property ;
    rdfs:label 'Matched Party Role' ;
    rdfs:comment 'Role of the payment party that triggered the sanctions match: originator, beneficiary, intermediary bank, or correspondent bank.' ;
    rdfs:domain ind:SanctionScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ofacBlockingReportReference rdf:type rdf:Property ;
    rdfs:label 'Ofac Blocking Report Reference' ;
    rdfs:comment 'Reference number of the blocking report submitted to Office of Foreign Assets Control (OFAC) for confirmed sanctions matches requiring asset blocking.' ;
    rdfs:domain ind:SanctionScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ofacBlockingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Ofac Blocking Required Flag' ;
    rdfs:comment 'Indicates whether the payment must be blocked and reported to Office of Foreign Assets Control (OFAC) due to confirmed match with a sanctioned entity under United States sanctions programs.' ;
    rdfs:domain ind:SanctionScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:screeningDecision rdf:type rdf:Property ;
    rdfs:label 'Screening Decision' ;
    rdfs:comment 'Automated or manual decision resulting from the sanctions screening: pass (allow payment), hold (suspend for review), block (reject payment), or escalate (send to compliance officer).' ;
    rdfs:domain ind:SanctionScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningDurationMs rdf:type rdf:Property ;
    rdfs:label 'Screening Duration Ms' ;
    rdfs:comment 'Time taken to complete the sanctions screening process measured in milliseconds, used for system performance monitoring and Service Level Agreement (SLA) compliance.' ;
    rdfs:domain ind:SanctionScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:screeningErrorCode rdf:type rdf:Property ;
    rdfs:label 'Screening Error Code' ;
    rdfs:comment 'Error code returned by the sanctions screening system if the screening process failed or encountered technical issues.' ;
    rdfs:domain ind:SanctionScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningErrorMessage rdf:type rdf:Property ;
    rdfs:label 'Screening Error Message' ;
    rdfs:comment 'Detailed error message describing any technical issues encountered during the sanctions screening process.' ;
    rdfs:domain ind:SanctionScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningSystemName rdf:type rdf:Property ;
    rdfs:label 'Screening System Name' ;
    rdfs:comment 'Name of the Anti-Money Laundering (AML) and sanctions screening system that performed the check (e.g., NICE Actimize, Oracle Financial Crime).' ;
    rdfs:domain ind:SanctionScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:watchlistType rdf:type rdf:Property ;
    rdfs:label 'Watchlist Type' ;
    rdfs:comment 'Type of sanctions or watchlist screened against: Office of Foreign Assets Control (OFAC) Specially Designated Nationals (SDN), European Union (EU) Consolidated List, United Nations (UN) Sanctions, Politically Exposed Persons (PEP), Her Majesty\'s Treasury (HMT) UK, or Department of Foreign Affairs and Trade (DFAT) Australia.' ;
    rdfs:domain ind:SanctionScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusEventId rdf:type rdf:Property ;
    rdfs:label 'Status Event Id' ;
    rdfs:comment 'Unique identifier for the payment status event record. Primary key for the immutable event log.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryStatusEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Status Employee Id' ;
    rdfs:comment 'Identifier of the human operator or service account that triggered this event. Null for fully automated STP events. Used for audit trail and accountability.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:swiftMessageId rdf:type rdf:Property ;
    rdfs:label 'Swift Message Id' ;
    rdfs:comment 'Unique identifier of the payment message (e.g., SWIFT MT103 message ID, ISO 20022 message identification) associated with this event. Used for message-level traceability.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SwiftMessage .

ind:eventSourceModule rdf:type rdf:Property ;
    rdfs:label 'Event Source Module' ;
    rdfs:comment 'Specific module or component within the payment hub that generated this event (e.g., Payment Validation Engine, Routing Engine, Settlement Engine, Exception Handler, Sanctions Filter). More granular than originating_system.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newStatusCode rdf:type rdf:Property ;
    rdfs:label 'New Status Code' ;
    rdfs:comment 'The payment status after this event. Uses ISO 20022 external payment status codes. Represents the current state of the payment following this transition. [ENUM-REF-CANDIDATE: INIT|PNDG|ACCP|ACSC|ACSP|ACTC|ACWC|RJCT|CANC|PDNG|PART|ACCC — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originatingSystem rdf:type rdf:Property ;
    rdfs:label 'Originating System' ;
    rdfs:comment 'Name or identifier of the system component that generated this event (e.g., ACI Payment Engine, Volante Routing Module, SWIFT Gateway, Exception Management Module, Sanctions Screening Engine).' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorStatusCode rdf:type rdf:Property ;
    rdfs:label 'Prior Status Code' ;
    rdfs:comment 'The payment status immediately before this event. Uses ISO 20022 external payment status codes: INIT (Initiated), PNDG (Pending), ACCP (Accepted Customer Profile), ACSC (Accepted Settlement Completed), ACSP (Accepted Settlement In Process), ACTC (Accepted Technical Validation), ACWC (Accepted With Change), RJCT (Rejected), CANC (Cancelled), PDNG (Pending), PART (Partially Accepted), ACCC (Accepted Settlement Completed Creditor Account). [ENUM-REF-CANDIDATE: INIT|PNDG|ACCP|ACSC|ACSP|ACTC|ACWC|RJCT|CANC|PDNG|PART|ACCC — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionReference rdf:type rdf:Property ;
    rdfs:label 'Transaction Reference' ;
    rdfs:comment 'End-to-end transaction reference provided by the payment originator. Used for reconciliation and customer inquiry. Also known as UETR (Unique End-to-End Transaction Reference) in SWIFT context.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:custodianAccountId rdf:type rdf:Property ;
    rdfs:label 'Custodian Account Id' ;
    rdfs:comment 'Foreign key linking to wealth.custodian_account. Business justification: Securities settlement requires cash movement through payment rails to/from custodian accounts. Treasury operations execute dividend payments, subscription/redemption settlements, and fee debits agains' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustodianAccount .

ind:primaryPaymentDepositAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Payment Deposit Account Id' ;
    rdfs:comment 'Reference to the account from which funds are debited in this transaction.' ;
    rdfs:domain ind:PaymentTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DepositAccount .

ind:primaryPaymentPartyId rdf:type rdf:Property ;
    rdfs:label 'Primary Payment Party Id' ;
    rdfs:comment 'Reference to the customer initiating the payment transaction.' ;
    rdfs:domain ind:PaymentTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:executionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Execution Timestamp' ;
    rdfs:comment 'The precise date and time when the payment transaction was executed and entered the clearing process.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:failureReasonCode rdf:type rdf:Property ;
    rdfs:label 'Failure Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for transaction failure or rejection (e.g., insufficient funds, invalid account, compliance hold).' ;
    rdfs:domain ind:PaymentTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netSettlementPosition rdf:type rdf:Property ;
    rdfs:label 'Net Settlement Position' ;
    rdfs:comment 'The net position of the transaction after multilateral netting with other transactions in the same settlement batch.' ;
    rdfs:domain ind:PaymentTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnReasonCode rdf:type rdf:Property ;
    rdfs:label 'Return Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for payment return (e.g., account closed, unauthorized, incorrect account number).' ;
    rdfs:domain ind:PaymentTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingPriority rdf:type rdf:Property ;
    rdfs:label 'Routing Priority' ;
    rdfs:comment 'Priority level assigned to the payment transaction for routing and processing (High, Normal, Low).' ;
    rdfs:domain ind:PaymentTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:senderCountryId rdf:type rdf:Property ;
    rdfs:label 'Sender Country Id' ;
    rdfs:comment 'Foreign key linking to reference.country. Business justification: SWIFT sender country determines regulatory reporting obligations (EU GDPR for data residency, US OFAC for sanctions), message routing priority, and GPI tracking requirements. Country master provides t' ;
    rdfs:domain ind:SwiftMessage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:beneficiaryAccount rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Account' ;
    rdfs:comment 'The account number or IBAN of the beneficiary receiving the payment.' ;
    rdfs:domain ind:SwiftMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargesCode rdf:type rdf:Property ;
    rdfs:label 'Charges Code' ;
    rdfs:comment 'Indicates who bears the transaction charges. OUR: sender pays all charges; BEN: beneficiary pays all charges; SHA: charges are shared.' ;
    rdfs:domain ind:SwiftMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditConfirmationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Credit Confirmation Timestamp' ;
    rdfs:comment 'The timestamp when the beneficiary bank confirmed that funds were credited to the beneficiary account. Part of SWIFT GPI tracking.' ;
    rdfs:domain ind:SwiftMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:gpiStatusCode rdf:type rdf:Property ;
    rdfs:label 'Gpi Status Code' ;
    rdfs:comment 'The SWIFT GPI status code indicating the current state of the payment in the GPI tracking system. Common codes: g001 (credit to beneficiary), g002 (funds available), g004 (payment completed).' ;
    rdfs:domain ind:SwiftMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gpiTrackerTimestamp rdf:type rdf:Property ;
    rdfs:label 'Gpi Tracker Timestamp' ;
    rdfs:comment 'The timestamp when the payment status was last updated in the SWIFT GPI tracking system.' ;
    rdfs:domain ind:SwiftMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:messageBody rdf:type rdf:Property ;
    rdfs:label 'Message Body' ;
    rdfs:comment 'The complete payload of the SWIFT message in its native format (MT or MX/XML). Contains all transaction details, beneficiary information, and payment instructions.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:messageProcessedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Message Processed Timestamp' ;
    rdfs:comment 'The timestamp when the SWIFT message was processed and posted to internal systems (e.g., core banking, payment hub).' ;
    rdfs:domain ind:SwiftMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:messageReceivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Message Received Timestamp' ;
    rdfs:comment 'The timestamp when the SWIFT message was received by the destination institution.' ;
    rdfs:domain ind:SwiftMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:messageReference rdf:type rdf:Property ;
    rdfs:label 'Message Reference' ;
    rdfs:comment 'The unique reference number assigned to the SWIFT message by the sender. Used for message tracking and reconciliation.' ;
    rdfs:domain ind:SwiftMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:messageSentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Message Sent Timestamp' ;
    rdfs:comment 'The timestamp when the SWIFT message was sent by the originating institution.' ;
    rdfs:domain ind:SwiftMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:messageStatus rdf:type rdf:Property ;
    rdfs:label 'Message Status' ;
    rdfs:comment 'Current processing status of the SWIFT message in its lifecycle. Tracks acknowledgement, delivery confirmation, and any failure states.' ;
    rdfs:domain ind:SwiftMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:messageType rdf:type rdf:Property ;
    rdfs:label 'Message Type' ;
    rdfs:comment 'The SWIFT message type identifier. For MT messages: MT103, MT202, MT900, MT910, etc. For MX (ISO 20022) messages: pacs.008, camt.054, pain.001, etc.' ;
    rdfs:domain ind:SwiftMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderingCustomerAccount rdf:type rdf:Property ;
    rdfs:label 'Ordering Customer Account' ;
    rdfs:comment 'The account number or IBAN of the customer initiating the payment.' ;
    rdfs:domain ind:SwiftMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderingCustomerName rdf:type rdf:Property ;
    rdfs:label 'Ordering Customer Name' ;
    rdfs:comment 'The name of the customer or entity initiating the payment instruction.' ;
    rdfs:domain ind:SwiftMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportingCode rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Code' ;
    rdfs:comment 'Code used for regulatory reporting purposes, such as purpose of payment codes required by central banks or tax authorities (e.g., FATCA, CRS reporting codes).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relatedReference rdf:type rdf:Property ;
    rdfs:label 'Related Reference' ;
    rdfs:comment 'Reference to a related SWIFT message, such as the original message being amended, cancelled, or queried. Nullable if not applicable.' ;
    rdfs:domain ind:SwiftMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:senderChargesAmount rdf:type rdf:Property ;
    rdfs:label 'Sender Charges Amount' ;
    rdfs:comment 'The amount of charges deducted by the sending bank or intermediary banks during message processing.' ;
    rdfs:domain ind:SwiftMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:senderChargesCurrency rdf:type rdf:Property ;
    rdfs:label 'Sender Charges Currency' ;
    rdfs:comment 'The three-letter ISO 4217 currency code for the sender charges amount.' ;
    rdfs:domain ind:SwiftMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uetr rdf:type rdf:Property ;
    rdfs:label 'Uetr' ;
    rdfs:comment 'The UETR is a universally unique identifier (UUID v4) that enables end-to-end tracking of payment messages across the SWIFT network, particularly for SWIFT GPI transactions.' ;
    rdfs:domain ind:SwiftMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benchmarkRateFixingId rdf:type rdf:Property ;
    rdfs:label 'Benchmark Rate Fixing Id' ;
    rdfs:comment 'Unique identifier for each benchmark rate fixing record. Primary key for the benchmark_rate_fixing product.' ;
    rdfs:domain ind:BenchmarkRateFixing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:compoundingMethod rdf:type rdf:Property ;
    rdfs:label 'Compounding Method' ;
    rdfs:comment 'The calculation methodology used to derive the rate fixing when based on multiple observations (e.g., simple average, compound, weighted average). Set to \'none\' for single-observation spot rates.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fallbackMethodology rdf:type rdf:Property ;
    rdfs:label 'Fallback Methodology' ;
    rdfs:comment 'Description of the fallback calculation methodology applied if this is a fallback rate (e.g., compounded SOFR plus spread adjustment). Null if not a fallback.' ;
    rdfs:domain ind:BenchmarkRateFixing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fallbackRateIndicator rdf:type rdf:Property ;
    rdfs:label 'Fallback Rate Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this rate is a fallback or substitute rate used when the primary benchmark is unavailable (e.g., LIBOR transition fallbacks). True if this is a fallback rate.' ;
    rdfs:domain ind:BenchmarkRateFixing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isBusinessDay rdf:type rdf:Property ;
    rdfs:label 'Is Business Day' ;
    rdfs:comment 'Boolean flag indicating whether the fixing date is a business day in the relevant market. False if the fixing date falls on a weekend or holiday, which may affect rate applicability.' ;
    rdfs:domain ind:BenchmarkRateFixing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRevised rdf:type rdf:Property ;
    rdfs:label 'Is Revised' ;
    rdfs:comment 'Boolean flag indicating whether this fixing is a revision or correction of a previously published rate. True if this record supersedes an earlier fixing for the same date and tenor.' ;
    rdfs:domain ind:BenchmarkRateFixing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:numberOfTransactions rdf:type rdf:Property ;
    rdfs:label 'Number Of Transactions' ;
    rdfs:comment 'The count of individual transactions used to calculate the benchmark rate, if published by the rate authority. Indicates market breadth. Null if not disclosed.' ;
    rdfs:domain ind:BenchmarkRateFixing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:observationPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Observation Period End' ;
    rdfs:comment 'The end date of the observation period used to calculate the rate fixing. Null for spot rates.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:observationPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Observation Period Start' ;
    rdfs:comment 'The start date of the observation period used to calculate the rate fixing, applicable for compounded or averaged rates (e.g., SOFR averages). Null for spot rates.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:publicationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Publication Timestamp' ;
    rdfs:comment 'The exact date and time when the rate fixing was officially published by the rate authority. Used for audit trails and to determine which rate applies for time-sensitive calculations.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rateBasisPoints rdf:type rdf:Property ;
    rdfs:label 'Rate Basis Points' ;
    rdfs:comment 'The rate value expressed in basis points for convenience (e.g., 525.00 BPS for 5.25%). One basis point equals 0.01%. Commonly used in trading and risk reporting.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateValue rdf:type rdf:Property ;
    rdfs:label 'Rate Value' ;
    rdfs:comment 'The published benchmark interest rate value expressed as a decimal (e.g., 0.05250000 for 5.25%). This is the official fixing rate used for loan accrual, derivative settlement, and mark-to-market calculations.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revisionReason rdf:type rdf:Property ;
    rdfs:label 'Revision Reason' ;
    rdfs:comment 'Explanation provided by the rate authority for why the rate was revised or corrected. Null if not a revision.' ;
    rdfs:domain ind:BenchmarkRateFixing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionSequence rdf:type rdf:Property ;
    rdfs:label 'Revision Sequence' ;
    rdfs:comment 'Sequential number indicating the revision iteration for this fixing date and tenor. Initial publication is 1, first revision is 2, etc. Null if never revised.' ;
    rdfs:domain ind:BenchmarkRateFixing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceAuthority rdf:type rdf:Property ;
    rdfs:label 'Source Authority' ;
    rdfs:comment 'The official organization or entity that published the benchmark rate fixing (e.g., Federal Reserve Bank of New York for SOFR, European Money Markets Institute for EURIBOR, Bank of England for SONIA).' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spreadAdjustment rdf:type rdf:Property ;
    rdfs:label 'Spread Adjustment' ;
    rdfs:comment 'The spread adjustment (in decimal form) added to the fallback rate to align it with the discontinued benchmark. Used in LIBOR transition scenarios. Null if not applicable.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supersededRateValue rdf:type rdf:Property ;
    rdfs:label 'Superseded Rate Value' ;
    rdfs:comment 'The previous rate value that this fixing replaces, if this is a revision. Null for initial publications. Used for audit trails and impact analysis of rate corrections.' ;
    rdfs:domain ind:BenchmarkRateFixing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tenorCode rdf:type rdf:Property ;
    rdfs:label 'Tenor Code' ;
    rdfs:comment 'The maturity period for which the rate applies. Standard tenors include overnight (O/N), tomorrow-next (T/N), spot-next (S/N), and term periods (1W, 1M, 3M, 6M, 12M). Critical for matching rates to loan and derivative contract terms. [ENUM-REF-CANDIDATE: O/N|T/N|S/N|1W|2W|1M|2M|3M|6M|9M|12M — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BenchmarkRateFixing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeTraded rdf:type rdf:Property ;
    rdfs:label 'Volume Traded' ;
    rdfs:comment 'The total transaction volume (in currency units) underlying the rate calculation, if published by the rate authority. Provides transparency on market depth. Null if not disclosed.' ;
    rdfs:domain ind:BenchmarkRateFixing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bic11 rdf:type rdf:Property ;
    rdfs:label 'Bic11' ;
    rdfs:comment 'The 11-character BIC code including the 3-character branch code suffix. Used for branch-level identification in SWIFT messaging.' ;
    rdfs:domain ind:BicDirectory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bic8 rdf:type rdf:Property ;
    rdfs:label 'Bic8' ;
    rdfs:comment 'The 8-character BIC code identifying the institution, comprising institution code (4 chars), country code (2 chars), and location code (2 chars). Used for head office identification.' ;
    rdfs:domain ind:BicDirectory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:connectivityStatus rdf:type rdf:Property ;
    rdfs:label 'Connectivity Status' ;
    rdfs:comment 'The current operational status of the BIC code in the SWIFT network. Live indicates active production use; test indicates sandbox environment; inactive indicates decommissioned; suspended indicates temporarily disabled.' ;
    rdfs:domain ind:BicDirectory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correspondentBankingRole rdf:type rdf:Property ;
    rdfs:label 'Correspondent Banking Role' ;
    rdfs:comment 'The role this institution plays in correspondent banking relationships. Nostro indicates the institution holds accounts at other banks; vostro indicates other banks hold accounts here; both indicates bidirectional relationships; none indicates no correspondent banking.' ;
    rdfs:domain ind:BicDirectory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cutOffTimeLocal rdf:type rdf:Property ;
    rdfs:label 'Cut Off Time Local' ;
    rdfs:comment 'The local time (HH:MM format) by which payment instructions must be received for same-day value. Used by payment processing hubs for scheduling.' ;
    rdfs:domain ind:BicDirectory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ibanSupported rdf:type rdf:Property ;
    rdfs:label 'Iban Supported' ;
    rdfs:comment 'Indicates whether the institution supports IBAN format for account identification. Mandatory in SEPA countries; optional elsewhere.' ;
    rdfs:domain ind:BicDirectory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:institutionName rdf:type rdf:Property ;
    rdfs:label 'Institution Name' ;
    rdfs:comment 'The legal name of the financial institution associated with this BIC code. Used for correspondent banking identification and payment processing.' ;
    rdfs:domain ind:BicDirectory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nationalIdentifierCode rdf:type rdf:Property ;
    rdfs:label 'National Identifier Code' ;
    rdfs:comment 'The national registration or license number assigned by the domestic banking regulator. Format varies by jurisdiction (e.g., FDIC Certificate Number in USA, Financial Conduct Authority (FCA) number in UK).' ;
    rdfs:domain ind:BicDirectory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentServicesEnabled rdf:type rdf:Property ;
    rdfs:label 'Payment Services Enabled' ;
    rdfs:comment 'Indicates whether this BIC is enabled for payment processing services including wire transfers, Automated Clearing House (ACH), and Real-Time Gross Settlement (RTGS).' ;
    rdfs:domain ind:BicDirectory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:routingNumber rdf:type rdf:Property ;
    rdfs:label 'Routing Number' ;
    rdfs:comment 'The domestic routing or sort code used for local payment clearing. Examples include American Bankers Association (ABA) routing number (USA), sort code (UK), Bankleitzahl (Germany). Null for institutions without domestic clearing participation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securitiesServicesEnabled rdf:type rdf:Property ;
    rdfs:label 'Securities Services Enabled' ;
    rdfs:comment 'Indicates whether this BIC is enabled for securities settlement, custody, and clearing services. Relevant for broker-dealers and custodian banks.' ;
    rdfs:domain ind:BicDirectory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sepaParticipant rdf:type rdf:Property ;
    rdfs:label 'Sepa Participant' ;
    rdfs:comment 'Indicates whether the institution is a participant in the Single Euro Payments Area for euro-denominated payments. Applicable to European Economic Area (EEA) institutions.' ;
    rdfs:domain ind:BicDirectory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:swiftServiceProfile rdf:type rdf:Property ;
    rdfs:label 'Swift Service Profile' ;
    rdfs:comment 'Comma-separated list of SWIFT service types supported by this BIC. Examples include FIN (financial messaging), FileAct (file transfer), InterAct (real-time messaging), and Browse (information retrieval).' ;
    rdfs:domain ind:BicDirectory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeFinanceServicesEnabled rdf:type rdf:Property ;
    rdfs:label 'Trade Finance Services Enabled' ;
    rdfs:comment 'Indicates whether this BIC is enabled for trade finance services including letters of credit, guarantees, and documentary collections.' ;
    rdfs:domain ind:BicDirectory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:businessOwner rdf:type rdf:Property ;
    rdfs:label 'Business Owner' ;
    rdfs:comment 'Name or identifier of the business unit, line of business (LOB), or functional area responsible for defining and maintaining this code value. Establishes accountability for code list governance.' ;
    rdfs:domain ind:CodeList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codeDescription rdf:type rdf:Property ;
    rdfs:label 'Code Description' ;
    rdfs:comment 'Detailed business definition and explanation of the code value, including usage context, calculation rules, and business implications. Provides comprehensive documentation for business users and analysts.' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codeLabel rdf:type rdf:Property ;
    rdfs:label 'Code Label' ;
    rdfs:comment 'Human-readable short label or display name for the code value, used in user interfaces and reports (e.g., \'Actual/360\', \'Corporate Counterparty\', \'Investment Grade\').' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codeLevel rdf:type rdf:Property ;
    rdfs:label 'Code Level' ;
    rdfs:comment 'Hierarchical level or depth of the code within its taxonomy (e.g., 1 for top-level, 2 for sub-category, 3 for detail). Used for hierarchical navigation and aggregation logic.' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:codeListType rdf:type rdf:Property ;
    rdfs:label 'Code List Type' ;
    rdfs:comment 'The category or domain of the code list (e.g., day_count_convention, settlement_instruction_type, counterparty_type, credit_rating_scale, gl_account_type, nace_sector_code, sic_sector_code). Serves as the primary discriminator for grouping related code values.' ;
    rdfs:domain ind:CodeList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codeValue rdf:type rdf:Property ;
    rdfs:label 'Code Value' ;
    rdfs:comment 'The actual code or key value used in operational systems and data models (e.g., ACT/360, 30/360, T+1, CORP, GOVT). This is the machine-readable identifier that applications reference.' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataSteward rdf:type rdf:Property ;
    rdfs:label 'Data Steward' ;
    rdfs:comment 'Name or identifier of the individual or team responsible for the operational maintenance, quality assurance, and lifecycle management of this code value.' ;
    rdfs:domain ind:CodeList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalCodeMapping rdf:type rdf:Property ;
    rdfs:label 'External Code Mapping' ;
    rdfs:comment 'Cross-reference to equivalent codes in external systems, vendor platforms, or industry standards (e.g., mapping internal credit rating codes to S&P, Moody\'s, and Fitch scales). Supports data integration and regulatory reporting.' ;
    rdfs:domain ind:CodeList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDefault rdf:type rdf:Property ;
    rdfs:label 'Is Default' ;
    rdfs:comment 'Indicates whether this code value should be used as the default selection in user interfaces or system processes when no explicit value is provided. Only one code per code_list_type should be marked as default.' ;
    rdfs:domain ind:CodeList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSystemGenerated rdf:type rdf:Property ;
    rdfs:label 'Is System Generated' ;
    rdfs:comment 'Indicates whether this code value was automatically generated by system processes (true) or manually created by data stewards (false). Supports audit trails and data lineage tracking.' ;
    rdfs:domain ind:CodeList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentCodeValue rdf:type rdf:Property ;
    rdfs:label 'Parent Code Value' ;
    rdfs:comment 'Reference to the parent code value for hierarchical code lists (e.g., NACE/SIC sector hierarchies, GL account type hierarchies). Null for top-level codes. Enables drill-down and roll-up analytics.' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sortOrder rdf:type rdf:Property ;
    rdfs:label 'Sort Order' ;
    rdfs:comment 'Numeric sequence for controlling display order in user interfaces, reports, and dropdown lists. Lower numbers appear first. Enables business-driven presentation logic independent of alphabetical sorting.' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supersededByCodeValue rdf:type rdf:Property ;
    rdfs:label 'Superseded By Code Value' ;
    rdfs:comment 'Reference to the replacement code value when this code is deprecated or retired (e.g., LIBOR codes superseded by SOFR codes). Enables automated migration and data remediation processes.' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:achSystemName rdf:type rdf:Property ;
    rdfs:label 'Ach System Name' ;
    rdfs:comment 'Name of the country\'s automated clearing house system for retail payments (e.g., ACH for USA, Bacs for UK, SEPA for Eurozone). Used for batch payment processing, direct debit operations, and retail payment routing.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselCommitteeMemberFlag rdf:type rdf:Property ;
    rdfs:label 'Basel Committee Member Flag' ;
    rdfs:comment 'Indicates whether the country is represented on the Basel Committee on Banking Supervision. Signals adoption of Basel III capital and liquidity standards, relevant for counterparty risk assessment and regulatory capital calculations.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:callingCode rdf:type rdf:Property ;
    rdfs:label 'Calling Code' ;
    rdfs:comment 'International dialing prefix for the country (e.g., +1 for USA, +44 for UK). Used for phone number validation, customer contact data standardization, and communication routing.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capitalCity rdf:type rdf:Property ;
    rdfs:label 'Capital City' ;
    rdfs:comment 'Name of the country\'s capital city. Used for geographic reference, branch location planning, and regulatory correspondence addressing.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryName rdf:type rdf:Property ;
    rdfs:label 'Country Name' ;
    rdfs:comment 'Official short-form name of the country in English (e.g., United States of America, United Kingdom, Germany). Used for customer-facing displays, reports, and regulatory filings.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crsJurisdictionFlag rdf:type rdf:Property ;
    rdfs:label 'Crs Jurisdiction Flag' ;
    rdfs:comment 'Indicates whether the country is a CRS participating jurisdiction requiring automatic exchange of financial account information. Essential for global tax compliance and regulatory reporting.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crsReportableJurisdictionFlag rdf:type rdf:Property ;
    rdfs:label 'Crs Reportable Jurisdiction Flag' ;
    rdfs:comment 'Indicates whether accounts held by residents of this country must be reported under CRS. Used in customer classification and regulatory reporting workflows.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eeaMemberFlag rdf:type rdf:Property ;
    rdfs:label 'Eea Member Flag' ;
    rdfs:comment 'Indicates whether the country is a member of the European Economic Area (EU plus Iceland, Liechtenstein, Norway). Relevant for passporting rights, regulatory equivalence, and data protection frameworks.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:euMemberFlag rdf:type rdf:Property ;
    rdfs:label 'Eu Member Flag' ;
    rdfs:comment 'Indicates whether the country is a current member of the European Union. Used for regulatory compliance (GDPR, MiFID II), cross-border payment processing (SEPA), and risk classification.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fatcaGiinRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Fatca Giin Required Flag' ;
    rdfs:comment 'Indicates whether financial institutions in this country must obtain a GIIN for FATCA compliance. Used in onboarding and due diligence processes for institutional counterparties.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fatcaJurisdictionFlag rdf:type rdf:Property ;
    rdfs:label 'Fatca Jurisdiction Flag' ;
    rdfs:comment 'Indicates whether the country is a FATCA reporting jurisdiction requiring financial institutions to report US person accounts to the IRS. Critical for compliance with US tax regulations and customer onboarding workflows.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fatfHighRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Fatf High Risk Flag' ;
    rdfs:comment 'Indicates whether the country is identified by FATF as a high-risk jurisdiction with strategic AML/CFT deficiencies. Triggers enhanced due diligence requirements and elevated risk ratings in customer onboarding and transaction monitoring.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fatfMemberFlag rdf:type rdf:Property ;
    rdfs:label 'Fatf Member Flag' ;
    rdfs:comment 'Indicates whether the country is a member of the Financial Action Task Force. Used for assessing AML/CFT framework strength and country risk rating in financial crime compliance.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ibanLength rdf:type rdf:Property ;
    rdfs:label 'Iban Length' ;
    rdfs:comment 'Standard length of IBAN for this country (e.g., 22 for Germany, 27 for France). Used for IBAN validation and account number format checking.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ibanRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Iban Required Flag' ;
    rdfs:comment 'Indicates whether IBAN format is required for bank account numbers in this country. Used for payment validation, account number formatting, and cross-border payment processing.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:intermediateRegion rdf:type rdf:Property ;
    rdfs:label 'Intermediate Region' ;
    rdfs:comment 'Intermediate-level geographic classification between region and sub-region where applicable (e.g., Caribbean, Channel Islands). Used for specialized regional analytics and compliance grouping.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isoAlpha2Code rdf:type rdf:Property ;
    rdfs:label 'Iso Alpha 2 Code' ;
    rdfs:comment 'Two-letter country code as defined by ISO 3166-1 alpha-2 standard (e.g., US, GB, DE). Primary business identifier for country lookup in KYC, AML, and regulatory reporting systems.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isoAlpha3Code rdf:type rdf:Property ;
    rdfs:label 'Iso Alpha 3 Code' ;
    rdfs:comment 'Three-letter country code as defined by ISO 3166-1 alpha-3 standard (e.g., USA, GBR, DEU). Used in SWIFT messaging, trade finance, and cross-border payment processing.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isoNumericCode rdf:type rdf:Property ;
    rdfs:label 'Iso Numeric Code' ;
    rdfs:comment 'Three-digit numeric country code as defined by ISO 3166-1 numeric standard (e.g., 840 for USA, 826 for GBR). Used in systems requiring language-independent country representation.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oecdMemberFlag rdf:type rdf:Property ;
    rdfs:label 'Oecd Member Flag' ;
    rdfs:comment 'Indicates whether the country is a member of the OECD. Used for assessing regulatory standards, tax treaty eligibility, and country risk classification.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ofacSanctionsFlag rdf:type rdf:Property ;
    rdfs:label 'Ofac Sanctions Flag' ;
    rdfs:comment 'Indicates whether the country is subject to comprehensive OFAC sanctions programs. Critical for transaction screening, customer onboarding, and AML compliance.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ofacSanctionsProgram rdf:type rdf:Property ;
    rdfs:label 'Ofac Sanctions Program' ;
    rdfs:comment 'Name of the specific OFAC sanctions program applicable to this country (e.g., Iran Sanctions, North Korea Sanctions). Used for detailed compliance screening and risk assessment.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:officialName rdf:type rdf:Property ;
    rdfs:label 'Official Name' ;
    rdfs:comment 'Official long-form name of the country including full legal designation (e.g., United States of America, United Kingdom of Great Britain and Northern Ireland). Used in legal contracts, regulatory submissions, and formal documentation.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rtgsSystemName rdf:type rdf:Property ;
    rdfs:label 'Rtgs System Name' ;
    rdfs:comment 'Name of the country\'s real-time gross settlement system for high-value payments (e.g., Fedwire for USA, CHAPS for UK, TARGET2 for Eurozone). Used for payment routing, liquidity management, and settlement risk assessment.' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sovereignCreditRating rdf:type rdf:Property ;
    rdfs:label 'Sovereign Credit Rating' ;
    rdfs:comment 'Long-term foreign currency sovereign credit rating from major rating agencies (e.g., AAA, AA+, BBB-, CCC). Used for risk-weighted asset (RWA) calculations, credit valuation adjustment (CVA), and investment grade classification.' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sovereignRatingAgency rdf:type rdf:Property ;
    rdfs:label 'Sovereign Rating Agency' ;
    rdfs:comment 'Name of the rating agency providing the sovereign credit rating (e.g., S&P, Moody\'s, Fitch). Used for rating source attribution and multi-agency rating reconciliation.' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sovereignRatingDate rdf:type rdf:Property ;
    rdfs:label 'Sovereign Rating Date' ;
    rdfs:comment 'Date of the most recent sovereign credit rating assessment. Used for rating staleness checks and triggering rating review workflows.' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sovereignStatus rdf:type rdf:Property ;
    rdfs:label 'Sovereign Status' ;
    rdfs:comment 'Indicates the political sovereignty status of the country or territory. Critical for determining applicable regulatory frameworks, tax treaties, and legal jurisdiction in cross-border transactions.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subRegion rdf:type rdf:Property ;
    rdfs:label 'Sub Region' ;
    rdfs:comment 'Detailed sub-region classification within the broader region (e.g., Northern America, Western Europe, South-Eastern Asia). Used for granular geographic segmentation and risk analysis.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxHavenFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Haven Flag' ;
    rdfs:comment 'Indicates whether the country is classified as a tax haven or low-tax jurisdiction. Used for enhanced due diligence, beneficial ownership verification, and tax evasion risk assessment.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:benchmarkRateType rdf:type rdf:Property ;
    rdfs:label 'Benchmark Rate Type' ;
    rdfs:comment 'The primary interest rate benchmark associated with this currency (e.g., Secured Overnight Financing Rate (SOFR) for USD, Euro Short-Term Rate (ESTR) for EUR, Sterling Overnight Index Average (SONIA) for GBP). Used for pricing loans, derivatives, and other financial instruments. Reflects the transition from London Interbank Offered Rate (LIBOR) to alternative reference rates.' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:centralBankName rdf:type rdf:Property ;
    rdfs:label 'Central Bank Name' ;
    rdfs:comment 'Name of the central bank or monetary authority responsible for issuing and regulating this currency (e.g., Federal Reserve System for USD, European Central Bank for EUR, Bank of England for GBP). Used for regulatory reporting and monetary policy reference.' ;
    rdfs:domain ind:Currency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currencyName rdf:type rdf:Property ;
    rdfs:label 'Currency Name' ;
    rdfs:comment 'Full official name of the currency (e.g., United States Dollar, Euro, British Pound Sterling, Japanese Yen).' ;
    rdfs:domain ind:Currency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currencyStatus rdf:type rdf:Property ;
    rdfs:label 'Currency Status' ;
    rdfs:comment 'Current lifecycle status of the currency. Active currencies are currently in circulation and available for transactions. Inactive currencies are temporarily suspended. Deprecated currencies are being phased out (e.g., legacy currencies replaced by EUR). Historical currencies are no longer in use but retained for historical transaction reference. Pending currencies are approved but not yet in circulation.' ;
    rdfs:domain ind:Currency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currencyType rdf:type rdf:Property ;
    rdfs:label 'Currency Type' ;
    rdfs:comment 'Classification of the currency by its fundamental nature. Fiat currencies are government-issued legal tender. Commodity currencies are backed by physical commodities. Digital currencies include cryptocurrencies and central bank digital currencies. Fund represents investment fund units. Special Drawing Right (SDR) is the International Monetary Fund (IMF) reserve asset.' ;
    rdfs:domain ind:Currency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBaseCurrency rdf:type rdf:Property ;
    rdfs:label 'Is Base Currency' ;
    rdfs:comment 'Indicates whether this currency serves as a base currency for the enterprise\'s financial reporting and consolidation. Typically the functional currency of the parent company. Used for General Ledger (GL) consolidation and financial statement preparation.' ;
    rdfs:domain ind:Currency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isConvertible rdf:type rdf:Property ;
    rdfs:label 'Is Convertible' ;
    rdfs:comment 'Indicates whether this currency is freely convertible on international foreign exchange markets without significant restrictions. True for major reserve currencies and freely traded currencies. False for currencies with limited convertibility or capital controls.' ;
    rdfs:domain ind:Currency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCryptoCurrency rdf:type rdf:Property ;
    rdfs:label 'Is Crypto Currency' ;
    rdfs:comment 'Indicates whether this is a cryptocurrency or digital asset rather than a fiat currency issued by a central bank. Used to apply different regulatory treatment, risk controls, and processing rules for digital assets.' ;
    rdfs:domain ind:Currency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFundCurrency rdf:type rdf:Property ;
    rdfs:label 'Is Fund Currency' ;
    rdfs:comment 'Indicates whether this currency code represents a fund or investment vehicle unit rather than a traditional currency. Used for mutual funds, exchange-traded funds, and other investment products that have their own unit pricing.' ;
    rdfs:domain ind:Currency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLegalTender rdf:type rdf:Property ;
    rdfs:label 'Is Legal Tender' ;
    rdfs:comment 'Indicates whether this currency is currently recognized as legal tender in its issuing jurisdiction. True for currencies that must be accepted for payment of debts. False for commemorative, historical, or non-legal tender currencies.' ;
    rdfs:domain ind:Currency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPreciousMetal rdf:type rdf:Property ;
    rdfs:label 'Is Precious Metal' ;
    rdfs:comment 'Indicates whether this currency code represents a precious metal (e.g., XAU for gold, XAG for silver, XPT for platinum) used as a store of value or trading instrument. ISO 4217 includes codes for precious metals alongside traditional currencies.' ;
    rdfs:domain ind:Currency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRestricted rdf:type rdf:Property ;
    rdfs:label 'Is Restricted' ;
    rdfs:comment 'Indicates whether this currency is subject to capital controls, exchange restrictions, or regulatory limitations that restrict its convertibility or cross-border movement. True for currencies with government-imposed restrictions. Used for compliance and risk management.' ;
    rdfs:domain ind:Currency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isoCode rdf:type rdf:Property ;
    rdfs:label 'Iso Code' ;
    rdfs:comment 'Three-letter alphabetic currency code as defined by ISO 4217 standard (e.g., USD, EUR, GBP, JPY). This is the primary business identifier used across all financial systems for currency denomination.' ;
    rdfs:domain ind:Currency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minorUnit rdf:type rdf:Property ;
    rdfs:label 'Minor Unit' ;
    rdfs:comment 'Number of decimal places used for the currency\'s minor unit. Indicates the relationship between the major currency unit and its minor unit (e.g., 2 for USD cents, 0 for JPY which has no minor unit, 3 for certain Middle Eastern currencies). Critical for accurate financial calculations and rounding.' ;
    rdfs:domain ind:Currency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numericCode rdf:type rdf:Property ;
    rdfs:label 'Numeric Code' ;
    rdfs:comment 'Three-digit numeric currency code as defined by ISO 4217 standard (e.g., 840 for USD, 978 for EUR). Used in systems where alphabetic codes are not suitable.' ;
    rdfs:domain ind:Currency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roundingMethod rdf:type rdf:Property ;
    rdfs:label 'Rounding Method' ;
    rdfs:comment 'Standard rounding method to be applied for this currency in financial calculations. Standard uses mathematical rounding (0.5 rounds up). Bankers rounding rounds 0.5 to the nearest even number. Up always rounds up. Down always rounds down. Truncate drops decimal places without rounding. Critical for ensuring consistent calculation results across systems.' ;
    rdfs:domain ind:Currency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementLagDays rdf:type rdf:Property ;
    rdfs:label 'Settlement Lag Days' ;
    rdfs:comment 'Standard number of business days required for settlement of foreign exchange (FX) transactions involving this currency. Typically 2 days (T+2) for major currencies, but can vary. Used for calculating settlement dates in FX trading and payment processing.' ;
    rdfs:domain ind:Currency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:symbol rdf:type rdf:Property ;
    rdfs:label 'Symbol' ;
    rdfs:comment 'Graphical symbol used to represent the currency in financial displays and reports (e.g., $, €, £, ¥). Used for user interface presentation and customer-facing documents.' ;
    rdfs:domain ind:Currency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benchmarkRateFlag rdf:type rdf:Property ;
    rdfs:label 'Benchmark Rate Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether this rate is an official benchmark rate used for regulatory reporting, financial statement revaluation, or contractual reference (e.g., WM/Reuters 4pm London Fix). Benchmark rates have heightened governance and audit requirements.' ;
    rdfs:domain ind:ExchangeRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crossRateFlag rdf:type rdf:Property ;
    rdfs:label 'Cross Rate Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether this rate is a cross rate (derived from two other currency pairs) rather than a directly traded pair. For example, EUR/GBP may be derived from EUR/USD and GBP/USD. Cross rates may have wider spreads.' ;
    rdfs:domain ind:ExchangeRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ecbPublishedFlag rdf:type rdf:Property ;
    rdfs:label 'Ecb Published Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether this rate was published by the European Central Bank as an official ECB reference rate. ECB rates are used for regulatory reporting and accounting revaluations in the Eurozone.' ;
    rdfs:domain ind:ExchangeRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:expiryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Expiry Timestamp' ;
    rdfs:comment 'The date and time when this exchange rate expires and is no longer valid for use. For spot rates this may be end-of-day, for forward rates this is the forward settlement date. Null indicates an open-ended rate.' ;
    rdfs:domain ind:ExchangeRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fedPublishedFlag rdf:type rdf:Property ;
    rdfs:label 'Fed Published Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether this rate was published by the U.S. Federal Reserve as an official Fed reference rate. Fed rates are used for regulatory reporting and accounting revaluations in the United States.' ;
    rdfs:domain ind:ExchangeRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:glRevaluationEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Gl Revaluation Eligible Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether this rate is approved for use in general ledger foreign currency revaluation processes. GL revaluation rates must meet accounting policy standards and audit requirements.' ;
    rdfs:domain ind:ExchangeRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:holidayAdjustedFlag rdf:type rdf:Property ;
    rdfs:label 'Holiday Adjusted Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether this rate has been adjusted for banking holidays in either the base or quote currency jurisdiction. Holiday adjustments affect settlement dates and may impact rate calculations.' ;
    rdfs:domain ind:ExchangeRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inverseRateValue rdf:type rdf:Property ;
    rdfs:label 'Inverse Rate Value' ;
    rdfs:comment 'The inverse of the rate_value, representing the exchange rate when the base and quote currencies are swapped. Calculated as 1 / rate_value. Stored for performance optimization in bidirectional FX calculations.' ;
    rdfs:domain ind:ExchangeRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryReportingEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Eligible Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether this rate is approved for use in regulatory reporting submissions (e.g., Basel III, CCAR, DFAST, IFRS 9, CECL). Only rates from approved sources and meeting regulatory standards are eligible.' ;
    rdfs:domain ind:ExchangeRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceProvider rdf:type rdf:Property ;
    rdfs:label 'Source Provider' ;
    rdfs:comment 'The name or identifier of the market data provider or central bank that published this exchange rate (e.g., Bloomberg, Reuters, ECB, Federal Reserve, WM/Reuters Closing Spot Rates). Critical for audit trail and rate validation.' ;
    rdfs:domain ind:ExchangeRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tenor rdf:type rdf:Property ;
    rdfs:label 'Tenor' ;
    rdfs:comment 'The time period for forward exchange rates, expressed in standard market conventions. ON=Overnight, TN=Tom-Next, SN=Spot-Next, W=Weeks, M=Months, Y=Years. SPOT indicates a spot rate with no forward tenor. Used primarily for forward rates and FX swaps.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradingSession rdf:type rdf:Property ;
    rdfs:label 'Trading Session' ;
    rdfs:comment 'The global FX trading session during which this rate was captured or published. FX markets operate 24 hours across major financial centers. Continuous indicates a real-time streaming rate not tied to a specific session. [ENUM-REF-CANDIDATE: london_open|london_close|ny_open|ny_close|tokyo_open|tokyo_close|sydney_open|sydney_close|continuous — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triangulationMethod rdf:type rdf:Property ;
    rdfs:label 'Triangulation Method' ;
    rdfs:comment 'The method used to calculate this rate if it is a cross rate. Via_usd indicates the rate was triangulated through USD as the vehicle currency. Not_applicable indicates a directly traded pair. Triangulation method affects precision and spread.' ;
    rdfs:domain ind:ExchangeRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volatilityIndicator rdf:type rdf:Property ;
    rdfs:label 'Volatility Indicator' ;
    rdfs:comment 'Qualitative assessment of the market volatility level at the time this rate was published. High or extreme volatility may trigger additional risk management controls or require manual review before use in automated systems.' ;
    rdfs:domain ind:ExchangeRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersCountryId rdf:type rdf:Property ;
    rdfs:label 'Headquarters Country Id' ;
    rdfs:comment 'Foreign key linking to reference.country. Business justification: Geographic regions have headquarters located in specific countries. The headquarters_country_code STRING column should be replaced with a proper FK to country.country_id. This enables JOIN to retrieve' ;
    rdfs:domain ind:GeographicRegion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:parentRegionGeographicRegionId rdf:type rdf:Property ;
    rdfs:label 'Parent Region Geographic Region Id' ;
    rdfs:comment 'Reference to the parent region in the hierarchical structure. Null for top-level regions.' ;
    rdfs:domain ind:GeographicRegion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GeographicRegion .

ind:baselImplementationStatus rdf:type rdf:Property ;
    rdfs:label 'Basel Implementation Status' ;
    rdfs:comment 'Indicates which Basel Accord framework is implemented in this geographic region for capital adequacy and risk management purposes.' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryCodes rdf:type rdf:Property ;
    rdfs:label 'Country Codes' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes that belong to this geographic region. Enables mapping between regions and countries for reporting and risk aggregation.' ;
    rdfs:domain ind:GeographicRegion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataResidencyRequirement rdf:type rdf:Property ;
    rdfs:label 'Data Residency Requirement' ;
    rdfs:comment 'Indicates whether the geographic region has data residency or data localization requirements mandating that customer data must be stored within the region. True if requirements exist, False otherwise.' ;
    rdfs:domain ind:GeographicRegion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataStewardName rdf:type rdf:Property ;
    rdfs:label 'Data Steward Name' ;
    rdfs:comment 'Name of the individual or team responsible for maintaining and governing this geographic region reference data.' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersCity rdf:type rdf:Property ;
    rdfs:label 'Headquarters City' ;
    rdfs:comment 'City where the regional headquarters or primary office for this geographic region is located.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ifrsAdoptionStatus rdf:type rdf:Property ;
    rdfs:label 'Ifrs Adoption Status' ;
    rdfs:comment 'Accounting standard framework adopted in this geographic region (e.g., full IFRS, IFRS-converged standards, local GAAP, US GAAP).' ;
    rdfs:domain ind:GeographicRegion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isReportingRegion rdf:type rdf:Property ;
    rdfs:label 'Is Reporting Region' ;
    rdfs:comment 'Indicates whether this geographic region is used as a primary reporting dimension for management and regulatory reporting. True if used for reporting, False otherwise.' ;
    rdfs:domain ind:GeographicRegion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRiskAggregationUnit rdf:type rdf:Property ;
    rdfs:label 'Is Risk Aggregation Unit' ;
    rdfs:comment 'Indicates whether this geographic region is used as a unit for risk aggregation and Risk-Weighted Assets (RWA) calculation. True if used for risk aggregation, False otherwise.' ;
    rdfs:domain ind:GeographicRegion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lobOwnership rdf:type rdf:Property ;
    rdfs:label 'Lob Ownership' ;
    rdfs:comment 'Primary line of business or business unit responsible for this geographic region (e.g., Retail Banking, Investment Banking, Wealth Management).' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionLevel rdf:type rdf:Property ;
    rdfs:label 'Region Level' ;
    rdfs:comment 'Numeric level in the geographic hierarchy (e.g., 1 for global, 2 for super region, 3 for region, etc.). Used for hierarchical rollup and aggregation.' ;
    rdfs:domain ind:GeographicRegion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regionName rdf:type rdf:Property ;
    rdfs:label 'Region Name' ;
    rdfs:comment 'Full descriptive name of the geographic region (e.g., North America, EMEA, Asia Pacific, Latin America).' ;
    rdfs:domain ind:GeographicRegion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionPath rdf:type rdf:Property ;
    rdfs:label 'Region Path' ;
    rdfs:comment 'Full hierarchical path from root to current region, typically pipe or slash delimited (e.g., Global|Americas|North America). Enables efficient hierarchical queries.' ;
    rdfs:domain ind:GeographicRegion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionShortName rdf:type rdf:Property ;
    rdfs:label 'Region Short Name' ;
    rdfs:comment 'Abbreviated or short form of the region name for display and reporting purposes.' ;
    rdfs:domain ind:GeographicRegion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionType rdf:type rdf:Property ;
    rdfs:label 'Region Type' ;
    rdfs:comment 'Classification of the region within the geographic hierarchy (e.g., global, super region, region, sub-region, territory, market).' ;
    rdfs:domain ind:GeographicRegion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionalManagerEmail rdf:type rdf:Property ;
    rdfs:label 'Regional Manager Email' ;
    rdfs:comment 'Email address of the regional manager for operational communication and escalation purposes.' ;
    rdfs:domain ind:GeographicRegion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionalManagerName rdf:type rdf:Property ;
    rdfs:label 'Regional Manager Name' ;
    rdfs:comment 'Name of the senior executive or regional manager responsible for this geographic region.' ;
    rdfs:domain ind:GeographicRegion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sanctionsFlag rdf:type rdf:Property ;
    rdfs:label 'Sanctions Flag' ;
    rdfs:comment 'Indicates whether the geographic region is subject to international sanctions or embargoes (e.g., OFAC sanctions). True if sanctions apply, False otherwise.' ;
    rdfs:domain ind:GeographicRegion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stressTestingRegime rdf:type rdf:Property ;
    rdfs:label 'Stress Testing Regime' ;
    rdfs:comment 'Regulatory stress testing framework applicable to this geographic region (e.g., CCAR, DFAST, EBA Stress Test, APRA Stress Test).' ;
    rdfs:domain ind:GeographicRegion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appliesToDerivatives rdf:type rdf:Property ;
    rdfs:label 'Applies To Derivatives' ;
    rdfs:comment 'Indicates whether this calendar is used for derivatives contract settlement, coupon payment dates, and option expiry calculations (e.g., interest rate swaps, Credit Default Swaps (CDS), foreign exchange (FX) forwards). True for calendars referenced in International Swaps and Derivatives Association (ISDA) documentation.' ;
    rdfs:domain ind:HolidayCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appliesToLoans rdf:type rdf:Property ;
    rdfs:label 'Applies To Loans' ;
    rdfs:comment 'Indicates whether this calendar is used for loan payment scheduling, interest accrual period calculations, and covenant compliance date computations. True for banking calendars used in commercial lending and credit origination.' ;
    rdfs:domain ind:HolidayCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appliesToPayments rdf:type rdf:Property ;
    rdfs:label 'Applies To Payments' ;
    rdfs:comment 'Indicates whether this calendar is used for payment processing and funds transfer date calculations (e.g., Automated Clearing House (ACH), wire transfers, Real-Time Gross Settlement (RTGS), Society for Worldwide Interbank Financial Telecommunication (SWIFT) payments). True for payment system and banking calendars.' ;
    rdfs:domain ind:HolidayCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appliesToSecurities rdf:type rdf:Property ;
    rdfs:label 'Applies To Securities' ;
    rdfs:comment 'Indicates whether this calendar is used for securities settlement date calculations (e.g., equity trades, bond settlements, derivatives). True for exchange and clearing calendars; may be false for payment-only or banking-only calendars.' ;
    rdfs:domain ind:HolidayCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:calendarCode rdf:type rdf:Property ;
    rdfs:label 'Calendar Code' ;
    rdfs:comment 'Unique business identifier code for the holiday calendar (e.g., TARGET2, NYSE, SIFMA, LME, FED, ECB). Used as the externally-known reference key for settlement and payment systems.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calendarName rdf:type rdf:Property ;
    rdfs:label 'Calendar Name' ;
    rdfs:comment 'Full descriptive name of the holiday calendar (e.g., Trans-European Automated Real-time Gross Settlement Express Transfer System, New York Stock Exchange, Securities Industry and Financial Markets Association).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calendarSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Calendar Source System' ;
    rdfs:comment 'Name of the upstream system or data provider from which this calendar is sourced (e.g., Bloomberg, Reuters, SWIFT, internal treasury system, regulatory authority website). Used for data lineage and reconciliation.' ;
    rdfs:domain ind:HolidayCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calendarStatus rdf:type rdf:Property ;
    rdfs:label 'Calendar Status' ;
    rdfs:comment 'Current lifecycle status of the holiday calendar. Active calendars are in use for settlement and payment calculations. Inactive calendars are no longer used but retained for historical reference. Deprecated calendars are being phased out (e.g., LIBOR-based calendars transitioning to SOFR). Pending calendars are scheduled for future activation.' ;
    rdfs:domain ind:HolidayCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calendarType rdf:type rdf:Property ;
    rdfs:label 'Calendar Type' ;
    rdfs:comment 'Classification of the calendar by its primary business purpose: settlement (for trade settlement systems), exchange (for securities exchanges), banking (for commercial banking operations), clearing (for clearing houses), payment (for payment systems), public (for national public holidays), or custom (for institution-specific calendars). [ENUM-REF-CANDIDATE: settlement|exchange|banking|clearing|payment|public|custom — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calendarUrl rdf:type rdf:Property ;
    rdfs:label 'Calendar Url' ;
    rdfs:comment 'Web address of the official source where the authoritative holiday calendar is published (e.g., central bank website, exchange website, SIFMA holiday schedule page). Used for reference and validation.' ;
    rdfs:domain ind:HolidayCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calendarVersion rdf:type rdf:Property ;
    rdfs:label 'Calendar Version' ;
    rdfs:comment 'Version identifier for this calendar publication (e.g., 2024, 1.0, 2.3). Calendars are versioned annually or when significant changes occur (e.g., addition of new public holidays, changes in weekend patterns). Used to track calendar updates and ensure correct historical calculations.' ;
    rdfs:domain ind:HolidayCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialCenterCode rdf:type rdf:Property ;
    rdfs:label 'Financial Center Code' ;
    rdfs:comment 'ISO 10383 Market Identifier Code (MIC) or ISO 3166-1 alpha-2 country code representing the financial center or market to which this calendar applies (e.g., XNYS for NYSE, XLON for London Stock Exchange, US for United States, GB for United Kingdom).' ;
    rdfs:domain ind:HolidayCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingAuthority rdf:type rdf:Property ;
    rdfs:label 'Governing Authority' ;
    rdfs:comment 'Name of the regulatory body, central bank, exchange, or industry association that publishes and maintains this calendar (e.g., European Central Bank, Federal Reserve System, New York Stock Exchange, Securities Industry and Financial Markets Association, Bank of England).' ;
    rdfs:domain ind:HolidayCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDefaultCalendar rdf:type rdf:Property ;
    rdfs:label 'Is Default Calendar' ;
    rdfs:comment 'Indicates whether this is the default holiday calendar for the institution or financial center when no specific calendar is designated. Typically true for the primary banking calendar of the institutions home country or the main exchange calendar for securities operations.' ;
    rdfs:domain ind:HolidayCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastUpdatedDate rdf:type rdf:Property ;
    rdfs:label 'Last Updated Date' ;
    rdfs:comment 'The date on which this calendar record was last modified in the system. Used for change tracking and data quality monitoring.' ;
    rdfs:domain ind:HolidayCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:settlementCycleDays rdf:type rdf:Property ;
    rdfs:label 'Settlement Cycle Days' ;
    rdfs:comment 'Standard number of business days for settlement in this market (e.g., 1 for T+1, 2 for T+2). Used as the default settlement period for securities trades, foreign exchange (FX) transactions, and payment instructions when calculating settlement dates using this calendar.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supportsPartialDays rdf:type rdf:Property ;
    rdfs:label 'Supports Partial Days' ;
    rdfs:comment 'Indicates whether this calendar supports partial business days (e.g., early close days for exchanges on days before major holidays, half-day trading sessions). True if the calendar includes partial day holiday entries; false if all non-business days are full-day closures.' ;
    rdfs:domain ind:HolidayCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:weekendPattern rdf:type rdf:Property ;
    rdfs:label 'Weekend Pattern' ;
    rdfs:comment 'Standard weekend days for this financial center or market. Most Western markets observe Saturday-Sunday; Middle Eastern markets may observe Friday-Saturday or Thursday-Friday. Used in conjunction with holiday dates to determine non-business days for settlement calculations.' ;
    rdfs:domain ind:HolidayCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holidayDateId rdf:type rdf:Property ;
    rdfs:label 'Holiday Date Id' ;
    rdfs:comment 'Unique identifier for the holiday date record. Primary key.' ;
    rdfs:domain ind:HolidayDate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualHolidayDate rdf:type rdf:Property ;
    rdfs:label 'Actual Holiday Date' ;
    rdfs:comment 'The actual calendar date of the holiday before any substitution or observance adjustment. Populated when observance_rule is \'substitute\' and the observed date differs from the actual date.' ;
    rdfs:domain ind:HolidayDate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:affectsAccrual rdf:type rdf:Property ;
    rdfs:label 'Affects Accrual' ;
    rdfs:comment 'Indicates whether this holiday affects interest accrual calculations for loans, deposits, and fixed income securities. True if accrual is suspended or adjusted, False otherwise.' ;
    rdfs:domain ind:HolidayDate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:affectsPayment rdf:type rdf:Property ;
    rdfs:label 'Affects Payment' ;
    rdfs:comment 'Indicates whether this holiday affects scheduled payment processing (loan payments, coupon payments, dividends). True if payments are deferred to the next business day, False otherwise.' ;
    rdfs:domain ind:HolidayDate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:affectsSettlement rdf:type rdf:Property ;
    rdfs:label 'Affects Settlement' ;
    rdfs:comment 'Indicates whether this holiday affects securities settlement and trade date plus one (T+1) or T+2 calculations. True if settlement is impacted, False otherwise.' ;
    rdfs:domain ind:HolidayDate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:holidayDate rdf:type rdf:Property ;
    rdfs:label 'Holiday Date' ;
    rdfs:comment 'The specific non-business date observed as a holiday. Used for settlement date calculations, accrual period adjustments, and payment scheduling across loan, securities, and treasury operations.' ;
    rdfs:domain ind:HolidayDate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:holidayName rdf:type rdf:Property ;
    rdfs:label 'Holiday Name' ;
    rdfs:comment 'The official name or description of the holiday (e.g., New Year\'s Day, Christmas, Good Friday, Independence Day, Market Closure).' ;
    rdfs:domain ind:HolidayDate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holidayType rdf:type rdf:Property ;
    rdfs:label 'Holiday Type' ;
    rdfs:comment 'Classification of the holiday type. Public: national/regional public holiday. Exchange: securities exchange closure. Settlement: payment system closure (ACH, RTGS, SWIFT). Bank: banking institution closure. Custom: client-specific or internal calendar event. Regulatory: regulatory reporting deadline adjustment.' ;
    rdfs:domain ind:HolidayDate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPartialDay rdf:type rdf:Property ;
    rdfs:label 'Is Partial Day' ;
    rdfs:comment 'Indicates whether the holiday is a partial day (e.g., early market close, half-day banking). True if partial, False if full-day closure.' ;
    rdfs:domain ind:HolidayDate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketIdentifierCode rdf:type rdf:Property ;
    rdfs:label 'Market Identifier Code' ;
    rdfs:comment 'ISO 10383 Market Identifier Code (MIC) for the exchange or trading venue to which this holiday applies (e.g., XNYS for NYSE, XLON for London Stock Exchange). Null if not exchange-specific.' ;
    rdfs:domain ind:HolidayDate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:observanceRule rdf:type rdf:Property ;
    rdfs:label 'Observance Rule' ;
    rdfs:comment 'Indicates how the holiday date is determined. Fixed: same calendar date each year. Floating: varies by rule (e.g., third Monday of January). Calculated: computed based on lunar calendar or other algorithm. Substitute: observed on a different date when the actual holiday falls on a weekend.' ;
    rdfs:domain ind:HolidayDate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partialDayCloseTime rdf:type rdf:Property ;
    rdfs:label 'Partial Day Close Time' ;
    rdfs:comment 'The closing time for partial day holidays in HH:mm format (24-hour). Null if not a partial day or if closed all day.' ;
    rdfs:domain ind:HolidayDate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:partialDayOpenTime rdf:type rdf:Property ;
    rdfs:label 'Partial Day Open Time' ;
    rdfs:comment 'The opening time for partial day holidays in HH:mm format (24-hour). Null if not a partial day or if closed all day.' ;
    rdfs:domain ind:HolidayDate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:paymentSystemCode rdf:type rdf:Property ;
    rdfs:label 'Payment System Code' ;
    rdfs:comment 'Code identifying the payment or settlement system affected by this holiday (e.g., FEDWIRE, CHIPS, TARGET2, CHAPS, ACH). Used for payment scheduling and liquidity management.' ;
    rdfs:domain ind:HolidayDate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recurringPattern rdf:type rdf:Property ;
    rdfs:label 'Recurring Pattern' ;
    rdfs:comment 'Description of the recurrence pattern for floating holidays (e.g., \'Third Monday in January\', \'Last Friday in March\', \'Easter Sunday + 1 day\'). Null for fixed-date holidays.' ;
    rdfs:domain ind:HolidayDate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reference' ;
    rdfs:comment 'Reference to the regulatory rule, statute, or official gazette that establishes this holiday (e.g., \'Federal Reserve Board Regulation D\', \'UK Banking Act 1971 Schedule 1\').' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classificationSystem rdf:type rdf:Property ;
    rdfs:label 'Classification System' ;
    rdfs:comment 'The industry classification system or taxonomy used (Standard Industrial Classification, North American Industry Classification System, Global Industry Classification Standard, Industry Classification Benchmark).' ;
    rdfs:domain ind:IndustryCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:climateRiskExposure rdf:type rdf:Property ;
    rdfs:label 'Climate Risk Exposure' ;
    rdfs:comment 'The level of physical and transition climate risk exposure associated with this industry, used for climate stress testing and scenario analysis.' ;
    rdfs:domain ind:IndustryCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codePath rdf:type rdf:Property ;
    rdfs:label 'Code Path' ;
    rdfs:comment 'Full hierarchical path from root to current code, typically pipe or slash delimited (e.g., Financials|Banks|Diversified Banks), enabling efficient hierarchy queries.' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codeShortName rdf:type rdf:Property ;
    rdfs:label 'Code Short Name' ;
    rdfs:comment 'Abbreviated or short name for the industry classification code, used for display and reporting purposes.' ;
    rdfs:domain ind:IndustryCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:concentrationRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Concentration Risk Flag' ;
    rdfs:comment 'Indicates whether exposures to this industry are subject to concentration risk monitoring and limits under the banks risk appetite framework and regulatory guidance.' ;
    rdfs:domain ind:IndustryCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cyclicalSensitivity rdf:type rdf:Property ;
    rdfs:label 'Cyclical Sensitivity' ;
    rdfs:comment 'The sensitivity of this industry to economic cycles, informing credit risk modeling, stress testing, and portfolio diversification strategies.' ;
    rdfs:domain ind:IndustryCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esgRiskCategory rdf:type rdf:Property ;
    rdfs:label 'Esg Risk Category' ;
    rdfs:comment 'The Environmental, Social, and Governance risk category assigned to this industry, supporting sustainable finance and climate risk assessment.' ;
    rdfs:domain ind:IndustryCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gicsEquivalentCode rdf:type rdf:Property ;
    rdfs:label 'Gics Equivalent Code' ;
    rdfs:comment 'Cross-mapping to the equivalent GICS code, enabling global equity market analysis and portfolio classification.' ;
    rdfs:domain ind:IndustryCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:highRiskIndustryFlag rdf:type rdf:Property ;
    rdfs:label 'High Risk Industry Flag' ;
    rdfs:comment 'Indicates whether this industry is classified as high-risk for Anti-Money Laundering (AML), sanctions, fraud, or credit risk purposes, triggering enhanced due diligence requirements.' ;
    rdfs:domain ind:IndustryCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:icbEquivalentCode rdf:type rdf:Property ;
    rdfs:label 'Icb Equivalent Code' ;
    rdfs:comment 'Cross-mapping to the equivalent ICB code, enabling FTSE Russell index alignment and international market analysis.' ;
    rdfs:domain ind:IndustryCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industryCodeStatus rdf:type rdf:Property ;
    rdfs:label 'Industry Code Status' ;
    rdfs:comment 'The current lifecycle status of this industry code, indicating whether it is actively used, deprecated, superseded by another code, or proposed for future adoption.' ;
    rdfs:domain ind:IndustryCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industryGroupName rdf:type rdf:Property ;
    rdfs:label 'Industry Group Name' ;
    rdfs:comment 'The mid-level industry group name within the sector hierarchy, providing intermediate classification granularity.' ;
    rdfs:domain ind:IndustryCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:naicsEquivalentCode rdf:type rdf:Property ;
    rdfs:label 'Naics Equivalent Code' ;
    rdfs:comment 'Cross-mapping to the equivalent NAICS code, enabling regulatory reporting alignment and North American market analysis.' ;
    rdfs:domain ind:IndustryCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskWeightCategory rdf:type rdf:Property ;
    rdfs:label 'Risk Weight Category' ;
    rdfs:comment 'The risk weight category assigned to exposures in this industry for regulatory capital calculation under Basel III standardized or internal ratings-based approaches.' ;
    rdfs:domain ind:IndustryCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sanctionsExposureFlag rdf:type rdf:Property ;
    rdfs:label 'Sanctions Exposure Flag' ;
    rdfs:comment 'Indicates whether this industry has heightened exposure to OFAC or international sanctions regimes, requiring enhanced screening and monitoring.' ;
    rdfs:domain ind:IndustryCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sicEquivalentCode rdf:type rdf:Property ;
    rdfs:label 'Sic Equivalent Code' ;
    rdfs:comment 'Cross-mapping to the equivalent Standard Industrial Classification code, enabling legacy system integration and historical analysis.' ;
    rdfs:domain ind:IndustryCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subIndustryName rdf:type rdf:Property ;
    rdfs:label 'Sub Industry Name' ;
    rdfs:comment 'The most granular sub-industry name, providing detailed industry segment classification for specialized analysis.' ;
    rdfs:domain ind:IndustryCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageNotes rdf:type rdf:Property ;
    rdfs:label 'Usage Notes' ;
    rdfs:comment 'Free-text notes providing guidance on proper usage, interpretation, or special considerations for this industry code classification.' ;
    rdfs:domain ind:IndustryCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:centralClearingEligible rdf:type rdf:Property ;
    rdfs:label 'Central Clearing Eligible' ;
    rdfs:comment 'Flag indicating whether the instrument is eligible for central clearing through a central counterparty (CCP). Impacts margin requirements and capital charges.' ;
    rdfs:domain ind:InstrumentClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cfiCode rdf:type rdf:Property ;
    rdfs:label 'Cfi Code' ;
    rdfs:comment 'Six-character ISO 10962 CFI code that classifies the financial instrument by category, group, and attributes. Used globally for instrument identification and regulatory reporting.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classificationEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Classification Effective Date' ;
    rdfs:comment 'Date from which this classification becomes effective. Used for point-in-time regulatory reporting and historical analysis.' ;
    rdfs:domain ind:InstrumentClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:classificationEndDate rdf:type rdf:Property ;
    rdfs:label 'Classification End Date' ;
    rdfs:comment 'Date on which this classification ceases to be effective. Null for currently active classifications. Supports temporal classification changes.' ;
    rdfs:domain ind:InstrumentClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:classificationRationale rdf:type rdf:Property ;
    rdfs:label 'Classification Rationale' ;
    rdfs:comment 'Business justification and regulatory basis for the assigned classification. Documents the decision-making process for audit and compliance purposes.' ;
    rdfs:domain ind:InstrumentClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classificationVersion rdf:type rdf:Property ;
    rdfs:label 'Classification Version' ;
    rdfs:comment 'Version number of the classification record. Incremented when classification attributes are updated due to regulatory changes or internal policy revisions.' ;
    rdfs:domain ind:InstrumentClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complexProductIndicator rdf:type rdf:Property ;
    rdfs:label 'Complex Product Indicator' ;
    rdfs:comment 'Flag indicating whether the instrument is classified as a complex product under MiFID II, requiring enhanced client suitability assessment and disclosure.' ;
    rdfs:domain ind:InstrumentClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:counterpartyCreditRiskCategory rdf:type rdf:Property ;
    rdfs:label 'Counterparty Credit Risk Category' ;
    rdfs:comment 'Classification for counterparty credit risk exposure calculation, including CVA, DVA, and FVA. Determines exposure methodology and capital treatment.' ;
    rdfs:domain ind:InstrumentClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditRiskMitigationEligible rdf:type rdf:Property ;
    rdfs:label 'Credit Risk Mitigation Eligible' ;
    rdfs:comment 'Flag indicating whether the instrument is eligible for credit risk mitigation under Basel III standardized or internal ratings-based approaches. Affects risk-weighted asset calculation.' ;
    rdfs:domain ind:InstrumentClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:derivativeIndicator rdf:type rdf:Property ;
    rdfs:label 'Derivative Indicator' ;
    rdfs:comment 'Flag indicating whether the instrument is a derivative contract. Used for derivative-specific regulatory reporting, margin requirements, and central clearing obligations.' ;
    rdfs:domain ind:InstrumentClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exchangeTradedIndicator rdf:type rdf:Property ;
    rdfs:label 'Exchange Traded Indicator' ;
    rdfs:comment 'Flag indicating whether the instrument is traded on a regulated exchange or multilateral trading facility. Affects transparency requirements and best execution obligations.' ;
    rdfs:domain ind:InstrumentClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fairValueHierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Fair Value Hierarchy Level' ;
    rdfs:comment 'IFRS 13 / ASC 820 fair value hierarchy level indicating the observability of valuation inputs. Level 1 uses quoted prices, Level 2 uses observable inputs, Level 3 uses unobservable inputs.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frtbBookClassification rdf:type rdf:Property ;
    rdfs:label 'Frtb Book Classification' ;
    rdfs:comment 'Regulatory classification determining whether the instrument belongs to the trading book or banking book under FRTB rules. Critical for capital calculation and risk-weighted asset determination.' ;
    rdfs:domain ind:InstrumentClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ifrs9MeasurementCategory rdf:type rdf:Property ;
    rdfs:label 'Ifrs9 Measurement Category' ;
    rdfs:comment 'IFRS 9 accounting measurement category determining how the instrument is valued and how gains/losses are recognized. Drives financial statement presentation and expected credit loss calculation.' ;
    rdfs:domain ind:InstrumentClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketRiskCategory rdf:type rdf:Property ;
    rdfs:label 'Market Risk Category' ;
    rdfs:comment 'Market risk classification for VaR, stressed VaR, and incremental risk charge calculations. Used by market risk management and trading desk risk limits.' ;
    rdfs:domain ind:InstrumentClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mifid2InstrumentCategory rdf:type rdf:Property ;
    rdfs:label 'Mifid2 Instrument Category' ;
    rdfs:comment 'MiFID II regulatory categorization for European market transparency and reporting requirements. Determines transaction reporting obligations and best execution rules.' ;
    rdfs:domain ind:InstrumentClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otcIndicator rdf:type rdf:Property ;
    rdfs:label 'Otc Indicator' ;
    rdfs:comment 'Flag indicating whether the instrument is traded over-the-counter rather than on an exchange. Impacts clearing requirements, margin rules, and trade reporting obligations.' ;
    rdfs:domain ind:InstrumentClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productControlCategory rdf:type rdf:Property ;
    rdfs:label 'Product Control Category' ;
    rdfs:comment 'Internal product control classification used by finance and product management teams for P&L attribution, valuation hierarchy, and product lifecycle management.' ;
    rdfs:domain ind:InstrumentClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securitizationIndicator rdf:type rdf:Property ;
    rdfs:label 'Securitization Indicator' ;
    rdfs:comment 'Flag indicating whether the instrument is a securitization (e.g., MBS, ABS, CDO, CLO). Triggers specific capital treatment and risk retention requirements.' ;
    rdfs:domain ind:InstrumentClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stressTestingCategory rdf:type rdf:Property ;
    rdfs:label 'Stress Testing Category' ;
    rdfs:comment 'Classification used for CCAR, DFAST, and internal stress testing scenarios. Determines which stress factors and shocks are applied to the instrument.' ;
    rdfs:domain ind:InstrumentClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:structuredProductIndicator rdf:type rdf:Property ;
    rdfs:label 'Structured Product Indicator' ;
    rdfs:comment 'Flag indicating whether the instrument is a structured product combining multiple underlying instruments or derivatives. Used for risk decomposition and valuation.' ;
    rdfs:domain ind:InstrumentClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:subAssetClass rdf:type rdf:Property ;
    rdfs:label 'Sub Asset Class' ;
    rdfs:comment 'Granular sub-classification within the asset class (e.g., common stock, corporate bond, interest rate swap, FX forward). Used for detailed risk segmentation and product management.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volckerRuleCovered rdf:type rdf:Property ;
    rdfs:label 'Volcker Rule Covered' ;
    rdfs:comment 'Flag indicating whether the instrument is subject to Volcker Rule proprietary trading restrictions. Used for compliance monitoring and permitted market-making activities.' ;
    rdfs:domain ind:InstrumentClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:instrumentIdentifierId rdf:type rdf:Property ;
    rdfs:label 'Instrument Identifier Id' ;
    rdfs:comment 'Primary key for instrument_identifier' ;
    rdfs:domain ind:InstrumentIdentifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:issuerCountryId rdf:type rdf:Property ;
    rdfs:label 'Issuer Country Id' ;
    rdfs:comment 'Foreign key linking to reference.country. Business justification: Financial instruments are issued in specific countries. The issuer_country_code STRING column should be replaced with a proper FK to country.country_id. This enables JOIN to retrieve country_name, reg' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:figi rdf:type rdf:Property ;
    rdfs:label 'Figi' ;
    rdfs:comment '12-character alphanumeric code providing a unique identifier for financial instruments across asset classes and markets. Formerly known as Bloomberg Global Identifier (BBGID).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identifierType rdf:type rdf:Property ;
    rdfs:label 'Identifier Type' ;
    rdfs:comment 'Classification of the identifier record indicating its role in the cross-reference hierarchy. Primary identifiers are the golden source; alternate identifiers provide cross-system mapping.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instrumentIdentifierStatus rdf:type rdf:Property ;
    rdfs:label 'Instrument Identifier Status' ;
    rdfs:comment 'Current lifecycle status of the instrument identifier record indicating whether it is actively traded, matured, called, defaulted, or suspended.' ;
    rdfs:domain ind:InstrumentIdentifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalInstrumentCode rdf:type rdf:Property ;
    rdfs:label 'Internal Instrument Code' ;
    rdfs:comment 'Bank-specific internal code or mnemonic used to identify the instrument within proprietary trading, risk, and accounting systems.' ;
    rdfs:domain ind:InstrumentIdentifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPrimaryIdentifier rdf:type rdf:Property ;
    rdfs:label 'Is Primary Identifier' ;
    rdfs:comment 'Boolean flag indicating whether this identifier is the primary golden-source identifier for the instrument. Only one identifier per instrument should be marked as primary.' ;
    rdfs:domain ind:InstrumentIdentifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTradable rdf:type rdf:Property ;
    rdfs:label 'Is Tradable' ;
    rdfs:comment 'Boolean flag indicating whether the instrument is currently available for trading in the banks trading systems.' ;
    rdfs:domain ind:InstrumentIdentifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reutersRic rdf:type rdf:Property ;
    rdfs:label 'Reuters Ric' ;
    rdfs:comment 'Reuters proprietary ticker-like code used to identify financial instruments within the Refinitiv (formerly Thomson Reuters) system.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentJurisdictionId rdf:type rdf:Property ;
    rdfs:label 'Parent Jurisdiction Id' ;
    rdfs:comment 'Reference to the parent jurisdiction for hierarchical relationships (e.g., New York State\'s parent is United States). Null for top-level jurisdictions.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Jurisdiction .

ind:amlAuthority rdf:type rdf:Property ;
    rdfs:label 'Aml Authority' ;
    rdfs:comment 'Name of the primary anti-money laundering and financial crime enforcement authority in this jurisdiction (e.g., Financial Crimes Enforcement Network, Financial Intelligence Unit).' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bicCountryCode rdf:type rdf:Property ;
    rdfs:label 'Bic Country Code' ;
    rdfs:comment 'Two-letter ISO 3166-1 alpha-2 country code used in Bank Identifier Codes (BIC) and International Bank Account Numbers (IBAN) for this jurisdiction.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capitalAdequacyFramework rdf:type rdf:Property ;
    rdfs:label 'Capital Adequacy Framework' ;
    rdfs:comment 'The approach to capital adequacy calculation permitted or mandated in this jurisdiction: Standardized Approach (SA), Internal Ratings-Based (IRB) Approach, Advanced IRB, or other.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLossMethodology rdf:type rdf:Property ;
    rdfs:label 'Credit Loss Methodology' ;
    rdfs:comment 'Required methodology for credit loss provisioning: Current Expected Credit Losses (CECL), IFRS 9 Expected Credit Loss (ECL), incurred loss model, or other.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataPrivacyRegime rdf:type rdf:Property ;
    rdfs:label 'Data Privacy Regime' ;
    rdfs:comment 'Primary data protection and privacy regulatory framework applicable in this jurisdiction (e.g., General Data Protection Regulation (GDPR), California Consumer Privacy Act (CCPA), Personal Data Protection Act (PDPA)).' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:highRiskJurisdictionFlag rdf:type rdf:Property ;
    rdfs:label 'High Risk Jurisdiction Flag' ;
    rdfs:comment 'Indicates whether this jurisdiction is classified as high-risk for Anti-Money Laundering (AML) or Counter-Terrorist Financing (CTF) purposes by international bodies such as the Financial Action Task Force (FATF).' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ibanSupportedFlag rdf:type rdf:Property ;
    rdfs:label 'Iban Supported Flag' ;
    rdfs:comment 'Indicates whether this jurisdiction uses the International Bank Account Number (IBAN) standard for bank account identification.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insolvencyRegimeType rdf:type rdf:Property ;
    rdfs:label 'Insolvency Regime Type' ;
    rdfs:comment 'Classification of the insolvency and bankruptcy framework in this jurisdiction (e.g., debtor-friendly, creditor-friendly, administrative, judicial). Impacts Loss Given Default (LGD) and recovery rate assumptions.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionLevel rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Level' ;
    rdfs:comment 'Hierarchical level of the jurisdiction: national (country-level), sub-national (state/province/region), supranational (multi-country bodies like EU or Basel Committee), or territorial (dependent territories).' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionName rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Name' ;
    rdfs:comment 'Full legal name of the jurisdiction (e.g., United States of America, State of New York, European Union).' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionStatus rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Status' ;
    rdfs:comment 'Current operational status of the jurisdiction record: active (currently in use), inactive (no longer used for new transactions), historical (archived), or pending (under review for activation).' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalSystemType rdf:type rdf:Property ;
    rdfs:label 'Legal System Type' ;
    rdfs:comment 'The foundational legal system governing the jurisdiction: common law (precedent-based), civil law (code-based), Sharia law (Islamic principles), mixed (combination), customary law, or other.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nettingEnforceabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Netting Enforceability Flag' ;
    rdfs:comment 'Indicates whether close-out netting provisions in derivative contracts are legally enforceable in this jurisdiction under insolvency or default scenarios. Critical for collateral and credit risk management.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nettingOpinionDate rdf:type rdf:Property ;
    rdfs:label 'Netting Opinion Date' ;
    rdfs:comment 'Date of the most recent legal opinion confirming netting enforceability in this jurisdiction. Used to track currency of legal assessments.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sanctionsRegimeFlag rdf:type rdf:Property ;
    rdfs:label 'Sanctions Regime Flag' ;
    rdfs:comment 'Indicates whether this jurisdiction is subject to international economic sanctions or embargoes that restrict banking and financial transactions.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:securitiesRegulator rdf:type rdf:Property ;
    rdfs:label 'Securities Regulator' ;
    rdfs:comment 'Name of the primary securities and capital markets regulatory authority in this jurisdiction (e.g., Securities and Exchange Commission, Financial Conduct Authority, European Securities and Markets Authority).' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stressTestingRequirement rdf:type rdf:Property ;
    rdfs:label 'Stress Testing Requirement' ;
    rdfs:comment 'Mandatory stress testing framework applicable in this jurisdiction: Comprehensive Capital Analysis and Review (CCAR), Dodd-Frank Act Stress Testing (DFAST), European Banking Authority (EBA) stress test, local framework, or none.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxHavenClassification rdf:type rdf:Property ;
    rdfs:label 'Tax Haven Classification' ;
    rdfs:comment 'Classification of the jurisdiction\'s tax regime: tax haven (minimal or no taxation), low-tax (preferential tax rates), standard (typical tax rates), or not classified.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxTreatyNetworkFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Treaty Network Flag' ;
    rdfs:comment 'Indicates whether this jurisdiction participates in international tax treaty networks for withholding tax relief and double taxation avoidance.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalAddressCountryId rdf:type rdf:Property ;
    rdfs:label 'Legal Address Country Id' ;
    rdfs:comment 'Foreign key linking to reference.country. Business justification: LEI entities have legal addresses in specific countries. The legal_address_country_code STRING column should be replaced with a proper FK to country.country_id. This is the first of two FKs from lei_r' ;
    rdfs:domain ind:LeiRegistry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:entityCategory rdf:type rdf:Property ;
    rdfs:label 'Entity Category' ;
    rdfs:comment 'The category classification of the entity as defined by GLEIF, indicating the type of legal entity (e.g., BRANCH for branch offices, FUND for investment funds, GENERAL for standard legal entities). [ENUM-REF-CANDIDATE: BRANCH|FUND|SOLE_PROPRIETOR|RESIDENT_GOVERNMENT_ENTITY|NON_RESIDENT_GOVERNMENT_ENTITY|INTERNATIONAL_ORGANIZATION|GENERAL — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LeiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entityExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Entity Expiration Date' ;
    rdfs:comment 'The date on which the legal entity is scheduled to expire, dissolve, or terminate, if applicable. This is relevant for entities with a defined lifespan such as special purpose vehicles, project companies, or entities in liquidation.' ;
    rdfs:domain ind:LeiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:entityExpirationReason rdf:type rdf:Property ;
    rdfs:label 'Entity Expiration Reason' ;
    rdfs:comment 'The reason for the entitys expiration or termination, if applicable. Indicates the business or legal event that led to the entitys cessation.' ;
    rdfs:domain ind:LeiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entityRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Entity Registration Number' ;
    rdfs:comment 'The unique registration number or identifier assigned to the entity by the registration authority in its jurisdiction of incorporation or registration.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersAddressCity rdf:type rdf:Property ;
    rdfs:label 'Headquarters Address City' ;
    rdfs:comment 'The city or municipality component of the headquarters address.' ;
    rdfs:domain ind:LeiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersAddressCountryCode rdf:type rdf:Property ;
    rdfs:label 'Headquarters Address Country Code' ;
    rdfs:comment 'The ISO 3166-1 alpha-2 two-letter country code representing the country of the headquarters address.' ;
    rdfs:domain ind:LeiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Headquarters Address Line 1' ;
    rdfs:comment 'The first line of the headquarters address where the entity conducts its primary business operations, which may differ from the legal address.' ;
    rdfs:domain ind:LeiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Headquarters Address Line 2' ;
    rdfs:comment 'The second line of the headquarters address, containing additional address details.' ;
    rdfs:domain ind:LeiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersAddressPostalCode rdf:type rdf:Property ;
    rdfs:label 'Headquarters Address Postal Code' ;
    rdfs:comment 'The postal code or ZIP code component of the headquarters address.' ;
    rdfs:domain ind:LeiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersAddressRegion rdf:type rdf:Property ;
    rdfs:label 'Headquarters Address Region' ;
    rdfs:comment 'The region, state, province, or administrative subdivision component of the headquarters address.' ;
    rdfs:domain ind:LeiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initialRegistrationDate rdf:type rdf:Property ;
    rdfs:label 'Initial Registration Date' ;
    rdfs:comment 'The date when the LEI was first issued to the entity by a Local Operating Unit (LOU). This represents the original registration date in the GLEIF system.' ;
    rdfs:domain ind:LeiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastUpdateDate rdf:type rdf:Property ;
    rdfs:label 'Last Update Date' ;
    rdfs:comment 'The date when the LEI record was last updated in the GLEIF system, reflecting changes to entity information, status, or other attributes.' ;
    rdfs:domain ind:LeiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalAddressCity rdf:type rdf:Property ;
    rdfs:label 'Legal Address City' ;
    rdfs:comment 'The city or municipality component of the legal address.' ;
    rdfs:domain ind:LeiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Legal Address Line 1' ;
    rdfs:comment 'The first line of the legal address of the entity as registered with the relevant registration authority. This is the official address for legal and regulatory purposes.' ;
    rdfs:domain ind:LeiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Legal Address Line 2' ;
    rdfs:comment 'The second line of the legal address, typically containing additional address details such as suite, floor, or building information.' ;
    rdfs:domain ind:LeiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalAddressPostalCode rdf:type rdf:Property ;
    rdfs:label 'Legal Address Postal Code' ;
    rdfs:comment 'The postal code or ZIP code component of the legal address.' ;
    rdfs:domain ind:LeiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalAddressRegion rdf:type rdf:Property ;
    rdfs:label 'Legal Address Region' ;
    rdfs:comment 'The region, state, province, or administrative subdivision component of the legal address.' ;
    rdfs:domain ind:LeiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalEntityNameLocal rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Name Local' ;
    rdfs:comment 'The legal name of the entity in the local language and script of the jurisdiction of registration, if different from the transliterated or English version.' ;
    rdfs:domain ind:LeiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalFormCode rdf:type rdf:Property ;
    rdfs:label 'Legal Form Code' ;
    rdfs:comment 'The code representing the legal form of the entity (e.g., corporation, partnership, trust) as defined by the Entity Legal Forms (ELF) code list maintained by GLEIF.' ;
    rdfs:domain ind:LeiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalFormName rdf:type rdf:Property ;
    rdfs:label 'Legal Form Name' ;
    rdfs:comment 'The descriptive name of the legal form corresponding to the legal form code (e.g., Public Limited Company, Limited Liability Company).' ;
    rdfs:domain ind:LeiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leiStatus rdf:type rdf:Property ;
    rdfs:label 'Lei Status' ;
    rdfs:comment 'The current status of the LEI code itself within the GLEIF system. ISSUED indicates an active LEI; LAPSED indicates the LEI has not been renewed; MERGED, RETIRED, ANNULLED, CANCELLED indicate various termination states; TRANSFERRED and PENDING_TRANSFER indicate LEI management changes between LOUs. [ENUM-REF-CANDIDATE: ISSUED|LAPSED|MERGED|RETIRED|ANNULLED|CANCELLED|TRANSFERRED|PENDING_TRANSFER|PENDING_ARCHIVAL — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LeiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managingLouCode rdf:type rdf:Property ;
    rdfs:label 'Managing Lou Code' ;
    rdfs:comment 'The code identifying the Local Operating Unit (LOU) that currently manages and maintains the LEI record. LOUs are accredited organizations authorized by GLEIF to issue and manage LEIs.' ;
    rdfs:domain ind:LeiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managingLouName rdf:type rdf:Property ;
    rdfs:label 'Managing Lou Name' ;
    rdfs:comment 'The name of the Local Operating Unit (LOU) that currently manages the LEI record (e.g., London Stock Exchange, Bloomberg Finance L.P., DTCC).' ;
    rdfs:domain ind:LeiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextRenewalDate rdf:type rdf:Property ;
    rdfs:label 'Next Renewal Date' ;
    rdfs:comment 'The date by which the LEI must be renewed to maintain its ISSUED status. LEIs must be renewed annually; failure to renew results in a LAPSED status.' ;
    rdfs:domain ind:LeiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:registrationAuthorityCode rdf:type rdf:Property ;
    rdfs:label 'Registration Authority Code' ;
    rdfs:comment 'The identifier of the registration authority (business registry) where the entity is officially registered. This is typically a code from the Registration Authorities Code List (RAL) maintained by GLEIF.' ;
    rdfs:domain ind:LeiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Registration Authority Name' ;
    rdfs:comment 'The name of the registration authority or business registry where the entity is officially registered (e.g., Companies House UK, Delaware Division of Corporations).' ;
    rdfs:domain ind:LeiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipLastUpdateDate rdf:type rdf:Property ;
    rdfs:label 'Relationship Last Update Date' ;
    rdfs:comment 'The date when the parent-child relationship information (direct parent and ultimate parent LEIs) was last updated or validated in the GLEIF system.' ;
    rdfs:domain ind:LeiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:successorLei rdf:type rdf:Property ;
    rdfs:label 'Successor Lei' ;
    rdfs:comment 'The LEI code of the successor entity, if this entity has been merged, acquired, or otherwise succeeded by another legal entity. Used to maintain continuity in regulatory reporting and relationship tracking.' ;
    rdfs:domain ind:LeiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ultimateParentLei rdf:type rdf:Property ;
    rdfs:label 'Ultimate Parent Lei' ;
    rdfs:comment 'The LEI code of the ultimate parent entity at the top of the corporate ownership hierarchy. This represents the highest-level parent entity that is not itself owned or controlled by another entity, as reported under GLEIF Level 2 relationship data. Required for consolidated regulatory reporting and risk assessment.' ;
    rdfs:domain ind:LeiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationSource rdf:type rdf:Property ;
    rdfs:label 'Validation Source' ;
    rdfs:comment 'The level of validation and corroboration applied to the relationship data. FULLY_CORROBORATED indicates both parent and child have confirmed the relationship; PARTIALLY_CORROBORATED indicates one party has confirmed; ENTITY_SUPPLIED_ONLY indicates self-reported data without external validation; PENDING indicates validation is in progress.' ;
    rdfs:domain ind:LeiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradingCurrencyId rdf:type rdf:Property ;
    rdfs:label 'Trading Currency Id' ;
    rdfs:comment 'Foreign key linking to reference.currency. Business justification: Market centers have primary trading currencies. The trading_currency STRING column should be replaced with a proper FK to currency.currency_id. This enables JOIN to retrieve currency_name, iso_code, a' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:bestExecutionVenueFlag rdf:type rdf:Property ;
    rdfs:label 'Best Execution Venue Flag' ;
    rdfs:comment 'Boolean flag indicating whether this market center is designated as a best execution venue for order routing and execution quality reporting (True) or not (False).' ;
    rdfs:domain ind:MarketCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketCategory rdf:type rdf:Property ;
    rdfs:label 'Market Category' ;
    rdfs:comment 'Primary asset class or category traded on this market center (equities, fixed income, derivatives, commodities, foreign exchange, crypto, or multi-asset). [ENUM-REF-CANDIDATE: equities|fixed_income|derivatives|commodities|foreign_exchange|crypto|multi_asset — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MarketCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketCenterStatus rdf:type rdf:Property ;
    rdfs:label 'Market Center Status' ;
    rdfs:comment 'Current operational status of the market center: active (operating normally), suspended (temporarily halted), closed (permanently ceased operations), merged (consolidated into another venue), or decommissioned.' ;
    rdfs:domain ind:MarketCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketDataVendorCode rdf:type rdf:Property ;
    rdfs:label 'Market Data Vendor Code' ;
    rdfs:comment 'Proprietary code or identifier used by market data vendors (Bloomberg, Reuters, FactSet) to reference this market center in their data feeds.' ;
    rdfs:domain ind:MarketCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketName rdf:type rdf:Property ;
    rdfs:label 'Market Name' ;
    rdfs:comment 'Full legal or commonly recognized name of the market center, exchange, or trading venue (e.g., New York Stock Exchange, London Stock Exchange, Chicago Mercantile Exchange).' ;
    rdfs:domain ind:MarketCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketType rdf:type rdf:Property ;
    rdfs:label 'Market Type' ;
    rdfs:comment 'Classification of the trading venue type: regulated exchange, multilateral trading facility (MTF), organized trading facility (OTF), systematic internalizer (SI), over-the-counter (OTC), or dark pool.' ;
    rdfs:domain ind:MarketCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:micCode rdf:type rdf:Property ;
    rdfs:label 'Mic Code' ;
    rdfs:comment 'ISO 10383 four-character alphanumeric code uniquely identifying the market center, exchange, or trading venue (e.g., XNYS for New York Stock Exchange, XLON for London Stock Exchange).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mifid2TradingVenueFlag rdf:type rdf:Property ;
    rdfs:label 'Mifid2 Trading Venue Flag' ;
    rdfs:comment 'Boolean flag indicating whether this market center is classified as a trading venue under MiFID II regulations (True) or not (False).' ;
    rdfs:domain ind:MarketCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operatingHoursClose rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Close' ;
    rdfs:comment 'Standard market closing time in local timezone (HH:mm format, e.g., 16:00 for NYSE, 16:30 for LSE).' ;
    rdfs:domain ind:MarketCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingHoursOpen rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Open' ;
    rdfs:comment 'Standard market opening time in local timezone (HH:mm format, e.g., 09:30 for NYSE, 08:00 for LSE).' ;
    rdfs:domain ind:MarketCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingMic rdf:type rdf:Property ;
    rdfs:label 'Operating Mic' ;
    rdfs:comment 'Operating MIC code representing the entity operating the market infrastructure, which may differ from the segment MIC for multi-segment exchanges.' ;
    rdfs:domain ind:MarketCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentExchangeGroup rdf:type rdf:Property ;
    rdfs:label 'Parent Exchange Group' ;
    rdfs:comment 'Name of the parent exchange group or holding company that owns or operates this market center (e.g., Intercontinental Exchange, Euronext, CME Group).' ;
    rdfs:domain ind:MarketCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postTradingSessionEnd rdf:type rdf:Property ;
    rdfs:label 'Post Trading Session End' ;
    rdfs:comment 'End time of after-hours or post-close trading session in local timezone (HH:mm format), if applicable.' ;
    rdfs:domain ind:MarketCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preTradingSessionStart rdf:type rdf:Property ;
    rdfs:label 'Pre Trading Session Start' ;
    rdfs:comment 'Start time of pre-market or pre-opening auction session in local timezone (HH:mm format), if applicable.' ;
    rdfs:domain ind:MarketCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timezone rdf:type rdf:Property ;
    rdfs:label 'Timezone' ;
    rdfs:comment 'IANA timezone identifier for the market center\'s operating hours (e.g., America/New_York, Europe/London, Asia/Tokyo).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeReportingFacilityFlag rdf:type rdf:Property ;
    rdfs:label 'Trade Reporting Facility Flag' ;
    rdfs:comment 'Boolean flag indicating whether this market center operates as a trade reporting facility for off-exchange transactions (True) or not (False).' ;
    rdfs:domain ind:MarketCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:websiteUrl rdf:type rdf:Property ;
    rdfs:label 'Website Url' ;
    rdfs:comment 'Official website URL of the market center for reference and market data access.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fallbackSourceMarketDataSourceId rdf:type rdf:Property ;
    rdfs:label 'Fallback Source Market Data Source Id' ;
    rdfs:comment 'Reference to the alternative market data source to be used if this source becomes unavailable or fails quality checks. Self-referential foreign key to another market_data_source record.' ;
    rdfs:domain ind:MarketDataSource ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MarketDataSource .

ind:annualCostUsd rdf:type rdf:Property ;
    rdfs:label 'Annual Cost Usd' ;
    rdfs:comment 'Total annual subscription or licensing cost for this market data source in USD. Used for vendor cost management and budgeting.' ;
    rdfs:domain ind:MarketDataSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assetClassCoverage rdf:type rdf:Property ;
    rdfs:label 'Asset Class Coverage' ;
    rdfs:comment 'Comma-separated list of asset classes covered by this source (e.g., equities, fixed income, FX, commodities, derivatives, credit, structured products). Indicates scope of market data provided.' ;
    rdfs:domain ind:MarketDataSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessOwnerLob rdf:type rdf:Property ;
    rdfs:label 'Business Owner Lob' ;
    rdfs:comment 'Primary line of business or division that owns and funds this market data source (e.g., Trading, Asset Management, Risk, Treasury). Used for cost allocation and accountability.' ;
    rdfs:domain ind:MarketDataSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:connectivityMethod rdf:type rdf:Property ;
    rdfs:label 'Connectivity Method' ;
    rdfs:comment 'Technical delivery mechanism for the data feed: API (REST/SOAP), FTP/SFTP batch transfer, real-time streaming protocol, message queue (e.g., Kafka, MQ), direct market feed, or web service. [ENUM-REF-CANDIDATE: API|FTP|SFTP|real-time-stream|message-queue|direct-feed|web-service — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MarketDataSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataFrequency rdf:type rdf:Property ;
    rdfs:label 'Data Frequency' ;
    rdfs:comment 'Granularity or update frequency of the market data feed: tick-by-tick, per-second, per-minute, hourly, daily, weekly, or monthly. [ENUM-REF-CANDIDATE: tick|second|minute|hourly|daily|weekly|monthly — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MarketDataSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataQualityTier rdf:type rdf:Property ;
    rdfs:label 'Data Quality Tier' ;
    rdfs:comment 'Enterprise classification of the source\'s data quality and reliability: tier-1 (highest quality, regulatory-grade), tier-2 (standard quality), tier-3 (lower quality or unverified), or internal (proprietary pricing desk).' ;
    rdfs:domain ind:MarketDataSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataRetentionDays rdf:type rdf:Property ;
    rdfs:label 'Data Retention Days' ;
    rdfs:comment 'Number of days historical data from this source is retained in the enterprise data lake or warehouse. Driven by regulatory requirements, storage costs, and business needs.' ;
    rdfs:domain ind:MarketDataSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataStewardEmail rdf:type rdf:Property ;
    rdfs:label 'Data Steward Email' ;
    rdfs:comment 'Email address of the data steward responsible for this market data source.' ;
    rdfs:domain ind:MarketDataSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feedType rdf:type rdf:Property ;
    rdfs:label 'Feed Type' ;
    rdfs:comment 'Classification of the data feed delivery frequency and latency: real-time streaming, delayed quotes, end-of-day batch, intraday snapshots, evaluated pricing, or composite aggregated feeds.' ;
    rdfs:domain ind:MarketDataSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instrumentTypeCoverage rdf:type rdf:Property ;
    rdfs:label 'Instrument Type Coverage' ;
    rdfs:comment 'Specific instrument types or security classifications covered by this source (e.g., listed equities, corporate bonds, government securities, interest rate swaps, FX forwards, commodity futures). Complements asset_class_coverage with granular detail.' ;
    rdfs:domain ind:MarketDataSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseEndDate rdf:type rdf:Property ;
    rdfs:label 'License End Date' ;
    rdfs:comment 'Expiration or renewal date of the current license agreement. Null if perpetual or rolling subscription.' ;
    rdfs:domain ind:MarketDataSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseStartDate rdf:type rdf:Property ;
    rdfs:label 'License Start Date' ;
    rdfs:comment 'Effective start date of the current license agreement or subscription term with this provider.' ;
    rdfs:domain ind:MarketDataSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:marketCoverage rdf:type rdf:Property ;
    rdfs:label 'Market Coverage' ;
    rdfs:comment 'Geographic markets or exchanges covered by this source (e.g., NYSE, LSE, XETRA, TSE, global OTC). Comma-separated list of market identifiers or regions.' ;
    rdfs:domain ind:MarketDataSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketDataSourceStatus rdf:type rdf:Property ;
    rdfs:label 'Market Data Source Status' ;
    rdfs:comment 'Current operational status of the market data source: active (in production use), inactive (temporarily disabled), suspended (service issue), decommissioned (retired), pilot (testing phase), or pending-approval (awaiting governance approval).' ;
    rdfs:domain ind:MarketDataSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideGovernanceRule rdf:type rdf:Property ;
    rdfs:label 'Override Governance Rule' ;
    rdfs:comment 'Description of the governance process and approval requirements for overriding prices from this source. Defines who can override, under what conditions, and audit trail requirements.' ;
    rdfs:domain ind:MarketDataSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingMethodology rdf:type rdf:Property ;
    rdfs:label 'Pricing Methodology' ;
    rdfs:comment 'Description of how prices are determined by this source: exchange last trade, composite average (e.g., BGN composite), evaluated/model-based pricing, broker quotes, internal desk pricing, or consensus pricing.' ;
    rdfs:domain ind:MarketDataSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:providerCode rdf:type rdf:Property ;
    rdfs:label 'Provider Code' ;
    rdfs:comment 'Short alphanumeric code or ticker symbol uniquely identifying the provider within the enterprise (e.g., BBG, RFTV, ICE, MKIT).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryApprovedFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approved Flag' ;
    rdfs:comment 'Indicates whether this source is approved for use in regulatory reporting, capital calculations, or official valuations (e.g., CCAR, DFAST, Basel III, IFRS 9). True if approved, False otherwise.' ;
    rdfs:domain ind:MarketDataSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaDataAccuracyPct rdf:type rdf:Property ;
    rdfs:label 'Sla Data Accuracy Pct' ;
    rdfs:comment 'Contractually committed data accuracy rate (e.g., 99.99%). Measures correctness of prices, reference data, and corporate actions.' ;
    rdfs:domain ind:MarketDataSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaLatencyMs rdf:type rdf:Property ;
    rdfs:label 'Sla Latency Ms' ;
    rdfs:comment 'Maximum guaranteed latency in milliseconds for real-time or intraday feeds. Critical for trading and risk systems requiring low-latency market data.' ;
    rdfs:domain ind:MarketDataSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaUptimePct rdf:type rdf:Property ;
    rdfs:label 'Sla Uptime Pct' ;
    rdfs:comment 'Contractually committed uptime percentage for the data feed (e.g., 99.95%). Used to monitor vendor performance and trigger service credits.' ;
    rdfs:domain ind:MarketDataSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceDesignation rdf:type rdf:Property ;
    rdfs:label 'Source Designation' ;
    rdfs:comment 'Role of this source in the enterprise data hierarchy: primary (authoritative default), fallback (used when primary unavailable), supplementary (additional validation), or reference-only (not used for valuation).' ;
    rdfs:domain ind:MarketDataSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationUseCase rdf:type rdf:Property ;
    rdfs:label 'Valuation Use Case' ;
    rdfs:comment 'Comma-separated list of valuation contexts where this source is authoritative: MTM (mark-to-market), NAV (net asset value), risk valuation, regulatory reporting, client reporting, collateral valuation, or internal management reporting.' ;
    rdfs:domain ind:MarketDataSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorContactEmail rdf:type rdf:Property ;
    rdfs:label 'Vendor Contact Email' ;
    rdfs:comment 'Email address of the primary vendor contact for support, escalations, and service issues.' ;
    rdfs:domain ind:MarketDataSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorContactName rdf:type rdf:Property ;
    rdfs:label 'Vendor Contact Name' ;
    rdfs:comment 'Name of the primary vendor account manager or technical contact for this data source.' ;
    rdfs:domain ind:MarketDataSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorContactPhone rdf:type rdf:Property ;
    rdfs:label 'Vendor Contact Phone' ;
    rdfs:comment 'Phone number of the primary vendor contact for urgent support and escalations.' ;
    rdfs:domain ind:MarketDataSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amlMonitoringRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Aml Monitoring Required Flag' ;
    rdfs:comment 'Indicates whether transactions for this product type require anti-money laundering transaction monitoring, suspicious activity report (SAR) screening, and currency transaction report (CTR) filing.' ;
    rdfs:domain ind:ProductType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bookingModel rdf:type rdf:Property ;
    rdfs:label 'Booking Model' ;
    rdfs:comment 'Accounting treatment and valuation methodology applied to this product type (accrual, fair value, amortized cost, held for trading, available for sale). Determines how the product is measured and reported in the general ledger.' ;
    rdfs:domain ind:ProductType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ccarDfastCategory rdf:type rdf:Property ;
    rdfs:label 'Ccar Dfast Category' ;
    rdfs:comment 'Product classification used in CCAR and DFAST stress testing scenarios for capital planning and regulatory submissions to the Federal Reserve.' ;
    rdfs:domain ind:ProductType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ceclPortfolioSegment rdf:type rdf:Property ;
    rdfs:label 'Cecl Portfolio Segment' ;
    rdfs:comment 'Portfolio segment assignment for CECL expected credit loss calculation and allowance for credit losses (ACL) estimation under FASB ASC 326.' ;
    rdfs:domain ind:ProductType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Credit Risk Flag' ;
    rdfs:comment 'Indicates whether this product type carries credit risk exposure requiring probability of default (PD), loss given default (LGD), and exposure at default (EAD) calculations for capital adequacy purposes.' ;
    rdfs:domain ind:ProductType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:feeScheduleType rdf:type rdf:Property ;
    rdfs:label 'Fee Schedule Type' ;
    rdfs:comment 'Reference to the applicable fee schedule or pricing model for this product type (e.g., Standard Commercial Lending Fees, Wealth Management Advisory Fees, Transaction Banking Fees). Used to link product types to fee structures.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccountMapping rdf:type rdf:Property ;
    rdfs:label 'Gl Account Mapping' ;
    rdfs:comment 'Reference to the general ledger account code(s) or chart of accounts segment used for booking transactions of this product type. Enables financial reporting and reconciliation.' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liquidityRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Liquidity Risk Flag' ;
    rdfs:comment 'Indicates whether this product type contributes to liquidity risk metrics such as Liquidity Coverage Ratio (LCR) and Net Stable Funding Ratio (NSFR).' ;
    rdfs:domain ind:ProductType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Market Risk Flag' ;
    rdfs:comment 'Indicates whether this product type is subject to market risk (interest rate, foreign exchange, equity, commodity price movements) requiring Value at Risk (VaR) and stress testing.' ;
    rdfs:domain ind:ProductType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minimumAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Amount' ;
    rdfs:comment 'The minimum transaction or account balance amount required for this product type, expressed in the bank\'s base currency. Used for product eligibility and origination controls.' ;
    rdfs:domain ind:ProductType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:multiCurrencyFlag rdf:type rdf:Property ;
    rdfs:label 'Multi Currency Flag' ;
    rdfs:comment 'Indicates whether this product type supports multiple currencies (true for multi-currency accounts and foreign exchange products, false for single-currency products).' ;
    rdfs:domain ind:ProductType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operationalRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Operational Risk Flag' ;
    rdfs:comment 'Indicates whether this product type is subject to operational risk capital requirements under the Standardized Measurement Approach (SMA) or Advanced Measurement Approach (AMA).' ;
    rdfs:domain ind:ProductType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productFamily rdf:type rdf:Property ;
    rdfs:label 'Product Family' ;
    rdfs:comment 'High-level grouping of product types into major business lines (lending, deposit, investment, trading, advisory, payment, guarantee, custody, other). [ENUM-REF-CANDIDATE: lending|deposit|investment|trading|advisory|payment|guarantee|custody|other — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ProductType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productLifecycleStatus rdf:type rdf:Property ;
    rdfs:label 'Product Lifecycle Status' ;
    rdfs:comment 'Current lifecycle state of the product type in the bank\'s product catalog (active for current offerings, inactive for temporarily unavailable, discontinued for retired products, pending approval for new products under review, sunset for products being phased out).' ;
    rdfs:domain ind:ProductType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productTypeCode rdf:type rdf:Property ;
    rdfs:label 'Product Type Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the product type across all bank systems. Used as the business key for product classification in regulatory reporting and internal systems.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productTypeDescription rdf:type rdf:Property ;
    rdfs:label 'Product Type Description' ;
    rdfs:comment 'Detailed business description of the product type, including key features, typical use cases, target customer segments, and distinguishing characteristics.' ;
    rdfs:domain ind:ProductType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productTypeName rdf:type rdf:Property ;
    rdfs:label 'Product Type Name' ;
    rdfs:comment 'Full business name of the product type as recognized by business users and customers (e.g., Term Loan, Revolving Credit Facility, Demand Deposit Account, Interest Rate Swap).' ;
    rdfs:domain ind:ProductType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryProductCategoryBasel rdf:type rdf:Property ;
    rdfs:label 'Regulatory Product Category Basel' ;
    rdfs:comment 'Product classification according to Basel III regulatory framework for capital adequacy and risk-weighted asset (RWA) calculation (e.g., Corporate Exposure, Retail Exposure, Sovereign Exposure).' ;
    rdfs:domain ind:ProductType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryProductCategoryIfrs9 rdf:type rdf:Property ;
    rdfs:label 'Regulatory Product Category Ifrs9' ;
    rdfs:comment 'Product classification according to IFRS 9 accounting standard for financial instruments, determining measurement basis (amortized cost, fair value through other comprehensive income, fair value through profit or loss) and expected credit loss (ECL) calculation approach.' ;
    rdfs:domain ind:ProductType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rwaApproach rdf:type rdf:Property ;
    rdfs:label 'Rwa Approach' ;
    rdfs:comment 'The Basel III approach used to calculate risk-weighted assets for this product type (standardized approach, foundation internal ratings-based, advanced internal ratings-based, or not applicable for non-credit products).' ;
    rdfs:domain ind:ProductType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaServiceLevel rdf:type rdf:Property ;
    rdfs:label 'Sla Service Level' ;
    rdfs:comment 'The service level commitment associated with this product type, defining response times, processing speeds, and support availability (standard, priority, premium, or not applicable for non-service products).' ;
    rdfs:domain ind:ProductType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subProductType rdf:type rdf:Property ;
    rdfs:label 'Sub Product Type' ;
    rdfs:comment 'Granular sub-classification within the product type (e.g., for Term Loan: Senior Secured, Subordinated; for Deposit: Savings, Checking, Money Market).' ;
    rdfs:domain ind:ProductType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxReportingCategory rdf:type rdf:Property ;
    rdfs:label 'Tax Reporting Category' ;
    rdfs:comment 'Tax classification for this product type used for IRS Form 1099 reporting, withholding tax calculations, and tax compliance (e.g., interest income, dividend income, capital gains).' ;
    rdfs:domain ind:ProductType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typicalTermMonths rdf:type rdf:Property ;
    rdfs:label 'Typical Term Months' ;
    rdfs:comment 'The standard or most common term length in months for this product type (e.g., 60 months for a 5-year term loan, 12 months for a 1-year certificate of deposit). Null for demand or perpetual products.' ;
    rdfs:domain ind:ProductType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fallbackRateBenchmarkId rdf:type rdf:Property ;
    rdfs:label 'Fallback Rate Benchmark Id' ;
    rdfs:comment 'Reference to the alternative benchmark that serves as the fallback rate if this benchmark is discontinued (e.g., SOFR as fallback for USD LIBOR).' ;
    rdfs:domain ind:RateBenchmark ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RateBenchmark .

ind:administratorJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Administrator Jurisdiction' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the administrators regulatory jurisdiction (e.g., USA, GBR, EUR).' ;
    rdfs:domain ind:RateBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alternativeBenchmarkNames rdf:type rdf:Property ;
    rdfs:label 'Alternative Benchmark Names' ;
    rdfs:comment 'Comma-separated list of alternative names or abbreviations for the benchmark (e.g., \'Fed Funds, Federal Funds Rate, Effective Federal Funds Rate\').' ;
    rdfs:domain ind:RateBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benchmarkCode rdf:type rdf:Property ;
    rdfs:label 'Benchmark Code' ;
    rdfs:comment 'Standardized short code for the benchmark (e.g., SOFR, LIBOR_USD_3M, EURIBOR_6M, SONIA, ESTR, FED_FUNDS).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benchmarkFamily rdf:type rdf:Property ;
    rdfs:label 'Benchmark Family' ;
    rdfs:comment 'Grouping of related benchmarks under a common family name (e.g., LIBOR family includes USD LIBOR, GBP LIBOR, EUR LIBOR; SOFR family includes SOFR, Term SOFR).' ;
    rdfs:domain ind:RateBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benchmarkName rdf:type rdf:Property ;
    rdfs:label 'Benchmark Name' ;
    rdfs:comment 'Full legal name of the interest rate benchmark (e.g., Secured Overnight Financing Rate, London Interbank Offered Rate).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compoundingConvention rdf:type rdf:Property ;
    rdfs:label 'Compounding Convention' ;
    rdfs:comment 'Method for aggregating overnight rates into term rates: simple (arithmetic average), compounded (geometric compounding), averaged (simple average), none (single rate, not compounded).' ;
    rdfs:domain ind:RateBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSourceDescription rdf:type rdf:Property ;
    rdfs:label 'Data Source Description' ;
    rdfs:comment 'Description of the underlying data sources used to calculate the benchmark (e.g., tri-party repo transactions cleared through FICC, panel bank submissions, central bank policy rate).' ;
    rdfs:domain ind:RateBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fallbackSpreadAdjustment rdf:type rdf:Property ;
    rdfs:label 'Fallback Spread Adjustment' ;
    rdfs:comment 'Fixed spread (in basis points) added to the fallback rate to account for historical differences between the original benchmark and the fallback benchmark.' ;
    rdfs:domain ind:RateBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:iborTransitionStatus rdf:type rdf:Property ;
    rdfs:label 'Ibor Transition Status' ;
    rdfs:comment 'Current status of the benchmark in the context of IBOR reform: active (current use), legacy (being phased out, e.g., LIBOR), discontinued (no longer published), transition_phase (migration underway), fallback_activated (fallback rate in use).' ;
    rdfs:domain ind:RateBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRiskFreeRate rdf:type rdf:Property ;
    rdfs:label 'Is Risk Free Rate' ;
    rdfs:comment 'Indicates whether the benchmark is classified as a risk-free rate (e.g., SOFR, SONIA, ESTR) as opposed to a credit-sensitive rate (e.g., LIBOR). True for RFRs, False otherwise.' ;
    rdfs:domain ind:RateBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSecuredRate rdf:type rdf:Property ;
    rdfs:label 'Is Secured Rate' ;
    rdfs:comment 'Indicates whether the benchmark is based on secured transactions (e.g., repo transactions for SOFR) as opposed to unsecured lending (e.g., LIBOR). True for secured rates, False for unsecured.' ;
    rdfs:domain ind:RateBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastPublicationDate rdf:type rdf:Property ;
    rdfs:label 'Last Publication Date' ;
    rdfs:comment 'Most recent date on which a rate was published for this benchmark. Used to track currency of data and identify stale benchmarks.' ;
    rdfs:domain ind:RateBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:observationShiftDays rdf:type rdf:Property ;
    rdfs:label 'Observation Shift Days' ;
    rdfs:comment 'Number of days the observation period is shifted backward relative to the interest period (alternative to lookback for SOFR and other overnight rates).' ;
    rdfs:domain ind:RateBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:panelBankCount rdf:type rdf:Property ;
    rdfs:label 'Panel Bank Count' ;
    rdfs:comment 'Number of contributing banks or institutions in the benchmark panel (for panel-based benchmarks like legacy LIBOR). Null for transaction-based benchmarks.' ;
    rdfs:domain ind:RateBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paymentDelayDays rdf:type rdf:Property ;
    rdfs:label 'Payment Delay Days' ;
    rdfs:comment 'Standard number of business days between rate fixing and payment date (e.g., T+2 for some benchmarks).' ;
    rdfs:domain ind:RateBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:publicationSource rdf:type rdf:Property ;
    rdfs:label 'Publication Source' ;
    rdfs:comment 'Official source or platform where the benchmark rate is published (e.g., Federal Reserve website, Bloomberg, Reuters, ICE portal).' ;
    rdfs:domain ind:RateBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicationTime rdf:type rdf:Property ;
    rdfs:label 'Publication Time' ;
    rdfs:comment 'Standard time of day when the benchmark rate is published, in the administrators local timezone (e.g., 08:00 EST, 11:00 CET).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:tenorConvention rdf:type rdf:Property ;
    rdfs:label 'Tenor Convention' ;
    rdfs:comment 'Standard maturity or term structure for the benchmark (e.g., overnight, 1-month, 3-month, 6-month, 12-month). Overnight benchmarks use \'overnight\'; term benchmarks specify the period. [ENUM-REF-CANDIDATE: overnight|1_week|1_month|3_month|6_month|12_month|spot|custom — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RateBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionVolumeThreshold rdf:type rdf:Property ;
    rdfs:label 'Transaction Volume Threshold' ;
    rdfs:comment 'Minimum daily transaction volume (in currency units) required for the benchmark to be published. Used to assess benchmark robustness and representativeness.' ;
    rdfs:domain ind:RateBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usageScope rdf:type rdf:Property ;
    rdfs:label 'Usage Scope' ;
    rdfs:comment 'Description of typical use cases for the benchmark (e.g., loan pricing, derivatives valuation, asset-liability management, mortgage indexing, corporate debt).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPredecessorTaxonomyRegulatoryTaxonomyId rdf:type rdf:Property ;
    rdfs:label 'Primary Predecessor Taxonomy Regulatory Taxonomy Id' ;
    rdfs:comment 'Reference to the previous version of this taxonomy that this version supersedes. Null if this is the first version.' ;
    rdfs:domain ind:RegulatoryTaxonomy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryTaxonomy .

ind:applicableEntityTypes rdf:type rdf:Property ;
    rdfs:label 'Applicable Entity Types' ;
    rdfs:comment 'Comma-separated list of entity types or institution categories to which this taxonomy applies (e.g., Bank Holding Company, Savings and Loan, Investment Bank, Broker-Dealer, Insurance Company).' ;
    rdfs:domain ind:RegulatoryTaxonomy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetThresholdMinimum rdf:type rdf:Property ;
    rdfs:label 'Asset Threshold Minimum' ;
    rdfs:comment 'Minimum total asset threshold (in reporting currency) for institutions required to report using this taxonomy. Null if no threshold applies.' ;
    rdfs:domain ind:RegulatoryTaxonomy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:changeSummary rdf:type rdf:Property ;
    rdfs:label 'Change Summary' ;
    rdfs:comment 'Summary of key changes, additions, or deletions in this taxonomy version compared to the predecessor version.' ;
    rdfs:domain ind:RegulatoryTaxonomy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataPointCount rdf:type rdf:Property ;
    rdfs:label 'Data Point Count' ;
    rdfs:comment 'Total number of individual data points or reporting codes defined within this taxonomy version.' ;
    rdfs:domain ind:RegulatoryTaxonomy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hierarchicalStructure rdf:type rdf:Property ;
    rdfs:label 'Hierarchical Structure' ;
    rdfs:comment 'Indicates whether the taxonomy has a flat structure or a hierarchical/multi-level structure with parent-child code relationships (flat, hierarchical, multi-level, dimensional).' ;
    rdfs:domain ind:RegulatoryTaxonomy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implementationGuidanceUrl rdf:type rdf:Property ;
    rdfs:label 'Implementation Guidance Url' ;
    rdfs:comment 'URL or reference to official implementation guidance, FAQs, or technical documentation provided by the issuing authority.' ;
    rdfs:domain ind:RegulatoryTaxonomy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalOwner rdf:type rdf:Property ;
    rdfs:label 'Internal Owner' ;
    rdfs:comment 'Name or identifier of the internal business unit, team, or individual responsible for maintaining the mapping and compliance with this taxonomy.' ;
    rdfs:domain ind:RegulatoryTaxonomy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingFrequency rdf:type rdf:Property ;
    rdfs:label 'Reporting Frequency' ;
    rdfs:comment 'The required frequency at which reports using this taxonomy must be submitted to the regulatory authority (daily, weekly, monthly, quarterly, semi-annual, annual, ad-hoc). [ENUM-REF-CANDIDATE: daily|weekly|monthly|quarterly|semi_annual|annual|ad_hoc — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingPlatformCode rdf:type rdf:Property ;
    rdfs:label 'Reporting Platform Code' ;
    rdfs:comment 'Internal code or identifier used by the regulatory reporting platform (e.g., AxiomSL, OneSumX) to reference this taxonomy in mapping and transformation logic.' ;
    rdfs:domain ind:RegulatoryTaxonomy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleCount rdf:type rdf:Property ;
    rdfs:label 'Schedule Count' ;
    rdfs:comment 'Total number of schedules, forms, or report sections defined within this taxonomy.' ;
    rdfs:domain ind:RegulatoryTaxonomy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:schemaLocationUrl rdf:type rdf:Property ;
    rdfs:label 'Schema Location Url' ;
    rdfs:comment 'URL or file path to the official schema definition file (XSD, JSON schema, etc.) for this taxonomy.' ;
    rdfs:domain ind:RegulatoryTaxonomy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Source Document Reference' ;
    rdfs:comment 'Reference to the official regulatory document, circular, or publication that defines this taxonomy (e.g., BCBS document number, Federal Register citation, EBA guideline reference).' ;
    rdfs:domain ind:RegulatoryTaxonomy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxonomyCode rdf:type rdf:Property ;
    rdfs:label 'Taxonomy Code' ;
    rdfs:comment 'Unique code or identifier assigned to the taxonomy by the issuing regulatory authority (e.g., BCBS239, FFIEC031, SEC10K).' ;
    rdfs:domain ind:RegulatoryTaxonomy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxonomyDescription rdf:type rdf:Property ;
    rdfs:label 'Taxonomy Description' ;
    rdfs:comment 'Detailed description of the purpose, scope, and content of the regulatory taxonomy, including the types of data points and schedules it covers.' ;
    rdfs:domain ind:RegulatoryTaxonomy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxonomyName rdf:type rdf:Property ;
    rdfs:label 'Taxonomy Name' ;
    rdfs:comment 'Official name of the regulatory taxonomy or reporting framework (e.g., Basel III Pillar 3, CCAR Schedule A, DFAST FR Y-14Q, FATCA Form 8966).' ;
    rdfs:domain ind:RegulatoryTaxonomy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxonomyStatus rdf:type rdf:Property ;
    rdfs:label 'Taxonomy Status' ;
    rdfs:comment 'Current lifecycle status of the taxonomy version (draft, active, superseded, retired, under_review).' ;
    rdfs:domain ind:RegulatoryTaxonomy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxonomyType rdf:type rdf:Property ;
    rdfs:label 'Taxonomy Type' ;
    rdfs:comment 'The category or domain of regulatory reporting this taxonomy addresses (e.g., capital adequacy, liquidity, credit risk, market risk, operational risk, stress testing, tax compliance, trade reporting, financial statement). [ENUM-REF-CANDIDATE: capital_adequacy|liquidity|credit_risk|market_risk|operational_risk|stress_testing|tax_compliance|trade_reporting|financial_statement — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RegulatoryTaxonomy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxonomyVersion rdf:type rdf:Property ;
    rdfs:label 'Taxonomy Version' ;
    rdfs:comment 'Version number or release identifier of the taxonomy schema (e.g., v3.1, 2023Q4, Release 5.0).' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationRulesUrl rdf:type rdf:Property ;
    rdfs:label 'Validation Rules Url' ;
    rdfs:comment 'URL or reference to the official validation rules, business rules, or edit checks document for this taxonomy.' ;
    rdfs:domain ind:RegulatoryTaxonomy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:xbrlNamespace rdf:type rdf:Property ;
    rdfs:label 'Xbrl Namespace' ;
    rdfs:comment 'The XBRL namespace URI for this taxonomy if XBRL is the submission format. Null if not applicable.' ;
    rdfs:domain ind:RegulatoryTaxonomy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentCodeReportingCodeId rdf:type rdf:Property ;
    rdfs:label 'Parent Code Reporting Code Id' ;
    rdfs:comment 'Reference to the parent reporting code in hierarchical taxonomies. Enables navigation of nested reporting structures (e.g., schedule > section > line item). Null for top-level codes.' ;
    rdfs:domain ind:ReportingCode ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReportingCode .

ind:primarySupersededByCodeReportingCodeId rdf:type rdf:Property ;
    rdfs:label 'Primary Superseded By Code Reporting Code Id' ;
    rdfs:comment 'Reference to the reporting code that replaces this code when it is superseded or deprecated. Enables seamless transition during regulatory changes.' ;
    rdfs:domain ind:ReportingCode ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReportingCode .

ind:businessDefinition rdf:type rdf:Property ;
    rdfs:label 'Business Definition' ;
    rdfs:comment 'Detailed business definition and interpretation guidance for this reporting code. Provides context for data stewards and analysts mapping source data.' ;
    rdfs:domain ind:ReportingCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculationFormula rdf:type rdf:Property ;
    rdfs:label 'Calculation Formula' ;
    rdfs:comment 'Formula or expression defining how this reporting code value should be calculated from source data or other codes. Enables automated report generation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataQualityThreshold rdf:type rdf:Property ;
    rdfs:label 'Data Quality Threshold' ;
    rdfs:comment 'Minimum acceptable data quality score (as percentage) for values reported under this code. Drives data quality monitoring and remediation workflows.' ;
    rdfs:domain ind:ReportingCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataType rdf:type rdf:Property ;
    rdfs:label 'Data Type' ;
    rdfs:comment 'Expected data type for values reported under this code. Guides validation and formatting of regulatory submissions. [ENUM-REF-CANDIDATE: monetary|percentage|count|text|date|boolean|ratio — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ReportingCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exampleValue rdf:type rdf:Property ;
    rdfs:label 'Example Value' ;
    rdfs:comment 'Sample or example value for this reporting code to illustrate expected format and content. Aids in user training and system testing.' ;
    rdfs:domain ind:ReportingCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isCalculated rdf:type rdf:Property ;
    rdfs:label 'Is Calculated' ;
    rdfs:comment 'Indicates whether this code value is calculated from other codes (true) or directly sourced from operational systems (false). Guides data lineage and validation.' ;
    rdfs:domain ind:ReportingCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isConfidential rdf:type rdf:Property ;
    rdfs:label 'Is Confidential' ;
    rdfs:comment 'Indicates whether data reported under this code is considered confidential or sensitive by the regulatory authority. Drives access control and data handling.' ;
    rdfs:domain ind:ReportingCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMandatory rdf:type rdf:Property ;
    rdfs:label 'Is Mandatory' ;
    rdfs:comment 'Indicates whether this reporting code is mandatory (true) or optional (false) for regulatory submissions. Drives validation and completeness checks.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mappingNotes rdf:type rdf:Property ;
    rdfs:label 'Mapping Notes' ;
    rdfs:comment 'Detailed notes on how internal General Ledger (GL) accounts, risk data, or other source systems map to this reporting code. Critical for accurate regulatory submissions.' ;
    rdfs:domain ind:ReportingCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportScheduleName rdf:type rdf:Property ;
    rdfs:label 'Report Schedule Name' ;
    rdfs:comment 'Name of the regulatory report schedule or form that contains this code (e.g., FR Y-14A, Call Report Schedule RC-R, FINREP F01.01). Provides report context.' ;
    rdfs:domain ind:ReportingCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingCodeStatus rdf:type rdf:Property ;
    rdfs:label 'Reporting Code Status' ;
    rdfs:comment 'Current lifecycle status of the reporting code. Active codes are used in current submissions; deprecated codes are phased out; proposed codes are pending implementation.' ;
    rdfs:domain ind:ReportingCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roundingRule rdf:type rdf:Property ;
    rdfs:label 'Rounding Rule' ;
    rdfs:comment 'Rounding convention for reported values (e.g., round to nearest thousand, round up, truncate). Ensures compliance with regulatory formatting requirements.' ;
    rdfs:domain ind:ReportingCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signConvention rdf:type rdf:Property ;
    rdfs:label 'Sign Convention' ;
    rdfs:comment 'Convention for reporting positive or negative values (e.g., assets positive, liabilities negative, or absolute values only). Ensures consistent interpretation.' ;
    rdfs:domain ind:ReportingCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationRule rdf:type rdf:Property ;
    rdfs:label 'Validation Rule' ;
    rdfs:comment 'Business rule or formula for validating reported values (e.g., must be >= 0, sum of child codes, cross-schedule validation). Supports automated quality checks.' ;
    rdfs:domain ind:ReportingCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:xbrlTag rdf:type rdf:Property ;
    rdfs:label 'Xbrl Tag' ;
    rdfs:comment 'XBRL tag or element name associated with this reporting code for electronic regulatory filings. Enables automated XBRL report generation.' ;
    rdfs:domain ind:ReportingCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:concentrationRiskId rdf:type rdf:Property ;
    rdfs:label 'Concentration Risk Id' ;
    rdfs:comment 'Unique identifier for the concentration risk measurement record.' ;
    rdfs:domain ind:ConcentrationRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryConcentrationEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Concentration Employee Id' ;
    rdfs:comment 'Foreign key reference to the employee who is designated as the risk owner responsible for monitoring and managing this concentration risk.' ;
    rdfs:domain ind:ConcentrationRisk ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:alcoReviewDate rdf:type rdf:Property ;
    rdfs:label 'Alco Review Date' ;
    rdfs:comment 'Date on which the ALCO reviewed this concentration risk measurement and any associated breach or remediation plan.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:alcoReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Alco Review Status' ;
    rdfs:comment 'Status of ALCO review and approval for this concentration risk measurement, particularly for breaches requiring committee oversight.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cet1CapitalPercentage rdf:type rdf:Property ;
    rdfs:label 'Cet1 Capital Percentage' ;
    rdfs:comment 'Concentration exposure expressed as a percentage of the bank\'s Common Equity Tier 1 capital, used for large exposure monitoring.' ;
    rdfs:domain ind:ConcentrationRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collateralTypeCode rdf:type rdf:Property ;
    rdfs:label 'Collateral Type Code' ;
    rdfs:comment 'Collateral type classification code when concentration type is collateral-based (e.g., real estate, securities, cash, guarantees).' ;
    rdfs:domain ind:ConcentrationRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commentary rdf:type rdf:Property ;
    rdfs:label 'Commentary' ;
    rdfs:comment 'Free-text commentary providing additional context, analysis, or explanation regarding the concentration risk measurement, breach circumstances, or remediation plan.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:concentrationDimension rdf:type rdf:Property ;
    rdfs:label 'Concentration Dimension' ;
    rdfs:comment 'Specific dimension or segment being measured within the concentration type (e.g., specific counterparty name, industry sector code, country code, product category, collateral class).' ;
    rdfs:domain ind:ConcentrationRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:concentrationMetricName rdf:type rdf:Property ;
    rdfs:label 'Concentration Metric Name' ;
    rdfs:comment 'Name of the concentration risk metric being measured (e.g., Single-Name Exposure, Sector Concentration Index, Geographic HHI, Product Type Exposure).' ;
    rdfs:domain ind:ConcentrationRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:concentrationPercentage rdf:type rdf:Property ;
    rdfs:label 'Concentration Percentage' ;
    rdfs:comment 'Concentration exposure expressed as a percentage of total portfolio exposure, total capital, or other relevant denominator.' ;
    rdfs:domain ind:ConcentrationRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:concentrationType rdf:type rdf:Property ;
    rdfs:label 'Concentration Type' ;
    rdfs:comment 'Type of concentration risk being measured: counterparty (single-name), industry sector, geographic region, product type, collateral type, or currency concentration.' ;
    rdfs:domain ind:ConcentrationRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentExposureAmount rdf:type rdf:Property ;
    rdfs:label 'Current Exposure Amount' ;
    rdfs:comment 'Current exposure amount for the specified concentration dimension, representing the total credit or market risk exposure to that dimension.' ;
    rdfs:domain ind:ConcentrationRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:excessAmount rdf:type rdf:Property ;
    rdfs:label 'Excess Amount' ;
    rdfs:comment 'Amount by which the current exposure exceeds the applicable threshold, expressed in reporting currency. Null if no breach exists.' ;
    rdfs:domain ind:ConcentrationRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exposureReportingCurrency rdf:type rdf:Property ;
    rdfs:label 'Exposure Reporting Currency' ;
    rdfs:comment 'Current exposure amount converted to the reporting currency for consolidated risk reporting and limit monitoring.' ;
    rdfs:domain ind:ConcentrationRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hhiIndexValue rdf:type rdf:Property ;
    rdfs:label 'Hhi Index Value' ;
    rdfs:comment 'Herfindahl-Hirschman Index value measuring portfolio concentration, calculated as the sum of squared market shares. Higher values indicate greater concentration risk.' ;
    rdfs:domain ind:ConcentrationRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isLargeExposure rdf:type rdf:Property ;
    rdfs:label 'Is Large Exposure' ;
    rdfs:comment 'Boolean flag indicating whether this concentration meets the regulatory definition of a large exposure (typically exceeding 10% of Tier 1 capital).' ;
    rdfs:domain ind:ConcentrationRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:limitThreshold rdf:type rdf:Property ;
    rdfs:label 'Limit Threshold' ;
    rdfs:comment 'Hard limit threshold value for the concentration metric. Breaching this level requires immediate remediation action and senior management approval for any further exposure increase.' ;
    rdfs:domain ind:ConcentrationRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementDate rdf:type rdf:Property ;
    rdfs:label 'Measurement Date' ;
    rdfs:comment 'Business date on which the concentration risk exposure was measured and assessed.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementReference rdf:type rdf:Property ;
    rdfs:label 'Measurement Reference' ;
    rdfs:comment 'Business reference code for the concentration risk measurement, used for tracking and reporting purposes.' ;
    rdfs:domain ind:ConcentrationRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementStatus rdf:type rdf:Property ;
    rdfs:label 'Measurement Status' ;
    rdfs:comment 'Current lifecycle status of the concentration risk measurement record.' ;
    rdfs:domain ind:ConcentrationRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metricCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Metric Calculation Method' ;
    rdfs:comment 'Methodology or formula used to calculate the concentration metric (e.g., Herfindahl-Hirschman Index (HHI), percentage of total exposure, absolute exposure amount).' ;
    rdfs:domain ind:ConcentrationRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryThreshold rdf:type rdf:Property ;
    rdfs:label 'Regulatory Threshold' ;
    rdfs:comment 'Regulatory threshold or large exposure limit prescribed by banking supervisors (e.g., 25% of Tier 1 capital for single counterparty exposure under Basel large exposure framework).' ;
    rdfs:domain ind:ConcentrationRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remediationAction rdf:type rdf:Property ;
    rdfs:label 'Remediation Action' ;
    rdfs:comment 'Description of remediation actions planned or taken to reduce concentration exposure and bring it within approved thresholds.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdDirection rdf:type rdf:Property ;
    rdfs:label 'Threshold Direction' ;
    rdfs:comment 'Direction of threshold breach: \'above\' indicates risk when metric exceeds threshold, \'below\' indicates risk when metric falls below threshold.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tier1CapitalPercentage rdf:type rdf:Property ;
    rdfs:label 'Tier1 Capital Percentage' ;
    rdfs:comment 'Concentration exposure expressed as a percentage of the bank\'s Tier 1 capital, used for regulatory large exposure reporting.' ;
    rdfs:domain ind:ConcentrationRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warningThreshold rdf:type rdf:Property ;
    rdfs:label 'Warning Threshold' ;
    rdfs:comment 'Warning threshold value for the concentration metric. Breaching this level triggers management attention and monitoring escalation.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:analystOverrideFlag rdf:type rdf:Property ;
    rdfs:label 'Analyst Override Flag' ;
    rdfs:comment 'Indicates whether a credit analyst has manually overridden the model-generated rating. True = override applied. Overrides must be documented and approved per credit policy. Supports model performance monitoring and governance.' ;
    rdfs:domain ind:CounterpartyRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:defaultDate rdf:type rdf:Property ;
    rdfs:label 'Default Date' ;
    rdfs:comment 'The date on which the counterparty was classified as in default per the Basel III definition (CRR Article 178). Null if the counterparty has never defaulted. Used for LGD estimation and historical default analysis.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:defaultFlag rdf:type rdf:Property ;
    rdfs:label 'Default Flag' ;
    rdfs:comment 'Indicates whether the counterparty is currently in a state of default as defined under Basel III (CRR Article 178). True = counterparty is in default. Triggers NPL classification, ECL Stage 3, and regulatory reporting.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eclStage rdf:type rdf:Property ;
    rdfs:label 'Ecl Stage' ;
    rdfs:comment 'The IFRS 9 / CECL impairment stage assigned to this counterparty: Stage 1 (performing, 12-month ECL), Stage 2 (significant increase in credit risk, lifetime ECL), Stage 3 (credit-impaired, lifetime ECL). Drives provisioning and financial reporting.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fitchRating rdf:type rdf:Property ;
    rdfs:label 'Fitch Rating' ;
    rdfs:comment 'The most recent long-term issuer credit rating assigned by Fitch Ratings (e.g., AAA, A+, BBB-, BB). Used for external benchmark comparison, regulatory SA risk weight mapping, and credit underwriting.' ;
    rdfs:domain ind:CounterpartyRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moodysRating rdf:type rdf:Property ;
    rdfs:label 'Moodys Rating' ;
    rdfs:comment 'The most recent long-term issuer credit rating assigned by Moody\'s Investors Service (e.g., Aaa, Aa1, Baa2, Ba3). Used for external benchmark comparison, regulatory SA risk weight mapping, and credit underwriting.' ;
    rdfs:domain ind:CounterpartyRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideDirection rdf:type rdf:Property ;
    rdfs:label 'Override Direction' ;
    rdfs:comment 'Indicates whether the analyst override resulted in an upgrade or downgrade relative to the model-generated rating. Null if no override is in effect. Used for override tracking and model performance analysis.' ;
    rdfs:domain ind:CounterpartyRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorRatingCode rdf:type rdf:Property ;
    rdfs:label 'Prior Rating Code' ;
    rdfs:comment 'The internal rating grade code assigned to this counterparty immediately prior to the current rating. Enables rating migration analysis and transition matrix construction for credit risk modelling.' ;
    rdfs:domain ind:CounterpartyRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorRatingDate rdf:type rdf:Property ;
    rdfs:label 'Prior Rating Date' ;
    rdfs:comment 'The date on which the prior internal rating grade was assigned. Used in conjunction with prior_rating_code to construct rating migration history and transition matrices.' ;
    rdfs:domain ind:CounterpartyRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ratingApproach rdf:type rdf:Property ;
    rdfs:label 'Rating Approach' ;
    rdfs:comment 'Regulatory capital approach under which this rating is used: Internal Ratings-Based (IRB), Standardized Approach (SA), Foundation IRB (FIRB), or Advanced IRB (AIRB). Determines RWA calculation methodology.' ;
    rdfs:domain ind:CounterpartyRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingCode rdf:type rdf:Property ;
    rdfs:label 'Rating Code' ;
    rdfs:comment 'The internal credit rating grade code assigned to the counterparty under the bank\'s Internal Ratings-Based (IRB) model (e.g., 1A, 2B, CG3). Represents the bank\'s own assessment of creditworthiness.' ;
    rdfs:domain ind:CounterpartyRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingCommitteeApproval rdf:type rdf:Property ;
    rdfs:label 'Rating Committee Approval' ;
    rdfs:comment 'Indicates whether this rating was reviewed and approved by a formal credit rating committee (as opposed to individual analyst approval). True = committee-approved. Required for large or complex exposures per credit policy.' ;
    rdfs:domain ind:CounterpartyRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ratingDescription rdf:type rdf:Property ;
    rdfs:label 'Rating Description' ;
    rdfs:comment 'Human-readable description of the internal rating grade (e.g., \'Investment Grade — Strong\', \'Sub-Investment Grade — Speculative\'). Provides qualitative context for the rating code.' ;
    rdfs:domain ind:CounterpartyRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingModelVersion rdf:type rdf:Property ;
    rdfs:label 'Rating Model Version' ;
    rdfs:comment 'The version identifier of the rating model or scorecard used to produce this rating (e.g., \'v3.2\', \'2024.1\'). Supports model lifecycle management, backtesting, and SR 11-7 model inventory compliance.' ;
    rdfs:domain ind:CounterpartyRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingOutlook rdf:type rdf:Property ;
    rdfs:label 'Rating Outlook' ;
    rdfs:comment 'The rating outlook indicating the likely direction of the credit rating over the medium term (12–24 months). Applies to both internal and external ratings. Values: positive, stable, negative, developing.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingTriggerEvent rdf:type rdf:Property ;
    rdfs:label 'Rating Trigger Event' ;
    rdfs:comment 'The business event that triggered this rating action or review. [ENUM-REF-CANDIDATE: annual_review|financial_update|covenant_breach|market_event|acquisition|analyst_initiated|regulatory_requirement|credit_deterioration|other — promote to reference product]' ;
    rdfs:domain ind:CounterpartyRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rwaRiskWeight rdf:type rdf:Property ;
    rdfs:label 'Rwa Risk Weight' ;
    rdfs:comment 'The regulatory risk weight percentage assigned to this counterparty under the applicable Basel III approach (IRB or SA), expressed as a decimal (e.g., 0.75 = 75%). Directly drives Risk-Weighted Assets (RWA) calculation for capital adequacy.' ;
    rdfs:domain ind:CounterpartyRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spRating rdf:type rdf:Property ;
    rdfs:label 'Sp Rating' ;
    rdfs:comment 'The most recent long-term issuer credit rating assigned by S&P Global Ratings (e.g., AAA, AA+, BBB-, BB). Used for external benchmark comparison, regulatory SA risk weight mapping, and credit underwriting.' ;
    rdfs:domain ind:CounterpartyRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:watchStatus rdf:type rdf:Property ;
    rdfs:label 'Watch Status' ;
    rdfs:comment 'Indicates whether the counterparty\'s rating is currently on a rating watch list, and the direction of the potential rating action. \'none\' indicates no active watch. Signals near-term rating change risk.' ;
    rdfs:domain ind:CounterpartyRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repoPositionId rdf:type rdf:Property ;
    rdfs:label 'Repo Position Id' ;
    rdfs:comment 'Foreign key linking to treasury.repo_position. Business justification: Credit exposure calculations incorporate repo positions for counterparty credit risk measurement and CVA calculation under Basel III SA-CCR. Repo positions are collateralized exposures requiring speci' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RepoPosition .

ind:concentrationHhi rdf:type rdf:Property ;
    rdfs:label 'Concentration Hhi' ;
    rdfs:comment 'Herfindahl-Hirschman Index score measuring the degree of concentration of this exposure within its sector, geography, or single-name bucket. Used for concentration risk monitoring and regulatory large exposure limit compliance.' ;
    rdfs:domain ind:CreditExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:counterpartyType rdf:type rdf:Property ;
    rdfs:label 'Counterparty Type' ;
    rdfs:comment 'Classification of the counterparty for regulatory capital and large exposure reporting purposes. Determines applicable risk weight under SA and eligibility for IRB treatment. [ENUM-REF-CANDIDATE: corporate|financial_institution|sovereign|central_bank|retail|sme|fund — promote to reference product]' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cva rdf:type rdf:Property ;
    rdfs:label 'Cva' ;
    rdfs:comment 'Market value of counterparty credit risk embedded in OTC derivative positions, representing the expected loss due to counterparty default. Calculated under SA-CVA or BA-CVA regulatory framework. Impacts P&L and regulatory capital.' ;
    rdfs:domain ind:CreditExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cvaApproach rdf:type rdf:Property ;
    rdfs:label 'Cva Approach' ;
    rdfs:comment 'Regulatory methodology used to calculate the CVA capital charge: Standardised Approach for CVA (SA-CVA), Basic Approach for CVA (BA-CVA), or exempted (for transactions with non-financial counterparties below threshold).' ;
    rdfs:domain ind:CreditExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cvaCapitalCharge rdf:type rdf:Property ;
    rdfs:label 'Cva Capital Charge' ;
    rdfs:comment 'Regulatory capital requirement for CVA risk calculated under SA-CVA or BA-CVA methodology as prescribed by BCBS CRE51. Represents the RWA equivalent for counterparty credit valuation adjustment risk.' ;
    rdfs:domain ind:CreditExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dva rdf:type rdf:Property ;
    rdfs:label 'Dva' ;
    rdfs:comment 'Adjustment to derivative fair value reflecting the bank\'s own credit risk, representing the benefit to the bank from its own potential default. Reported under IFRS 13 but excluded from regulatory CVA capital charge.' ;
    rdfs:domain ind:CreditExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eclProvision rdf:type rdf:Property ;
    rdfs:label 'Ecl Provision' ;
    rdfs:comment 'Calculated expected credit loss provision amount for this exposure under IFRS 9 or CECL, representing the probability-weighted estimate of credit losses over the applicable horizon (12-month or lifetime). Feeds the allowance for loan and lease losses (ALLL).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:effectiveMaturityYears rdf:type rdf:Property ;
    rdfs:label 'Effective Maturity Years' ;
    rdfs:comment 'Effective maturity parameter (M) in years as defined under the IRB Advanced approach, capped at 5 years and floored at 1 year. Adjusts the IRB capital formula for longer-dated exposures via the maturity adjustment factor.' ;
    rdfs:domain ind:CreditExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedExposure rdf:type rdf:Property ;
    rdfs:label 'Expected Exposure' ;
    rdfs:comment 'Average exposure across all simulation paths at a future time horizon, used as the basis for CVA calculation and expected credit loss (ECL) provisioning under IFRS 9.' ;
    rdfs:domain ind:CreditExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exposureClass rdf:type rdf:Property ;
    rdfs:label 'Exposure Class' ;
    rdfs:comment 'Regulatory asset class of the exposure under Basel III/CRR2 framework, determining the applicable risk weight and capital treatment. [ENUM-REF-CANDIDATE: corporate|sovereign|institution|retail|equity|securitisation|other — promote to reference product]' ;
    rdfs:domain ind:CreditExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exposureReference rdf:type rdf:Property ;
    rdfs:label 'Exposure Reference' ;
    rdfs:comment 'Externally-known business reference number for this credit exposure record, as assigned by the risk management platform (SAS Risk Management / Moodys RiskAuthority) or trading system (Murex/Calypso). Used for reconciliation and regulatory reporting.' ;
    rdfs:domain ind:CreditExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exposureStatus rdf:type rdf:Property ;
    rdfs:label 'Exposure Status' ;
    rdfs:comment 'Current lifecycle status of the credit exposure. Drives provisioning, regulatory classification, and workout processes. [ENUM-REF-CANDIDATE: active|closed|defaulted|restructured|watch_list|written_off — promote to reference product if additional states required]' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fva rdf:type rdf:Property ;
    rdfs:label 'Fva' ;
    rdfs:comment 'Adjustment to derivative fair value reflecting the cost or benefit of funding uncollateralised derivative positions. Captures the funding spread between the bank\'s borrowing cost and the risk-free rate.' ;
    rdfs:domain ind:CreditExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:largeExposureFlag rdf:type rdf:Property ;
    rdfs:label 'Large Exposure Flag' ;
    rdfs:comment 'Indicates whether this exposure meets or exceeds the large exposure threshold (10% of eligible capital) requiring regulatory reporting under CRR2 Article 395. Triggers enhanced monitoring and reporting obligations.' ;
    rdfs:domain ind:CreditExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netExposure rdf:type rdf:Property ;
    rdfs:label 'Net Exposure' ;
    rdfs:comment 'Credit exposure after applying netting agreements and eligible collateral offsets (EAD minus collateral value). Represents the bank\'s actual economic risk position used for limit monitoring and large exposure reporting.' ;
    rdfs:domain ind:CreditExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pillar3DisclosureFlag rdf:type rdf:Property ;
    rdfs:label 'Pillar3 Disclosure Flag' ;
    rdfs:comment 'Indicates whether this exposure record is included in the bank\'s Pillar 3 public disclosure reporting under Basel III. Drives the regulatory reporting extract for AxiomSL/Wolters Kluwer OneSumX.' ;
    rdfs:domain ind:CreditExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryApproach rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approach' ;
    rdfs:comment 'Regulatory methodology applied to calculate risk-weighted assets (RWA) for this exposure: Standardised Approach (SA), Foundation Internal Ratings-Based (F-IRB), Advanced IRB (A-IRB), Standardised Approach for Counterparty Credit Risk (SA-CCR), or Internal Model Method (IMM).' ;
    rdfs:domain ind:CreditExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskWeight rdf:type rdf:Property ;
    rdfs:label 'Risk Weight' ;
    rdfs:comment 'Risk weight percentage applied to the exposure to derive credit RWA, expressed as a decimal (e.g., 1.00 = 100%). Determined by exposure class, counterparty rating, and regulatory approach (SA or IRB).' ;
    rdfs:domain ind:CreditExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rwaCredit rdf:type rdf:Property ;
    rdfs:label 'Rwa Credit' ;
    rdfs:comment 'Risk-weighted asset amount for credit risk calculated for this exposure under the applicable regulatory approach (SA or IRB). Primary input to CET1 capital ratio calculation and Pillar 3 disclosure.' ;
    rdfs:domain ind:CreditExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:irbDeveloperEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Irb Developer Employee Id' ;
    rdfs:comment 'Identifier of the team or individual who developed the IRB model. Supports model governance documentation, audit trail, and SR 11-7 accountability requirements.' ;
    rdfs:domain ind:IrbModel ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryIrbEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Irb Employee Id' ;
    rdfs:comment 'Identifier of the business unit or individual designated as the model owner responsible for model performance, ongoing monitoring, and remediation of findings. Aligns with SR 11-7 model ownership accountability requirements.' ;
    rdfs:domain ind:IrbModel ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:aucRoc rdf:type rdf:Property ;
    rdfs:label 'Auc Roc' ;
    rdfs:comment 'Area Under the Receiver Operating Characteristic Curve (AUC-ROC) measuring the model\'s discriminatory power. Ranges from 0.5 (random) to 1.0 (perfect). Complementary to the Gini coefficient (AUC = (Gini + 1) / 2). Reported in model validation and performance monitoring.' ;
    rdfs:domain ind:IrbModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:backtestingDate rdf:type rdf:Property ;
    rdfs:label 'Backtesting Date' ;
    rdfs:comment 'Date on which the most recent backtesting exercise was completed for this IRB model. Backtesting compares predicted PD/LGD/EAD estimates against realised outcomes over the monitoring period.' ;
    rdfs:domain ind:IrbModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:backtestingResult rdf:type rdf:Property ;
    rdfs:label 'Backtesting Result' ;
    rdfs:comment 'Red-Amber-Green (RAG) status from the most recent backtesting exercise comparing model-predicted default rates against observed default rates. Green: within tolerance; Amber: minor deviation requiring monitoring; Red: material deviation requiring recalibration or override. Reported to ALCO and model risk committee.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brierScore rdf:type rdf:Property ;
    rdfs:label 'Brier Score' ;
    rdfs:comment 'Brier score measuring the mean squared error between predicted PD estimates and observed default outcomes. Lower values indicate better calibration accuracy. Used in model validation to assess PD calibration quality alongside the Hosmer-Lemeshow test.' ;
    rdfs:domain ind:IrbModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:defaultDefinition rdf:type rdf:Property ;
    rdfs:label 'Default Definition' ;
    rdfs:comment 'Description of the default definition applied in the IRB model, specifying the criteria used to classify an obligor or facility as defaulted (e.g., 90 days past due, unlikeliness to pay, distressed restructuring). Must align with Basel III Article 178 and internal credit policy.' ;
    rdfs:domain ind:IrbModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downturnLgd rdf:type rdf:Property ;
    rdfs:label 'Downturn Lgd' ;
    rdfs:comment 'Downturn LGD estimate (expressed as a decimal, e.g., 0.45 = 45%) reflecting loss rates observed during periods of economic stress or downturn, as required by Basel III for regulatory capital calculation. Applicable to LGD model types only.' ;
    rdfs:domain ind:IrbModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eadCcfEstimate rdf:type rdf:Property ;
    rdfs:label 'Ead Ccf Estimate' ;
    rdfs:comment 'Credit Conversion Factor (CCF) estimate (expressed as a decimal, e.g., 0.75 = 75%) used to convert off-balance-sheet commitments to credit equivalent EAD amounts. Applicable to EAD/CCF model types. Used in RWA and ECL calculation.' ;
    rdfs:domain ind:IrbModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:giniCoefficient rdf:type rdf:Property ;
    rdfs:label 'Gini Coefficient' ;
    rdfs:comment 'Gini coefficient (also known as Accuracy Ratio) measuring the discriminatory power of the IRB model — its ability to rank-order defaulters from non-defaulters. Ranges from 0 (no discrimination) to 1 (perfect discrimination). Key model performance metric reported in validation reports and regulatory submissions.' ;
    rdfs:domain ind:IrbModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lgdInDefault rdf:type rdf:Property ;
    rdfs:label 'Lgd In Default' ;
    rdfs:comment 'Best estimate of LGD for exposures currently in default, used for IFRS 9 ECL Stage 3 provisioning and workout LGD calculations. Distinct from the regulatory downturn LGD used for RWA. Applicable to LGD model types.' ;
    rdfs:domain ind:IrbModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:longRunAveragePd rdf:type rdf:Property ;
    rdfs:label 'Long Run Average Pd' ;
    rdfs:comment 'Long-run average PD (expressed as a decimal, e.g., 0.0025 = 0.25%) estimated for the model\'s portfolio segment, representing the through-the-cycle central tendency. Used as the calibration anchor for Basel III regulatory capital. Applicable to PD model types only.' ;
    rdfs:domain ind:IrbModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:macroeconomicScenario rdf:type rdf:Property ;
    rdfs:label 'Macroeconomic Scenario' ;
    rdfs:comment 'Name or identifier of the macroeconomic scenario used to condition PIT PD estimates (e.g., \'Base Case 2024Q4\', \'Adverse Scenario DFAST 2024\', \'Severely Adverse\'). Relevant for IFRS 9 ECL multiple scenario weighting and CCAR/DFAST stress testing.' ;
    rdfs:domain ind:IrbModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelApproach rdf:type rdf:Property ;
    rdfs:label 'Model Approach' ;
    rdfs:comment 'Indicates whether the model operates under the Foundation Internal Ratings-Based (F-IRB) approach, where only PD is internally estimated and LGD/EAD use supervisory values, or the Advanced IRB (A-IRB) approach, where PD, LGD, and EAD are all internally estimated.' ;
    rdfs:domain ind:IrbModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelMethodology rdf:type rdf:Property ;
    rdfs:label 'Model Methodology' ;
    rdfs:comment 'Description of the statistical or econometric methodology used to develop the IRB model (e.g., logistic regression, survival analysis, machine learning gradient boosting, scorecard). Supports model governance documentation and SR 11-7 compliance.' ;
    rdfs:domain ind:IrbModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelRiskRating rdf:type rdf:Property ;
    rdfs:label 'Model Risk Rating' ;
    rdfs:comment 'Internal model risk rating assigned by the model risk management function reflecting the materiality and complexity of the model and the quality of its validation. Drives oversight intensity, validation frequency, and escalation thresholds under SR 11-7.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelStatus rdf:type rdf:Property ;
    rdfs:label 'Model Status' ;
    rdfs:comment 'Current lifecycle state of the IRB model within the model governance framework: Active (in production use for RWA/ECL), Under-Review (undergoing validation or recalibration), Deprecated (retired from use), Pending-Approval (awaiting regulatory or internal sign-off), Rejected (failed validation or regulatory review).' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextValidationDate rdf:type rdf:Property ;
    rdfs:label 'Next Validation Date' ;
    rdfs:comment 'Date by which the next independent model validation must be completed per the model governance calendar. Supports proactive scheduling of validation resources and regulatory compliance tracking.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:numberOfRatingGrades rdf:type rdf:Property ;
    rdfs:label 'Number Of Rating Grades' ;
    rdfs:comment 'Total number of distinct non-default rating grades in the model\'s rating scale. Basel III requires a minimum of 7 non-default grades for corporate/bank/sovereign exposures. Used in model governance and regulatory review.' ;
    rdfs:domain ind:IrbModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overrideCount rdf:type rdf:Property ;
    rdfs:label 'Override Count' ;
    rdfs:comment 'Number of times model outputs have been overridden by credit officers or risk managers since the model\'s last validation cycle. High override rates may indicate model weakness and trigger recalibration. Monitored under SR 11-7 model performance tracking.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overrideRate rdf:type rdf:Property ;
    rdfs:label 'Override Rate' ;
    rdfs:comment 'Proportion of model outputs overridden (expressed as a decimal, e.g., 0.05 = 5%) during the current monitoring period. Calculated as override_count divided by total model applications. Threshold breaches trigger escalation to model risk committee.' ;
    rdfs:domain ind:IrbModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pdEstimationApproach rdf:type rdf:Property ;
    rdfs:label 'Pd Estimation Approach' ;
    rdfs:comment 'Indicates whether the PD model produces Point-in-Time (PIT) estimates reflecting current economic conditions, Through-the-Cycle (TTC) estimates reflecting long-run average conditions, or a Hybrid blend. Applicable only to PD model types. PIT is required for IFRS 9 ECL; TTC is used for Basel III regulatory capital.' ;
    rdfs:domain ind:IrbModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pdFloor rdf:type rdf:Property ;
    rdfs:label 'Pd Floor' ;
    rdfs:comment 'Minimum PD floor applied to the model\'s estimates as required by Basel III (e.g., 0.0003 = 0.03% for corporate exposures). Ensures that regulatory capital is not understated by overly optimistic PD estimates. Applicable to PD model types.' ;
    rdfs:domain ind:IrbModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ratingScaleType rdf:type rdf:Property ;
    rdfs:label 'Rating Scale Type' ;
    rdfs:comment 'Type of rating scale used by the IRB model to assign obligor or facility grades (e.g., Numeric 1–10, Alphanumeric AAA–D, Letter-Grade A–G). Determines how model outputs are mapped to PD/LGD/EAD estimates and reported in regulatory submissions.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemModelCode rdf:type rdf:Property ;
    rdfs:label 'Source System Model Code' ;
    rdfs:comment 'Native model identifier as recorded in the source risk management platform (e.g., SAS Risk Management or Moody\'s RiskAuthority model registry). Enables lineage tracing from the lakehouse silver layer back to the operational system of record.' ;
    rdfs:domain ind:IrbModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:useInEclCalculation rdf:type rdf:Property ;
    rdfs:label 'Use In Ecl Calculation' ;
    rdfs:comment 'Indicates whether this IRB model is currently used in the calculation of Expected Credit Loss (ECL) for IFRS 9 or CECL provisioning. True = in active ECL use; False = not currently used for provisioning.' ;
    rdfs:domain ind:IrbModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:useInRwaCalculation rdf:type rdf:Property ;
    rdfs:label 'Use In Rwa Calculation' ;
    rdfs:comment 'Indicates whether this IRB model is currently approved and actively used in the calculation of regulatory Risk-Weighted Assets (RWA) for capital adequacy reporting under Basel III. True = in active RWA use; False = not currently used for regulatory capital.' ;
    rdfs:domain ind:IrbModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:validationOutcome rdf:type rdf:Property ;
    rdfs:label 'Validation Outcome' ;
    rdfs:comment 'Outcome of the most recent independent model validation: Pass (model fit for purpose), Pass-with-Conditions (minor findings requiring remediation), Fail (material deficiencies identified), or In-Progress (validation underway). Drives model risk rating and remediation planning.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kriMeasurementId rdf:type rdf:Property ;
    rdfs:label 'Kri Measurement Id' ;
    rdfs:comment 'Unique surrogate identifier for each KRI measurement record in the enterprise risk monitoring registry. Primary key for the kri_measurement data product.' ;
    rdfs:domain ind:KriMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:amberThreshold rdf:type rdf:Property ;
    rdfs:label 'Amber Threshold' ;
    rdfs:comment 'The boundary defining the warning (amber) zone for the KRI. Values breaching this threshold trigger heightened monitoring and management attention but do not yet require board-level escalation. Derived from the risk appetite framework.' ;
    rdfs:domain ind:KriMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataQualityFlag rdf:type rdf:Property ;
    rdfs:label 'Data Quality Flag' ;
    rdfs:comment 'Categorical data quality assessment for this KRI measurement record. \'passed\' indicates data meets quality standards, \'warning\' indicates minor data issues that do not invalidate the measurement, \'failed\' indicates the measurement should not be used, \'under_review\' indicates quality assessment is pending.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationAuthority rdf:type rdf:Property ;
    rdfs:label 'Escalation Authority' ;
    rdfs:comment 'The governance body or individual to whom the KRI breach has been escalated (e.g., \'ALCO\', \'Board Risk Committee\', \'CRO\', \'Risk Management Committee\'). Defines the escalation path for each breach severity level.' ;
    rdfs:domain ind:KriMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:greenThreshold rdf:type rdf:Property ;
    rdfs:label 'Green Threshold' ;
    rdfs:comment 'The upper or lower boundary defining the acceptable (green) zone for the KRI. Values within this threshold indicate normal operating conditions and no escalation is required. Derived from the risk appetite framework.' ;
    rdfs:domain ind:KriMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isBoardReported rdf:type rdf:Property ;
    rdfs:label 'Is Board Reported' ;
    rdfs:comment 'Indicates whether this KRI is included in board risk committee reporting packs (True) or is management-level only (False). Board-reported KRIs require higher data quality standards and formal sign-off per governance policy.' ;
    rdfs:domain ind:KriMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRegulatoryKri rdf:type rdf:Property ;
    rdfs:label 'Is Regulatory Kri' ;
    rdfs:comment 'Indicates whether this KRI is mandated by a regulatory body (True) or is an internally-defined management KRI (False). Regulatory KRIs (e.g., LCR, CET1, NSFR) require formal regulatory reporting and have prescribed minimum thresholds.' ;
    rdfs:domain ind:KriMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kriCode rdf:type rdf:Property ;
    rdfs:label 'Kri Code' ;
    rdfs:comment 'Unique business identifier for the KRI definition in the enterprise KRI taxonomy. Follows the format KRI-<CATEGORY>-<SEQUENCE> (e.g., KRI-CREDIT-0001). Links the measurement to the KRI master registry entry.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kriName rdf:type rdf:Property ;
    rdfs:label 'Kri Name' ;
    rdfs:comment 'Human-readable name of the KRI being measured (e.g., \'Non-Performing Loan Ratio\', \'Liquidity Coverage Ratio\', \'Value at Risk Utilisation\'). Sourced from the KRI master registry.' ;
    rdfs:domain ind:KriMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kriOwnerName rdf:type rdf:Property ;
    rdfs:label 'Kri Owner Name' ;
    rdfs:comment 'Full name of the individual accountable for the KRI measurement, remediation, and escalation. Typically a senior risk officer or business unit head. Classified confidential as it identifies internal accountability assignments.' ;
    rdfs:domain ind:KriMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kriOwnerRole rdf:type rdf:Property ;
    rdfs:label 'Kri Owner Role' ;
    rdfs:comment 'The job title or role designation of the KRI owner (e.g., \'Chief Risk Officer\', \'Head of Credit Risk\', \'Treasury Risk Manager\'). Supports role-based escalation routing and governance reporting.' ;
    rdfs:domain ind:KriMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalEntity rdf:type rdf:Property ;
    rdfs:label 'Legal Entity' ;
    rdfs:comment 'The legal entity or subsidiary to which this KRI measurement applies. Supports legal-entity-level risk aggregation required for CCAR, DFAST, and regulatory reporting submissions (e.g., \'Banking Corp USA\', \'Banking Corp UK Branch\').' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Measurement Period End' ;
    rdfs:comment 'The end date of the measurement period over which the KRI value was calculated. For point-in-time KRIs this equals measurement_date; for flow-based KRIs this defines the close of the accumulation window.' ;
    rdfs:domain ind:KriMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Measurement Period Start' ;
    rdfs:comment 'The start date of the measurement period over which the KRI value was calculated. For point-in-time KRIs this equals measurement_date; for flow-based KRIs (e.g., monthly loss events) this defines the beginning of the accumulation window.' ;
    rdfs:domain ind:KriMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:owningBusinessUnit rdf:type rdf:Property ;
    rdfs:label 'Owning Business Unit' ;
    rdfs:comment 'The line of business (LOB) or organisational unit responsible for managing and remediating this KRI (e.g., \'Commercial Lending\', \'Treasury\', \'Retail Banking\', \'Trading\'). Used for accountability assignment in GRC reporting and board risk committee packs.' ;
    rdfs:domain ind:KriMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorPeriodValue rdf:type rdf:Property ;
    rdfs:label 'Prior Period Value' ;
    rdfs:comment 'The KRI actual value from the immediately preceding measurement period. Stored on the record to support period-over-period variance analysis and trend computation without requiring a self-join. Expressed in the same unit_of_measure as actual_value.' ;
    rdfs:domain ind:KriMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:redThreshold rdf:type rdf:Property ;
    rdfs:label 'Red Threshold' ;
    rdfs:comment 'The boundary defining the breach (red) zone for the KRI. Values exceeding this threshold indicate a material risk limit breach requiring immediate escalation to senior management or the board risk committee.' ;
    rdfs:domain ind:KriMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:riskSubCategory rdf:type rdf:Property ;
    rdfs:label 'Risk Sub Category' ;
    rdfs:comment 'Granular risk sub-classification within the risk category (e.g., \'counterparty credit risk\', \'interest rate risk in the banking book\', \'settlement risk\', \'conduct risk\'). Supports drill-down analysis in GRC reporting.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stressScenarioFlag rdf:type rdf:Property ;
    rdfs:label 'Stress Scenario Flag' ;
    rdfs:comment 'Indicates whether this measurement record represents a stress scenario value (True) rather than a base-case actual measurement (False). Stress scenario KRI readings are used in CCAR, DFAST, and ICAAP submissions.' ;
    rdfs:domain ind:KriMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stressScenarioName rdf:type rdf:Property ;
    rdfs:label 'Stress Scenario Name' ;
    rdfs:comment 'Name of the stress scenario applied when stress_scenario_flag is True (e.g., \'Fed Severely Adverse\', \'Fed Adverse\', \'Internal Baseline\', \'COVID-19 Stress\'). Null for base-case actual measurements.' ;
    rdfs:domain ind:KriMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liquidityMetricId rdf:type rdf:Property ;
    rdfs:label 'Liquidity Metric Id' ;
    rdfs:comment 'Unique surrogate identifier for each daily liquidity risk measurement record. Primary key for the liquidity_metric data product in the risk domain.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LiquidityMetric .

ind:reportingUnitLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Reporting Unit Legal Entity Id' ;
    rdfs:comment 'Reference to the internal reporting unit or business line (e.g., retail banking, treasury, trading) for which the liquidity metric is computed. Supports ALCO sub-entity reporting.' ;
    rdfs:domain ind:LiquidityMetric ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:availableStableFundingAmount rdf:type rdf:Property ;
    rdfs:label 'Available Stable Funding Amount' ;
    rdfs:comment 'Total Available Stable Funding (ASF) representing the portion of capital and liabilities expected to be reliable over a one-year horizon. Numerator of the NSFR ratio.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calculationRunTimestamp rdf:type rdf:Property ;
    rdfs:label 'Calculation Run Timestamp' ;
    rdfs:comment 'The date and time when the liquidity metric calculation was executed in the risk management platform. Supports audit trail, reprocessing identification, and T+1 regulatory submission deadlines.' ;
    rdfs:domain ind:LiquidityMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:calculationStatus rdf:type rdf:Property ;
    rdfs:label 'Calculation Status' ;
    rdfs:comment 'Current workflow status of the liquidity metric record indicating whether the calculation is preliminary, final, restated, under review, or approved for regulatory submission.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:centralBankEligibleAmount rdf:type rdf:Property ;
    rdfs:label 'Central Bank Eligible Amount' ;
    rdfs:comment 'Total value of assets eligible for central bank repo or discount window operations (e.g., Fed discount window, Bank of England repo). Represents the ultimate liquidity backstop available to the institution.' ;
    rdfs:domain ind:LiquidityMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:committedFacilityOutflowAmount rdf:type rdf:Property ;
    rdfs:label 'Committed Facility Outflow Amount' ;
    rdfs:comment 'Expected cash outflows from drawdowns on committed credit and liquidity facilities extended to customers and counterparties over the 30-day LCR stress horizon. Includes undrawn revolving credit facilities.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consolidationScope rdf:type rdf:Property ;
    rdfs:label 'Consolidation Scope' ;
    rdfs:comment 'Indicates whether the liquidity metric is calculated on a solo (single legal entity), consolidated (group-wide), or sub-consolidated basis. Determines the perimeter of assets and liabilities included in LCR/NSFR calculations.' ;
    rdfs:domain ind:LiquidityMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:encumberedAssetsAmount rdf:type rdf:Property ;
    rdfs:label 'Encumbered Assets Amount' ;
    rdfs:comment 'Total value of assets pledged as collateral or otherwise encumbered (e.g., repo, covered bonds, central bank pledges) and therefore excluded from the HQLA buffer. Critical for accurate HQLA calculation.' ;
    rdfs:domain ind:LiquidityMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossCashInflowAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Cash Inflow Amount' ;
    rdfs:comment 'Total expected gross cash inflows over the 30-day LCR stress horizon, capped at 75% of gross outflows per Basel III rules. Includes contractual loan repayments and securities maturities.' ;
    rdfs:domain ind:LiquidityMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossCashOutflowAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Cash Outflow Amount' ;
    rdfs:comment 'Total expected gross cash outflows over the 30-day LCR stress horizon before netting of inflows. Includes retail deposit runoff, wholesale funding outflows, and off-balance-sheet commitments.' ;
    rdfs:domain ind:LiquidityMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hqlaAmount rdf:type rdf:Property ;
    rdfs:label 'Hqla Amount' ;
    rdfs:comment 'Total stock of High Quality Liquid Assets (HQLA) after applicable haircuts, expressed in the reporting currency. Comprises Level 1, Level 2A, and Level 2B assets as defined under the Basel III LCR framework.' ;
    rdfs:domain ind:LiquidityMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hqlaLevel1Amount rdf:type rdf:Property ;
    rdfs:label 'Hqla Level1 Amount' ;
    rdfs:comment 'Stock of Level 1 HQLA assets (e.g., central bank reserves, sovereign bonds with 0% risk weight) with no haircut applied. Highest quality component of the HQLA buffer.' ;
    rdfs:domain ind:LiquidityMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hqlaLevel2aAmount rdf:type rdf:Property ;
    rdfs:label 'Hqla Level2a Amount' ;
    rdfs:comment 'Stock of Level 2A HQLA assets (e.g., agency MBS, covered bonds, sovereign bonds with 20% risk weight) subject to a 15% haircut. Capped at 40% of total HQLA.' ;
    rdfs:domain ind:LiquidityMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hqlaLevel2bAmount rdf:type rdf:Property ;
    rdfs:label 'Hqla Level2b Amount' ;
    rdfs:comment 'Stock of Level 2B HQLA assets (e.g., non-agency RMBS, corporate bonds, equities) subject to haircuts of 25–50%. Capped at 15% of total HQLA.' ;
    rdfs:domain ind:LiquidityMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:intradayAvailableLiquidityAmount rdf:type rdf:Property ;
    rdfs:label 'Intraday Available Liquidity Amount' ;
    rdfs:comment 'Total liquidity resources available intraday at the start of the business day, including central bank reserves, committed intraday credit facilities, and unencumbered liquid assets accessible within the day.' ;
    rdfs:domain ind:LiquidityMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:intradayPeakLiquidityAmount rdf:type rdf:Property ;
    rdfs:label 'Intraday Peak Liquidity Amount' ;
    rdfs:comment 'Maximum intraday liquidity requirement observed during the reporting day, representing the peak net cumulative position across all payment systems (RTGS, ACH, SWIFT). Supports intraday liquidity monitoring per BCBS monitoring tools.' ;
    rdfs:domain ind:LiquidityMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isBreach rdf:type rdf:Property ;
    rdfs:label 'Is Breach' ;
    rdfs:comment 'Flag indicating whether the liquidity metric breaches the applicable regulatory minimum threshold (LCR < 100% or NSFR < 100%). Triggers escalation to ALCO and regulatory notification procedures.' ;
    rdfs:domain ind:LiquidityMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lcrBufferAmount rdf:type rdf:Property ;
    rdfs:label 'Lcr Buffer Amount' ;
    rdfs:comment 'Excess HQLA above the regulatory minimum LCR requirement, representing the institution\'s liquidity cushion. Calculated as HQLA minus (net cash outflows × regulatory minimum LCR). Used in ALCO reporting and internal liquidity stress testing.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lcrRatio rdf:type rdf:Property ;
    rdfs:label 'Lcr Ratio' ;
    rdfs:comment 'The Liquidity Coverage Ratio expressed as a decimal (e.g., 1.25 = 125%). Calculated as HQLA divided by total net cash outflows over a 30-day stress period. Regulatory minimum is 100% (1.00) under Basel III / Fed LCR Rule.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lcrRegulatoryMinimum rdf:type rdf:Property ;
    rdfs:label 'Lcr Regulatory Minimum' ;
    rdfs:comment 'The applicable regulatory minimum LCR threshold for this entity as of the metric date (e.g., 1.00 for 100%). May vary by jurisdiction (Fed, OCC, PRA) and entity classification (GSIB, non-GSIB).' ;
    rdfs:domain ind:LiquidityMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:liquidityTransferRestriction rdf:type rdf:Property ;
    rdfs:label 'Liquidity Transfer Restriction' ;
    rdfs:comment 'Indicates whether there are legal, regulatory, or operational restrictions on the transfer of liquidity between entities within the group (e.g., ring-fencing, local regulatory requirements). Affects consolidated vs. solo LCR/NSFR calculations.' ;
    rdfs:domain ind:LiquidityMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metricDate rdf:type rdf:Property ;
    rdfs:label 'Metric Date' ;
    rdfs:comment 'The business date (as-of date) for which the liquidity metrics are calculated. Represents the daily snapshot date used for LCR, NSFR, and intraday liquidity reporting.' ;
    rdfs:domain ind:LiquidityMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:metricType rdf:type rdf:Property ;
    rdfs:label 'Metric Type' ;
    rdfs:comment 'Classification of the liquidity metric record indicating which regulatory or internal liquidity measure is captured. Values: LCR (Liquidity Coverage Ratio), NSFR (Net Stable Funding Ratio), INTRADAY (intraday liquidity position), SURVIVAL_HORIZON, STRESS (internal stress test metric).' ;
    rdfs:domain ind:LiquidityMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netCashOutflowAmount rdf:type rdf:Property ;
    rdfs:label 'Net Cash Outflow Amount' ;
    rdfs:comment 'Total net cash outflows over the 30-calendar-day stress period, calculated as total expected cash outflows minus the minimum of total expected cash inflows and 75% of total expected cash outflows. Denominator of the LCR ratio.' ;
    rdfs:domain ind:LiquidityMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nsfrRatio rdf:type rdf:Property ;
    rdfs:label 'Nsfr Ratio' ;
    rdfs:comment 'The Net Stable Funding Ratio expressed as a decimal (e.g., 1.10 = 110%). Calculated as Available Stable Funding (ASF) divided by Required Stable Funding (RSF). Regulatory minimum is 100% (1.00) under Basel III.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nsfrRegulatoryMinimum rdf:type rdf:Property ;
    rdfs:label 'Nsfr Regulatory Minimum' ;
    rdfs:comment 'The applicable regulatory minimum NSFR threshold for this entity as of the metric date (e.g., 1.00 for 100%). Supports compliance monitoring against Fed/OCC/EBA NSFR rules.' ;
    rdfs:domain ind:LiquidityMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requiredStableFundingAmount rdf:type rdf:Property ;
    rdfs:label 'Required Stable Funding Amount' ;
    rdfs:comment 'Total Required Stable Funding (RSF) representing the amount of stable funding required to support assets and off-balance-sheet exposures over a one-year horizon. Denominator of the NSFR ratio.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retailDepositOutflowAmount rdf:type rdf:Property ;
    rdfs:label 'Retail Deposit Outflow Amount' ;
    rdfs:comment 'Expected cash outflows from retail deposits (stable and less stable) over the 30-day LCR stress horizon, applying Basel III run-off rates (3–10% for stable, 10–15% for less stable deposits).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:survivalHorizonDays rdf:type rdf:Property ;
    rdfs:label 'Survival Horizon Days' ;
    rdfs:comment 'The number of calendar days the institution can survive under a combined idiosyncratic and market-wide stress scenario without accessing wholesale funding markets. Key internal liquidity risk metric reported to ALCO.' ;
    rdfs:domain ind:LiquidityMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unencumberedAssetsAmount rdf:type rdf:Property ;
    rdfs:label 'Unencumbered Assets Amount' ;
    rdfs:comment 'Total value of assets that are free from legal, regulatory, or contractual restrictions and available to be monetized or pledged as collateral. Supports HQLA eligibility assessment.' ;
    rdfs:domain ind:LiquidityMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wholesaleFundingOutflowAmount rdf:type rdf:Property ;
    rdfs:label 'Wholesale Funding Outflow Amount' ;
    rdfs:comment 'Expected cash outflows from wholesale funding sources (e.g., interbank deposits, commercial paper, repo) over the 30-day LCR stress horizon. Key component of gross cash outflow calculation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valuationModelId rdf:type rdf:Property ;
    rdfs:label 'Valuation Model Id' ;
    rdfs:comment 'Foreign key linking to risk.valuation_model. Business justification: Market risk positions require valuation models to calculate mark-to-market (MTM) values. The market_risk_position table has mtm_value, which is produced by applying a valuation model to the instrument' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ValuationModel .

ind:bookType rdf:type rdf:Property ;
    rdfs:label 'Book Type' ;
    rdfs:comment 'Regulatory classification of the position as either trading book (subject to market risk capital under FRTB) or banking book (subject to IRRBB framework). Determines applicable capital treatment and risk measurement methodology.' ;
    rdfs:domain ind:MarketRiskPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cs01 rdf:type rdf:Property ;
    rdfs:label 'Cs01' ;
    rdfs:comment 'Credit Spread sensitivity — the change in MTM value for a 1 basis point widening in the credit spread of the underlying issuer or reference entity. Key measure for credit risk management and FRTB CSR (Credit Spread Risk) capital charge.' ;
    rdfs:domain ind:MarketRiskPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cvaCharge rdf:type rdf:Property ;
    rdfs:label 'Cva Charge' ;
    rdfs:comment 'Credit Valuation Adjustment representing the market value of counterparty default risk embedded in OTC derivative positions. Reflects the expected loss due to counterparty credit deterioration or default. Required under Basel III CVA framework.' ;
    rdfs:domain ind:MarketRiskPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:delta rdf:type rdf:Property ;
    rdfs:label 'Delta' ;
    rdfs:comment 'First-order sensitivity of the position\'s MTM value to a unit change in the underlying risk factor price (e.g., equity price, FX spot rate, commodity price). Used for delta hedging and FRTB SA delta risk charge calculation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dv01 rdf:type rdf:Property ;
    rdfs:label 'Dv01' ;
    rdfs:comment 'Dollar Value of a 01 (one basis point) shift in interest rates — the change in MTM value for a 1 basis point (0.01%) parallel upward shift in the yield curve. Primary interest rate sensitivity measure used for hedging and risk limit monitoring.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eveSensitivity rdf:type rdf:Property ;
    rdfs:label 'Eve Sensitivity' ;
    rdfs:comment 'Sensitivity of the Economic Value of Equity to standardised interest rate shock scenarios under IRRBB. Measures the long-term impact of rate changes on the present value of banking book assets and liabilities. Used in IRRBB supervisory outlier test.' ;
    rdfs:domain ind:MarketRiskPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedShortfall rdf:type rdf:Property ;
    rdfs:label 'Expected Shortfall' ;
    rdfs:comment 'Expected Shortfall (Conditional VaR) at 97.5% confidence level as required under FRTB IMA. Measures the average loss in the worst 2.5% of scenarios, replacing VaR as the primary IMA risk measure under FRTB.' ;
    rdfs:domain ind:MarketRiskPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:frtbApproach rdf:type rdf:Property ;
    rdfs:label 'Frtb Approach' ;
    rdfs:comment 'Indicates whether the FRTB capital charge for this position is computed under the Internal Models Approach (IMA), Standardised Approach (SA), or IMA with SA fallback for non-modellable risk factors (NMRFs).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frtbCapitalCharge rdf:type rdf:Property ;
    rdfs:label 'Frtb Capital Charge' ;
    rdfs:comment 'Total FRTB market risk capital charge for this position, representing the higher of the IMA (Internal Models Approach) or SA (Standardised Approach) capital requirement as applicable. Reported to regulators under FRTB framework.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gamma rdf:type rdf:Property ;
    rdfs:label 'Gamma' ;
    rdfs:comment 'Second-order (curvature) sensitivity of the position\'s MTM value to changes in the underlying risk factor. Captures non-linear risk for options and structured products. Used in FRTB SA curvature risk charge calculation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hedgeDesignation rdf:type rdf:Property ;
    rdfs:label 'Hedge Designation' ;
    rdfs:comment 'Accounting hedge designation for the position under IFRS 9 or ASC 815. Determines whether hedge accounting is applied and the treatment of fair value changes in OCI vs P&L. Relevant for banking book hedges of interest rate and FX risk.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hypotheticalPnl rdf:type rdf:Property ;
    rdfs:label 'Hypothetical Pnl' ;
    rdfs:comment 'Hypothetical P&L computed by revaluing the prior day\'s portfolio using current day\'s market prices, holding positions constant. Used in VaR backtesting and FRTB IMA P&L attribution test to validate risk model accuracy.' ;
    rdfs:domain ind:MarketRiskPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ircCharge rdf:type rdf:Property ;
    rdfs:label 'Irc Charge' ;
    rdfs:comment 'Incremental Risk Charge capturing default and migration risk for credit-sensitive positions in the trading book over a one-year capital horizon at 99.9% confidence. Applicable to non-securitisation credit positions under Basel 2.5.' ;
    rdfs:domain ind:MarketRiskPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isModellableRiskFactor rdf:type rdf:Property ;
    rdfs:label 'Is Modellable Risk Factor' ;
    rdfs:comment 'Indicates whether the primary risk factor for this position passes the FRTB Risk Factor Eligibility Test (RFET) and is classified as modellable. Non-modellable risk factors (NMRFs) attract a separate stress scenario capital add-on under FRTB IMA.' ;
    rdfs:domain ind:MarketRiskPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mtmValue rdf:type rdf:Property ;
    rdfs:label 'Mtm Value' ;
    rdfs:comment 'Current mark-to-market fair value of the position in the reporting currency as of the position date. Represents the present value of future cash flows discounted at current market rates. Core input for P&L attribution and capital calculations.' ;
    rdfs:domain ind:MarketRiskPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:niiSensitivity rdf:type rdf:Property ;
    rdfs:label 'Nii Sensitivity' ;
    rdfs:comment 'Sensitivity of Net Interest Income to a standardised interest rate shock scenario (e.g., +200bps parallel shift). Applicable to banking book positions under IRRBB framework. Measures short-term earnings impact of rate changes.' ;
    rdfs:domain ind:MarketRiskPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:notionalAmount rdf:type rdf:Property ;
    rdfs:label 'Notional Amount' ;
    rdfs:comment 'The face value or contractual notional amount of the position in the instrument\'s native currency. For derivatives, this is the reference principal used to compute cash flows and risk sensitivities.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pnlDaily rdf:type rdf:Property ;
    rdfs:label 'Pnl Daily' ;
    rdfs:comment 'Daily P&L for the position representing the change in MTM value from the prior business day. Used for P&L attribution analysis, backtesting of VaR models, and FRTB IMA P&L attribution test (PLAT) compliance.' ;
    rdfs:domain ind:MarketRiskPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:positionReference rdf:type rdf:Property ;
    rdfs:label 'Position Reference' ;
    rdfs:comment 'Externally-known business identifier for the risk position as assigned by the source trading or risk system (e.g., Murex position ID or Calypso deal reference). Used for reconciliation with the system of record.' ;
    rdfs:domain ind:MarketRiskPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repricingBucket rdf:type rdf:Property ;
    rdfs:label 'Repricing Bucket' ;
    rdfs:comment 'Time bucket classification for the repricing gap analysis (e.g., overnight, 1M, 3M, 6M, 1Y, 2Y, 5Y, 10Y+). Indicates when the position\'s interest rate resets or matures, driving IRRBB gap analysis and NII sensitivity computation. [ENUM-REF-CANDIDATE: overnight|1M|3M|6M|1Y|2Y|5Y|10Y_plus — promote to reference product]' ;
    rdfs:domain ind:MarketRiskPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repricingGap rdf:type rdf:Property ;
    rdfs:label 'Repricing Gap' ;
    rdfs:comment 'The net difference between rate-sensitive assets and rate-sensitive liabilities repricing within a given time bucket. Used in IRRBB repricing gap analysis to identify mismatches that create NII at risk. Applicable to banking book positions.' ;
    rdfs:domain ind:MarketRiskPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rwaMarketRisk rdf:type rdf:Property ;
    rdfs:label 'Rwa Market Risk' ;
    rdfs:comment 'Risk-Weighted Assets attributable to market risk for this position, computed as the capital charge multiplied by 12.5 (reciprocal of the 8% minimum capital ratio). Used in CET1 ratio and CCAR/DFAST capital adequacy reporting.' ;
    rdfs:domain ind:MarketRiskPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stressedVar rdf:type rdf:Property ;
    rdfs:label 'Stressed Var' ;
    rdfs:comment 'Stressed VaR computed using a continuous 12-month historical stress period calibrated to significant financial stress (e.g., 2008 financial crisis). Required under Basel 2.5 and used as a multiplier component in market risk capital calculation.' ;
    rdfs:domain ind:MarketRiskPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:var10d99 rdf:type rdf:Property ;
    rdfs:label 'Var 10d 99' ;
    rdfs:comment 'Ten-day Value at Risk at 99% confidence level, scaled from the 1-day VaR using the square-root-of-time rule or direct simulation. Used for regulatory capital calculation under Basel 2.5 market risk framework.' ;
    rdfs:domain ind:MarketRiskPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:var1d99 rdf:type rdf:Property ;
    rdfs:label 'Var 1d 99' ;
    rdfs:comment 'One-day Value at Risk at 99% confidence level computed using historical simulation methodology. Represents the maximum expected loss over a one-day horizon with 99% probability. Primary regulatory VaR metric under Basel 2.5 and FRTB IMA.' ;
    rdfs:domain ind:MarketRiskPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vega rdf:type rdf:Property ;
    rdfs:label 'Vega' ;
    rdfs:comment 'Sensitivity of the position\'s MTM value to a 1% change in implied volatility of the underlying. Applicable to options and volatility-sensitive instruments. Used in FRTB SA vega risk charge calculation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modelValidationId rdf:type rdf:Property ;
    rdfs:label 'Model Validation Id' ;
    rdfs:comment 'Unique surrogate identifier for each model validation record in the risk domain. Primary key for the model_validation data product.' ;
    rdfs:domain ind:ModelValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:backtestingExceptionsCount rdf:type rdf:Property ;
    rdfs:label 'Backtesting Exceptions Count' ;
    rdfs:comment 'Number of days (for VaR) or observations (for IRB/ECL) where actual losses or outcomes exceeded model predictions during the backtesting observation window. Directly drives the traffic light classification.' ;
    rdfs:domain ind:ModelValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:benchmarkingOutcome rdf:type rdf:Property ;
    rdfs:label 'Benchmarking Outcome' ;
    rdfs:comment 'Outcome of benchmarking the model\'s outputs against alternative models, industry benchmarks, or regulatory reference models. Indicates whether the model is consistent with, more conservative than, or more aggressive than benchmarks.' ;
    rdfs:domain ind:ModelValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conceptualSoundnessRating rdf:type rdf:Property ;
    rdfs:label 'Conceptual Soundness Rating' ;
    rdfs:comment 'Rating for the conceptual soundness component of the validation, assessing whether the model\'s theoretical basis, assumptions, and mathematical framework are appropriate for its intended use.' ;
    rdfs:domain ind:ModelValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataQualityRating rdf:type rdf:Property ;
    rdfs:label 'Data Quality Rating' ;
    rdfs:comment 'Rating for the data quality and integrity component of the validation, assessing whether input data is accurate, complete, representative, and appropriate for the model\'s intended use.' ;
    rdfs:domain ind:ModelValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRegulatoryCapitalModel rdf:type rdf:Property ;
    rdfs:label 'Is Regulatory Capital Model' ;
    rdfs:comment 'Indicates whether the model is used in the calculation of regulatory capital requirements (RWA, CET1). Models flagged true are subject to heightened validation standards and mandatory regulatory approval under Basel III IRB.' ;
    rdfs:domain ind:ModelValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kupiecTestResult rdf:type rdf:Property ;
    rdfs:label 'Kupiec Test Result' ;
    rdfs:comment 'Result of the Kupiec Proportion of Failures (POF) statistical test for VaR model accuracy. Tests whether the observed exception rate is statistically consistent with the model\'s confidence level (e.g., 99% VaR).' ;
    rdfs:domain ind:ModelValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialityAssessment rdf:type rdf:Property ;
    rdfs:label 'Materiality Assessment' ;
    rdfs:comment 'Assessment of whether identified model limitations and findings are material to the bank\'s financial position, capital adequacy, or regulatory compliance. Drives escalation to ALCO, Board Risk Committee, and regulators.' ;
    rdfs:domain ind:ModelValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelLimitationsSummary rdf:type rdf:Property ;
    rdfs:label 'Model Limitations Summary' ;
    rdfs:comment 'Narrative summary of key model limitations identified during validation, including known weaknesses in assumptions, data gaps, out-of-sample performance concerns, and boundary conditions where the model should not be applied.' ;
    rdfs:domain ind:ModelValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mraCount rdf:type rdf:Property ;
    rdfs:label 'Mra Count' ;
    rdfs:comment 'Number of Matters Requiring Attention (MRAs) identified during the validation. MRAs are significant findings that require corrective action but do not immediately impair model use. Key metric for regulatory examination readiness.' ;
    rdfs:domain ind:ModelValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mriaCount rdf:type rdf:Property ;
    rdfs:label 'Mria Count' ;
    rdfs:comment 'Number of Matters Requiring Immediate Attention (MRIAs) identified during the validation. MRIAs are critical findings that may require immediate suspension or restriction of model use pending remediation.' ;
    rdfs:domain ind:ModelValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:observationWindowEndDate rdf:type rdf:Property ;
    rdfs:label 'Observation Window End Date' ;
    rdfs:comment 'End date of the historical data observation window used for backtesting and performance testing. Defines the data cut-off for performance metrics reported in this validation.' ;
    rdfs:domain ind:ModelValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:observationWindowStartDate rdf:type rdf:Property ;
    rdfs:label 'Observation Window Start Date' ;
    rdfs:comment 'Start date of the historical data observation window used for backtesting and performance testing in this validation. For VaR models, typically 250 trading days; for IRB models, minimum 5–7 years per Basel III.' ;
    rdfs:domain ind:ModelValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:overallOutcome rdf:type rdf:Property ;
    rdfs:label 'Overall Outcome' ;
    rdfs:comment 'Final determination of the validation engagement: approved (model fit for purpose), approved_with_conditions (model usable subject to remediation), rejected (model not approved for use), or deferred (decision pending additional information).' ;
    rdfs:domain ind:ModelValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorySubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Date' ;
    rdfs:comment 'Date on which the model validation report or model approval application was submitted to the relevant regulator (Fed, OCC, PRA, EBA). Null if regulatory submission is not required.' ;
    rdfs:domain ind:ModelValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportIssuedDate rdf:type rdf:Property ;
    rdfs:label 'Report Issued Date' ;
    rdfs:comment 'Date the final model validation report was formally issued to model owners, senior management, and risk governance committees. May differ from validation_end_date if report drafting extends beyond fieldwork.' ;
    rdfs:domain ind:ModelValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sensitivityAnalysisOutcome rdf:type rdf:Property ;
    rdfs:label 'Sensitivity Analysis Outcome' ;
    rdfs:comment 'Summary outcome of sensitivity and stress testing of model inputs and assumptions. Indicates whether model outputs are stable under parameter perturbations or exhibit material sensitivity to key assumptions.' ;
    rdfs:domain ind:ModelValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:useApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Use Approval Status' ;
    rdfs:comment 'Current approval status for model use following validation: approved (unrestricted use), restricted (use permitted within defined constraints), suspended (use temporarily halted pending remediation), prohibited (model must not be used).' ;
    rdfs:domain ind:ModelValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:useRestrictions rdf:type rdf:Property ;
    rdfs:label 'Use Restrictions' ;
    rdfs:comment 'Narrative description of any restrictions placed on model use as a condition of approval (e.g., \'Apply conservative overlay of +15 bps to PD estimates\', \'Limit use to portfolios with LTV < 80%\', \'Not approved for CCAR submission without additional benchmarking\').' ;
    rdfs:domain ind:ModelValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationCode rdf:type rdf:Property ;
    rdfs:label 'Validation Code' ;
    rdfs:comment 'Externally-known business identifier for the validation engagement, used in regulatory submissions, audit trails, and correspondence with examiners (e.g., MV-IRBPD-2024). Unique across all validation cycles.' ;
    rdfs:domain ind:ModelValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationEndDate rdf:type rdf:Property ;
    rdfs:label 'Validation End Date' ;
    rdfs:comment 'Date on which the validation engagement was formally completed and the validation report issued. Null if still in progress.' ;
    rdfs:domain ind:ModelValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validationStartDate rdf:type rdf:Property ;
    rdfs:label 'Validation Start Date' ;
    rdfs:comment 'Date on which the independent model validation engagement formally commenced. Used to measure validation cycle duration and SLA compliance.' ;
    rdfs:domain ind:ModelValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validationType rdf:type rdf:Property ;
    rdfs:label 'Validation Type' ;
    rdfs:comment 'Nature of the validation engagement: initial (first-time validation of a new model), periodic (scheduled annual/biennial review), triggered (event-driven review due to material change, performance deterioration, or regulatory finding), pre-implementation, or post-implementation.' ;
    rdfs:domain ind:ModelValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedChannelId rdf:type rdf:Property ;
    rdfs:label 'Affected Channel Id' ;
    rdfs:comment 'Foreign key linking to channel.channel. Business justification: Operational risk events (outages, fraud, process failures) must track the affected channel for root cause analysis, regulatory reporting, and remediation. Banks report operational losses by channel. R' ;
    rdfs:domain ind:OperationalRiskEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:primaryOperationalEventOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Operational Event Owner Employee Id' ;
    rdfs:comment 'Employee identifier of the risk event owner responsible for managing the investigation, root cause analysis, corrective action, and closure of the operational risk event. Sourced from the Human Capital Management System (Workday/SAP SuccessFactors).' ;
    rdfs:domain ind:OperationalRiskEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:affectedProductLine rdf:type rdf:Property ;
    rdfs:label 'Affected Product Line' ;
    rdfs:comment 'The specific banking product or service line affected by the operational risk event (e.g., Mortgage Lending, FX Trading, ACH Payments, Wealth Management, Trade Finance). Used for product-level risk attribution and LOB reporting.' ;
    rdfs:domain ind:OperationalRiskEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselEventTypeCategory rdf:type rdf:Property ;
    rdfs:label 'Basel Event Type Category' ;
    rdfs:comment 'Basel III Level 1 operational risk event type category classification. Values: \'internal_fraud\' (Internal Fraud), \'external_fraud\' (External Fraud), \'epws\' (Employment Practices and Workplace Safety), \'cpbp\' (Clients Products and Business Practices), \'edpm\' (Execution Delivery and Process Management), \'bdsf\' (Business Disruption and System Failures), \'eflf\' (Damage to Physical Assets). Mandatory for SMA capital charge calculation and regulatory reporting. [ENUM-REF-CANDIDATE: internal_fraud|external_fraud|epws|cpbp|edpm|bdsf|eflf — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:OperationalRiskEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselEventTypeLevel2 rdf:type rdf:Property ;
    rdfs:label 'Basel Event Type Level2' ;
    rdfs:comment 'Basel III Level 2 sub-category providing granular classification within the Level 1 event type (e.g., \'Unauthorized Activity\' under Internal Fraud, \'Theft and Fraud\' under External Fraud, \'Suitability Disclosure and Fiduciary\' under CPBP). Supports detailed root cause analysis and trend reporting. [ENUM-REF-CANDIDATE: promote to reference product aligned with BCBS Annex 9 taxonomy]' ;
    rdfs:domain ind:OperationalRiskEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessLineCode rdf:type rdf:Property ;
    rdfs:label 'Business Line Code' ;
    rdfs:comment 'Basel III-defined business line classification code for the organizational unit where the operational risk event occurred. Standard Basel business lines include Corporate Finance, Trading and Sales, Retail Banking, Commercial Banking, Payment and Settlement, Agency Services, Asset Management, and Retail Brokerage. [ENUM-REF-CANDIDATE: corporate_finance|trading_and_sales|retail_banking|commercial_banking|payment_and_settlement|agency_services|asset_management|retail_brokerage — promote to reference product]' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:causalFactorCode rdf:type rdf:Property ;
    rdfs:label 'Causal Factor Code' ;
    rdfs:comment 'Standardized code from the enterprise causal factor taxonomy identifying the specific contributing factor(s) to the operational risk event (e.g., inadequate segregation of duties, system configuration error, third-party vendor failure, inadequate staff training). Used for trend analysis and KRI calibration.' ;
    rdfs:domain ind:OperationalRiskEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ccarDfastApplicableIndicator rdf:type rdf:Property ;
    rdfs:label 'Ccar Dfast Applicable Indicator' ;
    rdfs:comment 'Flag indicating whether this operational risk event is included in the operational risk loss scenario library used for CCAR and DFAST stress testing submissions to the Federal Reserve. Supports capital adequacy assessment under stressed conditions.' ;
    rdfs:domain ind:OperationalRiskEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:controlFailureType rdf:type rdf:Property ;
    rdfs:label 'Control Failure Type' ;
    rdfs:comment 'Classification of the internal control failure that contributed to the operational risk event. \'design_failure\' indicates the control was inadequately designed; \'operating_failure\' indicates the control existed but did not operate effectively; \'no_control\' indicates absence of a required control; \'override\' indicates management override of controls; \'circumvention\' indicates deliberate bypass of controls.' ;
    rdfs:domain ind:OperationalRiskEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionDueDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Due Date' ;
    rdfs:comment 'Target completion date for the corrective action plan associated with this operational risk event. Used for management escalation tracking and regulatory examination readiness.' ;
    rdfs:domain ind:OperationalRiskEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eventTitle rdf:type rdf:Property ;
    rdfs:label 'Event Title' ;
    rdfs:comment 'Short, descriptive title summarizing the nature of the operational risk event (e.g., \'Unauthorized Wire Transfer — Treasury Operations\', \'System Outage — Payment Processing Hub\'). Used for management reporting and GRC dashboard display.' ;
    rdfs:domain ind:OperationalRiskEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalLossDatabaseReference rdf:type rdf:Property ;
    rdfs:label 'External Loss Database Reference' ;
    rdfs:comment 'Reference identifier linking this internal loss event to a corresponding record in an external operational risk loss data consortium (e.g., ORX — Operational Riskdata eXchange Association). Supports benchmarking of internal loss experience against industry peers.' ;
    rdfs:domain ind:OperationalRiskEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalActionStatus rdf:type rdf:Property ;
    rdfs:label 'Legal Action Status' ;
    rdfs:comment 'Status of any legal proceedings or litigation associated with the operational risk event. \'none\' indicates no legal action; \'threatened\' indicates potential litigation notified; \'filed\' indicates lawsuit filed; \'settled\' indicates out-of-court settlement reached; \'judgment\' indicates court judgment rendered; \'dismissed\' indicates case dismissed.' ;
    rdfs:domain ind:OperationalRiskEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalProvisionAmount rdf:type rdf:Property ;
    rdfs:label 'Legal Provision Amount' ;
    rdfs:comment 'Financial provision or reserve established in the general ledger for potential legal liability arising from the operational risk event. Recognized per IFRS IAS 37 or FASB ASC 450 when outflow is probable and estimable.' ;
    rdfs:domain ind:OperationalRiskEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lossRecoveryDate rdf:type rdf:Property ;
    rdfs:label 'Loss Recovery Date' ;
    rdfs:comment 'Date on which the recovery amount was received or recognized, whether from insurance, legal settlement, or third-party reimbursement. Used for cash flow timing analysis and SMA recovery component allocation.' ;
    rdfs:domain ind:OperationalRiskEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lossThresholdMetIndicator rdf:type rdf:Property ;
    rdfs:label 'Loss Threshold Met Indicator' ;
    rdfs:comment 'Flag indicating whether the gross loss amount meets or exceeds the minimum loss data threshold (typically USD 20,000 per BCBS guidance) required for inclusion in the SMA Loss Component calculation and external loss data consortium submissions.' ;
    rdfs:domain ind:OperationalRiskEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nearMissIndicator rdf:type rdf:Property ;
    rdfs:label 'Near Miss Indicator' ;
    rdfs:comment 'Flag indicating whether this record represents a near-miss incident (potential loss that was averted) rather than an actual realized loss event. Near-miss events have zero gross loss but are captured for control environment assessment and KRI monitoring.' ;
    rdfs:domain ind:OperationalRiskEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryReportableIndicator rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reportable Indicator' ;
    rdfs:comment 'Flag indicating whether this operational risk event meets the threshold or criteria requiring mandatory regulatory reporting to OCC, Federal Reserve, PRA, or other supervisory authorities (e.g., significant operational events, cyber incidents, large losses).' ;
    rdfs:domain ind:OperationalRiskEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:smaLossComponent rdf:type rdf:Property ;
    rdfs:label 'Sma Loss Component' ;
    rdfs:comment 'Classification of how this event contributes to the SMA capital charge calculation under Basel III. \'loss_component\' indicates the event feeds the Loss Component (LC) of the SMA formula; \'recovery_component\' indicates a recovery adjustment; \'timing_adjustment\' indicates a multi-year loss requiring temporal allocation per BCBS guidance.' ;
    rdfs:domain ind:OperationalRiskEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByAppetiteId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Appetite Id' ;
    rdfs:comment 'Reference to the risk_appetite_id of the newer version that supersedes this record when approval_status is \'superseded\'. Enables forward-chaining of the version history for audit and regulatory review purposes.' ;
    rdfs:domain ind:Appetite ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Appetite .

ind:appetiteLevel rdf:type rdf:Property ;
    rdfs:label 'Appetite Level' ;
    rdfs:comment 'Qualitative board-approved appetite level indicating the degree of risk the institution is willing to accept in pursuit of its strategic objectives. Ranges from low (minimal risk tolerance) to high (aggressive risk-taking within regulatory bounds).' ;
    rdfs:domain ind:Appetite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachEscalationLevel rdf:type rdf:Property ;
    rdfs:label 'Breach Escalation Level' ;
    rdfs:comment 'Defines the escalation tier that must be notified upon breach of this appetite threshold. Establishes the governance response chain from management-level notification through CRO to Board Risk Committee escalation.' ;
    rdfs:domain ind:Appetite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachResponseTimeframeDays rdf:type rdf:Property ;
    rdfs:label 'Breach Response Timeframe Days' ;
    rdfs:comment 'Maximum number of calendar days within which a formal remediation plan must be submitted to the designated escalation body following a breach of this appetite threshold.' ;
    rdfs:domain ind:Appetite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:governanceBody rdf:type rdf:Property ;
    rdfs:label 'Governance Body' ;
    rdfs:comment 'The governing body that approved this risk appetite statement (e.g., Board of Directors, Board Risk Committee, ALCO, Executive Risk Committee). Establishes the authority level and escalation chain for breach management. [ENUM-REF-CANDIDATE: board|board_risk_committee|alco|executive_risk_committee|credit_committee|audit_committee|cro_office — promote to reference product]' ;
    rdfs:domain ind:Appetite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBoardApproved rdf:type rdf:Property ;
    rdfs:label 'Is Board Approved' ;
    rdfs:comment 'Indicates whether this risk appetite statement has received formal Board of Directors or Board Risk Committee approval (True) or is still in draft/management-approved status (False). Required for regulatory examination and SOX attestation.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isQuantitative rdf:type rdf:Property ;
    rdfs:label 'Is Quantitative' ;
    rdfs:comment 'Indicates whether this risk appetite statement is expressed as a quantitative metric with a numeric threshold (True) or as a qualitative statement without a numeric bound (False). Qualitative statements include zero-tolerance policies for regulatory violations or reputational risk.' ;
    rdfs:domain ind:Appetite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRegulatoryMinimum rdf:type rdf:Property ;
    rdfs:label 'Is Regulatory Minimum' ;
    rdfs:comment 'Indicates whether this appetite threshold is set at or derived from a regulatory minimum requirement (True) or represents an internally-set management buffer above the regulatory floor (False). Critical for distinguishing regulatory compliance floors from internal risk management buffers.' ;
    rdfs:domain ind:Appetite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:limitValue rdf:type rdf:Property ;
    rdfs:label 'Limit Value' ;
    rdfs:comment 'Hard operational limit assigned to a specific business line, desk, or portfolio that must not be exceeded. Derived from and subordinate to the enterprise-level appetite threshold. Used in daily risk limit monitoring within the Trading and Order Management System (Murex/Calypso).' ;
    rdfs:domain ind:Appetite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:metricDefinition rdf:type rdf:Property ;
    rdfs:label 'Metric Definition' ;
    rdfs:comment 'Formal definition of how the risk metric is calculated or assessed, including the numerator, denominator, observation period, and data sources. Ensures consistent measurement across business lines and regulatory submissions.' ;
    rdfs:domain ind:Appetite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metricName rdf:type rdf:Property ;
    rdfs:label 'Metric Name' ;
    rdfs:comment 'Name of the quantitative or qualitative metric used to measure risk against this appetite statement (e.g., \'CET1 Ratio\', \'VaR 99% 10-day\', \'LCR\', \'NSFR\', \'NPL Ratio\', \'ECL Coverage Ratio\').' ;
    rdfs:domain ind:Appetite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualitativeStatement rdf:type rdf:Property ;
    rdfs:label 'Qualitative Statement' ;
    rdfs:comment 'Full text of the board-approved qualitative risk appetite statement for non-quantifiable risk types (e.g., \'The Bank has zero tolerance for breaches of AML/BSA regulations\' or \'The Bank will not engage in activities that materially damage its reputation\'). Populated when is_quantitative is False.' ;
    rdfs:domain ind:Appetite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rangeLowerBound rdf:type rdf:Property ;
    rdfs:label 'Range Lower Bound' ;
    rdfs:comment 'Lower boundary of the acceptable risk range when direction is \'range\'. Applicable for metrics such as NIM targets or LCR operating ranges where both a floor and ceiling are defined.' ;
    rdfs:domain ind:Appetite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rangeUpperBound rdf:type rdf:Property ;
    rdfs:label 'Range Upper Bound' ;
    rdfs:comment 'Upper boundary of the acceptable risk range when direction is \'range\'. Used alongside range_lower_bound to define the full operating corridor for metrics managed within a band.' ;
    rdfs:domain ind:Appetite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rarocHurdleRate rdf:type rdf:Property ;
    rdfs:label 'Raroc Hurdle Rate' ;
    rdfs:comment 'Minimum Risk-Adjusted Return on Capital (RAROC) threshold that business activities must meet to be consistent with this risk appetite statement. Used in capital allocation decisions and new product approval processes.' ;
    rdfs:domain ind:Appetite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rwaLimit rdf:type rdf:Property ;
    rdfs:label 'Rwa Limit' ;
    rdfs:comment 'Maximum Risk-Weighted Assets (RWA) allocated to the applicable business line or portfolio under this appetite statement. Expressed in the institution\'s reporting currency. Supports capital adequacy management under Basel III Standardized Approach (SA) and Internal Ratings-Based (IRB) Approach.' ;
    rdfs:domain ind:Appetite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:statementCode rdf:type rdf:Property ;
    rdfs:label 'Statement Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the risk appetite statement, used in board documentation, ALCO packs, and regulatory submissions (e.g., RA-CREDIT-2024-001).' ;
    rdfs:domain ind:Appetite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statementName rdf:type rdf:Property ;
    rdfs:label 'Statement Name' ;
    rdfs:comment 'Human-readable name of the risk appetite statement as approved by the Board Risk Committee (e.g., \'Maximum Credit Risk Concentration — Single Obligor\').' ;
    rdfs:domain ind:Appetite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stressScenarioApplicability rdf:type rdf:Property ;
    rdfs:label 'Stress Scenario Applicability' ;
    rdfs:comment 'Indicates which stress testing scenario(s) this appetite threshold applies to: baseline (normal conditions), adverse (moderate stress), severely adverse (severe stress), or all scenarios. Directly maps to CCAR/DFAST scenario definitions.' ;
    rdfs:domain ind:Appetite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:threshold rdf:type rdf:Property ;
    rdfs:label 'Threshold' ;
    rdfs:comment 'Board-approved quantitative value representing the maximum level of risk the institution is willing to accept under normal operating conditions. For example, a CET1 ratio floor of 11.5% or a VaR limit of USD 50 million.' ;
    rdfs:domain ind:Appetite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:toleranceThreshold rdf:type rdf:Property ;
    rdfs:label 'Tolerance Threshold' ;
    rdfs:comment 'Maximum acceptable deviation from the risk appetite threshold before mandatory escalation is triggered. Represents the outer boundary of acceptable risk exposure (e.g., CET1 floor of 10.5% as the tolerance boundary below the 11.5% appetite).' ;
    rdfs:domain ind:Appetite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assessmentAssessorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Assessment Assessor Employee Id' ;
    rdfs:comment 'Identifier of the individual who performed or facilitated the risk assessment. Supports accountability tracking, assessor independence validation, and audit trail requirements.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assessmentEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Assessment Employee Id' ;
    rdfs:comment 'Identifier of the individual or role designated as the accountable risk owner responsible for managing and monitoring the assessed risk. Supports escalation routing and risk ownership reporting to the board risk committee.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actionPlan rdf:type rdf:Property ;
    rdfs:label 'Action Plan' ;
    rdfs:comment 'Documented plan of remediation actions to address identified control gaps or elevated risk ratings. Includes action steps, responsible parties, and target completion dates. Tracked in the GRC platform for management information reporting.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentCode rdf:type rdf:Property ;
    rdfs:label 'Assessment Code' ;
    rdfs:comment 'Externally-known business identifier for the assessment, used in GRC platform references, board risk committee reports, and regulatory submissions. Format: RA-{CATEGORY}-{YEAR}-{SEQUENCE}.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentType rdf:type rdf:Property ;
    rdfs:label 'Assessment Type' ;
    rdfs:comment 'Discriminator identifying the methodology and scope of the assessment. \'enterprise_risk_assessment\' covers holistic enterprise-wide evaluations; \'rcsa\' denotes Risk and Control Self-Assessment; \'thematic_review\' covers targeted deep-dives; \'icaap\' aligns with Internal Capital Adequacy Assessment Process; \'orsa\' aligns with Own Risk and Solvency Assessment.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingsSummary rdf:type rdf:Property ;
    rdfs:label 'Findings Summary' ;
    rdfs:comment 'Narrative summary of key findings identified during the risk assessment, including control gaps, risk drivers, and significant observations. Used in board risk committee packs, ICAAP documentation, and regulatory examination responses.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactRating rdf:type rdf:Property ;
    rdfs:label 'Impact Rating' ;
    rdfs:comment 'Qualitative assessment of the severity of financial, operational, reputational, or regulatory impact if the risk event materializes. Combined with likelihood to derive the inherent risk score.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isMaterialRisk rdf:type rdf:Property ;
    rdfs:label 'Is Material Risk' ;
    rdfs:comment 'Flag indicating whether the assessed risk has been classified as material under the enterprise risk appetite framework or ICAAP materiality assessment. Material risks receive enhanced monitoring, board-level reporting, and dedicated capital allocation consideration.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRegulatoryFinding rdf:type rdf:Property ;
    rdfs:label 'Is Regulatory Finding' ;
    rdfs:comment 'Flag indicating whether this risk assessment was initiated or escalated as a result of a regulatory examination finding, Matters Requiring Attention (MRA), or supervisory letter. Drives priority handling and regulatory response tracking.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:likelihoodRating rdf:type rdf:Property ;
    rdfs:label 'Likelihood Rating' ;
    rdfs:comment 'Qualitative assessment of the probability that the identified risk event will materialize within the assessment horizon. Combined with impact rating to derive the inherent risk score on the risk heat map.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskEventType rdf:type rdf:Property ;
    rdfs:label 'Risk Event Type' ;
    rdfs:comment 'Basel II/III operational risk event type classification applicable primarily to RCSA assessments. Maps to the seven Basel operational risk event categories used in Standardized Measurement Approach (SMA) capital calculations. [ENUM-REF-CANDIDATE: internal_fraud|external_fraud|employment_practices|clients_products_business|damage_physical_assets|business_disruption|execution_delivery — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskOwnerName rdf:type rdf:Property ;
    rdfs:label 'Risk Owner Name' ;
    rdfs:comment 'Full name of the designated risk owner accountable for the assessed risk. Retained as a denormalized field for reporting and audit trail purposes independent of HR system changes.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:threeLinesDefenceLayer rdf:type rdf:Property ;
    rdfs:label 'Three Lines Defence Layer' ;
    rdfs:comment 'Identifies which line of defence conducted or is responsible for this risk assessment. \'first_line\' is the business unit; \'second_line\' is risk management or compliance; \'third_line\' is internal audit. Supports governance framework reporting and assurance mapping.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskEclProvisionId rdf:type rdf:Property ;
    rdfs:label 'Risk Ecl Provision Id' ;
    rdfs:comment 'Unique surrogate identifier for each ECL provisioning and credit quality classification record in the risk domain. Primary key for the risk_ecl_provision data product.' ;
    rdfs:domain ind:RiskEclProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ftpAllocationId rdf:type rdf:Property ;
    rdfs:label 'Ftp Allocation Id' ;
    rdfs:comment 'Foreign key linking to treasury.ftp_allocation. Business justification: ECL provisions adjust FTP allocations for credit risk pricing in RAROC framework. Treasury FTP rates incorporate expected credit loss adjustments from risk ECL calculations to ensure risk-adjusted pro' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FtpAllocation .

ind:ceclPoolClassification rdf:type rdf:Property ;
    rdfs:label 'Cecl Pool Classification' ;
    rdfs:comment 'FASB ASC 326 (CECL) pool or segment classification used for collective assessment of expected credit losses. Identifies the homogeneous risk pool to which the instrument is assigned for CECL measurement purposes. [ENUM-REF-CANDIDATE: commercial_real_estate|commercial_industrial|consumer_mortgage|consumer_auto|consumer_unsecured|credit_card|other — promote to reference product]' ;
    rdfs:domain ind:RiskEclProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectiveAssessmentFlag rdf:type rdf:Property ;
    rdfs:label 'Collective Assessment Flag' ;
    rdfs:comment 'Indicates whether the ECL provision was calculated on a collective (pooled) basis rather than an individual (specific) basis. Collective assessment is applied when individual assessment is not practicable, typically for homogeneous retail portfolios.' ;
    rdfs:domain ind:RiskEclProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cureStatus rdf:type rdf:Property ;
    rdfs:label 'Cure Status' ;
    rdfs:comment 'Indicates the cure or exit status of a previously defaulted or forborne exposure. Tracks whether the borrower has exited NPL/forbearance status, is in the probation period, has been fully cured, or has re-defaulted.' ;
    rdfs:domain ind:RiskEclProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ecl12monthAmount rdf:type rdf:Property ;
    rdfs:label 'Ecl 12month Amount' ;
    rdfs:comment 'Calculated 12-month ECL provision amount representing the probability-weighted credit loss from default events expected within 12 months of the reporting date. Applied to Stage 1 exposures. Computed as PD_12month × LGD × EAD discounted at the effective interest rate.' ;
    rdfs:domain ind:RiskEclProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eclLifetimeAmount rdf:type rdf:Property ;
    rdfs:label 'Ecl Lifetime Amount' ;
    rdfs:comment 'Calculated lifetime ECL provision amount representing the probability-weighted credit loss over the remaining life of the instrument. Applied to Stage 2 and Stage 3 exposures under IFRS 9 and all exposures under CECL.' ;
    rdfs:domain ind:RiskEclProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:macroOverlayFactor rdf:type rdf:Property ;
    rdfs:label 'Macro Overlay Factor' ;
    rdfs:comment 'Forward-looking macroeconomic adjustment factor applied to the base ECL model output to incorporate point-in-time economic conditions (e.g., GDP growth, unemployment rate, house price index scenarios). Reflects IFRS 9 requirement for unbiased, probability-weighted forward-looking information.' ;
    rdfs:domain ind:RiskEclProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:macroScenarioWeight rdf:type rdf:Property ;
    rdfs:label 'Macro Scenario Weight' ;
    rdfs:comment 'Probability weight assigned to the macroeconomic scenario (base, upside, downside) used in the probability-weighted ECL calculation. The sum of scenario weights across all scenarios for a given exposure must equal 1.0.' ;
    rdfs:domain ind:RiskEclProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nplEntryDate rdf:type rdf:Property ;
    rdfs:label 'Npl Entry Date' ;
    rdfs:comment 'Date on which the credit exposure was first classified as non-performing under the EBA NPL definition. Used for NPL vintage analysis, cure period tracking, and EBA NPL ratio reporting.' ;
    rdfs:domain ind:RiskEclProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pd12month rdf:type rdf:Property ;
    rdfs:label 'Pd 12month' ;
    rdfs:comment 'Estimated probability that the obligor will default within the next 12 months, expressed as a decimal (e.g., 0.00250 = 0.25%). Used for Stage 1 ECL calculation and IRB capital requirement computation.' ;
    rdfs:domain ind:RiskEclProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pdLifetime rdf:type rdf:Property ;
    rdfs:label 'Pd Lifetime' ;
    rdfs:comment 'Estimated probability that the obligor will default over the remaining contractual life of the instrument. Used for Stage 2 and Stage 3 lifetime ECL calculation under IFRS 9.' ;
    rdfs:domain ind:RiskEclProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pociFlag rdf:type rdf:Property ;
    rdfs:label 'Poci Flag' ;
    rdfs:comment 'Indicates whether the financial instrument was purchased or originated as credit-impaired (POCI). POCI assets use a credit-adjusted effective interest rate and lifetime ECL from initial recognition under IFRS 9.' ;
    rdfs:domain ind:RiskEclProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recoveryExpectationAmount rdf:type rdf:Property ;
    rdfs:label 'Recovery Expectation Amount' ;
    rdfs:comment 'Estimated amount expected to be recovered from a written-off or defaulted exposure through collateral realization, guarantees, or workout proceedings. Informs the net LGD estimate and provision adequacy assessment.' ;
    rdfs:domain ind:RiskEclProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sicrFlag rdf:type rdf:Property ;
    rdfs:label 'Sicr Flag' ;
    rdfs:comment 'Indicates whether a significant increase in credit risk has been identified for this exposure since initial recognition, triggering migration from Stage 1 to Stage 2 under IFRS 9. Based on quantitative and qualitative SICR criteria.' ;
    rdfs:domain ind:RiskEclProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:writeOffAmount rdf:type rdf:Property ;
    rdfs:label 'Write Off Amount' ;
    rdfs:comment 'Cumulative amount of the credit exposure that has been written off against the provision balance, reducing both the gross loan balance and the provision. Triggered when there is no reasonable expectation of recovery.' ;
    rdfs:domain ind:RiskEclProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calibrationMethod rdf:type rdf:Property ;
    rdfs:label 'Calibration Method' ;
    rdfs:comment 'Statistical methodology used to calibrate the risk factor\'s shock distribution and volatility parameters for VaR, stressed VaR, and ECL models. Governs model validation requirements and regulatory approval under IRB and IMA frameworks.' ;
    rdfs:domain ind:Factor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ccarScenarioFlag rdf:type rdf:Property ;
    rdfs:label 'Ccar Scenario Flag' ;
    rdfs:comment 'Indicates whether this risk factor is included in the Federal Reserve\'s CCAR/DFAST stress testing scenario framework. True for factors that are shocked in supervisory adverse and severely adverse scenarios. Governs inclusion in stress testing data submissions to the Federal Reserve.' ;
    rdfs:domain ind:Factor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditQuality rdf:type rdf:Property ;
    rdfs:label 'Credit Quality' ;
    rdfs:comment 'Credit quality classification of the reference entity or issuer underlying a credit spread risk factor. Determines the applicable FRTB risk weight and correlation parameters. \'investment_grade\' corresponds to IG-rated issuers (BBB- and above); \'sub_investment_grade\' to HY/NR issuers.' ;
    rdfs:domain ind:Factor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:factorCode rdf:type rdf:Property ;
    rdfs:label 'Factor Code' ;
    rdfs:comment 'Externally-known, human-readable unique code identifying the risk factor across systems (e.g., \'IR_USD_SOFR_3M\', \'FX_EURUSD\', \'EQ_SPX\'). Used as the canonical business identifier in model configurations, regulatory submissions, and cross-system references.' ;
    rdfs:domain ind:Factor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:factorDescription rdf:type rdf:Property ;
    rdfs:label 'Factor Description' ;
    rdfs:comment 'Free-text narrative description of the risk factor, including its economic interpretation, model usage context, known limitations, and any special handling instructions. Supports model documentation requirements under SR 11-7 and provides context for risk analysts and model validators.' ;
    rdfs:domain ind:Factor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:factorName rdf:type rdf:Property ;
    rdfs:label 'Factor Name' ;
    rdfs:comment 'Full descriptive name of the risk factor as used in business communications, model documentation, and regulatory reports (e.g., \'USD SOFR 3-Month Swap Rate\', \'EUR/USD Spot FX Rate\', \'S&P 500 Equity Index\').' ;
    rdfs:domain ind:Factor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:factorStatus rdf:type rdf:Property ;
    rdfs:label 'Factor Status' ;
    rdfs:comment 'Current lifecycle status of the risk factor in the enterprise model inventory. \'active\' factors are used in live production models; \'deprecated\' factors are retained for historical audit; \'under_review\' factors are undergoing model validation or regulatory review.' ;
    rdfs:domain ind:Factor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:factorType rdf:type rdf:Property ;
    rdfs:label 'Factor Type' ;
    rdfs:comment 'Primary classification of the risk factor by its economic nature. Drives model selection, regulatory capital treatment, and VaR/CVA calculation methodology. [ENUM-REF-CANDIDATE: interest_rate|fx_rate|equity|commodity|credit_spread|volatility|inflation|real_estate|pd|lgd|ead — promote to reference product]' ;
    rdfs:domain ind:Factor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frtbBucket rdf:type rdf:Property ;
    rdfs:label 'Frtb Bucket' ;
    rdfs:comment 'FRTB Sensitivity-Based Method (SBM) bucket assignment for this risk factor as defined in BCBS FRTB Article 325. Determines the applicable risk weight and intra-bucket/inter-bucket correlation parameters for regulatory capital computation (e.g., \'GIRR_Bucket_1\', \'CSR_non_sec_Bucket_3\', \'EQ_Bucket_7\').' ;
    rdfs:domain ind:Factor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ifrs9EclFlag rdf:type rdf:Property ;
    rdfs:label 'Ifrs9 Ecl Flag' ;
    rdfs:comment 'Indicates whether this risk factor is used as a macroeconomic variable or credit parameter in IFRS 9 Expected Credit Loss (ECL) models. True for factors such as GDP growth, unemployment rate, PD term structures, and LGD curves used in forward-looking ECL projections.' ;
    rdfs:domain ind:Factor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isProxyFactor rdf:type rdf:Property ;
    rdfs:label 'Is Proxy Factor' ;
    rdfs:comment 'Indicates whether this risk factor is used as a proxy for another illiquid or unobservable factor. True when the factor substitutes for a non-modellable risk factor (NMRF) in model calculations. Proxy relationships require additional model validation documentation under SR 11-7.' ;
    rdfs:domain ind:Factor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastObservationDate rdf:type rdf:Property ;
    rdfs:label 'Last Observation Date' ;
    rdfs:comment 'Most recent date on which a real market price observation was recorded for this risk factor. Used in RFET assessment to verify that the factor has sufficient recent observations to qualify as modellable under FRTB IMA. Critical for daily data quality monitoring.' ;
    rdfs:domain ind:Factor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:liquidityHorizonDays rdf:type rdf:Property ;
    rdfs:label 'Liquidity Horizon Days' ;
    rdfs:comment 'FRTB-prescribed liquidity horizon in days assigned to this risk factor, reflecting the time required to exit or hedge the risk position in stressed market conditions (e.g., 10, 20, 40, 60, or 120 days per FRTB asset class). Used in ES scaling for IMA capital calculations.' ;
    rdfs:domain ind:Factor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:marketDataSource rdf:type rdf:Property ;
    rdfs:label 'Market Data Source' ;
    rdfs:comment 'Name of the primary market data vendor or internal source from which this risk factor\'s time series is sourced (e.g., \'Bloomberg\', \'Refinitiv\', \'ICE Data Services\', \'Federal Reserve H.15\', \'Internal Pricing Model\'). Governs data lineage and RFEТ (Risk Factor Eligibility Test) compliance under FRTB IMA.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketDataTicker rdf:type rdf:Property ;
    rdfs:label 'Market Data Ticker' ;
    rdfs:comment 'Vendor-specific ticker or field identifier used to retrieve this risk factor\'s market data from the designated source system (e.g., Bloomberg ticker \'USGG10YR Index\', Refinitiv RIC \'.SPX\'). Enables automated data feed mapping and reconciliation.' ;
    rdfs:domain ind:Factor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:observationWindowDays rdf:type rdf:Property ;
    rdfs:label 'Observation Window Days' ;
    rdfs:comment 'Length of the historical data observation window in calendar days used for calibrating this risk factor\'s shock distribution (e.g., 250 days for 1-year VaR, 1260 days for 5-year stressed VaR). Governs the backtesting and RFET assessment period.' ;
    rdfs:domain ind:Factor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:proxyFactorCode rdf:type rdf:Property ;
    rdfs:label 'Proxy Factor Code' ;
    rdfs:comment 'Factor code of the observable proxy risk factor used when is_proxy_factor is True. Documents the substitution relationship for model validation, audit, and NMRF capital add-on calculations. Null when the factor is directly observable.' ;
    rdfs:domain ind:Factor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfetObservationCount rdf:type rdf:Property ;
    rdfs:label 'Rfet Observation Count' ;
    rdfs:comment 'Number of real price observations recorded for this risk factor over the RFET assessment period (typically 12 months). A minimum of 24 observations (or 100 for the alternative test) is required for the factor to be classified as modellable under FRTB IMA. Populated by the market data quality process.' ;
    rdfs:domain ind:Factor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:riskClass rdf:type rdf:Property ;
    rdfs:label 'Risk Class' ;
    rdfs:comment 'Enterprise risk classification indicating which risk management pillar this factor belongs to: market risk (VaR, CVA), credit risk (PD/LGD/EAD, ECL, RWA), operational risk (SMA), or liquidity risk (LCR, NSFR). Governs routing to the appropriate risk engine and regulatory reporting stream.' ;
    rdfs:domain ind:Factor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sector rdf:type rdf:Property ;
    rdfs:label 'Sector' ;
    rdfs:comment 'Industry sector classification of the risk factor\'s underlying issuer or reference entity (e.g., \'financials\', \'energy\', \'technology\', \'sovereign\', \'covered_bond\'). Applies primarily to credit spread and equity risk factors. Aligns with FRTB SBM sector buckets for correlation and risk weight assignment. [ENUM-REF-CANDIDATE: financials|energy|technology|sovereign|covered_bond|consumer_discretionary|industrials|utilities|real_estate|materials — promote to reference product]' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shockType rdf:type rdf:Property ;
    rdfs:label 'Shock Type' ;
    rdfs:comment 'Convention used to express risk factor shocks in sensitivity and scenario analyses: \'absolute\' (additive shift in units), \'relative\' (percentage change), \'log_return\' (log-normal return), or \'basis_point\' (1bp = 0.0001 shift for rates). Determines how sensitivities (delta, vega) are computed and reported.' ;
    rdfs:domain ind:Factor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stressPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Stress Period End Date' ;
    rdfs:comment 'End date of the identified historical stress period used for stressed VaR and FRTB stressed ES calibration. Together with stress_period_start_date, defines the calibration window that produces the most adverse 12-month stressed scenario for this risk factor.' ;
    rdfs:domain ind:Factor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:stressPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Stress Period Start Date' ;
    rdfs:comment 'Start date of the identified historical stress period used for stressed VaR (sVaR) and FRTB stressed ES calibration for this risk factor. Must correspond to a period of significant financial stress relevant to the factor\'s asset class (e.g., 2008-09-01 for the Global Financial Crisis).' ;
    rdfs:domain ind:Factor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:subRiskClass rdf:type rdf:Property ;
    rdfs:label 'Sub Risk Class' ;
    rdfs:comment 'Granular sub-classification within the primary risk class (e.g., \'general_interest_rate_risk\', \'specific_risk\', \'counterparty_credit_risk\', \'settlement_risk\', \'concentration_risk\'). Used for detailed regulatory reporting and internal risk appetite segmentation. [ENUM-REF-CANDIDATE: general_interest_rate_risk|specific_risk|counterparty_credit_risk|settlement_risk|concentration_risk|basis_risk|vega_risk|curvature_risk — promote to reference product]' ;
    rdfs:domain ind:Factor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeSeriesCode rdf:type rdf:Property ;
    rdfs:label 'Time Series Code' ;
    rdfs:comment 'Reference to the historical time series record in the market data repository that stores the daily observations for this risk factor. Enables direct linkage from the factor definition to its underlying data for backtesting, calibration, and RFET assessment.' ;
    rdfs:domain ind:Factor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:underlyingIndex rdf:type rdf:Property ;
    rdfs:label 'Underlying Index' ;
    rdfs:comment 'Name of the underlying benchmark index or reference rate for the risk factor (e.g., \'SOFR\', \'EURIBOR\', \'LIBOR\', \'OIS\', \'S&P 500\', \'WTI Crude\'). Critical for IBOR transition tracking (LIBOR to SOFR/EURIBOR migration) and model calibration documentation.' ;
    rdfs:domain ind:Factor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varConfidenceLevel rdf:type rdf:Property ;
    rdfs:label 'Var Confidence Level' ;
    rdfs:comment 'Statistical confidence level used when computing Value at Risk (VaR) for this risk factor (e.g., 0.9900 for 99%, 0.9750 for 97.5% ES under FRTB). Stored as a decimal fraction. Governs the tail risk threshold for internal risk limits and regulatory capital calculations.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varContributionPct rdf:type rdf:Property ;
    rdfs:label 'Var Contribution Pct' ;
    rdfs:comment 'Percentage contribution of this risk factor to the total portfolio VaR as of the last calculation date. Expressed as a decimal (e.g., 0.0523 = 5.23%). Used for risk attribution reporting, limit monitoring, and identification of dominant risk drivers in the trading book.' ;
    rdfs:domain ind:Factor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ownerUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Owner User Employee Id' ;
    rdfs:comment 'Surrogate identifier of the business user (risk manager or desk head) who owns and is accountable for this risk limit. The limit owner is responsible for monitoring utilization and initiating breach remediation actions.' ;
    rdfs:domain ind:RiskLimit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:breachActionRule rdf:type rdf:Property ;
    rdfs:label 'Breach Action Rule' ;
    rdfs:comment 'Prescribed remediation action protocol to be executed upon a breach event (e.g., \'Immediate escalation to CRO and ALCO; position reduction within 24 hours; SAR filing if AML threshold exceeded\'). Codifies the breach governance framework for operational consistency.' ;
    rdfs:domain ind:RiskLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachCount rdf:type rdf:Property ;
    rdfs:label 'Breach Count' ;
    rdfs:comment 'Cumulative number of breach events recorded against this limit since its effective date. Used for trend analysis, KRI monitoring, and regulatory reporting on limit governance effectiveness.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deskCode rdf:type rdf:Property ;
    rdfs:label 'Desk Code' ;
    rdfs:comment 'Identifier of the trading desk or business unit responsible for the positions subject to this limit. Aligns with desk hierarchy in Murex/Calypso trading and order management systems. Required for FRTB desk-level capital attribution.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationLevel1 rdf:type rdf:Property ;
    rdfs:label 'Escalation Level 1' ;
    rdfs:comment 'Name or role title of the first-level escalation contact notified upon a limit warning or breach event (e.g., \'Head of Market Risk\', \'Senior Credit Officer\'). Defines the escalation chain for breach governance.' ;
    rdfs:domain ind:RiskLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationLevel2 rdf:type rdf:Property ;
    rdfs:label 'Escalation Level 2' ;
    rdfs:comment 'Name or role title of the second-level escalation contact notified if the breach is not remediated within the prescribed timeframe (e.g., \'Chief Risk Officer\', \'Board Risk Committee Chair\'). Supports multi-tier breach governance.' ;
    rdfs:domain ind:RiskLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographyCode rdf:type rdf:Property ;
    rdfs:label 'Geography Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country or region code identifying the geographic scope of the limit (e.g., \'USA\', \'GBR\', \'DEU\'). Used for country risk concentration limits and cross-border exposure management.' ;
    rdfs:domain ind:RiskLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hardStopFlag rdf:type rdf:Property ;
    rdfs:label 'Hard Stop Flag' ;
    rdfs:comment 'Indicates whether the limit enforces a hard stop (True) that prevents new transactions from being booked once the limit is reached, or a soft limit (False) that triggers alerts and escalation but does not block transactions. Critical for real-time limit monitoring integration with trading and order management systems.' ;
    rdfs:domain ind:RiskLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastBreachDate rdf:type rdf:Property ;
    rdfs:label 'Last Breach Date' ;
    rdfs:comment 'Date of the most recent breach event recorded against this limit. Null if no breach has occurred. Used for recency analysis in KRI dashboards and regulatory examination responses.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryCapitalFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Capital Flag' ;
    rdfs:comment 'Indicates whether this limit is directly tied to a regulatory capital constraint (True) under Basel III/FRTB (e.g., RWA limit, CET1 buffer limit, LCR minimum). Flags limits that require regulatory reporting upon breach.' ;
    rdfs:domain ind:RiskLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scopeEntityName rdf:type rdf:Property ;
    rdfs:label 'Scope Entity Name' ;
    rdfs:comment 'Human-readable name of the entity to which this limit applies (e.g., counterparty legal name, desk name, LOB name, country name). Retained for reporting and audit purposes independent of master data joins.' ;
    rdfs:domain ind:RiskLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeEntityType rdf:type rdf:Property ;
    rdfs:label 'Scope Entity Type' ;
    rdfs:comment 'The type of business entity to which this limit applies. Determines the dimension of risk aggregation (e.g., \'counterparty\' for single-name credit limits, \'desk\' for trading desk VaR limits, \'lob\' for Line of Business concentration limits, \'geography\' for country risk limits). [ENUM-REF-CANDIDATE: counterparty|portfolio|desk|lob|geography|sector|instrument|legal_entity — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RiskLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stressTestLimitFlag rdf:type rdf:Property ;
    rdfs:label 'Stress Test Limit Flag' ;
    rdfs:comment 'Indicates whether this limit is a stress-scenario limit (True) applied under CCAR/DFAST stress testing frameworks, as opposed to a business-as-usual (BAU) limit. Stress limits typically have higher thresholds and different breach protocols.' ;
    rdfs:domain ind:RiskLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:utilizationAsOfTimestamp rdf:type rdf:Property ;
    rdfs:label 'Utilization As Of Timestamp' ;
    rdfs:comment 'The precise date and time at which the current utilization amount was calculated or sourced from the risk management platform. Critical for intraday limit monitoring and audit trail integrity. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:RiskLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:utilizationBasis rdf:type rdf:Property ;
    rdfs:label 'Utilization Basis' ;
    rdfs:comment 'The measurement methodology used to calculate current utilization against the limit. Determines which risk metric is compared to the limit amount (e.g., \'var\' for Value at Risk limits, \'ead\' for Exposure at Default credit limits, \'rwa\' for Risk-Weighted Asset limits, \'lcr_outflow\' for liquidity limits). [ENUM-REF-CANDIDATE: notional|mtm|ead|var|rwa|ecl|nii_impact|lcr_outflow|cva|pv01|dv01 — promote to reference product]' ;
    rdfs:domain ind:RiskLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utilizationPct rdf:type rdf:Property ;
    rdfs:label 'Utilization Pct' ;
    rdfs:comment 'Current utilization expressed as a percentage of the approved limit amount (current_utilization_amount / limit_amount × 100). Enables threshold-based alerting and trend analysis. Values above 100 indicate a breach condition.' ;
    rdfs:domain ind:RiskLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varHoldingPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Var Holding Period Days' ;
    rdfs:comment 'The holding period in calendar days used in the VaR calculation for market risk limits (e.g., 1 for daily VaR, 10 for 10-day regulatory VaR under Basel III). Applicable only for market risk limit types.' ;
    rdfs:domain ind:RiskLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:warningThresholdPct rdf:type rdf:Property ;
    rdfs:label 'Warning Threshold Pct' ;
    rdfs:comment 'Percentage of the limit amount at which an early-warning alert is triggered (e.g., 80.00 for 80%). Enables proactive escalation before a formal breach occurs. Expressed as a percentage (0–100). Configured per limit in SAS Risk Management / Moody\'s RiskAuthority.' ;
    rdfs:domain ind:RiskLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tertiaryRiskReviewedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Risk Reviewed By User Employee Id' ;
    rdfs:comment 'User identifier of the individual who reviewed this risk report prior to approval.' ;
    rdfs:domain ind:RiskReport ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:audienceType rdf:type rdf:Property ;
    rdfs:label 'Audience Type' ;
    rdfs:comment 'Primary audience or governance body for whom this risk report is prepared. [ENUM-REF-CANDIDATE: board|executive_management|risk_committee|alco|regulator|internal_audit|business_unit — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RiskReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cet1Ratio rdf:type rdf:Property ;
    rdfs:label 'Cet1 Ratio' ;
    rdfs:comment 'Common Equity Tier 1 capital ratio reported, expressed as a percentage of risk-weighted assets.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:generationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Generation Timestamp' ;
    rdfs:comment 'Date and time when the risk report was generated by the risk management system.' ;
    rdfs:domain ind:RiskReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:keyFindings rdf:type rdf:Property ;
    rdfs:label 'Key Findings' ;
    rdfs:comment 'Detailed narrative of key findings, trends, and risk observations identified in this report.' ;
    rdfs:domain ind:RiskReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nplRatio rdf:type rdf:Property ;
    rdfs:label 'Npl Ratio' ;
    rdfs:comment 'Non-performing loan ratio reported, calculated as non-performing loans divided by total loan portfolio.' ;
    rdfs:domain ind:RiskReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportCode rdf:type rdf:Property ;
    rdfs:label 'Report Code' ;
    rdfs:comment 'Business identifier code for the risk report, used for external reference and tracking.' ;
    rdfs:domain ind:RiskReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportName rdf:type rdf:Property ;
    rdfs:label 'Report Name' ;
    rdfs:comment 'Descriptive name of the risk report identifying its purpose and content.' ;
    rdfs:domain ind:RiskReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingUnitCode rdf:type rdf:Property ;
    rdfs:label 'Reporting Unit Code' ;
    rdfs:comment 'Code identifying the business unit or division responsible for this risk report.' ;
    rdfs:domain ind:RiskReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stressedVarAmount rdf:type rdf:Property ;
    rdfs:label 'Stressed Var Amount' ;
    rdfs:comment 'Stressed Value at Risk amount reported, calculated using a historical period of significant financial stress.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:submissionReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Submission Reference Number' ;
    rdfs:comment 'External reference number assigned by the regulatory authority upon submission of this report.' ;
    rdfs:domain ind:RiskReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tier1Ratio rdf:type rdf:Property ;
    rdfs:label 'Tier1 Ratio' ;
    rdfs:comment 'Tier 1 capital ratio reported, expressed as a percentage of risk-weighted assets.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCapitalRatio rdf:type rdf:Property ;
    rdfs:label 'Total Capital Ratio' ;
    rdfs:comment 'Total capital ratio reported, expressed as a percentage of risk-weighted assets.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalRwaAmount rdf:type rdf:Property ;
    rdfs:label 'Total Rwa Amount' ;
    rdfs:comment 'Total risk-weighted assets amount reported in this risk report, used for capital adequacy calculations.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varAmount rdf:type rdf:Property ;
    rdfs:label 'Var Amount' ;
    rdfs:comment 'Value at Risk amount reported, representing the maximum potential loss over a specified time horizon at a given confidence level.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scenarioResultId rdf:type rdf:Property ;
    rdfs:label 'Scenario Result Id' ;
    rdfs:comment 'Unique identifier for the scenario result record. Primary key.' ;
    rdfs:domain ind:ScenarioResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:breachFlag rdf:type rdf:Property ;
    rdfs:label 'Breach Flag' ;
    rdfs:comment 'Indicates whether this scenario result breaches a regulatory minimum or internal risk appetite threshold.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capitalImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Capital Impact Amount' ;
    rdfs:comment 'The net impact on regulatory capital resulting from this scenario result.' ;
    rdfs:domain ind:ScenarioResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:portfolioScopeCode rdf:type rdf:Property ;
    rdfs:label 'Portfolio Scope Code' ;
    rdfs:comment 'Code identifying the portfolio segment or scope to which this result applies (e.g., retail lending, trading book, corporate loan portfolio).' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectionDate rdf:type rdf:Property ;
    rdfs:label 'Projection Date' ;
    rdfs:comment 'The specific date within the stress test horizon to which this result applies.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:projectionQuarter rdf:type rdf:Property ;
    rdfs:label 'Projection Quarter' ;
    rdfs:comment 'The quarter number within the stress test horizon to which this result applies (e.g., 1 for Q1, 9 for nine-quarter horizon).' ;
    rdfs:domain ind:ScenarioResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryProgram rdf:type rdf:Property ;
    rdfs:label 'Regulatory Program' ;
    rdfs:comment 'The regulatory stress testing program under which this result was generated (e.g., CCAR, DFAST, EBA, ICAAP).' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Result Reference Number' ;
    rdfs:comment 'Business identifier for the scenario result, used for external reporting and audit trails.' ;
    rdfs:domain ind:ScenarioResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultStatus rdf:type rdf:Property ;
    rdfs:label 'Result Status' ;
    rdfs:comment 'Current lifecycle status of the scenario result record.' ;
    rdfs:domain ind:ScenarioResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stressedCet1Ratio rdf:type rdf:Property ;
    rdfs:label 'Stressed Cet1 Ratio' ;
    rdfs:comment 'The projected Common Equity Tier 1 capital ratio under the stress scenario, expressed as a percentage.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stressedCvaAmount rdf:type rdf:Property ;
    rdfs:label 'Stressed Cva Amount' ;
    rdfs:comment 'The projected Credit Valuation Adjustment under the stress scenario.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stressedEclAmount rdf:type rdf:Property ;
    rdfs:label 'Stressed Ecl Amount' ;
    rdfs:comment 'The projected Expected Credit Loss under the stress scenario.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stressedLcrRatio rdf:type rdf:Property ;
    rdfs:label 'Stressed Lcr Ratio' ;
    rdfs:comment 'The projected Liquidity Coverage Ratio under the stress scenario, expressed as a percentage.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stressedLeverageRatio rdf:type rdf:Property ;
    rdfs:label 'Stressed Leverage Ratio' ;
    rdfs:comment 'The projected leverage ratio under the stress scenario, expressed as a percentage.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stressedLossAmount rdf:type rdf:Property ;
    rdfs:label 'Stressed Loss Amount' ;
    rdfs:comment 'The projected loss amount under the stress scenario for this portfolio or risk factor.' ;
    rdfs:domain ind:ScenarioResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stressedNiiAmount rdf:type rdf:Property ;
    rdfs:label 'Stressed Nii Amount' ;
    rdfs:comment 'The projected Net Interest Income under the stress scenario.' ;
    rdfs:domain ind:ScenarioResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stressedNimBps rdf:type rdf:Property ;
    rdfs:label 'Stressed Nim Bps' ;
    rdfs:comment 'The projected Net Interest Margin under the stress scenario, expressed in basis points.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stressedNsfrRatio rdf:type rdf:Property ;
    rdfs:label 'Stressed Nsfr Ratio' ;
    rdfs:comment 'The projected Net Stable Funding Ratio under the stress scenario, expressed as a percentage.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stressedPpnrAmount rdf:type rdf:Property ;
    rdfs:label 'Stressed Ppnr Amount' ;
    rdfs:comment 'The projected Pre-Provision Net Revenue under the stress scenario.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stressedProvisionAmount rdf:type rdf:Property ;
    rdfs:label 'Stressed Provision Amount' ;
    rdfs:comment 'The projected credit loss provision amount under the stress scenario.' ;
    rdfs:domain ind:ScenarioResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stressedRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Stressed Revenue Amount' ;
    rdfs:comment 'The projected revenue amount under the stress scenario.' ;
    rdfs:domain ind:ScenarioResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stressedRwaAmount rdf:type rdf:Property ;
    rdfs:label 'Stressed Rwa Amount' ;
    rdfs:comment 'The projected risk-weighted assets amount under the stress scenario.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stressedTier1Ratio rdf:type rdf:Property ;
    rdfs:label 'Stressed Tier1 Ratio' ;
    rdfs:comment 'The projected Tier 1 capital ratio under the stress scenario, expressed as a percentage.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stressedTotalCapitalRatio rdf:type rdf:Property ;
    rdfs:label 'Stressed Total Capital Ratio' ;
    rdfs:comment 'The projected total capital ratio under the stress scenario, expressed as a percentage.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primarySupersededByStressScenarioId rdf:type rdf:Property ;
    rdfs:label 'Primary Superseded By Stress Scenario Id' ;
    rdfs:comment 'Reference to the stress_scenario_id of the newer scenario that supersedes this record when approval_status = \'superseded\'. Enables scenario lineage tracking and version chain navigation for audit and regulatory review purposes.' ;
    rdfs:domain ind:StressScenario ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StressScenario .

ind:sourceScenarioStressScenarioId rdf:type rdf:Property ;
    rdfs:label 'Source Scenario Stress Scenario Id' ;
    rdfs:comment 'The native identifier of this stress scenario in the originating source system (e.g., AxiomSL scenario ID, OneSumX scenario reference). Enables traceability from the lakehouse silver layer back to the operational system of record.' ;
    rdfs:domain ind:StressScenario ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StressScenario .

ind:stressScenarioCfpId rdf:type rdf:Property ;
    rdfs:label 'Stress Scenario Cfp Id' ;
    rdfs:comment 'Foreign key linking to treasury.stress_scenario_cfp. Business justification: Risk stress scenarios reference treasury contingency funding plan stress scenarios for integrated liquidity stress testing required by CCAR/DFAST. Treasury CFP scenarios define liquidity shocks that r' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StressScenarioCfp .

ind:cet1FloorPct rdf:type rdf:Property ;
    rdfs:label 'Cet1 Floor Pct' ;
    rdfs:comment 'The minimum CET1 capital ratio floor assumed or targeted under this stress scenario, expressed as a percentage. Used to assess whether the bank maintains adequate capital buffers above regulatory minimums (4.5% CET1 minimum under Basel III) throughout the stress horizon.' ;
    rdfs:domain ind:StressScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:crePriceShockPct rdf:type rdf:Property ;
    rdfs:label 'Cre Price Shock Pct' ;
    rdfs:comment 'The peak-to-trough decline in commercial real estate prices assumed under this scenario, expressed as a percentage. Key driver for CRE loan portfolio stress testing, collateral valuation, and LTV-based ECL estimation under CECL/IFRS 9.' ;
    rdfs:domain ind:StressScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditSpreadShockBps rdf:type rdf:Property ;
    rdfs:label 'Credit Spread Shock Bps' ;
    rdfs:comment 'The widening of corporate/sovereign credit spreads assumed under this scenario, expressed in basis points. Drives mark-to-market losses on bond portfolios, CVA stress, and CDS pricing in trading book stress tests under FRTB.' ;
    rdfs:domain ind:StressScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:equityPriceShockPct rdf:type rdf:Property ;
    rdfs:label 'Equity Price Shock Pct' ;
    rdfs:comment 'The percentage decline in broad equity market indices (e.g., S&P 500) assumed under this scenario (e.g., -50.00 for a 50% market decline). Drives mark-to-market losses on equity portfolios, CVA stress, and trading book VaR under FRTB.' ;
    rdfs:domain ind:StressScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fxShockPct rdf:type rdf:Property ;
    rdfs:label 'Fx Shock Pct' ;
    rdfs:comment 'The percentage depreciation or appreciation of the USD (or base currency) against major foreign currencies assumed under this scenario. Drives FX translation losses, cross-currency swap valuation, and international portfolio stress.' ;
    rdfs:domain ind:StressScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gdpGrowthShockPct rdf:type rdf:Property ;
    rdfs:label 'Gdp Growth Shock Pct' ;
    rdfs:comment 'The peak-to-trough or annualized GDP growth rate shock applied under this scenario, expressed as a percentage (e.g., -8.50 for an 8.5% contraction). A key macroeconomic variable in CCAR/DFAST scenarios used to drive credit loss and revenue projections.' ;
    rdfs:domain ind:StressScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hpiShockPct rdf:type rdf:Property ;
    rdfs:label 'Hpi Shock Pct' ;
    rdfs:comment 'The peak-to-trough decline in the House Price Index (HPI) assumed under this scenario, expressed as a percentage (e.g., -25.00 for a 25% decline). Critical for mortgage portfolio stress testing and LTV-based credit loss estimation.' ;
    rdfs:domain ind:StressScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inflationRateShockPct rdf:type rdf:Property ;
    rdfs:label 'Inflation Rate Shock Pct' ;
    rdfs:comment 'The peak inflation rate (CPI/PCE) assumed under this scenario, expressed as a percentage. Used in real rate calculations, ALM stress testing, and cost-of-funds projections under CCAR/DFAST and ICAAP.' ;
    rdfs:domain ind:StressScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isRegulatoryPrescribed rdf:type rdf:Property ;
    rdfs:label 'Is Regulatory Prescribed' ;
    rdfs:comment 'Indicates whether this scenario was prescribed by a regulatory authority (True) or developed internally by the bank (False). Regulatory-prescribed scenarios (e.g., Fed CCAR scenarios) have mandatory use requirements and cannot be modified by the bank.' ;
    rdfs:domain ind:StressScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReverseStress rdf:type rdf:Property ;
    rdfs:label 'Is Reverse Stress' ;
    rdfs:comment 'Indicates whether this scenario is a reverse stress test (True), i.e., a scenario designed to identify conditions that would cause the bank to fail or breach critical thresholds, working backwards from the outcome. Required under PRA SS3/13 and BCBS stress testing principles.' ;
    rdfs:domain ind:StressScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lcrFloorPct rdf:type rdf:Property ;
    rdfs:label 'Lcr Floor Pct' ;
    rdfs:comment 'The minimum Liquidity Coverage Ratio (LCR) floor assumed under this stress scenario, expressed as a percentage. Used in liquidity stress testing to assess whether the bank maintains sufficient high-quality liquid assets (HQLA) under the scenario conditions.' ;
    rdfs:domain ind:StressScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:legalEntityScope rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Scope' ;
    rdfs:comment 'The legal entity or consolidated group to which this stress scenario applies (e.g., \'BHC Consolidated\', \'Bank Subsidiary\', \'Broker-Dealer\'). Supports multi-entity stress testing and regulatory reporting at the appropriate consolidation level.' ;
    rdfs:domain ind:StressScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lgdMultiplier rdf:type rdf:Property ;
    rdfs:label 'Lgd Multiplier' ;
    rdfs:comment 'The scalar multiplier applied to baseline Loss Given Default (LGD) estimates under this scenario to derive stressed LGD inputs for ECL/CECL and RWA stress calculations. Reflects collateral value deterioration and recovery rate compression under stress.' ;
    rdfs:domain ind:StressScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineOfBusinessScope rdf:type rdf:Property ;
    rdfs:label 'Line Of Business Scope' ;
    rdfs:comment 'The line of business or portfolio segment to which this scenario applies (e.g., \'All LOBs\', \'Commercial Lending\', \'Trading Book\', \'Retail Banking\'). Null or \'All LOBs\' indicates enterprise-wide applicability. Supports LOB-level stress attribution.' ;
    rdfs:domain ind:StressScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:longTermRateShockBps rdf:type rdf:Property ;
    rdfs:label 'Long Term Rate Shock Bps' ;
    rdfs:comment 'The shock to long-term interest rates (e.g., 10-year Treasury yield) applied under this scenario, expressed in basis points (BPS). Used in bond portfolio valuation, NII stress testing, and duration/convexity analysis under CCAR/DFAST.' ;
    rdfs:domain ind:StressScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pdMultiplier rdf:type rdf:Property ;
    rdfs:label 'Pd Multiplier' ;
    rdfs:comment 'The scalar multiplier applied to baseline Probability of Default (PD) estimates under this scenario to derive stressed PD inputs for ECL/CECL calculations and RWA stress testing. A value of 2.50 means stressed PD = 2.5x baseline PD. Used in IRB model stress testing.' ;
    rdfs:domain ind:StressScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rwaScalar rdf:type rdf:Property ;
    rdfs:label 'Rwa Scalar' ;
    rdfs:comment 'The scalar factor applied to baseline Risk-Weighted Assets (RWA) under this scenario to project stressed RWA for capital adequacy assessment. Used in CCAR/DFAST capital ratio projections and CET1 depletion analysis.' ;
    rdfs:domain ind:StressScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scenarioCode rdf:type rdf:Property ;
    rdfs:label 'Scenario Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the stress scenario within the regulatory program or internal stress framework (e.g., CCAR-2024-SA, DFAST-2024-ADV, ICAAP-2024-BL). Used as the business key for cross-system referencing in AxiomSL/OneSumX.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scenarioDescription rdf:type rdf:Property ;
    rdfs:label 'Scenario Description' ;
    rdfs:comment 'Narrative description of the macroeconomic and financial conditions assumed under the stress scenario, including the economic story, key assumptions, and the nature of the shock being modeled.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scenarioHorizonQuarters rdf:type rdf:Property ;
    rdfs:label 'Scenario Horizon Quarters' ;
    rdfs:comment 'The projection horizon of the stress scenario expressed in quarters. Standard CCAR/DFAST horizon is 9 quarters (13 quarters for certain programs). Determines the length of the macroeconomic variable path and the stress run projection period.' ;
    rdfs:domain ind:StressScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scenarioName rdf:type rdf:Property ;
    rdfs:label 'Scenario Name' ;
    rdfs:comment 'Human-readable descriptive name of the stress scenario (e.g., \'2024 CCAR Severely Adverse\', \'2024 DFAST Adverse\', \'Internal Recession Scenario Q1-2024\'). Used in regulatory submissions, board presentations, and risk reporting.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scenarioSeverity rdf:type rdf:Property ;
    rdfs:label 'Scenario Severity' ;
    rdfs:comment 'Severity classification of the stress scenario per regulatory and internal taxonomy. \'baseline\' = expected/central economic path; \'adverse\' = moderate stress; \'severely_adverse\' = severe recession/crisis conditions; \'reverse_stress\' = scenario designed to cause failure; \'exploratory\' = ad-hoc sensitivity analysis.' ;
    rdfs:domain ind:StressScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scenarioSource rdf:type rdf:Property ;
    rdfs:label 'Scenario Source' ;
    rdfs:comment 'The originating authority or institution that published or defined the stress scenario. \'federal_reserve\' = Fed-prescribed CCAR/DFAST scenario; \'occ\' = OCC-prescribed scenario; \'eba\' = European Banking Authority; \'pra\' = Prudential Regulation Authority; \'internal\' = bank-developed scenario; \'imf\' = IMF FSAP scenario; \'bis\' = BIS/BCBS scenario. [ENUM-REF-CANDIDATE: federal_reserve|occ|fdic|eba|pra|internal|imf|bis — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StressScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scenarioVintage rdf:type rdf:Property ;
    rdfs:label 'Scenario Vintage' ;
    rdfs:comment 'The publication or reference vintage of the scenario, typically expressed as a year (e.g., \'2024\') or year-quarter (e.g., \'2024Q1\'). Identifies the cycle in which the scenario was issued by the regulator or approved internally. Critical for tracking scenario evolution across CCAR/DFAST cycles.' ;
    rdfs:domain ind:StressScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortTermRateShockBps rdf:type rdf:Property ;
    rdfs:label 'Short Term Rate Shock Bps' ;
    rdfs:comment 'The shock to short-term interest rates (e.g., 3-month Treasury, Fed Funds Rate) applied under this scenario, expressed in basis points (BPS). Used in NII/NIM stress testing and ALM analysis. Positive = rate increase; negative = rate decrease.' ;
    rdfs:domain ind:StressScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unemploymentRateShockPct rdf:type rdf:Property ;
    rdfs:label 'Unemployment Rate Shock Pct' ;
    rdfs:comment 'The peak unemployment rate assumed under this stress scenario, expressed as a percentage (e.g., 12.50 for 12.5% peak unemployment). A primary macroeconomic driver for consumer credit loss models in CCAR/DFAST stress testing.' ;
    rdfs:domain ind:StressScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:asOfDate rdf:type rdf:Property ;
    rdfs:label 'As Of Date' ;
    rdfs:comment 'The reference balance sheet date from which the stress test projects forward. All starting positions (exposures, capital, liquidity) are measured as of this date.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capitalActionRestrictionFlag rdf:type rdf:Property ;
    rdfs:label 'Capital Action Restriction Flag' ;
    rdfs:comment 'Indicates whether this stress test result triggered restrictions on capital distributions (dividends, share buybacks) under the stress capital buffer framework or CCAR objection process.' ;
    rdfs:domain ind:StressTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:executedBy rdf:type rdf:Property ;
    rdfs:label 'Executed By' ;
    rdfs:comment 'The name or system identifier of the team, user, or automated process that initiated and executed this stress test run. Used for governance and audit trail purposes.' ;
    rdfs:domain ind:StressTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irbApproachFlag rdf:type rdf:Property ;
    rdfs:label 'Irb Approach Flag' ;
    rdfs:comment 'Indicates whether the Internal Ratings-Based (IRB) approach was used for credit risk RWA calculation in this stress test run. If False, the Standardized Approach (SA) was applied.' ;
    rdfs:domain ind:StressTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:projectionEndDate rdf:type rdf:Property ;
    rdfs:label 'Projection End Date' ;
    rdfs:comment 'The final date of the stress projection horizon, calculated as as_of_date plus the stress horizon. Defines the terminal point for all stressed capital and liquidity metrics.' ;
    rdfs:domain ind:StressTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryOutcome rdf:type rdf:Property ;
    rdfs:label 'Regulatory Outcome' ;
    rdfs:comment 'The regulatory determination resulting from this stress test submission. \'no_objection\' and \'pass\' indicate capital plan approval; \'objection\' or \'fail\' require remediation. \'pending\' indicates awaiting regulatory response.' ;
    rdfs:domain ind:StressTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runCode rdf:type rdf:Property ;
    rdfs:label 'Run Code' ;
    rdfs:comment 'Externally-known business identifier for this stress test execution, used in regulatory submissions and internal reporting (e.g., CCAR-2024-ADV-001). Unique within a submission cycle.' ;
    rdfs:domain ind:StressTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runNotes rdf:type rdf:Property ;
    rdfs:label 'Run Notes' ;
    rdfs:comment 'Free-text field for qualitative commentary on this stress test run, including methodology overrides, data quality issues, management adjustments, or explanations of material deviations from prior runs.' ;
    rdfs:domain ind:StressTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runTimestamp rdf:type rdf:Property ;
    rdfs:label 'Run Timestamp' ;
    rdfs:comment 'The date and time at which the stress test computation was initiated. This is the principal business event timestamp representing when the scenario was applied to the portfolio.' ;
    rdfs:domain ind:StressTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:stressCapitalBufferPct rdf:type rdf:Property ;
    rdfs:label 'Stress Capital Buffer Pct' ;
    rdfs:comment 'The stress capital buffer (SCB) requirement derived from this stress test run, expressed as a percentage. Calculated as the maximum decline in CET1 ratio under the severely adverse scenario, subject to a 2.5% floor.' ;
    rdfs:domain ind:StressTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stressHorizonQuarters rdf:type rdf:Property ;
    rdfs:label 'Stress Horizon Quarters' ;
    rdfs:comment 'The number of quarters over which the stress scenario is projected. Standard CCAR/DFAST horizon is 9 quarters; internal stress tests may use shorter or longer horizons.' ;
    rdfs:domain ind:StressTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stressedNiiImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Stressed Nii Impact Amount' ;
    rdfs:comment 'The cumulative change in Net Interest Income (NII) projected under the stress scenario relative to the baseline over the horizon, in reporting currency. Negative values indicate NII compression under stress.' ;
    rdfs:domain ind:StressTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:submissionReference rdf:type rdf:Property ;
    rdfs:label 'Submission Reference' ;
    rdfs:comment 'The reference number or acknowledgement ID assigned by the regulatory authority upon receipt of the stress test submission (e.g., Federal Reserve submission tracking number). Null if not yet submitted.' ;
    rdfs:domain ind:StressTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:administratorLei rdf:type rdf:Property ;
    rdfs:label 'Administrator Lei' ;
    rdfs:comment 'ISO 17442 Legal Entity Identifier of the benchmark administrator.' ;
    rdfs:domain ind:Benchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constituentCount rdf:type rdf:Property ;
    rdfs:label 'Constituent Count' ;
    rdfs:comment 'Number of constituent instruments or securities included in the index. Applicable to equity and credit indices.' ;
    rdfs:domain ind:Benchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:geographicCoverage rdf:type rdf:Property ;
    rdfs:label 'Geographic Coverage' ;
    rdfs:comment 'Geographic scope of the benchmark or index (e.g., USA, Europe, Global, Emerging Markets). Pipe-separated list of ISO 3166-1 alpha-3 country codes or region names.' ;
    rdfs:domain ind:Benchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indexBaseDate rdf:type rdf:Property ;
    rdfs:label 'Index Base Date' ;
    rdfs:comment 'Date on which the index base value was established. Applicable to equity and credit indices.' ;
    rdfs:domain ind:Benchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:indexBaseValue rdf:type rdf:Property ;
    rdfs:label 'Index Base Value' ;
    rdfs:comment 'Base or starting value of the index at inception. Applicable to equity and credit indices.' ;
    rdfs:domain ind:Benchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ioscoCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Iosco Compliant Flag' ;
    rdfs:comment 'Indicates whether the benchmark complies with IOSCO Principles for Financial Benchmarks.' ;
    rdfs:domain ind:Benchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:methodologyDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Methodology Document Url' ;
    rdfs:comment 'URL to the official methodology document describing the benchmark calculation and governance.' ;
    rdfs:domain ind:Benchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicationFrequency rdf:type rdf:Property ;
    rdfs:label 'Publication Frequency' ;
    rdfs:comment 'Frequency at which the benchmark rate or index value is published (daily, weekly, monthly, quarterly, real-time, intraday).' ;
    rdfs:domain ind:Benchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sectorCoverage rdf:type rdf:Property ;
    rdfs:label 'Sector Coverage' ;
    rdfs:comment 'Industry sectors covered by the benchmark or index (e.g., Technology, Financials, Healthcare, Broad Market). Applicable to equity and credit indices.' ;
    rdfs:domain ind:Benchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spreadAdjustmentBps rdf:type rdf:Property ;
    rdfs:label 'Spread Adjustment Bps' ;
    rdfs:comment 'Fixed spread adjustment in basis points to be added when transitioning to the fallback benchmark (e.g., LIBOR to SOFR transition spread).' ;
    rdfs:domain ind:Benchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usageRestriction rdf:type rdf:Property ;
    rdfs:label 'Usage Restriction' ;
    rdfs:comment 'Any restrictions or licensing requirements for using the benchmark in financial contracts or products.' ;
    rdfs:domain ind:Benchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightingScheme rdf:type rdf:Property ;
    rdfs:label 'Weighting Scheme' ;
    rdfs:comment 'Method used to weight constituents in the index (market capitalization, free-float adjusted, price, equal, fundamental, risk parity). Applicable to indices.' ;
    rdfs:domain ind:Benchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classificationId rdf:type rdf:Property ;
    rdfs:label 'Classification Id' ;
    rdfs:comment 'Primary key for classification' ;
    rdfs:domain ind:Classification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:classificationCode rdf:type rdf:Property ;
    rdfs:label 'Classification Code' ;
    rdfs:comment 'The specific classification code value within the chosen scheme. For CFI this is a 6-character code (e.g., ESVUFR for equity), for ISDA this is the product type code, for EMIR this is the asset class code, for SFDR this is the sustainability category (Article 6/8/9), for MiFID II this is the product complexity indicator, for FRTB this is the risk bucket identifier.' ;
    rdfs:domain ind:Classification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classificationDescription rdf:type rdf:Property ;
    rdfs:label 'Classification Description' ;
    rdfs:comment 'Human-readable description of the classification code. Provides business-friendly explanation of what the classification represents (e.g., \'Common Share\', \'Interest Rate Swap\', \'Equity Derivative\', \'Article 8 Fund - Promotes Environmental Characteristics\').' ;
    rdfs:domain ind:Classification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classificationLevel rdf:type rdf:Property ;
    rdfs:label 'Classification Level' ;
    rdfs:comment 'Hierarchical level within the classification taxonomy. Level 1 represents the highest level (e.g., asset class), with increasing numbers representing more granular categorization. Supports multi-level taxonomies where instruments are classified at multiple levels of detail.' ;
    rdfs:domain ind:Classification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:classificationSource rdf:type rdf:Property ;
    rdfs:label 'Classification Source' ;
    rdfs:comment 'The authoritative source of this classification. Identifies whether the classification was provided by a vendor (e.g., Bloomberg, Refinitiv), derived internally by the bank\'s reference data team, mandated by a regulatory authority, provided by the exchange, supplied by the issuer, or obtained from a third-party data provider.' ;
    rdfs:domain ind:Classification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complexityIndicator rdf:type rdf:Property ;
    rdfs:label 'Complexity Indicator' ;
    rdfs:comment 'MiFID II product complexity classification. Non-complex instruments can be sold without appropriateness assessment; complex instruments require suitability or appropriateness assessment. Critical for investment policy compliance screening and client advisory.' ;
    rdfs:domain ind:Classification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidenceScore rdf:type rdf:Property ;
    rdfs:label 'Confidence Score' ;
    rdfs:comment 'Confidence score (0.00 to 100.00) indicating the reliability or certainty of the classification. Used when classifications are algorithmically derived or when multiple sources provide conflicting classifications. Higher scores indicate greater confidence.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:frtbRiskBucket rdf:type rdf:Property ;
    rdfs:label 'Frtb Risk Bucket' ;
    rdfs:comment 'FRTB sensitivities-based approach risk bucket assignment. Used for market risk capital calculation under Basel III FRTB framework. Buckets vary by asset class (e.g., interest rate buckets by currency and tenor, equity buckets by sector and market cap, credit buckets by rating and sector).' ;
    rdfs:domain ind:Classification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalAssetClass rdf:type rdf:Property ;
    rdfs:label 'Internal Asset Class' ;
    rdfs:comment 'Internal proprietary asset class hierarchy used for portfolio management, risk reporting, and investment policy compliance. May differ from regulatory classifications to align with the bank\'s internal risk management and business line structure.' ;
    rdfs:domain ind:Classification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalProductCategory rdf:type rdf:Property ;
    rdfs:label 'Internal Product Category' ;
    rdfs:comment 'Internal product categorization for business line reporting, profitability analysis, and operational management. Aligns with the bank\'s line of business (LOB) structure and product governance framework.' ;
    rdfs:domain ind:Classification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPrimaryClassification rdf:type rdf:Property ;
    rdfs:label 'Is Primary Classification' ;
    rdfs:comment 'Indicates whether this is the primary or default classification for the instrument within this classification scheme. True when this classification should be used as the authoritative categorization; false for alternative or supplementary classifications.' ;
    rdfs:domain ind:Classification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overrideApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Override Approved By' ;
    rdfs:comment 'User ID or name of the authorized person who approved the classification override. Required when override_indicator is true. Supports audit trail and accountability for manual classification decisions.' ;
    rdfs:domain ind:Classification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentClassificationCode rdf:type rdf:Property ;
    rdfs:label 'Parent Classification Code' ;
    rdfs:comment 'The classification code of the parent category in hierarchical taxonomies. Enables navigation of multi-level classification structures (e.g., \'Equity\' as parent of \'Common Share\'). Null for top-level classifications.' ;
    rdfs:domain ind:Classification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schemeCode rdf:type rdf:Property ;
    rdfs:label 'Scheme Code' ;
    rdfs:comment 'The classification framework or taxonomy being applied. Supports CFI (Classification of Financial Instruments ISO 10962), ISDA product taxonomy, ESMA EMIR classification, SFDR (Sustainable Finance Disclosure Regulation) sustainability classification, MiFID II product governance classification, FRTB (Fundamental Review of the Trading Book) sensitivities-based approach, and internal asset class hierarchy. [ENUM-REF-CANDIDATE: CFI|ISDA|EMIR|SFDR|MIFID2|FRTB|INTERNAL — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Classification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityClassification rdf:type rdf:Property ;
    rdfs:label 'Sustainability Classification' ;
    rdfs:comment 'SFDR sustainability classification for funds and financial products. Article 6 (no sustainability objective), Article 8 (promotes environmental or social characteristics), Article 9 (has sustainable investment as objective). Required for EU regulatory reporting and ESG investment screening.' ;
    rdfs:domain ind:Classification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cashCurrencyId rdf:type rdf:Property ;
    rdfs:label 'Cash Currency Id' ;
    rdfs:comment 'Foreign key linking to reference.currency. Business justification: Cash dividend and redemption currency determines entitlement calculations and FX conversion for cross-border corporate actions. Critical for accurate custody accounting and client entitlement processi' ;
    rdfs:domain ind:CorporateAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:primaryCorporateInstrumentId rdf:type rdf:Property ;
    rdfs:label 'Primary Corporate Instrument Id' ;
    rdfs:comment 'Reference to the security instrument affected by this corporate action.' ;
    rdfs:domain ind:CorporateAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Instrument .

ind:cashRate rdf:type rdf:Property ;
    rdfs:label 'Cash Rate' ;
    rdfs:comment 'Cash amount per share or unit to be distributed as part of the corporate action (e.g., dividend per share).' ;
    rdfs:domain ind:CorporateAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Certification Required Flag' ;
    rdfs:comment 'Indicates whether beneficial owners must provide certification (e.g., tax forms, eligibility declarations) to participate.' ;
    rdfs:domain ind:CorporateAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificationType rdf:type rdf:Property ;
    rdfs:label 'Certification Type' ;
    rdfs:comment 'Type of certification required (e.g., W-8BEN, W-9, beneficial ownership declaration).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultOptionCode rdf:type rdf:Property ;
    rdfs:label 'Default Option Code' ;
    rdfs:comment 'Code identifying the default option that will be applied if no election is received from the beneficial owner.' ;
    rdfs:domain ind:CorporateAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:electionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Election Required Flag' ;
    rdfs:comment 'Indicates whether beneficial owners must submit an election instruction to participate or receive entitlements.' ;
    rdfs:domain ind:CorporateAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:entitlementCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Entitlement Calculation Method' ;
    rdfs:comment 'Method used to calculate beneficial owner entitlements (e.g., based on record date position, average balance, or transaction history).' ;
    rdfs:domain ind:CorporateAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exDate rdf:type rdf:Property ;
    rdfs:label 'Ex Date' ;
    rdfs:comment 'Ex-dividend or ex-entitlement date. The first trading day on which the security trades without the entitlement to participate in the corporate action.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fractionalShareTreatment rdf:type rdf:Property ;
    rdfs:label 'Fractional Share Treatment' ;
    rdfs:comment 'Method for handling fractional shares resulting from the corporate action.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuerLei rdf:type rdf:Property ;
    rdfs:label 'Issuer Lei' ;
    rdfs:comment 'Legal Entity Identifier of the issuer as defined by the Global Legal Entity Identifier Foundation.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mandatoryVoluntaryIndicator rdf:type rdf:Property ;
    rdfs:label 'Mandatory Voluntary Indicator' ;
    rdfs:comment 'Indicates whether the corporate action is mandatory for all holders or requires voluntary election by beneficial owners.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketClaimFlag rdf:type rdf:Property ;
    rdfs:label 'Market Claim Flag' ;
    rdfs:comment 'Indicates whether market claims are applicable for trades settling after the record date but before the ex-date.' ;
    rdfs:domain ind:CorporateAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:offerPriceCurrency rdf:type rdf:Property ;
    rdfs:label 'Offer Price Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the offer price.' ;
    rdfs:domain ind:CorporateAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payingAgentBic rdf:type rdf:Property ;
    rdfs:label 'Paying Agent Bic' ;
    rdfs:comment 'SWIFT Bank Identifier Code of the paying agent.' ;
    rdfs:domain ind:CorporateAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payingAgentName rdf:type rdf:Property ;
    rdfs:label 'Paying Agent Name' ;
    rdfs:comment 'Name of the financial institution acting as paying agent for the distribution of cash or securities.' ;
    rdfs:domain ind:CorporateAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protectDate rdf:type rdf:Property ;
    rdfs:label 'Protect Date' ;
    rdfs:comment 'Date by which custodians and intermediaries must submit protect instructions to ensure entitlements are preserved for beneficial owners.' ;
    rdfs:domain ind:CorporateAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceEventReference rdf:type rdf:Property ;
    rdfs:label 'Source Event Reference' ;
    rdfs:comment 'Unique identifier assigned to this corporate action event by the source system or data provider.' ;
    rdfs:domain ind:CorporateAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockRateDenominator rdf:type rdf:Property ;
    rdfs:label 'Stock Rate Denominator' ;
    rdfs:comment 'Denominator of the stock distribution ratio (e.g., in a 3-for-2 split, this would be 2).' ;
    rdfs:domain ind:CorporateAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stockRateNumerator rdf:type rdf:Property ;
    rdfs:label 'Stock Rate Numerator' ;
    rdfs:comment 'Numerator of the stock distribution ratio (e.g., in a 3-for-2 split, this would be 3).' ;
    rdfs:domain ind:CorporateAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the tax jurisdiction applying withholding tax.' ;
    rdfs:domain ind:CorporateAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:couponScheduleId rdf:type rdf:Property ;
    rdfs:label 'Coupon Schedule Id' ;
    rdfs:comment 'Unique identifier for the coupon payment schedule entry.' ;
    rdfs:domain ind:CouponSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualCouponAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Coupon Amount' ;
    rdfs:comment 'The actual coupon payment amount after rate reset (for floating rate instruments) or final calculation. Populated after payment determination.' ;
    rdfs:domain ind:CouponSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:couponPeriodNumber rdf:type rdf:Property ;
    rdfs:label 'Coupon Period Number' ;
    rdfs:comment 'Sequential number identifying the coupon period within the instrument\'s lifecycle (e.g., 1, 2, 3...).' ;
    rdfs:domain ind:CouponSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:couponType rdf:type rdf:Property ;
    rdfs:label 'Coupon Type' ;
    rdfs:comment 'Classification of the coupon rate structure for this period.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dayCountFraction rdf:type rdf:Property ;
    rdfs:label 'Day Count Fraction' ;
    rdfs:comment 'The calculated fraction of the year represented by this coupon period based on the day count convention.' ;
    rdfs:domain ind:CouponSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netCouponAmount rdf:type rdf:Property ;
    rdfs:label 'Net Coupon Amount' ;
    rdfs:comment 'The coupon payment amount after deduction of withholding taxes and any other applicable deductions.' ;
    rdfs:domain ind:CouponSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Payment Timestamp' ;
    rdfs:comment 'The actual date and time when the coupon payment was executed. Null if payment has not yet occurred.' ;
    rdfs:domain ind:CouponSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:projectedCouponAmount rdf:type rdf:Property ;
    rdfs:label 'Projected Coupon Amount' ;
    rdfs:comment 'The estimated coupon payment amount calculated at schedule creation time, used for cash flow projection and Net Interest Income (NII) forecasting.' ;
    rdfs:domain ind:CouponSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:referenceRateValue rdf:type rdf:Property ;
    rdfs:label 'Reference Rate Value' ;
    rdfs:comment 'The observed value of the reference rate index on the rate reset date, used to calculate the floating coupon rate.' ;
    rdfs:domain ind:CouponSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditRatingId rdf:type rdf:Property ;
    rdfs:label 'Credit Rating Id' ;
    rdfs:comment 'Primary key for credit_rating' ;
    rdfs:domain ind:CreditRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:issuerPartyId rdf:type rdf:Property ;
    rdfs:label 'Issuer Party Id' ;
    rdfs:comment 'Reference to the issuer entity whose creditworthiness is being assessed.' ;
    rdfs:domain ind:CreditRating ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:baselCreditQualityStep rdf:type rdf:Property ;
    rdfs:label 'Basel Credit Quality Step' ;
    rdfs:comment 'Credit quality step (1-6) under Basel III mapping framework for regulatory capital calculation.' ;
    rdfs:domain ind:CreditRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:baselRiskWeightPct rdf:type rdf:Property ;
    rdfs:label 'Basel Risk Weight Pct' ;
    rdfs:comment 'Risk weight percentage assigned under Basel III Standardized Approach for Risk-Weighted Assets (RWA) calculation.' ;
    rdfs:domain ind:CreditRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ceclRiskCategory rdf:type rdf:Property ;
    rdfs:label 'Cecl Risk Category' ;
    rdfs:comment 'Risk category under US GAAP CECL framework for expected credit loss estimation.' ;
    rdfs:domain ind:CreditRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalOverrideFlag rdf:type rdf:Property ;
    rdfs:label 'Internal Override Flag' ;
    rdfs:comment 'Indicates whether the bank has applied an internal override to the external rating for risk management purposes.' ;
    rdfs:domain ind:CreditRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:internalOverrideReason rdf:type rdf:Property ;
    rdfs:label 'Internal Override Reason' ;
    rdfs:comment 'Explanation for why an internal override was applied to the external rating.' ;
    rdfs:domain ind:CreditRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investmentGradeFlag rdf:type rdf:Property ;
    rdfs:label 'Investment Grade Flag' ;
    rdfs:comment 'Indicates whether the rating qualifies as investment grade (BBB-/Baa3 or higher) versus speculative/high-yield.' ;
    rdfs:domain ind:CreditRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:longTermRating rdf:type rdf:Property ;
    rdfs:label 'Long Term Rating' ;
    rdfs:comment 'Long-term credit rating assigned (e.g., AAA, Aaa, AA+, BBB-, Ba1, CCC). Format varies by agency.' ;
    rdfs:domain ind:CreditRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousRating rdf:type rdf:Property ;
    rdfs:label 'Previous Rating' ;
    rdfs:comment 'The rating that was in effect immediately prior to the current rating action. Used for tracking rating migration.' ;
    rdfs:domain ind:CreditRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:probabilityOfDefaultPct rdf:type rdf:Property ;
    rdfs:label 'Probability Of Default Pct' ;
    rdfs:comment 'Estimated probability of default associated with this rating, expressed as a percentage. Used for Expected Credit Loss (ECL) calculation under IFRS 9 and Current Expected Credit Losses (CECL).' ;
    rdfs:domain ind:CreditRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:publicRatingFlag rdf:type rdf:Property ;
    rdfs:label 'Public Rating Flag' ;
    rdfs:comment 'Indicates whether the rating is publicly disclosed or private/confidential.' ;
    rdfs:domain ind:CreditRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ratedEntityType rdf:type rdf:Property ;
    rdfs:label 'Rated Entity Type' ;
    rdfs:comment 'Type of entity being rated: instrument-level rating or issuer-level rating.' ;
    rdfs:domain ind:CreditRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingActionType rdf:type rdf:Property ;
    rdfs:label 'Rating Action Type' ;
    rdfs:comment 'Type of rating action: initial assignment, upgrade, downgrade, affirmation, withdrawal, or review status. [ENUM-REF-CANDIDATE: initial|upgrade|downgrade|affirmed|withdrawn|suspended|under_review — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CreditRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingAgencyCode rdf:type rdf:Property ;
    rdfs:label 'Rating Agency Code' ;
    rdfs:comment 'Code identifying the rating agency that assigned the rating (Moody\'s, S&P, Fitch, DBRS, Kroll, or internal model). [ENUM-REF-CANDIDATE: MOODYS|SP|FITCH|DBRS|KROLL|AM_BEST|JCR|INTERNAL — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CreditRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingAgencyName rdf:type rdf:Property ;
    rdfs:label 'Rating Agency Name' ;
    rdfs:comment 'Full legal name of the rating agency.' ;
    rdfs:domain ind:CreditRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingChangeReason rdf:type rdf:Property ;
    rdfs:label 'Rating Change Reason' ;
    rdfs:comment 'Brief description of the primary reason for rating change (e.g., deteriorating financial performance, improved liquidity, sector outlook change).' ;
    rdfs:domain ind:CreditRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingIdentifier rdf:type rdf:Property ;
    rdfs:label 'Rating Identifier' ;
    rdfs:comment 'External identifier or reference number assigned by the rating agency to this specific rating.' ;
    rdfs:domain ind:CreditRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingNotch rdf:type rdf:Property ;
    rdfs:label 'Rating Notch' ;
    rdfs:comment 'Numeric representation of the rating on a standardized scale for quantitative analysis and comparison across agencies.' ;
    rdfs:domain ind:CreditRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ratingSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Rating Source System' ;
    rdfs:comment 'Source system or data feed from which the rating was obtained (e.g., Bloomberg, Reuters, direct agency feed, internal model).' ;
    rdfs:domain ind:CreditRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortTermRating rdf:type rdf:Property ;
    rdfs:label 'Short Term Rating' ;
    rdfs:comment 'Short-term credit rating assigned (e.g., A-1+, P-1, F1, R-1H). Format varies by agency.' ;
    rdfs:domain ind:CreditRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:solicitedFlag rdf:type rdf:Property ;
    rdfs:label 'Solicited Flag' ;
    rdfs:comment 'Indicates whether the rating was solicited (requested by issuer) or unsolicited (assigned independently by agency).' ;
    rdfs:domain ind:CreditRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notionalCurrencyId rdf:type rdf:Property ;
    rdfs:label 'Notional Currency Id' ;
    rdfs:comment 'Foreign key linking to reference.currency. Business justification: Notional currency defines derivative contract size and exposure. Critical for risk aggregation, CVA calculation, and regulatory reporting (EMIR, Dodd-Frank). First of four currency FKs needed for deri' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:referenceLoanFacilityId rdf:type rdf:Property ;
    rdfs:label 'Reference Loan Facility Id' ;
    rdfs:comment 'Foreign key linking to loan.facility. Business justification: Credit derivatives (CDS, total return swaps, credit-linked notes) referencing loan facilities as underlying exposure require facility identification for mark-to-market valuation, credit event determin' ;
    rdfs:domain ind:Derivative ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:underlyingInstrumentId rdf:type rdf:Property ;
    rdfs:label 'Underlying Instrument Id' ;
    rdfs:comment 'Reference to the underlying asset or instrument upon which the derivative contract is based (equity, bond, commodity, index, currency pair, or another derivative).' ;
    rdfs:domain ind:Security ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Instrument .

ind:barrierLevel rdf:type rdf:Property ;
    rdfs:label 'Barrier Level' ;
    rdfs:comment 'Price threshold that activates (knock-in) or deactivates (knock-out) the derivative contract. Used in barrier options and structured products.' ;
    rdfs:domain ind:Derivative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:barrierType rdf:type rdf:Property ;
    rdfs:label 'Barrier Type' ;
    rdfs:comment 'Classification of barrier feature: knock-in (option activates when barrier is breached), knock-out (option terminates when barrier is breached), double-barrier (both upper and lower barriers), or none for non-barrier derivatives.' ;
    rdfs:domain ind:Derivative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ccpName rdf:type rdf:Property ;
    rdfs:label 'Ccp Name' ;
    rdfs:comment 'Name of the central clearing house through which the derivative is cleared (e.g., LCH, CME, Eurex Clearing). Applicable only for cleared derivatives.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:derivativeType rdf:type rdf:Property ;
    rdfs:label 'Derivative Type' ;
    rdfs:comment 'Classification of the derivative instrument by contract structure: swap, forward, future, option, swaption, credit default swap (CDS), total return swap, variance swap, or exotic derivative. [ENUM-REF-CANDIDATE: swap|forward|future|option|swaption|credit_default_swap|total_return_swap|variance_swap|exotic — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Derivative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exerciseStyle rdf:type rdf:Property ;
    rdfs:label 'Exercise Style' ;
    rdfs:comment 'Defines when the option holder can exercise the contract: European (only at expiry), American (any time before expiry), Bermudan (on specific dates), or Asian (based on average price over period).' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marginCurrency rdf:type rdf:Property ;
    rdfs:label 'Margin Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code in which initial and variation margin are posted.' ;
    rdfs:domain ind:Derivative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:markToMarketValue rdf:type rdf:Property ;
    rdfs:label 'Mark To Market Value' ;
    rdfs:comment 'Current fair value of the derivative contract based on prevailing market prices and valuation models. Updated daily for profit and loss (PnL) attribution and CVA calculation.' ;
    rdfs:domain ind:Derivative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mtmCurrency rdf:type rdf:Property ;
    rdfs:label 'Mtm Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code in which the mark-to-market value is denominated.' ;
    rdfs:domain ind:Derivative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingObligation rdf:type rdf:Property ;
    rdfs:label 'Reporting Obligation' ;
    rdfs:comment 'Identifies the regulatory framework under which the derivative must be reported: EMIR (EU), Dodd-Frank (US), MiFID II (EU), SFTR (Securities Financing Transactions Regulation), or none.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementType rdf:type rdf:Property ;
    rdfs:label 'Settlement Type' ;
    rdfs:comment 'Method of settlement at maturity: cash settlement (net cash payment based on market value) or physical delivery (actual transfer of underlying asset).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strikeCurrency rdf:type rdf:Property ;
    rdfs:label 'Strike Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the strike price. Relevant for FX options and cross-currency derivatives.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strikePrice rdf:type rdf:Property ;
    rdfs:label 'Strike Price' ;
    rdfs:comment 'The predetermined price at which the holder of an option can buy (call) or sell (put) the underlying asset. Applicable to options, swaptions, and structured derivatives with embedded optionality.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:uti rdf:type rdf:Property ;
    rdfs:label 'Uti' ;
    rdfs:comment 'Globally unique identifier assigned to each derivative transaction for trade repository reporting under EMIR and Dodd-Frank regulations.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parValueCurrencyId rdf:type rdf:Property ;
    rdfs:label 'Par Value Currency Id' ;
    rdfs:comment 'Foreign key linking to reference.currency. Business justification: Par value currency determines corporate action entitlements (stock splits, dividends). Distinct from trading currency. Essential for accurate entitlement calculations in multi-currency equity portfoli' ;
    rdfs:domain ind:Equity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:adrRatio rdf:type rdf:Property ;
    rdfs:label 'Adr Ratio' ;
    rdfs:comment 'Ratio expressing how many underlying foreign shares one ADR represents (e.g., 1:5 means one ADR equals five foreign shares).' ;
    rdfs:domain ind:Equity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:convertibleFlag rdf:type rdf:Property ;
    rdfs:label 'Convertible Flag' ;
    rdfs:comment 'Indicates whether this equity is convertible into another class of equity or security.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cumulativeDividendFlag rdf:type rdf:Property ;
    rdfs:label 'Cumulative Dividend Flag' ;
    rdfs:comment 'Indicates whether unpaid dividends on preferred stock accumulate and must be paid before common stock dividends.' ;
    rdfs:domain ind:Equity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:delistingDate rdf:type rdf:Property ;
    rdfs:label 'Delisting Date' ;
    rdfs:comment 'Date on which the equity was removed from exchange listing, if applicable.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:depositaryBank rdf:type rdf:Property ;
    rdfs:label 'Depositary Bank' ;
    rdfs:comment 'Name of the financial institution acting as depositary for ADRs or GDRs.' ;
    rdfs:domain ind:Equity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dividendEligibility rdf:type rdf:Property ;
    rdfs:label 'Dividend Eligibility' ;
    rdfs:comment 'Indicates whether this equity class is eligible to receive dividend distributions.' ;
    rdfs:domain ind:Equity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dividendFrequency rdf:type rdf:Property ;
    rdfs:label 'Dividend Frequency' ;
    rdfs:comment 'Frequency at which dividends are paid to shareholders.' ;
    rdfs:domain ind:Equity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dividendRate rdf:type rdf:Property ;
    rdfs:label 'Dividend Rate' ;
    rdfs:comment 'Annual dividend rate per share for preferred stock or fixed-dividend equities, expressed as a percentage of par value or absolute amount.' ;
    rdfs:domain ind:Equity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:equityName rdf:type rdf:Property ;
    rdfs:label 'Equity Name' ;
    rdfs:comment 'Full legal name of the equity security as registered with the issuer and exchange.' ;
    rdfs:domain ind:Equity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equityStatus rdf:type rdf:Property ;
    rdfs:label 'Equity Status' ;
    rdfs:comment 'Current lifecycle status of the equity instrument.' ;
    rdfs:domain ind:Equity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equityType rdf:type rdf:Property ;
    rdfs:label 'Equity Type' ;
    rdfs:comment 'Classification of the equity instrument: common stock, preferred stock, American Depositary Receipt (ADR), Global Depositary Receipt (GDR), Exchange-Traded Fund (ETF), or Real Estate Investment Trust (REIT).' ;
    rdfs:domain ind:Equity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:floatShares rdf:type rdf:Property ;
    rdfs:label 'Float Shares' ;
    rdfs:comment 'Number of shares available for public trading, excluding restricted shares held by insiders and large institutional holders.' ;
    rdfs:domain ind:Equity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gicsIndustryCode rdf:type rdf:Property ;
    rdfs:label 'Gics Industry Code' ;
    rdfs:comment 'Six-digit code representing the GICS industry classification of the issuer.' ;
    rdfs:domain ind:Equity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gicsIndustryGroupCode rdf:type rdf:Property ;
    rdfs:label 'Gics Industry Group Code' ;
    rdfs:comment 'Four-digit code representing the GICS industry group classification of the issuer.' ;
    rdfs:domain ind:Equity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gicsSectorCode rdf:type rdf:Property ;
    rdfs:label 'Gics Sector Code' ;
    rdfs:comment 'Two-digit code representing the GICS sector classification of the issuer (e.g., 10=Energy, 20=Materials, 45=Information Technology).' ;
    rdfs:domain ind:Equity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gicsSubIndustryCode rdf:type rdf:Property ;
    rdfs:label 'Gics Sub Industry Code' ;
    rdfs:comment 'Eight-digit code representing the most granular GICS sub-industry classification of the issuer.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indexMembership rdf:type rdf:Property ;
    rdfs:label 'Index Membership' ;
    rdfs:comment 'Comma-separated list of major indices in which this equity is a constituent (e.g., S&P 500, DJIA, NASDAQ-100, MSCI World, Russell 2000).' ;
    rdfs:domain ind:Equity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:listingDate rdf:type rdf:Property ;
    rdfs:label 'Listing Date' ;
    rdfs:comment 'Date on which the equity was first listed and began trading on the primary exchange.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:marketCapTier rdf:type rdf:Property ;
    rdfs:label 'Market Cap Tier' ;
    rdfs:comment 'Classification of the equity based on market capitalization size: mega-cap (>$200B), large-cap ($10B-$200B), mid-cap ($2B-$10B), small-cap ($300M-$2B), micro-cap ($50M-$300M), nano-cap (<$50M).' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parValue rdf:type rdf:Property ;
    rdfs:label 'Par Value' ;
    rdfs:comment 'Nominal or face value of one share as stated in the corporate charter, used for accounting and legal purposes.' ;
    rdfs:domain ind:Equity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:participatingFlag rdf:type rdf:Property ;
    rdfs:label 'Participating Flag' ;
    rdfs:comment 'Indicates whether preferred stockholders can receive additional dividends beyond the stated rate if common stockholders receive dividends above a certain threshold.' ;
    rdfs:domain ind:Equity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryExchange rdf:type rdf:Property ;
    rdfs:label 'Primary Exchange' ;
    rdfs:comment 'Market Identifier Code (MIC) of the primary exchange where the equity is listed and traded.' ;
    rdfs:domain ind:Equity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:puttableFlag rdf:type rdf:Property ;
    rdfs:label 'Puttable Flag' ;
    rdfs:comment 'Indicates whether the holder has the right to sell the equity back to the issuer at a predetermined price (applicable to preferred stock).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shareClass rdf:type rdf:Property ;
    rdfs:label 'Share Class' ;
    rdfs:comment 'Designation of the share class (e.g., Class A, Class B, Class C) indicating different rights, voting power, or dividend structures.' ;
    rdfs:domain ind:Equity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sharesAuthorized rdf:type rdf:Property ;
    rdfs:label 'Shares Authorized' ;
    rdfs:comment 'Maximum number of shares the corporation is legally permitted to issue as defined in the corporate charter.' ;
    rdfs:domain ind:Equity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tickerSymbol rdf:type rdf:Property ;
    rdfs:label 'Ticker Symbol' ;
    rdfs:comment 'Exchange-specific trading symbol used to identify the equity on trading platforms.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradingStatus rdf:type rdf:Property ;
    rdfs:label 'Trading Status' ;
    rdfs:comment 'Current real-time trading status on the exchange.' ;
    rdfs:domain ind:Equity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:underlyingSecurityIsin rdf:type rdf:Property ;
    rdfs:label 'Underlying Security Isin' ;
    rdfs:comment 'ISIN of the underlying foreign security for ADRs and GDRs.' ;
    rdfs:domain ind:Equity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:votingRights rdf:type rdf:Property ;
    rdfs:label 'Voting Rights' ;
    rdfs:comment 'Indicates whether the equity carries voting rights and the type: voting (standard one share one vote), non-voting, limited voting, or super voting (multiple votes per share).' ;
    rdfs:domain ind:Equity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callPrice rdf:type rdf:Property ;
    rdfs:label 'Call Price' ;
    rdfs:comment 'Price at which the issuer may redeem the bond if the call option is exercised. Often expressed as a percentage of face value plus accrued interest.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:convexity rdf:type rdf:Property ;
    rdfs:label 'Convexity' ;
    rdfs:comment 'Measure of the curvature in the relationship between bond prices and yields. Used to refine duration-based interest rate risk estimates for large rate movements.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:couponFrequency rdf:type rdf:Property ;
    rdfs:label 'Coupon Frequency' ;
    rdfs:comment 'Frequency at which coupon interest payments are made to bondholders. Determines the number of payment periods per year and cash flow timing.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:duration rdf:type rdf:Property ;
    rdfs:label 'Duration' ;
    rdfs:comment 'Measure of the bond\'s price sensitivity to changes in interest rates, expressed in years. Critical for interest rate risk management and ALM gap analysis.' ;
    rdfs:domain ind:FixedIncome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:firstCouponDate rdf:type rdf:Property ;
    rdfs:label 'First Coupon Date' ;
    rdfs:comment 'Date of the first scheduled coupon payment. May differ from a regular period if the bond has an odd first coupon period.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fixedIncomeStatus rdf:type rdf:Property ;
    rdfs:label 'Fixed Income Status' ;
    rdfs:comment 'Current state of the bond in its lifecycle. Active bonds are trading normally, matured bonds have reached their maturity date, called bonds have been redeemed early, defaulted bonds have missed payments.' ;
    rdfs:domain ind:FixedIncome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:floatingRateIndex rdf:type rdf:Property ;
    rdfs:label 'Floating Rate Index' ;
    rdfs:comment 'Reference interest rate index to which the coupon rate is linked for floating-rate bonds. Common indices include SOFR, LIBOR, EURIBOR, and Treasury rates.' ;
    rdfs:domain ind:FixedIncome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:floatingRateSpread rdf:type rdf:Property ;
    rdfs:label 'Floating Rate Spread' ;
    rdfs:comment 'Fixed spread in basis points added to the reference index rate to determine the coupon rate for floating-rate bonds. Reflects issuer credit risk and market conditions at issuance.' ;
    rdfs:domain ind:FixedIncome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:instrumentName rdf:type rdf:Property ;
    rdfs:label 'Instrument Name' ;
    rdfs:comment 'Full legal name or description of the fixed income security as registered with the issuer and regulatory authorities.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuerCountryCode rdf:type rdf:Property ;
    rdfs:label 'Issuer Country Code' ;
    rdfs:comment 'Three-letter ISO country code representing the country of domicile of the bond issuer. Used for country risk assessment and regulatory capital calculations.' ;
    rdfs:domain ind:FixedIncome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastCouponDate rdf:type rdf:Property ;
    rdfs:label 'Last Coupon Date' ;
    rdfs:comment 'Date of the final scheduled coupon payment before maturity. Typically occurs on or shortly before the maturity date.' ;
    rdfs:domain ind:FixedIncome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:marketPrice rdf:type rdf:Property ;
    rdfs:label 'Market Price' ;
    rdfs:comment 'Most recent trading price or valuation of the bond in the secondary market, typically expressed as a percentage of face value. Used for mark-to-market valuation and PnL calculation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceDate rdf:type rdf:Property ;
    rdfs:label 'Price Date' ;
    rdfs:comment 'Date on which the current market price was observed or calculated. Critical for fair value accounting and regulatory reporting.' ;
    rdfs:domain ind:FixedIncome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:putDate rdf:type rdf:Property ;
    rdfs:label 'Put Date' ;
    rdfs:comment 'Earliest date on which the bondholder may exercise the put option to sell the bond back to the issuer. Null if the bond is not puttable.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:putPrice rdf:type rdf:Property ;
    rdfs:label 'Put Price' ;
    rdfs:comment 'Price at which the bondholder may sell the bond back to the issuer if the put option is exercised. Typically at or near par value.' ;
    rdfs:domain ind:FixedIncome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resetFrequency rdf:type rdf:Property ;
    rdfs:label 'Reset Frequency' ;
    rdfs:comment 'Frequency at which the coupon rate is recalculated based on the current reference index rate for floating-rate bonds. Determines interest rate risk exposure.' ;
    rdfs:domain ind:FixedIncome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sinkingFundFlag rdf:type rdf:Property ;
    rdfs:label 'Sinking Fund Flag' ;
    rdfs:comment 'Indicates whether the bond has a sinking fund provision requiring the issuer to retire a portion of the bond issue periodically before maturity. Reduces credit risk but may limit upside.' ;
    rdfs:domain ind:FixedIncome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:yieldToMaturity rdf:type rdf:Property ;
    rdfs:label 'Yield To Maturity' ;
    rdfs:comment 'Total return anticipated on the bond if held until maturity, expressed as an annual rate. Incorporates coupon payments, principal repayment, and current market price.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:identifierId rdf:type rdf:Property ;
    rdfs:label 'Identifier Id' ;
    rdfs:comment 'Primary key for identifier' ;
    rdfs:domain ind:Identifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:compositeIdentifierFlag rdf:type rdf:Property ;
    rdfs:label 'Composite Identifier Flag' ;
    rdfs:comment 'Boolean flag indicating whether this identifier is a composite or concatenated identifier formed from multiple components (e.g., ticker + exchange code). True indicates composite; False indicates atomic identifier.' ;
    rdfs:domain ind:Identifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:countryOfIssuance rdf:type rdf:Property ;
    rdfs:label 'Country Of Issuance' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the country where the identifier was issued or where the issuing authority is domiciled. Examples include USA, GBR, DEU, JPN. Used for regulatory reporting and geographic segmentation.' ;
    rdfs:domain ind:Identifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeCode rdf:type rdf:Property ;
    rdfs:label 'Exchange Code' ;
    rdfs:comment 'Market Identifier Code (MIC) or exchange code where this identifier is recognized or traded. Examples include XNYS (New York Stock Exchange), XNAS (NASDAQ), XLON (London Stock Exchange). Applicable primarily for ticker symbols and exchange-specific identifiers.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identifierDescription rdf:type rdf:Property ;
    rdfs:label 'Identifier Description' ;
    rdfs:comment 'Free-text description or additional context about this identifier. May include notes on usage, special handling instructions, or clarifications on identifier scope and applicability.' ;
    rdfs:domain ind:Identifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indexConstituentId rdf:type rdf:Property ;
    rdfs:label 'Index Constituent Id' ;
    rdfs:comment 'Unique identifier for the index constituent membership record.' ;
    rdfs:domain ind:IndexConstituent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:indexInstrumentId rdf:type rdf:Property ;
    rdfs:label 'Index Instrument Id' ;
    rdfs:comment 'Reference to the financial index (S&P 500, MSCI World, Bloomberg Barclays Aggregate, CDX, iTraxx) to which this constituent belongs.' ;
    rdfs:domain ind:IndexConstituent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Instrument .

ind:benchmarkEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Benchmark Eligible Flag' ;
    rdfs:comment 'Indicates whether this constituent is eligible for use in benchmark attribution and performance measurement.' ;
    rdfs:domain ind:IndexConstituent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cappingFactor rdf:type rdf:Property ;
    rdfs:label 'Capping Factor' ;
    rdfs:comment 'The capping adjustment factor applied to limit the maximum weight of this constituent in the index, used for diversification requirements.' ;
    rdfs:domain ind:IndexConstituent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:constituentStatus rdf:type rdf:Property ;
    rdfs:label 'Constituent Status' ;
    rdfs:comment 'Current membership status of the security within the index.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryClassification rdf:type rdf:Property ;
    rdfs:label 'Country Classification' ;
    rdfs:comment 'The country classification assigned to this constituent for index purposes, typically based on domicile or primary listing location.' ;
    rdfs:domain ind:IndexConstituent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:etfCreationBasketFlag rdf:type rdf:Property ;
    rdfs:label 'Etf Creation Basket Flag' ;
    rdfs:comment 'Indicates whether this constituent is included in the ETF creation/redemption basket for index-tracking ETFs.' ;
    rdfs:domain ind:IndexConstituent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exclusionDate rdf:type rdf:Property ;
    rdfs:label 'Exclusion Date' ;
    rdfs:comment 'The date on which the security was removed from the index, if applicable. Null for active constituents.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:freeFloatFactor rdf:type rdf:Property ;
    rdfs:label 'Free Float Factor' ;
    rdfs:comment 'The free float adjustment factor applied to this constituent, representing the proportion of shares available for public trading (0 to 1).' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inclusionDate rdf:type rdf:Property ;
    rdfs:label 'Inclusion Date' ;
    rdfs:comment 'The date on which the security was added to the index as a constituent member.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:indexCode rdf:type rdf:Property ;
    rdfs:label 'Index Code' ;
    rdfs:comment 'The standard market code or ticker symbol for the index (e.g., SPX for S&P 500, MXWO for MSCI World).' ;
    rdfs:domain ind:IndexConstituent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indexDivisorImpact rdf:type rdf:Property ;
    rdfs:label 'Index Divisor Impact' ;
    rdfs:comment 'The impact of this constituent change on the index divisor, used to maintain index continuity during rebalancing events.' ;
    rdfs:domain ind:IndexConstituent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:indexFamily rdf:type rdf:Property ;
    rdfs:label 'Index Family' ;
    rdfs:comment 'The family or series to which this index belongs (e.g., S&P 500 family, MSCI World family).' ;
    rdfs:domain ind:IndexConstituent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indexProvider rdf:type rdf:Property ;
    rdfs:label 'Index Provider' ;
    rdfs:comment 'The organization that publishes and maintains the index (e.g., S&P Dow Jones Indices, MSCI, FTSE Russell, Bloomberg).' ;
    rdfs:domain ind:IndexConstituent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indexType rdf:type rdf:Property ;
    rdfs:label 'Index Type' ;
    rdfs:comment 'The asset class type of the index to which this constituent belongs.' ;
    rdfs:domain ind:IndexConstituent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indexWeight rdf:type rdf:Property ;
    rdfs:label 'Index Weight' ;
    rdfs:comment 'The proportional weight of this constituent within the index, expressed as a decimal (e.g., 0.0325 for 3.25%). Used for weighted index calculations.' ;
    rdfs:domain ind:IndexConstituent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:industryClassification rdf:type rdf:Property ;
    rdfs:label 'Industry Classification' ;
    rdfs:comment 'The industry classification of this constituent within the index framework, providing finer granularity than sector.' ;
    rdfs:domain ind:IndexConstituent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liquidityScore rdf:type rdf:Property ;
    rdfs:label 'Liquidity Score' ;
    rdfs:comment 'A quantitative score representing the trading liquidity of this constituent, used for index eligibility and weighting decisions.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketCapWeight rdf:type rdf:Property ;
    rdfs:label 'Market Cap Weight' ;
    rdfs:comment 'The market capitalization-based weight of this constituent, used for market-cap weighted indices. Represents the proportion of total index market cap.' ;
    rdfs:domain ind:IndexConstituent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumLiquidityThreshold rdf:type rdf:Property ;
    rdfs:label 'Minimum Liquidity Threshold' ;
    rdfs:comment 'The minimum liquidity threshold (typically measured in average daily trading volume or value) required for this constituent to remain in the index.' ;
    rdfs:domain ind:IndexConstituent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parWeight rdf:type rdf:Property ;
    rdfs:label 'Par Weight' ;
    rdfs:comment 'The par value-based weight for bond index constituents, representing the proportion of total index par value. Applicable primarily to fixed income indices.' ;
    rdfs:domain ind:IndexConstituent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:passiveInvestmentEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Passive Investment Eligible Flag' ;
    rdfs:comment 'Indicates whether this constituent is eligible for inclusion in passive investment strategies and index-tracking portfolios.' ;
    rdfs:domain ind:IndexConstituent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rebalancingEventDate rdf:type rdf:Property ;
    rdfs:label 'Rebalancing Event Date' ;
    rdfs:comment 'The date on which the rebalancing event occurred that affected this constituent membership or weight.' ;
    rdfs:domain ind:IndexConstituent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rebalancingEventType rdf:type rdf:Property ;
    rdfs:label 'Rebalancing Event Type' ;
    rdfs:comment 'The type of event that triggered the inclusion, exclusion, or weight adjustment of this constituent. [ENUM-REF-CANDIDATE: scheduled|corporate_action|market_cap_change|liquidity_review|sector_reclassification|ipo_inclusion|delisting|merger|acquisition|spin_off — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionClassification rdf:type rdf:Property ;
    rdfs:label 'Region Classification' ;
    rdfs:comment 'The regional classification of this constituent within the index framework.' ;
    rdfs:domain ind:IndexConstituent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sectorClassification rdf:type rdf:Property ;
    rdfs:label 'Sector Classification' ;
    rdfs:comment 'The sector classification of this constituent within the index framework (e.g., Technology, Financials, Healthcare).' ;
    rdfs:domain ind:IndexConstituent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sharesHeld rdf:type rdf:Property ;
    rdfs:label 'Shares Held' ;
    rdfs:comment 'The number of shares of this security held in the index for calculation purposes. Used in share-weighted and market-cap weighted indices.' ;
    rdfs:domain ind:IndexConstituent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceRecordReference rdf:type rdf:Property ;
    rdfs:label 'Source Record Reference' ;
    rdfs:comment 'The unique identifier of this constituent record in the source system.' ;
    rdfs:domain ind:IndexConstituent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightPercentage rdf:type rdf:Property ;
    rdfs:label 'Weight Percentage' ;
    rdfs:comment 'The weight of this constituent expressed as a percentage of the total index (e.g., 3.25000 for 3.25%). Derived from index_weight for reporting convenience.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightingMethodology rdf:type rdf:Property ;
    rdfs:label 'Weighting Methodology' ;
    rdfs:comment 'The methodology used to calculate the weight of this constituent within the index. [ENUM-REF-CANDIDATE: market_cap|equal_weight|fundamental|price_weighted|float_adjusted|gdp_weighted|revenue_weighted — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:IndexConstituent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuanceCountryId rdf:type rdf:Property ;
    rdfs:label 'Issuance Country Id' ;
    rdfs:comment 'Foreign key linking to reference.country. Business justification: Country of issuance determines legal jurisdiction, tax treatment, and regulatory reporting requirements. Critical for sanctions screening, country risk limits, and Basel country exposure reporting. Ro' ;
    rdfs:domain ind:Instrument ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:lotSize rdf:type rdf:Property ;
    rdfs:label 'Lot Size' ;
    rdfs:comment 'Minimum trading unit or contract size for the instrument. Represents the number of units per lot.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optionType rdf:type rdf:Property ;
    rdfs:label 'Option Type' ;
    rdfs:comment 'Specifies whether the option is a call (right to buy) or put (right to sell).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seniority rdf:type rdf:Property ;
    rdfs:label 'Seniority' ;
    rdfs:comment 'Priority ranking of the instrument in the issuer\'s capital structure for claim settlement in case of default.' ;
    rdfs:domain ind:Instrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementConvention rdf:type rdf:Property ;
    rdfs:label 'Settlement Convention' ;
    rdfs:comment 'Standard number of business days between trade date and settlement date for this instrument.' ;
    rdfs:domain ind:Instrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Status Effective Date' ;
    rdfs:comment 'Date on which the current lifecycle status became effective.' ;
    rdfs:domain ind:Instrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tradingCurrency rdf:type rdf:Property ;
    rdfs:label 'Trading Currency' ;
    rdfs:comment '3-letter ISO currency code representing the currency in which the instrument is traded on the exchange.' ;
    rdfs:domain ind:Instrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instrumentLifecycleId rdf:type rdf:Property ;
    rdfs:label 'Instrument Lifecycle Id' ;
    rdfs:comment 'Unique identifier for the instrument lifecycle status record.' ;
    rdfs:domain ind:InstrumentLifecycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryInstrumentId rdf:type rdf:Property ;
    rdfs:label 'Primary Instrument Id' ;
    rdfs:comment 'Foreign key reference to the financial instrument in the instrument master. Links this lifecycle event to the specific security (equity, bond, derivative, MBS, ABS, CDS, CLO, CDO, or OTC instrument).' ;
    rdfs:domain ind:InstrumentLifecycle ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Instrument .

ind:creditRatingImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Credit Rating Impact Flag' ;
    rdfs:comment 'Boolean indicator of whether this lifecycle event triggered or resulted from a credit rating change. True for defaults, downgrades to distressed levels, or rating withdrawals.' ;
    rdfs:domain ind:InstrumentLifecycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lifecycleStage rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Stage' ;
    rdfs:comment 'Current lifecycle stage of the financial instrument. Pre-issuance indicates the instrument is registered but not yet trading; active indicates normal trading status; suspended indicates temporary halt; called indicates issuer has exercised call option; defaulted indicates issuer has failed to meet obligations; matured indicates instrument has reached maturity date; redeemed indicates early redemption; delisted indicates removal from exchange trading. [ENUM-REF-CANDIDATE: pre_issuance|active|suspended|called|defaulted|matured|redeemed|delisted — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InstrumentLifecycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskWeightAdjustmentFlag rdf:type rdf:Property ;
    rdfs:label 'Risk Weight Adjustment Flag' ;
    rdfs:comment 'Boolean indicator of whether this lifecycle change requires recalculation of Risk-Weighted Assets (RWA) for regulatory capital purposes under Basel III. True for defaults, rating changes, or maturity changes that affect risk weighting.' ;
    rdfs:domain ind:InstrumentLifecycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:settlementEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Settlement Eligibility Flag' ;
    rdfs:comment 'Boolean indicator of whether existing trades in this instrument can still settle through central clearing. May be false for defaulted or delisted instruments even if trading has ceased.' ;
    rdfs:domain ind:InstrumentLifecycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tradingEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Trading Eligibility Flag' ;
    rdfs:comment 'Boolean indicator of whether the instrument remains eligible for trading in this lifecycle stage. False for suspended, defaulted, matured, redeemed, or delisted instruments; true for active and pre-issuance stages.' ;
    rdfs:domain ind:InstrumentLifecycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:triggeringEventReference rdf:type rdf:Property ;
    rdfs:label 'Triggering Event Reference' ;
    rdfs:comment 'External reference identifier for the event that triggered this lifecycle change. May be a corporate action ID, regulatory filing number, exchange notice number, or credit event determination committee ruling reference.' ;
    rdfs:domain ind:InstrumentLifecycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Valuation Impact Flag' ;
    rdfs:comment 'Boolean indicator of whether this lifecycle change requires immediate portfolio revaluation. True for events like default, suspension, or delisting that materially affect fair value; false for routine transitions.' ;
    rdfs:domain ind:InstrumentLifecycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:instrumentRelationshipId rdf:type rdf:Property ;
    rdfs:label 'Instrument Relationship Id' ;
    rdfs:comment 'Unique identifier for the instrument relationship record. Primary key.' ;
    rdfs:domain ind:InstrumentRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceInstrumentId rdf:type rdf:Property ;
    rdfs:label 'Source Instrument Id' ;
    rdfs:comment 'Identifier of the source financial instrument in the relationship. For example, the convertible bond in a convertible-to-equity relationship, or the ADR in an ADR-to-ordinary-share relationship.' ;
    rdfs:domain ind:InstrumentRelationship ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Instrument .

ind:targetInstrumentId rdf:type rdf:Property ;
    rdfs:label 'Target Instrument Id' ;
    rdfs:comment 'Identifier of the target financial instrument in the relationship. For example, the underlying equity in a convertible-to-equity relationship, or the ordinary share underlying an ADR.' ;
    rdfs:domain ind:InstrumentRelationship ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Instrument .

ind:conversionCurrency rdf:type rdf:Property ;
    rdfs:label 'Conversion Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code in which the conversion price is denominated.' ;
    rdfs:domain ind:InstrumentRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionPrice rdf:type rdf:Property ;
    rdfs:label 'Conversion Price' ;
    rdfs:comment 'Price at which the source instrument can be converted into the target instrument. Applicable for convertible bonds, warrants, and similar instruments with conversion features.' ;
    rdfs:domain ind:InstrumentRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conversionRatio rdf:type rdf:Property ;
    rdfs:label 'Conversion Ratio' ;
    rdfs:comment 'Numeric ratio defining the conversion or exchange rate between the source and target instruments. For example, the number of ordinary shares received per convertible bond, or the ratio of ADR to underlying ordinary shares. Expressed as a decimal value.' ;
    rdfs:domain ind:InstrumentRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:corporateActionPropagationFlag rdf:type rdf:Property ;
    rdfs:label 'Corporate Action Propagation Flag' ;
    rdfs:comment 'Boolean flag indicating whether corporate actions on the target instrument should be propagated to the source instrument. True if propagation is required, false otherwise.' ;
    rdfs:domain ind:InstrumentRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lookThroughRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Look Through Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether regulatory look-through to the underlying instrument is required for transparency and reporting purposes under MiFID II, FRTB, or other regulatory frameworks. True if look-through is required, false otherwise.' ;
    rdfs:domain ind:InstrumentRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notionalCurrency rdf:type rdf:Property ;
    rdfs:label 'Notional Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code in which the notional amount is denominated.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipPriority rdf:type rdf:Property ;
    rdfs:label 'Relationship Priority' ;
    rdfs:comment 'Priority ranking of this relationship when multiple relationships exist for the same source instrument. Lower numbers indicate higher priority. Used to determine which relationship to apply in corporate actions and risk calculations.' ;
    rdfs:domain ind:InstrumentRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:riskAggregationFlag rdf:type rdf:Property ;
    rdfs:label 'Risk Aggregation Flag' ;
    rdfs:comment 'Boolean flag indicating whether risk exposures should be aggregated across the related instruments for risk management and regulatory capital calculations. True if aggregation is required, false otherwise.' ;
    rdfs:domain ind:InstrumentRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentIssuerId rdf:type rdf:Property ;
    rdfs:label 'Parent Issuer Id' ;
    rdfs:comment 'Reference to the immediate parent entity in the corporate hierarchy. Used for consolidated risk reporting and group exposure aggregation under Basel III.' ;
    rdfs:domain ind:Issuer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Issuer .

ind:primaryUltimateParentIssuerId rdf:type rdf:Property ;
    rdfs:label 'Primary Ultimate Parent Issuer Id' ;
    rdfs:comment 'Reference to the top-level parent entity in the corporate hierarchy. Critical for ultimate risk aggregation, large exposure monitoring, and CCAR/DFAST stress testing.' ;
    rdfs:domain ind:Issuer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Issuer .

ind:bloombergIssuerCode rdf:type rdf:Property ;
    rdfs:label 'Bloomberg Issuer Code' ;
    rdfs:comment 'Bloomberg\'s proprietary issuer identifier used for market data integration, pricing feeds, and reference data synchronization with Bloomberg Terminal.' ;
    rdfs:domain ind:Issuer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cvaAdjustment rdf:type rdf:Property ;
    rdfs:label 'Cva Adjustment' ;
    rdfs:comment 'The market value of counterparty credit risk for derivative exposures with this issuer. Required under Basel III CVA capital charge and IFRS 13 fair value accounting.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fitchIssuerRating rdf:type rdf:Property ;
    rdfs:label 'Fitch Issuer Rating' ;
    rdfs:comment 'Current long-term issuer default rating assigned by Fitch Ratings. Provides third opinion for credit risk triangulation.' ;
    rdfs:domain ind:Issuer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fitchRatingDate rdf:type rdf:Property ;
    rdfs:label 'Fitch Rating Date' ;
    rdfs:comment 'Date when the current Fitch issuer rating was assigned or last affirmed.' ;
    rdfs:domain ind:Issuer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fitchRatingOutlook rdf:type rdf:Property ;
    rdfs:label 'Fitch Rating Outlook' ;
    rdfs:comment 'Fitch\'s assessment of the potential direction of the issuer rating over a one to two-year period.' ;
    rdfs:domain ind:Issuer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incorporationJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Incorporation Jurisdiction' ;
    rdfs:comment 'The legal jurisdiction (country and state/province if applicable) where the issuer is incorporated or legally established. May differ from domicile country for tax optimization structures.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalLgd rdf:type rdf:Property ;
    rdfs:label 'Internal Lgd' ;
    rdfs:comment 'Bank\'s estimate of the economic loss as a percentage of Exposure at Default if the issuer defaults. Expressed as percentage (e.g., 45.00 = 45%). Used for IRB capital and expected loss calculations.' ;
    rdfs:domain ind:Issuer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:internalPd rdf:type rdf:Property ;
    rdfs:label 'Internal Pd' ;
    rdfs:comment 'Bank\'s estimate of the one-year probability of default for the issuer, expressed as a decimal (e.g., 0.015 = 1.5%). Core input for IRB capital calculations and CECL/IFRS 9 expected credit loss provisioning.' ;
    rdfs:domain ind:Issuer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isFinancialInstitution rdf:type rdf:Property ;
    rdfs:label 'Is Financial Institution' ;
    rdfs:comment 'Boolean indicator whether the issuer is classified as a financial institution under Basel III. Determines interbank exposure treatment and contagion risk assessment.' ;
    rdfs:domain ind:Issuer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isInvestmentGrade rdf:type rdf:Property ;
    rdfs:label 'Is Investment Grade' ;
    rdfs:comment 'Boolean indicator whether the issuer\'s credit rating meets investment grade threshold (BBB-/Baa3 or higher). Used for portfolio mandate compliance and risk appetite limits.' ;
    rdfs:domain ind:Issuer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPublicSectorEntity rdf:type rdf:Property ;
    rdfs:label 'Is Public Sector Entity' ;
    rdfs:comment 'Boolean indicator whether the issuer is a public sector entity eligible for preferential risk weighting under Basel III Standardized Approach.' ;
    rdfs:domain ind:Issuer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSanctionedEntity rdf:type rdf:Property ;
    rdfs:label 'Is Sanctioned Entity' ;
    rdfs:comment 'Boolean indicator whether the issuer is subject to economic sanctions by OFAC, EU, UN, or other sanctioning authorities. Critical for AML/CFT compliance and transaction screening.' ;
    rdfs:domain ind:Issuer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuerStatus rdf:type rdf:Property ;
    rdfs:label 'Issuer Status' ;
    rdfs:comment 'Current lifecycle status of the issuer entity. Inactive, merged, or bankrupt issuers require special handling for legacy securities and credit event processing.' ;
    rdfs:domain ind:Issuer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moodysIssuerRating rdf:type rdf:Property ;
    rdfs:label 'Moodys Issuer Rating' ;
    rdfs:comment 'Current long-term issuer rating assigned by Moody\'s Investors Service. Used for credit risk assessment, portfolio limits, and regulatory capital calculations.' ;
    rdfs:domain ind:Issuer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moodysRatingDate rdf:type rdf:Property ;
    rdfs:label 'Moodys Rating Date' ;
    rdfs:comment 'Date when the current Moody\'s issuer rating was assigned or last affirmed.' ;
    rdfs:domain ind:Issuer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:moodysRatingOutlook rdf:type rdf:Property ;
    rdfs:label 'Moodys Rating Outlook' ;
    rdfs:comment 'Moody\'s opinion on the likely direction of the issuer rating over the medium term.' ;
    rdfs:domain ind:Issuer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryExchangeCode rdf:type rdf:Property ;
    rdfs:label 'Primary Exchange Code' ;
    rdfs:comment 'ISO 10383 Market Identifier Code (MIC) for the issuer\'s primary listing exchange. Used for market data sourcing and trading venue identification.' ;
    rdfs:domain ind:Issuer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spIssuerCreditRating rdf:type rdf:Property ;
    rdfs:label 'Sp Issuer Credit Rating' ;
    rdfs:comment 'Current long-term issuer credit rating assigned by Standard & Poor\'s. Used for credit risk assessment, RWA calculation under Standardized Approach, and investment policy compliance.' ;
    rdfs:domain ind:Issuer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spRatingDate rdf:type rdf:Property ;
    rdfs:label 'Sp Rating Date' ;
    rdfs:comment 'Date when the current S&P issuer credit rating was assigned or last affirmed. Critical for determining rating staleness in credit risk models.' ;
    rdfs:domain ind:Issuer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:spRatingOutlook rdf:type rdf:Property ;
    rdfs:label 'Sp Rating Outlook' ;
    rdfs:comment 'S&P\'s forward-looking opinion on the potential direction of the issuer credit rating over the intermediate term (typically 6-24 months).' ;
    rdfs:domain ind:Issuer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:circuitBreakerThresholdPct rdf:type rdf:Property ;
    rdfs:label 'Circuit Breaker Threshold Pct' ;
    rdfs:comment 'Price movement threshold percentage that triggers automatic trading halt or circuit breaker for this listing.' ;
    rdfs:domain ind:Listing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentRecordFlag rdf:type rdf:Property ;
    rdfs:label 'Current Record Flag' ;
    rdfs:comment 'Indicates whether this is the current active version of the listing record in a slowly changing dimension (SCD) Type 2 history.' ;
    rdfs:domain ind:Listing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:effectiveFromTimestamp rdf:type rdf:Property ;
    rdfs:label 'Effective From Timestamp' ;
    rdfs:comment 'Timestamp from which this version of the listing record is effective, supporting slowly changing dimension (SCD) Type 2 historization.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:effectiveToTimestamp rdf:type rdf:Property ;
    rdfs:label 'Effective To Timestamp' ;
    rdfs:comment 'Timestamp until which this version of the listing record is effective. Null indicates current active record.' ;
    rdfs:domain ind:Listing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:exchangeTickerSymbol rdf:type rdf:Property ;
    rdfs:label 'Exchange Ticker Symbol' ;
    rdfs:comment 'Exchange-specific ticker or trading symbol used to identify the security on this particular exchange.' ;
    rdfs:domain ind:Listing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isinCode rdf:type rdf:Property ;
    rdfs:label 'Isin Code' ;
    rdfs:comment 'ISO 6166 twelve-character alphanumeric code uniquely identifying the security globally. Included here for denormalized reference and regulatory reporting convenience.' ;
    rdfs:domain ind:Listing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastTradingDate rdf:type rdf:Property ;
    rdfs:label 'Last Trading Date' ;
    rdfs:comment 'Final date on which the security can be traded on this exchange before expiry or delisting. Applicable primarily to derivatives and structured products.' ;
    rdfs:domain ind:Listing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:listingStatus rdf:type rdf:Property ;
    rdfs:label 'Listing Status' ;
    rdfs:comment 'Current trading status of the listing on the exchange. Active indicates normal trading; suspended indicates temporary halt due to regulatory or corporate action; halted indicates intraday trading pause; delisted indicates removed from exchange; pending indicates listing application in progress.' ;
    rdfs:domain ind:Listing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:listingType rdf:type rdf:Property ;
    rdfs:label 'Listing Type' ;
    rdfs:comment 'Classification of the listing relationship. Primary indicates home exchange; secondary indicates additional listing; dual indicates simultaneous primary listing on multiple exchanges; ADR indicates American Depositary Receipt; GDR indicates Global Depositary Receipt.' ;
    rdfs:domain ind:Listing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localInstrumentCode rdf:type rdf:Property ;
    rdfs:label 'Local Instrument Code' ;
    rdfs:comment 'Exchange-specific instrument identifier or code assigned by the listing exchange for internal reference and order routing.' ;
    rdfs:domain ind:Listing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketDataSubscriptionTier rdf:type rdf:Property ;
    rdfs:label 'Market Data Subscription Tier' ;
    rdfs:comment 'Exchange-defined tier or package level for market data distribution rights for this listing (e.g., Level 1, Level 2, Premium).' ;
    rdfs:domain ind:Listing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketMakerRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Market Maker Required Flag' ;
    rdfs:comment 'Indicates whether designated market makers or liquidity providers are required for this listing under exchange rules.' ;
    rdfs:domain ind:Listing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mifidLiquidFlag rdf:type rdf:Property ;
    rdfs:label 'Mifid Liquid Flag' ;
    rdfs:comment 'Indicates whether this listing is classified as a liquid instrument under MiFID II transparency and best execution requirements.' ;
    rdfs:domain ind:Listing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priceBandLowerPct rdf:type rdf:Property ;
    rdfs:label 'Price Band Lower Pct' ;
    rdfs:comment 'Lower limit percentage for intraday price movement relative to reference price, beyond which orders are rejected or trading is paused.' ;
    rdfs:domain ind:Listing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceBandUpperPct rdf:type rdf:Property ;
    rdfs:label 'Price Band Upper Pct' ;
    rdfs:comment 'Upper limit percentage for intraday price movement relative to reference price, beyond which orders are rejected or trading is paused.' ;
    rdfs:domain ind:Listing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceMultiplier rdf:type rdf:Property ;
    rdfs:label 'Price Multiplier' ;
    rdfs:comment 'Multiplier applied to quoted price to calculate actual contract or notional value. Commonly used for derivatives and structured products.' ;
    rdfs:domain ind:Listing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryListingFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Listing Flag' ;
    rdfs:comment 'Indicates whether this is the primary or home exchange listing for the security. True for primary listing; false for secondary or cross-listings.' ;
    rdfs:domain ind:Listing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shortSellingAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Short Selling Allowed Flag' ;
    rdfs:comment 'Indicates whether short selling is permitted for this listing under current exchange and regulatory rules.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sponsor rdf:type rdf:Property ;
    rdfs:label 'Sponsor' ;
    rdfs:comment 'Name of the financial institution or broker-dealer sponsoring or facilitating the listing on this exchange.' ;
    rdfs:domain ind:Listing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tickSize rdf:type rdf:Property ;
    rdfs:label 'Tick Size' ;
    rdfs:comment 'Minimum price increment or tick size for this listing. Prices must move in multiples of this value.' ;
    rdfs:domain ind:Listing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tradingHoursEnd rdf:type rdf:Property ;
    rdfs:label 'Trading Hours End' ;
    rdfs:comment 'Local exchange time when regular trading session ends for this listing, in HH:MM format.' ;
    rdfs:domain ind:Listing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradingHoursStart rdf:type rdf:Property ;
    rdfs:label 'Trading Hours Start' ;
    rdfs:comment 'Local exchange time when regular trading session begins for this listing, in HH:MM format.' ;
    rdfs:domain ind:Listing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradingPhase rdf:type rdf:Property ;
    rdfs:label 'Trading Phase' ;
    rdfs:comment 'Current intraday trading phase or session state for this listing on the exchange.' ;
    rdfs:domain ind:Listing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradingTimezone rdf:type rdf:Property ;
    rdfs:label 'Trading Timezone' ;
    rdfs:comment 'IANA timezone identifier for the exchange trading hours (e.g., America/New_York, Europe/London, Asia/Tokyo).' ;
    rdfs:domain ind:Listing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradingVenueType rdf:type rdf:Property ;
    rdfs:label 'Trading Venue Type' ;
    rdfs:comment 'Classification of the trading venue under MiFID II. Regulated Market indicates traditional exchange; MTF indicates Multilateral Trading Facility; OTF indicates Organised Trading Facility; Systematic Internaliser indicates bank internal crossing.' ;
    rdfs:domain ind:Listing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByPriceId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Price Id' ;
    rdfs:comment 'Reference to the price_id of the corrected observation that supersedes this record. Null if this is the current valid observation.' ;
    rdfs:domain ind:Price ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Price .

ind:adjustedClosePrice rdf:type rdf:Property ;
    rdfs:label 'Adjusted Close Price' ;
    rdfs:comment 'The closing price adjusted for corporate actions (stock splits, dividends, rights issues) to maintain historical price continuity for performance analysis.' ;
    rdfs:domain ind:Price ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:askPrice rdf:type rdf:Property ;
    rdfs:label 'Ask Price' ;
    rdfs:comment 'The lowest price a seller is willing to accept for the security at the observation time. Used for liquidity analysis and bid-ask spread calculation.' ;
    rdfs:domain ind:Price ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:basis rdf:type rdf:Property ;
    rdfs:label 'Basis' ;
    rdfs:comment 'Indicates whether the price is clean (excluding accrued interest) or dirty (including accrued interest). Primarily applicable to fixed income securities.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bidPrice rdf:type rdf:Property ;
    rdfs:label 'Bid Price' ;
    rdfs:comment 'The highest price a buyer is willing to pay for the security at the observation time. Used for liquidity analysis and bid-ask spread calculation.' ;
    rdfs:domain ind:Price ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:changeAmount rdf:type rdf:Property ;
    rdfs:label 'Change Amount' ;
    rdfs:comment 'The absolute change in price from the previous observation, calculated as current price minus prior price. Used for volatility analysis and market movement tracking.' ;
    rdfs:domain ind:Price ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:changePercentage rdf:type rdf:Property ;
    rdfs:label 'Change Percentage' ;
    rdfs:comment 'The percentage change in price from the previous observation, calculated as ((current price - prior price) / prior price) * 100. Used for performance attribution and trend analysis.' ;
    rdfs:domain ind:Price ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:correctionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Correction Reason Code' ;
    rdfs:comment 'Standardized code explaining why a price observation was corrected or superseded. Supports audit trail and data quality monitoring.' ;
    rdfs:domain ind:Price ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:highPrice rdf:type rdf:Property ;
    rdfs:label 'High Price' ;
    rdfs:comment 'The highest traded price of the security during the trading session or observation period.' ;
    rdfs:domain ind:Price ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isSuperseded rdf:type rdf:Property ;
    rdfs:label 'Is Superseded' ;
    rdfs:comment 'Boolean flag indicating whether this price observation has been superseded by a subsequent correction or restatement. Supports immutable append-only architecture.' ;
    rdfs:domain ind:Price ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastTradePrice rdf:type rdf:Property ;
    rdfs:label 'Last Trade Price' ;
    rdfs:comment 'The price at which the most recent trade was executed for this instrument. Represents actual market transaction price.' ;
    rdfs:domain ind:Price ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lowPrice rdf:type rdf:Property ;
    rdfs:label 'Low Price' ;
    rdfs:comment 'The lowest traded price of the security during the trading session or observation period.' ;
    rdfs:domain ind:Price ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:midPrice rdf:type rdf:Property ;
    rdfs:label 'Mid Price' ;
    rdfs:comment 'The midpoint between bid and ask prices, calculated as (bid + ask) / 2. Commonly used for fair value estimation and portfolio valuation.' ;
    rdfs:domain ind:Price ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:notation rdf:type rdf:Property ;
    rdfs:label 'Notation' ;
    rdfs:comment 'The format in which the price is expressed: decimal (e.g., 105.50), percentage (e.g., 98.75%), yield (e.g., 3.25%), basis points, or fractional (e.g., 32nds for US Treasuries).' ;
    rdfs:domain ind:Price ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:observationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Observation Timestamp' ;
    rdfs:comment 'The timestamp when this price record was captured and appended to the immutable time-series. Distinct from pricing_timestamp; supports data lineage and audit.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:officialClosePrice rdf:type rdf:Property ;
    rdfs:label 'Official Close Price' ;
    rdfs:comment 'The official closing price published by the exchange or pricing authority at end of trading day. Used for Net Asset Value (NAV) calculation and regulatory reporting.' ;
    rdfs:domain ind:Price ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:openPrice rdf:type rdf:Property ;
    rdfs:label 'Open Price' ;
    rdfs:comment 'The first traded price of the security at the start of the trading session.' ;
    rdfs:domain ind:Price ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceSource rdf:type rdf:Property ;
    rdfs:label 'Price Source' ;
    rdfs:comment 'The originating system or vendor that provided this price observation (e.g., Bloomberg, Reuters/Refinitiv, exchange feed, broker quote, internal valuation model). [ENUM-REF-CANDIDATE: bloomberg|reuters|refinitiv|exchange_feed|broker_quote|internal_model|vendor — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Price ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceStatus rdf:type rdf:Property ;
    rdfs:label 'Price Status' ;
    rdfs:comment 'The current status of pricing for this instrument: active (normal trading), suspended (temporarily halted), halted (trading stopped), delisted (removed from exchange), matured (instrument expired).' ;
    rdfs:domain ind:Price ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceType rdf:type rdf:Property ;
    rdfs:label 'Price Type' ;
    rdfs:comment 'Classification of the price observation: market (actual traded price), model (derived from valuation model), indicative (non-binding quote), official (exchange-published), closing (end-of-day), opening (start-of-day).' ;
    rdfs:domain ind:Price ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pricing Timestamp' ;
    rdfs:comment 'The precise date and time when this price observation was recorded or became effective. Critical for intraday Mark-to-Market (MTM) and trade execution analysis.' ;
    rdfs:domain ind:Price ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:qualityFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Flag' ;
    rdfs:comment 'Indicator of the reliability and timeliness of the price observation. Verified = confirmed by multiple sources; stale = outdated; estimated = model-derived; challenged = disputed or under review.' ;
    rdfs:domain ind:Price ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryPriceFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Price Flag' ;
    rdfs:comment 'Boolean flag indicating whether this price observation is used for regulatory reporting purposes (e.g., CCAR, DFAST, Basel III stress testing, IFRS 9 fair value measurement).' ;
    rdfs:domain ind:Price ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:spreadToBenchmarkBps rdf:type rdf:Property ;
    rdfs:label 'Spread To Benchmark Bps' ;
    rdfs:comment 'The yield spread over a benchmark rate (e.g., LIBOR, SOFR, Treasury) expressed in basis points (BPS). Used for credit risk assessment and relative value analysis.' ;
    rdfs:domain ind:Price ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vwap rdf:type rdf:Property ;
    rdfs:label 'Vwap' ;
    rdfs:comment 'The average price weighted by trading volume over the observation period. Used for execution quality assessment and algorithmic trading benchmarks.' ;
    rdfs:domain ind:Price ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prospectusId rdf:type rdf:Property ;
    rdfs:label 'Prospectus Id' ;
    rdfs:comment 'Unique identifier for the prospectus record. Primary key.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Prospectus .

ind:offeringCurrencyId rdf:type rdf:Property ;
    rdfs:label 'Offering Currency Id' ;
    rdfs:comment 'Foreign key linking to reference.currency. Business justification: Offering terms are currency-specific for subscription processing and allocation. Essential for new issue processing, syndicate management, and investor subscription accounting in investment banking op' ;
    rdfs:domain ind:Prospectus ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:supersededProspectusId rdf:type rdf:Property ;
    rdfs:label 'Superseded Prospectus Id' ;
    rdfs:comment 'Reference to the previous prospectus that this document supersedes or amends.' ;
    rdfs:domain ind:Prospectus ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Prospectus .

ind:cikNumber rdf:type rdf:Property ;
    rdfs:label 'Cik Number' ;
    rdfs:comment 'SEC Central Index Key number identifying the issuer.' ;
    rdfs:domain ind:Prospectus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dividendPolicy rdf:type rdf:Property ;
    rdfs:label 'Dividend Policy' ;
    rdfs:comment 'Description of the issuers dividend policy as stated in the prospectus.' ;
    rdfs:domain ind:Prospectus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:extractionMethod rdf:type rdf:Property ;
    rdfs:label 'Extraction Method' ;
    rdfs:comment 'Method used to extract structured data from the prospectus document.' ;
    rdfs:domain ind:Prospectus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:greenshoeShares rdf:type rdf:Property ;
    rdfs:label 'Greenshoe Shares' ;
    rdfs:comment 'Number of additional shares available under the greenshoe option.' ;
    rdfs:domain ind:Prospectus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:legalCounselName rdf:type rdf:Property ;
    rdfs:label 'Legal Counsel Name' ;
    rdfs:comment 'Name of the law firm serving as legal counsel for the offering.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offeringAmount rdf:type rdf:Property ;
    rdfs:label 'Offering Amount' ;
    rdfs:comment 'Total monetary value of securities being offered under this prospectus.' ;
    rdfs:domain ind:Prospectus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricePerShare rdf:type rdf:Property ;
    rdfs:label 'Price Per Share' ;
    rdfs:comment 'Offering price per share or unit as stated in the prospectus.' ;
    rdfs:domain ind:Prospectus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prospectusStatus rdf:type rdf:Property ;
    rdfs:label 'Prospectus Status' ;
    rdfs:comment 'Current lifecycle status of the prospectus document. [ENUM-REF-CANDIDATE: draft|filed|effective|withdrawn|expired|amended|superseded — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Prospectus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskFactorsSummary rdf:type rdf:Property ;
    rdfs:label 'Risk Factors Summary' ;
    rdfs:comment 'Summary of key risk factors disclosed in the prospectus.' ;
    rdfs:domain ind:Prospectus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:underwriterLei rdf:type rdf:Property ;
    rdfs:label 'Underwriter Lei' ;
    rdfs:comment 'Legal Entity Identifier of the lead underwriter.' ;
    rdfs:domain ind:Prospectus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:underwriterName rdf:type rdf:Property ;
    rdfs:label 'Underwriter Name' ;
    rdfs:comment 'Name of the lead underwriter or investment bank managing the offering.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityWatchlistId rdf:type rdf:Property ;
    rdfs:label 'Security Watchlist Id' ;
    rdfs:comment 'Unique identifier for the security watchlist entry.' ;
    rdfs:domain ind:SecurityWatchlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:restrictedEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Restricted Employee Id' ;
    rdfs:comment 'Foreign key linking to hr.employee. Business justification: Banks maintain employee-specific security watchlists for compliance (insider trading, conflicts of interest, personal account restrictions). Pre-trade systems check if employee is restricted from trad' ;
    rdfs:domain ind:SecurityWatchlist ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:alertNotificationRecipients rdf:type rdf:Property ;
    rdfs:label 'Alert Notification Recipients' ;
    rdfs:comment 'Comma-separated list of email addresses or distribution lists to be notified when a transaction triggers this watchlist entry.' ;
    rdfs:domain ind:SecurityWatchlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableBusinessUnits rdf:type rdf:Property ;
    rdfs:label 'Applicable Business Units' ;
    rdfs:comment 'Comma-separated list of business units or Lines of Business (LOB) to which this restriction applies (e.g., Wealth Management, Asset Management, Proprietary Trading). Null indicates firm-wide restriction.' ;
    rdfs:domain ind:SecurityWatchlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableClientSegments rdf:type rdf:Property ;
    rdfs:label 'Applicable Client Segments' ;
    rdfs:comment 'Comma-separated list of client segments to which this restriction applies (e.g., retail, institutional, high_net_worth, pension_funds). Null indicates applies to all client types.' ;
    rdfs:domain ind:SecurityWatchlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bestExecutionImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Best Execution Impact Flag' ;
    rdfs:comment 'Indicates whether this restriction impacts best execution analysis and venue selection. True = restriction affects execution strategy, False = no best execution impact.' ;
    rdfs:domain ind:SecurityWatchlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:esgExclusionCategory rdf:type rdf:Property ;
    rdfs:label 'Esg Exclusion Category' ;
    rdfs:comment 'Category of ESG exclusion if the restriction is ESG-related (e.g., fossil fuels, tobacco, weapons, human rights violations, environmental damage). [ENUM-REF-CANDIDATE: fossil_fuels|tobacco|weapons|gambling|adult_entertainment|human_rights_violations|environmental_damage|animal_testing — promote to reference product]' ;
    rdfs:domain ind:SecurityWatchlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:listType rdf:type rdf:Property ;
    rdfs:label 'List Type' ;
    rdfs:comment 'Type of watchlist or restriction list. OFAC = Office of Foreign Assets Control sanctions, SDN = Specially Designated Nationals, restricted_securities = insider trading restrictions, investment_policy_exclusion = internal policy-based exclusions, ESG_exclusion = Environmental Social Governance screens, sector_exclusion = sector-based exclusions, regulatory_restricted = regulatory product governance restrictions. [ENUM-REF-CANDIDATE: OFAC|SDN|restricted_securities|investment_policy_exclusion|ESG_exclusion|sector_exclusion|regulatory_restricted — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postTradeMonitoringFlag rdf:type rdf:Property ;
    rdfs:label 'Post Trade Monitoring Flag' ;
    rdfs:comment 'Indicates whether executed trades should be monitored against this restriction for compliance reporting. True = post-trade surveillance active, False = no post-trade monitoring.' ;
    rdfs:domain ind:SecurityWatchlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preTradeCheckRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Pre Trade Check Required Flag' ;
    rdfs:comment 'Indicates whether this restriction must be checked before trade execution. True = pre-trade compliance check mandatory, False = post-trade monitoring only.' ;
    rdfs:domain ind:SecurityWatchlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:restrictionLevel rdf:type rdf:Property ;
    rdfs:label 'Restriction Level' ;
    rdfs:comment 'Severity level of the restriction. hard_block = trading is prohibited and will be rejected, soft_alert = trading is allowed but generates compliance alert, advisory = informational only.' ;
    rdfs:domain ind:SecurityWatchlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictionScope rdf:type rdf:Property ;
    rdfs:label 'Restriction Scope' ;
    rdfs:comment 'Scope of transactions affected by the restriction. all_transactions = applies to all buy and sell orders, buy_only = only new purchases restricted, sell_only = only sales restricted, new_positions = only opening new positions restricted, existing_positions = only existing holdings affected.' ;
    rdfs:domain ind:SecurityWatchlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Review Frequency Days' ;
    rdfs:comment 'Number of days between mandatory reviews of this watchlist entry. Used to calculate next_review_date.' ;
    rdfs:domain ind:SecurityWatchlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sectorExclusionCode rdf:type rdf:Property ;
    rdfs:label 'Sector Exclusion Code' ;
    rdfs:comment 'Industry sector code subject to exclusion using standard classification (e.g., GICS sector code, NAICS code). Used for sector-based investment policy restrictions.' ;
    rdfs:domain ind:SecurityWatchlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityWatchlistStatus rdf:type rdf:Property ;
    rdfs:label 'Security Watchlist Status' ;
    rdfs:comment 'Current lifecycle status of the watchlist entry. active = currently enforced, expired = past expiry date, suspended = temporarily not enforced, pending_approval = awaiting compliance approval, cancelled = permanently removed.' ;
    rdfs:domain ind:SecurityWatchlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suitabilityAssessmentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Suitability Assessment Required Flag' ;
    rdfs:comment 'Indicates whether client suitability assessment must be performed before allowing transactions in this security. True = suitability check mandatory, False = no suitability requirement.' ;
    rdfs:domain ind:SecurityWatchlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:referenceLoanAccountId rdf:type rdf:Property ;
    rdfs:label 'Reference Loan Account Id' ;
    rdfs:comment 'Foreign key linking to loan.loan_account. Business justification: Structured products referencing specific loan accounts in their collateral pool (e.g., CLO tranches backed by identified corporate loans) require account-level tracking for performance monitoring, def' ;
    rdfs:domain ind:StructuredProduct ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LoanAccount .

ind:underlyingLoanFacilityId rdf:type rdf:Property ;
    rdfs:label 'Underlying Loan Facility Id' ;
    rdfs:comment 'Foreign key linking to loan.facility. Business justification: Structured products (CLOs, loan-backed securities, ABS) backed by loan facilities require facility reference for collateral pool tracking, cash flow modeling, and credit risk assessment. Core securiti' ;
    rdfs:domain ind:StructuredProduct ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:capitalTreatment rdf:type rdf:Property ;
    rdfs:label 'Capital Treatment' ;
    rdfs:comment 'The regulatory capital approach applied to this structured product: Standardized Approach (SA), Internal Ratings-Based (IRB), or Securitization framework variants.' ;
    rdfs:domain ind:StructuredProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditEnhancementLevel rdf:type rdf:Property ;
    rdfs:label 'Credit Enhancement Level' ;
    rdfs:comment 'The percentage of credit protection provided through subordination, overcollateralization, or reserve accounts to protect senior tranches from losses.' ;
    rdfs:domain ind:StructuredProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentFaceValue rdf:type rdf:Property ;
    rdfs:label 'Current Face Value' ;
    rdfs:comment 'The current outstanding principal balance after accounting for amortization, prepayments, and defaults.' ;
    rdfs:domain ind:StructuredProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geographicConcentration rdf:type rdf:Property ;
    rdfs:label 'Geographic Concentration' ;
    rdfs:comment 'Primary geographic region or country where the underlying collateral is concentrated.' ;
    rdfs:domain ind:StructuredProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalFaceValue rdf:type rdf:Property ;
    rdfs:label 'Original Face Value' ;
    rdfs:comment 'The initial principal amount of the structured product at issuance.' ;
    rdfs:domain ind:StructuredProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:poolFactor rdf:type rdf:Property ;
    rdfs:label 'Pool Factor' ;
    rdfs:comment 'Ratio of current face value to original face value, representing the remaining principal as a decimal (e.g., 0.85 means 85% remaining).' ;
    rdfs:domain ind:StructuredProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prepaymentSpeedAssumption rdf:type rdf:Property ;
    rdfs:label 'Prepayment Speed Assumption' ;
    rdfs:comment 'The assumed rate of prepayment for the underlying collateral, expressed as PSA (Public Securities Association) percentage or CPR (Constant Prepayment Rate).' ;
    rdfs:domain ind:StructuredProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceRate rdf:type rdf:Property ;
    rdfs:label 'Reference Rate' ;
    rdfs:comment 'The benchmark interest rate used for floating-rate structured products (e.g., SOFR, LIBOR, EURIBOR).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rwa rdf:type rdf:Property ;
    rdfs:label 'Rwa' ;
    rdfs:comment 'The risk-weighted asset value calculated under Basel III standardized or internal ratings-based approach for regulatory capital requirements.' ;
    rdfs:domain ind:StructuredProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:servicerName rdf:type rdf:Property ;
    rdfs:label 'Servicer Name' ;
    rdfs:comment 'The name of the financial institution responsible for collecting payments from the underlying collateral and distributing them to investors.' ;
    rdfs:domain ind:StructuredProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:structuredProductStatus rdf:type rdf:Property ;
    rdfs:label 'Structured Product Status' ;
    rdfs:comment 'Current lifecycle status of the structured product.' ;
    rdfs:domain ind:StructuredProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trancheClass rdf:type rdf:Property ;
    rdfs:label 'Tranche Class' ;
    rdfs:comment 'Credit rating or seniority classification of the tranche indicating payment priority and risk level. [ENUM-REF-CANDIDATE: AAA|AA|A|BBB|BB|B|Mezzanine|Equity|Senior|Subordinated — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StructuredProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trancheIdentifier rdf:type rdf:Property ;
    rdfs:label 'Tranche Identifier' ;
    rdfs:comment 'Unique identifier for the specific tranche within the structured product deal.' ;
    rdfs:domain ind:StructuredProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wac rdf:type rdf:Property ;
    rdfs:label 'Wac' ;
    rdfs:comment 'The weighted average interest rate of the underlying collateral pool, expressed as a percentage.' ;
    rdfs:domain ind:StructuredProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wal rdf:type rdf:Property ;
    rdfs:label 'Wal' ;
    rdfs:comment 'The weighted average time until principal is repaid, expressed in years, accounting for prepayment assumptions.' ;
    rdfs:domain ind:StructuredProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wam rdf:type rdf:Property ;
    rdfs:label 'Wam' ;
    rdfs:comment 'The weighted average time to maturity of the underlying collateral pool, expressed in months.' ;
    rdfs:domain ind:StructuredProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collateralizationType rdf:type rdf:Property ;
    rdfs:label 'Collateralization Type' ;
    rdfs:comment 'Collateral arrangement assumed for derivative discounting (e.g., OIS-collateralized for CSA trades, uncollateralized for legacy trades).' ;
    rdfs:domain ind:YieldCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constructionDate rdf:type rdf:Property ;
    rdfs:label 'Construction Date' ;
    rdfs:comment 'The business date on which the yield curve was constructed. Represents the valuation date for the curve snapshot.' ;
    rdfs:domain ind:YieldCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:constructionMethodology rdf:type rdf:Property ;
    rdfs:label 'Construction Methodology' ;
    rdfs:comment 'Mathematical method used to construct the yield curve from market instrument prices (e.g., bootstrapping, Nelson-Siegel, cubic spline interpolation).' ;
    rdfs:domain ind:YieldCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constructionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Construction Timestamp' ;
    rdfs:comment 'Precise date and time when the yield curve was constructed or last recalculated, supporting intraday curve updates and audit trails.' ;
    rdfs:domain ind:YieldCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:curveName rdf:type rdf:Property ;
    rdfs:label 'Curve Name' ;
    rdfs:comment 'Business name or label for the yield curve (e.g., USD SOFR Swap Curve, EUR Government Curve, USD Corporate AA Spread Curve).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:curveNodesJson rdf:type rdf:Property ;
    rdfs:label 'Curve Nodes Json' ;
    rdfs:comment 'JSON-serialized array of tenor-rate nodes defining the complete curve shape. Each node includes tenor label, tenor in days, zero rate, par rate, forward rate, discount factor, and interpolation method. Supports full curve reconstruction for valuation and risk analytics.' ;
    rdfs:domain ind:YieldCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:curveShiftScenario rdf:type rdf:Property ;
    rdfs:label 'Curve Shift Scenario' ;
    rdfs:comment 'Name of the stress or shock scenario applied to the curve (e.g., +100 bps parallel shift, CCAR Severely Adverse). Null for base case curves.' ;
    rdfs:domain ind:YieldCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:curveStatus rdf:type rdf:Property ;
    rdfs:label 'Curve Status' ;
    rdfs:comment 'Current lifecycle status of the yield curve. Active curves are used for valuation; superseded curves are retained for historical analysis.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:curveType rdf:type rdf:Property ;
    rdfs:label 'Curve Type' ;
    rdfs:comment 'Classification of the yield curve by underlying instrument or market segment. Determines the curve\'s application in valuation and risk measurement. [ENUM-REF-CANDIDATE: government|swap|credit_spread|ois|corporate|treasury|libor|sofr|euribor — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:curveVersion rdf:type rdf:Property ;
    rdfs:label 'Curve Version' ;
    rdfs:comment 'Version number for the curve construction on a given date. Supports intraday curve revisions and audit trails.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:interpolationMethod rdf:type rdf:Property ;
    rdfs:label 'Interpolation Method' ;
    rdfs:comment 'Technique applied to interpolate rates between observed tenor nodes on the curve. Critical for pricing instruments with non-standard maturities.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRiskFree rdf:type rdf:Property ;
    rdfs:label 'Is Risk Free' ;
    rdfs:comment 'Flag indicating whether the curve represents a risk-free rate (e.g., government or OIS curve). True for risk-free curves, false for credit or spread curves.' ;
    rdfs:domain ind:YieldCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:longestTenorDays rdf:type rdf:Property ;
    rdfs:label 'Longest Tenor Days' ;
    rdfs:comment 'Tenor in days of the longest maturity node on the curve (e.g., 10950 for 30 years). Defines the curve\'s maximum extrapolation horizon.' ;
    rdfs:domain ind:YieldCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shortestTenorDays rdf:type rdf:Property ;
    rdfs:label 'Shortest Tenor Days' ;
    rdfs:comment 'Tenor in days of the shortest maturity node on the curve (e.g., 1 for overnight, 30 for 1-month).' ;
    rdfs:domain ind:YieldCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tenorCount rdf:type rdf:Property ;
    rdfs:label 'Tenor Count' ;
    rdfs:comment 'Number of tenor nodes (pillars) defining the curve shape. Typical curves have 8-15 nodes spanning overnight to 30 years.' ;
    rdfs:domain ind:YieldCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:valuationPurpose rdf:type rdf:Property ;
    rdfs:label 'Valuation Purpose' ;
    rdfs:comment 'Primary business use case for the curve (e.g., trading book mark-to-market, IFRS 9 ECL discounting, FTP curve, regulatory stress testing).' ;
    rdfs:domain ind:YieldCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yieldCurveNodeId rdf:type rdf:Property ;
    rdfs:label 'Yield Curve Node Id' ;
    rdfs:comment 'Unique identifier for the yield curve node record.' ;
    rdfs:domain ind:YieldCurveNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bidRate rdf:type rdf:Property ;
    rdfs:label 'Bid Rate' ;
    rdfs:comment 'The bid side of the market quote for this tenor, representing the rate at which market makers are willing to buy the instrument. Expressed as a decimal. Used for bid-offer spread analysis.' ;
    rdfs:domain ind:YieldCurveNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discountFactor rdf:type rdf:Property ;
    rdfs:label 'Discount Factor' ;
    rdfs:comment 'The present value of one unit of currency to be received at this tenor, calculated as exp(-zero_rate * tenor_years). Used for discounting future cash flows to present value.' ;
    rdfs:domain ind:YieldCurveNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forwardRate rdf:type rdf:Property ;
    rdfs:label 'Forward Rate' ;
    rdfs:comment 'The implied forward interest rate starting at this tenor, derived from the zero curve. Expressed as a decimal. Used for forward rate agreement (FRA) pricing and interest rate derivative valuation.' ;
    rdfs:domain ind:YieldCurveNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketQuote rdf:type rdf:Property ;
    rdfs:label 'Market Quote' ;
    rdfs:comment 'The raw market-quoted rate for this tenor before any adjustments or transformations. May differ from zero_rate or par_rate depending on quotation convention. Expressed as a decimal.' ;
    rdfs:domain ind:YieldCurveNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:midRate rdf:type rdf:Property ;
    rdfs:label 'Mid Rate' ;
    rdfs:comment 'The mid-point between the bid and offer rates, calculated as (bid_rate + offer_rate) / 2. Commonly used for fair value pricing and mark-to-market (MTM) valuation. Expressed as a decimal.' ;
    rdfs:domain ind:YieldCurveNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nodeSequence rdf:type rdf:Property ;
    rdfs:label 'Node Sequence' ;
    rdfs:comment 'The ordinal position of this node within the yield curve, ordered by increasing tenor. Used for curve traversal and interpolation logic.' ;
    rdfs:domain ind:YieldCurveNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:offerRate rdf:type rdf:Property ;
    rdfs:label 'Offer Rate' ;
    rdfs:comment 'The offer (ask) side of the market quote for this tenor, representing the rate at which market makers are willing to sell the instrument. Expressed as a decimal. Used for bid-offer spread analysis.' ;
    rdfs:domain ind:YieldCurveNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parRate rdf:type rdf:Property ;
    rdfs:label 'Par Rate' ;
    rdfs:comment 'The coupon rate at which a bond with this maturity would trade at par (face value). Expressed as a decimal (e.g., 0.0350 for 3.50%). Used for pricing coupon-bearing securities.' ;
    rdfs:domain ind:YieldCurveNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateSource rdf:type rdf:Property ;
    rdfs:label 'Rate Source' ;
    rdfs:comment 'The market data vendor or authoritative source from which this node rate was obtained (e.g., Bloomberg, Reuters, ICE, CME, Federal Reserve, European Central Bank, internal model). [ENUM-REF-CANDIDATE: bloomberg|reuters|ice|cme|fed|ecb|vendor|internal — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shockMagnitudeBps rdf:type rdf:Property ;
    rdfs:label 'Shock Magnitude Bps' ;
    rdfs:comment 'The magnitude of the interest rate shock applied to this tenor in a stress scenario, expressed in basis points. Positive values indicate upward shocks, negative values indicate downward shocks. Null for base case.' ;
    rdfs:domain ind:YieldCurveNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tenorLabel rdf:type rdf:Property ;
    rdfs:label 'Tenor Label' ;
    rdfs:comment 'Standard market convention label for the maturity point on the yield curve (e.g., 1M for one month, 3M for three months, 1Y for one year, 10Y for ten years, 30Y for thirty years). [ENUM-REF-CANDIDATE: 1M|3M|6M|1Y|2Y|3Y|5Y|7Y|10Y|20Y|30Y — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:YieldCurveNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationModel rdf:type rdf:Property ;
    rdfs:label 'Valuation Model' ;
    rdfs:comment 'The quantitative model or methodology used to derive or validate this node rate (e.g., bootstrapping, Nelson-Siegel, cubic spline, Hull-White, Black-Karasinski). Used for model risk management and validation.' ;
    rdfs:domain ind:YieldCurveNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zeroRate rdf:type rdf:Property ;
    rdfs:label 'Zero Rate' ;
    rdfs:comment 'The continuously compounded zero-coupon interest rate (spot rate) for this tenor, expressed as a decimal (e.g., 0.0325 for 3.25%). Used for discounting cash flows and pricing zero-coupon instruments.' ;
    rdfs:domain ind:YieldCurveNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bestExecutionId rdf:type rdf:Property ;
    rdfs:label 'Best Execution Id' ;
    rdfs:comment 'Unique identifier for the best execution analysis record. Primary key for this entity.' ;
    rdfs:domain ind:BestExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryBestEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Best Employee Id' ;
    rdfs:comment 'Reference to the trader responsible for executing the order and ensuring best execution.' ;
    rdfs:domain ind:BestExecution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:alternativeVenueCount rdf:type rdf:Property ;
    rdfs:label 'Alternative Venue Count' ;
    rdfs:comment 'Number of alternative execution venues that were evaluated during the best execution analysis.' ;
    rdfs:domain ind:BestExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:analysisReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Analysis Reference Number' ;
    rdfs:comment 'External reference number for the best execution analysis record, used for regulatory reporting and audit trails.' ;
    rdfs:domain ind:BestExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analysisStatus rdf:type rdf:Property ;
    rdfs:label 'Analysis Status' ;
    rdfs:comment 'Current status of the best execution analysis workflow, tracking progression from initial assessment through regulatory approval.' ;
    rdfs:domain ind:BestExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analysisTimestamp rdf:type rdf:Property ;
    rdfs:label 'Analysis Timestamp' ;
    rdfs:comment 'Date and time when the best execution analysis was performed, representing the principal business event for this record.' ;
    rdfs:domain ind:BestExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:benchmarkPrice rdf:type rdf:Property ;
    rdfs:label 'Benchmark Price' ;
    rdfs:comment 'Reference price used as the benchmark for best execution comparison, typically the mid-market price at time of execution or arrival price.' ;
    rdfs:domain ind:BestExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clientInstructionDetails rdf:type rdf:Property ;
    rdfs:label 'Client Instruction Details' ;
    rdfs:comment 'Details of any specific client instructions that influenced venue selection or execution approach.' ;
    rdfs:domain ind:BestExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientOrderType rdf:type rdf:Property ;
    rdfs:label 'Client Order Type' ;
    rdfs:comment 'Classification of the client placing the order under MiFID II, determining the level of best execution obligation.' ;
    rdfs:domain ind:BestExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executedQuantity rdf:type rdf:Property ;
    rdfs:label 'Executed Quantity' ;
    rdfs:comment 'Quantity of the instrument that was executed in this transaction.' ;
    rdfs:domain ind:Trade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:executionCost rdf:type rdf:Property ;
    rdfs:label 'Execution Cost' ;
    rdfs:comment 'Total cost of execution including explicit costs (commissions, fees, taxes) and implicit costs (market impact, spread, opportunity cost).' ;
    rdfs:domain ind:BestExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:executionQualityScore rdf:type rdf:Property ;
    rdfs:label 'Execution Quality Score' ;
    rdfs:comment 'Composite score (0-100) assessing overall execution quality based on price improvement, speed, likelihood of execution, and cost factors.' ;
    rdfs:domain ind:BestExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:explicitCost rdf:type rdf:Property ;
    rdfs:label 'Explicit Cost' ;
    rdfs:comment 'Direct, observable costs of execution including commissions, exchange fees, clearing fees, and transaction taxes.' ;
    rdfs:domain ind:BestExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:factors rdf:type rdf:Property ;
    rdfs:label 'Factors' ;
    rdfs:comment 'Comma-separated list of factors considered in the best execution determination (price, cost, speed, likelihood of execution, settlement, size, nature, or other relevant considerations).' ;
    rdfs:domain ind:BestExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implicitCost rdf:type rdf:Property ;
    rdfs:label 'Implicit Cost' ;
    rdfs:comment 'Indirect costs of execution including market impact, bid-ask spread, and opportunity cost from delayed or partial fills.' ;
    rdfs:domain ind:BestExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketImpactCost rdf:type rdf:Property ;
    rdfs:label 'Market Impact Cost' ;
    rdfs:comment 'Cost attributable to the price movement caused by the execution of the order itself, measuring the order\'s effect on market prices.' ;
    rdfs:domain ind:BestExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceImprovement rdf:type rdf:Property ;
    rdfs:label 'Price Improvement' ;
    rdfs:comment 'Difference between execution price and benchmark price, expressed in the trade currency. Positive values indicate favorable execution.' ;
    rdfs:domain ind:BestExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceImprovementBps rdf:type rdf:Property ;
    rdfs:label 'Price Improvement Bps' ;
    rdfs:comment 'Price improvement expressed in basis points relative to the benchmark price, providing a normalized measure of execution quality.' ;
    rdfs:domain ind:BestExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reporting Timestamp' ;
    rdfs:comment 'Date and time when the best execution analysis was reported to the relevant regulatory authority or made available for client reporting.' ;
    rdfs:domain ind:Trade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:specificClientInstructionFlag rdf:type rdf:Property ;
    rdfs:label 'Specific Client Instruction Flag' ;
    rdfs:comment 'Indicates whether the client provided specific instructions that may have prevented the firm from following its best execution policy.' ;
    rdfs:domain ind:BestExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:spreadCost rdf:type rdf:Property ;
    rdfs:label 'Spread Cost' ;
    rdfs:comment 'Cost attributable to crossing the bid-ask spread at the time of execution.' ;
    rdfs:domain ind:BestExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:venueMicCode rdf:type rdf:Property ;
    rdfs:label 'Venue Mic Code' ;
    rdfs:comment 'ISO 10383 Market Identifier Code for the execution venue, providing standardized venue identification for regulatory reporting.' ;
    rdfs:domain ind:Trade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:venueRank rdf:type rdf:Property ;
    rdfs:label 'Venue Rank' ;
    rdfs:comment 'Ranking of the selected execution venue among all eligible venues for this order, based on pre-trade analysis (1 = best venue).' ;
    rdfs:domain ind:BestExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clearingHouseId rdf:type rdf:Property ;
    rdfs:label 'Clearing House Id' ;
    rdfs:comment 'Identifier of the central counterparty (CCP) or clearing house through which this broker clears trades.' ;
    rdfs:domain ind:Trade ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClearingHouse .

ind:commissionCurrencyId rdf:type rdf:Property ;
    rdfs:label 'Commission Currency Id' ;
    rdfs:comment 'Foreign key linking to reference.currency. Business justification: Broker commission currency validation required for cost accrual, payment processing, and commission schedule management. Reference data provides currency attributes for broker payment instructions.' ;
    rdfs:domain ind:Broker ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:commissionScheduleId rdf:type rdf:Property ;
    rdfs:label 'Commission Schedule Id' ;
    rdfs:comment 'Reference to the commission rate schedule or fee structure applicable to trades executed through this broker.' ;
    rdfs:domain ind:Trade ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CommissionSchedule .

ind:brokerCode rdf:type rdf:Property ;
    rdfs:label 'Broker Code' ;
    rdfs:comment 'Internal business identifier or mnemonic code assigned to the broker for operational reference and reporting purposes.' ;
    rdfs:domain ind:Broker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brokerStatus rdf:type rdf:Property ;
    rdfs:label 'Broker Status' ;
    rdfs:comment 'Current operational status of the broker relationship: active (approved for trading), inactive (not currently used), suspended (temporarily restricted), pending approval (under review), or terminated (relationship ended).' ;
    rdfs:domain ind:Broker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brokerType rdf:type rdf:Property ;
    rdfs:label 'Broker Type' ;
    rdfs:comment 'Classification of the broker based on the primary service provided: executing broker (trade execution), prime broker (financing and custody), clearing broker (post-trade clearing), introducing broker (client referral), custodian broker (asset custody), or agency broker (agent capacity).' ;
    rdfs:domain ind:Broker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimitCurrency rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the credit limit is denominated.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultCommissionRate rdf:type rdf:Property ;
    rdfs:label 'Default Commission Rate' ;
    rdfs:comment 'Standard commission rate (in basis points or percentage) charged by the broker for trade execution when no specific schedule applies.' ;
    rdfs:domain ind:Broker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eligibleAssetClasses rdf:type rdf:Property ;
    rdfs:label 'Eligible Asset Classes' ;
    rdfs:comment 'Comma-separated list of asset classes for which this broker is approved to execute trades (e.g., equities, fixed_income, derivatives, fx, commodities).' ;
    rdfs:domain ind:Broker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibleMarkets rdf:type rdf:Property ;
    rdfs:label 'Eligible Markets' ;
    rdfs:comment 'Comma-separated list of trading venues or market identifiers (MIC codes) where this broker is authorized to execute trades.' ;
    rdfs:domain ind:Broker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementAgentBic rdf:type rdf:Property ;
    rdfs:label 'Settlement Agent Bic' ;
    rdfs:comment 'SWIFT BIC of the settlement agent or custodian bank used by the broker for post-trade settlement and cash movements.' ;
    rdfs:domain ind:Trade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingInstructionId rdf:type rdf:Property ;
    rdfs:label 'Clearing Instruction Id' ;
    rdfs:comment 'Unique identifier for the clearing instruction record. Primary key for the clearing instruction entity.' ;
    rdfs:domain ind:Trade ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClearingInstruction .

ind:compressionCycleId rdf:type rdf:Property ;
    rdfs:label 'Compression Cycle Id' ;
    rdfs:comment 'Identifier of the portfolio compression cycle in which this trade participated. Portfolio compression reduces gross notional and operational risk by terminating offsetting trades.' ;
    rdfs:domain ind:Trade ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CompressionCycle .

ind:giveUpBrokerId rdf:type rdf:Property ;
    rdfs:label 'Give Up Broker Id' ;
    rdfs:comment 'Identifier of the executing broker who gives up the trade to the clearing member. Common in agency clearing arrangements.' ;
    rdfs:domain ind:ClearingInstruction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Broker .

ind:marginCurrencyId rdf:type rdf:Property ;
    rdfs:label 'Margin Currency Id' ;
    rdfs:comment 'Foreign key linking to reference.currency. Business justification: Clearing margin currency must validate for CCP margin calculation, settlement processing, and collateral management. Reference data provides currency attributes for initial and variation margin proces' ;
    rdfs:domain ind:ClearingInstruction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:tradeRepositoryId rdf:type rdf:Property ;
    rdfs:label 'Trade Repository Id' ;
    rdfs:comment 'Identifier of the registered trade repository to which this clearing instruction was reported for regulatory purposes.' ;
    rdfs:domain ind:Trade ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TradeRepository .

ind:acceptanceTimestamp rdf:type rdf:Property ;
    rdfs:label 'Acceptance Timestamp' ;
    rdfs:comment 'Date and time when the CCP formally accepted the clearing instruction and confirmed clearing eligibility.' ;
    rdfs:domain ind:ClearingInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:bookingEntityLei rdf:type rdf:Property ;
    rdfs:label 'Booking Entity Lei' ;
    rdfs:comment '20-character Legal Entity Identifier of the legal entity that booked the trade and is submitting it for clearing.' ;
    rdfs:domain ind:Trade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Clearing Eligibility Flag' ;
    rdfs:comment 'Boolean indicator of whether the trade is eligible for central clearing based on product type, jurisdiction, and regulatory requirements. True indicates the trade meets mandatory clearing obligations under Dodd-Frank or EMIR.' ;
    rdfs:domain ind:ClearingInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clearingFeeCurrency rdf:type rdf:Property ;
    rdfs:label 'Clearing Fee Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the clearing fee amount.' ;
    rdfs:domain ind:ClearingInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingMemberLei rdf:type rdf:Property ;
    rdfs:label 'Clearing Member Lei' ;
    rdfs:comment '20-character Legal Entity Identifier of the clearing member as defined by the Global LEI Foundation. Required for regulatory reporting under EMIR and Dodd-Frank.' ;
    rdfs:domain ind:ClearingInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingVenue rdf:type rdf:Property ;
    rdfs:label 'Clearing Venue' ;
    rdfs:comment 'Type of venue where the trade was executed before clearing. Exchange-traded products clear automatically. SEF-executed swaps clear under Dodd-Frank. Bilateral OTC trades may be voluntarily cleared.' ;
    rdfs:domain ind:ClearingInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientAccountType rdf:type rdf:Property ;
    rdfs:label 'Client Account Type' ;
    rdfs:comment 'Classification of the clearing account structure. House accounts hold the clearing member\'s proprietary positions. Client accounts hold customer positions. Omnibus accounts aggregate multiple clients. Individual Segregated Accounts (ISA) provide full segregation for each client.' ;
    rdfs:domain ind:ClearingInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collateralAmount rdf:type rdf:Property ;
    rdfs:label 'Collateral Amount' ;
    rdfs:comment 'Total value of collateral posted to the CCP for this cleared position, including both initial and variation margin.' ;
    rdfs:domain ind:ClearingInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compressionFlag rdf:type rdf:Property ;
    rdfs:label 'Compression Flag' ;
    rdfs:comment 'Boolean indicator of whether this trade has been subject to portfolio compression. True indicates the trade was included in a compression exercise.' ;
    rdfs:domain ind:Trade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:defaultFundContribution rdf:type rdf:Property ;
    rdfs:label 'Default Fund Contribution' ;
    rdfs:comment 'Clearing member\'s contribution to the CCP\'s default fund (also called guarantee fund). Used to mutualize losses in the event of a clearing member default that exceeds initial margin.' ;
    rdfs:domain ind:ClearingInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mandatoryClearingFlag rdf:type rdf:Property ;
    rdfs:label 'Mandatory Clearing Flag' ;
    rdfs:comment 'Boolean indicator of whether this trade is subject to mandatory clearing obligations under Dodd-Frank or EMIR regulations. True indicates regulatory requirement to clear through a CCP.' ;
    rdfs:domain ind:ClearingInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryReportTimestamp rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Timestamp' ;
    rdfs:comment 'Date and time when the clearing instruction was reported to the trade repository or regulatory authority.' ;
    rdfs:domain ind:Trade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rejectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Rejection Timestamp' ;
    rdfs:comment 'Date and time when the CCP rejected the clearing instruction. Null if instruction was not rejected.' ;
    rdfs:domain ind:Trade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:clearingRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Clearing Requirement Flag' ;
    rdfs:comment 'Indicates whether trades under this agreement are subject to mandatory central clearing requirements.' ;
    rdfs:domain ind:CounterpartyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:collateralArrangementFlag rdf:type rdf:Property ;
    rdfs:label 'Collateral Arrangement Flag' ;
    rdfs:comment 'Indicates whether the agreement includes collateral or margin posting requirements.' ;
    rdfs:domain ind:CounterpartyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditRatingTriggerFlag rdf:type rdf:Property ;
    rdfs:label 'Credit Rating Trigger Flag' ;
    rdfs:comment 'Indicates whether the agreement contains provisions triggered by credit rating downgrades.' ;
    rdfs:domain ind:CounterpartyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disputeResolutionMethod rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Method' ;
    rdfs:comment 'Primary method specified in the agreement for resolving disputes between parties.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentRepositoryReference rdf:type rdf:Property ;
    rdfs:label 'Document Repository Reference' ;
    rdfs:comment 'Reference identifier or URI to the physical or electronic storage location of the signed agreement document.' ;
    rdfs:domain ind:CounterpartyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marginCallFrequency rdf:type rdf:Property ;
    rdfs:label 'Margin Call Frequency' ;
    rdfs:comment 'Frequency at which margin calls may be issued under the agreement.' ;
    rdfs:domain ind:CounterpartyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:masterConfirmationFlag rdf:type rdf:Property ;
    rdfs:label 'Master Confirmation Flag' ;
    rdfs:comment 'Indicates whether a master confirmation agreement exists that pre-defines economic terms for specific product types.' ;
    rdfs:domain ind:CounterpartyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mtmLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Mtm Limit Amount' ;
    rdfs:comment 'Maximum mark-to-market exposure permitted under the agreement. Null if no limit applies.' ;
    rdfs:domain ind:CounterpartyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nettingProvisionFlag rdf:type rdf:Property ;
    rdfs:label 'Netting Provision Flag' ;
    rdfs:comment 'Indicates whether the agreement includes close-out netting provisions for offsetting obligations upon default or termination.' ;
    rdfs:domain ind:CounterpartyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notionalLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Notional Limit Amount' ;
    rdfs:comment 'Maximum aggregate notional amount of outstanding trades permitted under the agreement. Null if no limit applies.' ;
    rdfs:domain ind:Trade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementTime rdf:type rdf:Property ;
    rdfs:label 'Settlement Time' ;
    rdfs:comment 'Standard settlement timeframe for collateral transfers under the agreement, expressed as trade date plus number of business days.' ;
    rdfs:domain ind:CounterpartyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:bestExecutionVenueRank rdf:type rdf:Property ;
    rdfs:label 'Best Execution Venue Rank' ;
    rdfs:comment 'Rank of this execution venue in the firms best-execution venue selection process. Used for MiFID II RTS 27 and SEC Rule 606 best-execution reporting.' ;
    rdfs:domain ind:Execution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capacity rdf:type rdf:Property ;
    rdfs:label 'Capacity' ;
    rdfs:comment 'Capacity in which the firm executed the trade: principal (trading for own account), agency (acting as broker), riskless principal, or matched principal. Required for regulatory reporting.' ;
    rdfs:domain ind:Trade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingFee rdf:type rdf:Property ;
    rdfs:label 'Clearing Fee' ;
    rdfs:comment 'Fee charged by the clearinghouse for clearing and settlement of this execution. Denominated in execution_currency.' ;
    rdfs:domain ind:Execution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exchangeFee rdf:type rdf:Property ;
    rdfs:label 'Exchange Fee' ;
    rdfs:comment 'Fee charged by the trading venue or exchange for this execution. Denominated in execution_currency.' ;
    rdfs:domain ind:Execution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:executionStatus rdf:type rdf:Property ;
    rdfs:label 'Execution Status' ;
    rdfs:comment 'Current lifecycle status of the execution record. Tracks progression from fill through settlement.' ;
    rdfs:domain ind:Execution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionType rdf:type rdf:Property ;
    rdfs:label 'Execution Type' ;
    rdfs:comment 'Classification of the execution method. Indicates whether this is a full fill, partial fill, block trade, program trade, algorithmic execution, or manual execution.' ;
    rdfs:domain ind:Execution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossTradeValue rdf:type rdf:Property ;
    rdfs:label 'Gross Trade Value' ;
    rdfs:comment 'Total value of the execution before commissions and fees, calculated as executed_quantity × execution_price. Denominated in execution_currency.' ;
    rdfs:domain ind:Execution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:liquidityIndicator rdf:type rdf:Property ;
    rdfs:label 'Liquidity Indicator' ;
    rdfs:comment 'Indicates whether this execution added liquidity to the market (maker), removed liquidity (taker), or was routed. Affects exchange fee rebates and best-execution analysis.' ;
    rdfs:domain ind:Execution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketMicrostructureIndicator rdf:type rdf:Property ;
    rdfs:label 'Market Microstructure Indicator' ;
    rdfs:comment 'Classification of the market microstructure where the execution occurred: lit exchange, dark pool, systematic internaliser, over-the-counter (OTC), or request-for-quote (RFQ). Required for MiFID II best-execution reporting.' ;
    rdfs:domain ind:Execution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netTradeValue rdf:type rdf:Property ;
    rdfs:label 'Net Trade Value' ;
    rdfs:comment 'Total value of the execution after all commissions and fees. Calculated as gross_trade_value ± commission_amount ± exchange_fee ± clearing_fee. Denominated in execution_currency.' ;
    rdfs:domain ind:Execution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:price rdf:type rdf:Property ;
    rdfs:label 'Price' ;
    rdfs:comment 'The price per unit at which this execution was filled. Used to calculate gross trade value and for Mark-to-Market (MTM) valuation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tradeReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Trade Reporting Flag' ;
    rdfs:comment 'Indicates whether this execution has been reported to the relevant trade reporting facility (e.g., FINRA TRACE, EMIR trade repository). True if reported, False if pending.' ;
    rdfs:domain ind:Execution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tradeReportingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Trade Reporting Timestamp' ;
    rdfs:comment 'Date and time when this execution was reported to the trade reporting facility. Null if not yet reported. Used to verify compliance with T+1 reporting deadlines.' ;
    rdfs:domain ind:Execution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:tradeSide rdf:type rdf:Property ;
    rdfs:label 'Trade Side' ;
    rdfs:comment 'Indicates whether this execution is a buy or sell from the perspective of the reporting institution.' ;
    rdfs:domain ind:Execution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:venue rdf:type rdf:Property ;
    rdfs:label 'Venue' ;
    rdfs:comment 'Name or code of the trading venue where the execution occurred (e.g., NYSE, NASDAQ, LSE, OTC, ECN). Critical for best-execution reporting under MiFID II and SEC Rule 606.' ;
    rdfs:domain ind:Execution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mtmValuationId rdf:type rdf:Property ;
    rdfs:label 'Mtm Valuation Id' ;
    rdfs:comment 'Unique identifier for the mark-to-market valuation record.' ;
    rdfs:domain ind:MtmValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:balanceSheetPositionId rdf:type rdf:Property ;
    rdfs:label 'Balance Sheet Position Id' ;
    rdfs:comment 'Foreign key linking to treasury.balance_sheet_position. Business justification: MTM valuations feed balance sheet fair value measurements and unrealized P&L calculations. Required for fair value accounting, EVE sensitivity analysis, capital adequacy assessments, and IFRS 13 fair ' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BalanceSheetPosition .

ind:valuationCurrencyId rdf:type rdf:Property ;
    rdfs:label 'Valuation Currency Id' ;
    rdfs:comment 'Foreign key linking to reference.currency. Business justification: Valuation currency validation required for fair value hierarchy compliance, IFRS reporting, and FX revaluation. Reference currency master provides rounding rules, minor units, and regulatory reporting' ;
    rdfs:domain ind:MtmValuation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:cleanPrice rdf:type rdf:Property ;
    rdfs:label 'Clean Price' ;
    rdfs:comment 'The price of the security excluding accrued interest, typically used for bonds and fixed income instruments.' ;
    rdfs:domain ind:Trade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:correlationInput rdf:type rdf:Property ;
    rdfs:label 'Correlation Input' ;
    rdfs:comment 'The correlation parameter used in multi-asset or basket derivative valuations, expressed as a decimal between -1 and 1.' ;
    rdfs:domain ind:MtmValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dirtyPrice rdf:type rdf:Property ;
    rdfs:label 'Dirty Price' ;
    rdfs:comment 'The price of the security including accrued interest, representing the total amount paid by the buyer.' ;
    rdfs:domain ind:Trade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dvaAdjustment rdf:type rdf:Property ;
    rdfs:label 'Dva Adjustment' ;
    rdfs:comment 'Debit Valuation Adjustment reflecting the market value of own credit risk, adjusting the fair value to account for the entity\'s own default risk.' ;
    rdfs:domain ind:MtmValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fairValue rdf:type rdf:Property ;
    rdfs:label 'Fair Value' ;
    rdfs:comment 'The mark-to-market fair value of the position or trade at the valuation date and time, representing the price that would be received to sell an asset or paid to transfer a liability in an orderly transaction.' ;
    rdfs:domain ind:MtmValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fvaAdjustment rdf:type rdf:Property ;
    rdfs:label 'Fva Adjustment' ;
    rdfs:comment 'Funding Valuation Adjustment reflecting the cost of funding uncollateralized derivatives, adjusting the fair value for funding costs.' ;
    rdfs:domain ind:MtmValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:independentPriceVerificationFlag rdf:type rdf:Property ;
    rdfs:label 'Independent Price Verification Flag' ;
    rdfs:comment 'Boolean flag indicating whether the valuation has undergone independent price verification by a separate control function, as required by regulatory standards.' ;
    rdfs:domain ind:MtmValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ipvVariance rdf:type rdf:Property ;
    rdfs:label 'Ipv Variance' ;
    rdfs:comment 'The variance between the trading desk valuation and the independent price verification valuation, used for control and escalation purposes.' ;
    rdfs:domain ind:MtmValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:previousFairValue rdf:type rdf:Property ;
    rdfs:label 'Previous Fair Value' ;
    rdfs:comment 'The fair value from the previous valuation date, used to calculate daily P&L movements.' ;
    rdfs:domain ind:MtmValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalValuationAdjustments rdf:type rdf:Property ;
    rdfs:label 'Total Valuation Adjustments' ;
    rdfs:comment 'The sum of all valuation adjustments (CVA, DVA, FVA, and other XVA components) applied to the fair value.' ;
    rdfs:domain ind:MtmValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unrealizedPnl rdf:type rdf:Property ;
    rdfs:label 'Unrealized Pnl' ;
    rdfs:comment 'The unrealized profit or loss calculated as the difference between the current fair value and the previous valuation or book value, supporting daily P&L attribution.' ;
    rdfs:domain ind:Trade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valuationRemarks rdf:type rdf:Property ;
    rdfs:label 'Valuation Remarks' ;
    rdfs:comment 'Free-text field for additional notes, explanations, or exceptions related to the valuation, supporting audit trails and control documentation.' ;
    rdfs:domain ind:MtmValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Valuation Source System' ;
    rdfs:comment 'The name of the source system that generated the valuation (e.g., Murex, Calypso, Bloomberg MARS, internal risk engine).' ;
    rdfs:domain ind:MtmValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volatilityInput rdf:type rdf:Property ;
    rdfs:label 'Volatility Input' ;
    rdfs:comment 'The volatility parameter used in option pricing models and derivative valuations, expressed as a decimal (e.g., 0.25 for 25% volatility).' ;
    rdfs:domain ind:MtmValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yieldRate rdf:type rdf:Property ;
    rdfs:label 'Yield Rate' ;
    rdfs:comment 'The yield to maturity or effective yield rate used in the valuation calculation for fixed income instruments.' ;
    rdfs:domain ind:MtmValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentOrderId rdf:type rdf:Property ;
    rdfs:label 'Parent Order Id' ;
    rdfs:comment 'Reference to the parent order in hierarchical order structures. Used for algorithmic trading and smart order routing where a parent order is split into multiple child orders for execution. Null for top-level orders.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:averageExecutionPrice rdf:type rdf:Property ;
    rdfs:label 'Average Execution Price' ;
    rdfs:comment 'Volume-weighted average price at which the order was executed. For partially filled orders, average of fills to date. Used for P&L calculation, transaction cost analysis, and client reporting. Expressed in order currency per unit.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:entryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Entry Timestamp' ;
    rdfs:comment 'Precise date and time when the order was entered into the trading system. Recorded in UTC with microsecond precision. Critical for transaction cost analysis, market abuse surveillance, and regulatory reporting under MiFID II clock synchronization requirements.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:executionStrategy rdf:type rdf:Property ;
    rdfs:label 'Execution Strategy' ;
    rdfs:comment 'Name or identifier of the algorithmic execution strategy applied to the order. Examples include VWAP, TWAP, implementation shortfall, liquidity-seeking, dark pool aggregation. Null for manual execution. Used for strategy performance analysis and best execution compliance.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filledQuantity rdf:type rdf:Property ;
    rdfs:label 'Filled Quantity' ;
    rdfs:comment 'Cumulative quantity executed to date. Updated as partial fills occur. When filled_quantity equals quantity, order status transitions to filled. Used to calculate remaining open quantity and order completion percentage.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:instruction rdf:type rdf:Property ;
    rdfs:label 'Instruction' ;
    rdfs:comment 'Free-text field for special handling instructions or trader notes. May include client preferences, execution constraints, or operational notes. Not used for automated processing but valuable for audit trail and client service.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAlgorithmic rdf:type rdf:Property ;
    rdfs:label 'Is Algorithmic' ;
    rdfs:comment 'Indicates whether the order was generated or executed by an algorithmic trading system. True for algo orders, false for manual orders. Required for MiFID II algorithmic trading transparency and risk control reporting.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDiscretionary rdf:type rdf:Property ;
    rdfs:label 'Is Discretionary' ;
    rdfs:comment 'Indicates whether the order was placed under discretionary authority where the firm has latitude in execution timing and price. True for discretionary orders, false for non-discretionary. Impacts regulatory reporting and best execution obligations.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastUpdateTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Update Timestamp' ;
    rdfs:comment 'Date and time of the most recent modification to the order record. Updated on status changes, partial fills, amendments, or cancellations. Used for audit trail and change tracking.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:limitPrice rdf:type rdf:Property ;
    rdfs:label 'Limit Price' ;
    rdfs:comment 'Maximum price for buy orders or minimum price for sell orders. Only applicable for limit and stop-limit order types. Null for market orders. Expressed in currency per unit of the security.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originationChannel rdf:type rdf:Property ;
    rdfs:label 'Origination Channel' ;
    rdfs:comment 'Channel through which the order was received. Electronic includes FIX protocol and API. Voice for phone orders. Algo for algorithmic trading. DMA (Direct Market Access) for client-routed orders. Client portal for self-service platforms. Used for channel analytics and operational efficiency measurement.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryTradeFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Trade Flag' ;
    rdfs:comment 'Indicator for special regulatory treatment or reporting requirements. Examples include short sale indicator, large in scale (LIS), pre-trade transparency waiver, algorithmic trading flag. Used for regulatory reporting to FINRA, SEC, ESMA.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:side rdf:type rdf:Property ;
    rdfs:label 'Side' ;
    rdfs:comment 'Direction of the trade order. Buy increases position, sell decreases position. Short sell creates negative position. Buy to cover closes short position. Critical for position management and P&L calculation.' ;
    rdfs:domain ind:Trade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stopPrice rdf:type rdf:Property ;
    rdfs:label 'Stop Price' ;
    rdfs:comment 'Trigger price for stop and stop-limit orders. Order becomes active when market price reaches this level. Null for market and limit orders. Used for risk management and automated trading strategies.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:timeInForce rdf:type rdf:Property ;
    rdfs:label 'Time In Force' ;
    rdfs:comment 'Duration for which the order remains active. Day orders expire at market close. GTC (Good Till Cancelled) remains active until filled or cancelled. IOC (Immediate or Cancel) executes immediately or cancels. FOK (Fill or Kill) must fill completely or cancel. GTD (Good Till Date) expires on specified date.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pnlAttributionId rdf:type rdf:Property ;
    rdfs:label 'Pnl Attribution Id' ;
    rdfs:comment 'Unique identifier for the P&L attribution record.' ;
    rdfs:domain ind:PnlAttribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:attributionCurrencyId rdf:type rdf:Property ;
    rdfs:label 'Attribution Currency Id' ;
    rdfs:comment 'Foreign key linking to reference.currency. Business justification: P&L attribution currency must align with trading book base currency from reference data. Reference master provides FX rates for currency translation and consolidated P&L reporting.' ;
    rdfs:domain ind:PnlAttribution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:pnlProductTypeId rdf:type rdf:Property ;
    rdfs:label 'Pnl Product Type Id' ;
    rdfs:comment 'Foreign key linking to reference.product_type. Business justification: P&L attribution product type needed for product-level performance analysis, management reporting, and business line profitability. Reference data provides product hierarchy and cost allocation rules.' ;
    rdfs:domain ind:PnlAttribution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductType .

ind:attributionMethod rdf:type rdf:Property ;
    rdfs:label 'Attribution Method' ;
    rdfs:comment 'Methodology used to calculate the P&L attribution (risk factor-based, scenario-based, hybrid, or full revaluation).' ;
    rdfs:domain ind:PnlAttribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attributionQualityScore rdf:type rdf:Property ;
    rdfs:label 'Attribution Quality Score' ;
    rdfs:comment 'Quality score (0-100) indicating the accuracy and completeness of the P&L attribution, with higher scores indicating lower unexplained P&L.' ;
    rdfs:domain ind:PnlAttribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:attributionStatus rdf:type rdf:Property ;
    rdfs:label 'Attribution Status' ;
    rdfs:comment 'Current status of the P&L attribution record in the attribution workflow.' ;
    rdfs:domain ind:PnlAttribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attributionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Attribution Timestamp' ;
    rdfs:comment 'Timestamp when the P&L attribution calculation was performed.' ;
    rdfs:domain ind:PnlAttribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:basisPnl rdf:type rdf:Property ;
    rdfs:label 'Basis Pnl' ;
    rdfs:comment 'P&L component arising from basis risk, representing the difference between related but non-identical instruments or markets.' ;
    rdfs:domain ind:PnlAttribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cancellationPnl rdf:type rdf:Property ;
    rdfs:label 'Cancellation Pnl' ;
    rdfs:comment 'P&L component arising from trade cancellations or amendments during the valuation date.' ;
    rdfs:domain ind:PnlAttribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carryPnl rdf:type rdf:Property ;
    rdfs:label 'Carry Pnl' ;
    rdfs:comment 'P&L component representing the carry or cost of funding a position over time, including funding costs and benefits.' ;
    rdfs:domain ind:PnlAttribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditSpreadPnl rdf:type rdf:Property ;
    rdfs:label 'Credit Spread Pnl' ;
    rdfs:comment 'P&L component attributable to changes in credit spreads for credit-sensitive instruments.' ;
    rdfs:domain ind:PnlAttribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deltaPnl rdf:type rdf:Property ;
    rdfs:label 'Delta Pnl' ;
    rdfs:comment 'P&L component attributable to changes in the underlying asset price (delta sensitivity).' ;
    rdfs:domain ind:PnlAttribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dividendPnl rdf:type rdf:Property ;
    rdfs:label 'Dividend Pnl' ;
    rdfs:comment 'P&L component arising from dividend payments or changes in expected dividend forecasts for equity and equity derivative positions.' ;
    rdfs:domain ind:PnlAttribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fxTranslationPnl rdf:type rdf:Property ;
    rdfs:label 'Fx Translation Pnl' ;
    rdfs:comment 'P&L arising from foreign exchange translation effects when converting positions denominated in foreign currencies to the reporting currency.' ;
    rdfs:domain ind:PnlAttribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gammaPnl rdf:type rdf:Property ;
    rdfs:label 'Gamma Pnl' ;
    rdfs:comment 'P&L component attributable to changes in delta due to underlying price movements (gamma sensitivity).' ;
    rdfs:domain ind:PnlAttribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mtmPnl rdf:type rdf:Property ;
    rdfs:label 'Mtm Pnl' ;
    rdfs:comment 'P&L arising from changes in the mark-to-market valuation of positions held at the end of the valuation date.' ;
    rdfs:domain ind:PnlAttribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:newDealPnl rdf:type rdf:Property ;
    rdfs:label 'New Deal Pnl' ;
    rdfs:comment 'P&L component arising from new trades executed during the valuation date.' ;
    rdfs:domain ind:PnlAttribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reconciliationDifference rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Difference' ;
    rdfs:comment 'Difference between front-office attributed P&L and finance-reported P&L, used for reconciliation and control purposes.' ;
    rdfs:domain ind:PnlAttribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:repoPnl rdf:type rdf:Property ;
    rdfs:label 'Repo Pnl' ;
    rdfs:comment 'P&L component arising from repurchase agreement (repo) transactions and related financing activities.' ;
    rdfs:domain ind:PnlAttribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rhoPnl rdf:type rdf:Property ;
    rdfs:label 'Rho Pnl' ;
    rdfs:comment 'P&L component attributable to changes in interest rates (rho sensitivity).' ;
    rdfs:domain ind:PnlAttribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:riskFactorCount rdf:type rdf:Property ;
    rdfs:label 'Risk Factor Count' ;
    rdfs:comment 'Number of risk factors used in the P&L attribution calculation for this record.' ;
    rdfs:domain ind:PnlAttribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:thetaPnl rdf:type rdf:Property ;
    rdfs:label 'Theta Pnl' ;
    rdfs:comment 'P&L component attributable to time decay (theta) of options and other time-sensitive derivatives.' ;
    rdfs:domain ind:PnlAttribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPnl rdf:type rdf:Property ;
    rdfs:label 'Total Pnl' ;
    rdfs:comment 'Total P&L for the trading book and instrument on the valuation date, representing the sum of all P&L components.' ;
    rdfs:domain ind:PnlAttribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tradingPnl rdf:type rdf:Property ;
    rdfs:label 'Trading Pnl' ;
    rdfs:comment 'P&L arising from trading activity, including realized gains and losses from executed trades.' ;
    rdfs:domain ind:PnlAttribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unexplainedPnl rdf:type rdf:Property ;
    rdfs:label 'Unexplained Pnl' ;
    rdfs:comment 'Residual P&L that cannot be attributed to any specific risk factor or component, representing model risk or unidentified factors.' ;
    rdfs:domain ind:PnlAttribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vegaPnl rdf:type rdf:Property ;
    rdfs:label 'Vega Pnl' ;
    rdfs:comment 'P&L component attributable to changes in implied volatility (vega sensitivity).' ;
    rdfs:domain ind:PnlAttribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:treasuryNostroAccountId rdf:type rdf:Property ;
    rdfs:label 'Treasury Nostro Account Id' ;
    rdfs:comment 'Foreign key linking to treasury.nostro_account. Business justification: Settlement instructions specify nostro accounts for cash settlement of trades. Required for trade settlement cash management, nostro liquidity forecasting, intraday liquidity monitoring, and nostro re' ;
    rdfs:domain ind:SettlementInstruction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NostroAccount .

ind:affirmationStatus rdf:type rdf:Property ;
    rdfs:label 'Affirmation Status' ;
    rdfs:comment 'Status indicating whether the institutional investor has affirmed the settlement details.' ;
    rdfs:domain ind:Trade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affirmationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Affirmation Timestamp' ;
    rdfs:comment 'Date and time when the settlement instruction was affirmed by the institutional investor.' ;
    rdfs:domain ind:Trade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:buyInExecutionDate rdf:type rdf:Property ;
    rdfs:label 'Buy In Execution Date' ;
    rdfs:comment 'Date on which the mandatory buy-in was executed to cover the failed settlement.' ;
    rdfs:domain ind:SettlementInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:buyInFlag rdf:type rdf:Property ;
    rdfs:label 'Buy In Flag' ;
    rdfs:comment 'Boolean indicator of whether a mandatory buy-in process has been initiated under CSDR settlement discipline regime.' ;
    rdfs:domain ind:SettlementInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:buyInStatus rdf:type rdf:Property ;
    rdfs:label 'Buy In Status' ;
    rdfs:comment 'Current status of the mandatory buy-in process if initiated.' ;
    rdfs:domain ind:SettlementInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cashCorrespondentBic rdf:type rdf:Property ;
    rdfs:label 'Cash Correspondent Bic' ;
    rdfs:comment 'SWIFT BIC of the cash correspondent bank handling the cash leg of the settlement.' ;
    rdfs:domain ind:SettlementInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:csdName rdf:type rdf:Property ;
    rdfs:label 'Csd Name' ;
    rdfs:comment 'Name of the Central Securities Depository or International Central Securities Depository handling the settlement.' ;
    rdfs:domain ind:SettlementInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:csdParticipantCode rdf:type rdf:Property ;
    rdfs:label 'Csd Participant Code' ;
    rdfs:comment 'Participant code identifying the entity within the CSD or ICSD system (e.g., DTC participant number, Euroclear participant ID).' ;
    rdfs:domain ind:SettlementInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:csdrPenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Csdr Penalty Amount' ;
    rdfs:comment 'Total cash penalty charges incurred under CSDR mandatory buy-in and penalty regime for settlement fails.' ;
    rdfs:domain ind:SettlementInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:csdrPenaltyCurrency rdf:type rdf:Property ;
    rdfs:label 'Csdr Penalty Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code in which CSDR penalties are denominated.' ;
    rdfs:domain ind:SettlementInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failDate rdf:type rdf:Property ;
    rdfs:label 'Fail Date' ;
    rdfs:comment 'Date on which the settlement instruction first failed to settle.' ;
    rdfs:domain ind:SettlementInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:failDurationDays rdf:type rdf:Property ;
    rdfs:label 'Fail Duration Days' ;
    rdfs:comment 'Number of business days the settlement instruction has been in a failed state.' ;
    rdfs:domain ind:SettlementInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:failFlag rdf:type rdf:Property ;
    rdfs:label 'Fail Flag' ;
    rdfs:comment 'Boolean indicator of whether this settlement instruction has failed to settle on the intended settlement date.' ;
    rdfs:domain ind:SettlementInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:failReasonCode rdf:type rdf:Property ;
    rdfs:label 'Fail Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for settlement failure: counterparty default (CPTY), insufficient securities (SECU), cash shortfall (CASH), matching discrepancy (MTCH), technical issue (TECH), or other (OTHR).' ;
    rdfs:domain ind:SettlementInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Fail Reason Description' ;
    rdfs:comment 'Detailed textual description of the reason for settlement failure.' ;
    rdfs:domain ind:SettlementInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instructionCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Instruction Created Timestamp' ;
    rdfs:comment 'Date and time when the settlement instruction record was first created in the system.' ;
    rdfs:domain ind:SettlementInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:instructionModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Instruction Modified Timestamp' ;
    rdfs:comment 'Date and time when the settlement instruction record was last modified.' ;
    rdfs:domain ind:SettlementInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:instructionReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Instruction Reference Number' ;
    rdfs:comment 'Externally visible unique reference number for this settlement instruction, used in SWIFT messaging and counterparty communication.' ;
    rdfs:domain ind:SettlementInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intendedSettlementDate rdf:type rdf:Property ;
    rdfs:label 'Intended Settlement Date' ;
    rdfs:comment 'Original intended settlement date before any amendments or fails occurred.' ;
    rdfs:domain ind:SettlementInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:matchingStatus rdf:type rdf:Property ;
    rdfs:label 'Matching Status' ;
    rdfs:comment 'Status indicating whether the settlement instruction has been matched with the counterparty instruction.' ;
    rdfs:domain ind:SettlementInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Matching Timestamp' ;
    rdfs:comment 'Date and time when the settlement instruction was successfully matched with the counterparty instruction.' ;
    rdfs:domain ind:SettlementInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:securityQuantity rdf:type rdf:Property ;
    rdfs:label 'Security Quantity' ;
    rdfs:comment 'Quantity of securities to be delivered or received in this settlement instruction.' ;
    rdfs:domain ind:SettlementInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationId rdf:type rdf:Property ;
    rdfs:label 'Allocation Id' ;
    rdfs:comment 'Unique identifier for the trade allocation record. Primary key for the trade allocation entity.' ;
    rdfs:domain ind:Trade ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Allocation .

ind:allocationBlockTradeTradeCaptureId rdf:type rdf:Property ;
    rdfs:label 'Allocation Block Trade Trade Capture Id' ;
    rdfs:comment 'Reference to the parent block trade that is being allocated across multiple accounts or sub-portfolios.' ;
    rdfs:domain ind:Allocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Capture .

ind:allocationCaptureId rdf:type rdf:Property ;
    rdfs:label 'Allocation Capture Id' ;
    rdfs:comment 'Reference to the underlying trade execution record from the trading system.' ;
    rdfs:domain ind:Allocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Capture .

ind:allocationClearingBrokerId rdf:type rdf:Property ;
    rdfs:label 'Allocation Clearing Broker Id' ;
    rdfs:comment 'Reference to the broker responsible for clearing and settlement of this allocation.' ;
    rdfs:domain ind:Allocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Broker .

ind:allocationCustodianPartyId rdf:type rdf:Property ;
    rdfs:label 'Allocation Custodian Party Id' ;
    rdfs:comment 'Reference to the custodian bank holding the securities for the allocated account, used for settlement instruction routing.' ;
    rdfs:domain ind:Allocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:allocationExecutingBrokerId rdf:type rdf:Property ;
    rdfs:label 'Allocation Executing Broker Id' ;
    rdfs:comment 'Reference to the broker who executed the original block trade before allocation.' ;
    rdfs:domain ind:Allocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Broker .

ind:allocationGiveUpBrokerId rdf:type rdf:Property ;
    rdfs:label 'Allocation Give Up Broker Id' ;
    rdfs:comment 'Reference to the broker receiving the give-up allocation in step-out workflows, where execution is transferred to another broker for clearing.' ;
    rdfs:domain ind:Allocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Broker .

ind:allocationPartyId rdf:type rdf:Property ;
    rdfs:label 'Allocation Party Id' ;
    rdfs:comment 'Reference to the institutional client on whose behalf the allocation is made, used in prime brokerage and institutional trading.' ;
    rdfs:domain ind:Allocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:affirmationPlatform rdf:type rdf:Property ;
    rdfs:label 'Affirmation Platform' ;
    rdfs:comment 'The name of the affirmation platform used to confirm the allocation, such as OASYS, ALERT, Omgeo Central Trade Manager (CTM), or Bloomberg AIM.' ;
    rdfs:domain ind:Allocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocatedPrice rdf:type rdf:Property ;
    rdfs:label 'Allocated Price' ;
    rdfs:comment 'The price at which the allocated quantity is assigned to this account. May be average price or specific fill price depending on allocation method.' ;
    rdfs:domain ind:Allocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocatedQuantity rdf:type rdf:Property ;
    rdfs:label 'Allocated Quantity' ;
    rdfs:comment 'The quantity of the security or instrument allocated to this account or fund from the block trade.' ;
    rdfs:domain ind:Allocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commissionCurrency rdf:type rdf:Property ;
    rdfs:label 'Commission Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the commission amount.' ;
    rdfs:domain ind:Allocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:percentage rdf:type rdf:Property ;
    rdfs:label 'Percentage' ;
    rdfs:comment 'The percentage of the total block trade allocated to this account, expressed as a decimal (e.g., 25.50 for 25.5%).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amendmentId rdf:type rdf:Property ;
    rdfs:label 'Amendment Id' ;
    rdfs:comment 'Unique identifier for the trade amendment record. Primary key.' ;
    rdfs:domain ind:Trade ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Amendment .

ind:amendmentEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Amendment Employee Id' ;
    rdfs:comment 'Reference to the trader who initiated the amendment request.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:amendmentNovationSuccessorPartyId rdf:type rdf:Property ;
    rdfs:label 'Amendment Novation Successor Party Id' ;
    rdfs:comment 'Reference to the new counterparty in case of novation. The party to whom the trade obligation is transferred. Null for non-novation amendments.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:amendmentPartyId rdf:type rdf:Property ;
    rdfs:label 'Amendment Party Id' ;
    rdfs:comment 'Reference to the counterparty involved in the trade amendment. May differ from original trade counterparty in case of novation.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:amendedFieldNames rdf:type rdf:Property ;
    rdfs:label 'Amended Field Names' ;
    rdfs:comment 'Comma-separated list of trade fields that were modified in this amendment (e.g., notional_amount, maturity_date, fixed_rate). Supports audit trail and change tracking.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendedFixedRate rdf:type rdf:Property ;
    rdfs:label 'Amended Fixed Rate' ;
    rdfs:comment 'The new fixed rate after the amendment. Null if rate was not changed.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amendedMaturityDate rdf:type rdf:Property ;
    rdfs:label 'Amended Maturity Date' ;
    rdfs:comment 'The new maturity date after the amendment. Null if maturity was not changed.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:amendedNotionalAmount rdf:type rdf:Property ;
    rdfs:label 'Amended Notional Amount' ;
    rdfs:comment 'The new notional amount after the amendment. Null if notional was not changed.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amendedStrikePrice rdf:type rdf:Property ;
    rdfs:label 'Amended Strike Price' ;
    rdfs:comment 'The new strike price after the amendment. Null if strike was not changed.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amendmentStatus rdf:type rdf:Property ;
    rdfs:label 'Amendment Status' ;
    rdfs:comment 'Current lifecycle status of the amendment request. Tracks the approval workflow from submission through completion or rejection.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Amendment Timestamp' ;
    rdfs:comment 'Date and time when the amendment was executed and became effective. This is the business event timestamp for the modification.' ;
    rdfs:domain ind:Trade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:compressionCycleCode rdf:type rdf:Property ;
    rdfs:label 'Compression Cycle Code' ;
    rdfs:comment 'Reference to the portfolio compression cycle if this amendment is part of a multilateral compression exercise. Null for non-compression amendments.' ;
    rdfs:domain ind:Trade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmationStatus rdf:type rdf:Property ;
    rdfs:label 'Confirmation Status' ;
    rdfs:comment 'Status of trade confirmation with the counterparty following the amendment. Tracks whether both parties have agreed to the amended terms.' ;
    rdfs:domain ind:Trade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mtmImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Mtm Impact Amount' ;
    rdfs:comment 'The change in mark-to-market valuation resulting from the amendment. Positive values indicate gains, negative values indicate losses.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalFixedRate rdf:type rdf:Property ;
    rdfs:label 'Original Fixed Rate' ;
    rdfs:comment 'The fixed rate (expressed as a decimal, e.g., 0.0325 for 3.25%) before the amendment. Applicable to interest rate swaps and fixed-income derivatives.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalNotionalAmount rdf:type rdf:Property ;
    rdfs:label 'Original Notional Amount' ;
    rdfs:comment 'The notional amount of the trade before the amendment. Captured for audit trail and regulatory reporting of economic changes.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalStrikePrice rdf:type rdf:Property ;
    rdfs:label 'Original Strike Price' ;
    rdfs:comment 'The strike price before the amendment. Applicable to options and structured products.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pnlImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Pnl Impact Amount' ;
    rdfs:comment 'The realized profit or loss impact of the amendment on the trading book. Captures economic gain or loss from the modification.' ;
    rdfs:domain ind:Trade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:captureEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Capture Employee Id' ;
    rdfs:comment 'The unique identifier of the trader who executed the trade. Used for P&L attribution, performance measurement, and MiFID II trader identification requirements.' ;
    rdfs:domain ind:Capture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tradeCurrencyId rdf:type rdf:Property ;
    rdfs:label 'Trade Currency Id' ;
    rdfs:comment 'Foreign key linking to reference.currency. Business justification: Trade currency validation essential for booking, valuation, regulatory reporting, and FX risk calculation. Reference currency master provides ISO codes, central bank data, and convertibility restricti' ;
    rdfs:domain ind:Capture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:tradeProductTypeId rdf:type rdf:Property ;
    rdfs:label 'Trade Product Type Id' ;
    rdfs:comment 'Foreign key linking to reference.product_type. Business justification: Trade product type classification drives booking model, risk categorization, regulatory capital treatment, and P&L attribution. Reference product type master provides Basel, IFRS9, and regulatory repo' ;
    rdfs:domain ind:Capture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductType .

ind:amendedBy rdf:type rdf:Property ;
    rdfs:label 'Amended By' ;
    rdfs:comment 'The user ID of the person who submitted the amendment. Part of the audit trail for trade lifecycle changes and SOX compliance.' ;
    rdfs:domain ind:Capture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookingStatus rdf:type rdf:Property ;
    rdfs:label 'Booking Status' ;
    rdfs:comment 'The current lifecycle status of the trade booking record. Tracks progression from initial capture through confirmation, amendment, settlement, or cancellation.' ;
    rdfs:domain ind:Capture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionVenue rdf:type rdf:Property ;
    rdfs:label 'Execution Venue' ;
    rdfs:comment 'The trading venue, exchange, or platform where the trade was executed. Required for MiFID II best execution and transparency reporting. Use MIC code where applicable.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portfolioCode rdf:type rdf:Property ;
    rdfs:label 'Portfolio Code' ;
    rdfs:comment 'The portfolio or strategy code for risk and P&L aggregation. Used for desk-level reporting, risk limit monitoring, and performance attribution.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeAmount rdf:type rdf:Property ;
    rdfs:label 'Trade Amount' ;
    rdfs:comment 'The total monetary value of the trade in trade currency. For cash instruments, equals notional × price. For derivatives, may represent premium or initial margin.' ;
    rdfs:domain ind:Capture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tradeReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Trade Reference Number' ;
    rdfs:comment 'Internal business identifier for the trade used across front office, middle office, and back office systems. Human-readable reference for trade inquiries and reconciliation.' ;
    rdfs:domain ind:Capture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Trade Timestamp' ;
    rdfs:comment 'Precise timestamp when the trade was executed, including milliseconds. Required for MiFID II transaction reporting and best execution analysis.' ;
    rdfs:domain ind:Capture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:tradeVersion rdf:type rdf:Property ;
    rdfs:label 'Trade Version' ;
    rdfs:comment 'Sequential version number incremented with each amendment or lifecycle event. Version 1 represents the original trade; subsequent versions capture economic amendments, administrative corrections, novations, or compressions.' ;
    rdfs:domain ind:Capture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tradingBook rdf:type rdf:Property ;
    rdfs:label 'Trading Book' ;
    rdfs:comment 'The trading book or portfolio to which the trade is assigned. Used for P&L attribution, risk limits, and FRTB boundary determination between trading book and banking book.' ;
    rdfs:domain ind:Capture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usi rdf:type rdf:Property ;
    rdfs:label 'Usi' ;
    rdfs:comment 'US-specific unique identifier for swap transactions required under Dodd-Frank Act reporting rules. Used for CFTC and SEC swap data repository reporting.' ;
    rdfs:domain ind:Trade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmationId rdf:type rdf:Property ;
    rdfs:label 'Confirmation Id' ;
    rdfs:comment 'Unique identifier for the trade confirmation record. Primary key for the trade confirmation entity.' ;
    rdfs:domain ind:Confirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:confirmationMethod rdf:type rdf:Property ;
    rdfs:label 'Confirmation Method' ;
    rdfs:comment 'Method by which the trade confirmation was exchanged with the counterparty. Electronic methods include DTCC, MarkitWire, SWIFT MT3xx messages; manual methods include paper, email, fax. [ENUM-REF-CANDIDATE: electronic|paper|swift|dtcc|markit_wire|email|fax — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Confirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Confirmation Timestamp' ;
    rdfs:comment 'Date and time when the trade confirmation was successfully matched and confirmed by both parties. Critical for regulatory timely confirmation requirements under Dodd-Frank and EMIR.' ;
    rdfs:domain ind:Trade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:counterpartyConfirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Counterparty Confirmation Number' ;
    rdfs:comment 'The confirmation reference number assigned by the counterparty to this trade. Used for bilateral reconciliation and matching.' ;
    rdfs:domain ind:Confirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deadline rdf:type rdf:Property ;
    rdfs:label 'Deadline' ;
    rdfs:comment 'Regulatory deadline by which the trade must be confirmed to comply with Dodd-Frank and EMIR timely confirmation requirements. Varies by asset class and trade type.' ;
    rdfs:domain ind:Confirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:discrepancyResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Resolution Date' ;
    rdfs:comment 'The date on which any identified discrepancies were resolved and the confirmation was successfully matched. Null if discrepancies remain outstanding.' ;
    rdfs:domain ind:Confirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dtccConfirmationReference rdf:type rdf:Property ;
    rdfs:label 'Dtcc Confirmation Reference' ;
    rdfs:comment 'Unique confirmation identifier assigned by DTCC for electronically confirmed trades processed through DTCC Deriv/SERV or other DTCC confirmation platforms.' ;
    rdfs:domain ind:Confirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leiReportingEntity rdf:type rdf:Property ;
    rdfs:label 'Lei Reporting Entity' ;
    rdfs:comment '20-character Legal Entity Identifier of the reporting entity (the bank) for regulatory trade reporting purposes.' ;
    rdfs:domain ind:Confirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:markitWireReference rdf:type rdf:Property ;
    rdfs:label 'Markit Wire Reference' ;
    rdfs:comment 'Unique reference number assigned by MarkitWire electronic confirmation platform for OTC derivative confirmations processed through MarkitWire.' ;
    rdfs:domain ind:Confirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchingToleranceBreached rdf:type rdf:Property ;
    rdfs:label 'Matching Tolerance Breached' ;
    rdfs:comment 'Indicates whether the confirmation matching process identified differences that exceeded predefined tolerance thresholds for price, quantity, or other economic terms.' ;
    rdfs:domain ind:Confirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sent Timestamp' ;
    rdfs:comment 'Date and time when the confirmation was initially sent to the counterparty for matching and acknowledgment.' ;
    rdfs:domain ind:Confirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:tradePrice rdf:type rdf:Property ;
    rdfs:label 'Trade Price' ;
    rdfs:comment 'The execution price of the trade as confirmed by both parties. For securities, this is the per-unit price; for derivatives, may represent strike, rate, or spread.' ;
    rdfs:domain ind:Confirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tradeFeeId rdf:type rdf:Property ;
    rdfs:label 'Trade Fee Id' ;
    rdfs:comment 'Unique identifier for the trade fee record. Primary key for the trade fee entity.' ;
    rdfs:domain ind:TradeFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:externalFeeReference rdf:type rdf:Property ;
    rdfs:label 'External Fee Reference' ;
    rdfs:comment 'Fee identifier from the source system. Supports reconciliation and lineage tracking back to operational systems.' ;
    rdfs:domain ind:TradeFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rate rdf:type rdf:Property ;
    rdfs:label 'Rate' ;
    rdfs:comment 'Rate or percentage applied to calculate the fee amount. For BPS-based fees, expressed in basis points. For percentage fees, expressed as decimal (e.g., 0.0025 for 0.25%).' ;
    rdfs:domain ind:TradeFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rebateAmount rdf:type rdf:Property ;
    rdfs:label 'Rebate Amount' ;
    rdfs:comment 'Rebate or discount applied to the gross fee. Supports volume-based rebate programs and fee negotiation tracking.' ;
    rdfs:domain ind:TradeFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxRate rdf:type rdf:Property ;
    rdfs:label 'Tax Rate' ;
    rdfs:comment 'Tax rate applied to the fee, expressed as a decimal. Supports tax calculation verification and audit.' ;
    rdfs:domain ind:TradeFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tcaEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Tca Eligible Flag' ;
    rdfs:comment 'Indicates whether this fee is included in Transaction Cost Analysis (TCA) for best execution monitoring and broker performance evaluation.' ;
    rdfs:domain ind:TradeFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tradeLifecycleEventId rdf:type rdf:Property ;
    rdfs:label 'Trade Lifecycle Event Id' ;
    rdfs:comment 'Unique identifier for the trade lifecycle event record. Primary key for the immutable event log.' ;
    rdfs:domain ind:Trade ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TradeLifecycleEvent .

ind:eventProductTypeId rdf:type rdf:Property ;
    rdfs:label 'Event Product Type Id' ;
    rdfs:comment 'Foreign key linking to reference.product_type. Business justification: Lifecycle event product type classification required for regulatory reporting, operational processing, and event routing. Reference product type master provides regulatory categories and processing ru' ;
    rdfs:domain ind:TradeLifecycleEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductType .

ind:primaryTradeSuccessorCounterpartyId rdf:type rdf:Property ;
    rdfs:label 'Primary Trade Successor Counterparty Id' ;
    rdfs:comment 'Identifier of the new counterparty assuming obligations in a novation event. Null for non-novation events.' ;
    rdfs:domain ind:TradeLifecycleEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:tradePartyId rdf:type rdf:Property ;
    rdfs:label 'Trade Party Id' ;
    rdfs:comment 'Identifier of the counterparty involved in the lifecycle event. For novations, this may represent the transferring or receiving party.' ;
    rdfs:domain ind:TradeLifecycleEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:cashSettlementAmount rdf:type rdf:Property ;
    rdfs:label 'Cash Settlement Amount' ;
    rdfs:comment 'Actual cash amount exchanged between counterparties as a result of the lifecycle event. Includes termination fees, novation premiums, or compression payments.' ;
    rdfs:domain ind:Trade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cashSettlementCurrency rdf:type rdf:Property ;
    rdfs:label 'Cash Settlement Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the cash settlement amount.' ;
    rdfs:domain ind:TradeLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compressionServiceProvider rdf:type rdf:Property ;
    rdfs:label 'Compression Service Provider' ;
    rdfs:comment 'Name of the third-party service provider facilitating the portfolio compression. Examples include TriOptima, LCH, CME.' ;
    rdfs:domain ind:Trade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:economicImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Economic Impact Amount' ;
    rdfs:comment 'Net cash or mark-to-market impact resulting from the lifecycle event. Positive values represent gains, negative values represent losses.' ;
    rdfs:domain ind:TradeLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:economicImpactCurrency rdf:type rdf:Property ;
    rdfs:label 'Economic Impact Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the economic impact amount.' ;
    rdfs:domain ind:TradeLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalEventReference rdf:type rdf:Property ;
    rdfs:label 'External Event Reference' ;
    rdfs:comment 'Identifier assigned to this lifecycle event by an external system or counterparty. Used for cross-system reconciliation.' ;
    rdfs:domain ind:TradeLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portfolioReconciliationFlag rdf:type rdf:Property ;
    rdfs:label 'Portfolio Reconciliation Flag' ;
    rdfs:comment 'Indicates whether this lifecycle event was identified and processed as part of a portfolio reconciliation exercise between counterparties.' ;
    rdfs:domain ind:TradeLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reconciliationDiscrepancyFlag rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Discrepancy Flag' ;
    rdfs:comment 'Indicates whether a discrepancy was identified during portfolio reconciliation that triggered this lifecycle event.' ;
    rdfs:domain ind:TradeLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:successorCounterpartyLei rdf:type rdf:Property ;
    rdfs:label 'Successor Counterparty Lei' ;
    rdfs:comment 'Legal Entity Identifier of the successor counterparty in a novation. Required for regulatory reporting of novation events.' ;
    rdfs:domain ind:TradeLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeRepositoryCode rdf:type rdf:Property ;
    rdfs:label 'Trade Repository Code' ;
    rdfs:comment 'Identifier of the trade repository to which this lifecycle event was reported. Examples include DTCC, Regis-TR, KDPW.' ;
    rdfs:domain ind:Trade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeMarginCallId rdf:type rdf:Property ;
    rdfs:label 'Trade Margin Call Id' ;
    rdfs:comment 'Unique identifier for the margin call record. Primary key for the trade margin call entity.' ;
    rdfs:domain ind:TradeMarginCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:callCurrencyId rdf:type rdf:Property ;
    rdfs:label 'Call Currency Id' ;
    rdfs:comment 'Foreign key linking to reference.currency. Business justification: Margin call currency validation required for collateral valuation, settlement processing, and CSA agreement compliance. Reference data provides FX rates and currency restrictions for margin calculatio' ;
    rdfs:domain ind:TradeMarginCall ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:callType rdf:type rdf:Property ;
    rdfs:label 'Call Type' ;
    rdfs:comment 'Type of margin call: variation margin (VM) to cover mark-to-market exposure, initial margin (IM) for potential future exposure, additional margin for increased risk, or return of excess collateral.' ;
    rdfs:domain ind:TradeMarginCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingHouseCode rdf:type rdf:Property ;
    rdfs:label 'Clearing House Code' ;
    rdfs:comment 'Reference to the central counterparty clearing house if this is a cleared margin call.' ;
    rdfs:domain ind:Trade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingHouseFlag rdf:type rdf:Property ;
    rdfs:label 'Clearing House Flag' ;
    rdfs:comment 'Indicates whether this margin call is for a centrally cleared derivative (true) or a bilateral OTC derivative (false).' ;
    rdfs:domain ind:TradeMarginCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:collateralHeldAmount rdf:type rdf:Property ;
    rdfs:label 'Collateral Held Amount' ;
    rdfs:comment 'The total value of collateral currently held against the exposure prior to this margin call.' ;
    rdfs:domain ind:TradeMarginCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:custodianAccountReference rdf:type rdf:Property ;
    rdfs:label 'Custodian Account Reference' ;
    rdfs:comment 'Reference to the third-party custodian account where segregated initial margin is held.' ;
    rdfs:domain ind:TradeMarginCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeRaisedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Dispute Raised Timestamp' ;
    rdfs:comment 'Timestamp when the dispute was formally raised by the counterparty.' ;
    rdfs:domain ind:TradeMarginCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:disputeResolvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolved Timestamp' ;
    rdfs:comment 'Timestamp when the margin call dispute was resolved between the parties.' ;
    rdfs:domain ind:TradeMarginCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eligibleCollateralSchedule rdf:type rdf:Property ;
    rdfs:label 'Eligible Collateral Schedule' ;
    rdfs:comment 'Reference to the schedule in the CSA defining which types of collateral are acceptable for this margin call.' ;
    rdfs:domain ind:TradeMarginCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exposureAmount rdf:type rdf:Property ;
    rdfs:label 'Exposure Amount' ;
    rdfs:comment 'The current mark-to-market exposure or net present value of the derivative position that drives the margin call calculation.' ;
    rdfs:domain ind:TradeMarginCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isdaAgreementReference rdf:type rdf:Property ;
    rdfs:label 'Isda Agreement Reference' ;
    rdfs:comment 'Reference number of the master ISDA agreement under which this margin call is executed.' ;
    rdfs:domain ind:TradeMarginCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netMarginCallAmount rdf:type rdf:Property ;
    rdfs:label 'Net Margin Call Amount' ;
    rdfs:comment 'The net amount to be transferred after accounting for existing collateral, threshold, and minimum transfer amount.' ;
    rdfs:domain ind:TradeMarginCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responseDeadlineTimestamp rdf:type rdf:Property ;
    rdfs:label 'Response Deadline Timestamp' ;
    rdfs:comment 'The deadline by which the counterparty must respond to and settle the margin call.' ;
    rdfs:domain ind:TradeMarginCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:segregationRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Segregation Requirement Flag' ;
    rdfs:comment 'Indicates whether regulatory initial margin segregation is required for this margin call under BCBS-IOSCO UMR.' ;
    rdfs:domain ind:TradeMarginCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:averageCost rdf:type rdf:Property ;
    rdfs:label 'Average Cost' ;
    rdfs:comment 'The weighted average cost per unit at which the position was acquired. Used for realized P&L calculation.' ;
    rdfs:domain ind:TradePosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Base Currency Code' ;
    rdfs:comment 'The three-letter ISO currency code of the reporting entity\'s base currency for P&L and risk reporting.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseCurrencyMarketValue rdf:type rdf:Property ;
    rdfs:label 'Base Currency Market Value' ;
    rdfs:comment 'The market value of the position converted to the base currency using the FX rate.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseCurrencyUnrealizedPnl rdf:type rdf:Property ;
    rdfs:label 'Base Currency Unrealized Pnl' ;
    rdfs:comment 'The unrealized P&L converted to the base currency for consolidated reporting.' ;
    rdfs:domain ind:TradePosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:breakFlag rdf:type rdf:Property ;
    rdfs:label 'Break Flag' ;
    rdfs:comment 'Indicates whether this position has a reconciliation break or discrepancy that requires investigation.' ;
    rdfs:domain ind:TradePosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:breakReason rdf:type rdf:Property ;
    rdfs:label 'Break Reason' ;
    rdfs:comment 'Description of the reason for the position break or reconciliation discrepancy, if applicable.' ;
    rdfs:domain ind:TradePosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastRevaluationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Revaluation Timestamp' ;
    rdfs:comment 'The timestamp of the most recent MTM revaluation cycle that updated this position\'s market value and P&L.' ;
    rdfs:domain ind:TradePosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:positionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Position Timestamp' ;
    rdfs:comment 'The precise timestamp when this position record was captured or updated. Used for intraday position keeping and real-time risk monitoring.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:quantityUnit rdf:type rdf:Property ;
    rdfs:label 'Quantity Unit' ;
    rdfs:comment 'The unit of measure for the position quantity (e.g., shares for equities, contracts for futures, notional for swaps).' ;
    rdfs:domain ind:TradePosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:realizedPnl rdf:type rdf:Property ;
    rdfs:label 'Realized Pnl' ;
    rdfs:comment 'The cumulative realized profit or loss from closed or partially closed positions during the current period.' ;
    rdfs:domain ind:TradePosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rho rdf:type rdf:Property ;
    rdfs:label 'Rho' ;
    rdfs:comment 'The sensitivity of the position value to changes in the risk-free interest rate. Greek for interest rate sensitivity.' ;
    rdfs:domain ind:TradePosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:theta rdf:type rdf:Property ;
    rdfs:label 'Theta' ;
    rdfs:comment 'The rate of change of the position value with respect to the passage of time (time decay). Key Greek for options positions.' ;
    rdfs:domain ind:TradePosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryReportId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Id' ;
    rdfs:comment 'Unique identifier for the regulatory trade report record. Primary key for the trade regulatory report entity.' ;
    rdfs:domain ind:RegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clearingHouseLei rdf:type rdf:Property ;
    rdfs:label 'Clearing House Lei' ;
    rdfs:comment '20-character Legal Entity Identifier of the central counterparty (CCP) clearing house if the trade is centrally cleared.' ;
    rdfs:domain ind:RegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collateralPortfolioCode rdf:type rdf:Property ;
    rdfs:label 'Collateral Portfolio Code' ;
    rdfs:comment 'Identifier for the collateral portfolio or margin account associated with this trade for uncleared derivatives subject to margin requirements under EMIR and Dodd-Frank.' ;
    rdfs:domain ind:RegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intragroupFlag rdf:type rdf:Property ;
    rdfs:label 'Intragroup Flag' ;
    rdfs:comment 'Boolean indicator of whether this trade is between entities within the same corporate group. Intragroup trades may be exempt from certain clearing and margin requirements.' ;
    rdfs:domain ind:RegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rejectionCode rdf:type rdf:Property ;
    rdfs:label 'Rejection Code' ;
    rdfs:comment 'Standardized error code assigned by the trade repository indicating the specific validation rule or data quality check that failed.' ;
    rdfs:domain ind:RegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportVersion rdf:type rdf:Property ;
    rdfs:label 'Report Version' ;
    rdfs:comment 'Version number of the regulatory report for the same trade, incremented with each modification or correction submission to track the reporting history.' ;
    rdfs:domain ind:RegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reportingCounterpartyLei rdf:type rdf:Property ;
    rdfs:label 'Reporting Counterparty Lei' ;
    rdfs:comment '20-character Legal Entity Identifier of the counterparty responsible for submitting this regulatory report to the trade repository or regulatory authority.' ;
    rdfs:domain ind:RegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingEntityLei rdf:type rdf:Property ;
    rdfs:label 'Reporting Entity Lei' ;
    rdfs:comment '20-character Legal Entity Identifier of the legal entity within the bank that is submitting this report on behalf of the reporting counterparty.' ;
    rdfs:domain ind:RegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingSide rdf:type rdf:Property ;
    rdfs:label 'Reporting Side' ;
    rdfs:comment 'Indicates which side of the trade this report represents - buy side, sell side, or both sides for dual-sided reporting requirements.' ;
    rdfs:domain ind:RegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeRepositoryName rdf:type rdf:Property ;
    rdfs:label 'Trade Repository Name' ;
    rdfs:comment 'Name of the authorized trade repository to which this regulatory report was submitted, such as DTCC GTR, REGIS-TR, UnaVista, CME SDR, ICE Trade Vault, or Bloomberg SDR.' ;
    rdfs:domain ind:RegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:venueOfExecution rdf:type rdf:Property ;
    rdfs:label 'Venue Of Execution' ;
    rdfs:comment 'Market Identifier Code (MIC) or name of the trading venue where the trade was executed - exchange, MTF, OTF, SEF, or OTC bilateral.' ;
    rdfs:domain ind:RegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentBookTradingBookId rdf:type rdf:Property ;
    rdfs:label 'Parent Book Trading Book Id' ;
    rdfs:comment 'Identifier of the parent trading book in the book hierarchy. Null if this is a top-level book. Used for hierarchical risk aggregation.' ;
    rdfs:domain ind:TradingBook ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TradingBook .

ind:primaryTradingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Trading Employee Id' ;
    rdfs:comment 'Employee identifier of the head trader or portfolio manager responsible for the book. Used for accountability and limit approval workflows.' ;
    rdfs:domain ind:TradingBook ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryTradingHeadTraderEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Trading Head Trader Employee Id' ;
    rdfs:comment 'FK to hr.employee' ;
    rdfs:domain ind:TradingBook ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryTradingApprovedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Trading Approved By User Employee Id' ;
    rdfs:comment 'User identifier of the risk manager or approver who approved this trading book or its limit framework.' ;
    rdfs:domain ind:TradingBook ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:bookCode rdf:type rdf:Property ;
    rdfs:label 'Book Code' ;
    rdfs:comment 'Externally-known unique alphanumeric code identifying the trading book across systems and regulatory reports. Used in trade capture, risk reporting, and P&L attribution.' ;
    rdfs:domain ind:TradingBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookHierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Book Hierarchy Level' ;
    rdfs:comment 'Numeric level in the trading book hierarchy (1 = top level, 2 = sub-book, etc.). Used for roll-up and drill-down reporting.' ;
    rdfs:domain ind:TradingBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bookName rdf:type rdf:Property ;
    rdfs:label 'Book Name' ;
    rdfs:comment 'Human-readable name of the trading book, typically reflecting the desk, asset class, or strategy (e.g., \'USD Rates Desk\', \'Equity Derivatives EMEA\').' ;
    rdfs:domain ind:TradingBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookShortName rdf:type rdf:Property ;
    rdfs:label 'Book Short Name' ;
    rdfs:comment 'Abbreviated name or acronym for the trading book used in operational systems and trader screens.' ;
    rdfs:domain ind:TradingBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookStatus rdf:type rdf:Property ;
    rdfs:label 'Book Status' ;
    rdfs:comment 'Current operational status of the trading book. Only active books can accept new trades.' ;
    rdfs:domain ind:TradingBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deskName rdf:type rdf:Property ;
    rdfs:label 'Desk Name' ;
    rdfs:comment 'Name of the trading desk or unit responsible for this book. Used for organizational hierarchy and P&L roll-up.' ;
    rdfs:domain ind:TradingBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dv01LimitAmount rdf:type rdf:Property ;
    rdfs:label 'Dv01 Limit Amount' ;
    rdfs:comment 'Maximum DV01 (dollar value of a one basis point move in interest rates) limit for the book, expressed in base currency. Applicable primarily to rates books.' ;
    rdfs:domain ind:TradingBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:imaApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Ima Approval Status' ;
    rdfs:comment 'Regulatory approval status for using Internal Models Approach (IMA) for this book. Only approved books can use IMA for capital calculation.' ;
    rdfs:domain ind:TradingBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isProprietaryTrading rdf:type rdf:Property ;
    rdfs:label 'Is Proprietary Trading' ;
    rdfs:comment 'Boolean flag indicating whether this book engages in proprietary trading (True) or client-facilitation trading (False). Relevant for Volcker Rule compliance.' ;
    rdfs:domain ind:TradingBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastLimitReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Limit Review Date' ;
    rdfs:comment 'Date when risk limits for this book were last reviewed and approved by the Asset-Liability Committee (ALCO) or risk committee.' ;
    rdfs:domain ind:TradingBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:locationCode rdf:type rdf:Property ;
    rdfs:label 'Location Code' ;
    rdfs:comment 'Three-letter code identifying the primary trading location or office for this book (e.g., NYC, LDN, HKG).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextLimitReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Limit Review Date' ;
    rdfs:comment 'Scheduled date for the next risk limit review for this book.' ;
    rdfs:domain ind:TradingBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:stressLossLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Stress Loss Limit Amount' ;
    rdfs:comment 'Maximum allowable loss under stress scenarios, expressed in base currency. Used for stress testing and CCAR/DFAST compliance.' ;
    rdfs:domain ind:TradingBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tradingStrategy rdf:type rdf:Property ;
    rdfs:label 'Trading Strategy' ;
    rdfs:comment 'Primary trading strategy employed by the book (e.g., market making, proprietary trading, client facilitation). Influences risk appetite and limit framework.' ;
    rdfs:domain ind:TradingBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Var Limit Amount' ;
    rdfs:comment 'Maximum Value at Risk (VaR) limit assigned to this trading book, expressed in base currency. Represents the maximum potential loss at a given confidence level.' ;
    rdfs:domain ind:TradingBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varTimeHorizonDays rdf:type rdf:Property ;
    rdfs:label 'Var Time Horizon Days' ;
    rdfs:comment 'Time horizon in days over which VaR is calculated, typically 1 day or 10 days.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:volckerRuleExemption rdf:type rdf:Property ;
    rdfs:label 'Volcker Rule Exemption' ;
    rdfs:comment 'Applicable Volcker Rule exemption category for this book, if any. Determines permissible trading activities under Dodd-Frank.' ;
    rdfs:domain ind:TradingBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minutesApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Minutes Approved By Employee Id' ;
    rdfs:comment 'Foreign key linking to hr.employee. Business justification: ALCO meeting minutes require formal approval by secretary or compliance officer for regulatory examination readiness and board governance. minutes_approved_by text field should be FK to employee_id fo' ;
    rdfs:domain ind:AlcoMeeting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actionItemsCount rdf:type rdf:Property ;
    rdfs:label 'Action Items Count' ;
    rdfs:comment 'Total number of action items assigned during the meeting, requiring follow-up by specific owners with target completion dates.' ;
    rdfs:domain ind:AlcoMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:agendaSummary rdf:type rdf:Property ;
    rdfs:label 'Agenda Summary' ;
    rdfs:comment 'High-level summary of the meeting agenda topics, including key discussion items such as interest rate risk review, liquidity position, Funds Transfer Pricing (FTP) methodology, capital adequacy, and funding strategy.' ;
    rdfs:domain ind:AlcoMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capitalAllocationDecision rdf:type rdf:Property ;
    rdfs:label 'Capital Allocation Decision' ;
    rdfs:comment 'Description of any capital allocation decisions made during the meeting, including capital deployment to business lines, dividend policy changes, or share repurchase authorizations.' ;
    rdfs:domain ind:AlcoMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cet1RatioReviewed rdf:type rdf:Property ;
    rdfs:label 'Cet1 Ratio Reviewed' ;
    rdfs:comment 'The Common Equity Tier 1 capital ratio reviewed and discussed during the ALCO meeting, expressed as a percentage. CET1 ratio measures the banks core equity capital against its risk-weighted assets.' ;
    rdfs:domain ind:AlcoMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chairpersonName rdf:type rdf:Property ;
    rdfs:label 'Chairperson Name' ;
    rdfs:comment 'Full name of the executive who chaired the ALCO meeting, typically the Chief Financial Officer (CFO) or Treasurer.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chairpersonTitle rdf:type rdf:Property ;
    rdfs:label 'Chairperson Title' ;
    rdfs:comment 'Official title of the chairperson (e.g., Chief Financial Officer, Treasurer, Chief Risk Officer).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dissentingOpinionsFlag rdf:type rdf:Property ;
    rdfs:label 'Dissenting Opinions Flag' ;
    rdfs:comment 'Indicator of whether any voting members recorded dissenting opinions or objections to approved resolutions. True if dissenting opinions were recorded, False otherwise.' ;
    rdfs:domain ind:AlcoMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dissentingOpinionsSummary rdf:type rdf:Property ;
    rdfs:label 'Dissenting Opinions Summary' ;
    rdfs:comment 'Summary of any dissenting opinions or objections recorded by voting members, including the nature of the dissent and the members who dissented.' ;
    rdfs:domain ind:AlcoMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ftpMethodologyChangeFlag rdf:type rdf:Property ;
    rdfs:label 'Ftp Methodology Change Flag' ;
    rdfs:comment 'Indicator of whether any changes to the Funds Transfer Pricing methodology were approved during the meeting. True if FTP methodology was modified, False otherwise.' ;
    rdfs:domain ind:AlcoMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ftpRateChangeSummary rdf:type rdf:Property ;
    rdfs:label 'Ftp Rate Change Summary' ;
    rdfs:comment 'Summary of any FTP rate changes approved during the meeting, including affected product lines, rate adjustments, and effective dates.' ;
    rdfs:domain ind:AlcoMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundingStrategyDecision rdf:type rdf:Property ;
    rdfs:label 'Funding Strategy Decision' ;
    rdfs:comment 'Description of any funding strategy decisions made during the meeting, including changes to wholesale funding mix, deposit pricing strategy, repo and reverse repo activity, or interbank funding approach.' ;
    rdfs:domain ind:AlcoMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hedgingMandateDecision rdf:type rdf:Property ;
    rdfs:label 'Hedging Mandate Decision' ;
    rdfs:comment 'Description of any hedging mandates or derivative strategy decisions made during the meeting, including interest rate swaps, currency hedges, or other risk mitigation instruments.' ;
    rdfs:domain ind:AlcoMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interestRateRiskAssessment rdf:type rdf:Property ;
    rdfs:label 'Interest Rate Risk Assessment' ;
    rdfs:comment 'Summary of the interest rate risk position and sensitivity analysis reviewed during the meeting, including duration gap, earnings-at-risk, and economic value of equity impact under various rate scenarios.' ;
    rdfs:domain ind:AlcoMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyDecisionsSummary rdf:type rdf:Property ;
    rdfs:label 'Key Decisions Summary' ;
    rdfs:comment 'Executive summary of the most significant decisions made during the meeting, including FTP rate changes, liquidity limit revisions, hedging mandates, capital actions, and funding strategy approvals.' ;
    rdfs:domain ind:AlcoMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lcrRatioReviewed rdf:type rdf:Property ;
    rdfs:label 'Lcr Ratio Reviewed' ;
    rdfs:comment 'The Liquidity Coverage Ratio value reviewed and discussed during the ALCO meeting, expressed as a percentage. LCR measures the banks ability to meet short-term liquidity needs under stress scenarios.' ;
    rdfs:domain ind:AlcoMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:liquidityLimitRevision rdf:type rdf:Property ;
    rdfs:label 'Liquidity Limit Revision' ;
    rdfs:comment 'Description of any revisions to liquidity limits or risk appetite thresholds approved during the meeting, including changes to minimum LCR targets, NSFR targets, or contingency funding plan triggers.' ;
    rdfs:domain ind:AlcoMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meetingDate rdf:type rdf:Property ;
    rdfs:label 'Meeting Date' ;
    rdfs:comment 'The calendar date on which the ALCO meeting was held.' ;
    rdfs:domain ind:AlcoMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:meetingEndTime rdf:type rdf:Property ;
    rdfs:label 'Meeting End Time' ;
    rdfs:comment 'The precise timestamp when the ALCO meeting concluded.' ;
    rdfs:domain ind:AlcoMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:meetingLocation rdf:type rdf:Property ;
    rdfs:label 'Meeting Location' ;
    rdfs:comment 'Physical or virtual location where the ALCO meeting was held (e.g., headquarters boardroom, regional office, video conference platform).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meetingReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Meeting Reference Number' ;
    rdfs:comment 'Business-facing unique reference number for the ALCO meeting, used in governance documentation and regulatory examination records.' ;
    rdfs:domain ind:AlcoMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meetingStartTime rdf:type rdf:Property ;
    rdfs:label 'Meeting Start Time' ;
    rdfs:comment 'The precise timestamp when the ALCO meeting commenced.' ;
    rdfs:domain ind:AlcoMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:meetingStatus rdf:type rdf:Property ;
    rdfs:label 'Meeting Status' ;
    rdfs:comment 'Current lifecycle status of the ALCO meeting: scheduled (planned but not yet held), in_progress (currently underway), completed (concluded with minutes finalized), cancelled (meeting did not occur), or postponed (rescheduled to future date).' ;
    rdfs:domain ind:AlcoMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meetingType rdf:type rdf:Property ;
    rdfs:label 'Meeting Type' ;
    rdfs:comment 'Classification of the ALCO meeting based on its purpose and scheduling: regular (scheduled recurring), special (called for specific issue), emergency (urgent convening), quarterly (formal quarterly review), annual (annual strategic review), or ad hoc (unscheduled).' ;
    rdfs:domain ind:AlcoMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minutesFinalizedDate rdf:type rdf:Property ;
    rdfs:label 'Minutes Finalized Date' ;
    rdfs:comment 'The date on which the official meeting minutes were finalized and approved for distribution to ALCO members and regulatory examination files.' ;
    rdfs:domain ind:AlcoMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextMeetingScheduledDate rdf:type rdf:Property ;
    rdfs:label 'Next Meeting Scheduled Date' ;
    rdfs:comment 'The scheduled date for the next ALCO meeting, as determined during the current meeting.' ;
    rdfs:domain ind:AlcoMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nimReviewed rdf:type rdf:Property ;
    rdfs:label 'Nim Reviewed' ;
    rdfs:comment 'The Net Interest Margin value reviewed and discussed during the ALCO meeting, expressed as a percentage. NIM measures the difference between interest income generated and interest paid out relative to interest-earning assets.' ;
    rdfs:domain ind:AlcoMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nsfrRatioReviewed rdf:type rdf:Property ;
    rdfs:label 'Nsfr Ratio Reviewed' ;
    rdfs:comment 'The Net Stable Funding Ratio value reviewed and discussed during the ALCO meeting, expressed as a percentage. NSFR measures the banks stable funding relative to required stable funding over a one-year horizon.' ;
    rdfs:domain ind:AlcoMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quorumAchievedFlag rdf:type rdf:Property ;
    rdfs:label 'Quorum Achieved Flag' ;
    rdfs:comment 'Indicator of whether the meeting achieved the required quorum of voting members to conduct official business and pass resolutions. True if quorum was met, False otherwise.' ;
    rdfs:domain ind:AlcoMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryExaminationReadiness rdf:type rdf:Property ;
    rdfs:label 'Regulatory Examination Readiness' ;
    rdfs:comment 'Assessment of the banks readiness for upcoming regulatory examinations by the Federal Reserve or OCC, including any governance gaps or documentation improvements identified.' ;
    rdfs:domain ind:AlcoMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionsApproved rdf:type rdf:Property ;
    rdfs:label 'Resolutions Approved' ;
    rdfs:comment 'Number of resolutions that received approval from the voting members during the meeting.' ;
    rdfs:domain ind:AlcoMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:resolutionsDeferred rdf:type rdf:Property ;
    rdfs:label 'Resolutions Deferred' ;
    rdfs:comment 'Number of resolutions that were deferred to a future meeting for further analysis or discussion.' ;
    rdfs:domain ind:AlcoMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:resolutionsRejected rdf:type rdf:Property ;
    rdfs:label 'Resolutions Rejected' ;
    rdfs:comment 'Number of resolutions that were rejected or voted down by the voting members during the meeting.' ;
    rdfs:domain ind:AlcoMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:secretaryName rdf:type rdf:Property ;
    rdfs:label 'Secretary Name' ;
    rdfs:comment 'Full name of the individual responsible for recording meeting minutes and maintaining ALCO governance documentation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalAttendees rdf:type rdf:Property ;
    rdfs:label 'Total Attendees' ;
    rdfs:comment 'Total number of individuals who attended the ALCO meeting, including voting members, non-voting participants, and observers.' ;
    rdfs:domain ind:AlcoMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalResolutions rdf:type rdf:Property ;
    rdfs:label 'Total Resolutions' ;
    rdfs:comment 'Total number of formal resolutions or decisions voted upon and recorded during the ALCO meeting.' ;
    rdfs:domain ind:AlcoMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:votingMembersPresent rdf:type rdf:Property ;
    rdfs:label 'Voting Members Present' ;
    rdfs:comment 'Number of voting ALCO members present at the meeting, used to determine quorum and voting eligibility.' ;
    rdfs:domain ind:AlcoMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:votingMembersRequired rdf:type rdf:Property ;
    rdfs:label 'Voting Members Required' ;
    rdfs:comment 'Minimum number of voting members required to achieve quorum for the ALCO meeting, as defined in the ALCO charter.' ;
    rdfs:domain ind:AlcoMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supersededResolutionAlcoResolutionId rdf:type rdf:Property ;
    rdfs:label 'Superseded Resolution Alco Resolution Id' ;
    rdfs:comment 'Reference to a prior ALCO resolution that this resolution replaces or amends. Maintains resolution lineage.' ;
    rdfs:domain ind:AlcoResolution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AlcoResolution .

ind:approvedByUser rdf:type rdf:Property ;
    rdfs:label 'Approved By User' ;
    rdfs:comment 'User identifier or name of the individual who formally approved the resolution (typically ALCO Chair or designated authority).' ;
    rdfs:domain ind:Treasury ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionStatus rdf:type rdf:Property ;
    rdfs:label 'Decision Status' ;
    rdfs:comment 'Current lifecycle status of the resolution. Tracks progression from proposal through implementation.' ;
    rdfs:domain ind:AlcoResolution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionType rdf:type rdf:Property ;
    rdfs:label 'Decision Type' ;
    rdfs:comment 'Classification of the resolution decision. Categorizes the nature of the ALCO action for regulatory reporting and internal tracking.' ;
    rdfs:domain ind:AlcoResolution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dissentingMemberNames rdf:type rdf:Property ;
    rdfs:label 'Dissenting Member Names' ;
    rdfs:comment 'Comma-separated list of ALCO member names who dissented. Provides accountability and audit trail.' ;
    rdfs:domain ind:AlcoResolution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dissentingOpinion rdf:type rdf:Property ;
    rdfs:label 'Dissenting Opinion' ;
    rdfs:comment 'Formal statement of dissent from ALCO members who voted against the resolution. Captures alternative viewpoints for governance record.' ;
    rdfs:domain ind:AlcoResolution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implementationDeadline rdf:type rdf:Property ;
    rdfs:label 'Implementation Deadline' ;
    rdfs:comment 'Target date by which the resolution must be fully implemented. Used for tracking and escalation.' ;
    rdfs:domain ind:AlcoResolution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:implementationOwner rdf:type rdf:Property ;
    rdfs:label 'Implementation Owner' ;
    rdfs:comment 'Name or identifier of the business unit or individual responsible for executing the resolution. Establishes accountability for follow-through.' ;
    rdfs:domain ind:AlcoResolution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implementationOwnerDepartment rdf:type rdf:Property ;
    rdfs:label 'Implementation Owner Department' ;
    rdfs:comment 'Department or line of business responsible for implementing the resolution (e.g., Treasury, Risk Management, Capital Markets).' ;
    rdfs:domain ind:AlcoResolution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relatedPolicyDocument rdf:type rdf:Property ;
    rdfs:label 'Related Policy Document' ;
    rdfs:comment 'Reference to the formal policy document, procedure, or guideline that this resolution updates or creates (e.g., FTP Policy, Liquidity Contingency Plan).' ;
    rdfs:domain ind:AlcoResolution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionNumber rdf:type rdf:Property ;
    rdfs:label 'Resolution Number' ;
    rdfs:comment 'Business identifier for the resolution, typically formatted as ALCO-YYYY-NNN for tracking and audit purposes.' ;
    rdfs:domain ind:AlcoResolution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionText rdf:type rdf:Property ;
    rdfs:label 'Resolution Text' ;
    rdfs:comment 'Full text of the formal resolution as recorded in the ALCO minutes. Contains the complete decision language and rationale.' ;
    rdfs:domain ind:AlcoResolution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionTitle rdf:type rdf:Property ;
    rdfs:label 'Resolution Title' ;
    rdfs:comment 'Short descriptive title of the resolution for quick identification and reporting purposes.' ;
    rdfs:domain ind:AlcoResolution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:votesAbstained rdf:type rdf:Property ;
    rdfs:label 'Votes Abstained' ;
    rdfs:comment 'Number of ALCO members who abstained from voting on the resolution.' ;
    rdfs:domain ind:AlcoResolution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:votesAgainst rdf:type rdf:Property ;
    rdfs:label 'Votes Against' ;
    rdfs:comment 'Number of ALCO members who voted against the resolution.' ;
    rdfs:domain ind:AlcoResolution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:votesFor rdf:type rdf:Property ;
    rdfs:label 'Votes For' ;
    rdfs:comment 'Number of ALCO members who voted in favor of the resolution.' ;
    rdfs:domain ind:AlcoResolution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:votingOutcome rdf:type rdf:Property ;
    rdfs:label 'Voting Outcome' ;
    rdfs:comment 'Summary result of the ALCO member vote on the resolution. Provides governance transparency for regulatory examination.' ;
    rdfs:domain ind:AlcoResolution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterpartyLeiRegistryId rdf:type rdf:Property ;
    rdfs:label 'Counterparty Lei Registry Id' ;
    rdfs:comment 'Foreign key linking to reference.lei_registry. Business justification: ALM hedges reference counterparty by LEI for credit risk and regulatory reporting. Link enables counterparty identification, ultimate parent lookup, ISDA documentation validation, and EMIR/Dodd-Frank ' ;
    rdfs:domain ind:AlmHedge ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LeiRegistry .

ind:csaAgreementId rdf:type rdf:Property ;
    rdfs:label 'Csa Agreement Id' ;
    rdfs:comment 'Reference to the CSA that governs collateral posting requirements for the hedge transaction.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CsaAgreement .

ind:floatingRateBenchmarkId rdf:type rdf:Property ;
    rdfs:label 'Floating Rate Benchmark Id' ;
    rdfs:comment 'Foreign key linking to reference.rate_benchmark. Business justification: ALM hedges reference floating rate benchmarks (SOFR, EURIBOR) for interest rate swaps. Link enables daily rate fixing, IBOR fallback application, hedge effectiveness calculation, and accrual.' ;
    rdfs:domain ind:AlmHedge ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RateBenchmark .

ind:bookingSystem rdf:type rdf:Property ;
    rdfs:label 'Booking System' ;
    rdfs:comment 'Source system where the hedge transaction was originally recorded (e.g., Murex, Calypso, Bloomberg AIM).' ;
    rdfs:domain ind:Treasury ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deDesignationDate rdf:type rdf:Property ;
    rdfs:label 'De Designation Date' ;
    rdfs:comment 'Date on which the hedge relationship was discontinued or de-designated. Triggers cessation of hedge accounting treatment.' ;
    rdfs:domain ind:AlmHedge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deDesignationReason rdf:type rdf:Property ;
    rdfs:label 'De Designation Reason' ;
    rdfs:comment 'Business or regulatory reason for discontinuing the hedge relationship (e.g., ineffectiveness, hedged item derecognition, strategic decision).' ;
    rdfs:domain ind:AlmHedge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivenessTestDate rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Test Date' ;
    rdfs:comment 'Date on which the most recent hedge effectiveness test was performed. Required for hedge accounting compliance.' ;
    rdfs:domain ind:AlmHedge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectivenessTestMethod rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Test Method' ;
    rdfs:comment 'Statistical or quantitative method used to assess hedge effectiveness. Determines compliance with hedge accounting standards.' ;
    rdfs:domain ind:AlmHedge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fairValueAmount rdf:type rdf:Property ;
    rdfs:label 'Fair Value Amount' ;
    rdfs:comment 'Current mark-to-market fair value of the hedge instrument. Used for balance sheet reporting and hedge effectiveness testing.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fairValueCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Fair Value Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the fair value amount.' ;
    rdfs:domain ind:AlmHedge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fixedRate rdf:type rdf:Property ;
    rdfs:label 'Fixed Rate' ;
    rdfs:comment 'Fixed interest rate leg of the swap or hedge instrument, expressed as a decimal (e.g., 0.0325 for 3.25%).' ;
    rdfs:domain ind:AlmHedge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:floatingRateSpreadBps rdf:type rdf:Property ;
    rdfs:label 'Floating Rate Spread Bps' ;
    rdfs:comment 'Spread in basis points added to or subtracted from the floating rate index. Represents the credit or liquidity premium.' ;
    rdfs:domain ind:AlmHedge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hedgeEffectivenessRatioProspective rdf:type rdf:Property ;
    rdfs:label 'Hedge Effectiveness Ratio Prospective' ;
    rdfs:comment 'Forward-looking ratio measuring expected effectiveness of the hedge relationship. Must be within 80-125% range for hedge accounting qualification under legacy standards.' ;
    rdfs:domain ind:AlmHedge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hedgeEffectivenessRatioRetrospective rdf:type rdf:Property ;
    rdfs:label 'Hedge Effectiveness Ratio Retrospective' ;
    rdfs:comment 'Historical ratio measuring actual effectiveness of the hedge relationship over the reporting period.' ;
    rdfs:domain ind:AlmHedge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hedgeInstrumentType rdf:type rdf:Property ;
    rdfs:label 'Hedge Instrument Type' ;
    rdfs:comment 'Type of derivative instrument used for ALM hedging purposes. Determines the risk mitigation strategy and accounting treatment. [ENUM-REF-CANDIDATE: interest_rate_swap|cross_currency_swap|basis_swap|cap|floor|swaption|futures|forward_rate_agreement — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AlmHedge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hedgeReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Hedge Reference Number' ;
    rdfs:comment 'External business identifier for the hedge transaction, used for operational tracking and ALCO reporting.' ;
    rdfs:domain ind:AlmHedge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hedgeStatus rdf:type rdf:Property ;
    rdfs:label 'Hedge Status' ;
    rdfs:comment 'Current lifecycle status of the hedge relationship. Tracks whether the hedge is actively mitigating risk or has been discontinued.' ;
    rdfs:domain ind:AlmHedge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hedgedItemReference rdf:type rdf:Property ;
    rdfs:label 'Hedged Item Reference' ;
    rdfs:comment 'Identifier of the balance sheet item or portfolio being hedged (e.g., fixed-rate loan portfolio, floating-rate deposits, foreign currency investment). Links hedge to the underlying exposure.' ;
    rdfs:domain ind:AlmHedge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hedgedRiskType rdf:type rdf:Property ;
    rdfs:label 'Hedged Risk Type' ;
    rdfs:comment 'Specific risk component being hedged. Defines the risk exposure that the hedge is designed to mitigate.' ;
    rdfs:domain ind:AlmHedge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ineffectivenessAmount rdf:type rdf:Property ;
    rdfs:label 'Ineffectiveness Amount' ;
    rdfs:comment 'Portion of hedge value change that does not offset the hedged item. Must be recognized immediately in profit and loss.' ;
    rdfs:domain ind:AlmHedge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mtmValuationDate rdf:type rdf:Property ;
    rdfs:label 'Mtm Valuation Date' ;
    rdfs:comment 'Date on which the fair value was calculated. Used for tracking valuation frequency and reporting.' ;
    rdfs:domain ind:Treasury ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:strikeRate rdf:type rdf:Property ;
    rdfs:label 'Strike Rate' ;
    rdfs:comment 'Strike rate for cap, floor, or swaption instruments. Defines the rate at which the option becomes in-the-money.' ;
    rdfs:domain ind:AlmHedge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assetLiabilityIndicator rdf:type rdf:Property ;
    rdfs:label 'Asset Liability Indicator' ;
    rdfs:comment 'Indicates whether this position represents an asset or a liability on the balance sheet.' ;
    rdfs:domain ind:BalanceSheetPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:basisRiskAmount rdf:type rdf:Property ;
    rdfs:label 'Basis Risk Amount' ;
    rdfs:comment 'The exposure to basis risk, arising from imperfect correlation between different interest rate indices.' ;
    rdfs:domain ind:Treasury ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bookValueAmount rdf:type rdf:Property ;
    rdfs:label 'Book Value Amount' ;
    rdfs:comment 'The carrying or book value of the position as recorded in the general ledger.' ;
    rdfs:domain ind:Treasury ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:durationOfEquity rdf:type rdf:Property ;
    rdfs:label 'Duration Of Equity' ;
    rdfs:comment 'The duration of equity measure, representing the sensitivity of the bank\'s economic value of equity to interest rate changes.' ;
    rdfs:domain ind:Treasury ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eveSensitivity100bps rdf:type rdf:Property ;
    rdfs:label 'Eve Sensitivity 100bps' ;
    rdfs:comment 'The change in Economic Value of Equity under a parallel shift of +/-100 basis points in interest rates.' ;
    rdfs:domain ind:BalanceSheetPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eveSensitivity200bps rdf:type rdf:Property ;
    rdfs:label 'Eve Sensitivity 200bps' ;
    rdfs:comment 'The change in Economic Value of Equity under a parallel shift of +/-200 basis points in interest rates.' ;
    rdfs:domain ind:BalanceSheetPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eveSensitivity300bps rdf:type rdf:Property ;
    rdfs:label 'Eve Sensitivity 300bps' ;
    rdfs:comment 'The change in Economic Value of Equity under a parallel shift of +/-300 basis points in interest rates.' ;
    rdfs:domain ind:BalanceSheetPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ftpProfitabilityAmount rdf:type rdf:Property ;
    rdfs:label 'Ftp Profitability Amount' ;
    rdfs:comment 'The profitability attribution for this position based on the FTP methodology.' ;
    rdfs:domain ind:BalanceSheetPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ftpRateBps rdf:type rdf:Property ;
    rdfs:label 'Ftp Rate Bps' ;
    rdfs:comment 'The internal funds transfer pricing rate applied to this position, expressed in basis points.' ;
    rdfs:domain ind:BalanceSheetPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lcrClassification rdf:type rdf:Property ;
    rdfs:label 'Lcr Classification' ;
    rdfs:comment 'The classification of this position for Liquidity Coverage Ratio calculation purposes (e.g., HQLA Level 1, HQLA Level 2A, inflow, outflow).' ;
    rdfs:domain ind:Treasury ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketValueAmount rdf:type rdf:Property ;
    rdfs:label 'Market Value Amount' ;
    rdfs:comment 'The mark-to-market (MTM) valuation of the position in the original currency.' ;
    rdfs:domain ind:Treasury ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maturityBucket rdf:type rdf:Property ;
    rdfs:label 'Maturity Bucket' ;
    rdfs:comment 'The time bucket indicating the remaining time to maturity (e.g., 0-1 year, 1-5 years, 5-10 years, over 10 years).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:niiSensitivity100bps rdf:type rdf:Property ;
    rdfs:label 'Nii Sensitivity 100bps' ;
    rdfs:comment 'The projected change in Net Interest Income over a 12-month horizon under a parallel shift of +/-100 basis points in interest rates.' ;
    rdfs:domain ind:BalanceSheetPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:niiSensitivity200bps rdf:type rdf:Property ;
    rdfs:label 'Nii Sensitivity 200bps' ;
    rdfs:comment 'The projected change in Net Interest Income over a 12-month horizon under a parallel shift of +/-200 basis points in interest rates.' ;
    rdfs:domain ind:BalanceSheetPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:niiSensitivity300bps rdf:type rdf:Property ;
    rdfs:label 'Nii Sensitivity 300bps' ;
    rdfs:comment 'The projected change in Net Interest Income over a 12-month horizon under a parallel shift of +/-300 basis points in interest rates.' ;
    rdfs:domain ind:BalanceSheetPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nsfrAsfFactor rdf:type rdf:Property ;
    rdfs:label 'Nsfr Asf Factor' ;
    rdfs:comment 'The Available Stable Funding factor applied to this position for NSFR calculation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nsfrRsfFactor rdf:type rdf:Property ;
    rdfs:label 'Nsfr Rsf Factor' ;
    rdfs:comment 'The Required Stable Funding factor applied to this position for NSFR calculation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:optionalityRiskAmount rdf:type rdf:Property ;
    rdfs:label 'Optionality Risk Amount' ;
    rdfs:comment 'The exposure to optionality risk, arising from embedded options in financial instruments (e.g., prepayment options, caps, floors).' ;
    rdfs:domain ind:Treasury ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:repricingGapAmount rdf:type rdf:Property ;
    rdfs:label 'Repricing Gap Amount' ;
    rdfs:comment 'The net repricing gap (rate-sensitive assets minus rate-sensitive liabilities) for this position within its tenor bucket.' ;
    rdfs:domain ind:Treasury ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:repricingTenorBucket rdf:type rdf:Property ;
    rdfs:label 'Repricing Tenor Bucket' ;
    rdfs:comment 'The time bucket indicating when the interest rate on this position will next reprice (e.g., overnight, 1-3 months, 3-6 months, 1-2 years).' ;
    rdfs:domain ind:BalanceSheetPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stressScenarioType rdf:type rdf:Property ;
    rdfs:label 'Stress Scenario Type' ;
    rdfs:comment 'The type of stress scenario applied to this position (e.g., baseline, adverse, severely adverse, custom).' ;
    rdfs:domain ind:Treasury ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yieldCurveRiskAmount rdf:type rdf:Property ;
    rdfs:label 'Yield Curve Risk Amount' ;
    rdfs:comment 'The exposure to yield curve risk, arising from non-parallel shifts in the yield curve.' ;
    rdfs:domain ind:Treasury ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Approved By User Employee Id' ;
    rdfs:comment 'Foreign key linking to hr.employee. Business justification: Capital plans require executive approval (CFO/CRO) for CCAR/DFAST regulatory submissions. approved_by_user text field should be FK to employee_id for governance audit trail and regulatory examination ' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:alcoApprovedTargetCet1Ratio rdf:type rdf:Property ;
    rdfs:label 'Alco Approved Target Cet1 Ratio' ;
    rdfs:comment 'Internal target CET1 ratio approved by the Asset-Liability Committee, typically above regulatory minimums to provide a management buffer.' ;
    rdfs:domain ind:CapitalPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:at1TriggerThreshold rdf:type rdf:Property ;
    rdfs:label 'At1 Trigger Threshold' ;
    rdfs:comment 'CET1 ratio threshold at which Additional Tier 1 capital instruments would be written down or converted, expressed as a percentage.' ;
    rdfs:domain ind:CapitalPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baselineCet1Ratio rdf:type rdf:Property ;
    rdfs:label 'Baseline Cet1 Ratio' ;
    rdfs:comment 'Starting Common Equity Tier 1 capital ratio at the beginning of the planning horizon, expressed as a percentage.' ;
    rdfs:domain ind:CapitalPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baselineRwaAmount rdf:type rdf:Property ;
    rdfs:label 'Baseline Rwa Amount' ;
    rdfs:comment 'Starting Risk-Weighted Assets amount at the beginning of the planning horizon, in millions of base currency.' ;
    rdfs:domain ind:CapitalPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capitalActionDescription rdf:type rdf:Property ;
    rdfs:label 'Capital Action Description' ;
    rdfs:comment 'Narrative description of planned capital actions including issuances, redemptions, dividends, and buybacks over the planning horizon.' ;
    rdfs:domain ind:CapitalPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managementBufferAboveMinimum rdf:type rdf:Property ;
    rdfs:label 'Management Buffer Above Minimum' ;
    rdfs:comment 'Management buffer maintained above the regulatory minimum CET1 ratio, expressed as percentage points.' ;
    rdfs:domain ind:CapitalPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumCet1RatioStressed rdf:type rdf:Property ;
    rdfs:label 'Minimum Cet1 Ratio Stressed' ;
    rdfs:comment 'Lowest projected CET1 ratio during the planning horizon under the stress scenario, representing the trough capital level.' ;
    rdfs:domain ind:CapitalPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netIncomeProjection rdf:type rdf:Property ;
    rdfs:label 'Net Income Projection' ;
    rdfs:comment 'Projected net income over the planning horizon under the specified scenario, in millions of base currency.' ;
    rdfs:domain ind:CapitalPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planVersion rdf:type rdf:Property ;
    rdfs:label 'Plan Version' ;
    rdfs:comment 'Version identifier for the capital plan to track revisions and resubmissions (e.g., \'v1.0\', \'v2.1 Revised\').' ;
    rdfs:domain ind:Treasury ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedCapitalIssuanceAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Capital Issuance Amount' ;
    rdfs:comment 'Total planned capital issuance (common equity, preferred stock, subordinated debt) over the planning horizon, in millions of base currency.' ;
    rdfs:domain ind:CapitalPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedCapitalRedemptionAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Capital Redemption Amount' ;
    rdfs:comment 'Total planned capital redemptions (preferred stock, subordinated debt) over the planning horizon, in millions of base currency.' ;
    rdfs:domain ind:CapitalPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedCommonStockDividendAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Common Stock Dividend Amount' ;
    rdfs:comment 'Total planned common stock dividend distributions over the planning horizon, in millions of base currency.' ;
    rdfs:domain ind:CapitalPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedDividendPayoutRatio rdf:type rdf:Property ;
    rdfs:label 'Planned Dividend Payout Ratio' ;
    rdfs:comment 'Planned dividend payout ratio as a percentage of net income over the planning horizon.' ;
    rdfs:domain ind:CapitalPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedShareBuybackAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Share Buyback Amount' ;
    rdfs:comment 'Total planned share repurchase amount over the planning horizon, in millions of base currency.' ;
    rdfs:domain ind:CapitalPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planningHorizonEndDate rdf:type rdf:Property ;
    rdfs:label 'Planning Horizon End Date' ;
    rdfs:comment 'End date of the multi-year capital planning horizon covered by this plan.' ;
    rdfs:domain ind:CapitalPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planningHorizonStartDate rdf:type rdf:Property ;
    rdfs:label 'Planning Horizon Start Date' ;
    rdfs:comment 'Start date of the multi-year capital planning horizon covered by this plan.' ;
    rdfs:domain ind:CapitalPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preProvisionNetRevenueProjection rdf:type rdf:Property ;
    rdfs:label 'Pre Provision Net Revenue Projection' ;
    rdfs:comment 'Projected pre-provision net revenue over the planning horizon under the specified scenario, in millions of base currency.' ;
    rdfs:domain ind:CapitalPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectedCet1RatioYear1 rdf:type rdf:Property ;
    rdfs:label 'Projected Cet1 Ratio Year 1' ;
    rdfs:comment 'Projected CET1 capital ratio at the end of year 1 under the specified scenario, expressed as a percentage.' ;
    rdfs:domain ind:CapitalPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectedCet1RatioYear2 rdf:type rdf:Property ;
    rdfs:label 'Projected Cet1 Ratio Year 2' ;
    rdfs:comment 'Projected CET1 capital ratio at the end of year 2 under the specified scenario, expressed as a percentage.' ;
    rdfs:domain ind:CapitalPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectedCet1RatioYear3 rdf:type rdf:Property ;
    rdfs:label 'Projected Cet1 Ratio Year 3' ;
    rdfs:comment 'Projected CET1 capital ratio at the end of year 3 under the specified scenario, expressed as a percentage.' ;
    rdfs:domain ind:CapitalPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectedRwaGrowthRateYear1 rdf:type rdf:Property ;
    rdfs:label 'Projected Rwa Growth Rate Year 1' ;
    rdfs:comment 'Projected annual growth rate of RWA in year 1, expressed as a percentage.' ;
    rdfs:domain ind:CapitalPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectedRwaGrowthRateYear2 rdf:type rdf:Property ;
    rdfs:label 'Projected Rwa Growth Rate Year 2' ;
    rdfs:comment 'Projected annual growth rate of RWA in year 2, expressed as a percentage.' ;
    rdfs:domain ind:CapitalPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectedRwaGrowthRateYear3 rdf:type rdf:Property ;
    rdfs:label 'Projected Rwa Growth Rate Year 3' ;
    rdfs:comment 'Projected annual growth rate of RWA in year 3, expressed as a percentage.' ;
    rdfs:domain ind:CapitalPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:provisionForCreditLossesProjection rdf:type rdf:Property ;
    rdfs:label 'Provision For Credit Losses Projection' ;
    rdfs:comment 'Projected provision for credit losses over the planning horizon under the specified scenario, in millions of base currency.' ;
    rdfs:domain ind:CapitalPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryMinimumCet1Ratio rdf:type rdf:Property ;
    rdfs:label 'Regulatory Minimum Cet1 Ratio' ;
    rdfs:comment 'Regulatory minimum CET1 ratio requirement applicable to the institution, expressed as a percentage.' ;
    rdfs:domain ind:Treasury ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportingEntityName rdf:type rdf:Property ;
    rdfs:label 'Reporting Entity Name' ;
    rdfs:comment 'Legal name of the bank holding company or financial institution submitting the capital plan.' ;
    rdfs:domain ind:CapitalPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stressLossProjectionAmount rdf:type rdf:Property ;
    rdfs:label 'Stress Loss Projection Amount' ;
    rdfs:comment 'Total projected losses under the stress scenario over the planning horizon, in millions of base currency.' ;
    rdfs:domain ind:CapitalPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportingCurrencyId rdf:type rdf:Property ;
    rdfs:label 'Reporting Currency Id' ;
    rdfs:comment 'Foreign key linking to reference.currency. Business justification: Capital ratios reported in regulatory currency (USD for US banks, EUR for EU banks). Link enables multi-entity consolidation, FX revaluation for group reporting, and regulatory submission validation.' ;
    rdfs:domain ind:Treasury ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:alcoTargetCet1Ratio rdf:type rdf:Property ;
    rdfs:label 'Alco Target Cet1 Ratio' ;
    rdfs:comment 'The internal ALCO-approved target CET1 ratio, typically set above regulatory minimums to provide a management buffer for business volatility and growth.' ;
    rdfs:domain ind:CapitalRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:at1TriggerBreachFlag rdf:type rdf:Property ;
    rdfs:label 'At1 Trigger Breach Flag' ;
    rdfs:comment 'Indicates whether the CET1 ratio has breached the contractual trigger level for AT1 instrument write-down or conversion (typically 5.125% or 7.0% depending on instrument terms).' ;
    rdfs:domain ind:CapitalRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capitalConservationBuffer rdf:type rdf:Property ;
    rdfs:label 'Capital Conservation Buffer' ;
    rdfs:comment 'The capital conservation buffer requirement, expressed as a percentage of RWA. Standard requirement is 2.5% of RWA in CET1 capital above the minimum.' ;
    rdfs:domain ind:CapitalRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capitalIssuanceAmount rdf:type rdf:Property ;
    rdfs:label 'Capital Issuance Amount' ;
    rdfs:comment 'The amount of new capital issuance (common equity, AT1, or Tier 2 instruments) planned or executed during the reporting period.' ;
    rdfs:domain ind:CapitalRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capitalRedemptionAmount rdf:type rdf:Property ;
    rdfs:label 'Capital Redemption Amount' ;
    rdfs:comment 'The amount of capital instrument redemptions (AT1 or Tier 2 instruments) planned or executed during the reporting period.' ;
    rdfs:domain ind:CapitalRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cet1BufferAmount rdf:type rdf:Property ;
    rdfs:label 'Cet1 Buffer Amount' ;
    rdfs:comment 'The absolute amount of CET1 capital held above the minimum regulatory requirement plus buffers, representing the management buffer or excess capital.' ;
    rdfs:domain ind:CapitalRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cet1CapitalAmount rdf:type rdf:Property ;
    rdfs:label 'Cet1 Capital Amount' ;
    rdfs:comment 'The total Common Equity Tier 1 capital amount, representing the highest quality capital consisting of common shares, retained earnings, and other comprehensive income, net of regulatory adjustments.' ;
    rdfs:domain ind:CapitalRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consolidationLevel rdf:type rdf:Property ;
    rdfs:label 'Consolidation Level' ;
    rdfs:comment 'Indicates whether the capital ratio is calculated at consolidated group level, solo legal entity level, or sub-consolidated level.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countercyclicalBuffer rdf:type rdf:Property ;
    rdfs:label 'Countercyclical Buffer' ;
    rdfs:comment 'The countercyclical capital buffer requirement, expressed as a percentage of RWA. Ranges from 0% to 2.5% and varies by jurisdiction based on credit cycle conditions.' ;
    rdfs:domain ind:CapitalRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditRwaAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Rwa Amount' ;
    rdfs:comment 'Risk-weighted assets arising from credit risk exposures, calculated using either the Standardized Approach (SA) or Internal Ratings-Based (IRB) approach.' ;
    rdfs:domain ind:CapitalRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gsibSurcharge rdf:type rdf:Property ;
    rdfs:label 'Gsib Surcharge' ;
    rdfs:comment 'The additional capital surcharge for Global Systemically Important Banks, ranging from 1.0% to 3.5% of RWA based on systemic importance score.' ;
    rdfs:domain ind:CapitalRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketRwaAmount rdf:type rdf:Property ;
    rdfs:label 'Market Rwa Amount' ;
    rdfs:comment 'Risk-weighted assets arising from market risk exposures in the trading book, calculated under the Fundamental Review of the Trading Book (FRTB) or legacy market risk framework.' ;
    rdfs:domain ind:CapitalRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operationalRwaAmount rdf:type rdf:Property ;
    rdfs:label 'Operational Rwa Amount' ;
    rdfs:comment 'Risk-weighted assets arising from operational risk, calculated using the Standardized Measurement Approach (SMA) or legacy approaches.' ;
    rdfs:domain ind:CapitalRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedBuybackAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Buyback Amount' ;
    rdfs:comment 'The planned share repurchase amount for the reporting period under the capital plan.' ;
    rdfs:domain ind:CapitalRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedDividendAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Dividend Amount' ;
    rdfs:comment 'The planned common stock dividend distribution amount for the reporting period under the capital plan.' ;
    rdfs:domain ind:CapitalRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectedCet1RatioYear1 rdf:type rdf:Property ;
    rdfs:label 'Projected Cet1 Ratio Year1' ;
    rdfs:comment 'The projected CET1 ratio for the first year of the capital planning horizon under the specified scenario.' ;
    rdfs:domain ind:CapitalRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectedCet1RatioYear2 rdf:type rdf:Property ;
    rdfs:label 'Projected Cet1 Ratio Year2' ;
    rdfs:comment 'The projected CET1 ratio for the second year of the capital planning horizon under the specified scenario.' ;
    rdfs:domain ind:CapitalRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectedCet1RatioYear3 rdf:type rdf:Property ;
    rdfs:label 'Projected Cet1 Ratio Year3' ;
    rdfs:comment 'The projected CET1 ratio for the third year of the capital planning horizon under the specified scenario.' ;
    rdfs:domain ind:CapitalRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectedRwaGrowthRate rdf:type rdf:Property ;
    rdfs:label 'Projected Rwa Growth Rate' ;
    rdfs:comment 'The assumed annual growth rate for RWA in the capital planning scenario, expressed as a percentage.' ;
    rdfs:domain ind:CapitalRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportingPeriod rdf:type rdf:Property ;
    rdfs:label 'Reporting Period' ;
    rdfs:comment 'The reporting period identifier in format YYYY-QN for quarterly or YYYY-MNN for monthly reporting cycles.' ;
    rdfs:domain ind:Treasury ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tier1CapitalAmount rdf:type rdf:Property ;
    rdfs:label 'Tier1 Capital Amount' ;
    rdfs:comment 'The total Tier 1 capital amount, comprising CET1 capital plus Additional Tier 1 (AT1) instruments such as perpetual non-cumulative preferred stock.' ;
    rdfs:domain ind:CapitalRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tier2CapitalAmount rdf:type rdf:Property ;
    rdfs:label 'Tier2 Capital Amount' ;
    rdfs:comment 'The total Tier 2 capital amount, comprising subordinated debt, hybrid instruments, and loan loss reserves up to regulatory limits.' ;
    rdfs:domain ind:CapitalRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalBufferRequirement rdf:type rdf:Property ;
    rdfs:label 'Total Buffer Requirement' ;
    rdfs:comment 'The sum of all capital buffer requirements (conservation, countercyclical, G-SIB surcharge), expressed as a percentage of RWA.' ;
    rdfs:domain ind:CapitalRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCapitalAmount rdf:type rdf:Property ;
    rdfs:label 'Total Capital Amount' ;
    rdfs:comment 'The sum of Tier 1 and Tier 2 capital, representing the total regulatory capital available to absorb losses.' ;
    rdfs:domain ind:CapitalRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalExposureMeasure rdf:type rdf:Property ;
    rdfs:label 'Total Exposure Measure' ;
    rdfs:comment 'The total exposure measure used in the leverage ratio calculation, comprising on-balance sheet exposures, derivative exposures, securities financing transaction exposures, and off-balance sheet items.' ;
    rdfs:domain ind:CapitalRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:behavioralInflowAmount rdf:type rdf:Property ;
    rdfs:label 'Behavioral Inflow Amount' ;
    rdfs:comment 'Projected behavioral cash inflows modeled from historical patterns such as deposit inflows, fee income, and trading revenues.' ;
    rdfs:domain ind:Treasury ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:behavioralOutflowAmount rdf:type rdf:Property ;
    rdfs:label 'Behavioral Outflow Amount' ;
    rdfs:comment 'Projected behavioral cash outflows including deposit runoff, credit line drawdowns, and operational expenses based on historical behavior.' ;
    rdfs:domain ind:Treasury ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bondMaturityInflowAmount rdf:type rdf:Property ;
    rdfs:label 'Bond Maturity Inflow Amount' ;
    rdfs:comment 'Projected cash inflows from bond maturities and coupon payments on held-to-maturity securities.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cashFlowCategory rdf:type rdf:Property ;
    rdfs:label 'Cash Flow Category' ;
    rdfs:comment 'Classification of the cash flow as contractual (legally binding), behavioral (modeled based on historical patterns), or contingent (conditional on events).' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contingencyFundingTriggerStatus rdf:type rdf:Property ;
    rdfs:label 'Contingency Funding Trigger Status' ;
    rdfs:comment 'Status indicating whether contingency funding plan triggers have been activated based on the forecast results.' ;
    rdfs:domain ind:Treasury ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contingentInflowAmount rdf:type rdf:Property ;
    rdfs:label 'Contingent Inflow Amount' ;
    rdfs:comment 'Projected contingent cash inflows dependent on specific events such as asset sales, securitization proceeds, or central bank facilities.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contingentOutflowAmount rdf:type rdf:Property ;
    rdfs:label 'Contingent Outflow Amount' ;
    rdfs:comment 'Projected contingent cash outflows including margin calls, collateral top-ups, guarantees called, and off-balance-sheet commitments.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractualInflowAmount rdf:type rdf:Property ;
    rdfs:label 'Contractual Inflow Amount' ;
    rdfs:comment 'Projected contractual cash inflows including loan repayments, bond maturities, coupon payments, and committed credit line repayments.' ;
    rdfs:domain ind:Treasury ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractualOutflowAmount rdf:type rdf:Property ;
    rdfs:label 'Contractual Outflow Amount' ;
    rdfs:comment 'Projected contractual cash outflows including debt maturities, coupon payments, committed facility drawdowns, and collateral posting obligations.' ;
    rdfs:domain ind:Treasury ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditLineDrawdownOutflowAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Line Drawdown Outflow Amount' ;
    rdfs:comment 'Projected cash outflows from expected drawdowns on committed credit facilities and revolving lines of credit.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cumulativeNetCashFlowAmount rdf:type rdf:Property ;
    rdfs:label 'Cumulative Net Cash Flow Amount' ;
    rdfs:comment 'Cumulative net cash flow from the forecast start date through the current tenor bucket, used for liquidity gap analysis.' ;
    rdfs:domain ind:Treasury ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depositRunoffOutflowAmount rdf:type rdf:Property ;
    rdfs:label 'Deposit Runoff Outflow Amount' ;
    rdfs:comment 'Projected cash outflows from deposit withdrawals modeled using behavioral runoff rates by deposit type and stability.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:derivativeSettlementNetAmount rdf:type rdf:Property ;
    rdfs:label 'Derivative Settlement Net Amount' ;
    rdfs:comment 'Net projected cash flows from derivative settlements including foreign exchange forwards, interest rate swaps, and options.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:flowDirection rdf:type rdf:Property ;
    rdfs:label 'Flow Direction' ;
    rdfs:comment 'Indicates whether the forecast represents a cash inflow or outflow.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastDate rdf:type rdf:Property ;
    rdfs:label 'Forecast Date' ;
    rdfs:comment 'The date for which the cash flow forecast is projected.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:forecastReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Forecast Reference Number' ;
    rdfs:comment 'Business identifier for the cash flow forecast used for tracking and audit purposes.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastRunTimestamp rdf:type rdf:Property ;
    rdfs:label 'Forecast Run Timestamp' ;
    rdfs:comment 'The timestamp when the forecast calculation was executed.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:forecastType rdf:type rdf:Property ;
    rdfs:label 'Forecast Type' ;
    rdfs:comment 'Classification of the forecast by time horizon: intraday, overnight, short-term, medium-term, or long-term.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loanRepaymentInflowAmount rdf:type rdf:Property ;
    rdfs:label 'Loan Repayment Inflow Amount' ;
    rdfs:comment 'Projected cash inflows from scheduled loan principal and interest repayments.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netCashFlowAmount rdf:type rdf:Property ;
    rdfs:label 'Net Cash Flow Amount' ;
    rdfs:comment 'Net projected cash flow calculated as total inflows minus total outflows for the tenor bucket.' ;
    rdfs:domain ind:Treasury ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operationalExpenseOutflowAmount rdf:type rdf:Property ;
    rdfs:label 'Operational Expense Outflow Amount' ;
    rdfs:comment 'Projected cash outflows for operational expenses including payroll, rent, technology costs, and other recurring expenses.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:repoFundingNetAmount rdf:type rdf:Property ;
    rdfs:label 'Repo Funding Net Amount' ;
    rdfs:comment 'Net projected cash flows from repurchase and reverse repurchase agreements maturing in the tenor bucket.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tenorBucket rdf:type rdf:Property ;
    rdfs:label 'Tenor Bucket' ;
    rdfs:comment 'Time bucket for the cash flow projection (intraday, overnight, 1 week, 2 weeks, 1 month, 3 months, 6 months, 1 year, beyond 1 year). [ENUM-REF-CANDIDATE: intraday|overnight|1W|2W|1M|3M|6M|1Y|beyond_1Y — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Treasury ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContingencyEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Contingency Employee Id' ;
    rdfs:comment 'Identifier of the ALCO chairperson or authorized officer who approved the plan.' ;
    rdfs:domain ind:ContingencyFundingPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assetMonetizationCapacityAmount rdf:type rdf:Property ;
    rdfs:label 'Asset Monetization Capacity Amount' ;
    rdfs:comment 'Estimated liquidity that can be raised through asset sales or securitization under stress conditions as documented in this plan.' ;
    rdfs:domain ind:ContingencyFundingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:centralBankFacilityAccessFlag rdf:type rdf:Property ;
    rdfs:label 'Central Bank Facility Access Flag' ;
    rdfs:comment 'Indicates whether this contingency funding plan includes pre-approved access to Federal Reserve discount window or other central bank emergency liquidity facilities.' ;
    rdfs:domain ind:ContingencyFundingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:communicationProtocolDescription rdf:type rdf:Property ;
    rdfs:label 'Communication Protocol Description' ;
    rdfs:comment 'Description of internal and external communication protocols to be followed during contingency funding plan activation.' ;
    rdfs:domain ind:ContingencyFundingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contingentLiquiditySourceCount rdf:type rdf:Property ;
    rdfs:label 'Contingent Liquidity Source Count' ;
    rdfs:comment 'Number of pre-approved contingent liquidity sources documented in this plan (central bank facilities, FHLB advances, asset monetization channels).' ;
    rdfs:domain ind:ContingencyFundingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:documentLocationUri rdf:type rdf:Property ;
    rdfs:label 'Document Location Uri' ;
    rdfs:comment 'URI or file path to the full contingency funding plan document stored in the document management system.' ;
    rdfs:domain ind:ContingencyFundingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:earlyWarningIndicatorCount rdf:type rdf:Property ;
    rdfs:label 'Early Warning Indicator Count' ;
    rdfs:comment 'Number of early warning indicators (EWIs) defined in this contingency funding plan for monitoring liquidity stress signals.' ;
    rdfs:domain ind:ContingencyFundingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:escalationLevel1Threshold rdf:type rdf:Property ;
    rdfs:label 'Escalation Level 1 Threshold' ;
    rdfs:comment 'Description of the threshold conditions that trigger Level 1 escalation (initial alert and monitoring intensification).' ;
    rdfs:domain ind:ContingencyFundingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationLevel2Threshold rdf:type rdf:Property ;
    rdfs:label 'Escalation Level 2 Threshold' ;
    rdfs:comment 'Description of the threshold conditions that trigger Level 2 escalation (activation of contingent liquidity sources).' ;
    rdfs:domain ind:ContingencyFundingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationLevel3Threshold rdf:type rdf:Property ;
    rdfs:label 'Escalation Level 3 Threshold' ;
    rdfs:comment 'Description of the threshold conditions that trigger Level 3 escalation (full crisis mode and central bank facility access).' ;
    rdfs:domain ind:ContingencyFundingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fhlbAdvanceCapacityAmount rdf:type rdf:Property ;
    rdfs:label 'Fhlb Advance Capacity Amount' ;
    rdfs:comment 'Maximum borrowing capacity available from Federal Home Loan Bank (FHLB) advances as documented in this contingency funding plan.' ;
    rdfs:domain ind:ContingencyFundingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryNotificationRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Requirement Flag' ;
    rdfs:comment 'Indicates whether activation of this contingency funding plan requires immediate notification to regulatory authorities (Federal Reserve, OCC).' ;
    rdfs:domain ind:ContingencyFundingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:repoFundingCapacityAmount rdf:type rdf:Property ;
    rdfs:label 'Repo Funding Capacity Amount' ;
    rdfs:comment 'Maximum additional funding capacity available through repurchase agreement (repo) transactions under stress scenarios.' ;
    rdfs:domain ind:ContingencyFundingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stressSeverityLevel rdf:type rdf:Property ;
    rdfs:label 'Stress Severity Level' ;
    rdfs:comment 'Severity level of the liquidity stress scenario for which this plan provides response actions.' ;
    rdfs:domain ind:ContingencyFundingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalContingentFundingCapacityAmount rdf:type rdf:Property ;
    rdfs:label 'Total Contingent Funding Capacity Amount' ;
    rdfs:comment 'Total aggregate contingent funding capacity available across all sources documented in this plan.' ;
    rdfs:domain ind:ContingencyFundingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:triggerThresholdDepositOutflowPercentage rdf:type rdf:Property ;
    rdfs:label 'Trigger Threshold Deposit Outflow Percentage' ;
    rdfs:comment 'Percentage of deposit outflow over a specified period that triggers escalation to contingency funding procedures.' ;
    rdfs:domain ind:ContingencyFundingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:triggerThresholdLcrPercentage rdf:type rdf:Property ;
    rdfs:label 'Trigger Threshold Lcr Percentage' ;
    rdfs:comment 'Liquidity Coverage Ratio (LCR) threshold percentage that triggers activation of contingency funding actions. Typically set above regulatory minimum (e.g., 110% vs 100% minimum).' ;
    rdfs:domain ind:ContingencyFundingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:triggerThresholdNsfrPercentage rdf:type rdf:Property ;
    rdfs:label 'Trigger Threshold Nsfr Percentage' ;
    rdfs:comment 'Net Stable Funding Ratio (NSFR) threshold percentage that triggers activation of contingency funding actions.' ;
    rdfs:domain ind:ContingencyFundingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:triggerThresholdWholesaleFundingLossAmount rdf:type rdf:Property ;
    rdfs:label 'Trigger Threshold Wholesale Funding Loss Amount' ;
    rdfs:comment 'Absolute amount of wholesale funding loss that triggers activation of contingency funding plan actions.' ;
    rdfs:domain ind:ContingencyFundingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditRatingAgency rdf:type rdf:Property ;
    rdfs:label 'Credit Rating Agency' ;
    rdfs:comment 'Name of the credit rating agency that assigned the rating to this debt issuance (e.g., Moodys, S&P, Fitch). Multiple agencies may rate the same instrument.' ;
    rdfs:domain ind:Treasury ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:greenBondFlag rdf:type rdf:Property ;
    rdfs:label 'Green Bond Flag' ;
    rdfs:comment 'Indicates whether the debt issuance qualifies as a green bond with proceeds dedicated to environmentally beneficial projects. True if certified green bond; false otherwise.' ;
    rdfs:domain ind:DebtIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuanceStatus rdf:type rdf:Property ;
    rdfs:label 'Issuance Status' ;
    rdfs:comment 'Current lifecycle status of the debt issuance from planning through maturity or early termination. [ENUM-REF-CANDIDATE: planned|priced|issued|outstanding|matured|called|defaulted — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DebtIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuePrice rdf:type rdf:Property ;
    rdfs:label 'Issue Price' ;
    rdfs:comment 'Price at which the debt instrument was issued, expressed as a percentage of par value. Values below 100 indicate discount; above 100 indicate premium.' ;
    rdfs:domain ind:DebtIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lcrTreatment rdf:type rdf:Property ;
    rdfs:label 'Lcr Treatment' ;
    rdfs:comment 'Classification of the debt issuance for LCR calculation purposes. Indicates the outflow rate assumption and time bucket for liquidity stress testing.' ;
    rdfs:domain ind:Treasury ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nsfrTreatment rdf:type rdf:Property ;
    rdfs:label 'Nsfr Treatment' ;
    rdfs:comment 'Classification of the debt issuance for NSFR calculation purposes. Indicates the available stable funding factor based on maturity and counterparty type.' ;
    rdfs:domain ind:Treasury ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalMaturityTenor rdf:type rdf:Property ;
    rdfs:label 'Original Maturity Tenor' ;
    rdfs:comment 'Time period from issuance date to maturity date expressed in standard market convention (e.g., 5Y, 10Y, 30Y). Used for funding maturity profile analysis.' ;
    rdfs:domain ind:DebtIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outstandingAmount rdf:type rdf:Property ;
    rdfs:label 'Outstanding Amount' ;
    rdfs:comment 'Current principal amount outstanding after accounting for any partial redemptions, amortization, or calls. Used for balance sheet and capital ratio calculations.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:syndicateMembers rdf:type rdf:Property ;
    rdfs:label 'Syndicate Members' ;
    rdfs:comment 'Comma-separated list of all underwriting syndicate members participating in the debt issuance. Includes co-managers and selling group members.' ;
    rdfs:domain ind:DebtIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalAllocationFtpAllocationId rdf:type rdf:Property ;
    rdfs:label 'Original Allocation Ftp Allocation Id' ;
    rdfs:comment 'Reference to the original FTP allocation ID if this record is a reversal or adjustment. Null for original allocations.' ;
    rdfs:domain ind:FtpAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FtpAllocation .

ind:alcoReportingCategory rdf:type rdf:Property ;
    rdfs:label 'Alco Reporting Category' ;
    rdfs:comment 'The ALCO reporting category or classification for this FTP allocation. Used for Asset-Liability Management (ALM) and ALCO reporting purposes.' ;
    rdfs:domain ind:Treasury ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditAdjustmentBps rdf:type rdf:Property ;
    rdfs:label 'Credit Adjustment Bps' ;
    rdfs:comment 'The credit risk adjustment component in basis points included in the FTP rate. Reflects the Expected Credit Loss (ECL) or credit risk premium.' ;
    rdfs:domain ind:FtpAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:economicCapitalAmount rdf:type rdf:Property ;
    rdfs:label 'Economic Capital Amount' ;
    rdfs:comment 'The economic capital allocated to this account balance. Used for Risk-Adjusted Return on Capital (RAROC) calculation and capital planning.' ;
    rdfs:domain ind:FtpAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ftpAmount rdf:type rdf:Property ;
    rdfs:label 'Ftp Amount' ;
    rdfs:comment 'The calculated FTP charge or credit amount in the account currency. Computed as notional_balance × ftp_rate × day_count_fraction.' ;
    rdfs:domain ind:FtpAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:liquidityPremiumBps rdf:type rdf:Property ;
    rdfs:label 'Liquidity Premium Bps' ;
    rdfs:comment 'The liquidity premium component in basis points included in the FTP rate. Reflects the cost or benefit of liquidity for the tenor and product type.' ;
    rdfs:domain ind:Treasury ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nimContribution rdf:type rdf:Property ;
    rdfs:label 'Nim Contribution' ;
    rdfs:comment 'The contribution of this FTP allocation to the overall Net Interest Margin (NIM) for the business line or product. Calculated as FTP amount adjusted for actual interest income or expense.' ;
    rdfs:domain ind:FtpAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:notionalBalance rdf:type rdf:Property ;
    rdfs:label 'Notional Balance' ;
    rdfs:comment 'The principal or notional balance amount of the account on which the FTP rate is applied. Represents the base amount for FTP calculation.' ;
    rdfs:domain ind:FtpAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryTreatment rdf:type rdf:Property ;
    rdfs:label 'Regulatory Treatment' ;
    rdfs:comment 'The regulatory treatment classification for the account balance. Determines how the position is treated under Basel III, Fundamental Review of the Trading Book (FRTB), and other regulatory frameworks.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseRateBenchmarkId rdf:type rdf:Property ;
    rdfs:label 'Base Rate Benchmark Id' ;
    rdfs:comment 'Foreign key linking to reference.rate_benchmark. Business justification: FTP rates built on benchmark rates (SOFR, SONIA, etc.) for curve construction. Link enables daily rate fixing, benchmark transition management, and spread calculation over risk-free rate.' ;
    rdfs:domain ind:FtpRate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RateBenchmark .

ind:primaryFtpEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Ftp Employee Id' ;
    rdfs:comment 'Identifier of the user or system process that created this FTP rate record.' ;
    rdfs:domain ind:FtpRate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:supersededByRateFtpRateId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Rate Ftp Rate Id' ;
    rdfs:comment 'Reference to the FTP rate that supersedes this rate; null if this is the current active rate.' ;
    rdfs:domain ind:FtpRate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FtpRate .

ind:tertiaryFtpApprovedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Ftp Approved By User Employee Id' ;
    rdfs:comment 'Identifier of the user who approved this FTP rate for activation.' ;
    rdfs:domain ind:FtpRate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:alcoApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Alco Approval Date' ;
    rdfs:comment 'Date on which the ALCO formally approved this FTP rate for use.' ;
    rdfs:domain ind:FtpRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:alcoApprovalReference rdf:type rdf:Property ;
    rdfs:label 'Alco Approval Reference' ;
    rdfs:comment 'Reference number or identifier of the ALCO meeting or decision that approved this rate.' ;
    rdfs:domain ind:Treasury ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetLiabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Asset Liability Flag' ;
    rdfs:comment 'Indicates whether this FTP rate applies to asset products (loans, investments) or liability products (deposits, borrowings).' ;
    rdfs:domain ind:FtpRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseRateValue rdf:type rdf:Property ;
    rdfs:label 'Base Rate Value' ;
    rdfs:comment 'Numeric value of the base rate component expressed in basis points (BPS) or percentage.' ;
    rdfs:domain ind:FtpRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:basisAdjustmentBps rdf:type rdf:Property ;
    rdfs:label 'Basis Adjustment Bps' ;
    rdfs:comment 'Additional basis point adjustment for market basis risk, cross-currency basis, or other technical adjustments.' ;
    rdfs:domain ind:FtpRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compositeRateBps rdf:type rdf:Property ;
    rdfs:label 'Composite Rate Bps' ;
    rdfs:comment 'Fully loaded FTP rate in basis points, representing the sum of base rate and all spread components.' ;
    rdfs:domain ind:FtpRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditSpreadBps rdf:type rdf:Property ;
    rdfs:label 'Credit Spread Bps' ;
    rdfs:comment 'Credit risk adjustment component in basis points, capturing expected credit loss or risk premium.' ;
    rdfs:domain ind:Treasury ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nimAllocationFlag rdf:type rdf:Property ;
    rdfs:label 'Nim Allocation Flag' ;
    rdfs:comment 'Indicates whether this FTP rate is used for NIM decomposition and profitability analysis.' ;
    rdfs:domain ind:FtpRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optionalityChargeBps rdf:type rdf:Property ;
    rdfs:label 'Optionality Charge Bps' ;
    rdfs:comment 'Adjustment in basis points for embedded optionality (e.g., prepayment risk, early withdrawal penalties).' ;
    rdfs:domain ind:FtpRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rarocCalculationFlag rdf:type rdf:Property ;
    rdfs:label 'Raroc Calculation Flag' ;
    rdfs:comment 'Indicates whether this FTP rate is used in RAROC calculations for risk-adjusted performance measurement.' ;
    rdfs:domain ind:FtpRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rateCode rdf:type rdf:Property ;
    rdfs:label 'Rate Code' ;
    rdfs:comment 'Business identifier for the FTP rate, used for external reference and reporting.' ;
    rdfs:domain ind:FtpRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateDescription rdf:type rdf:Property ;
    rdfs:label 'Rate Description' ;
    rdfs:comment 'Detailed textual description of the FTP rate, including methodology notes, assumptions, and business context.' ;
    rdfs:domain ind:FtpRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateName rdf:type rdf:Property ;
    rdfs:label 'Rate Name' ;
    rdfs:comment 'Descriptive name of the FTP rate for business user identification.' ;
    rdfs:domain ind:FtpRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualCostOfFundsRate rdf:type rdf:Property ;
    rdfs:label 'Actual Cost Of Funds Rate' ;
    rdfs:comment 'Actual realized all-in cost of funds rate for this instrument type during the plan period, expressed as a decimal. Tracks execution vs. target pricing.' ;
    rdfs:domain ind:FundingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualIssuanceAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Issuance Amount' ;
    rdfs:comment 'Actual notional amount raised through this funding instrument during the plan period, in the plan\'s base currency. Tracks execution vs. plan.' ;
    rdfs:domain ind:FundingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:callFeatureFlag rdf:type rdf:Property ;
    rdfs:label 'Call Feature Flag' ;
    rdfs:comment 'Indicates whether the debt instrument includes a call feature allowing the issuer to redeem the instrument before maturity. True if callable, False otherwise.' ;
    rdfs:domain ind:FundingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:counterpartyConcentrationLimit rdf:type rdf:Property ;
    rdfs:label 'Counterparty Concentration Limit' ;
    rdfs:comment 'Maximum notional amount that can be sourced from a single counterparty or investor group for this instrument type, in the plan\'s base currency. Enforces counterparty concentration risk limits.' ;
    rdfs:domain ind:FundingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:notionalOutstanding rdf:type rdf:Property ;
    rdfs:label 'Notional Outstanding' ;
    rdfs:comment 'Current outstanding notional principal amount of the debt instrument, in the instrument\'s currency. Tracks amortization and prepayments.' ;
    rdfs:domain ind:FundingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Plan Period End Date' ;
    rdfs:comment 'The effective end date of the funding plan period (e.g., end of fiscal quarter or year).' ;
    rdfs:domain ind:FundingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Plan Period Start Date' ;
    rdfs:comment 'The effective start date of the funding plan period (e.g., beginning of fiscal quarter or year).' ;
    rdfs:domain ind:FundingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:putFeatureFlag rdf:type rdf:Property ;
    rdfs:label 'Put Feature Flag' ;
    rdfs:comment 'Indicates whether the debt instrument includes a put feature allowing the investor to demand early redemption. True if puttable, False otherwise.' ;
    rdfs:domain ind:FundingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetCostOfFundsRate rdf:type rdf:Property ;
    rdfs:label 'Target Cost Of Funds Rate' ;
    rdfs:comment 'Planned or target all-in cost of funds rate for this instrument type, expressed as a decimal (e.g., 0.0325 for 3.25% or 325 basis points). Includes coupon, fees, and issuance costs.' ;
    rdfs:domain ind:FundingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetIssuanceAmount rdf:type rdf:Property ;
    rdfs:label 'Target Issuance Amount' ;
    rdfs:comment 'Planned or target notional amount to be raised through this funding instrument during the plan period, in the plan\'s base currency.' ;
    rdfs:domain ind:FundingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetMaturityProfile rdf:type rdf:Property ;
    rdfs:label 'Target Maturity Profile' ;
    rdfs:comment 'Planned maturity profile for the funding instrument: short-term (< 1 year), medium-term (1-5 years), long-term (> 5 years), perpetual (no maturity), or mixed (diversified maturities).' ;
    rdfs:domain ind:FundingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetWeightedAverageMaturityYears rdf:type rdf:Property ;
    rdfs:label 'Target Weighted Average Maturity Years' ;
    rdfs:comment 'Planned weighted average maturity of the funding instrument issuances, expressed in years. Used for maturity ladder and duration management.' ;
    rdfs:domain ind:FundingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:encumberedAmount rdf:type rdf:Property ;
    rdfs:label 'Encumbered Amount' ;
    rdfs:comment 'Market value of the asset that is pledged, restricted, or otherwise encumbered and not available for LCR purposes.' ;
    rdfs:domain ind:HqlaInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hqlaLevel rdf:type rdf:Property ;
    rdfs:label 'Hqla Level' ;
    rdfs:comment 'Classification of the asset under Basel III liquidity framework: Level 1 (central bank reserves, sovereign bonds with 0% haircut), Level 2A (agency MBS, covered bonds with 15% haircut), or Level 2B (corporate bonds, equities with 50% haircut).' ;
    rdfs:domain ind:HqlaInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hqlaValueAmount rdf:type rdf:Property ;
    rdfs:label 'Hqla Value Amount' ;
    rdfs:comment 'Post-haircut value of the asset eligible for LCR calculation, computed as market value multiplied by (1 minus haircut percentage).' ;
    rdfs:domain ind:HqlaInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ineligibilityReason rdf:type rdf:Property ;
    rdfs:label 'Ineligibility Reason' ;
    rdfs:comment 'Explanation of why the asset does not qualify for HQLA treatment, if eligibility status is Ineligible or Conditionally Eligible.' ;
    rdfs:domain ind:HqlaInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lcrInclusionFlag rdf:type rdf:Property ;
    rdfs:label 'Lcr Inclusion Flag' ;
    rdfs:comment 'Boolean indicator of whether this asset is currently included in the LCR numerator calculation.' ;
    rdfs:domain ind:Treasury ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketValueBaseCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Market Value Base Currency Amount' ;
    rdfs:comment 'Market value of the HQLA position converted to the bank\'s base reporting currency using the valuation date exchange rate.' ;
    rdfs:domain ind:HqlaInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:movementDate rdf:type rdf:Property ;
    rdfs:label 'Movement Date' ;
    rdfs:comment 'Date on which the most recent inventory movement or change occurred.' ;
    rdfs:domain ind:HqlaInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:movementType rdf:type rdf:Property ;
    rdfs:label 'Movement Type' ;
    rdfs:comment 'Classification of the most recent change to the HQLA inventory record, tracking asset lifecycle events. [ENUM-REF-CANDIDATE: Addition|Disposal|Substitution|Encumbrance Change|Valuation Adjustment|Maturity|Transfer In|Transfer Out — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:HqlaInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nominalAmount rdf:type rdf:Property ;
    rdfs:label 'Nominal Amount' ;
    rdfs:comment 'Face value or par value of the security holdings in the security\'s denomination currency.' ;
    rdfs:domain ind:HqlaInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nsfrInclusionFlag rdf:type rdf:Property ;
    rdfs:label 'Nsfr Inclusion Flag' ;
    rdfs:comment 'Boolean indicator of whether this asset is included in the NSFR available stable funding calculation.' ;
    rdfs:domain ind:Treasury ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stressScenarioHaircutPercentage rdf:type rdf:Property ;
    rdfs:label 'Stress Scenario Haircut Percentage' ;
    rdfs:comment 'Additional haircut percentage applied to the asset under internal liquidity stress testing scenarios beyond the regulatory Basel III haircut.' ;
    rdfs:domain ind:HqlaInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unencumberedHqlaValueAmount rdf:type rdf:Property ;
    rdfs:label 'Unencumbered Hqla Value Amount' ;
    rdfs:comment 'Post-haircut value of the unencumbered portion of the asset that qualifies for LCR numerator calculation.' ;
    rdfs:domain ind:HqlaInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interbankPlacementId rdf:type rdf:Property ;
    rdfs:label 'Interbank Placement Id' ;
    rdfs:comment 'Unique identifier for the interbank placement transaction. Primary key for this entity.' ;
    rdfs:domain ind:InterbankPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:benchmarkRateValue rdf:type rdf:Property ;
    rdfs:label 'Benchmark Rate Value' ;
    rdfs:comment 'The actual benchmark rate value at trade execution, expressed as a percentage (e.g., 5.25 for 5.25%). Null if placement is fixed rate with no benchmark.' ;
    rdfs:domain ind:Treasury ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bookingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Booking Timestamp' ;
    rdfs:comment 'Timestamp when the placement transaction was recorded in the treasury management system.' ;
    rdfs:domain ind:InterbankPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:counterpartyConcentrationFlag rdf:type rdf:Property ;
    rdfs:label 'Counterparty Concentration Flag' ;
    rdfs:comment 'Indicates whether this placement contributes to a counterparty concentration risk threshold breach (True) or not (False), used for large exposure monitoring.' ;
    rdfs:domain ind:InterbankPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:counterpartyCreditRating rdf:type rdf:Property ;
    rdfs:label 'Counterparty Credit Rating' ;
    rdfs:comment 'External credit rating of the counterparty institution (e.g., AAA, AA+, A, BBB) from a recognized rating agency, used for credit risk assessment.' ;
    rdfs:domain ind:InterbankPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedCreditLoss rdf:type rdf:Property ;
    rdfs:label 'Expected Credit Loss' ;
    rdfs:comment 'Calculated expected credit loss provision for this placement under IFRS 9 or CECL methodology, based on PD, LGD, and EAD.' ;
    rdfs:domain ind:InterbankPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exposureAtDefault rdf:type rdf:Property ;
    rdfs:label 'Exposure At Default' ;
    rdfs:comment 'Total exposure amount at risk if the counterparty defaults, including notional principal and accrued interest, used for credit risk capital calculation.' ;
    rdfs:domain ind:InterbankPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:liquidityGapBucket rdf:type rdf:Property ;
    rdfs:label 'Liquidity Gap Bucket' ;
    rdfs:comment 'Time bucket for liquidity gap analysis based on remaining maturity: overnight, 1-7 days, 8-30 days, 31-90 days, 91-180 days, 181-365 days, or over 1 year. [ENUM-REF-CANDIDATE: overnight|1_7_days|8_30_days|31_90_days|91_180_days|181_365_days|over_1_year — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InterbankPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lossGivenDefault rdf:type rdf:Property ;
    rdfs:label 'Loss Given Default' ;
    rdfs:comment 'Estimated percentage of exposure that will be lost if the counterparty defaults, expressed as a decimal (e.g., 0.45 for 45%), used for ECL calculation.' ;
    rdfs:domain ind:InterbankPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:placementReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Placement Reference Number' ;
    rdfs:comment 'External business identifier for the interbank placement transaction, used for operational reference and reconciliation with counterparties.' ;
    rdfs:domain ind:InterbankPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:placementType rdf:type rdf:Property ;
    rdfs:label 'Placement Type' ;
    rdfs:comment 'Classification of the interbank placement by tenor structure: overnight (1 day), term (fixed maturity), call money (callable on demand), notice (requires advance notice), or fixed deposit.' ;
    rdfs:domain ind:InterbankPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:probabilityOfDefault rdf:type rdf:Property ;
    rdfs:label 'Probability Of Default' ;
    rdfs:comment 'Estimated probability that the counterparty will default within one year, expressed as a decimal (e.g., 0.0025 for 0.25%), used for Expected Credit Loss (ECL) calculation.' ;
    rdfs:domain ind:InterbankPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rolloverInstruction rdf:type rdf:Property ;
    rdfs:label 'Rollover Instruction' ;
    rdfs:comment 'Type of rollover instruction: automatic (system-driven rollover), manual (requires explicit approval), or none (no rollover planned).' ;
    rdfs:domain ind:InterbankPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rolloverStatus rdf:type rdf:Property ;
    rdfs:label 'Rollover Status' ;
    rdfs:comment 'Indicates whether the placement is subject to rollover at maturity: none (no rollover), pending (rollover requested), executed (rolled over), or declined (rollover not agreed).' ;
    rdfs:domain ind:InterbankPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionDirection rdf:type rdf:Property ;
    rdfs:label 'Transaction Direction' ;
    rdfs:comment 'Indicates whether the bank is placing funds with a counterparty (asset) or borrowing funds from a counterparty (liability).' ;
    rdfs:domain ind:InterbankPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:behavioralAssumptionSet rdf:type rdf:Property ;
    rdfs:label 'Behavioral Assumption Set' ;
    rdfs:comment 'The set of behavioral assumptions applied for non-maturity deposits, prepayment rates, and other customer behavior modeling.' ;
    rdfs:domain ind:InterestRateRiskPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eveSensitivityAmount rdf:type rdf:Property ;
    rdfs:label 'Eve Sensitivity Amount' ;
    rdfs:comment 'The change in the present value of the bank\'s assets minus liabilities (economic value of equity) resulting from interest rate shocks.' ;
    rdfs:domain ind:InterestRateRiskPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eveSensitivityPercentage rdf:type rdf:Property ;
    rdfs:label 'Eve Sensitivity Percentage' ;
    rdfs:comment 'The percentage change in economic value of equity relative to total equity capital under interest rate shock scenarios.' ;
    rdfs:domain ind:InterestRateRiskPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modifiedDuration rdf:type rdf:Property ;
    rdfs:label 'Modified Duration' ;
    rdfs:comment 'The measure of the price sensitivity of the banking book portfolio to a 1% change in interest rates.' ;
    rdfs:domain ind:InterestRateRiskPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:niiSensitivityAmount rdf:type rdf:Property ;
    rdfs:label 'Nii Sensitivity Amount' ;
    rdfs:comment 'The projected change in net interest income over a specified time horizon (typically 12 months) resulting from interest rate shocks.' ;
    rdfs:domain ind:InterestRateRiskPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:niiSensitivityPercentage rdf:type rdf:Property ;
    rdfs:label 'Nii Sensitivity Percentage' ;
    rdfs:comment 'The percentage change in net interest income relative to baseline NII under interest rate shock scenarios.' ;
    rdfs:domain ind:InterestRateRiskPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateSensitiveAssetsAmount rdf:type rdf:Property ;
    rdfs:label 'Rate Sensitive Assets Amount' ;
    rdfs:comment 'The total value of assets that will reprice or mature within the specified time bucket.' ;
    rdfs:domain ind:InterestRateRiskPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateSensitiveLiabilitiesAmount rdf:type rdf:Property ;
    rdfs:label 'Rate Sensitive Liabilities Amount' ;
    rdfs:comment 'The total value of liabilities that will reprice or mature within the specified time bucket.' ;
    rdfs:domain ind:InterestRateRiskPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shockScenarioType rdf:type rdf:Property ;
    rdfs:label 'Shock Scenario Type' ;
    rdfs:comment 'The interest rate shock scenario applied to calculate sensitivity metrics, expressed in basis points (bps) parallel shift.' ;
    rdfs:domain ind:InterestRateRiskPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeBucket rdf:type rdf:Property ;
    rdfs:label 'Time Bucket' ;
    rdfs:comment 'The repricing or maturity time band used to classify rate-sensitive positions for gap analysis. [ENUM-REF-CANDIDATE: overnight|1_7_days|8_30_days|31_90_days|91_180_days|181_365_days|1_2_years|2_3_years|3_5_years|5_10_years|over_10_years — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InterestRateRiskPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investmentManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Investment Manager Employee Id' ;
    rdfs:comment 'FK to hr.employee' ;
    rdfs:domain ind:InvestmentPortfolio ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:creditRatingAverage rdf:type rdf:Property ;
    rdfs:label 'Credit Rating Average' ;
    rdfs:comment 'Weighted average credit rating of all securities in the portfolio based on ratings from major credit rating agencies (Moody\'s, S&P, Fitch).' ;
    rdfs:domain ind:InvestmentPortfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentYieldPercentage rdf:type rdf:Property ;
    rdfs:label 'Current Yield Percentage' ;
    rdfs:comment 'Current yield of the portfolio calculated as annual coupon income divided by current market value, expressed as a percentage.' ;
    rdfs:domain ind:InvestmentPortfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastRebalanceDate rdf:type rdf:Property ;
    rdfs:label 'Last Rebalance Date' ;
    rdfs:comment 'Date when the portfolio was last rebalanced to align with target allocation, duration, or risk parameters.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:modifiedDurationYears rdf:type rdf:Property ;
    rdfs:label 'Modified Duration Years' ;
    rdfs:comment 'Modified duration of the portfolio measuring interest rate sensitivity. Indicates the approximate percentage change in portfolio value for a 1% change in interest rates.' ;
    rdfs:domain ind:InvestmentPortfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:portfolioClassification rdf:type rdf:Property ;
    rdfs:label 'Portfolio Classification' ;
    rdfs:comment 'Accounting classification of the investment portfolio under IFRS 9 or GAAP standards. Determines measurement and recognition treatment for gains and losses.' ;
    rdfs:domain ind:InvestmentPortfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portfolioName rdf:type rdf:Property ;
    rdfs:label 'Portfolio Name' ;
    rdfs:comment 'Human-readable name of the investment portfolio for identification and reporting purposes.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portfolioReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Portfolio Reference Number' ;
    rdfs:comment 'External business identifier for the investment portfolio used in regulatory reporting and ALCO presentations. Unique across the organization.' ;
    rdfs:domain ind:InvestmentPortfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portfolioStatus rdf:type rdf:Property ;
    rdfs:label 'Portfolio Status' ;
    rdfs:comment 'Current operational status of the investment portfolio indicating whether it is actively managed, restricted from new investments, or closed.' ;
    rdfs:domain ind:InvestmentPortfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:realizedGainLossYtdAmount rdf:type rdf:Property ;
    rdfs:label 'Realized Gain Loss Ytd Amount' ;
    rdfs:comment 'Year-to-date realized gains or losses from securities sold or matured from the portfolio, recognized in profit and loss statement.' ;
    rdfs:domain ind:InvestmentPortfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetDurationYears rdf:type rdf:Property ;
    rdfs:label 'Target Duration Years' ;
    rdfs:comment 'Target modified duration in years for the investment portfolio to manage interest rate risk exposure in alignment with ALM strategy.' ;
    rdfs:domain ind:InvestmentPortfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetYieldPercentage rdf:type rdf:Property ;
    rdfs:label 'Target Yield Percentage' ;
    rdfs:comment 'Target yield or return objective for the investment portfolio expressed as an annual percentage rate.' ;
    rdfs:domain ind:InvestmentPortfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unrealizedGainLossAmount rdf:type rdf:Property ;
    rdfs:label 'Unrealized Gain Loss Amount' ;
    rdfs:comment 'Cumulative unrealized gain or loss on the portfolio calculated as the difference between market value and book value. Positive values indicate gains, negative values indicate losses.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightedAverageMaturityYears rdf:type rdf:Property ;
    rdfs:label 'Weighted Average Maturity Years' ;
    rdfs:comment 'Weighted average time to maturity of all securities in the portfolio expressed in years, weighted by market value of each holding.' ;
    rdfs:domain ind:InvestmentPortfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yieldToMaturityPercentage rdf:type rdf:Property ;
    rdfs:label 'Yield To Maturity Percentage' ;
    rdfs:comment 'Weighted average yield to maturity of all fixed income securities in the portfolio expressed as an annual percentage rate.' ;
    rdfs:domain ind:InvestmentPortfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:availableLiquidityAmount rdf:type rdf:Property ;
    rdfs:label 'Available Liquidity Amount' ;
    rdfs:comment 'Total available liquidity calculated as liquid assets plus cash balances plus undrawn facilities plus net cash inflows for the tenor bucket.' ;
    rdfs:domain ind:LiquidityPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:centralBankReserveBalance rdf:type rdf:Property ;
    rdfs:label 'Central Bank Reserve Balance' ;
    rdfs:comment 'Balance held in reserve accounts at central banks (e.g., Federal Reserve, ECB), representing the highest quality liquid asset.' ;
    rdfs:domain ind:LiquidityPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interbankFundingAmount rdf:type rdf:Property ;
    rdfs:label 'Interbank Funding Amount' ;
    rdfs:comment 'Total unsecured interbank borrowing outstanding at the position date, including federal funds purchased and interbank deposits.' ;
    rdfs:domain ind:LiquidityPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:liquidAssetBalance rdf:type rdf:Property ;
    rdfs:label 'Liquid Asset Balance' ;
    rdfs:comment 'Total value of high-quality liquid assets (HQLA) available for immediate liquidation, including Level 1 and Level 2 assets per Basel III LCR framework.' ;
    rdfs:domain ind:LiquidityPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nsfrBufferAmount rdf:type rdf:Property ;
    rdfs:label 'Nsfr Buffer Amount' ;
    rdfs:comment 'Excess stable funding buffer above the regulatory minimum NSFR requirement, calculated as (NSFR ratio - 100%) multiplied by required stable funding.' ;
    rdfs:domain ind:LiquidityPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:repoFundingAmount rdf:type rdf:Property ;
    rdfs:label 'Repo Funding Amount' ;
    rdfs:comment 'Total funding obtained through repurchase agreements (repos) outstanding at the position date, representing secured short-term borrowing.' ;
    rdfs:domain ind:LiquidityPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reverseRepoFundingAmount rdf:type rdf:Property ;
    rdfs:label 'Reverse Repo Funding Amount' ;
    rdfs:comment 'Total funding provided through reverse repurchase agreements (reverse repos) outstanding at the position date, representing secured short-term lending.' ;
    rdfs:domain ind:LiquidityPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:undrawnCommittedFacilityAmount rdf:type rdf:Property ;
    rdfs:label 'Undrawn Committed Facility Amount' ;
    rdfs:comment 'Total amount of undrawn committed credit facilities available to the bank for liquidity purposes, including interbank lines and central bank standing facilities.' ;
    rdfs:domain ind:LiquidityPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:alcoApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Alco Approval Status' ;
    rdfs:comment 'The approval status of the liquidity ratio by the ALCO, indicating whether the ratio and any remediation plans have been formally accepted.' ;
    rdfs:domain ind:LiquidityRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bufferPercentage rdf:type rdf:Property ;
    rdfs:label 'Buffer Percentage' ;
    rdfs:comment 'The buffer above the regulatory minimum threshold, calculated as (Actual Ratio - Regulatory Threshold). Positive values indicate compliance buffer; negative values indicate breach.' ;
    rdfs:domain ind:LiquidityRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:derivativeOutflowAmount rdf:type rdf:Property ;
    rdfs:label 'Derivative Outflow Amount' ;
    rdfs:comment 'Expected cash outflows from derivative contracts and collateral calls over the 30-day stress horizon.' ;
    rdfs:domain ind:LiquidityRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hqlaLevel1Amount rdf:type rdf:Property ;
    rdfs:label 'Hqla Level 1 Amount' ;
    rdfs:comment 'Total value of Level 1 HQLA (cash, central bank reserves, sovereign debt) eligible for LCR numerator with 0% haircut.' ;
    rdfs:domain ind:LiquidityRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hqlaLevel2aAmount rdf:type rdf:Property ;
    rdfs:label 'Hqla Level 2a Amount' ;
    rdfs:comment 'Total value of Level 2A HQLA (high-quality corporate bonds, covered bonds) eligible for LCR numerator with 15% haircut.' ;
    rdfs:domain ind:LiquidityRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hqlaLevel2bAmount rdf:type rdf:Property ;
    rdfs:label 'Hqla Level 2b Amount' ;
    rdfs:comment 'Total value of Level 2B HQLA (lower-rated corporate bonds, residential mortgage-backed securities, equities) eligible for LCR numerator with haircuts ranging from 25% to 50%.' ;
    rdfs:domain ind:LiquidityRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lcrPercentage rdf:type rdf:Property ;
    rdfs:label 'Lcr Percentage' ;
    rdfs:comment 'The calculated LCR expressed as a percentage. Calculated as (Total HQLA / Total Net Cash Outflows) * 100. Regulatory minimum is 100%.' ;
    rdfs:domain ind:LiquidityRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nsfrPercentage rdf:type rdf:Property ;
    rdfs:label 'Nsfr Percentage' ;
    rdfs:comment 'The calculated NSFR expressed as a percentage. Calculated as (Available Stable Funding / Required Stable Funding) * 100. Regulatory minimum is 100%.' ;
    rdfs:domain ind:LiquidityRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:periodOverPeriodChangePercentage rdf:type rdf:Property ;
    rdfs:label 'Period Over Period Change Percentage' ;
    rdfs:comment 'The percentage point change in the liquidity ratio compared to the prior reporting period. Calculated as (Current Ratio - Prior Period Ratio).' ;
    rdfs:domain ind:LiquidityRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorPeriodRatioPercentage rdf:type rdf:Property ;
    rdfs:label 'Prior Period Ratio Percentage' ;
    rdfs:comment 'The liquidity ratio percentage from the previous reporting period, used for trend analysis and variance reporting.' ;
    rdfs:domain ind:LiquidityRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ratioType rdf:type rdf:Property ;
    rdfs:label 'Ratio Type' ;
    rdfs:comment 'Discriminator indicating the type of liquidity ratio: LCR (Liquidity Coverage Ratio) for 30-day stress horizon or NSFR (Net Stable Funding Ratio) for one-year structural funding stability.' ;
    rdfs:domain ind:LiquidityRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryThresholdPercentage rdf:type rdf:Property ;
    rdfs:label 'Regulatory Threshold Percentage' ;
    rdfs:comment 'The regulatory minimum threshold for the ratio (typically 100% for both LCR and NSFR under Basel III).' ;
    rdfs:domain ind:LiquidityRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:securedFundingOutflowAmount rdf:type rdf:Property ;
    rdfs:label 'Secured Funding Outflow Amount' ;
    rdfs:comment 'Expected cash outflows from maturing secured funding transactions (repos, covered bonds) over the 30-day stress horizon.' ;
    rdfs:domain ind:LiquidityRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalHqlaAmount rdf:type rdf:Property ;
    rdfs:label 'Total Hqla Amount' ;
    rdfs:comment 'Total stock of HQLA after applying haircuts and caps. Numerator of the LCR calculation.' ;
    rdfs:domain ind:LiquidityRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalNetCashOutflowAmount rdf:type rdf:Property ;
    rdfs:label 'Total Net Cash Outflow Amount' ;
    rdfs:comment 'Total expected net cash outflows over the 30-day stress scenario. Denominator of the LCR calculation.' ;
    rdfs:domain ind:LiquidityRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accountManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Account Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to hr.employee. Business justification: Nostro accounts require designated relationship manager for correspondent bank coordination, break resolution, and intraday liquidity monitoring. account_manager_name text field should be FK to employ' ;
    rdfs:domain ind:NostroAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accountCloseDate rdf:type rdf:Property ;
    rdfs:label 'Account Close Date' ;
    rdfs:comment 'Date when the nostro account was closed, if applicable.' ;
    rdfs:domain ind:NostroAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accountOpenDate rdf:type rdf:Property ;
    rdfs:label 'Account Open Date' ;
    rdfs:comment 'Date when the nostro account was opened with the correspondent bank.' ;
    rdfs:domain ind:NostroAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accountPurpose rdf:type rdf:Property ;
    rdfs:label 'Account Purpose' ;
    rdfs:comment 'Primary business purpose of the nostro account (e.g., settlement, foreign exchange, securities, general operations, liquidity management).' ;
    rdfs:domain ind:NostroAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedSignatories rdf:type rdf:Property ;
    rdfs:label 'Authorized Signatories' ;
    rdfs:comment 'List or reference to individuals authorized to operate and sign on behalf of this nostro account.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breakAgingCategory rdf:type rdf:Property ;
    rdfs:label 'Break Aging Category' ;
    rdfs:comment 'Aging category of unmatched items (breaks) based on the number of days outstanding.' ;
    rdfs:domain ind:Treasury ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Current Balance Amount' ;
    rdfs:comment 'Current balance of the nostro account as per the latest reconciliation or statement.' ;
    rdfs:domain ind:NostroAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:escalationTriggerFlag rdf:type rdf:Property ;
    rdfs:label 'Escalation Trigger Flag' ;
    rdfs:comment 'Boolean flag indicating whether reconciliation breaks have triggered an escalation process.' ;
    rdfs:domain ind:NostroAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fxPositionManagementFlag rdf:type rdf:Property ;
    rdfs:label 'Fx Position Management Flag' ;
    rdfs:comment 'Boolean flag indicating whether this nostro account is used for foreign exchange position management.' ;
    rdfs:domain ind:NostroAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:intradayLiquidityMonitoringFlag rdf:type rdf:Property ;
    rdfs:label 'Intraday Liquidity Monitoring Flag' ;
    rdfs:comment 'Boolean flag indicating whether this nostro account is subject to intraday liquidity monitoring under BCBS 248.' ;
    rdfs:domain ind:NostroAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastReconciliationDate rdf:type rdf:Property ;
    rdfs:label 'Last Reconciliation Date' ;
    rdfs:comment 'Date of the most recent reconciliation performed for this nostro account.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:overdraftLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Overdraft Limit Amount' ;
    rdfs:comment 'Maximum overdraft limit authorized by the correspondent bank for this nostro account.' ;
    rdfs:domain ind:NostroAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rtgsSettlementFlag rdf:type rdf:Property ;
    rdfs:label 'Rtgs Settlement Flag' ;
    rdfs:comment 'Boolean flag indicating whether this nostro account is used for RTGS payment settlement.' ;
    rdfs:domain ind:NostroAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unmatchedItemsCount rdf:type rdf:Property ;
    rdfs:label 'Unmatched Items Count' ;
    rdfs:comment 'Number of unmatched items (breaks) identified during the last reconciliation.' ;
    rdfs:domain ind:Treasury ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nostroReconciliationId rdf:type rdf:Property ;
    rdfs:label 'Nostro Reconciliation Id' ;
    rdfs:comment 'Primary key for nostro_reconciliation' ;
    rdfs:domain ind:NostroReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryNostroEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Nostro Employee Id' ;
    rdfs:comment 'Identifier of the user who performed or approved the reconciliation.' ;
    rdfs:domain ind:NostroReconciliation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:breakAgingDays rdf:type rdf:Property ;
    rdfs:label 'Break Aging Days' ;
    rdfs:comment 'Number of days the oldest unmatched item has remained unresolved.' ;
    rdfs:domain ind:NostroReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:correspondentStatementBalance rdf:type rdf:Property ;
    rdfs:label 'Correspondent Statement Balance' ;
    rdfs:comment 'Balance of the nostro account as reported by the correspondent bank statement.' ;
    rdfs:domain ind:NostroReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exceptionThresholdBreachFlag rdf:type rdf:Property ;
    rdfs:label 'Exception Threshold Breach Flag' ;
    rdfs:comment 'Indicates whether the reconciliation difference exceeds predefined exception thresholds.' ;
    rdfs:domain ind:NostroReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:internalLedgerBalance rdf:type rdf:Property ;
    rdfs:label 'Internal Ledger Balance' ;
    rdfs:comment 'Balance of the nostro account as recorded in the internal general ledger system.' ;
    rdfs:domain ind:NostroReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:intradayLiquidityImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Intraday Liquidity Impact Flag' ;
    rdfs:comment 'Indicates whether reconciliation breaks impact intraday liquidity monitoring and management.' ;
    rdfs:domain ind:NostroReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:matchedItemsAmount rdf:type rdf:Property ;
    rdfs:label 'Matched Items Amount' ;
    rdfs:comment 'Total monetary value of successfully matched transaction items.' ;
    rdfs:domain ind:NostroReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:matchedItemsCount rdf:type rdf:Property ;
    rdfs:label 'Matched Items Count' ;
    rdfs:comment 'Number of transaction items successfully matched between internal records and correspondent statement.' ;
    rdfs:domain ind:NostroReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reconciliationDifferenceAmount rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Difference Amount' ;
    rdfs:comment 'Net difference between internal ledger balance and correspondent statement balance.' ;
    rdfs:domain ind:NostroReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:statementReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Statement Reference Number' ;
    rdfs:comment 'Unique reference number of the correspondent bank statement used for reconciliation.' ;
    rdfs:domain ind:NostroReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unmatchedExternalItemsAmount rdf:type rdf:Property ;
    rdfs:label 'Unmatched External Items Amount' ;
    rdfs:comment 'Total monetary value of items present on correspondent statement but not found in internal ledger.' ;
    rdfs:domain ind:NostroReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unmatchedExternalItemsCount rdf:type rdf:Property ;
    rdfs:label 'Unmatched External Items Count' ;
    rdfs:comment 'Number of items present on correspondent statement but not found in internal ledger.' ;
    rdfs:domain ind:NostroReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unmatchedInternalItemsAmount rdf:type rdf:Property ;
    rdfs:label 'Unmatched Internal Items Amount' ;
    rdfs:comment 'Total monetary value of items present in internal ledger but not found on correspondent statement.' ;
    rdfs:domain ind:NostroReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unmatchedInternalItemsCount rdf:type rdf:Property ;
    rdfs:label 'Unmatched Internal Items Count' ;
    rdfs:comment 'Number of items present in internal ledger but not found on correspondent statement.' ;
    rdfs:domain ind:NostroReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unmatchedItemsAmount rdf:type rdf:Property ;
    rdfs:label 'Unmatched Items Amount' ;
    rdfs:comment 'Total monetary value of unmatched transaction items representing reconciliation breaks.' ;
    rdfs:domain ind:NostroReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collateralFundId rdf:type rdf:Property ;
    rdfs:label 'Collateral Fund Id' ;
    rdfs:comment 'Foreign key linking to asset.fund. Business justification: Repo transactions use fund units as collateral in tri-party arrangements. Treasury must track which funds are pledged, their market value, haircuts, and substitution rights for collateral management a' ;
    rdfs:domain ind:Treasury ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fund .

ind:clearingHouse rdf:type rdf:Property ;
    rdfs:label 'Clearing House' ;
    rdfs:comment 'The name of the clearing house or central counterparty (CCP) used for tri-party or cleared repos, if applicable.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cumulativePnl rdf:type rdf:Property ;
    rdfs:label 'Cumulative Pnl' ;
    rdfs:comment 'The cumulative profit or loss on the repo position from inception to the current valuation date.' ;
    rdfs:domain ind:RepoPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dailyPnl rdf:type rdf:Property ;
    rdfs:label 'Daily Pnl' ;
    rdfs:comment 'The daily profit or loss attributed to this repo position, calculated from mark-to-market changes and accrued interest.' ;
    rdfs:domain ind:RepoPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mtmDate rdf:type rdf:Property ;
    rdfs:label 'Mtm Date' ;
    rdfs:comment 'The date as of which the mark-to-market valuation was calculated.' ;
    rdfs:domain ind:RepoPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mtmValuation rdf:type rdf:Property ;
    rdfs:label 'Mtm Valuation' ;
    rdfs:comment 'The current mark-to-market valuation of the repo position, reflecting changes in collateral value and accrued interest.' ;
    rdfs:domain ind:RepoPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nsfrClassification rdf:type rdf:Property ;
    rdfs:label 'Nsfr Classification' ;
    rdfs:comment 'Required Stable Funding (RSF) factor classification for NSFR calculation: 0%, 5%, 10%, 15%, 50%, 65%, 85%, or 100%. [ENUM-REF-CANDIDATE: rsf_0|rsf_5|rsf_10|rsf_15|rsf_50|rsf_65|rsf_85|rsf_100 — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RepoPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termType rdf:type rdf:Property ;
    rdfs:label 'Term Type' ;
    rdfs:comment 'Classification of the repo duration: open (no fixed maturity), term (fixed maturity), or overnight.' ;
    rdfs:domain ind:RepoPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triPartyAgent rdf:type rdf:Property ;
    rdfs:label 'Tri Party Agent' ;
    rdfs:comment 'The name of the tri-party agent managing collateral for tri-party repo transactions.' ;
    rdfs:domain ind:Treasury ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundingCostAmount rdf:type rdf:Property ;
    rdfs:label 'Funding Cost Amount' ;
    rdfs:comment 'The calculated funding cost for this repo transaction, feeding into the treasury funding cost ledger.' ;
    rdfs:domain ind:RepoTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fundingCostRate rdf:type rdf:Property ;
    rdfs:label 'Funding Cost Rate' ;
    rdfs:comment 'The internal funds transfer pricing (FTP) rate applied to this repo transaction for treasury funding cost allocation.' ;
    rdfs:domain ind:RepoTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marginCallDate rdf:type rdf:Property ;
    rdfs:label 'Margin Call Date' ;
    rdfs:comment 'The date on which a margin call was issued for this repo transaction.' ;
    rdfs:domain ind:RepoTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mtmValuationAmount rdf:type rdf:Property ;
    rdfs:label 'Mtm Valuation Amount' ;
    rdfs:comment 'The mark-to-market valuation of the repo transaction, reflecting current market conditions and collateral value changes.' ;
    rdfs:domain ind:RepoTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pnlAmount rdf:type rdf:Property ;
    rdfs:label 'Pnl Amount' ;
    rdfs:comment 'The daily profit or loss attributed to this repo transaction, calculated from interest income, MTM changes, and funding costs.' ;
    rdfs:domain ind:RepoTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pnlAttributionDate rdf:type rdf:Property ;
    rdfs:label 'Pnl Attribution Date' ;
    rdfs:comment 'The business date for which the PnL amount was calculated and attributed to the repo book.' ;
    rdfs:domain ind:RepoTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:repurchaseAmount rdf:type rdf:Property ;
    rdfs:label 'Repurchase Amount' ;
    rdfs:comment 'The total amount due at maturity, including principal and accrued interest (closing leg).' ;
    rdfs:domain ind:RepoTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:alcoReviewFrequency rdf:type rdf:Property ;
    rdfs:label 'Alco Review Frequency' ;
    rdfs:comment 'Frequency at which ALCO reviews and updates this stress scenario: monthly, quarterly, semi-annually, or annually.' ;
    rdfs:domain ind:StressScenarioCfp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetMonetizationCapacity rdf:type rdf:Property ;
    rdfs:label 'Asset Monetization Capacity' ;
    rdfs:comment 'Estimated liquidity that can be raised through emergency asset sales or securitization under this stress scenario, in base currency.' ;
    rdfs:domain ind:StressScenarioCfp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:centralBankFacilityCapacity rdf:type rdf:Property ;
    rdfs:label 'Central Bank Facility Capacity' ;
    rdfs:comment 'Maximum borrowing capacity available from central bank discount window and emergency lending facilities under this stress scenario, in base currency.' ;
    rdfs:domain ind:StressScenarioCfp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cet1ImpactPercentage rdf:type rdf:Property ;
    rdfs:label 'Cet1 Impact Percentage' ;
    rdfs:comment 'Estimated percentage point impact on the Common Equity Tier 1 (CET1) capital ratio under this stress scenario, expressed as a decimal (e.g., -0.30 for 30 percentage point decline).' ;
    rdfs:domain ind:StressScenarioCfp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:committedFacilityDrawdownRate rdf:type rdf:Property ;
    rdfs:label 'Committed Facility Drawdown Rate' ;
    rdfs:comment 'Assumed percentage of undrawn committed credit facilities that will be drawn down by counterparties under stress, expressed as a decimal (e.g., 0.30 for 30% drawdown).' ;
    rdfs:domain ind:StressScenarioCfp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contingentLiquiditySourceAmount rdf:type rdf:Property ;
    rdfs:label 'Contingent Liquidity Source Amount' ;
    rdfs:comment 'Total amount of contingent liquidity sources available under this scenario, including central bank facilities, FHLB advances, and pre-arranged credit lines, in base currency.' ;
    rdfs:domain ind:StressScenarioCfp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:derivativeCollateralCallRate rdf:type rdf:Property ;
    rdfs:label 'Derivative Collateral Call Rate' ;
    rdfs:comment 'Assumed percentage increase in derivative collateral posting requirements under stress, expressed as a decimal (e.g., 0.50 for 50% increase).' ;
    rdfs:domain ind:StressScenarioCfp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:earlyWarningIndicatorThreshold rdf:type rdf:Property ;
    rdfs:label 'Early Warning Indicator Threshold' ;
    rdfs:comment 'Comma-separated list of early warning indicator thresholds that trigger escalation under this contingency funding plan (e.g., \'LCR<110%,deposit_outflow>5%,credit_rating_downgrade\').' ;
    rdfs:domain ind:StressScenarioCfp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationLevel1Trigger rdf:type rdf:Property ;
    rdfs:label 'Escalation Level 1 Trigger' ;
    rdfs:comment 'Description of conditions that trigger Level 1 escalation (heightened monitoring) in the contingency funding plan.' ;
    rdfs:domain ind:StressScenarioCfp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationLevel2Trigger rdf:type rdf:Property ;
    rdfs:label 'Escalation Level 2 Trigger' ;
    rdfs:comment 'Description of conditions that trigger Level 2 escalation (active response measures) in the contingency funding plan.' ;
    rdfs:domain ind:StressScenarioCfp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationLevel3Trigger rdf:type rdf:Property ;
    rdfs:label 'Escalation Level 3 Trigger' ;
    rdfs:comment 'Description of conditions that trigger Level 3 escalation (emergency liquidity actions) in the contingency funding plan.' ;
    rdfs:domain ind:StressScenarioCfp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fhlbAdvanceCapacity rdf:type rdf:Property ;
    rdfs:label 'Fhlb Advance Capacity' ;
    rdfs:comment 'Maximum borrowing capacity available from Federal Home Loan Bank advances under this stress scenario, in base currency.' ;
    rdfs:domain ind:StressScenarioCfp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hqlaLevel1HaircutRate rdf:type rdf:Property ;
    rdfs:label 'Hqla Level 1 Haircut Rate' ;
    rdfs:comment 'Stress haircut percentage applied to Level 1 HQLA assets (cash, central bank reserves, sovereign debt), expressed as a decimal. Typically minimal or zero.' ;
    rdfs:domain ind:StressScenarioCfp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hqlaLevel2aHaircutRate rdf:type rdf:Property ;
    rdfs:label 'Hqla Level 2a Haircut Rate' ;
    rdfs:comment 'Stress haircut percentage applied to Level 2A HQLA assets (high-quality corporate bonds, covered bonds), expressed as a decimal (e.g., 0.20 for 20% haircut).' ;
    rdfs:domain ind:StressScenarioCfp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hqlaLevel2bHaircutRate rdf:type rdf:Property ;
    rdfs:label 'Hqla Level 2b Haircut Rate' ;
    rdfs:comment 'Stress haircut percentage applied to Level 2B HQLA assets (lower-rated corporate bonds, equities), expressed as a decimal (e.g., 0.50 for 50% haircut).' ;
    rdfs:domain ind:StressScenarioCfp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lcrImpactPercentage rdf:type rdf:Property ;
    rdfs:label 'Lcr Impact Percentage' ;
    rdfs:comment 'Estimated percentage point impact on the Liquidity Coverage Ratio (LCR) under this stress scenario, expressed as a decimal (e.g., -0.25 for 25 percentage point decline).' ;
    rdfs:domain ind:StressScenarioCfp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:macroeconomicAssumptions rdf:type rdf:Property ;
    rdfs:label 'Macroeconomic Assumptions' ;
    rdfs:comment 'Summary of key macroeconomic assumptions underlying the stress scenario (e.g., GDP growth, unemployment rate, interest rate shocks, equity market decline).' ;
    rdfs:domain ind:StressScenarioCfp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketShockAssumptions rdf:type rdf:Property ;
    rdfs:label 'Market Shock Assumptions' ;
    rdfs:comment 'Description of assumed market shocks in the stress scenario (e.g., credit spread widening, FX volatility, commodity price collapse, liquidity freeze).' ;
    rdfs:domain ind:StressScenarioCfp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nsfrImpactPercentage rdf:type rdf:Property ;
    rdfs:label 'Nsfr Impact Percentage' ;
    rdfs:comment 'Estimated percentage point impact on the Net Stable Funding Ratio (NSFR) under this stress scenario, expressed as a decimal (e.g., -0.15 for 15 percentage point decline).' ;
    rdfs:domain ind:StressScenarioCfp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responseActionSummary rdf:type rdf:Property ;
    rdfs:label 'Response Action Summary' ;
    rdfs:comment 'High-level summary of pre-approved liquidity stress response actions defined in the contingency funding plan for this scenario (e.g., \'Activate FHLB advances, reduce new lending, sell liquid securities portfolio\').' ;
    rdfs:domain ind:StressScenarioCfp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retailDepositRunoffRate rdf:type rdf:Property ;
    rdfs:label 'Retail Deposit Runoff Rate' ;
    rdfs:comment 'Assumed percentage rate of retail deposit outflows under this stress scenario, expressed as a decimal (e.g., 0.15 for 15% runoff).' ;
    rdfs:domain ind:StressScenarioCfp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scenarioSeverityRating rdf:type rdf:Property ;
    rdfs:label 'Scenario Severity Rating' ;
    rdfs:comment 'Qualitative severity rating of the stress scenario: mild, moderate, severe, or extreme, based on the magnitude of assumed shocks and impacts.' ;
    rdfs:domain ind:StressScenarioCfp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scenarioStatus rdf:type rdf:Property ;
    rdfs:label 'Scenario Status' ;
    rdfs:comment 'Current lifecycle status of the stress scenario: draft (under development), active (approved for use), archived (historical), superseded (replaced by newer version).' ;
    rdfs:domain ind:StressScenarioCfp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securedFundingHaircutRate rdf:type rdf:Property ;
    rdfs:label 'Secured Funding Haircut Rate' ;
    rdfs:comment 'Additional haircut percentage applied to collateral values for secured funding transactions under stress, expressed as a decimal (e.g., 0.25 for 25% additional haircut).' ;
    rdfs:domain ind:StressScenarioCfp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stressHorizonDays rdf:type rdf:Property ;
    rdfs:label 'Stress Horizon Days' ;
    rdfs:comment 'Duration of the stress scenario in days (e.g., 30, 90, 365) over which liquidity and capital impacts are projected.' ;
    rdfs:domain ind:StressScenarioCfp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wholesaleDepositRunoffRate rdf:type rdf:Property ;
    rdfs:label 'Wholesale Deposit Runoff Rate' ;
    rdfs:comment 'Assumed percentage rate of wholesale deposit outflows under this stress scenario, expressed as a decimal (e.g., 0.40 for 40% runoff).' ;
    rdfs:domain ind:StressScenarioCfp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wholesaleFundingRolloverRate rdf:type rdf:Property ;
    rdfs:label 'Wholesale Funding Rollover Rate' ;
    rdfs:comment 'Assumed percentage of maturing wholesale funding that can be successfully rolled over under stress, expressed as a decimal (e.g., 0.50 for 50% rollover success).' ;
    rdfs:domain ind:StressScenarioCfp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:benchmarkRateBenchmarkId rdf:type rdf:Property ;
    rdfs:label 'Benchmark Rate Benchmark Id' ;
    rdfs:comment 'Foreign key linking to reference.rate_benchmark. Business justification: Transfer pricing curves built on benchmark rates (SOFR, SONIA) for curve construction. Link enables daily rate fixing, IBOR transition, and spread calculation over risk-free rate.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RateBenchmark .

ind:lcrTreatmentFlag rdf:type rdf:Property ;
    rdfs:label 'Lcr Treatment Flag' ;
    rdfs:comment 'Indicates whether this curve is used in Liquidity Coverage Ratio (LCR) calculations and reporting. True if applicable, false otherwise.' ;
    rdfs:domain ind:TransferPricingCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:liquiditySpreadBps rdf:type rdf:Property ;
    rdfs:label 'Liquidity Spread Bps' ;
    rdfs:comment 'The bank-specific liquidity premium adjustment in basis points added to the benchmark rate to reflect the institution\'s funding liquidity costs and liquidity risk.' ;
    rdfs:domain ind:TransferPricingCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketDataTimestamp rdf:type rdf:Property ;
    rdfs:label 'Market Data Timestamp' ;
    rdfs:comment 'The timestamp at which the underlying market benchmark rates were observed or extracted for curve construction.' ;
    rdfs:domain ind:TransferPricingCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:nsfrTreatmentFlag rdf:type rdf:Property ;
    rdfs:label 'Nsfr Treatment Flag' ;
    rdfs:comment 'Indicates whether this curve is used in Net Stable Funding Ratio (NSFR) calculations and reporting. True if applicable, false otherwise.' ;
    rdfs:domain ind:TransferPricingCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operationalSpreadBps rdf:type rdf:Property ;
    rdfs:label 'Operational Spread Bps' ;
    rdfs:comment 'Additional spread in basis points to cover operational costs, capital allocation, and other bank-specific adjustments not captured in liquidity or credit spreads.' ;
    rdfs:domain ind:TransferPricingCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:alternativeInvestmentId rdf:type rdf:Property ;
    rdfs:label 'Alternative Investment Id' ;
    rdfs:comment 'Unique identifier for the alternative investment holding record. Primary key for this entity.' ;
    rdfs:domain ind:AlternativeInvestment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cashAccountDepositAccountId rdf:type rdf:Property ;
    rdfs:label 'Cash Account Deposit Account Id' ;
    rdfs:comment 'Foreign key linking to account.deposit_account. Business justification: Alternative investments require deposit accounts for capital call funding and distribution receipts in private equity, hedge funds, and real estate investments. Essential for alternative investment ca' ;
    rdfs:domain ind:Wealth ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DepositAccount .

ind:originatingDealId rdf:type rdf:Property ;
    rdfs:label 'Originating Deal Id' ;
    rdfs:comment 'Foreign key linking to investment.deal. Business justification: Alternative investments (PE, VC funds) are often structured or originated through investment banking deals. Real business process: tracking deal origination for alternative investments to maintain cli' ;
    rdfs:domain ind:AlternativeInvestment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Deal .

ind:carriedInterestRate rdf:type rdf:Property ;
    rdfs:label 'Carried Interest Rate' ;
    rdfs:comment 'Performance fee or carried interest rate earned by the general partner on profits above the hurdle rate, expressed as a decimal (e.g., 0.2000 for 20%).' ;
    rdfs:domain ind:AlternativeInvestment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commitmentCurrency rdf:type rdf:Property ;
    rdfs:label 'Commitment Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the commitment amount.' ;
    rdfs:domain ind:AlternativeInvestment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionsReceived rdf:type rdf:Property ;
    rdfs:label 'Distributions Received' ;
    rdfs:comment 'Cumulative distributions received from the alternative investment fund to date, including return of capital and profits.' ;
    rdfs:domain ind:AlternativeInvestment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dpiMultiple rdf:type rdf:Property ;
    rdfs:label 'Dpi Multiple' ;
    rdfs:comment 'Distributions to paid-in capital multiple, calculated as distributions received divided by funded amount. Measures cash returned.' ;
    rdfs:domain ind:AlternativeInvestment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedLiquidationDate rdf:type rdf:Property ;
    rdfs:label 'Expected Liquidation Date' ;
    rdfs:comment 'Expected date by which the fund will be fully liquidated and all capital returned to investors.' ;
    rdfs:domain ind:AlternativeInvestment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fundManagerIdentifier rdf:type rdf:Property ;
    rdfs:label 'Fund Manager Identifier' ;
    rdfs:comment 'Regulatory or industry identifier for the fund manager (e.g., SEC CRD number, FCA FRN).' ;
    rdfs:domain ind:AlternativeInvestment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundManagerName rdf:type rdf:Property ;
    rdfs:label 'Fund Manager Name' ;
    rdfs:comment 'Name of the general partner or fund manager responsible for managing the alternative investment.' ;
    rdfs:domain ind:AlternativeInvestment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundTermYears rdf:type rdf:Property ;
    rdfs:label 'Fund Term Years' ;
    rdfs:comment 'Total term of the fund in years, including any extension periods.' ;
    rdfs:domain ind:AlternativeInvestment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fundVintageYear rdf:type rdf:Property ;
    rdfs:label 'Fund Vintage Year' ;
    rdfs:comment 'The year in which the fund began making investments, used for performance benchmarking and cohort analysis.' ;
    rdfs:domain ind:AlternativeInvestment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:investmentName rdf:type rdf:Property ;
    rdfs:label 'Investment Name' ;
    rdfs:comment 'Full legal or marketing name of the alternative investment fund or vehicle.' ;
    rdfs:domain ind:AlternativeInvestment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investmentNumber rdf:type rdf:Property ;
    rdfs:label 'Investment Number' ;
    rdfs:comment 'Business-facing unique identifier or reference number for this alternative investment holding.' ;
    rdfs:domain ind:AlternativeInvestment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investmentPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Investment Period End Date' ;
    rdfs:comment 'Date on which the funds investment period ends, after which no new investments can be made.' ;
    rdfs:domain ind:AlternativeInvestment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:investmentStatus rdf:type rdf:Property ;
    rdfs:label 'Investment Status' ;
    rdfs:comment 'Current lifecycle status of the alternative investment holding. Tracks progression from commitment through liquidation.' ;
    rdfs:domain ind:AlternativeInvestment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investmentType rdf:type rdf:Property ;
    rdfs:label 'Investment Type' ;
    rdfs:comment 'Classification of the alternative investment by asset class. Includes private equity, venture capital, hedge funds, real estate, infrastructure, and commodities.' ;
    rdfs:domain ind:AlternativeInvestment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irrPercent rdf:type rdf:Property ;
    rdfs:label 'Irr Percent' ;
    rdfs:comment 'Internal rate of return on the alternative investment since inception, expressed as a percentage.' ;
    rdfs:domain ind:AlternativeInvestment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:moicMultiple rdf:type rdf:Property ;
    rdfs:label 'Moic Multiple' ;
    rdfs:comment 'Multiple on invested capital, calculated as (distributions received plus NAV) divided by funded amount.' ;
    rdfs:domain ind:AlternativeInvestment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:navAmount rdf:type rdf:Property ;
    rdfs:label 'Nav Amount' ;
    rdfs:comment 'Current net asset value of the alternative investment holding as reported by the fund manager.' ;
    rdfs:domain ind:AlternativeInvestment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:navAsOfDate rdf:type rdf:Property ;
    rdfs:label 'Nav As Of Date' ;
    rdfs:comment 'Date as of which the NAV amount was calculated or reported by the fund manager.' ;
    rdfs:domain ind:AlternativeInvestment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:navReportingFrequency rdf:type rdf:Property ;
    rdfs:label 'Nav Reporting Frequency' ;
    rdfs:comment 'Frequency at which the fund manager provides NAV updates for this alternative investment.' ;
    rdfs:domain ind:AlternativeInvestment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rvpiMultiple rdf:type rdf:Property ;
    rdfs:label 'Rvpi Multiple' ;
    rdfs:comment 'Residual value to paid-in capital multiple, calculated as NAV divided by funded amount. Measures unrealized value.' ;
    rdfs:domain ind:AlternativeInvestment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sideLetterFlag rdf:type rdf:Property ;
    rdfs:label 'Side Letter Flag' ;
    rdfs:comment 'Indicates whether a side letter agreement exists that modifies standard fund terms for this investor.' ;
    rdfs:domain ind:AlternativeInvestment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tvpiMultiple rdf:type rdf:Property ;
    rdfs:label 'Tvpi Multiple' ;
    rdfs:comment 'Total value to paid-in capital multiple, calculated as (distributions plus NAV) divided by funded amount. Synonym for MOIC.' ;
    rdfs:domain ind:AlternativeInvestment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assetAllocationId rdf:type rdf:Property ;
    rdfs:label 'Asset Allocation Id' ;
    rdfs:comment 'Unique identifier for the asset allocation record.' ;
    rdfs:domain ind:AssetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocationCurrencyId rdf:type rdf:Property ;
    rdfs:label 'Allocation Currency Id' ;
    rdfs:comment 'Foreign key linking to reference.currency. Business justification: Asset allocations by currency (FX exposure management) require reference to valid currency codes. Portfolio construction, rebalancing, and risk reporting depend on currency allocation tracking against' ;
    rdfs:domain ind:AssetAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:assetClassCodeListId rdf:type rdf:Property ;
    rdfs:label 'Asset Class Code List Id' ;
    rdfs:comment 'Foreign key linking to reference.code_list. Business justification: Asset classes use standardized taxonomy (equity, fixed income, alternatives) for allocation. Portfolio construction, rebalancing, and risk reporting require code list reference for consistent classifi' ;
    rdfs:domain ind:Wealth ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CodeList .

ind:investmentPolicyStatementId rdf:type rdf:Property ;
    rdfs:label 'Investment Policy Statement Id' ;
    rdfs:comment 'Reference identifier linking this allocation to the governing Investment Policy Statement document or section.' ;
    rdfs:domain ind:Wealth ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InvestmentPolicyStatement .

ind:parentAllocationAssetAllocationId rdf:type rdf:Property ;
    rdfs:label 'Parent Allocation Asset Allocation Id' ;
    rdfs:comment 'Reference to the parent asset allocation record in a hierarchical allocation structure (nullable for top-level allocations).' ;
    rdfs:domain ind:AssetAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssetAllocation .

ind:actualWeightPercent rdf:type rdf:Property ;
    rdfs:label 'Actual Weight Percent' ;
    rdfs:comment 'Current actual allocation weight as a percentage of total portfolio value, calculated from current holdings and market values.' ;
    rdfs:domain ind:AssetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationHierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Allocation Hierarchy Level' ;
    rdfs:comment 'Hierarchical level of this allocation within the asset class taxonomy (1=top-level asset class, 2=subclass, 3=granular segment).' ;
    rdfs:domain ind:AssetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocationName rdf:type rdf:Property ;
    rdfs:label 'Allocation Name' ;
    rdfs:comment 'Business-friendly name or label for this asset allocation strategy (e.g., Conservative Growth, Aggressive Equity).' ;
    rdfs:domain ind:AssetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correlationCoefficient rdf:type rdf:Property ;
    rdfs:label 'Correlation Coefficient' ;
    rdfs:comment 'Statistical correlation of this asset class with the overall portfolio or a reference asset class, ranging from -1.000 to +1.000.' ;
    rdfs:domain ind:AssetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:driftPercent rdf:type rdf:Property ;
    rdfs:label 'Drift Percent' ;
    rdfs:comment 'Calculated deviation of actual weight from target weight, expressed as percentage points (actual_weight_percent - target_weight_percent).' ;
    rdfs:domain ind:AssetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:driftThresholdPercent rdf:type rdf:Property ;
    rdfs:label 'Drift Threshold Percent' ;
    rdfs:comment 'Maximum allowable drift from target weight before rebalancing is triggered, expressed as percentage points.' ;
    rdfs:domain ind:AssetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:esgAlignmentFlag rdf:type rdf:Property ;
    rdfs:label 'Esg Alignment Flag' ;
    rdfs:comment 'Indicator whether this allocation aligns with Environmental, Social, and Governance (ESG) investment criteria (True/False).' ;
    rdfs:domain ind:AssetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:expectedReturnPercent rdf:type rdf:Property ;
    rdfs:label 'Expected Return Percent' ;
    rdfs:comment 'Projected annualized return for this asset class allocation, used in portfolio optimization and client reporting.' ;
    rdfs:domain ind:Wealth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedVolatilityPercent rdf:type rdf:Property ;
    rdfs:label 'Expected Volatility Percent' ;
    rdfs:comment 'Projected annualized standard deviation (volatility) for this asset class allocation, used in risk assessment.' ;
    rdfs:domain ind:Wealth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geographicAllocation rdf:type rdf:Property ;
    rdfs:label 'Geographic Allocation' ;
    rdfs:comment 'Geographic or regional focus of the allocation (e.g., USA, EUR, GBR, emerging markets, global).' ;
    rdfs:domain ind:AssetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastRebalancedDate rdf:type rdf:Property ;
    rdfs:label 'Last Rebalanced Date' ;
    rdfs:comment 'Date when this allocation was last rebalanced to bring actual weights back in line with target weights.' ;
    rdfs:domain ind:AssetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maximumWeightPercent rdf:type rdf:Property ;
    rdfs:label 'Maximum Weight Percent' ;
    rdfs:comment 'Maximum allowable allocation weight as a percentage, defining the upper bound of the rebalancing band.' ;
    rdfs:domain ind:AssetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumWeightPercent rdf:type rdf:Property ;
    rdfs:label 'Minimum Weight Percent' ;
    rdfs:comment 'Minimum allowable allocation weight as a percentage, defining the lower bound of the rebalancing band.' ;
    rdfs:domain ind:AssetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rebalancingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Rebalancing Required Flag' ;
    rdfs:comment 'Indicator whether this allocation line has breached drift thresholds and requires rebalancing action (True/False).' ;
    rdfs:domain ind:AssetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recordVersion rdf:type rdf:Property ;
    rdfs:label 'Record Version' ;
    rdfs:comment 'Version number of this allocation record, incremented with each update to support change tracking and audit history.' ;
    rdfs:domain ind:AssetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:riskToleranceAlignment rdf:type rdf:Property ;
    rdfs:label 'Risk Tolerance Alignment' ;
    rdfs:comment 'Risk profile category that this allocation is designed to support (conservative, moderate, balanced, growth, aggressive).' ;
    rdfs:domain ind:AssetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetWeightPercent rdf:type rdf:Property ;
    rdfs:label 'Target Weight Percent' ;
    rdfs:comment 'Strategic or tactical target allocation weight as a percentage of total portfolio value (e.g., 60.00 for 60%).' ;
    rdfs:domain ind:AssetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxEfficiencyRating rdf:type rdf:Property ;
    rdfs:label 'Tax Efficiency Rating' ;
    rdfs:comment 'Qualitative assessment of the tax efficiency of this asset class allocation (high, medium, low) for tax-aware portfolio management.' ;
    rdfs:domain ind:AssetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mandateTypeCodeListId rdf:type rdf:Property ;
    rdfs:label 'Mandate Type Code List Id' ;
    rdfs:comment 'Foreign key linking to reference.code_list. Business justification: Mandate types use standardized codes (discretionary, advisory, execution-only) for service model. Fee calculation, regulatory reporting, and service delivery require code list reference.' ;
    rdfs:domain ind:ClientMandate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CodeList .

ind:onboardingBranchId rdf:type rdf:Property ;
    rdfs:label 'Onboarding Branch Id' ;
    rdfs:comment 'Foreign key linking to channel.branch. Business justification: Mandates typically opened at specific branch for KYC, document notarization, and relationship establishment. Required for branch attribution, geographic regulatory compliance (state/country licensing)' ;
    rdfs:domain ind:ClientMandate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Branch .

ind:regulatoryClassificationProductTypeId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Classification Product Type Id' ;
    rdfs:comment 'Foreign key linking to reference.product_type. Business justification: Mandates are classified by product type for regulatory reporting. UCITS/AIF classification, Form ADV reporting, and product governance require product type reference.' ;
    rdfs:domain ind:ClientMandate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductType .

ind:taxReportingJurisdictionCountryId rdf:type rdf:Property ;
    rdfs:label 'Tax Reporting Jurisdiction Country Id' ;
    rdfs:comment 'Foreign key linking to reference.country. Business justification: Mandates specify tax reporting jurisdiction for FATCA/CRS compliance. Regulatory reporting, withholding tax calculation, and cross-border tax treaty application require country reference.' ;
    rdfs:domain ind:ClientMandate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:aumAtInception rdf:type rdf:Property ;
    rdfs:label 'Aum At Inception' ;
    rdfs:comment 'Total asset value under management at the time the mandate was established, used for performance tracking and fee calculation baseline.' ;
    rdfs:domain ind:ClientMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:authorizedSignatoryName rdf:type rdf:Property ;
    rdfs:label 'Authorized Signatory Name' ;
    rdfs:comment 'Name of the individual authorized to sign documents and approve transactions on behalf of the client for this mandate.' ;
    rdfs:domain ind:ClientMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedSignatoryTitle rdf:type rdf:Property ;
    rdfs:label 'Authorized Signatory Title' ;
    rdfs:comment 'Title or role of the authorized signatory (e.g., Trustee, Power of Attorney, Director).' ;
    rdfs:domain ind:ClientMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discretionaryLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Discretionary Limit Amount' ;
    rdfs:comment 'Maximum amount the wealth manager may invest or trade without explicit client approval, applicable to discretionary mandates.' ;
    rdfs:domain ind:ClientMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mandateNumber rdf:type rdf:Property ;
    rdfs:label 'Mandate Number' ;
    rdfs:comment 'Externally visible unique business identifier for the mandate, used in client communications and regulatory reporting.' ;
    rdfs:domain ind:ClientMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Balance Amount' ;
    rdfs:comment 'Minimum asset value required to maintain the mandate. Falling below this threshold may trigger review or termination.' ;
    rdfs:domain ind:ClientMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:riskProfile rdf:type rdf:Property ;
    rdfs:label 'Risk Profile' ;
    rdfs:comment 'Client\'s risk tolerance classification as assessed during suitability analysis, guiding asset allocation and investment strategy.' ;
    rdfs:domain ind:Wealth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxReportingJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Tax Reporting Jurisdiction' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code representing the primary tax jurisdiction for reporting purposes (e.g., USA, GBR, CHE).' ;
    rdfs:domain ind:ClientMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationConditions rdf:type rdf:Property ;
    rdfs:label 'Termination Conditions' ;
    rdfs:comment 'Textual description of the conditions under which the mandate may be terminated by the client or the wealth manager, including breach of terms, regulatory changes, or client request.' ;
    rdfs:domain ind:ClientMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compositeId rdf:type rdf:Property ;
    rdfs:label 'Composite Id' ;
    rdfs:comment 'Unique identifier for the GIPS composite. Primary key.' ;
    rdfs:domain ind:Wealth ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Composite .

ind:modelPortfolioId rdf:type rdf:Property ;
    rdfs:label 'Model Portfolio Id' ;
    rdfs:comment 'Foreign key linking to wealth.model_portfolio. Business justification: GIPS composites may be based on model portfolios. This optional FK links composites to the model portfolio strategy they represent. No redundant columns (composite tracks performance aggregation, mode' ;
    rdfs:domain ind:Wealth ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ModelPortfolio .

ind:aum rdf:type rdf:Property ;
    rdfs:label 'Aum' ;
    rdfs:comment 'Total market value of all assets managed within the composite as of the most recent valuation date, expressed in base currency.' ;
    rdfs:domain ind:Composite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:aumAsOfDate rdf:type rdf:Property ;
    rdfs:label 'Aum As Of Date' ;
    rdfs:comment 'Valuation date for the reported composite AUM and portfolio count.' ;
    rdfs:domain ind:Wealth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:compositeCode rdf:type rdf:Property ;
    rdfs:label 'Composite Code' ;
    rdfs:comment 'Internal system code or identifier for the composite used in operational systems.' ;
    rdfs:domain ind:Composite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compositeName rdf:type rdf:Property ;
    rdfs:label 'Composite Name' ;
    rdfs:comment 'Official name of the composite used in marketing materials and performance presentations.' ;
    rdfs:domain ind:Composite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compositeStatus rdf:type rdf:Property ;
    rdfs:label 'Composite Status' ;
    rdfs:comment 'Current operational status of the composite.' ;
    rdfs:domain ind:Composite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compositeType rdf:type rdf:Property ;
    rdfs:label 'Composite Type' ;
    rdfs:comment 'Classification of the composite by primary asset class or strategy type.' ;
    rdfs:domain ind:Composite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispersionCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Dispersion Calculation Method' ;
    rdfs:comment 'Statistical method used to calculate internal dispersion of portfolio returns within the composite.' ;
    rdfs:domain ind:Composite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusionCriteria rdf:type rdf:Property ;
    rdfs:label 'Exclusion Criteria' ;
    rdfs:comment 'Criteria defining which portfolios are excluded from the composite, including significant cash flow rules and other exclusions.' ;
    rdfs:domain ind:Composite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeScheduleDescription rdf:type rdf:Property ;
    rdfs:label 'Fee Schedule Description' ;
    rdfs:comment 'Description of the fee structure applied to portfolios within the composite for net return calculation.' ;
    rdfs:domain ind:Composite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gipsVerificationStatus rdf:type rdf:Property ;
    rdfs:label 'Gips Verification Status' ;
    rdfs:comment 'Status of independent third-party verification of the firm\'s claim of GIPS compliance for this composite.' ;
    rdfs:domain ind:Composite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossCompositeReturn1yr rdf:type rdf:Property ;
    rdfs:label 'Gross Composite Return 1yr' ;
    rdfs:comment 'Trailing one-year composite return before deduction of investment management fees, expressed as a percentage.' ;
    rdfs:domain ind:Composite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossCompositeReturn3yr rdf:type rdf:Property ;
    rdfs:label 'Gross Composite Return 3yr' ;
    rdfs:comment 'Trailing three-year annualized composite return before deduction of investment management fees, expressed as a percentage.' ;
    rdfs:domain ind:Composite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossCompositeReturn5yr rdf:type rdf:Property ;
    rdfs:label 'Gross Composite Return 5yr' ;
    rdfs:comment 'Trailing five-year annualized composite return before deduction of investment management fees, expressed as a percentage.' ;
    rdfs:domain ind:Composite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossCompositeReturnSinceInception rdf:type rdf:Property ;
    rdfs:label 'Gross Composite Return Since Inception' ;
    rdfs:comment 'Annualized composite return since inception before deduction of investment management fees, expressed as a percentage.' ;
    rdfs:domain ind:Composite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossCompositeReturnYtd rdf:type rdf:Property ;
    rdfs:label 'Gross Composite Return Ytd' ;
    rdfs:comment 'Year-to-date composite return before deduction of investment management fees, expressed as a percentage.' ;
    rdfs:domain ind:Composite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inclusionCriteria rdf:type rdf:Property ;
    rdfs:label 'Inclusion Criteria' ;
    rdfs:comment 'Detailed criteria defining which portfolios are eligible for inclusion in the composite based on mandate, strategy, and investment characteristics.' ;
    rdfs:domain ind:Composite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalDispersion rdf:type rdf:Property ;
    rdfs:label 'Internal Dispersion' ;
    rdfs:comment 'Statistical measure of the spread of individual portfolio returns within the composite, typically expressed as standard deviation or range, indicating consistency of performance across constituent portfolios.' ;
    rdfs:domain ind:Composite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumPortfolioSize rdf:type rdf:Property ;
    rdfs:label 'Minimum Portfolio Size' ;
    rdfs:comment 'Minimum asset size threshold for a portfolio to be eligible for inclusion in the composite, expressed in base currency.' ;
    rdfs:domain ind:Composite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netCompositeReturn1yr rdf:type rdf:Property ;
    rdfs:label 'Net Composite Return 1yr' ;
    rdfs:comment 'Trailing one-year composite return after deduction of investment management fees, expressed as a percentage.' ;
    rdfs:domain ind:Composite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netCompositeReturn3yr rdf:type rdf:Property ;
    rdfs:label 'Net Composite Return 3yr' ;
    rdfs:comment 'Trailing three-year annualized composite return after deduction of investment management fees, expressed as a percentage.' ;
    rdfs:domain ind:Composite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netCompositeReturn5yr rdf:type rdf:Property ;
    rdfs:label 'Net Composite Return 5yr' ;
    rdfs:comment 'Trailing five-year annualized composite return after deduction of investment management fees, expressed as a percentage.' ;
    rdfs:domain ind:Composite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netCompositeReturnSinceInception rdf:type rdf:Property ;
    rdfs:label 'Net Composite Return Since Inception' ;
    rdfs:comment 'Annualized composite return since inception after deduction of investment management fees, expressed as a percentage.' ;
    rdfs:domain ind:Composite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netCompositeReturnYtd rdf:type rdf:Property ;
    rdfs:label 'Net Composite Return Ytd' ;
    rdfs:comment 'Year-to-date composite return after deduction of investment management fees, expressed as a percentage.' ;
    rdfs:domain ind:Composite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:numberOfPortfolios rdf:type rdf:Property ;
    rdfs:label 'Number Of Portfolios' ;
    rdfs:comment 'Current count of portfolios included in the composite as of the most recent reporting period.' ;
    rdfs:domain ind:Composite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:significantCashFlowThresholdPct rdf:type rdf:Property ;
    rdfs:label 'Significant Cash Flow Threshold Pct' ;
    rdfs:comment 'Percentage threshold defining significant cash flows that may trigger temporary exclusion of a portfolio from the composite.' ;
    rdfs:domain ind:Composite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:strategyDescription rdf:type rdf:Property ;
    rdfs:label 'Strategy Description' ;
    rdfs:comment 'Detailed description of the investment mandate, strategy, and objectives that define the composite.' ;
    rdfs:domain ind:Composite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:threeYearAnnualizedExPostStandardDeviation rdf:type rdf:Property ;
    rdfs:label 'Three Year Annualized Ex Post Standard Deviation' ;
    rdfs:comment 'Three-year annualized standard deviation of composite returns, measuring historical volatility and risk.' ;
    rdfs:domain ind:Composite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:verifierName rdf:type rdf:Property ;
    rdfs:label 'Verifier Name' ;
    rdfs:comment 'Name of the independent third-party firm that performed GIPS verification.' ;
    rdfs:domain ind:Composite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:omnibusParentAccountId rdf:type rdf:Property ;
    rdfs:label 'Omnibus Parent Account Id' ;
    rdfs:comment 'Reference to the parent omnibus custodian account if this account is a sub-account within a pooled structure. Null for standalone or top-level accounts.' ;
    rdfs:domain ind:CustodianAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustodianAccount .

ind:primarySubCustodianInstitutionPartyId rdf:type rdf:Property ;
    rdfs:label 'Primary Sub Custodian Institution Party Id' ;
    rdfs:comment 'Reference to a sub-custodian institution in the custody chain, used when the primary custodian delegates safekeeping to a local custodian in specific markets (common for emerging markets and cross-border holdings).' ;
    rdfs:domain ind:CustodianAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:primeBrokerAgreementId rdf:type rdf:Property ;
    rdfs:label 'Prime Broker Agreement Id' ;
    rdfs:comment 'Reference to the prime brokerage agreement governing this custodian account, if applicable. Prime brokerage accounts provide integrated custody, financing, and execution services for hedge funds and institutional clients.' ;
    rdfs:domain ind:Wealth ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PrimeBrokerAgreement .

ind:settlementNostroAccountId rdf:type rdf:Property ;
    rdfs:label 'Settlement Nostro Account Id' ;
    rdfs:comment 'Foreign key linking to treasury.nostro_account. Business justification: Wealth custodian accounts settle cross-border transactions and FX trades through the bank\'s nostro accounts at correspondent banks. Business process: international settlement, multi-currency cash mana' ;
    rdfs:domain ind:CustodianAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NostroAccount .

ind:wealthFeeScheduleId rdf:type rdf:Property ;
    rdfs:label 'Wealth Fee Schedule Id' ;
    rdfs:comment 'Reference to the fee schedule governing custody fees, transaction fees, and ancillary charges for this account.' ;
    rdfs:domain ind:Wealth ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WealthFeeSchedule .

ind:accountOpeningDocumentationComplete rdf:type rdf:Property ;
    rdfs:label 'Account Opening Documentation Complete' ;
    rdfs:comment 'Boolean flag indicating whether all required account opening documentation (KYC, service agreements, authorized signatory forms) has been completed and verified.' ;
    rdfs:domain ind:CustodianAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:authorizedSignatoryList rdf:type rdf:Property ;
    rdfs:label 'Authorized Signatory List' ;
    rdfs:comment 'Comma-separated list or reference to individuals authorized to issue instructions on this custodian account. Critical for operational control and audit trail.' ;
    rdfs:domain ind:CustodianAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cassClassification rdf:type rdf:Property ;
    rdfs:label 'Cass Classification' ;
    rdfs:comment 'FCA CASS classification for UK-regulated accounts: CASS 5 (designated investment business), CASS 6 (custody assets), CASS 7 (client money), or not_applicable for non-UK accounts.' ;
    rdfs:domain ind:CustodianAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collateralManagementEnabled rdf:type rdf:Property ;
    rdfs:label 'Collateral Management Enabled' ;
    rdfs:comment 'Boolean flag indicating whether this custodian account is used for collateral management purposes, including posting and receiving collateral for derivatives and securities financing transactions.' ;
    rdfs:domain ind:CustodianAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:corporateActionElectionMethod rdf:type rdf:Property ;
    rdfs:label 'Corporate Action Election Method' ;
    rdfs:comment 'Defines how corporate action elections (dividends, rights issues, tender offers) are handled for securities held in this account: automatic (pre-defined rules), manual (case-by-case instruction), or custodian_discretion (custodian decides per standing instructions).' ;
    rdfs:domain ind:CustodianAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:custodianContactEmail rdf:type rdf:Property ;
    rdfs:label 'Custodian Contact Email' ;
    rdfs:comment 'Email address of the primary custodian contact for operational inquiries and settlement instructions.' ;
    rdfs:domain ind:CustodianAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:custodianContactName rdf:type rdf:Property ;
    rdfs:label 'Custodian Contact Name' ;
    rdfs:comment 'Name of the primary relationship manager or operations contact at the custodian institution for this account.' ;
    rdfs:domain ind:CustodianAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:custodianContactPhone rdf:type rdf:Property ;
    rdfs:label 'Custodian Contact Phone' ;
    rdfs:comment 'Phone number of the primary custodian contact for urgent operational matters and settlement issues.' ;
    rdfs:domain ind:CustodianAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marginLendingEnabled rdf:type rdf:Property ;
    rdfs:label 'Margin Lending Enabled' ;
    rdfs:comment 'Boolean flag indicating whether this custodian account supports margin lending and leveraged positions.' ;
    rdfs:domain ind:CustodianAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryReportingJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Jurisdiction' ;
    rdfs:comment 'Three-letter ISO country code indicating the primary regulatory jurisdiction for reporting requirements applicable to this custodian account (e.g., USA for SEC, GBR for FCA).' ;
    rdfs:domain ind:CustodianAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securitiesLendingEnabled rdf:type rdf:Property ;
    rdfs:label 'Securities Lending Enabled' ;
    rdfs:comment 'Boolean flag indicating whether securities held in this custodian account are eligible for securities lending programs to generate additional revenue.' ;
    rdfs:domain ind:CustodianAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:segregationRequirement rdf:type rdf:Property ;
    rdfs:label 'Segregation Requirement' ;
    rdfs:comment 'Regulatory or contractual requirement for asset segregation: client_segregated (individual client assets held separately per CASS/SEC 15c3-3), pooled (omnibus account), or partially_segregated (hybrid model).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementInstructionMethod rdf:type rdf:Property ;
    rdfs:label 'Settlement Instruction Method' ;
    rdfs:comment 'The primary method used to transmit settlement instructions to the custodian: SWIFT messaging, fax, electronic portal, API integration, or manual delivery.' ;
    rdfs:domain ind:CustodianAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subCustodianAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Sub Custodian Account Number' ;
    rdfs:comment 'The account number at the sub-custodian institution, if applicable. Used for tracking the full custody chain and reconciliation across multiple custodian layers.' ;
    rdfs:domain ind:CustodianAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estatePlanId rdf:type rdf:Property ;
    rdfs:label 'Estate Plan Id' ;
    rdfs:comment 'Unique identifier for the estate plan record. Primary key.' ;
    rdfs:domain ind:EstatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:executionBranchId rdf:type rdf:Property ;
    rdfs:label 'Execution Branch Id' ;
    rdfs:comment 'Foreign key linking to channel.branch. Business justification: Estate plans often executed at specific branch with notary, witnesses, and legal counsel present. Required for legal documentation validity, jurisdiction compliance (state-specific estate law), docume' ;
    rdfs:domain ind:EstatePlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Branch .

ind:primaryJurisdictionCountryId rdf:type rdf:Property ;
    rdfs:label 'Primary Jurisdiction Country Id' ;
    rdfs:comment 'Foreign key linking to reference.country. Business justification: Estate plans are subject to jurisdiction-specific estate tax and probate law. Estate tax calculation, asset distribution strategy, and legal document preparation require country reference.' ;
    rdfs:domain ind:EstatePlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:alternateExecutorName rdf:type rdf:Property ;
    rdfs:label 'Alternate Executor Name' ;
    rdfs:comment 'Full name of the alternate executor if the primary executor is unable to serve.' ;
    rdfs:domain ind:EstatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessSuccessionFlag rdf:type rdf:Property ;
    rdfs:label 'Business Succession Flag' ;
    rdfs:comment 'Indicates whether the estate plan includes business succession planning provisions.' ;
    rdfs:domain ind:EstatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:charitableBeneficiaryCount rdf:type rdf:Property ;
    rdfs:label 'Charitable Beneficiary Count' ;
    rdfs:comment 'Number of charitable organizations designated as beneficiaries in the estate plan.' ;
    rdfs:domain ind:EstatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:charitableGivingFlag rdf:type rdf:Property ;
    rdfs:label 'Charitable Giving Flag' ;
    rdfs:comment 'Indicates whether the estate plan includes charitable giving provisions.' ;
    rdfs:domain ind:EstatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contingentBeneficiaryCount rdf:type rdf:Property ;
    rdfs:label 'Contingent Beneficiary Count' ;
    rdfs:comment 'Number of contingent beneficiaries designated in the estate plan.' ;
    rdfs:domain ind:EstatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estateCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Estate Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for estate valuation.' ;
    rdfs:domain ind:EstatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedEstateTaxLiability rdf:type rdf:Property ;
    rdfs:label 'Estimated Estate Tax Liability' ;
    rdfs:comment 'Estimated estate tax liability based on current estate value and applicable tax laws.' ;
    rdfs:domain ind:EstatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:executorName rdf:type rdf:Property ;
    rdfs:label 'Executor Name' ;
    rdfs:comment 'Full name of the primary executor designated to administer the estate.' ;
    rdfs:domain ind:EstatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guardianName rdf:type rdf:Property ;
    rdfs:label 'Guardian Name' ;
    rdfs:comment 'Full name of the individual designated as guardian for minor children or dependents.' ;
    rdfs:domain ind:EstatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guardianshipDesignationFlag rdf:type rdf:Property ;
    rdfs:label 'Guardianship Designation Flag' ;
    rdfs:comment 'Indicates whether the estate plan includes guardianship designations for minor children or dependents.' ;
    rdfs:domain ind:EstatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:healthcareProxyName rdf:type rdf:Property ;
    rdfs:label 'Healthcare Proxy Name' ;
    rdfs:comment 'Full name of the individual designated to make healthcare decisions on behalf of the client.' ;
    rdfs:domain ind:EstatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lifeInsuranceCoverageAmount rdf:type rdf:Property ;
    rdfs:label 'Life Insurance Coverage Amount' ;
    rdfs:comment 'Total life insurance coverage amount designated for estate liquidity and beneficiary support.' ;
    rdfs:domain ind:EstatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:livingWillFlag rdf:type rdf:Property ;
    rdfs:label 'Living Will Flag' ;
    rdfs:comment 'Indicates whether a living will or advance healthcare directive is included in the estate plan.' ;
    rdfs:domain ind:EstatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:planNumber rdf:type rdf:Property ;
    rdfs:label 'Plan Number' ;
    rdfs:comment 'Business identifier for the estate plan, used for external reference and client communication.' ;
    rdfs:domain ind:EstatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:powerOfAttorneyHolder rdf:type rdf:Property ;
    rdfs:label 'Power Of Attorney Holder' ;
    rdfs:comment 'Full name of the individual designated to hold power of attorney.' ;
    rdfs:domain ind:EstatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:powerOfAttorneyType rdf:type rdf:Property ;
    rdfs:label 'Power Of Attorney Type' ;
    rdfs:comment 'Type of power of attorney designation included in the estate plan.' ;
    rdfs:domain ind:EstatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryBeneficiaryCount rdf:type rdf:Property ;
    rdfs:label 'Primary Beneficiary Count' ;
    rdfs:comment 'Number of primary beneficiaries designated in the estate plan.' ;
    rdfs:domain ind:EstatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Primary Jurisdiction' ;
    rdfs:comment 'Primary legal jurisdiction governing the estate plan, using ISO 3166-1 alpha-3 country code.' ;
    rdfs:domain ind:EstatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Secondary Jurisdiction' ;
    rdfs:comment 'Secondary legal jurisdiction if the estate spans multiple countries, using ISO 3166-1 alpha-3 country code.' ;
    rdfs:domain ind:EstatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxMinimizationStrategy rdf:type rdf:Property ;
    rdfs:label 'Tax Minimization Strategy' ;
    rdfs:comment 'Description of the tax minimization strategies employed in the estate plan.' ;
    rdfs:domain ind:EstatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalEstateValue rdf:type rdf:Property ;
    rdfs:label 'Total Estate Value' ;
    rdfs:comment 'Total estimated value of the client\'s estate covered by this plan.' ;
    rdfs:domain ind:EstatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trustDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Trust Document Reference' ;
    rdfs:comment 'Reference identifier or location of the trust agreement document.' ;
    rdfs:domain ind:EstatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trustStructureType rdf:type rdf:Property ;
    rdfs:label 'Trust Structure Type' ;
    rdfs:comment 'Type of trust structure incorporated into the estate plan, if any.' ;
    rdfs:domain ind:EstatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:willDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Will Document Reference' ;
    rdfs:comment 'Reference identifier or location of the last will and testament document.' ;
    rdfs:domain ind:EstatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:willExecutionDate rdf:type rdf:Property ;
    rdfs:label 'Will Execution Date' ;
    rdfs:comment 'Date when the will was executed and signed by the client.' ;
    rdfs:domain ind:EstatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:feeBillingId rdf:type rdf:Property ;
    rdfs:label 'Fee Billing Id' ;
    rdfs:comment 'Unique identifier for the fee billing record. Primary key for the fee billing entity.' ;
    rdfs:domain ind:FeeBilling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billingChannelId rdf:type rdf:Property ;
    rdfs:label 'Billing Channel Id' ;
    rdfs:comment 'Foreign key linking to channel.channel. Business justification: Fee invoices delivered through client-preferred channels (email, postal mail, digital portal). Required for client preference fulfillment, delivery confirmation tracking, dispute resolution (proof of ' ;
    rdfs:domain ind:FeeBilling ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:paymentDepositAccountId rdf:type rdf:Property ;
    rdfs:label 'Payment Deposit Account Id' ;
    rdfs:comment 'Foreign key linking to account.deposit_account. Business justification: Fee billing invoices are settled via deposit account debits. Essential for fee collection automation, payment reconciliation, and accounts receivable management in wealth management operations.' ;
    rdfs:domain ind:FeeBilling ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DepositAccount .

ind:aumBasisAmount rdf:type rdf:Property ;
    rdfs:label 'Aum Basis Amount' ;
    rdfs:comment 'The total value of assets under management used as the basis for fee calculation. This is the NAV of the portfolio at the measurement point defined by the fee calculation method.' ;
    rdfs:domain ind:Wealth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingStatus rdf:type rdf:Property ;
    rdfs:label 'Billing Status' ;
    rdfs:comment 'The current lifecycle status of the fee billing record. Draft indicates calculation in progress, pending approval requires management review, approved is ready for invoicing, invoiced means invoice has been generated, paid indicates client payment received, disputed indicates client challenge, waived means fee was forgiven, and reversed indicates the billing was cancelled and reversed. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|invoiced|paid|disputed|waived|reversed — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Wealth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeDiscountAmount rdf:type rdf:Property ;
    rdfs:label 'Fee Discount Amount' ;
    rdfs:comment 'Any discount or reduction applied to the gross fee amount. May result from promotional offers, relationship pricing, fee waivers for underperformance, or negotiated concessions for high-net-worth clients.' ;
    rdfs:domain ind:FeeBilling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Fee Amount' ;
    rdfs:comment 'The total fee amount calculated before any adjustments, discounts, or tax withholding. Calculated as AUM basis amount multiplied by the applied fee rate (prorated if necessary).' ;
    rdfs:domain ind:Wealth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxWithholdingAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Withholding Amount' ;
    rdfs:comment 'The amount of tax withheld from the fee, if applicable. Certain jurisdictions require withholding tax on investment management fees, particularly for non-resident clients or cross-border advisory services.' ;
    rdfs:domain ind:Wealth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvalChannelId rdf:type rdf:Property ;
    rdfs:label 'Approval Channel Id' ;
    rdfs:comment 'Foreign key linking to channel.channel. Business justification: IPS documents require formal approval through specific channels (branch meeting, digital signature, video conference). Essential for MiFID II/Reg BI compliance audit trail, client consent documentatio' ;
    rdfs:domain ind:Wealth ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:riskToleranceCodeListId rdf:type rdf:Property ;
    rdfs:label 'Risk Tolerance Code List Id' ;
    rdfs:comment 'Foreign key linking to reference.code_list. Business justification: Risk tolerance uses standardized scale (conservative, moderate, aggressive) for suitability. Asset allocation decisions, model portfolio assignment, and IPS compliance require code list reference.' ;
    rdfs:domain ind:InvestmentPolicyStatement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CodeList .

ind:annualWithdrawalAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Withdrawal Amount' ;
    rdfs:comment 'Expected annual withdrawal amount from the portfolio to meet client spending needs.' ;
    rdfs:domain ind:InvestmentPolicyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:esgExclusions rdf:type rdf:Property ;
    rdfs:label 'Esg Exclusions' ;
    rdfs:comment 'List of industries, sectors, or activities excluded from the portfolio based on ESG criteria (e.g., tobacco, firearms, fossil fuels).' ;
    rdfs:domain ind:InvestmentPolicyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esgPreference rdf:type rdf:Property ;
    rdfs:label 'Esg Preference' ;
    rdfs:comment 'Client\'s preference for ESG integration: none (no ESG consideration), basic (ESG screening), advanced (ESG integration), or impact_focused (mission-driven investing).' ;
    rdfs:domain ind:InvestmentPolicyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeStructure rdf:type rdf:Property ;
    rdfs:label 'Fee Structure' ;
    rdfs:comment 'Type of fee arrangement: AUM-based (percentage of assets under management), flat fee, performance-based, or hybrid.' ;
    rdfs:domain ind:InvestmentPolicyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipsNumber rdf:type rdf:Property ;
    rdfs:label 'Ips Number' ;
    rdfs:comment 'Business identifier for the IPS document, used for external reference and client communication.' ;
    rdfs:domain ind:InvestmentPolicyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipsStatus rdf:type rdf:Property ;
    rdfs:label 'Ips Status' ;
    rdfs:comment 'Current lifecycle status of the IPS document. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|active|suspended|terminated|superseded — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InvestmentPolicyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipsType rdf:type rdf:Property ;
    rdfs:label 'Ips Type' ;
    rdfs:comment 'Classification of the IPS lifecycle stage: proposal (pre-acceptance), approved_ips (client-accepted mandate), or amended_ips (revised mandate).' ;
    rdfs:domain ind:InvestmentPolicyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipsVersion rdf:type rdf:Property ;
    rdfs:label 'Ips Version' ;
    rdfs:comment 'Version number of the IPS document, incremented with each amendment or restatement.' ;
    rdfs:domain ind:InvestmentPolicyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:liquidityRequirementDescription rdf:type rdf:Property ;
    rdfs:label 'Liquidity Requirement Description' ;
    rdfs:comment 'Narrative description of the client\'s liquidity needs, including anticipated withdrawals, emergency reserves, and cash flow requirements.' ;
    rdfs:domain ind:InvestmentPolicyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managementFeePct rdf:type rdf:Property ;
    rdfs:label 'Management Fee Pct' ;
    rdfs:comment 'Annual management fee as a percentage of AUM, expressed as a decimal (e.g., 1.00 for 1%).' ;
    rdfs:domain ind:Wealth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceFeePct rdf:type rdf:Property ;
    rdfs:label 'Performance Fee Pct' ;
    rdfs:comment 'Performance-based fee as a percentage of returns above a hurdle rate, expressed as a decimal (e.g., 20.00 for 20%).' ;
    rdfs:domain ind:Wealth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prohibitedSecurities rdf:type rdf:Property ;
    rdfs:label 'Prohibited Securities' ;
    rdfs:comment 'Specific securities, issuers, or asset types explicitly prohibited by the client (e.g., employer stock, specific countries, derivatives).' ;
    rdfs:domain ind:InvestmentPolicyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposalDate rdf:type rdf:Property ;
    rdfs:label 'Proposal Date' ;
    rdfs:comment 'Date the initial investment proposal was presented to the client.' ;
    rdfs:domain ind:Wealth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rebalancingTriggerPct rdf:type rdf:Property ;
    rdfs:label 'Rebalancing Trigger Pct' ;
    rdfs:comment 'Percentage deviation from target asset allocation that triggers a portfolio rebalancing action, expressed as a decimal (e.g., 5.00 for 5%).' ;
    rdfs:domain ind:InvestmentPolicyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryRestrictions rdf:type rdf:Property ;
    rdfs:label 'Regulatory Restrictions' ;
    rdfs:comment 'Regulatory or legal constraints applicable to the portfolio, including ERISA fiduciary rules, UCITS limits, or jurisdiction-specific investment restrictions.' ;
    rdfs:domain ind:InvestmentPolicyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnObjectiveDescription rdf:type rdf:Property ;
    rdfs:label 'Return Objective Description' ;
    rdfs:comment 'Narrative description of the client\'s return expectations, including target return rates, benchmarks, and time horizon considerations.' ;
    rdfs:domain ind:InvestmentPolicyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskCapacity rdf:type rdf:Property ;
    rdfs:label 'Risk Capacity' ;
    rdfs:comment 'Client\'s financial ability to absorb investment losses without materially impacting their financial goals.' ;
    rdfs:domain ind:InvestmentPolicyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskTolerance rdf:type rdf:Property ;
    rdfs:label 'Risk Tolerance' ;
    rdfs:comment 'Client\'s stated risk tolerance level, ranging from conservative to aggressive.' ;
    rdfs:domain ind:InvestmentPolicyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sectorExclusions rdf:type rdf:Property ;
    rdfs:label 'Sector Exclusions' ;
    rdfs:comment 'List of economic sectors excluded from the portfolio per client mandate (e.g., financials, energy, healthcare).' ;
    rdfs:domain ind:InvestmentPolicyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suitabilityAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Suitability Assessment Date' ;
    rdfs:comment 'Date the most recent suitability assessment was completed to ensure the IPS aligns with client circumstances and objectives.' ;
    rdfs:domain ind:InvestmentPolicyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:suitabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Suitability Status' ;
    rdfs:comment 'Current suitability determination: suitable (IPS aligns with client profile), review_required (circumstances changed), or unsuitable (IPS no longer appropriate).' ;
    rdfs:domain ind:InvestmentPolicyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetAnnualReturnPct rdf:type rdf:Property ;
    rdfs:label 'Target Annual Return Pct' ;
    rdfs:comment 'Target annualized return percentage specified in the IPS, expressed as a decimal (e.g., 7.50 for 7.5%).' ;
    rdfs:domain ind:Wealth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxConsiderations rdf:type rdf:Property ;
    rdfs:label 'Tax Considerations' ;
    rdfs:comment 'Narrative description of tax-related constraints and preferences, including capital gains management, tax-loss harvesting, and jurisdiction-specific tax rules.' ;
    rdfs:domain ind:InvestmentPolicyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxStatus rdf:type rdf:Property ;
    rdfs:label 'Tax Status' ;
    rdfs:comment 'Tax treatment of the portfolio: taxable, tax-deferred (e.g., IRA, 401k), or tax-exempt (e.g., municipal bonds).' ;
    rdfs:domain ind:Wealth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeHorizonYears rdf:type rdf:Property ;
    rdfs:label 'Time Horizon Years' ;
    rdfs:comment 'Investment time horizon in years, representing the period until the client expects to draw down the portfolio.' ;
    rdfs:domain ind:Wealth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:alternativeAllocationPct rdf:type rdf:Property ;
    rdfs:label 'Alternative Allocation Pct' ;
    rdfs:comment 'Recommended percentage allocation to alternative investments (hedge funds, private equity, real estate, commodities) in the proposed portfolio.' ;
    rdfs:domain ind:InvestmentProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseCaseReturnPct rdf:type rdf:Property ;
    rdfs:label 'Base Case Return Pct' ;
    rdfs:comment 'Expected return percentage under the base case scenario, representing the most likely outcome.' ;
    rdfs:domain ind:InvestmentProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cashAllocationPct rdf:type rdf:Property ;
    rdfs:label 'Cash Allocation Pct' ;
    rdfs:comment 'Recommended percentage allocation to cash and cash equivalents in the proposed portfolio.' ;
    rdfs:domain ind:InvestmentProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:equityAllocationPct rdf:type rdf:Property ;
    rdfs:label 'Equity Allocation Pct' ;
    rdfs:comment 'Recommended percentage allocation to equity asset class in the proposed portfolio.' ;
    rdfs:domain ind:InvestmentProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:esgCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Esg Compliant Flag' ;
    rdfs:comment 'Indicates whether the proposed portfolio adheres to environmental, social, and governance investment criteria.' ;
    rdfs:domain ind:Wealth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:feeStructureDescription rdf:type rdf:Property ;
    rdfs:label 'Fee Structure Description' ;
    rdfs:comment 'Detailed description of the fee structure, including management fees, performance fees, transaction costs, and any other charges.' ;
    rdfs:domain ind:InvestmentProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fixedIncomeAllocationPct rdf:type rdf:Property ;
    rdfs:label 'Fixed Income Allocation Pct' ;
    rdfs:comment 'Recommended percentage allocation to fixed income asset class in the proposed portfolio.' ;
    rdfs:domain ind:InvestmentProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxDrawdownPct rdf:type rdf:Property ;
    rdfs:label 'Max Drawdown Pct' ;
    rdfs:comment 'Projected maximum peak-to-trough decline percentage for the proposed portfolio under stress scenarios.' ;
    rdfs:domain ind:InvestmentProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:optimisticReturnPct rdf:type rdf:Property ;
    rdfs:label 'Optimistic Return Pct' ;
    rdfs:comment 'Projected return percentage under an optimistic market scenario.' ;
    rdfs:domain ind:InvestmentProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otherAllocationPct rdf:type rdf:Property ;
    rdfs:label 'Other Allocation Pct' ;
    rdfs:comment 'Recommended percentage allocation to other asset classes not categorized above.' ;
    rdfs:domain ind:InvestmentProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pessimisticReturnPct rdf:type rdf:Property ;
    rdfs:label 'Pessimistic Return Pct' ;
    rdfs:comment 'Projected return percentage under a pessimistic market scenario.' ;
    rdfs:domain ind:InvestmentProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proposalName rdf:type rdf:Property ;
    rdfs:label 'Proposal Name' ;
    rdfs:comment 'Descriptive name or title of the investment proposal, summarizing the strategy or objective.' ;
    rdfs:domain ind:InvestmentProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposalNumber rdf:type rdf:Property ;
    rdfs:label 'Proposal Number' ;
    rdfs:comment 'Business-facing unique identifier for the investment proposal, used in client communications and documentation.' ;
    rdfs:domain ind:InvestmentProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposalStatus rdf:type rdf:Property ;
    rdfs:label 'Proposal Status' ;
    rdfs:comment 'Current lifecycle status of the investment proposal: draft, pending review, presented, accepted, rejected, expired, or withdrawn. [ENUM-REF-CANDIDATE: draft|pending_review|presented|accepted|rejected|expired|withdrawn — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InvestmentProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposalType rdf:type rdf:Property ;
    rdfs:label 'Proposal Type' ;
    rdfs:comment 'Classification of the proposal purpose: new mandate, portfolio restructuring, asset allocation change, strategy change, rebalancing, or other.' ;
    rdfs:domain ind:InvestmentProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposedAumAmount rdf:type rdf:Property ;
    rdfs:label 'Proposed Aum Amount' ;
    rdfs:comment 'Total assets under management amount proposed for the mandate or portfolio restructuring, in base currency.' ;
    rdfs:domain ind:InvestmentProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proposedStrategy rdf:type rdf:Property ;
    rdfs:label 'Proposed Strategy' ;
    rdfs:comment 'Description of the investment strategy recommended in the proposal, including asset classes, risk approach, and investment philosophy.' ;
    rdfs:domain ind:InvestmentProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shariahCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Shariah Compliant Flag' ;
    rdfs:comment 'Indicates whether the proposed portfolio adheres to Islamic finance principles and Shariah law.' ;
    rdfs:domain ind:Wealth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:var95Pct rdf:type rdf:Property ;
    rdfs:label 'Var 95 Pct' ;
    rdfs:comment 'Value at Risk at 95% confidence level, representing the maximum expected loss over a specified time period under normal market conditions.' ;
    rdfs:domain ind:InvestmentProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryChannelId rdf:type rdf:Property ;
    rdfs:label 'Primary Channel Id' ;
    rdfs:comment 'Foreign key linking to channel.channel. Business justification: Portfolios are serviced through primary channels (digital platform, branch, private banking). Required for channel preference tracking, service delivery routing, regulatory channel-of-record documenta' ;
    rdfs:domain ind:ManagedPortfolio ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:revenueGlAccountId rdf:type rdf:Property ;
    rdfs:label 'Revenue Gl Account Id' ;
    rdfs:comment 'Foreign key linking to ledger.gl_account. Business justification: Portfolios generate management and performance fee revenue that must post to specific GL revenue accounts for P&L reporting and revenue recognition. Banking operations require mapping each portfolio\'s' ;
    rdfs:domain ind:Wealth ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:statusCodeListId rdf:type rdf:Property ;
    rdfs:label 'Status Code List Id' ;
    rdfs:comment 'Foreign key linking to reference.code_list. Business justification: Portfolio status uses standardized codes (active, closed, suspended) for operational workflow. Portfolio administration, fee billing, and reporting require code list reference for status management.' ;
    rdfs:domain ind:ManagedPortfolio ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CodeList .

ind:treasuryInvestmentPortfolioId rdf:type rdf:Property ;
    rdfs:label 'Treasury Investment Portfolio Id' ;
    rdfs:comment 'Foreign key linking to treasury.investment_portfolio. Business justification: Wealth portfolios allocate client assets into treasury-managed fixed income portfolios (government bonds, corporate bonds) for capital preservation and liquidity management. Required for consolidated ' ;
    rdfs:domain ind:Wealth ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InvestmentPortfolio .

ind:aumAmount rdf:type rdf:Property ;
    rdfs:label 'Aum Amount' ;
    rdfs:comment 'Total market value of assets under management in the portfolio, expressed in the base currency. Updated daily based on market valuations.' ;
    rdfs:domain ind:Wealth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:derivativesAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Derivatives Allowed Flag' ;
    rdfs:comment 'Indicates whether the portfolio is permitted to invest in derivative instruments (options, futures, swaps).' ;
    rdfs:domain ind:ManagedPortfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:highWaterMark rdf:type rdf:Property ;
    rdfs:label 'High Water Mark' ;
    rdfs:comment 'Highest Net Asset Value (NAV) level reached by the portfolio, used to calculate performance fees. Ensures performance fees are only charged on new gains.' ;
    rdfs:domain ind:Wealth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:investmentHorizon rdf:type rdf:Property ;
    rdfs:label 'Investment Horizon' ;
    rdfs:comment 'Expected time horizon for the investment: short-term (< 3 years), medium-term (3-10 years), long-term (> 10 years), or perpetual.' ;
    rdfs:domain ind:ManagedPortfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leverageAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Leverage Allowed Flag' ;
    rdfs:comment 'Indicates whether the portfolio is permitted to use leverage or borrowed funds to amplify investment positions.' ;
    rdfs:domain ind:ManagedPortfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:managedPortfolioStatus rdf:type rdf:Property ;
    rdfs:label 'Managed Portfolio Status' ;
    rdfs:comment 'Current lifecycle status of the managed portfolio.' ;
    rdfs:domain ind:ManagedPortfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextRebalanceDate rdf:type rdf:Property ;
    rdfs:label 'Next Rebalance Date' ;
    rdfs:comment 'Scheduled date for the next portfolio rebalancing review.' ;
    rdfs:domain ind:ManagedPortfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:portfolioNumber rdf:type rdf:Property ;
    rdfs:label 'Portfolio Number' ;
    rdfs:comment 'Externally-known unique business identifier for the portfolio, used in client communications and regulatory reporting.' ;
    rdfs:domain ind:ManagedPortfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portfolioStrategy rdf:type rdf:Property ;
    rdfs:label 'Portfolio Strategy' ;
    rdfs:comment 'High-level investment strategy or approach for the portfolio (e.g., growth, income, balanced, capital preservation, ESG-focused).' ;
    rdfs:domain ind:ManagedPortfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investmentCommitteeId rdf:type rdf:Property ;
    rdfs:label 'Investment Committee Id' ;
    rdfs:comment 'Reference to the investment committee responsible for approving and overseeing this model portfolio.' ;
    rdfs:domain ind:Wealth ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InvestmentCommittee .

ind:investmentObjectiveCodeListId rdf:type rdf:Property ;
    rdfs:label 'Investment Objective Code List Id' ;
    rdfs:comment 'Foreign key linking to reference.code_list. Business justification: Investment objectives use standardized codes (growth, income, balanced) for client segmentation. Suitability matching, model portfolio selection, and marketing materials require code list reference.' ;
    rdfs:domain ind:ModelPortfolio ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CodeList .

ind:primaryModelEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Model Employee Id' ;
    rdfs:comment 'Reference to the lead portfolio manager responsible for maintaining and updating the model portfolio allocation.' ;
    rdfs:domain ind:ModelPortfolio ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:activeClientCount rdf:type rdf:Property ;
    rdfs:label 'Active Client Count' ;
    rdfs:comment 'Current number of client accounts assigned to this model portfolio, used for capacity monitoring and performance reporting.' ;
    rdfs:domain ind:ModelPortfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:investmentPolicyStatementUrl rdf:type rdf:Property ;
    rdfs:label 'Investment Policy Statement Url' ;
    rdfs:comment 'URL reference to the formal Investment Policy Statement document governing this model portfolio construction and management.' ;
    rdfs:domain ind:ModelPortfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelPortfolioDescription rdf:type rdf:Property ;
    rdfs:label 'Model Portfolio Description' ;
    rdfs:comment 'Comprehensive business description of the model portfolio including investment philosophy, target outcomes, and key differentiators for client communication.' ;
    rdfs:domain ind:ModelPortfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rebalancingThresholdPercent rdf:type rdf:Property ;
    rdfs:label 'Rebalancing Threshold Percent' ;
    rdfs:comment 'Percentage drift threshold from target allocation that triggers a rebalancing event for any asset class within the model portfolio.' ;
    rdfs:domain ind:ModelPortfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:strategicAllocationFlag rdf:type rdf:Property ;
    rdfs:label 'Strategic Allocation Flag' ;
    rdfs:comment 'Indicates whether this model portfolio uses strategic (long-term) asset allocation. True if strategic, False if tactical or dynamic allocation is primary.' ;
    rdfs:domain ind:ModelPortfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:suitabilityCriteria rdf:type rdf:Property ;
    rdfs:label 'Suitability Criteria' ;
    rdfs:comment 'Detailed description of client suitability requirements including risk tolerance, investment horizon, liquidity needs, and regulatory constraints.' ;
    rdfs:domain ind:ModelPortfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tacticalAllocationFlag rdf:type rdf:Property ;
    rdfs:label 'Tactical Allocation Flag' ;
    rdfs:comment 'Indicates whether this model portfolio incorporates tactical (short-term) asset allocation overlays to capitalize on market opportunities.' ;
    rdfs:domain ind:ModelPortfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetClientSegment rdf:type rdf:Property ;
    rdfs:label 'Target Client Segment' ;
    rdfs:comment 'Primary client segment or wealth tier for which this model portfolio is designed, such as high-net-worth, ultra-high-net-worth, mass affluent, or institutional.' ;
    rdfs:domain ind:ModelPortfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxOptimizationStrategy rdf:type rdf:Property ;
    rdfs:label 'Tax Optimization Strategy' ;
    rdfs:comment 'Primary tax optimization approach employed in the model portfolio construction and rebalancing to minimize client tax liability.' ;
    rdfs:domain ind:ModelPortfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalAum rdf:type rdf:Property ;
    rdfs:label 'Total Aum' ;
    rdfs:comment 'Current total assets under management across all client accounts using this model portfolio, reported in base currency.' ;
    rdfs:domain ind:ModelPortfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:navCalculationId rdf:type rdf:Property ;
    rdfs:label 'Nav Calculation Id' ;
    rdfs:comment 'Unique identifier for the NAV calculation record. Primary key for this entity.' ;
    rdfs:domain ind:NavCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryNavEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Nav Employee Id' ;
    rdfs:comment 'Identifier of the user or system process that executed the NAV calculation.' ;
    rdfs:domain ind:NavCalculation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:dividendIncome rdf:type rdf:Property ;
    rdfs:label 'Dividend Income' ;
    rdfs:comment 'Total dividend income received or accrued during the period ending on the valuation date.' ;
    rdfs:domain ind:NavCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expenseRatio rdf:type rdf:Property ;
    rdfs:label 'Expense Ratio' ;
    rdfs:comment 'Total expenses expressed as a percentage of average net assets, typically annualized. A key metric for fund cost transparency.' ;
    rdfs:domain ind:NavCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interestIncome rdf:type rdf:Property ;
    rdfs:label 'Interest Income' ;
    rdfs:comment 'Total interest income received or accrued from fixed-income securities and cash holdings during the period ending on the valuation date.' ;
    rdfs:domain ind:NavCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:navChangePercent rdf:type rdf:Property ;
    rdfs:label 'Nav Change Percent' ;
    rdfs:comment 'Percentage change in NAV from the prior valuation date, expressed as a decimal (e.g., 0.0250 for 2.5%).' ;
    rdfs:domain ind:NavCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netCashFlow rdf:type rdf:Property ;
    rdfs:label 'Net Cash Flow' ;
    rdfs:comment 'Net cash flow into or out of the fund, calculated as subscriptions minus redemptions.' ;
    rdfs:domain ind:Wealth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorNav rdf:type rdf:Property ;
    rdfs:label 'Prior Nav' ;
    rdfs:comment 'The NAV from the previous valuation date, used for period-over-period performance calculation and reconciliation.' ;
    rdfs:domain ind:NavCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:redemptionsAmount rdf:type rdf:Property ;
    rdfs:label 'Redemptions Amount' ;
    rdfs:comment 'Total value of investor redemptions (capital outflows) processed on or before the valuation date.' ;
    rdfs:domain ind:NavCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:subscriptionsAmount rdf:type rdf:Property ;
    rdfs:label 'Subscriptions Amount' ;
    rdfs:comment 'Total value of new investor subscriptions (capital inflows) processed on or before the valuation date.' ;
    rdfs:domain ind:NavCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:swingFactorApplied rdf:type rdf:Property ;
    rdfs:label 'Swing Factor Applied' ;
    rdfs:comment 'The swing pricing adjustment factor applied to the NAV to protect existing investors from dilution caused by large subscriptions or redemptions.' ;
    rdfs:domain ind:NavCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalExpenses rdf:type rdf:Property ;
    rdfs:label 'Total Expenses' ;
    rdfs:comment 'Sum of all operating expenses, management fees, performance fees, custody fees, and other costs incurred during the period ending on the valuation date.' ;
    rdfs:domain ind:NavCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceReason rdf:type rdf:Property ;
    rdfs:label 'Variance Reason' ;
    rdfs:comment 'Explanation of any material variance identified during NAV reconciliation, including root cause and resolution plan.' ;
    rdfs:domain ind:NavCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceReturnId rdf:type rdf:Property ;
    rdfs:label 'Performance Return Id' ;
    rdfs:comment 'Unique identifier for the performance return calculation record.' ;
    rdfs:domain ind:PerformanceReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:activeReturn rdf:type rdf:Property ;
    rdfs:label 'Active Return' ;
    rdfs:comment 'The difference between the portfolio gross return and the benchmark return, representing the value added by active management (alpha).' ;
    rdfs:domain ind:PerformanceReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annualizedReturn rdf:type rdf:Property ;
    rdfs:label 'Annualized Return' ;
    rdfs:comment 'The geometric average return expressed as an annual rate, standardizing returns across different time periods.' ;
    rdfs:domain ind:PerformanceReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annualizedVolatility rdf:type rdf:Property ;
    rdfs:label 'Annualized Volatility' ;
    rdfs:comment 'The annualized standard deviation of portfolio returns, measuring total risk.' ;
    rdfs:domain ind:PerformanceReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:attributionAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Attribution Available Flag' ;
    rdfs:comment 'Indicates whether detailed performance attribution analysis is available for this return calculation.' ;
    rdfs:domain ind:PerformanceReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:beginningMarketValue rdf:type rdf:Property ;
    rdfs:label 'Beginning Market Value' ;
    rdfs:comment 'The total market value of the portfolio at the start of the measurement period.' ;
    rdfs:domain ind:PerformanceReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:benchmarkReturn rdf:type rdf:Property ;
    rdfs:label 'Benchmark Return' ;
    rdfs:comment 'The return of the designated benchmark index over the same measurement period.' ;
    rdfs:domain ind:PerformanceReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calculatedBy rdf:type rdf:Property ;
    rdfs:label 'Calculated By' ;
    rdfs:comment 'The system user or automated process that performed the performance calculation.' ;
    rdfs:domain ind:PerformanceReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compositeMemberFlag rdf:type rdf:Property ;
    rdfs:label 'Composite Member Flag' ;
    rdfs:comment 'Indicates whether this portfolio is included as a member of a GIPS composite during this measurement period.' ;
    rdfs:domain ind:PerformanceReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:downsideDeviation rdf:type rdf:Property ;
    rdfs:label 'Downside Deviation' ;
    rdfs:comment 'The standard deviation of negative returns only, used in Sortino ratio calculation.' ;
    rdfs:domain ind:PerformanceReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:endingMarketValue rdf:type rdf:Property ;
    rdfs:label 'Ending Market Value' ;
    rdfs:comment 'The total market value of the portfolio at the end of the measurement period.' ;
    rdfs:domain ind:PerformanceReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incomeEarned rdf:type rdf:Property ;
    rdfs:label 'Income Earned' ;
    rdfs:comment 'The total income (dividends, interest, coupons) earned by the portfolio during the measurement period.' ;
    rdfs:domain ind:PerformanceReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:managementFees rdf:type rdf:Property ;
    rdfs:label 'Management Fees' ;
    rdfs:comment 'The investment management fees charged during the measurement period, used to calculate net-of-fee returns.' ;
    rdfs:domain ind:PerformanceReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumDrawdown rdf:type rdf:Property ;
    rdfs:label 'Maximum Drawdown' ;
    rdfs:comment 'The largest peak-to-trough decline in portfolio value during the measurement period, expressed as a percentage.' ;
    rdfs:domain ind:PerformanceReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mwrReturn rdf:type rdf:Property ;
    rdfs:label 'Mwr Return' ;
    rdfs:comment 'Money-weighted rate of return (also known as Internal Rate of Return or IRR) that accounts for the timing and magnitude of external cash flows.' ;
    rdfs:domain ind:PerformanceReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otherExpenses rdf:type rdf:Property ;
    rdfs:label 'Other Expenses' ;
    rdfs:comment 'Other portfolio expenses (custody, administration, transaction costs) incurred during the measurement period.' ;
    rdfs:domain ind:PerformanceReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:riskFreeRate rdf:type rdf:Property ;
    rdfs:label 'Risk Free Rate' ;
    rdfs:comment 'The risk-free rate of return used in risk-adjusted performance calculations (typically based on government securities).' ;
    rdfs:domain ind:PerformanceReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalContributions rdf:type rdf:Property ;
    rdfs:label 'Total Contributions' ;
    rdfs:comment 'The total amount of external contributions (deposits) made to the portfolio during the measurement period.' ;
    rdfs:domain ind:PerformanceReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalWithdrawals rdf:type rdf:Property ;
    rdfs:label 'Total Withdrawals' ;
    rdfs:comment 'The total amount of external withdrawals (distributions) made from the portfolio during the measurement period.' ;
    rdfs:domain ind:PerformanceReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trackingError rdf:type rdf:Property ;
    rdfs:label 'Tracking Error' ;
    rdfs:comment 'The standard deviation of the difference between portfolio returns and benchmark returns, measuring the consistency of active return.' ;
    rdfs:domain ind:PerformanceReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:twrGrossReturn rdf:type rdf:Property ;
    rdfs:label 'Twr Gross Return' ;
    rdfs:comment 'Time-weighted rate of return before deduction of investment management fees, calculated to eliminate the effect of external cash flows.' ;
    rdfs:domain ind:PerformanceReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:twrNetReturn rdf:type rdf:Property ;
    rdfs:label 'Twr Net Return' ;
    rdfs:comment 'Time-weighted rate of return after deduction of investment management fees and expenses.' ;
    rdfs:domain ind:PerformanceReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:portfolioCorporateActionId rdf:type rdf:Property ;
    rdfs:label 'Portfolio Corporate Action Id' ;
    rdfs:comment 'Primary key for portfolio_corporate_action' ;
    rdfs:domain ind:PortfolioCorporateAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:newSecurityInstrumentId rdf:type rdf:Property ;
    rdfs:label 'New Security Instrument Id' ;
    rdfs:comment 'Reference to the new security received as a result of the corporate action (for mergers, spin-offs, stock dividends).' ;
    rdfs:domain ind:PortfolioCorporateAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Instrument .

ind:actionRatioDenominator rdf:type rdf:Property ;
    rdfs:label 'Action Ratio Denominator' ;
    rdfs:comment 'Denominator of the corporate action ratio (e.g., for a 3-for-2 stock split, this would be 2).' ;
    rdfs:domain ind:PortfolioCorporateAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actionRatioNumerator rdf:type rdf:Property ;
    rdfs:label 'Action Ratio Numerator' ;
    rdfs:comment 'Numerator of the corporate action ratio (e.g., for a 3-for-2 stock split, this would be 3).' ;
    rdfs:domain ind:PortfolioCorporateAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cashAmountPerShare rdf:type rdf:Property ;
    rdfs:label 'Cash Amount Per Share' ;
    rdfs:comment 'Cash payment amount per share for dividend or cash distribution corporate actions.' ;
    rdfs:domain ind:PortfolioCorporateAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:corporateActionNumber rdf:type rdf:Property ;
    rdfs:label 'Corporate Action Number' ;
    rdfs:comment 'Externally-known unique identifier for the corporate action event, typically sourced from SWIFT CA messaging or custodian notification.' ;
    rdfs:domain ind:PortfolioCorporateAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:corporateActionType rdf:type rdf:Property ;
    rdfs:label 'Corporate Action Type' ;
    rdfs:comment 'Classification of the corporate action event (dividend, stock split, merger, rights issue, spin-off, tender offer, redemption, delisting). [ENUM-REF-CANDIDATE: dividend|stock_split|reverse_split|merger|acquisition|spin_off|rights_issue|tender_offer|redemption|delisting — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Wealth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:custodianReference rdf:type rdf:Property ;
    rdfs:label 'Custodian Reference' ;
    rdfs:comment 'Reference number assigned by the custodian bank for tracking the corporate action event.' ;
    rdfs:domain ind:PortfolioCorporateAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:electionDeadline rdf:type rdf:Property ;
    rdfs:label 'Election Deadline' ;
    rdfs:comment 'Timestamp by which the portfolio manager must submit their election for voluntary corporate actions.' ;
    rdfs:domain ind:PortfolioCorporateAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:electionOption rdf:type rdf:Property ;
    rdfs:label 'Election Option' ;
    rdfs:comment 'The election made by the portfolio manager for voluntary corporate actions (cash, stock, cash and stock, or no election for mandatory actions).' ;
    rdfs:domain ind:PortfolioCorporateAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:electionType rdf:type rdf:Property ;
    rdfs:label 'Election Type' ;
    rdfs:comment 'Indicates whether the corporate action is mandatory (no choice), voluntary (shareholder must elect), or mandatory with options.' ;
    rdfs:domain ind:Wealth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entitledCashAmount rdf:type rdf:Property ;
    rdfs:label 'Entitled Cash Amount' ;
    rdfs:comment 'Total cash amount the portfolio is entitled to receive as a result of the corporate action.' ;
    rdfs:domain ind:PortfolioCorporateAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:entitledShares rdf:type rdf:Property ;
    rdfs:label 'Entitled Shares' ;
    rdfs:comment 'Number of new shares the portfolio is entitled to receive as a result of the corporate action.' ;
    rdfs:domain ind:PortfolioCorporateAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holdingImpactType rdf:type rdf:Property ;
    rdfs:label 'Holding Impact Type' ;
    rdfs:comment 'Classification of how the corporate action impacts portfolio holdings (quantity change, security substitution, cash receipt, no impact).' ;
    rdfs:domain ind:PortfolioCorporateAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mandatoryVoluntaryFlag rdf:type rdf:Property ;
    rdfs:label 'Mandatory Voluntary Flag' ;
    rdfs:comment 'Boolean flag indicating whether the corporate action is mandatory (True) or voluntary (False).' ;
    rdfs:domain ind:PortfolioCorporateAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rebalancingTriggerFlag rdf:type rdf:Property ;
    rdfs:label 'Rebalancing Trigger Flag' ;
    rdfs:comment 'Boolean flag indicating whether this corporate action should trigger a portfolio rebalancing review.' ;
    rdfs:domain ind:PortfolioCorporateAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sharesHeldAtRecord rdf:type rdf:Property ;
    rdfs:label 'Shares Held At Record' ;
    rdfs:comment 'Number of shares held in the portfolio as of the record date, determining entitlement to the corporate action.' ;
    rdfs:domain ind:PortfolioCorporateAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceMessageReference rdf:type rdf:Property ;
    rdfs:label 'Source Message Reference' ;
    rdfs:comment 'Unique identifier of the source message or notification (e.g., SWIFT message reference) that communicated the corporate action.' ;
    rdfs:domain ind:PortfolioCorporateAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wealthPortfolioHoldingId rdf:type rdf:Property ;
    rdfs:label 'Wealth Portfolio Holding Id' ;
    rdfs:comment 'Unique identifier for each portfolio holding record. Primary key for the portfolio holding entity.' ;
    rdfs:domain ind:Wealth ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WealthPortfolioHolding .

ind:taxLotId rdf:type rdf:Property ;
    rdfs:label 'Tax Lot Id' ;
    rdfs:comment 'Unique identifier for the specific tax lot within the holding. Enables lot-level tracking for tax optimization strategies.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TaxLot .

ind:costBasisMethod rdf:type rdf:Property ;
    rdfs:label 'Cost Basis Method' ;
    rdfs:comment 'Accounting method used to determine which tax lots are sold first for capital gains calculation. Critical for tax-loss harvesting and capital gains optimization strategies.' ;
    rdfs:domain ind:Wealth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdingPeriodClassification rdf:type rdf:Property ;
    rdfs:label 'Holding Period Classification' ;
    rdfs:comment 'Tax classification based on holding period. Short-term applies to positions held one year or less; long-term applies to positions held more than one year. Determines capital gains tax rate.' ;
    rdfs:domain ind:Wealth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incomeType rdf:type rdf:Property ;
    rdfs:label 'Income Type' ;
    rdfs:comment 'Tax classification of income generated by the holding. Determines tax treatment and reporting requirements for client tax documents.' ;
    rdfs:domain ind:Wealth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotAcquisitionDate rdf:type rdf:Property ;
    rdfs:label 'Lot Acquisition Date' ;
    rdfs:comment 'Date when this specific tax lot was acquired. Used to determine short-term versus long-term capital gains treatment.' ;
    rdfs:domain ind:WealthPortfolioHolding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lotAcquisitionPrice rdf:type rdf:Property ;
    rdfs:label 'Lot Acquisition Price' ;
    rdfs:comment 'Per-unit purchase price for this specific tax lot including transaction costs allocated to the lot.' ;
    rdfs:domain ind:WealthPortfolioHolding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lotQuantity rdf:type rdf:Property ;
    rdfs:label 'Lot Quantity' ;
    rdfs:comment 'Number of units in this specific tax lot. Sum of all lot quantities equals the total holding quantity.' ;
    rdfs:domain ind:WealthPortfolioHolding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lotStatus rdf:type rdf:Property ;
    rdfs:label 'Lot Status' ;
    rdfs:comment 'Current lifecycle status of the tax lot indicating whether it is still held, has been sold, or affected by corporate actions.' ;
    rdfs:domain ind:Wealth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pledgedFlag rdf:type rdf:Property ;
    rdfs:label 'Pledged Flag' ;
    rdfs:comment 'Indicates whether the holding is pledged as collateral for margin loans, derivatives positions, or other obligations. Critical for available liquidity calculations.' ;
    rdfs:domain ind:WealthPortfolioHolding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:portfolioWeight rdf:type rdf:Property ;
    rdfs:label 'Portfolio Weight' ;
    rdfs:comment 'Percentage of total portfolio market value represented by this holding. Used for asset allocation analysis and rebalancing decisions.' ;
    rdfs:domain ind:Wealth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:restrictedFlag rdf:type rdf:Property ;
    rdfs:label 'Restricted Flag' ;
    rdfs:comment 'Indicates whether the holding is subject to trading restrictions such as lock-up periods, regulatory holds, or contractual limitations. Affects liquidity analysis and rebalancing decisions.' ;
    rdfs:domain ind:WealthPortfolioHolding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unitCostBasis rdf:type rdf:Property ;
    rdfs:label 'Unit Cost Basis' ;
    rdfs:comment 'Average cost per unit of the security for tax and performance calculation purposes. Calculated based on the cost basis method applied to all lots.' ;
    rdfs:domain ind:Wealth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unrealizedGainLossPercent rdf:type rdf:Property ;
    rdfs:label 'Unrealized Gain Loss Percent' ;
    rdfs:comment 'Unrealized gain or loss expressed as a percentage of total cost basis. Used for performance reporting and client communication.' ;
    rdfs:domain ind:Wealth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:washSaleFlag rdf:type rdf:Property ;
    rdfs:label 'Wash Sale Flag' ;
    rdfs:comment 'Indicates whether this holding is subject to wash sale rules, which disallow loss deductions when substantially identical securities are purchased within 30 days before or after a sale at a loss.' ;
    rdfs:domain ind:Wealth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:portfolioTransactionId rdf:type rdf:Property ;
    rdfs:label 'Portfolio Transaction Id' ;
    rdfs:comment 'Unique identifier for the portfolio transaction record.' ;
    rdfs:domain ind:Wealth ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PortfolioTransaction .

ind:executionChannelId rdf:type rdf:Property ;
    rdfs:label 'Execution Channel Id' ;
    rdfs:comment 'Foreign key linking to channel.channel. Business justification: Transactions execute through specific channels (online platform, mobile app, RM phone order, branch). Required for channel attribution reporting, differential fee calculation by channel, regulatory tr' ;
    rdfs:domain ind:PortfolioTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:rebalancingOrderId rdf:type rdf:Property ;
    rdfs:label 'Rebalancing Order Id' ;
    rdfs:comment 'Identifier of the portfolio rebalancing event that triggered this transaction, if applicable.' ;
    rdfs:domain ind:Wealth ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RebalancingOrder .

ind:settlementDepositAccountId rdf:type rdf:Property ;
    rdfs:label 'Settlement Deposit Account Id' ;
    rdfs:comment 'Foreign key linking to account.deposit_account. Business justification: Portfolio transactions settle cash legs via deposit accounts for trade execution, dividend payments, interest receipts, and fee debits. Required for trade settlement reconciliation and cash movement t' ;
    rdfs:domain ind:PortfolioTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DepositAccount .

ind:actionRatio rdf:type rdf:Property ;
    rdfs:label 'Action Ratio' ;
    rdfs:comment 'Ratio describing the terms of a corporate action (e.g., \'2:1\' for a stock split, \'1:0.5\' for a rights issue). Format varies by action type.' ;
    rdfs:domain ind:PortfolioTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commission rdf:type rdf:Property ;
    rdfs:label 'Commission' ;
    rdfs:comment 'Brokerage commission charged for executing the transaction.' ;
    rdfs:domain ind:PortfolioTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementInstruction rdf:type rdf:Property ;
    rdfs:label 'Settlement Instruction' ;
    rdfs:comment 'Method of settlement: Delivery Versus Payment (DVP), Receive Versus Payment (RVP), Free of Payment (FOP), or Against Payment.' ;
    rdfs:domain ind:PortfolioTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundingDepositAccountId rdf:type rdf:Property ;
    rdfs:label 'Funding Deposit Account Id' ;
    rdfs:comment 'Foreign key linking to account.deposit_account. Business justification: Rebalancing orders require deposit accounts for funding security purchases and receiving sale proceeds. Essential for portfolio rebalancing execution, cash availability verification, and transaction c' ;
    rdfs:domain ind:RebalancingOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DepositAccount .

ind:orderStatusCodeListId rdf:type rdf:Property ;
    rdfs:label 'Order Status Code List Id' ;
    rdfs:comment 'Foreign key linking to reference.code_list. Business justification: Order status uses standardized workflow codes (pending, approved, executed, cancelled). Rebalancing workflow, approval routing, and audit trail require code list reference.' ;
    rdfs:domain ind:RebalancingOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CodeList .

ind:primaryRebalancingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Rebalancing Employee Id' ;
    rdfs:comment 'Reference to the user who provided final approval for the rebalancing order. Null if not yet approved.' ;
    rdfs:domain ind:RebalancingOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryRebalancingLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Rebalancing Last Modified By User Employee Id' ;
    rdfs:comment 'Reference to the user who last modified this rebalancing order record.' ;
    rdfs:domain ind:RebalancingOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:triggeringDealId rdf:type rdf:Property ;
    rdfs:label 'Triggering Deal Id' ;
    rdfs:comment 'Foreign key linking to investment.deal. Business justification: Rebalancing orders may be triggered by corporate actions or events related to investment banking deals (M&A, restructuring). Real business process: portfolio rebalancing post-deal to maintain target a' ;
    rdfs:domain ind:RebalancingOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Deal .

ind:actualExecutionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Execution Date' ;
    rdfs:comment 'The actual date on which the rebalancing trades were executed and completed. Null if not yet executed.' ;
    rdfs:domain ind:RebalancingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualTransactionCost rdf:type rdf:Property ;
    rdfs:label 'Actual Transaction Cost' ;
    rdfs:comment 'The actual total transaction costs incurred during rebalancing execution. Null if not yet executed.' ;
    rdfs:domain ind:RebalancingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvalWorkflowStage rdf:type rdf:Property ;
    rdfs:label 'Approval Workflow Stage' ;
    rdfs:comment 'Current stage in the multi-level approval workflow for the rebalancing order, indicating which stakeholder group must review and approve next.' ;
    rdfs:domain ind:RebalancingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:driftTolerancePercentage rdf:type rdf:Property ;
    rdfs:label 'Drift Tolerance Percentage' ;
    rdfs:comment 'The maximum allowable percentage deviation from target asset allocation that triggers a rebalancing order, as defined in the clients Investment Policy Statement (IPS).' ;
    rdfs:domain ind:RebalancingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedTaxBenefit rdf:type rdf:Property ;
    rdfs:label 'Estimated Tax Benefit' ;
    rdfs:comment 'The estimated tax benefit from realized capital losses through tax-loss harvesting in this rebalancing order. Null if tax-loss harvesting is not applicable.' ;
    rdfs:domain ind:RebalancingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedTransactionCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Transaction Cost' ;
    rdfs:comment 'The estimated total transaction costs including brokerage commissions, bid-ask spreads, market impact, and other execution costs for the proposed rebalancing trades.' ;
    rdfs:domain ind:RebalancingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ipsComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Ips Compliance Flag' ;
    rdfs:comment 'Indicates whether the proposed rebalancing order is compliant with the clients Investment Policy Statement (IPS) constraints including asset allocation ranges, security restrictions, and risk limits.' ;
    rdfs:domain ind:RebalancingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:portfolioBaseCurrency rdf:type rdf:Property ;
    rdfs:label 'Portfolio Base Currency' ;
    rdfs:comment 'The three-letter ISO 4217 currency code representing the base currency of the portfolio for valuation and reporting purposes.' ;
    rdfs:domain ind:RebalancingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portfolioNavAtExecution rdf:type rdf:Property ;
    rdfs:label 'Portfolio Nav At Execution' ;
    rdfs:comment 'The total Net Asset Value (NAV) of the portfolio at the time of rebalancing execution. Null if not yet executed.' ;
    rdfs:domain ind:RebalancingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:portfolioNavAtTrigger rdf:type rdf:Property ;
    rdfs:label 'Portfolio Nav At Trigger' ;
    rdfs:comment 'The total Net Asset Value (NAV) of the portfolio at the time the rebalancing trigger was identified, expressed in the portfolio base currency.' ;
    rdfs:domain ind:RebalancingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postRebalanceDriftPercentage rdf:type rdf:Property ;
    rdfs:label 'Post Rebalance Drift Percentage' ;
    rdfs:comment 'The maximum percentage deviation from target asset allocation across all asset classes after rebalancing execution. Null if not yet executed.' ;
    rdfs:domain ind:RebalancingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preRebalanceDriftPercentage rdf:type rdf:Property ;
    rdfs:label 'Pre Rebalance Drift Percentage' ;
    rdfs:comment 'The maximum percentage deviation from target asset allocation across all asset classes before rebalancing, measured as the absolute difference between actual and target weights.' ;
    rdfs:domain ind:RebalancingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proposedExecutionDate rdf:type rdf:Property ;
    rdfs:label 'Proposed Execution Date' ;
    rdfs:comment 'The target date for executing the rebalancing trades, subject to approval and market conditions.' ;
    rdfs:domain ind:RebalancingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rebalancingMethod rdf:type rdf:Property ;
    rdfs:label 'Rebalancing Method' ;
    rdfs:comment 'The methodology used to determine rebalancing trades: cash-flow rebalancing (using new contributions/withdrawals), threshold-based (triggered by drift), calendar-based (periodic), or optimization-based (minimizing costs and taxes).' ;
    rdfs:domain ind:RebalancingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemOrderReference rdf:type rdf:Property ;
    rdfs:label 'Source System Order Reference' ;
    rdfs:comment 'The unique identifier for this rebalancing order in the originating source system, used for reconciliation and traceability.' ;
    rdfs:domain ind:RebalancingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxLossHarvestingFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Loss Harvesting Flag' ;
    rdfs:comment 'Indicates whether this rebalancing order includes tax-loss harvesting opportunities to realize capital losses for tax optimization purposes.' ;
    rdfs:domain ind:RebalancingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalEstimatedTradeValue rdf:type rdf:Property ;
    rdfs:label 'Total Estimated Trade Value' ;
    rdfs:comment 'The total estimated market value of all proposed trades (buys and sells) in the rebalancing order, expressed in the portfolio base currency.' ;
    rdfs:domain ind:RebalancingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tradeInstructionCount rdf:type rdf:Property ;
    rdfs:label 'Trade Instruction Count' ;
    rdfs:comment 'The total number of individual trade instructions (buy and sell orders) included in this rebalancing order.' ;
    rdfs:domain ind:RebalancingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:triggerDate rdf:type rdf:Property ;
    rdfs:label 'Trigger Date' ;
    rdfs:comment 'The date on which the rebalancing trigger condition was identified or the rebalancing instruction was initiated.' ;
    rdfs:domain ind:RebalancingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:triggerType rdf:type rdf:Property ;
    rdfs:label 'Trigger Type' ;
    rdfs:comment 'The business event or condition that initiated the rebalancing order, such as asset allocation drift exceeding threshold, Investment Policy Statement (IPS) mandate change, model portfolio update, explicit client instruction, scheduled periodic review, or tax-loss harvesting opportunity.' ;
    rdfs:domain ind:RebalancingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:washSaleCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Wash Sale Check Status' ;
    rdfs:comment 'Status of the wash sale rule compliance check to ensure that substantially identical securities are not repurchased within 30 days before or after a loss sale, which would disallow the tax loss.' ;
    rdfs:domain ind:RebalancingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentChannelId rdf:type rdf:Property ;
    rdfs:label 'Assessment Channel Id' ;
    rdfs:comment 'Foreign key linking to channel.channel. Business justification: Suitability assessments conducted through specific channels (branch interview, video call, digital questionnaire). Critical for MiFID II/Regulation Best Interest compliance, proving appropriate advice' ;
    rdfs:domain ind:SuitabilityAssessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:assessmentOutcomeCodeListId rdf:type rdf:Property ;
    rdfs:label 'Assessment Outcome Code List Id' ;
    rdfs:comment 'Foreign key linking to reference.code_list. Business justification: Assessment outcomes use standardized codes (suitable, unsuitable, conditional) for compliance tracking. Regulatory reporting, audit trail, and investment restriction enforcement require code list refe' ;
    rdfs:domain ind:SuitabilityAssessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CodeList .

ind:evaluatedDealId rdf:type rdf:Property ;
    rdfs:label 'Evaluated Deal Id' ;
    rdfs:comment 'Foreign key linking to investment.deal. Business justification: Suitability assessments for HNW clients may evaluate participation in specific investment banking deals (private placements, structured products). Real business process: suitability review for deal pa' ;
    rdfs:domain ind:SuitabilityAssessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Deal .

ind:supersededByAssessmentSuitabilityAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Assessment Suitability Assessment Id' ;
    rdfs:comment 'Reference to the subsequent suitability assessment that supersedes this record, enabling historical tracking of assessment evolution.' ;
    rdfs:domain ind:SuitabilityAssessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SuitabilityAssessment .

ind:alternativeInvestmentsSuitability rdf:type rdf:Property ;
    rdfs:label 'Alternative Investments Suitability' ;
    rdfs:comment 'Assessment of the client\'s suitability for alternative investments (hedge funds, private equity, real estate, commodities) based on knowledge, experience, and financial capacity.' ;
    rdfs:domain ind:SuitabilityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentOutcome rdf:type rdf:Property ;
    rdfs:label 'Assessment Outcome' ;
    rdfs:comment 'The overall outcome of the suitability assessment: suitable (client profile matches investment strategy), not suitable (mismatch identified), suitable with conditions (restrictions apply), or requires further review.' ;
    rdfs:domain ind:SuitabilityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessorNotes rdf:type rdf:Property ;
    rdfs:label 'Assessor Notes' ;
    rdfs:comment 'Free-text notes and observations recorded by the relationship manager or assessor during the suitability assessment process.' ;
    rdfs:domain ind:SuitabilityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complexProductsSuitability rdf:type rdf:Property ;
    rdfs:label 'Complex Products Suitability' ;
    rdfs:comment 'Assessment of the client\'s suitability for complex financial products (structured products, derivatives, leveraged instruments) based on knowledge and experience.' ;
    rdfs:domain ind:SuitabilityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:concentrationRiskTolerance rdf:type rdf:Property ;
    rdfs:label 'Concentration Risk Tolerance' ;
    rdfs:comment 'Client\'s tolerance for concentration risk, indicating willingness to hold large positions in individual securities or sectors.' ;
    rdfs:domain ind:SuitabilityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esgPreferenceCategory rdf:type rdf:Property ;
    rdfs:label 'Esg Preference Category' ;
    rdfs:comment 'The type of ESG preference expressed by the client: none, exclusionary screening (avoiding certain sectors), positive screening (favoring ESG leaders), impact investing, or thematic ESG investing.' ;
    rdfs:domain ind:SuitabilityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esgPreferenceFlag rdf:type rdf:Property ;
    rdfs:label 'Esg Preference Flag' ;
    rdfs:comment 'Indicates whether the client has expressed a preference for Environmental, Social, and Governance (ESG) or sustainable investment criteria.' ;
    rdfs:domain ind:SuitabilityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:investableAssetsAmount rdf:type rdf:Property ;
    rdfs:label 'Investable Assets Amount' ;
    rdfs:comment 'Total value of assets the client intends to allocate for investment management, forming the basis for Assets Under Management (AUM) calculation.' ;
    rdfs:domain ind:SuitabilityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:investmentExperienceYears rdf:type rdf:Property ;
    rdfs:label 'Investment Experience Years' ;
    rdfs:comment 'Number of years the client has been actively investing in financial markets.' ;
    rdfs:domain ind:SuitabilityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:investmentKnowledgeLevel rdf:type rdf:Property ;
    rdfs:label 'Investment Knowledge Level' ;
    rdfs:comment 'Client\'s level of investment knowledge and understanding of financial instruments, ranging from basic to expert.' ;
    rdfs:domain ind:SuitabilityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investmentObjectivePrimary rdf:type rdf:Property ;
    rdfs:label 'Investment Objective Primary' ;
    rdfs:comment 'The client\'s primary investment objective, which drives portfolio construction and asset allocation strategy.' ;
    rdfs:domain ind:SuitabilityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investmentObjectiveSecondary rdf:type rdf:Property ;
    rdfs:label 'Investment Objective Secondary' ;
    rdfs:comment 'The client\'s secondary investment objective, providing additional context for portfolio construction.' ;
    rdfs:domain ind:SuitabilityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investmentTimeHorizonYears rdf:type rdf:Property ;
    rdfs:label 'Investment Time Horizon Years' ;
    rdfs:comment 'The number of years the client expects to maintain the investment before needing to liquidate, influencing asset allocation and risk capacity.' ;
    rdfs:domain ind:SuitabilityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:leverageTolerance rdf:type rdf:Property ;
    rdfs:label 'Leverage Tolerance' ;
    rdfs:comment 'Client\'s tolerance for the use of leverage or margin in the investment portfolio.' ;
    rdfs:domain ind:SuitabilityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liquidAssetsAmount rdf:type rdf:Property ;
    rdfs:label 'Liquid Assets Amount' ;
    rdfs:comment 'Value of client\'s liquid assets (cash, marketable securities, money market funds) available for investment, excluding illiquid assets such as real estate or private equity.' ;
    rdfs:domain ind:SuitabilityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:liquidityNeedsDescription rdf:type rdf:Property ;
    rdfs:label 'Liquidity Needs Description' ;
    rdfs:comment 'Textual description of the client\'s anticipated liquidity needs, including planned withdrawals, major expenses, or cash flow requirements.' ;
    rdfs:domain ind:SuitabilityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lossCapacityPercentage rdf:type rdf:Property ;
    rdfs:label 'Loss Capacity Percentage' ;
    rdfs:comment 'The maximum percentage loss the client can financially absorb without materially impacting their lifestyle or financial goals, expressed as a percentage of investable assets.' ;
    rdfs:domain ind:SuitabilityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netWorthAmount rdf:type rdf:Property ;
    rdfs:label 'Net Worth Amount' ;
    rdfs:comment 'Client\'s total net worth (assets minus liabilities), used to determine high-net-worth (HNW) or ultra-high-net-worth (UHNW) status and investment suitability.' ;
    rdfs:domain ind:SuitabilityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:restrictionsNotes rdf:type rdf:Property ;
    rdfs:label 'Restrictions Notes' ;
    rdfs:comment 'Textual notes documenting any investment restrictions, limitations, or special conditions identified during the suitability assessment (e.g., sector exclusions, leverage limits, concentration caps).' ;
    rdfs:domain ind:SuitabilityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskToleranceCategory rdf:type rdf:Property ;
    rdfs:label 'Risk Tolerance Category' ;
    rdfs:comment 'Categorical classification of the client\'s risk tolerance based on the risk tolerance score and qualitative assessment.' ;
    rdfs:domain ind:SuitabilityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskToleranceScore rdf:type rdf:Property ;
    rdfs:label 'Risk Tolerance Score' ;
    rdfs:comment 'Quantitative risk tolerance score derived from client questionnaire, typically on a scale of 0-100, indicating the client\'s willingness and capacity to accept investment risk.' ;
    rdfs:domain ind:SuitabilityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:suitabilityScore rdf:type rdf:Property ;
    rdfs:label 'Suitability Score' ;
    rdfs:comment 'Quantitative suitability score (0-100) indicating the degree of alignment between the client\'s profile and the proposed investment strategy or portfolio.' ;
    rdfs:domain ind:SuitabilityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:timeHorizonCategory rdf:type rdf:Property ;
    rdfs:label 'Time Horizon Category' ;
    rdfs:comment 'Categorical classification of the investment time horizon: short-term (0-3 years), medium-term (3-10 years), long-term (10+ years), or multi-generational (estate planning).' ;
    rdfs:domain ind:SuitabilityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:washSaleReferenceLotId rdf:type rdf:Property ;
    rdfs:label 'Wash Sale Reference Lot Id' ;
    rdfs:comment 'Reference to the replacement tax lot that triggered the wash sale rule.' ;
    rdfs:domain ind:TaxLot ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TaxLot .

ind:accruedIncomeAmount rdf:type rdf:Property ;
    rdfs:label 'Accrued Income Amount' ;
    rdfs:comment 'Accrued interest or dividend income included in the acquisition cost for fixed income or dividend-bearing securities.' ;
    rdfs:domain ind:TaxLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acquisitionPrice rdf:type rdf:Property ;
    rdfs:label 'Acquisition Price' ;
    rdfs:comment 'Price per unit at which the security was acquired.' ;
    rdfs:domain ind:TaxLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adjustedCostBasisAmount rdf:type rdf:Property ;
    rdfs:label 'Adjusted Cost Basis Amount' ;
    rdfs:comment 'Cost basis after adjustments for corporate actions, return of capital, or other events.' ;
    rdfs:domain ind:TaxLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commissionFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Commission Fee Amount' ;
    rdfs:comment 'Commission and transaction fees included in the cost basis of the tax lot.' ;
    rdfs:domain ind:TaxLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:corporateActionAdjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Corporate Action Adjustment Amount' ;
    rdfs:comment 'Total adjustments to cost basis resulting from corporate actions such as stock splits, mergers, spin-offs, or return of capital.' ;
    rdfs:domain ind:TaxLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costBasisAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Basis Amount' ;
    rdfs:comment 'Total cost basis for the tax lot, including acquisition cost and any adjustments.' ;
    rdfs:domain ind:TaxLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disposalDate rdf:type rdf:Property ;
    rdfs:label 'Disposal Date' ;
    rdfs:comment 'Date when the tax lot was fully or partially disposed of through a sale or other transaction.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disposalPrice rdf:type rdf:Property ;
    rdfs:label 'Disposal Price' ;
    rdfs:comment 'Price per unit at which the security was disposed of or sold.' ;
    rdfs:domain ind:TaxLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:donorCostBasisAmount rdf:type rdf:Property ;
    rdfs:label 'Donor Cost Basis Amount' ;
    rdfs:comment 'Original cost basis from the donor for gifted securities, used to determine gain or loss upon disposal.' ;
    rdfs:domain ind:TaxLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fairMarketValueAtGiftDate rdf:type rdf:Property ;
    rdfs:label 'Fair Market Value At Gift Date' ;
    rdfs:comment 'Fair market value of the security on the date of gift, used for determining loss basis if lower than donor cost basis.' ;
    rdfs:domain ind:TaxLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:giftInheritanceFlag rdf:type rdf:Property ;
    rdfs:label 'Gift Inheritance Flag' ;
    rdfs:comment 'Indicates whether this lot was acquired through gift or inheritance, which has special cost basis rules.' ;
    rdfs:domain ind:TaxLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lotNumber rdf:type rdf:Property ;
    rdfs:label 'Lot Number' ;
    rdfs:comment 'Business identifier for the tax lot, typically assigned by the portfolio management system.' ;
    rdfs:domain ind:TaxLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotType rdf:type rdf:Property ;
    rdfs:label 'Lot Type' ;
    rdfs:comment 'Type or origin of the tax lot acquisition. [ENUM-REF-CANDIDATE: purchase|dividend_reinvestment|stock_split|merger|spin_off|return_of_capital|gift|inheritance|transfer_in — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TaxLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noncoveredSecurityFlag rdf:type rdf:Property ;
    rdfs:label 'Noncovered Security Flag' ;
    rdfs:comment 'Indicates whether the security is noncovered for IRS Form 1099-B reporting purposes, meaning cost basis reporting is not required by the custodian.' ;
    rdfs:domain ind:TaxLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originalQuantity rdf:type rdf:Property ;
    rdfs:label 'Original Quantity' ;
    rdfs:comment 'Original number of units or shares when the lot was first acquired, before any partial sales or adjustments.' ;
    rdfs:domain ind:TaxLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:realizedGainLossAmount rdf:type rdf:Property ;
    rdfs:label 'Realized Gain Loss Amount' ;
    rdfs:comment 'Realized gain or loss from disposal of the tax lot, calculated as proceeds minus adjusted cost basis.' ;
    rdfs:domain ind:TaxLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportingCategory rdf:type rdf:Property ;
    rdfs:label 'Reporting Category' ;
    rdfs:comment 'IRS tax form category for reporting this tax lot.' ;
    rdfs:domain ind:TaxLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificIdentificationFlag rdf:type rdf:Property ;
    rdfs:label 'Specific Identification Flag' ;
    rdfs:comment 'Indicates whether this lot was specifically identified by the client or advisor for disposal, overriding the default cost basis method.' ;
    rdfs:domain ind:TaxLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxLossHarvestingCandidateFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Loss Harvesting Candidate Flag' ;
    rdfs:comment 'Indicates whether this lot is a candidate for tax-loss harvesting strategy based on unrealized losses and holding period.' ;
    rdfs:domain ind:TaxLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:washSaleDisallowedLossAmount rdf:type rdf:Property ;
    rdfs:label 'Wash Sale Disallowed Loss Amount' ;
    rdfs:comment 'Amount of loss disallowed due to wash sale rules, which must be added to the cost basis of the replacement security.' ;
    rdfs:domain ind:TaxLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cashDepositAccountId rdf:type rdf:Property ;
    rdfs:label 'Cash Deposit Account Id' ;
    rdfs:comment 'Foreign key linking to account.deposit_account. Business justification: Trust accounts maintain linked deposit accounts for trust cash management, beneficiary distributions, income collection, and expense payments. Required for fiduciary cash handling and trust administra' ;
    rdfs:domain ind:TrustAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DepositAccount .

ind:servicingBranchId rdf:type rdf:Property ;
    rdfs:label 'Servicing Branch Id' ;
    rdfs:comment 'Foreign key linking to channel.branch. Business justification: Trust accounts often have designated servicing branch for fiduciary oversight, trustee meetings, and beneficiary interactions. Required for local jurisdiction compliance, fiduciary duty documentation,' ;
    rdfs:domain ind:TrustAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Branch .

ind:beneficiaryCount rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Count' ;
    rdfs:comment 'Total number of beneficiaries designated to receive distributions or benefits from the trust.' ;
    rdfs:domain ind:TrustAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:distributionProvisionType rdf:type rdf:Property ;
    rdfs:label 'Distribution Provision Type' ;
    rdfs:comment 'Classification of the distribution rules governing how and when trust assets are distributed to beneficiaries.' ;
    rdfs:domain ind:TrustAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiduciaryDutyClassification rdf:type rdf:Property ;
    rdfs:label 'Fiduciary Duty Classification' ;
    rdfs:comment 'Classification of the fiduciary responsibility and duty of care owed to the trust beneficiaries.' ;
    rdfs:domain ind:TrustAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingLawJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Governing Law Jurisdiction' ;
    rdfs:comment 'State or country jurisdiction whose laws govern the interpretation and administration of the trust.' ;
    rdfs:domain ind:TrustAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantorTaxIdentifier rdf:type rdf:Property ;
    rdfs:label 'Grantor Tax Identifier' ;
    rdfs:comment 'Tax identification number of the grantor for IRS reporting and tax compliance purposes.' ;
    rdfs:domain ind:TrustAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryBeneficiaryName rdf:type rdf:Property ;
    rdfs:label 'Primary Beneficiary Name' ;
    rdfs:comment 'Full legal name of the primary beneficiary entitled to receive distributions from the trust.' ;
    rdfs:domain ind:TrustAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revocableFlag rdf:type rdf:Property ;
    rdfs:label 'Revocable Flag' ;
    rdfs:comment 'Indicates whether the grantor retains the right to revoke, amend, or terminate the trust during their lifetime.' ;
    rdfs:domain ind:TrustAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:spendthriftProvisionFlag rdf:type rdf:Property ;
    rdfs:label 'Spendthrift Provision Flag' ;
    rdfs:comment 'Indicates whether the trust includes a spendthrift clause restricting beneficiary ability to transfer or pledge trust interests and protecting assets from creditors.' ;
    rdfs:domain ind:TrustAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:successorTrusteeName rdf:type rdf:Property ;
    rdfs:label 'Successor Trustee Name' ;
    rdfs:comment 'Name of the designated successor trustee who will assume fiduciary duties upon the current trustee\'s resignation, incapacity, or death.' ;
    rdfs:domain ind:TrustAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationEvent rdf:type rdf:Property ;
    rdfs:label 'Termination Event' ;
    rdfs:comment 'Description of the event or condition that triggered the termination of the trust, such as beneficiary reaching specified age or grantor death.' ;
    rdfs:domain ind:TrustAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trustAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Trust Account Number' ;
    rdfs:comment 'Externally visible unique account number assigned to the trust account for client communication and regulatory reporting.' ;
    rdfs:domain ind:TrustAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trustInstrumentDate rdf:type rdf:Property ;
    rdfs:label 'Trust Instrument Date' ;
    rdfs:comment 'Date on which the trust instrument or declaration was executed and legally established.' ;
    rdfs:domain ind:TrustAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trustPurpose rdf:type rdf:Property ;
    rdfs:label 'Trust Purpose' ;
    rdfs:comment 'Stated purpose and intent of the trust as documented in the trust instrument, describing the grantor\'s objectives.' ;
    rdfs:domain ind:TrustAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trustStatus rdf:type rdf:Property ;
    rdfs:label 'Trust Status' ;
    rdfs:comment 'Current operational status of the trust account in its lifecycle.' ;
    rdfs:domain ind:TrustAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trustTaxIdentifier rdf:type rdf:Property ;
    rdfs:label 'Trust Tax Identifier' ;
    rdfs:comment 'Employer Identification Number (EIN) or Tax Identification Number assigned to the trust for tax reporting purposes.' ;
    rdfs:domain ind:TrustAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trustType rdf:type rdf:Property ;
    rdfs:label 'Trust Type' ;
    rdfs:comment 'Classification of the trust structure indicating the legal and tax treatment of the trust arrangement. [ENUM-REF-CANDIDATE: revocable|irrevocable|testamentary|living|charitable|special_needs|grantor_retained|qualified_personal_residence — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TrustAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trusteeType rdf:type rdf:Property ;
    rdfs:label 'Trustee Type' ;
    rdfs:comment 'Classification of the trustee role indicating whether the trustee is an individual or institutional fiduciary.' ;
    rdfs:domain ind:TrustAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingDepositAccountId rdf:type rdf:Property ;
    rdfs:label 'Billing Deposit Account Id' ;
    rdfs:comment 'Foreign key linking to account.deposit_account. Business justification: Wealth management fees are debited from client deposit accounts per fee schedule terms. Required for automated fee billing, payment processing, and revenue recognition in wealth advisory operations.' ;
    rdfs:domain ind:WealthFeeSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DepositAccount .

ind:aumCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Aum Calculation Method' ;
    rdfs:comment 'The method used to determine the AUM basis for fee calculation. Average daily is most precise; beginning or ending balance is simpler but less accurate during volatile periods.' ;
    rdfs:domain ind:WealthFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingInAdvanceFlag rdf:type rdf:Property ;
    rdfs:label 'Billing In Advance Flag' ;
    rdfs:comment 'Indicates whether fees are billed at the beginning (true) or end (false) of the billing period. Management fees are commonly billed in advance; performance fees are billed in arrears.' ;
    rdfs:domain ind:WealthFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:feeWaiverAmount rdf:type rdf:Property ;
    rdfs:label 'Fee Waiver Amount' ;
    rdfs:comment 'The amount of fee waived or discounted for this billing period. May result from promotional arrangements, relationship pricing, or service level adjustments.' ;
    rdfs:domain ind:WealthFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:flatFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Flat Fee Amount' ;
    rdfs:comment 'Fixed fee amount charged when fee_basis is flat. Null for percentage-based or tiered fee structures.' ;
    rdfs:domain ind:WealthFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Invoice Reference Number' ;
    rdfs:comment 'The unique invoice number generated for this fee billing. Used for client communication, payment tracking, and reconciliation.' ;
    rdfs:domain ind:WealthFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:negotiatedDiscountPercentage rdf:type rdf:Property ;
    rdfs:label 'Negotiated Discount Percentage' ;
    rdfs:comment 'Permanent discount percentage negotiated with the client, applied to the standard fee rate. Common for UHNW clients or large institutional mandates.' ;
    rdfs:domain ind:WealthFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceHurdleRate rdf:type rdf:Property ;
    rdfs:label 'Performance Hurdle Rate' ;
    rdfs:comment 'The minimum return threshold that must be exceeded before performance fees are charged. Expressed as an annual percentage. Null for non-performance-based fees.' ;
    rdfs:domain ind:WealthFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryDisclosureFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Disclosure Flag' ;
    rdfs:comment 'Indicates whether this fee must be disclosed in regulatory filings such as Form ADV Part 2 (SEC) or MIFID II cost disclosures (EU). True for material fees subject to disclosure requirements.' ;
    rdfs:domain ind:WealthFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tierLowerBound rdf:type rdf:Property ;
    rdfs:label 'Tier Lower Bound' ;
    rdfs:comment 'The minimum AUM threshold for this fee tier. Used in tiered fee structures where different rates apply to different asset levels. Null for non-tiered fee schedules.' ;
    rdfs:domain ind:WealthFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tierUpperBound rdf:type rdf:Property ;
    rdfs:label 'Tier Upper Bound' ;
    rdfs:comment 'The maximum AUM threshold for this fee tier. Null indicates no upper limit (top tier). Used in tiered fee structures.' ;
    rdfs:domain ind:WealthFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:instrumentChannelAvailabilityId rdf:type rdf:Property ;
    rdfs:label 'Instrument Channel Availability Id' ;
    rdfs:comment 'Primary key for the instrument_channel_availability association' ;
    rdfs:domain ind:InstrumentChannelAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dealParticipationId rdf:type rdf:Property ;
    rdfs:label 'Deal Participation Id' ;
    rdfs:comment 'Unique surrogate identifier for the deal participation record. Primary key for the association.' ;
    rdfs:domain ind:DealParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:participationPercentage rdf:type rdf:Property ;
    rdfs:label 'Participation Percentage' ;
    rdfs:comment 'The percentage of the deal this party is participating in, relevant for syndicated transactions. Used for risk allocation and fee distribution.' ;
    rdfs:domain ind:Investment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:correspondentCurrencyServiceId rdf:type rdf:Property ;
    rdfs:label 'Correspondent Currency Service Id' ;
    rdfs:comment 'Primary key for the correspondent-currency service agreement record' ;
    rdfs:domain ind:CorrespondentCurrencyService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceStatus rdf:type rdf:Property ;
    rdfs:label 'Service Status' ;
    rdfs:comment 'Current operational status of currency service through this correspondent' ;
    rdfs:domain ind:CorrespondentCurrencyService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerInvestorOrderId rdf:type rdf:Property ;
    rdfs:label 'Customer Investor Order Id' ;
    rdfs:comment 'Primary key for customer_investor_order' ;
    rdfs:domain ind:CustomerInvestorOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:investorOrderId rdf:type rdf:Property ;
    rdfs:label 'Investor Order Id' ;
    rdfs:comment 'Unique surrogate identifier for the investor order record. Primary key for the investor_order association.' ;
    rdfs:domain ind:CustomerInvestorOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InvestmentInvestorOrder .

ind:allocationDecisionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Allocation Decision Timestamp' ;
    rdfs:comment 'Timestamp when the syndicate desk finalized the allocation decision for this investor order. Typically occurs after pricing_date and before settlement_date.' ;
    rdfs:domain ind:CustomerInvestorOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:orderSubmissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Order Submission Timestamp' ;
    rdfs:comment 'Timestamp when the investor order was first received by the syndicate desk during the book-building period. Used to track order flow timing and priority.' ;
    rdfs:domain ind:CustomerInvestorOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:loanCollateralPledgeId rdf:type rdf:Property ;
    rdfs:label 'Loan Collateral Pledge Id' ;
    rdfs:comment 'Primary key for loan_collateral_pledge' ;
    rdfs:domain ind:LoanCollateralPledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:marginCallThresholdPct rdf:type rdf:Property ;
    rdfs:label 'Margin Call Threshold Pct' ;
    rdfs:comment 'LTV ratio threshold that triggers a margin call or requirement for additional collateral. When the calculated ltv_ratio exceeds this threshold, the borrower must pledge additional collateral or reduce the facility balance. Typically set in the credit agreement.' ;
    rdfs:domain ind:LoanCollateralPledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wealthHoldingId rdf:type rdf:Property ;
    rdfs:label 'Wealth Holding Id' ;
    rdfs:comment 'Primary key for wealth_holding' ;
    rdfs:domain ind:WealthHolding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:holdingId rdf:type rdf:Property ;
    rdfs:label 'Holding Id' ;
    rdfs:comment 'Unique identifier for this portfolio holding position. Primary key.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Banking .

ind:periodClassification rdf:type rdf:Property ;
    rdfs:label 'Period Classification' ;
    rdfs:comment 'Tax classification of the holding period (short-term < 1 year, long-term >= 1 year) affecting capital gains tax treatment. Explicitly identified in detection phase as relationship-specific data.' ;
    rdfs:domain ind:WealthHolding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portfolioPledgeId rdf:type rdf:Property ;
    rdfs:label 'Portfolio Pledge Id' ;
    rdfs:comment 'Unique identifier for this portfolio-pledge assignment relationship. Primary key.' ;
    rdfs:domain ind:PortfolioPledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignmentEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Assignment Effective Date' ;
    rdfs:comment 'The date from which this portfolio-pledge assignment becomes legally effective and enforceable. Required for tracking when each portfolio begins securing each obligation.' ;
    rdfs:domain ind:PortfolioPledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignmentMaturityDate rdf:type rdf:Property ;
    rdfs:label 'Assignment Maturity Date' ;
    rdfs:comment 'The date on which this portfolio-pledge assignment expires or is scheduled to be released, if applicable. Supports term-limited collateral arrangements.' ;
    rdfs:domain ind:PortfolioPledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pledgeAmount rdf:type rdf:Property ;
    rdfs:label 'Pledge Amount' ;
    rdfs:comment 'The monetary value of this specific portfolio pledged to this specific obligation, expressed in the pledge currency. Moved from pledge entity because pledge_amount is portfolio-specific in cross-collateralization scenarios.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:portfolioAllocationPercentage rdf:type rdf:Property ;
    rdfs:label 'Portfolio Allocation Percentage' ;
    rdfs:comment 'The percentage of this portfolio\'s value allocated to secure this specific pledge, used when a portfolio is partially pledged or split across multiple obligations. Supports proportional cross-collateralization.' ;
    rdfs:domain ind:PortfolioPledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accountHolderId rdf:type rdf:Property ;
    rdfs:label 'Account Holder Id' ;
    rdfs:comment 'Unique identifier for this account holder relationship record. Primary key for the association.' ;
    rdfs:domain ind:AccountHolder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountPositionId rdf:type rdf:Property ;
    rdfs:label 'Account Position Id' ;
    rdfs:comment 'Primary key for account_position' ;
    rdfs:domain ind:AccountPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lotId rdf:type rdf:Property ;
    rdfs:label 'Lot Id' ;
    rdfs:comment 'Identifier for the specific tax lot within the position. Multiple lots may exist for the same account-instrument combination with different acquisition dates and cost bases.' ;
    rdfs:domain ind:AccountPosition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TaxLot .

ind:positionId rdf:type rdf:Property ;
    rdfs:label 'Position Id' ;
    rdfs:comment 'Unique identifier for this custodial account position. Primary key.' ;
    rdfs:domain ind:AccountPosition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TradePosition .

ind:incomeEarnedYtd rdf:type rdf:Property ;
    rdfs:label 'Income Earned Ytd' ;
    rdfs:comment 'Total income (dividends, interest, distributions) earned from this position in the current calendar year. Used for tax reporting (Form 1099-DIV, 1099-INT).' ;
    rdfs:domain ind:AccountPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:securityHoldingId rdf:type rdf:Property ;
    rdfs:label 'Security Holding Id' ;
    rdfs:comment 'Primary key for security_holding' ;
    rdfs:domain ind:SecurityHolding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capitalCharge rdf:type rdf:Property ;
    rdfs:label 'Capital Charge' ;
    rdfs:comment 'Regulatory capital charge amount required for this holding under Basel III rules. Calculated based on risk weight, exposure, and regulatory treatment.' ;
    rdfs:domain ind:SecurityHolding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:classification rdf:type rdf:Property ;
    rdfs:label 'Classification' ;
    rdfs:comment 'Accounting and regulatory classification of the holding. Determines capital treatment and valuation methodology under Basel III and IFRS 9.' ;
    rdfs:domain ind:SecurityHolding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionQuantity rdf:type rdf:Property ;
    rdfs:label 'Position Quantity' ;
    rdfs:comment 'Number of units of the instrument held by the legal entity. For bonds, represents face value; for equities, number of shares; for derivatives, number of contracts.' ;
    rdfs:domain ind:SecurityHolding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holdingPledgeId rdf:type rdf:Property ;
    rdfs:label 'Holding Pledge Id' ;
    rdfs:comment 'Unique identifier for this holding-pledge assignment record. Primary key.' ;
    rdfs:domain ind:HoldingPledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eligibleValue rdf:type rdf:Property ;
    rdfs:label 'Eligible Value' ;
    rdfs:comment 'The collateral value of this specific holding after applying the haircut, representing the amount eligible for credit risk mitigation. Calculated as (pledged_quantity × market_price × (1 - haircut_percentage)).' ;
    rdfs:domain ind:HoldingPledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pledgedQuantity rdf:type rdf:Property ;
    rdfs:label 'Pledged Quantity' ;
    rdfs:comment 'The specific quantity of units from the portfolio holding that are allocated to this pledge. Enables partial pledging where a holding is split across multiple facilities (e.g., 500 shares to Facility A, 300 to Facility B, 200 unpledged).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:branchAuditScopeId rdf:type rdf:Property ;
    rdfs:label 'Branch Audit Scope Id' ;
    rdfs:comment 'Unique identifier for this branch-engagement scope record. Primary key.' ;
    rdfs:domain ind:BranchAuditScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditorAssigned rdf:type rdf:Property ;
    rdfs:label 'Auditor Assigned' ;
    rdfs:comment 'Name or identifier of the auditor assigned to conduct fieldwork at this specific branch. In large engagements, different auditors may cover different branches.' ;
    rdfs:domain ind:BranchAuditScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:branchAuditStatus rdf:type rdf:Property ;
    rdfs:label 'Branch Audit Status' ;
    rdfs:comment 'Current status of the audit work for this specific branch within the engagement. Allows tracking of multi-branch engagements where different branches may be at different stages.' ;
    rdfs:domain ind:BranchAuditScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:branchRiskRating rdf:type rdf:Property ;
    rdfs:label 'Branch Risk Rating' ;
    rdfs:comment 'Risk rating assigned to this specific branch within the context of this audit engagement. Reflects branch-specific risk factors such as transaction volume, prior findings, regulatory issues, or control weaknesses.' ;
    rdfs:domain ind:BranchAuditScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdDate rdf:type rdf:Property ;
    rdfs:label 'Created Date' ;
    rdfs:comment 'Timestamp when this branch was added to the engagement scope.' ;
    rdfs:domain ind:BranchAuditScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scopeEndDate rdf:type rdf:Property ;
    rdfs:label 'Scope End Date' ;
    rdfs:comment 'End date of the audit period for this specific branch within the engagement. Defines the business period under review for this branch.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scopeStartDate rdf:type rdf:Property ;
    rdfs:label 'Scope Start Date' ;
    rdfs:comment 'Start date of the audit period for this specific branch within the engagement. May differ from the overall engagement audit period if branches are audited in phases.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:updatedDate rdf:type rdf:Property ;
    rdfs:label 'Updated Date' ;
    rdfs:comment 'Timestamp when this scope record was last modified.' ;
    rdfs:domain ind:BranchAuditScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dealBrokerParticipationId rdf:type rdf:Property ;
    rdfs:label 'Deal Broker Participation Id' ;
    rdfs:comment 'Unique surrogate identifier for the deal-broker participation record. Primary key for the association.' ;
    rdfs:domain ind:DealBrokerParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:brokerRole rdf:type rdf:Property ;
    rdfs:label 'Broker Role' ;
    rdfs:comment 'The specific role the broker plays in this deal syndicate. Bookrunner leads the transaction, lead managers have significant responsibility, co-managers participate in distribution, selling group members assist with placement. Drives fee allocation and tombstone positioning.' ;
    rdfs:domain ind:DealBrokerParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:economicsCurrency rdf:type rdf:Property ;
    rdfs:label 'Economics Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the fee share amount is denominated. Typically matches deal currency but may differ for cross-border syndicates.' ;
    rdfs:domain ind:DealBrokerParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementDate rdf:type rdf:Property ;
    rdfs:label 'Engagement Date' ;
    rdfs:comment 'The date on which this broker was formally engaged or added to the deal syndicate. May differ from deal mandate date if brokers join at different stages (e.g., selling group added closer to pricing).' ;
    rdfs:domain ind:DealBrokerParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:feeShareAmount rdf:type rdf:Property ;
    rdfs:label 'Fee Share Amount' ;
    rdfs:comment 'The absolute dollar amount of advisory or underwriting fees allocated to this broker for this specific deal. Calculated based on participation percentage, broker role, and negotiated fee splits.' ;
    rdfs:domain ind:DealBrokerParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tombstoneCreditFlag rdf:type rdf:Property ;
    rdfs:label 'Tombstone Credit Flag' ;
    rdfs:comment 'Indicates whether this broker receives credit on the deal tombstone advertisement. Typically true for bookrunners and managers, may be false for passive selling group members depending on deal terms.' ;
    rdfs:domain ind:DealBrokerParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:auditScopeId rdf:type rdf:Property ;
    rdfs:label 'Audit Scope Id' ;
    rdfs:comment 'Unique identifier for this channel-engagement scope record. Primary key.' ;
    rdfs:domain ind:AuditScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:createdByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Created By Employee Id' ;
    rdfs:comment 'Identifier of the audit staff member who added this channel to the engagement scope.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:auditHoursAllocated rdf:type rdf:Property ;
    rdfs:label 'Audit Hours Allocated' ;
    rdfs:comment 'Number of audit hours allocated and expended on reviewing this specific channel within the engagement. Used for audit resource planning, variance analysis, and cost allocation.' ;
    rdfs:domain ind:AuditScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:channelAuditOpinion rdf:type rdf:Property ;
    rdfs:label 'Channel Audit Opinion' ;
    rdfs:comment 'Audit opinion specific to this channel within the engagement. May differ from the overall engagement opinion if the engagement covers multiple channels with varying control effectiveness.' ;
    rdfs:domain ind:AuditScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelRiskRating rdf:type rdf:Property ;
    rdfs:label 'Channel Risk Rating' ;
    rdfs:comment 'Risk rating assigned to this specific channel within the context of this audit engagement, based on transaction volume, control environment, prior findings, and inherent channel risk. May differ from the overall engagement risk rating.' ;
    rdfs:domain ind:AuditScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeInclusionRationale rdf:type rdf:Property ;
    rdfs:label 'Scope Inclusion Rationale' ;
    rdfs:comment 'Business justification for including this channel in the engagement scope (e.g., high transaction volume, prior control deficiencies, regulatory focus area, new channel launch).' ;
    rdfs:domain ind:AuditScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testingApproach rdf:type rdf:Property ;
    rdfs:label 'Testing Approach' ;
    rdfs:comment 'Audit testing methodology applied to this channel within the engagement (full population review, statistical sampling, judgmental sampling, process walkthrough, inquiry only).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionVolumeReviewed rdf:type rdf:Property ;
    rdfs:label 'Transaction Volume Reviewed' ;
    rdfs:comment 'Number of transactions sampled and reviewed for this channel during this audit engagement. Used for audit sampling documentation and effort tracking.' ;
    rdfs:domain ind:AuditScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stressValuationId rdf:type rdf:Property ;
    rdfs:label 'Stress Valuation Id' ;
    rdfs:comment 'Unique identifier for this collateral asset stress valuation record. Primary key.' ;
    rdfs:domain ind:StressValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:centralBankEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Central Bank Eligible Flag' ;
    rdfs:comment 'Indicates whether this collateral asset is eligible for central bank discount window borrowing under this stress scenario.' ;
    rdfs:domain ind:StressValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fhlbEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Fhlb Eligible Flag' ;
    rdfs:comment 'Indicates whether this collateral asset is eligible for Federal Home Loan Bank advance borrowing under this stress scenario.' ;
    rdfs:domain ind:StressValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fireSaleDiscountPercentage rdf:type rdf:Property ;
    rdfs:label 'Fire Sale Discount Percentage' ;
    rdfs:comment 'Additional discount percentage applied for emergency asset monetization under this stress scenario. Reflects illiquidity premium and forced sale conditions.' ;
    rdfs:domain ind:StressValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lcrTreatmentCode rdf:type rdf:Property ;
    rdfs:label 'Lcr Treatment Code' ;
    rdfs:comment 'Basel III Liquidity Coverage Ratio treatment classification for this asset under this stress scenario (Level 1, Level 2A, Level 2B, or ineligible).' ;
    rdfs:domain ind:StressValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monetizationCapacityAmount rdf:type rdf:Property ;
    rdfs:label 'Monetization Capacity Amount' ;
    rdfs:comment 'Estimated liquidity that can be raised from this collateral asset under this stress scenario through asset sales, repo, or central bank borrowing. Used in contingency funding plan calculations.' ;
    rdfs:domain ind:StressValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scenarioSpecificEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Scenario Specific Eligibility Flag' ;
    rdfs:comment 'Indicates whether the collateral asset remains eligible for liquidity purposes under this specific stress scenario. Eligibility may change due to rating downgrades, concentration limits, or counterparty stress assumptions.' ;
    rdfs:domain ind:StressValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stressedEligibleValueAmount rdf:type rdf:Property ;
    rdfs:label 'Stressed Eligible Value Amount' ;
    rdfs:comment 'Net eligible collateral value after applying stressed market value and stressed haircut. This is the value available for liquidity purposes under the stress scenario.' ;
    rdfs:domain ind:StressValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stressedHaircutPercentage rdf:type rdf:Property ;
    rdfs:label 'Stressed Haircut Percentage' ;
    rdfs:comment 'Haircut percentage applied to the collateral asset under this stress scenario. Combines base haircut with scenario-specific additional haircuts for secured funding stress.' ;
    rdfs:domain ind:StressValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stressedMarketValueAmount rdf:type rdf:Property ;
    rdfs:label 'Stressed Market Value Amount' ;
    rdfs:comment 'Market value of the collateral asset after applying the scenario-specific market value shock. Represents the estimated value under stress conditions.' ;
    rdfs:domain ind:StressValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dealTeamMemberId rdf:type rdf:Property ;
    rdfs:label 'Deal Team Member Id' ;
    rdfs:comment 'Unique surrogate identifier for the deal team member assignment record. Primary key for this association.' ;
    rdfs:domain ind:DealTeamMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isLeadBanker rdf:type rdf:Property ;
    rdfs:label 'Is Lead Banker' ;
    rdfs:comment 'Flag indicating whether this employee is designated as the lead or primary banker for the deal. Typically one lead per deal, but may change during deal lifecycle. Explicitly identified in detection reasoning as relationship data.' ;
    rdfs:domain ind:DealTeamMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revenueCreditPct rdf:type rdf:Property ;
    rdfs:label 'Revenue Credit Pct' ;
    rdfs:comment 'Percentage of deal revenue credited to this employee for compensation and performance evaluation purposes (0.00-100.00%). Sum across all team members may exceed 100% due to overlapping credit rules. Explicitly identified in detection reasoning as relationship data.' ;
    rdfs:domain ind:DealTeamMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:roleType rdf:type rdf:Property ;
    rdfs:label 'Role Type' ;
    rdfs:comment 'The specific role or function the employee performs on this deal team. Determines responsibility scope, revenue credit eligibility, and approval authority. Explicitly identified in detection reasoning as relationship data.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountCollateralPledgeId rdf:type rdf:Property ;
    rdfs:label 'Account Collateral Pledge Id' ;
    rdfs:comment 'Primary key for account_collateral_pledge' ;
    rdfs:domain ind:AccountCollateralPledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assetCollateralAssetId rdf:type rdf:Property ;
    rdfs:label 'Asset Collateral Asset Id' ;
    rdfs:comment 'Foreign key linking to the collateral asset that is pledged to secure the deposit account or related obligation' ;
    rdfs:domain ind:AccountCollateralPledge ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CollateralAsset .

ind:pledgeAgreementReference rdf:type rdf:Property ;
    rdfs:label 'Pledge Agreement Reference' ;
    rdfs:comment 'Reference to the legal agreement or document governing this pledge arrangement' ;
    rdfs:domain ind:AccountCollateralPledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectAccountLinkId rdf:type rdf:Property ;
    rdfs:label 'Subject Account Link Id' ;
    rdfs:comment 'Unique identifier for this fraud subject to investor account association record. Primary key.' ;
    rdfs:domain ind:SubjectAccountLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:evidenceStrength rdf:type rdf:Property ;
    rdfs:label 'Evidence Strength' ;
    rdfs:comment 'Assessment of the strength of evidence linking the fraud subject to this specific investor account. Determines confidence level for law enforcement referral. Explicitly identified in detection phase.' ;
    rdfs:domain ind:SubjectAccountLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkDiscoveryDate rdf:type rdf:Property ;
    rdfs:label 'Link Discovery Date' ;
    rdfs:comment 'Date when the fraud investigation team first identified the connection between this fraud subject and investor account.' ;
    rdfs:domain ind:SubjectAccountLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:linkDiscoveryMethod rdf:type rdf:Property ;
    rdfs:label 'Link Discovery Method' ;
    rdfs:comment 'The investigative method or data source that revealed the connection between the fraud subject and the account.' ;
    rdfs:domain ind:SubjectAccountLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleInFraud rdf:type rdf:Property ;
    rdfs:label 'Role In Fraud' ;
    rdfs:comment 'The fraud subject\'s specific role in the fraudulent activity involving this account. Determines investigation priority and legal action. Explicitly identified in detection phase.' ;
    rdfs:domain ind:SubjectAccountLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountTestingScopeId rdf:type rdf:Property ;
    rdfs:label 'Account Testing Scope Id' ;
    rdfs:comment 'Unique identifier for this account testing scope record' ;
    rdfs:domain ind:AccountTestingScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountTestingStatus rdf:type rdf:Property ;
    rdfs:label 'Account Testing Status' ;
    rdfs:comment 'Current status of testing for this GL account within this engagement lifecycle' ;
    rdfs:domain ind:AccountTestingScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditorNotes rdf:type rdf:Property ;
    rdfs:label 'Auditor Notes' ;
    rdfs:comment 'Free-text notes documenting observations, issues, or context specific to testing this GL account during this engagement' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplingMethodology rdf:type rdf:Property ;
    rdfs:label 'Sampling Methodology' ;
    rdfs:comment 'The audit sampling approach applied to this GL account for this engagement, such as statistical sampling, judgmental sampling, or monetary unit sampling' ;
    rdfs:domain ind:AccountTestingScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testingCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Testing Completion Date' ;
    rdfs:comment 'Date when audit testing procedures for this GL account were completed for this engagement' ;
    rdfs:domain ind:AccountTestingScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:testingProcedures rdf:type rdf:Property ;
    rdfs:label 'Testing Procedures' ;
    rdfs:comment 'Specific audit procedures to be performed on this GL account during this engagement, such as substantive testing, control testing, reconciliation review, or analytical procedures' ;
    rdfs:domain ind:AccountTestingScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instrumentEligibilityId rdf:type rdf:Property ;
    rdfs:label 'Instrument Eligibility Id' ;
    rdfs:comment 'Unique identifier for this instrument-eligibility rule pairing. Primary key.' ;
    rdfs:domain ind:InstrumentEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastEvaluationDate rdf:type rdf:Property ;
    rdfs:label 'Last Evaluation Date' ;
    rdfs:comment 'Date when this instrument was last evaluated against this eligibility rule by the collateral optimization engine.' ;
    rdfs:domain ind:InstrumentEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:instrumentHaircutApplicabilityId rdf:type rdf:Property ;
    rdfs:label 'Instrument Haircut Applicability Id' ;
    rdfs:comment 'Primary key for the instrument_haircut_applicability association' ;
    rdfs:domain ind:InstrumentHaircutApplicability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicableInternalModelHaircutPct rdf:type rdf:Property ;
    rdfs:label 'Applicable Internal Model Haircut Pct' ;
    rdfs:comment 'The specific internal model-derived haircut percentage that applies to this instrument under the bank\'s own VaR methodology. Instrument-specific calculation based on the schedule\'s methodology parameters.' ;
    rdfs:domain ind:InstrumentHaircutApplicability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:applicableSupervisoryHaircutPct rdf:type rdf:Property ;
    rdfs:label 'Applicable Supervisory Haircut Pct' ;
    rdfs:comment 'The specific supervisory haircut percentage from the schedule that applies to this instrument based on its credit quality, maturity, and other characteristics. Captured at the association level because the schedule defines ranges and this records the specific value for this instrument.' ;
    rdfs:domain ind:InstrumentHaircutApplicability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:liquidityHoldingId rdf:type rdf:Property ;
    rdfs:label 'Liquidity Holding Id' ;
    rdfs:comment 'Unique identifier for this liquidity holding record. Primary key.' ;
    rdfs:domain ind:LiquidityHolding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:custodianAccount rdf:type rdf:Property ;
    rdfs:label 'Custodian Account' ;
    rdfs:comment 'Custodian account identifier where this instrument holding is maintained, supporting reconciliation and operational liquidity tracking.' ;
    rdfs:domain ind:LiquidityHolding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fxRateToPositionCurrency rdf:type rdf:Property ;
    rdfs:label 'Fx Rate To Position Currency' ;
    rdfs:comment 'Foreign exchange rate used to convert holding currency to position currency for aggregation. 1.0 if currencies match.' ;
    rdfs:domain ind:LiquidityHolding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holdingCurrency rdf:type rdf:Property ;
    rdfs:label 'Holding Currency' ;
    rdfs:comment 'ISO 4217 3-letter currency code for this holding. May differ from position currency if FX conversion applied.' ;
    rdfs:domain ind:LiquidityHolding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hqlaValue rdf:type rdf:Property ;
    rdfs:label 'Hqla Value' ;
    rdfs:comment 'Post-haircut value of the instrument eligible for inclusion in HQLA for LCR calculation. Calculated as market_value * (1 - haircut_percentage) if instrument qualifies as HQLA, otherwise zero.' ;
    rdfs:domain ind:LiquidityHolding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tradingRestrictionId rdf:type rdf:Property ;
    rdfs:label 'Trading Restriction Id' ;
    rdfs:comment 'Unique identifier for the trading restriction record. Primary key for the association.' ;
    rdfs:domain ind:TradingRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preClearanceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Pre Clearance Required Flag' ;
    rdfs:comment 'Indicates whether the employee must obtain explicit compliance approval before executing any trade in this instrument. True for high-risk scenarios (MNPI exposure, investment banking relationships). False for watch-list monitoring without pre-approval requirement. Drives pre-trade compliance workflow routing.' ;
    rdfs:domain ind:TradingRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stressProjectionId rdf:type rdf:Property ;
    rdfs:label 'Stress Projection Id' ;
    rdfs:comment 'Unique surrogate identifier for this loan-scenario stress projection record. Primary key.' ;
    rdfs:domain ind:StressProjection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stressRunId rdf:type rdf:Property ;
    rdfs:label 'Stress Run Id' ;
    rdfs:comment 'Reference to the specific stress testing run execution that produced this projection. Links to stress run metadata (run date, model version, approval status).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StressTestRun .

ind:stressedBalance rdf:type rdf:Property ;
    rdfs:label 'Stressed Balance' ;
    rdfs:comment 'Projected outstanding principal balance of the loan account under this stress scenario at the projection date. Reflects expected prepayments, defaults, and charge-offs under stress conditions.' ;
    rdfs:domain ind:StressProjection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stressedDelinquencyBucket rdf:type rdf:Property ;
    rdfs:label 'Stressed Delinquency Bucket' ;
    rdfs:comment 'Projected delinquency bucket (current, 30 DPD, 60 DPD, 90+ DPD) for this loan under this stress scenario at the projection date.' ;
    rdfs:domain ind:StressProjection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stressedEclProvision rdf:type rdf:Property ;
    rdfs:label 'Stressed Ecl Provision' ;
    rdfs:comment 'Expected Credit Loss (ECL) provision calculated for this loan under this stress scenario. Used for IFRS 9 stress testing and regulatory capital stress testing (CCAR/DFAST).' ;
    rdfs:domain ind:StressProjection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stressedLgd rdf:type rdf:Property ;
    rdfs:label 'Stressed Lgd' ;
    rdfs:comment 'Loss Given Default (LGD) for this loan under this stress scenario, expressed as a decimal. Reflects collateral value deterioration under stressed macroeconomic conditions (e.g., HPI shocks for mortgage collateral).' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stressedNplFlag rdf:type rdf:Property ;
    rdfs:label 'Stressed Npl Flag' ;
    rdfs:comment 'Indicates whether this loan is projected to be classified as non-performing (NPL) under this stress scenario at the projection date.' ;
    rdfs:domain ind:StressProjection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stressedPd rdf:type rdf:Property ;
    rdfs:label 'Stressed Pd' ;
    rdfs:comment 'Probability of Default (PD) for this loan under this stress scenario, expressed as a decimal. Calculated by applying scenario-specific PD multipliers and macroeconomic shocks to baseline PD models.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stressedRwa rdf:type rdf:Property ;
    rdfs:label 'Stressed Rwa' ;
    rdfs:comment 'Risk-Weighted Assets (RWA) calculated for this loan under this stress scenario. Used for regulatory capital adequacy stress testing (CCAR/DFAST).' ;
    rdfs:domain ind:StressProjection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stressTestResultId rdf:type rdf:Property ;
    rdfs:label 'Stress Test Result Id' ;
    rdfs:comment 'Unique identifier for this loan-scenario stress test result record. Primary key.' ;
    rdfs:domain ind:StressTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scenarioApplicationDate rdf:type rdf:Property ;
    rdfs:label 'Scenario Application Date' ;
    rdfs:comment 'Date when this stress scenario was applied to this loan account for stress testing. Represents the as-of date for the stress calculation. Critical for time-series analysis of stress test results across quarters.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scenarioImpactCategory rdf:type rdf:Property ;
    rdfs:label 'Scenario Impact Category' ;
    rdfs:comment 'Categorical classification of the stress impact on this loan: minimal (ECL increase <10%), moderate (10-25%), severe (25-50%), critical (>50%). Used for risk reporting and identification of loans most vulnerable to stress scenarios.' ;
    rdfs:domain ind:StressTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stressedExposureAmount rdf:type rdf:Property ;
    rdfs:label 'Stressed Exposure Amount' ;
    rdfs:comment 'Projected exposure at default (EAD) for this loan under this stress scenario. Incorporates assumed drawdowns on committed facilities and accrued interest under stress. Used as the base for ECL calculation.' ;
    rdfs:domain ind:StressTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:portfolioServicingId rdf:type rdf:Property ;
    rdfs:label 'Portfolio Servicing Id' ;
    rdfs:comment 'Unique identifier for this portfolio-branch servicing relationship record. Primary key.' ;
    rdfs:domain ind:PortfolioServicing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryContactEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Employee Id' ;
    rdfs:comment 'Reference to the employee at this branch who serves as the primary contact for this portfolio. Specific to this portfolio-branch combination.' ;
    rdfs:domain ind:PortfolioServicing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:portfolioServicingStatus rdf:type rdf:Property ;
    rdfs:label 'Portfolio Servicing Status' ;
    rdfs:comment 'Current status of this servicing relationship: active (currently servicing), suspended (temporarily inactive), terminated (permanently ended), pending (awaiting activation).' ;
    rdfs:domain ind:PortfolioServicing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceLevelTier rdf:type rdf:Property ;
    rdfs:label 'Service Level Tier' ;
    rdfs:comment 'Service level agreement tier for this portfolio at this specific branch. May vary by branch based on local capabilities and client preferences.' ;
    rdfs:domain ind:PortfolioServicing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:servicingEndDate rdf:type rdf:Property ;
    rdfs:label 'Servicing End Date' ;
    rdfs:comment 'Date when this branch ceased providing services to this portfolio. Null for active servicing relationships.' ;
    rdfs:domain ind:PortfolioServicing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:servicingStartDate rdf:type rdf:Property ;
    rdfs:label 'Servicing Start Date' ;
    rdfs:comment 'Date when this branch began providing services to this portfolio. Tracks temporal validity of the servicing relationship.' ;
    rdfs:domain ind:PortfolioServicing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:servicingType rdf:type rdf:Property ;
    rdfs:label 'Servicing Type' ;
    rdfs:comment 'Classification of the servicing relationship: primary (main servicing branch), secondary (additional service location), trust (trust services), vacation (seasonal location), temporary (short-term arrangement).' ;
    rdfs:domain ind:PortfolioServicing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleValidationId rdf:type rdf:Property ;
    rdfs:label 'Rule Validation Id' ;
    rdfs:comment 'Unique identifier for this rule validation test record. Primary key for the association.' ;
    rdfs:domain ind:RuleValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:alertVolumeReviewed rdf:type rdf:Property ;
    rdfs:label 'Alert Volume Reviewed' ;
    rdfs:comment 'Number of alerts generated by this monitoring rule that were sampled and reviewed during the audit engagement. Explicitly identified in detection reasoning.' ;
    rdfs:domain ind:RuleValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:falsePositiveRateObserved rdf:type rdf:Property ;
    rdfs:label 'False Positive Rate Observed' ;
    rdfs:comment 'Percentage of alerts generated by this rule during the audit period that were determined to be false positives, as measured during engagement testing. Explicitly identified in detection reasoning.' ;
    rdfs:domain ind:RuleValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ruleEffectivenessRating rdf:type rdf:Property ;
    rdfs:label 'Rule Effectiveness Rating' ;
    rdfs:comment 'Audit assessment of the monitoring rule\'s effectiveness in detecting the intended risk scenarios during the engagement testing period. Explicitly identified in detection reasoning.' ;
    rdfs:domain ind:RuleValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tuningRecommendations rdf:type rdf:Property ;
    rdfs:label 'Tuning Recommendations' ;
    rdfs:comment 'Auditor recommendations for threshold adjustments, logic refinements, or parameter changes to improve rule effectiveness or reduce false positives. Explicitly identified in detection reasoning.' ;
    rdfs:domain ind:RuleValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationMethodology rdf:type rdf:Property ;
    rdfs:label 'Validation Methodology' ;
    rdfs:comment 'Audit testing approach used to validate this rule during the engagement (e.g., transaction sampling, back-testing, scenario analysis, model validation). Explicitly identified in detection reasoning.' ;
    rdfs:domain ind:RuleValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageId rdf:type rdf:Property ;
    rdfs:label 'Coverage Id' ;
    rdfs:comment 'Unique identifier for this audit coverage record. Primary key.' ;
    rdfs:domain ind:Coverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualTestHours rdf:type rdf:Property ;
    rdfs:label 'Actual Test Hours' ;
    rdfs:comment 'Actual audit hours expended testing this specific obligation within this engagement. Used for variance analysis and future planning.' ;
    rdfs:domain ind:Coverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditScopeDescription rdf:type rdf:Property ;
    rdfs:label 'Audit Scope Description' ;
    rdfs:comment 'Detailed description of how this specific obligation is scoped and tested within this engagement, including specific controls tested, sample sizes, time periods covered, and any scope limitations.' ;
    rdfs:domain ind:Coverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageStatus rdf:type rdf:Property ;
    rdfs:label 'Coverage Status' ;
    rdfs:comment 'Current status of this coverage record: planned (scheduled but not started), in progress (testing underway), completed (testing finished), deferred (postponed to future engagement), or cancelled (removed from scope).' ;
    rdfs:domain ind:Coverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextTestDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Test Due Date' ;
    rdfs:comment 'The scheduled date when this obligation must be tested again, based on the testing frequency and risk rating. Used for audit planning and coverage gap analysis.' ;
    rdfs:domain ind:Coverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedTestHours rdf:type rdf:Property ;
    rdfs:label 'Planned Test Hours' ;
    rdfs:comment 'Budgeted audit hours allocated to testing this specific obligation within this engagement. Used for resource planning and variance analysis.' ;
    rdfs:domain ind:Coverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:testFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Test Frequency Months' ;
    rdfs:comment 'The required testing frequency for this obligation in months (e.g., 12 for annual, 36 for triennial). Drives audit planning and coverage scheduling.' ;
    rdfs:domain ind:Coverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:testResult rdf:type rdf:Property ;
    rdfs:label 'Test Result' ;
    rdfs:comment 'The outcome of testing this obligation within this engagement: compliant, non-compliant, partially compliant, not tested, or in progress.' ;
    rdfs:domain ind:Coverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limitAllocationId rdf:type rdf:Property ;
    rdfs:label 'Limit Allocation Id' ;
    rdfs:comment 'Unique surrogate identifier for each party-limit allocation record. Primary key for the limit allocation association.' ;
    rdfs:domain ind:LimitAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Approving Employee Id' ;
    rdfs:comment 'Surrogate identifier of the risk officer or credit committee member who approved this specific allocation. Supports accountability and audit requirements.' ;
    rdfs:domain ind:LimitAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:allocatedLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Allocated Limit Amount' ;
    rdfs:comment 'The specific limit amount allocated to this party for this limit type. May differ from the master limit amount in risk_limit when the limit is subdivided across multiple counterparties.' ;
    rdfs:domain ind:LimitAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationCurrency rdf:type rdf:Property ;
    rdfs:label 'Allocation Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which this allocation amount is denominated. May differ from master limit currency for multi-currency counterparty management.' ;
    rdfs:domain ind:LimitAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerUnitRegisterId rdf:type rdf:Property ;
    rdfs:label 'Customer Unit Register Id' ;
    rdfs:comment 'Primary key for customer_unit_register' ;
    rdfs:domain ind:CustomerUnitRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unitRegisterId rdf:type rdf:Property ;
    rdfs:label 'Unit Register Id' ;
    rdfs:comment 'Unique identifier for this investor position record. Primary key for the unit register.' ;
    rdfs:domain ind:CustomerUnitRegister ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssetUnitRegister .

ind:stressTestFactorResultId rdf:type rdf:Property ;
    rdfs:label 'Stress Test Factor Result Id' ;
    rdfs:comment 'Unique surrogate identifier for each stress test factor result record. Primary key for this association.' ;
    rdfs:domain ind:StressTestFactorResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contributionToCapitalImpact rdf:type rdf:Property ;
    rdfs:label 'Contribution To Capital Impact' ;
    rdfs:comment 'The marginal contribution of this risk factor to the overall change in capital ratios (CET1, Tier 1, Total Capital) under this stress scenario. Expressed in the same currency as the stress test run. Used for factor attribution analysis.' ;
    rdfs:domain ind:StressTestFactorResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contributionToEclImpact rdf:type rdf:Property ;
    rdfs:label 'Contribution To Ecl Impact' ;
    rdfs:comment 'The marginal contribution of this risk factor to the change in Expected Credit Loss (ECL) under this stress scenario. Expressed in the same currency as the stress test run. Critical for CECL and IFRS 9 stress testing.' ;
    rdfs:domain ind:StressTestFactorResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contributionToRwaImpact rdf:type rdf:Property ;
    rdfs:label 'Contribution To Rwa Impact' ;
    rdfs:comment 'The marginal contribution of this risk factor to the change in Risk-Weighted Assets (RWA) under this stress scenario. Expressed in the same currency as the stress test run. Required for Basel III regulatory attribution.' ;
    rdfs:domain ind:StressTestFactorResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:factorLoading rdf:type rdf:Property ;
    rdfs:label 'Factor Loading' ;
    rdfs:comment 'The portfolio exposure or loading to this risk factor at the as-of date of the stress test. Represents the dollar exposure, duration, or beta depending on the risk factor type. Used to calculate the factor contribution from sensitivity and shock size.' ;
    rdfs:domain ind:StressTestFactorResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modelVersionUsed rdf:type rdf:Property ;
    rdfs:label 'Model Version Used' ;
    rdfs:comment 'Version identifier of the risk model that produced this factor-level result. May differ from the overall stress test run model version if factor-level models are versioned independently. Required for model risk management and validation.' ;
    rdfs:domain ind:StressTestFactorResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sensitivityCoefficient rdf:type rdf:Property ;
    rdfs:label 'Sensitivity Coefficient' ;
    rdfs:comment 'The partial derivative or sensitivity coefficient measuring the rate of change in the stress test output (capital, RWA, ECL) with respect to a unit change in this risk factor. Used for marginal sensitivity analysis and model validation.' ;
    rdfs:domain ind:StressTestFactorResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shockDirection rdf:type rdf:Property ;
    rdfs:label 'Shock Direction' ;
    rdfs:comment 'The direction of the shock applied to this risk factor in this stress scenario. Values: up (factor increased), down (factor decreased), neutral (no shock applied to this factor in this scenario).' ;
    rdfs:domain ind:StressTestFactorResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shockMagnitude rdf:type rdf:Property ;
    rdfs:label 'Shock Magnitude' ;
    rdfs:comment 'The magnitude of the shock applied to this risk factor in this stress scenario, expressed in the units appropriate to the factor (basis points for rates, percentage for equity indices, etc.). Derived from the scenario definition but stored here for attribution transparency.' ;
    rdfs:domain ind:StressTestFactorResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stressedValue rdf:type rdf:Property ;
    rdfs:label 'Stressed Value' ;
    rdfs:comment 'The shocked or stressed value of this risk factor applied in this specific stress test run (e.g., shocked interest rate level, stressed credit spread, shocked equity index value). Unit depends on the risk factor type.' ;
    rdfs:domain ind:StressTestFactorResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accountPortfolioHoldingId rdf:type rdf:Property ;
    rdfs:label 'Account Portfolio Holding Id' ;
    rdfs:comment 'Primary key for account_portfolio_holding' ;
    rdfs:domain ind:AccountPortfolioHolding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:portfolioHoldingId rdf:type rdf:Property ;
    rdfs:label 'Portfolio Holding Id' ;
    rdfs:comment 'Unique system identifier for this portfolio holding record. Primary key.' ;
    rdfs:domain ind:AccountPortfolioHolding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WealthPortfolioHolding .

ind:holdingClassification rdf:type rdf:Property ;
    rdfs:label 'Holding Classification' ;
    rdfs:comment 'Portfolio management classification of this CD holding within the investment strategy. Core: long-term strategic allocation; Satellite: tactical positioning; Cash_equivalent: liquidity management component.' ;
    rdfs:domain ind:AccountPortfolioHolding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleConfigurationId rdf:type rdf:Property ;
    rdfs:label 'Rule Configuration Id' ;
    rdfs:comment 'Unique identifier for this channel-rule configuration record. Primary key.' ;
    rdfs:domain ind:RuleConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:channelSpecificThreshold rdf:type rdf:Property ;
    rdfs:label 'Channel Specific Threshold' ;
    rdfs:comment 'Threshold value tuned specifically for this channel-rule combination, overriding the default rule threshold when channel risk profiles differ (e.g., ATM may have lower velocity thresholds than mobile banking)' ;
    rdfs:domain ind:RuleConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:configurationStatus rdf:type rdf:Property ;
    rdfs:label 'Configuration Status' ;
    rdfs:comment 'Operational status of this rule on this channel: active (in production), inactive (disabled for this channel), testing (pilot mode), suspended (temporarily disabled due to performance issues)' ;
    rdfs:domain ind:RuleConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleEffectivenessScore rdf:type rdf:Property ;
    rdfs:label 'Rule Effectiveness Score' ;
    rdfs:comment 'Composite effectiveness metric (0-100) for this rule on this specific channel, calculated from channel-specific true positive rate, false positive rate, and detection coverage' ;
    rdfs:domain ind:RuleConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costAllocationId rdf:type rdf:Property ;
    rdfs:label 'Cost Allocation Id' ;
    rdfs:comment 'Unique identifier for this cost center to channel allocation relationship. Primary key.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocationAmountAnnual rdf:type rdf:Property ;
    rdfs:label 'Allocation Amount Annual' ;
    rdfs:comment 'Budgeted or actual annual cost amount allocated from this cost center to this channel in the reporting currency. Calculated as cost_center.budget_amount * allocation_percentage. Used for channel P&L reporting and profitability analysis.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costDriverMetric rdf:type rdf:Property ;
    rdfs:label 'Cost Driver Metric' ;
    rdfs:comment 'The specific business metric or cost driver used to determine the allocation percentage for activity-based costing methods (e.g., transaction_count, customer_count, FTE_count, square_feet, server_hours). Null for direct allocation methods.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costDriverValue rdf:type rdf:Property ;
    rdfs:label 'Cost Driver Value' ;
    rdfs:comment 'The quantitative value of the cost driver metric for this cost center-channel allocation (e.g., 15000 transactions, 250 FTEs, 5000 square feet). Used to calculate allocation_percentage when using activity-based methods.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryChannelFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Channel Flag' ;
    rdfs:comment 'Indicates whether this channel is the primary recipient of costs from this cost center. Used when a cost center predominantly supports one channel but has minor allocations to others. Supports simplified reporting and primary cost center assignment for channels.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:custodyMandateId rdf:type rdf:Property ;
    rdfs:label 'Custody Mandate Id' ;
    rdfs:comment 'Unique identifier for this custody mandate arrangement. Primary key.' ;
    rdfs:domain ind:CustodyMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:arrangementEndDate rdf:type rdf:Property ;
    rdfs:label 'Arrangement End Date' ;
    rdfs:comment 'Date when this custody arrangement was terminated or the mandate was completed. Null for active arrangements.' ;
    rdfs:domain ind:CustodyMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:arrangementStartDate rdf:type rdf:Property ;
    rdfs:label 'Arrangement Start Date' ;
    rdfs:comment 'Date when this custodial account was designated to support this mandate and custody services commenced.' ;
    rdfs:domain ind:CustodyMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assetTypesHeld rdf:type rdf:Property ;
    rdfs:label 'Asset Types Held' ;
    rdfs:comment 'Comma-separated list or structured description of asset types held in this custodial account for this specific mandate (e.g., \'Equity Securities\', \'Fixed Income\', \'Cash Collateral\', \'Derivatives\'). Asset segregation by mandate is critical for regulatory compliance and client reporting.' ;
    rdfs:domain ind:CustodyMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:custodyRole rdf:type rdf:Property ;
    rdfs:label 'Custody Role' ;
    rdfs:comment 'The specific custodial role this account plays in supporting the mandate. Defines the nature of custody services provided (e.g., Primary Custodian for all deal assets, Escrow Agent for IPO proceeds, Collateral Agent for secured lending).' ;
    rdfs:domain ind:CustodyMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountPledgeId rdf:type rdf:Property ;
    rdfs:label 'Account Pledge Id' ;
    rdfs:comment 'Primary key for account_pledge' ;
    rdfs:domain ind:AccountPledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountContributionPercentage rdf:type rdf:Property ;
    rdfs:label 'Account Contribution Percentage' ;
    rdfs:comment 'The percentage of the total pledge amount that is contributed by this specific custodial account. Used when multiple accounts collectively secure a single pledge (consolidated collateral pool scenario).' ;
    rdfs:domain ind:AccountPledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accountPledgeStatus rdf:type rdf:Property ;
    rdfs:label 'Account Pledge Status' ;
    rdfs:comment 'Current status of this specific account-pledge assignment: active (currently pledged), released (returned to account), substituted (replaced with other collateral), partial_release (some quantity released), defaulted (pledge enforced).' ;
    rdfs:domain ind:AccountPledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseConditions rdf:type rdf:Property ;
    rdfs:label 'Release Conditions' ;
    rdfs:comment 'Specific conditions under which the assets from this custodial account can be released from this pledge. May vary by account due to different governing instruments or beneficiary restrictions.' ;
    rdfs:domain ind:AccountPledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationAtPledge rdf:type rdf:Property ;
    rdfs:label 'Valuation At Pledge' ;
    rdfs:comment 'The market value of the pledged assets from this account at the time of pledge inception. Used for historical LTV tracking and collateral coverage calculations specific to this account-pledge combination.' ;
    rdfs:domain ind:AccountPledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:channelEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Channel Enrollment Id' ;
    rdfs:comment 'Unique system identifier for the account-channel enrollment record. Primary key.' ;
    rdfs:domain ind:ChannelEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:channelEnrollmentStatus rdf:type rdf:Property ;
    rdfs:label 'Channel Enrollment Status' ;
    rdfs:comment 'Current lifecycle status of the account-channel enrollment. Active = channel is available for use; Suspended = temporarily disabled (e.g., fraud alert); Inactive = customer deactivated; Pending_activation = awaiting verification; Revoked = permanently disabled by bank.' ;
    rdfs:domain ind:ChannelEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deactivationReason rdf:type rdf:Property ;
    rdfs:label 'Deactivation Reason' ;
    rdfs:comment 'Reason code or description for enrollment deactivation (e.g., customer_request, fraud_alert, account_closure, security_breach). Null for active enrollments.' ;
    rdfs:domain ind:ChannelEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentChannel rdf:type rdf:Property ;
    rdfs:label 'Enrollment Channel' ;
    rdfs:comment 'Channel through which the enrollment was initiated (e.g., branch, mobile_app, web_banking, contact_center). Used to track enrollment source and self-service adoption.' ;
    rdfs:domain ind:ChannelEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredFlag rdf:type rdf:Property ;
    rdfs:label 'Preferred Flag' ;
    rdfs:comment 'Indicates whether this is the customer\'s preferred channel for interacting with this specific account. Used for routing notifications, optimizing customer experience, and channel recommendation engines.' ;
    rdfs:domain ind:ChannelEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transactionLimitOverride rdf:type rdf:Property ;
    rdfs:label 'Transaction Limit Override' ;
    rdfs:comment 'Account-specific transaction limit override for this channel, if different from the channel\'s default limit. Null indicates channel default applies. Used for high-value customers or risk-based controls.' ;
    rdfs:domain ind:ChannelEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usageCount rdf:type rdf:Property ;
    rdfs:label 'Usage Count' ;
    rdfs:comment 'Cumulative count of transactions or interactions performed on this account through this channel since enrollment. Used for channel adoption analytics and customer behavior profiling.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rmAccountAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Rm Account Assignment Id' ;
    rdfs:comment 'Unique system identifier for this relationship manager account assignment record. Primary key.' ;
    rdfs:domain ind:RmAccountAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lobContext rdf:type rdf:Property ;
    rdfs:label 'Lob Context' ;
    rdfs:comment 'Line of business context for this specific assignment, which may differ from the RM\'s primary LOB assignment if the RM provides cross-LOB coverage. Examples: commercial_banking, wealth_management, private_banking, treasury_services. Used for LOB-specific performance reporting and coverage analysis.' ;
    rdfs:domain ind:RmAccountAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rmAccountAssignmentStatus rdf:type rdf:Property ;
    rdfs:label 'Rm Account Assignment Status' ;
    rdfs:comment 'Current status of this RM account assignment. Active = currently serving; Inactive = assignment ended; Pending = scheduled future assignment; Suspended = temporarily paused (e.g., RM on leave). Determines whether this assignment is included in active portfolio counts and service routing.' ;
    rdfs:domain ind:RmAccountAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundManagementAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Fund Management Assignment Id' ;
    rdfs:comment 'Unique system identifier for the fund management assignment record. Primary key for the association.' ;
    rdfs:domain ind:FundManagementAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryManagerFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Manager Flag' ;
    rdfs:comment 'Boolean flag indicating whether this employee is the primary or lead manager for the fund (true) or a supporting team member (false). Used for regulatory disclosures, investor communications, and escalation paths. Only one employee per fund should have this flag set to true at any given time for active assignments.' ;
    rdfs:domain ind:FundManagementAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responsibilityPercentage rdf:type rdf:Property ;
    rdfs:label 'Responsibility Percentage' ;
    rdfs:comment 'The percentage of management responsibility or time allocation the employee dedicates to this fund, expressed as a decimal (e.g., 25.00 for 25%). Used in matrix organizations where employees manage multiple funds simultaneously. Supports workload balancing, capacity planning, and proportional compensation allocation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:facilityCfpAssumptionId rdf:type rdf:Property ;
    rdfs:label 'Facility Cfp Assumption Id' ;
    rdfs:comment 'Unique surrogate identifier for this facility assumption record within the contingency funding plan. Primary key.' ;
    rdfs:domain ind:FacilityCfpAssumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assumptionRationale rdf:type rdf:Property ;
    rdfs:label 'Assumption Rationale' ;
    rdfs:comment 'Business justification for the drawdown assumption rate applied to this facility in this stress scenario. Documents Treasury analyst reasoning based on facility type, borrower behavior, historical utilization patterns, and relationship strength.' ;
    rdfs:domain ind:FacilityCfpAssumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assumptionStatus rdf:type rdf:Property ;
    rdfs:label 'Assumption Status' ;
    rdfs:comment 'Current status of this facility assumption within the CFP. Active assumptions are used in current stress testing; superseded assumptions are retained for historical audit; excluded facilities are no longer modeled in the plan.' ;
    rdfs:domain ind:FacilityCfpAssumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contingentExposureAmount rdf:type rdf:Property ;
    rdfs:label 'Contingent Exposure Amount' ;
    rdfs:comment 'Incremental liquidity outflow expected from this facility under stress, calculated as stress utilization amount minus current drawn amount. Represents the additional funding need that must be covered by contingent liquidity sources.' ;
    rdfs:domain ind:FacilityCfpAssumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:drawdownAssumptionRate rdf:type rdf:Property ;
    rdfs:label 'Drawdown Assumption Rate' ;
    rdfs:comment 'Assumed rate at which the undrawn portion of the facility will be drawn down under the stress scenario modeled in this CFP. Expressed as a decimal (e.g., 0.75 = 75% drawdown assumption). Varies by facility type, borrower relationship strength, and stress severity.' ;
    rdfs:domain ind:FacilityCfpAssumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planInclusionDate rdf:type rdf:Property ;
    rdfs:label 'Plan Inclusion Date' ;
    rdfs:comment 'Date on which this facility was included in the contingency funding plan stress modeling. Tracks when the assumption was established and supports audit trail for CFP updates.' ;
    rdfs:domain ind:FacilityCfpAssumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:stressUtilizationAmount rdf:type rdf:Property ;
    rdfs:label 'Stress Utilization Amount' ;
    rdfs:comment 'Projected total outstanding amount for this facility under the stress scenario, calculated as current drawn amount plus (undrawn amount × drawdown assumption rate). Represents the contingent liquidity demand from this facility.' ;
    rdfs:domain ind:FacilityCfpAssumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fundRiskExposureId rdf:type rdf:Property ;
    rdfs:label 'Fund Risk Exposure Id' ;
    rdfs:comment 'Unique surrogate identifier for each fund-risk factor exposure record. Primary key for the association.' ;
    rdfs:domain ind:FundRiskExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contributionToVar rdf:type rdf:Property ;
    rdfs:label 'Contribution To Var' ;
    rdfs:comment 'The marginal contribution of this specific risk factor to the fund\'s total Value at Risk (VaR). Calculated using partial derivatives and correlation structure. Expressed in base currency units.' ;
    rdfs:domain ind:FundRiskExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:factorExposureAmount rdf:type rdf:Property ;
    rdfs:label 'Factor Exposure Amount' ;
    rdfs:comment 'Absolute exposure amount of the fund to this risk factor, expressed in the fund\'s base currency. Represents the notional or market value of positions driven by this risk factor.' ;
    rdfs:domain ind:FundRiskExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:factorSensitivity rdf:type rdf:Property ;
    rdfs:label 'Factor Sensitivity' ;
    rdfs:comment 'Quantitative sensitivity of the fund\'s portfolio value to a unit change in the risk factor. For interest rate risk this is DV01 (dollar value of 1 basis point), for equity risk this is delta, for FX risk this is FX delta. Expressed in base currency units per unit change in the risk factor.' ;
    rdfs:domain ind:FundRiskExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hedgeRatio rdf:type rdf:Property ;
    rdfs:label 'Hedge Ratio' ;
    rdfs:comment 'The proportion of the risk factor exposure that is hedged through derivatives or offsetting positions. Expressed as a decimal (0.0 = unhedged, 1.0 = fully hedged). Used for net exposure calculation and hedge effectiveness monitoring.' ;
    rdfs:domain ind:FundRiskExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stressScenarioImpact rdf:type rdf:Property ;
    rdfs:label 'Stress Scenario Impact' ;
    rdfs:comment 'The estimated profit or loss impact on the fund if the risk factor experiences the regulatory stress scenario shock defined in the risk_factor master. Expressed in base currency units. Used for FRTB stressed VaR and scenario analysis.' ;
    rdfs:domain ind:FundRiskExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:constituentId rdf:type rdf:Property ;
    rdfs:label 'Constituent Id' ;
    rdfs:comment 'Unique identifier for this index constituent membership record. Primary key.' ;
    rdfs:domain ind:Constituent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:modelDeploymentId rdf:type rdf:Property ;
    rdfs:label 'Model Deployment Id' ;
    rdfs:comment 'Unique surrogate identifier for this model deployment record' ;
    rdfs:domain ind:ModelDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deploymentDate rdf:type rdf:Property ;
    rdfs:label 'Deployment Date' ;
    rdfs:comment 'Date on which the IRB model was deployed to this legal entity for production use in credit risk estimation and capital calculation' ;
    rdfs:domain ind:ModelDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deploymentStatus rdf:type rdf:Property ;
    rdfs:label 'Deployment Status' ;
    rdfs:comment 'Current operational status of this model deployment. ACTIVE = in production use, INACTIVE = approved but not yet implemented, SUSPENDED = temporarily disabled pending review, DECOMMISSIONED = permanently retired' ;
    rdfs:domain ind:ModelDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exposureAtDeployment rdf:type rdf:Property ;
    rdfs:label 'Exposure At Deployment' ;
    rdfs:comment 'Total credit exposure (EAD) in this legal entity covered by this model deployment at the time of initial deployment, used for tracking model coverage and materiality' ;
    rdfs:domain ind:ModelDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:portfolioScope rdf:type rdf:Property ;
    rdfs:label 'Portfolio Scope' ;
    rdfs:comment 'Description of the credit portfolio scope within this legal entity to which the IRB model applies (e.g., \'North American Corporate Lending\', \'Retail Mortgages - Prime\', \'SME Commercial Real Estate\')' ;
    rdfs:domain ind:ModelDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryComments rdf:type rdf:Property ;
    rdfs:label 'Regulatory Comments' ;
    rdfs:comment 'Free-text field capturing any conditions, limitations, or comments from the prudential supervisor regarding this specific model-entity deployment' ;
    rdfs:domain ind:ModelDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portfolioBrokerRelationshipId rdf:type rdf:Property ;
    rdfs:label 'Portfolio Broker Relationship Id' ;
    rdfs:comment 'Unique identifier for this portfolio-broker relationship record. Primary key.' ;
    rdfs:domain ind:PortfolioBrokerRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastTradeDate rdf:type rdf:Property ;
    rdfs:label 'Last Trade Date' ;
    rdfs:comment 'Date of the most recent trade executed by this broker for this portfolio, used for relationship monitoring and broker panel review.' ;
    rdfs:domain ind:PortfolioBrokerRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:portfolioBrokerRelationshipStatus rdf:type rdf:Property ;
    rdfs:label 'Portfolio Broker Relationship Status' ;
    rdfs:comment 'Current operational status of this portfolio-broker relationship: active (approved for trading), suspended (temporarily inactive), terminated (relationship ended), or pending_approval (under review).' ;
    rdfs:domain ind:PortfolioBrokerRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredAssetClasses rdf:type rdf:Property ;
    rdfs:label 'Preferred Asset Classes' ;
    rdfs:comment 'Comma-separated list of asset classes for which this broker is preferred or approved for execution within this specific portfolio (e.g., equities, fixed_income, derivatives). May be a subset of the broker\'s overall eligible asset classes based on portfolio strategy and broker expertise.' ;
    rdfs:domain ind:PortfolioBrokerRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ytdCommissionPaid rdf:type rdf:Property ;
    rdfs:label 'Ytd Commission Paid' ;
    rdfs:comment 'Total commission fees paid to this broker for trades executed on behalf of this portfolio in the current calendar year.' ;
    rdfs:domain ind:PortfolioBrokerRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ytdTradeVolume rdf:type rdf:Property ;
    rdfs:label 'Ytd Trade Volume' ;
    rdfs:comment 'Total notional value of trades executed by this broker for this portfolio in the current calendar year, used for commission analysis and broker panel rebalancing.' ;
    rdfs:domain ind:PortfolioBrokerRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:portfolioAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Portfolio Assignment Id' ;
    rdfs:comment 'Unique identifier for the portfolio assignment record. Primary key.' ;
    rdfs:domain ind:PortfolioAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryContactFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Flag' ;
    rdfs:comment 'Indicates whether this employee is the primary client contact for this portfolio. Only one employee per portfolio should have this flag set to true at any time.' ;
    rdfs:domain ind:PortfolioAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:portfolioStressApplicationId rdf:type rdf:Property ;
    rdfs:label 'Portfolio Stress Application Id' ;
    rdfs:comment 'Unique surrogate identifier for this portfolio stress test application record. Primary key.' ;
    rdfs:domain ind:PortfolioStressApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capitalImpact rdf:type rdf:Property ;
    rdfs:label 'Capital Impact' ;
    rdfs:comment 'The estimated capital impact (loss or gain) on the firm\'s regulatory capital resulting from this portfolio\'s performance under this stress scenario. Used for CCAR/DFAST capital adequacy calculations.' ;
    rdfs:domain ind:PortfolioStressApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:portfolioScopeFlag rdf:type rdf:Property ;
    rdfs:label 'Portfolio Scope Flag' ;
    rdfs:comment 'Boolean flag indicating whether this portfolio is in scope for this particular stress scenario run. True = portfolio included in regulatory submission, False = portfolio excluded or out of scope.' ;
    rdfs:domain ind:PortfolioStressApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stressedPortfolioValue rdf:type rdf:Property ;
    rdfs:label 'Stressed Portfolio Value' ;
    rdfs:comment 'The projected market value of the portfolio under this stress scenario at the scenario horizon, expressed in the portfolio\'s base currency. Represents the stressed AUM after applying scenario shocks.' ;
    rdfs:domain ind:PortfolioStressApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stressedReturn rdf:type rdf:Property ;
    rdfs:label 'Stressed Return' ;
    rdfs:comment 'The portfolio return (percentage) under this stress scenario over the scenario horizon. Calculated as (stressed_portfolio_value - baseline_value) / baseline_value.' ;
    rdfs:domain ind:PortfolioStressApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:submissionFlag rdf:type rdf:Property ;
    rdfs:label 'Submission Flag' ;
    rdfs:comment 'Boolean flag indicating whether this portfolio-scenario result was included in the regulatory submission to the Fed/OCC/EBA. True = included in official submission.' ;
    rdfs:domain ind:PortfolioStressApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:programStepId rdf:type rdf:Property ;
