    rdfs:range ind:Card .

ind:atmWithdrawalEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Atm Withdrawal Enabled Flag' ;
    rdfs:comment 'Indicates whether the card is enabled for cash withdrawals at ATMs.' ;
    rdfs:domain ind:Card ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:binNumber rdf:type rdf:Property ;
    rdfs:label 'Bin Number' ;
    rdfs:comment 'The first six digits of the card number identifying the issuing institution and card type. Also known as Issuer Identification Number (IIN).' ;
    rdfs:domain ind:Card ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardBrand rdf:type rdf:Property ;
    rdfs:label 'Card Brand' ;
    rdfs:comment 'The payment network brand associated with the card, determining routing and acceptance.' ;
    rdfs:domain ind:Card ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardDeliveryAddress rdf:type rdf:Property ;
    rdfs:label 'Card Delivery Address' ;
    rdfs:comment 'The address to which the physical card was delivered or is registered for delivery.' ;
    rdfs:domain ind:Card ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardDeliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Card Delivery Method' ;
    rdfs:comment 'The method by which the physical or digital card was delivered to the cardholder.' ;
    rdfs:domain ind:Card ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardDesignCode rdf:type rdf:Property ;
    rdfs:label 'Card Design Code' ;
    rdfs:comment 'Code identifying the visual design or theme applied to the physical card (e.g., standard, premium, custom image).' ;
    rdfs:domain ind:Card ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardNumber rdf:type rdf:Property ;
    rdfs:label 'Card Number' ;
    rdfs:comment 'The 16-digit primary account number (PAN) embossed on the card. Uniquely identifies the card for payment processing.' ;
    rdfs:domain ind:Card ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardProductCode rdf:type rdf:Property ;
    rdfs:label 'Card Product Code' ;
    rdfs:comment 'Internal product code identifying the specific card program or product offering (e.g., platinum rewards, student card).' ;
    rdfs:domain ind:Card ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardStatus rdf:type rdf:Property ;
    rdfs:label 'Card Status' ;
    rdfs:comment 'Current lifecycle status of the card indicating its operational state and usability for transactions.' ;
    rdfs:domain ind:Card ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardholderName rdf:type rdf:Property ;
    rdfs:label 'Cardholder Name' ;
    rdfs:comment 'The name of the individual or entity to whom the card is issued, as embossed on the card.' ;
    rdfs:domain ind:Card ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chipEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Chip Enabled Flag' ;
    rdfs:comment 'Indicates whether the card is equipped with an EMV chip for secure chip-and-PIN or chip-and-signature transactions.' ;
    rdfs:domain ind:Card ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contactlessEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Contactless Enabled Flag' ;
    rdfs:comment 'Indicates whether the card supports contactless (NFC) payment transactions.' ;
    rdfs:domain ind:Card ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cvvHash rdf:type rdf:Property ;
    rdfs:label 'Cvv Hash' ;
    rdfs:comment 'Hashed representation of the card verification value used for card-not-present transactions. Actual CVV is never stored per PCI DSS.' ;
    rdfs:domain ind:Card ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:embossingName rdf:type rdf:Property ;
    rdfs:label 'Embossing Name' ;
    rdfs:comment 'The name physically embossed or printed on the card, which may differ slightly from the legal cardholder name for display purposes.' ;
    rdfs:domain ind:Card ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudAlertFlag rdf:type rdf:Property ;
    rdfs:label 'Fraud Alert Flag' ;
    rdfs:comment 'Indicates whether the card has been flagged for potential fraudulent activity and is under enhanced monitoring.' ;
    rdfs:domain ind:Card ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:internationalUsageEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'International Usage Enabled Flag' ;
    rdfs:comment 'Indicates whether the card is enabled for international transactions outside the issuing country.' ;
    rdfs:domain ind:Card ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuingBranchCode rdf:type rdf:Property ;
    rdfs:label 'Issuing Branch Code' ;
    rdfs:comment 'Code identifying the branch or business unit that issued the card.' ;
    rdfs:domain ind:Card ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onlineTransactionEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Online Transaction Enabled Flag' ;
    rdfs:comment 'Indicates whether the card is enabled for online and e-commerce transactions.' ;
    rdfs:domain ind:Card ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pinSetFlag rdf:type rdf:Property ;
    rdfs:label 'Pin Set Flag' ;
    rdfs:comment 'Indicates whether a PIN has been set for this card, enabling ATM and point-of-sale transactions requiring PIN authentication.' ;
    rdfs:domain ind:Card ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:posTransactionEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Pos Transaction Enabled Flag' ;
    rdfs:comment 'Indicates whether the card is enabled for point-of-sale merchant transactions.' ;
    rdfs:domain ind:Card ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reissueReasonCode rdf:type rdf:Property ;
    rdfs:label 'Reissue Reason Code' ;
    rdfs:comment 'Code indicating the reason why the card was reissued or replaced.' ;
    rdfs:domain ind:Card ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tokenProvisionedFlag rdf:type rdf:Property ;
    rdfs:label 'Token Provisioned Flag' ;
    rdfs:comment 'Indicates whether a payment token has been provisioned for this card for use in digital wallets or tokenized payment systems.' ;
    rdfs:domain ind:Card ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:automationEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Automation Enabled Flag' ;
    rdfs:comment 'Indicates whether disclosures using this template can be generated and submitted through automated compliance workflows and systems.' ;
    rdfs:domain ind:DisclosureTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataFieldsJson rdf:type rdf:Property ;
    rdfs:label 'Data Fields Json' ;
    rdfs:comment 'JSON schema or structured definition of the data fields, sections, and validation rules required in disclosures generated from this template.' ;
    rdfs:domain ind:DisclosureTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalTemplateReference rdf:type rdf:Property ;
    rdfs:label 'External Template Reference' ;
    rdfs:comment 'Reference identifier or URL to the official regulatory template or form published by the regulatory authority (e.g., FinCEN SAR form number).' ;
    rdfs:domain ind:DisclosureTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingDeadlineDays rdf:type rdf:Property ;
    rdfs:label 'Filing Deadline Days' ;
    rdfs:comment 'Number of days from the triggering event or period end by which the disclosure must be filed with the regulatory authority.' ;
    rdfs:domain ind:DisclosureTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastRegulatoryUpdateDate rdf:type rdf:Property ;
    rdfs:label 'Last Regulatory Update Date' ;
    rdfs:comment 'Date when the regulatory authority last updated the official requirements or format for this disclosure template.' ;
    rdfs:domain ind:DisclosureTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:multiJurisdictionFlag rdf:type rdf:Property ;
    rdfs:label 'Multi Jurisdiction Flag' ;
    rdfs:comment 'Indicates whether this disclosure template can be used for reporting across multiple regulatory jurisdictions (true) or is specific to a single jurisdiction (false).' ;
    rdfs:domain ind:DisclosureTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:relatedPolicyReference rdf:type rdf:Property ;
    rdfs:label 'Related Policy Reference' ;
    rdfs:comment 'Reference identifier or name of the internal compliance policy or procedure document that governs the use of this disclosure template.' ;
    rdfs:domain ind:DisclosureTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateDescription rdf:type rdf:Property ;
    rdfs:label 'Template Description' ;
    rdfs:comment 'Detailed description of the disclosure template including its purpose, scope, regulatory requirements, and usage guidelines.' ;
    rdfs:domain ind:DisclosureTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateOwner rdf:type rdf:Property ;
    rdfs:label 'Template Owner' ;
    rdfs:comment 'Business unit, department, or role responsible for maintaining and updating this disclosure template.' ;
    rdfs:domain ind:DisclosureTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateVersion rdf:type rdf:Property ;
    rdfs:label 'Template Version' ;
    rdfs:comment 'Version number of the disclosure template following semantic versioning to track regulatory updates and template revisions.' ;
    rdfs:domain ind:DisclosureTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delegatedFromUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Delegated From User Employee Id' ;
    rdfs:comment 'Identifier of the original approver who delegated their authority, if delegation occurred.' ;
    rdfs:domain ind:OverrideApproval ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:overrideRequestId rdf:type rdf:Property ;
    rdfs:label 'Override Request Id' ;
    rdfs:comment 'Reference to the original override request that triggered this approval workflow.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OverrideRequest .

ind:actualTurnaroundHours rdf:type rdf:Property ;
    rdfs:label 'Actual Turnaround Hours' ;
    rdfs:comment 'Actual elapsed time in hours from request submission to approval decision.' ;
    rdfs:domain ind:OverrideApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvalComments rdf:type rdf:Property ;
    rdfs:label 'Approval Comments' ;
    rdfs:comment 'Free-text comments provided by the approver explaining their decision rationale or conditions.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalDecision rdf:type rdf:Property ;
    rdfs:label 'Approval Decision' ;
    rdfs:comment 'The final decision rendered by the approver on the override request.' ;
    rdfs:domain ind:OverrideApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalDecisionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approval Decision Timestamp' ;
    rdfs:comment 'Date and time when the approver made their decision on the override request.' ;
    rdfs:domain ind:OverrideApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:approvalReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Approval Reference Number' ;
    rdfs:comment 'Externally visible unique reference number for this override approval, used for audit trails and customer communication.' ;
    rdfs:domain ind:OverrideApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Approval Source System' ;
    rdfs:comment 'Name of the system or application from which the override approval was processed.' ;
    rdfs:domain ind:OverrideApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedLimitValue rdf:type rdf:Property ;
    rdfs:label 'Approved Limit Value' ;
    rdfs:comment 'The new limit or threshold value approved through this override, if applicable.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approverRole rdf:type rdf:Property ;
    rdfs:label 'Approver Role' ;
    rdfs:comment 'The organizational role or authority level of the approver (e.g., Branch Manager, Regional Director, Chief Credit Officer).' ;
    rdfs:domain ind:OverrideApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditTrailRequired rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Required' ;
    rdfs:comment 'Indicates whether enhanced audit trail documentation is required for this override approval.' ;
    rdfs:domain ind:OverrideApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:delegationFlag rdf:type rdf:Property ;
    rdfs:label 'Delegation Flag' ;
    rdfs:comment 'Indicates whether the approval authority was delegated from another user or role.' ;
    rdfs:domain ind:OverrideApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:effectiveUntilTimestamp rdf:type rdf:Property ;
    rdfs:label 'Effective Until Timestamp' ;
    rdfs:comment 'Date and time when the override approval ceases to be valid.' ;
    rdfs:domain ind:OverrideApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:notificationSentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Timestamp' ;
    rdfs:comment 'Date and time when the approval decision notification was sent.' ;
    rdfs:domain ind:OverrideApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:originalLimitValue rdf:type rdf:Property ;
    rdfs:label 'Original Limit Value' ;
    rdfs:comment 'The original policy limit or threshold that was breached, requiring the override approval.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overrideAmount rdf:type rdf:Property ;
    rdfs:label 'Override Amount' ;
    rdfs:comment 'Monetary value associated with the override (e.g., amount exceeding limit, fee being waived, pricing adjustment).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overrideCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Override Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the override amount.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideReasonCode rdf:type rdf:Property ;
    rdfs:label 'Override Reason Code' ;
    rdfs:comment 'Standardized code representing the business reason for the override request.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Override Reason Description' ;
    rdfs:comment 'Detailed textual explanation of why the override was requested and the business justification.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideType rdf:type rdf:Property ;
    rdfs:label 'Override Type' ;
    rdfs:comment 'Classification of the type of override being approved (e.g., limit breach, policy exception, pricing override).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestSubmittedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Request Submitted Timestamp' ;
    rdfs:comment 'Date and time when the override request was originally submitted for approval.' ;
    rdfs:domain ind:OverrideApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:serviceLevelAgreementHours rdf:type rdf:Property ;
    rdfs:label 'Service Level Agreement Hours' ;
    rdfs:comment 'Target number of hours within which the override approval decision should be made per service level agreement.' ;
    rdfs:domain ind:OverrideApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:journeyTemplateId rdf:type rdf:Property ;
    rdfs:label 'Journey Template Id' ;
    rdfs:comment 'Primary key for journey_template' ;
    rdfs:domain ind:JourneyTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:abandonmentRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Abandonment Rate Percentage' ;
    rdfs:comment 'Percentage of journey instances based on this template that were abandoned by customers before completion.' ;
    rdfs:domain ind:JourneyTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accessibilityCompliant rdf:type rdf:Property ;
    rdfs:label 'Accessibility Compliant' ;
    rdfs:comment 'Indicates whether this journey template meets accessibility standards for customers with disabilities (e.g., WCAG 2.1).' ;
    rdfs:domain ind:JourneyTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:apiIntegrationEnabled rdf:type rdf:Property ;
    rdfs:label 'Api Integration Enabled' ;
    rdfs:comment 'Indicates whether this journey template supports API or open banking integration for third-party access.' ;
    rdfs:domain ind:JourneyTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:authenticationRequired rdf:type rdf:Property ;
    rdfs:label 'Authentication Required' ;
    rdfs:comment 'Indicates whether customer authentication is required to initiate this journey.' ;
    rdfs:domain ind:JourneyTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:averageCompletionMinutes rdf:type rdf:Property ;
    rdfs:label 'Average Completion Minutes' ;
    rdfs:comment 'Average actual time in minutes taken by customers to complete journeys based on this template.' ;
    rdfs:domain ind:JourneyTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceFramework rdf:type rdf:Property ;
    rdfs:label 'Compliance Framework' ;
    rdfs:comment 'Applicable regulatory compliance frameworks that govern this journey template (e.g., KYC, AML, GDPR, PCI-DSS).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentRequired rdf:type rdf:Property ;
    rdfs:label 'Consent Required' ;
    rdfs:comment 'Indicates whether explicit customer consent is required during this journey for data processing or marketing purposes.' ;
    rdfs:domain ind:JourneyTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:digitalSignatureRequired rdf:type rdf:Property ;
    rdfs:label 'Digital Signature Required' ;
    rdfs:comment 'Indicates whether digital signature or electronic signature is required for legal binding in this journey.' ;
    rdfs:domain ind:JourneyTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Estimated Duration Minutes' ;
    rdfs:comment 'Expected time in minutes for a customer to complete the journey based on this template.' ;
    rdfs:domain ind:JourneyTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:journeyStageCount rdf:type rdf:Property ;
    rdfs:label 'Journey Stage Count' ;
    rdfs:comment 'Total number of stages or steps defined in this journey template.' ;
    rdfs:domain ind:JourneyTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:multiLanguageSupported rdf:type rdf:Property ;
    rdfs:label 'Multi Language Supported' ;
    rdfs:comment 'Indicates whether this journey template supports multiple languages for international or diverse customer bases.' ;
    rdfs:domain ind:JourneyTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:omnichannelEnabled rdf:type rdf:Property ;
    rdfs:label 'Omnichannel Enabled' ;
    rdfs:comment 'Indicates whether this journey template supports omnichannel orchestration allowing customers to switch channels mid-journey.' ;
    rdfs:domain ind:JourneyTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ownerBusinessUnit rdf:type rdf:Property ;
    rdfs:label 'Owner Business Unit' ;
    rdfs:comment 'Business unit or department responsible for maintaining and governing this journey template.' ;
    rdfs:domain ind:JourneyTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryComplianceRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Required' ;
    rdfs:comment 'Indicates whether this journey template includes mandatory regulatory compliance steps (e.g., KYC, AML, disclosure requirements).' ;
    rdfs:domain ind:JourneyTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:successRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Success Rate Percentage' ;
    rdfs:comment 'Percentage of journey instances based on this template that were successfully completed by customers.' ;
    rdfs:domain ind:JourneyTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:apiIntegrationMethod rdf:type rdf:Property ;
    rdfs:label 'Api Integration Method' ;
    rdfs:comment 'Technical integration method used to connect with the third party providers services.' ;
    rdfs:domain ind:ThirdPartyProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessContinuityPlanFlag rdf:type rdf:Property ;
    rdfs:label 'Business Continuity Plan Flag' ;
    rdfs:comment 'Indicates whether the third party provider has a documented and tested business continuity plan.' ;
    rdfs:domain ind:ThirdPartyProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractRenewalDate rdf:type rdf:Property ;
    rdfs:label 'Contract Renewal Date' ;
    rdfs:comment 'Next scheduled date for contract renewal review with the third party provider.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dataProcessingAgreementFlag rdf:type rdf:Property ;
    rdfs:label 'Data Processing Agreement Flag' ;
    rdfs:comment 'Indicates whether a formal data processing agreement is in place with the third party provider.' ;
    rdfs:domain ind:ThirdPartyProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataResidencyCountryCode rdf:type rdf:Property ;
    rdfs:label 'Data Residency Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code indicating where the third party provider stores and processes data.' ;
    rdfs:domain ind:ThirdPartyProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextAuditDate rdf:type rdf:Property ;
    rdfs:label 'Next Audit Date' ;
    rdfs:comment 'Scheduled date for the next audit or assessment of the third party provider.' ;
    rdfs:domain ind:ThirdPartyProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentTermsDays rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Days' ;
    rdfs:comment 'Number of days within which payment is due to the third party provider from invoice date.' ;
    rdfs:domain ind:ThirdPartyProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preferredCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Preferred Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for financial transactions with the third party provider.' ;
    rdfs:domain ind:ThirdPartyProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:providerType rdf:type rdf:Property ;
    rdfs:label 'Provider Type' ;
    rdfs:comment 'Classification of the third party provider based on the service category they provide to the bank.' ;
    rdfs:domain ind:ThirdPartyProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceLevelAgreementTier rdf:type rdf:Property ;
    rdfs:label 'Service Level Agreement Tier' ;
    rdfs:comment 'Service level agreement tier defining the performance and support commitments from the third party provider.' ;
    rdfs:domain ind:ThirdPartyProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uptimeCommitmentPercentage rdf:type rdf:Property ;
    rdfs:label 'Uptime Commitment Percentage' ;
    rdfs:comment 'Contractually committed uptime percentage for services provided by the third party provider.' ;
    rdfs:domain ind:ThirdPartyProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:counterpartyId rdf:type rdf:Property ;
    rdfs:label 'Counterparty Id' ;
    rdfs:comment 'Reference to the counterparty entity with whom this ISDA Master Agreement is executed.' ;
    rdfs:domain ind:Collateral ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:additionalTerminationEvents rdf:type rdf:Property ;
    rdfs:label 'Additional Termination Events' ;
    rdfs:comment 'Free-text description of any additional termination events specified in the Schedule to the ISDA Master Agreement beyond standard events.' ;
    rdfs:domain ind:IsdaMasterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:automaticEarlyTerminationIndicator rdf:type rdf:Property ;
    rdfs:label 'Automatic Early Termination Indicator' ;
    rdfs:comment 'Indicates whether early termination occurs automatically upon occurrence of a termination event, without requiring notice.' ;
    rdfs:domain ind:IsdaMasterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:counterpartyLegalEntityIdentifier rdf:type rdf:Property ;
    rdfs:label 'Counterparty Legal Entity Identifier' ;
    rdfs:comment 'The 20-character ISO 17442 Legal Entity Identifier of the counterparty entity to this ISDA Master Agreement.' ;
    rdfs:domain ind:Collateral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditEventUponMergerIndicator rdf:type rdf:Property ;
    rdfs:label 'Credit Event Upon Merger Indicator' ;
    rdfs:comment 'Indicates whether a merger or consolidation of the counterparty that results in credit deterioration constitutes a termination event.' ;
    rdfs:domain ind:IsdaMasterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditSupportAnnexIndicator rdf:type rdf:Property ;
    rdfs:label 'Credit Support Annex Indicator' ;
    rdfs:comment 'Indicates whether a Credit Support Annex (CSA) is attached to this ISDA Master Agreement, governing collateral posting requirements.' ;
    rdfs:domain ind:IsdaMasterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crossDefaultProvisionIndicator rdf:type rdf:Property ;
    rdfs:label 'Cross Default Provision Indicator' ;
    rdfs:comment 'Indicates whether a default under other agreements with the counterparty triggers a default under this ISDA Master Agreement.' ;
    rdfs:domain ind:IsdaMasterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crossDefaultThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Cross Default Threshold Amount' ;
    rdfs:comment 'The minimum default amount under other agreements that would trigger a cross-default event under this ISDA Master Agreement.' ;
    rdfs:domain ind:IsdaMasterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:csaType rdf:type rdf:Property ;
    rdfs:label 'Csa Type' ;
    rdfs:comment 'The type of Credit Support Annex arrangement: bilateral (both parties post collateral), one-way (only one party posts), or none (no CSA attached).' ;
    rdfs:domain ind:IsdaMasterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeResolutionPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Period Days' ;
    rdfs:comment 'The number of business days allowed for resolving valuation disputes under the ISDA Master Agreement.' ;
    rdfs:domain ind:Collateral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:earlyTerminationProvisionIndicator rdf:type rdf:Property ;
    rdfs:label 'Early Termination Provision Indicator' ;
    rdfs:comment 'Indicates whether the agreement includes provisions for early termination upon occurrence of specified events (e.g., default, credit event).' ;
    rdfs:domain ind:IsdaMasterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:initialMarginModelType rdf:type rdf:Property ;
    rdfs:label 'Initial Margin Model Type' ;
    rdfs:comment 'The methodology used to calculate initial margin requirements: Standard Initial Margin Model (SIMM), grid-based, schedule-based, or internal model.' ;
    rdfs:domain ind:IsdaMasterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:masterConfirmationAgreementIndicator rdf:type rdf:Property ;
    rdfs:label 'Master Confirmation Agreement Indicator' ;
    rdfs:comment 'Indicates whether a Master Confirmation Agreement is in place to streamline the confirmation process for specific transaction types.' ;
    rdfs:domain ind:IsdaMasterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nettingProvisionIndicator rdf:type rdf:Property ;
    rdfs:label 'Netting Provision Indicator' ;
    rdfs:comment 'Indicates whether close-out netting provisions are included in this ISDA Master Agreement, allowing offsetting of obligations upon default or termination.' ;
    rdfs:domain ind:IsdaMasterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentNettingIndicator rdf:type rdf:Property ;
    rdfs:label 'Payment Netting Indicator' ;
    rdfs:comment 'Indicates whether payments due on the same date in the same currency are netted to a single payment obligation.' ;
    rdfs:domain ind:IsdaMasterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rehypothecationRightsIndicator rdf:type rdf:Property ;
    rdfs:label 'Rehypothecation Rights Indicator' ;
    rdfs:comment 'Indicates whether the collateral taker has the right to rehypothecate (reuse) posted collateral for its own purposes.' ;
    rdfs:domain ind:IsdaMasterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specifiedEntities rdf:type rdf:Property ;
    rdfs:label 'Specified Entities' ;
    rdfs:comment 'Comma-separated list of affiliated entities whose credit events or defaults would trigger termination rights under this agreement.' ;
    rdfs:domain ind:IsdaMasterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substitutionRightsIndicator rdf:type rdf:Property ;
    rdfs:label 'Substitution Rights Indicator' ;
    rdfs:comment 'Indicates whether the collateral provider has the right to substitute posted collateral with other eligible collateral of equivalent value.' ;
    rdfs:domain ind:IsdaMasterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:variationMarginFrequency rdf:type rdf:Property ;
    rdfs:label 'Variation Margin Frequency' ;
    rdfs:comment 'The frequency at which variation margin is calculated and exchanged to reflect changes in mark-to-market exposure.' ;
    rdfs:domain ind:IsdaMasterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibilityRuleSetId rdf:type rdf:Property ;
    rdfs:label 'Eligibility Rule Set Id' ;
    rdfs:comment 'Reference to the collateral eligibility rule set that defines which asset types and criteria are acceptable for this basket.' ;
    rdfs:domain ind:CollateralBasket ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Set .

ind:basketCode rdf:type rdf:Property ;
    rdfs:label 'Basket Code' ;
    rdfs:comment 'Externally-known unique business identifier for the collateral basket used in operational systems and reporting.' ;
    rdfs:domain ind:CollateralBasket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:basketName rdf:type rdf:Property ;
    rdfs:label 'Basket Name' ;
    rdfs:comment 'Human-readable name or title of the collateral basket for identification and reporting purposes.' ;
    rdfs:domain ind:CollateralBasket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:basketStatus rdf:type rdf:Property ;
    rdfs:label 'Basket Status' ;
    rdfs:comment 'Current lifecycle status of the collateral basket indicating its operational state.' ;
    rdfs:domain ind:CollateralBasket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:basketType rdf:type rdf:Property ;
    rdfs:label 'Basket Type' ;
    rdfs:comment 'Classification of the collateral basket by its primary business purpose or transaction type.' ;
    rdfs:domain ind:CollateralBasket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumCollateralValue rdf:type rdf:Property ;
    rdfs:label 'Minimum Collateral Value' ;
    rdfs:comment 'Minimum required collateral value that must be maintained in the basket to meet margin or coverage requirements.' ;
    rdfs:domain ind:CollateralBasket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalAdjustedValue rdf:type rdf:Property ;
    rdfs:label 'Total Adjusted Value' ;
    rdfs:comment 'Total collateral value after applying haircuts and adjustments, representing the effective collateral coverage.' ;
    rdfs:domain ind:CollateralBasket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalMarketValue rdf:type rdf:Property ;
    rdfs:label 'Total Market Value' ;
    rdfs:comment 'Current aggregate market value of all collateral assets held within the basket, expressed in the basket currency.' ;
    rdfs:domain ind:CollateralBasket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sanctionsListEntryId rdf:type rdf:Property ;
    rdfs:label 'Sanctions List Entry Id' ;
    rdfs:comment 'Primary key for sanctions_list_entry' ;
    rdfs:domain ind:SanctionsListEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:aircraftManufacturer rdf:type rdf:Property ;
    rdfs:label 'Aircraft Manufacturer' ;
    rdfs:comment 'Manufacturer name of sanctioned aircraft. Null for non-aircraft entries.' ;
    rdfs:domain ind:SanctionsListEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aircraftModel rdf:type rdf:Property ;
    rdfs:label 'Aircraft Model' ;
    rdfs:comment 'Model designation of sanctioned aircraft. Null for non-aircraft entries.' ;
    rdfs:domain ind:SanctionsListEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aircraftTailNumber rdf:type rdf:Property ;
    rdfs:label 'Aircraft Tail Number' ;
    rdfs:comment 'Registration or tail number of sanctioned aircraft. Null for non-aircraft entries.' ;
    rdfs:domain ind:SanctionsListEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aliasNames rdf:type rdf:Property ;
    rdfs:label 'Alias Names' ;
    rdfs:comment 'Known aliases, alternate spellings, or also-known-as (AKA) names associated with the sanctioned party. Multiple aliases may be concatenated or stored as delimited text.' ;
    rdfs:domain ind:SanctionsListEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSourceTimestamp rdf:type rdf:Property ;
    rdfs:label 'Data Source Timestamp' ;
    rdfs:comment 'Timestamp indicating when the sanctions list data was last published or updated by the source authority.' ;
    rdfs:domain ind:SanctionsListEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:entryStatus rdf:type rdf:Property ;
    rdfs:label 'Entry Status' ;
    rdfs:comment 'Current lifecycle status of the sanctions list entry indicating whether it is actively enforced, removed, or under review.' ;
    rdfs:domain ind:SanctionsListEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPepIndicator rdf:type rdf:Property ;
    rdfs:label 'Is Pep Indicator' ;
    rdfs:comment 'Boolean flag indicating whether the sanctioned individual is also identified as a Politically Exposed Person (PEP) by the sanctions authority.' ;
    rdfs:domain ind:SanctionsListEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:listSourceName rdf:type rdf:Property ;
    rdfs:label 'List Source Name' ;
    rdfs:comment 'Name of the sanctions list source authority or program (e.g., OFAC SDN, UN Consolidated List, EU Sanctions List, HMT UK Sanctions List).' ;
    rdfs:domain ind:SanctionsListEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nationalIdentificationNumber rdf:type rdf:Property ;
    rdfs:label 'National Identification Number' ;
    rdfs:comment 'National ID number, tax ID, or other government-issued identification number for sanctioned individuals or entities.' ;
    rdfs:domain ind:SanctionsListEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:placeOfBirth rdf:type rdf:Property ;
    rdfs:label 'Place Of Birth' ;
    rdfs:comment 'City and country of birth for sanctioned individuals. Null for entities, vessels, and aircraft.' ;
    rdfs:domain ind:SanctionsListEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryName rdf:type rdf:Property ;
    rdfs:label 'Primary Name' ;
    rdfs:comment 'Primary legal name or designation of the sanctioned individual, entity, vessel, or aircraft as published by the sanctions authority.' ;
    rdfs:domain ind:SanctionsListEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programDescription rdf:type rdf:Property ;
    rdfs:label 'Program Description' ;
    rdfs:comment 'Full description of the sanctions program or legal authority under which the entry is designated.' ;
    rdfs:domain ind:SanctionsListEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remarks rdf:type rdf:Property ;
    rdfs:label 'Remarks' ;
    rdfs:comment 'Additional remarks, notes, or contextual information provided by the sanctions authority regarding the entry.' ;
    rdfs:domain ind:SanctionsListEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningPriority rdf:type rdf:Property ;
    rdfs:label 'Screening Priority' ;
    rdfs:comment 'Priority level assigned for real-time transaction screening and customer due diligence checks based on risk and regulatory requirements.' ;
    rdfs:domain ind:SanctionsListEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceUrl rdf:type rdf:Property ;
    rdfs:label 'Source Url' ;
    rdfs:comment 'URL or web link to the official sanctions list publication or entry detail page from the issuing authority.' ;
    rdfs:domain ind:SanctionsListEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uniqueReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Unique Reference Number' ;
    rdfs:comment 'Official unique identifier assigned by the sanctions authority to this entry (e.g., OFAC SDN number, UN reference number).' ;
    rdfs:domain ind:SanctionsListEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vesselCallSign rdf:type rdf:Property ;
    rdfs:label 'Vessel Call Sign' ;
    rdfs:comment 'Radio call sign assigned to sanctioned vessels. Null for non-vessel entries.' ;
    rdfs:domain ind:SanctionsListEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vesselFlag rdf:type rdf:Property ;
    rdfs:label 'Vessel Flag' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the flag state under which a sanctioned vessel is registered. Null for non-vessel entries.' ;
    rdfs:domain ind:SanctionsListEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vesselImoNumber rdf:type rdf:Property ;
    rdfs:label 'Vessel Imo Number' ;
    rdfs:comment 'IMO ship identification number for sanctioned vessels. Null for non-vessel entries.' ;
    rdfs:domain ind:SanctionsListEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vesselTonnage rdf:type rdf:Property ;
    rdfs:label 'Vessel Tonnage' ;
    rdfs:comment 'Gross tonnage of sanctioned vessels in metric tons. Null for non-vessel entries.' ;
    rdfs:domain ind:SanctionsListEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataSubjectId rdf:type rdf:Property ;
    rdfs:label 'Data Subject Id' ;
    rdfs:comment 'Reference to the individual (customer, employee, or other party) who submitted the data subject request.' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Subject .

ind:completedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Completed Timestamp' ;
    rdfs:comment 'Date and time when the data subject request was fully fulfilled and closed.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dataCategoriesRequested rdf:type rdf:Property ;
    rdfs:label 'Data Categories Requested' ;
    rdfs:comment 'Comma-separated list of data categories requested (e.g., personal identifiers, financial data, transaction history, communication records).' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSubjectEmail rdf:type rdf:Property ;
    rdfs:label 'Data Subject Email' ;
    rdfs:comment 'Email address of the data subject used for request correspondence and verification.' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSubjectName rdf:type rdf:Property ;
    rdfs:label 'Data Subject Name' ;
    rdfs:comment 'Full legal name of the individual who submitted the data subject request.' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSubjectPhone rdf:type rdf:Property ;
    rdfs:label 'Data Subject Phone' ;
    rdfs:comment 'Contact phone number of the data subject for request follow-up and verification.' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:extendedDueDate rdf:type rdf:Property ;
    rdfs:label 'Extended Due Date' ;
    rdfs:comment 'New deadline if an extension was granted (typically up to 60 days under GDPR, 90 days under CCPA).' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:extensionGrantedFlag rdf:type rdf:Property ;
    rdfs:label 'Extension Granted Flag' ;
    rdfs:comment 'Indicates whether a time extension was granted for complex requests (allowed under GDPR and CCPA).' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:feeChargedAmount rdf:type rdf:Property ;
    rdfs:label 'Fee Charged Amount' ;
    rdfs:comment 'Fee charged for fulfilling the request, if applicable for manifestly unfounded or excessive requests.' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recordsFoundCount rdf:type rdf:Property ;
    rdfs:label 'Records Found Count' ;
    rdfs:comment 'Total number of records found across all systems that match the data subject request criteria.' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requestStatus rdf:type rdf:Property ;
    rdfs:label 'Request Status' ;
    rdfs:comment 'Current lifecycle status of the data subject request in the fulfillment workflow.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestType rdf:type rdf:Property ;
    rdfs:label 'Request Type' ;
    rdfs:comment 'Type of data subject request: access (right to know), rectification (correction), erasure (right to be forgotten), portability (data export), restriction (processing limitation), or objection (opt-out).' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseFormat rdf:type rdf:Property ;
    rdfs:label 'Response Format' ;
    rdfs:comment 'Format in which the data was provided to the data subject (PDF, CSV, JSON, XML, or paper).' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseMethod rdf:type rdf:Property ;
    rdfs:label 'Response Method' ;
    rdfs:comment 'Method used to deliver the response to the data subject (secure portal, encrypted email, postal mail, or in-person).' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionChannel rdf:type rdf:Property ;
    rdfs:label 'Submission Channel' ;
    rdfs:comment 'Channel through which the data subject request was submitted (web portal, email, phone, postal mail, in-person, or third-party service).' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:systemsSearched rdf:type rdf:Property ;
    rdfs:label 'Systems Searched' ;
    rdfs:comment 'Comma-separated list of systems and databases searched to fulfill the request.' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartyProcessorInvolvedFlag rdf:type rdf:Property ;
    rdfs:label 'Third Party Processor Involved Flag' ;
    rdfs:comment 'Indicates whether third-party data processors were contacted to fulfill this request.' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:thirdPartyProcessors rdf:type rdf:Property ;
    rdfs:label 'Third Party Processors' ;
    rdfs:comment 'Comma-separated list of third-party data processors contacted to fulfill the request.' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingCampaignId rdf:type rdf:Property ;
    rdfs:label 'Marketing Campaign Id' ;
    rdfs:comment 'Primary key for marketing_campaign' ;
    rdfs:domain ind:MarketingCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentCampaignId rdf:type rdf:Property ;
    rdfs:label 'Parent Campaign Id' ;
    rdfs:comment 'Reference to a parent or umbrella campaign if this is a sub-campaign or variant. Nullable for standalone campaigns.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Banking .

ind:actualReach rdf:type rdf:Property ;
    rdfs:label 'Actual Reach' ;
    rdfs:comment 'Number of unique customers or prospects actually reached by the campaign.' ;
    rdfs:domain ind:MarketingCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:campaignObjective rdf:type rdf:Property ;
    rdfs:label 'Campaign Objective' ;
    rdfs:comment 'Primary business goal the campaign is designed to achieve.' ;
    rdfs:domain ind:MarketingCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignOwner rdf:type rdf:Property ;
    rdfs:label 'Campaign Owner' ;
    rdfs:comment 'Name or identifier of the marketing manager or team responsible for the campaign.' ;
    rdfs:domain ind:MarketingCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelPrimary rdf:type rdf:Property ;
    rdfs:label 'Channel Primary' ;
    rdfs:comment 'Primary communication channel used to deliver the campaign.' ;
    rdfs:domain ind:MarketingCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelSecondary rdf:type rdf:Property ;
    rdfs:label 'Channel Secondary' ;
    rdfs:comment 'Secondary or supporting communication channel used in the campaign. Nullable if single-channel.' ;
    rdfs:domain ind:MarketingCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creativeVersion rdf:type rdf:Property ;
    rdfs:label 'Creative Version' ;
    rdfs:comment 'Version identifier for the creative assets (copy, images, design) used in the campaign.' ;
    rdfs:domain ind:MarketingCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:launchedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Launched Timestamp' ;
    rdfs:comment 'Timestamp when the campaign was actually launched and became active. Nullable if not yet launched.' ;
    rdfs:domain ind:MarketingCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:offerCode rdf:type rdf:Property ;
    rdfs:label 'Offer Code' ;
    rdfs:comment 'Unique promotional code customers can use to redeem the campaign offer.' ;
    rdfs:domain ind:MarketingCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerDescription rdf:type rdf:Property ;
    rdfs:label 'Offer Description' ;
    rdfs:comment 'Detailed description of the promotional offer or value proposition presented in the campaign.' ;
    rdfs:domain ind:MarketingCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trackingUrl rdf:type rdf:Property ;
    rdfs:label 'Tracking Url' ;
    rdfs:comment 'URL with tracking parameters used to measure campaign click-through and conversions.' ;
    rdfs:domain ind:MarketingCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastUpdatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Last Updated By User Employee Id' ;
    rdfs:comment 'Identifier of the user or system that last updated the fraud ring record.' ;
    rdfs:domain ind:FraudRing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:affectedChannel rdf:type rdf:Property ;
    rdfs:label 'Affected Channel' ;
    rdfs:comment 'Primary banking channel targeted or exploited by the fraud ring.' ;
    rdfs:domain ind:FraudRing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmedDate rdf:type rdf:Property ;
    rdfs:label 'Confirmed Date' ;
    rdfs:comment 'Date when the fraud ring was confirmed as a coordinated fraud operation through investigation.' ;
    rdfs:domain ind:FraudRing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:confirmedMemberCount rdf:type rdf:Property ;
    rdfs:label 'Confirmed Member Count' ;
    rdfs:comment 'Number of confirmed members identified and verified as part of the fraud ring.' ;
    rdfs:domain ind:FraudRing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedMemberCount rdf:type rdf:Property ;
    rdfs:label 'Estimated Member Count' ;
    rdfs:comment 'Estimated number of individuals or entities participating in the fraud ring.' ;
    rdfs:domain ind:FraudRing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:firstDetectedDate rdf:type rdf:Property ;
    rdfs:label 'First Detected Date' ;
    rdfs:comment 'Date when the fraud ring activity was first detected or flagged by fraud detection systems.' ;
    rdfs:domain ind:FraudRing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:linkedCaseCount rdf:type rdf:Property ;
    rdfs:label 'Linked Case Count' ;
    rdfs:comment 'Number of individual fraud cases linked to and attributed to this fraud ring.' ;
    rdfs:domain ind:FraudRing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:modusOperandiDescription rdf:type rdf:Property ;
    rdfs:label 'Modus Operandi Description' ;
    rdfs:comment 'Detailed description of the fraud rings methods, techniques, and operational patterns.' ;
    rdfs:domain ind:FraudRing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkAnalysisCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Network Analysis Completed Flag' ;
    rdfs:comment 'Indicates whether network link analysis has been completed to map relationships within the fraud ring.' ;
    rdfs:domain ind:FraudRing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryOperatingRegion rdf:type rdf:Property ;
    rdfs:label 'Primary Operating Region' ;
    rdfs:comment 'Primary geographic region or jurisdiction where the fraud ring conducts most of its operations.' ;
    rdfs:domain ind:FraudRing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prosecutionStatus rdf:type rdf:Property ;
    rdfs:label 'Prosecution Status' ;
    rdfs:comment 'Current status of criminal prosecution proceedings against the fraud ring members.' ;
    rdfs:domain ind:FraudRing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ringIdentifierCode rdf:type rdf:Property ;
    rdfs:label 'Ring Identifier Code' ;
    rdfs:comment 'Externally-known unique code assigned to the fraud ring for cross-system reference and reporting.' ;
    rdfs:domain ind:FraudRing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ringName rdf:type rdf:Property ;
    rdfs:label 'Ring Name' ;
    rdfs:comment 'Human-readable name or label assigned to the fraud ring for identification and tracking purposes.' ;
