    rdfs:range xsd:string .

ind:trancheCode rdf:type rdf:Property ;
    rdfs:label 'Tranche Code' ;
    rdfs:comment 'Externally-known unique code or identifier for the tranche, used in deal documentation and regulatory filings.' ;
    rdfs:domain ind:Tranche ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trancheName rdf:type rdf:Property ;
    rdfs:label 'Tranche Name' ;
    rdfs:comment 'Human-readable name or label for the tranche, often indicating seniority or class (e.g., Senior Secured, Mezzanine, Class A).' ;
    rdfs:domain ind:Tranche ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trancheType rdf:type rdf:Property ;
    rdfs:label 'Tranche Type' ;
    rdfs:comment 'Classification of the tranche based on its position in the capital structure and risk profile.' ;
    rdfs:domain ind:Tranche ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:underwritingFeeRate rdf:type rdf:Property ;
    rdfs:label 'Underwriting Fee Rate' ;
    rdfs:comment 'The underwriting or arrangement fee rate charged for the tranche, expressed as a decimal percentage of principal.' ;
    rdfs:domain ind:Tranche ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:utilizationFeeRate rdf:type rdf:Property ;
    rdfs:label 'Utilization Fee Rate' ;
    rdfs:comment 'The utilization fee rate applied when drawn amounts exceed a specified threshold, expressed as a decimal.' ;
    rdfs:domain ind:Tranche ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentConsolidationGroupId rdf:type rdf:Property ;
    rdfs:label 'Parent Consolidation Group Id' ;
    rdfs:comment 'Reference to the parent consolidation group in the organizational hierarchy. Null for top-level consolidation groups. Enables multi-level consolidation structures.' ;
    rdfs:domain ind:ConsolidationGroup ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConsolidationGroup .

ind:consolidationGroupCode rdf:type rdf:Property ;
    rdfs:label 'Consolidation Group Code' ;
    rdfs:comment 'Business identifier code for the consolidation group used in financial reporting and external communications. Unique alphanumeric code following organizational standards.' ;
    rdfs:domain ind:ConsolidationGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationGroupName rdf:type rdf:Property ;
    rdfs:label 'Consolidation Group Name' ;
    rdfs:comment 'Full business name of the consolidation group as it appears in financial statements and regulatory filings.' ;
    rdfs:domain ind:ConsolidationGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationGroupType rdf:type rdf:Property ;
    rdfs:label 'Consolidation Group Type' ;
    rdfs:comment 'Classification of the consolidation group indicating the organizational dimension it represents (legal entity structure, business unit, geographic region, product line, functional area, or custom grouping).' ;
    rdfs:domain ind:ConsolidationGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationStatus rdf:type rdf:Property ;
    rdfs:label 'Consolidation Status' ;
    rdfs:comment 'Current lifecycle status of the consolidation group. Active groups are included in current period consolidation, inactive groups are excluded, pending groups are awaiting activation, suspended groups are temporarily excluded, dissolved groups are permanently closed.' ;
    rdfs:domain ind:ConsolidationGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intercompanyEliminationRequired rdf:type rdf:Property ;
    rdfs:label 'Intercompany Elimination Required' ;
    rdfs:comment 'Flag indicating whether intercompany transactions and balances must be eliminated during consolidation for this group. True for fully consolidated entities, false for equity method or non-consolidated entities.' ;
    rdfs:domain ind:ConsolidationGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jointControlIndicator rdf:type rdf:Property ;
    rdfs:label 'Joint Control Indicator' ;
    rdfs:comment 'Flag indicating whether this consolidation group is subject to joint control by multiple parties as defined by IFRS 11. True indicates joint control arrangement exists.' ;
    rdfs:domain ind:ConsolidationGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minorityInterestApplicable rdf:type rdf:Property ;
    rdfs:label 'Minority Interest Applicable' ;
    rdfs:comment 'Flag indicating whether non-controlling (minority) interest calculations are required for this consolidation group. True when ownership is less than 100% but control exists.' ;
    rdfs:domain ind:ConsolidationGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:segmentReportingCode rdf:type rdf:Property ;
    rdfs:label 'Segment Reporting Code' ;
    rdfs:comment 'Code identifying the operating segment or reportable segment to which this consolidation group belongs for IFRS 8 segment reporting purposes.' ;
    rdfs:domain ind:ConsolidationGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:significantInfluenceIndicator rdf:type rdf:Property ;
    rdfs:label 'Significant Influence Indicator' ;
    rdfs:comment 'Flag indicating whether the parent entity has significant influence over this consolidation group as defined by IAS 28. True indicates significant influence exists, typically requiring equity method accounting.' ;
    rdfs:domain ind:ConsolidationGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:soxScopeIndicator rdf:type rdf:Property ;
    rdfs:label 'Sox Scope Indicator' ;
    rdfs:comment 'Flag indicating whether this consolidation group is within the scope of Sarbanes-Oxley Act compliance and internal control testing. True for entities subject to SOX Section 404 requirements.' ;
    rdfs:domain ind:ConsolidationGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxConsolidationGroupCode rdf:type rdf:Property ;
    rdfs:label 'Tax Consolidation Group Code' ;
    rdfs:comment 'Identifier for the tax consolidation group to which this entity belongs. Used for tax reporting and consolidated tax return preparation. May differ from financial consolidation grouping.' ;
    rdfs:domain ind:ConsolidationGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentTemplateId rdf:type rdf:Property ;
    rdfs:label 'Parent Template Id' ;
    rdfs:comment 'Reference to the previous version of this task template, supporting version history and lineage tracking. Null for initial versions.' ;
    rdfs:domain ind:TaskTemplate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TaskTemplate .

ind:approvalLevelCount rdf:type rdf:Property ;
    rdfs:label 'Approval Level Count' ;
    rdfs:comment 'Number of sequential approval levels required for tasks generated from this template, supporting segregation of duties requirements.' ;
    rdfs:domain ind:TaskTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:automationEligible rdf:type rdf:Property ;
    rdfs:label 'Automation Eligible' ;
    rdfs:comment 'Indicates whether tasks created from this template are candidates for robotic process automation or system automation.' ;
    rdfs:domain ind:TaskTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:automationScriptPath rdf:type rdf:Property ;
    rdfs:label 'Automation Script Path' ;
    rdfs:comment 'File system path or repository location of the automation script or workflow definition for this task template.' ;
    rdfs:domain ind:TaskTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentRetentionYears rdf:type rdf:Property ;
    rdfs:label 'Document Retention Years' ;
    rdfs:comment 'Number of years that documentation for tasks created from this template must be retained to meet regulatory and audit requirements.' ;
    rdfs:domain ind:TaskTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:documentationRequired rdf:type rdf:Property ;
    rdfs:label 'Documentation Required' ;
    rdfs:comment 'Indicates whether supporting documentation must be attached to task instances created from this template for audit trail purposes.' ;
    rdfs:domain ind:TaskTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedDurationHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Duration Hours' ;
    rdfs:comment 'Expected time in hours required to complete a task instance created from this template, used for resource planning and scheduling.' ;
    rdfs:domain ind:TaskTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:glAccountCategory rdf:type rdf:Property ;
    rdfs:label 'Gl Account Category' ;
    rdfs:comment 'Primary financial statement category that this task template typically affects within the chart of accounts structure.' ;
    rdfs:domain ind:TaskTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instructions rdf:type rdf:Property ;
    rdfs:label 'Instructions' ;
    rdfs:comment 'Detailed step-by-step instructions for completing tasks created from this template, including system navigation, data sources, and calculation methods.' ;
    rdfs:domain ind:TaskTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastUsedDate rdf:type rdf:Property ;
    rdfs:label 'Last Used Date' ;
    rdfs:comment 'Most recent date when a task instance was created from this template, used to identify obsolete templates.' ;
    rdfs:domain ind:TaskTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:materialityCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Materiality Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the materiality threshold amount.' ;
    rdfs:domain ind:TaskTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresApproval rdf:type rdf:Property ;
    rdfs:label 'Requires Approval' ;
    rdfs:comment 'Indicates whether tasks created from this template require managerial or supervisory approval before completion, supporting SOX compliance controls.' ;
    rdfs:domain ind:TaskTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responsibleRole rdf:type rdf:Property ;
    rdfs:label 'Responsible Role' ;
    rdfs:comment 'Job role or function responsible for executing tasks generated from this template, such as Staff Accountant, Controller, or Financial Analyst.' ;
    rdfs:domain ind:TaskTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewerRole rdf:type rdf:Property ;
    rdfs:label 'Reviewer Role' ;
    rdfs:comment 'Job role or function responsible for reviewing and approving tasks generated from this template, supporting segregation of duties.' ;
    rdfs:domain ind:TaskTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlId rdf:type rdf:Property ;
    rdfs:label 'Control Id' ;
    rdfs:comment 'Reference identifier to the SOX internal control documentation that governs this recurring template. Nullable if not SOX-controlled.' ;
    rdfs:domain ind:RecurringTemplate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LedgerSoxControl .

ind:amountCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Amount Calculation Method' ;
    rdfs:comment 'Method used to determine the journal entry amount at execution time: fixed uses default_amount, formula applies a calculation rule, percentage applies a rate, variable requires manual input.' ;
    rdfs:domain ind:RecurringTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoPostFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Post Flag' ;
    rdfs:comment 'Indicates whether journal entries generated from this template should be automatically posted to the general ledger without manual review. True for automatic posting, False for manual review required.' ;
    rdfs:domain ind:RecurringTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:defaultAmount rdf:type rdf:Property ;
    rdfs:label 'Default Amount' ;
    rdfs:comment 'Standard monetary amount to be used when generating journal entries from this template. May be overridden at execution time.' ;
    rdfs:domain ind:RecurringTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recurrenceDay rdf:type rdf:Property ;
    rdfs:label 'Recurrence Day' ;
    rdfs:comment 'Specific day of the period (month, week, etc.) on which the recurring journal entry should be generated. For monthly templates, values 1-31; for weekly, values 1-7.' ;
    rdfs:domain ind:RecurringTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recurrenceFrequency rdf:type rdf:Property ;
    rdfs:label 'Recurrence Frequency' ;
    rdfs:comment 'Frequency at which the template automatically generates journal entries in the general ledger system.' ;
    rdfs:domain ind:RecurringTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalPeriodOffset rdf:type rdf:Property ;
    rdfs:label 'Reversal Period Offset' ;
    rdfs:comment 'Number of periods after the original entry date when the reversing entry should be created. Typically 1 for next-period reversal. Nullable if reversal_flag is False.' ;
    rdfs:domain ind:RecurringTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentCalendarId rdf:type rdf:Property ;
    rdfs:label 'Parent Calendar Id' ;
    rdfs:comment 'Reference to a parent accounting calendar for hierarchical calendar structures. Supports subsidiary calendar inheritance.' ;
    rdfs:domain ind:AccountingCalendar ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccountingCalendar .

ind:budgetCalendarFlag rdf:type rdf:Property ;
    rdfs:label 'Budget Calendar Flag' ;
    rdfs:comment 'Indicates whether this calendar is used for budgeting and planning activities. True for calendars aligned with budget cycles.' ;
    rdfs:domain ind:AccountingCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consolidationCalendarFlag rdf:type rdf:Property ;
    rdfs:label 'Consolidation Calendar Flag' ;
    rdfs:comment 'Indicates whether this calendar is used for corporate consolidation and group reporting. True for parent company calendars.' ;
    rdfs:domain ind:AccountingCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fiscalYearStartDay rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year Start Day' ;
    rdfs:comment 'Day of month (1-31) when the fiscal year begins. Combined with start month to define fiscal year boundaries.' ;
    rdfs:domain ind:AccountingCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fiscalYearStartMonth rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year Start Month' ;
    rdfs:comment 'Month number (1-12) when the fiscal year begins. Used to calculate fiscal periods and year-end reporting cycles.' ;
    rdfs:domain ind:AccountingCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:leapYearHandling rdf:type rdf:Property ;
    rdfs:label 'Leap Year Handling' ;
    rdfs:comment 'Method for handling leap year extra day in period calculations. Defines how February 29th is allocated to accounting periods.' ;
    rdfs:domain ind:AccountingCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberOfPeriods rdf:type rdf:Property ;
    rdfs:label 'Number Of Periods' ;
    rdfs:comment 'Total number of accounting periods in the fiscal year. Typically 12 for monthly, 13 for 4-week cycles, or 52/53 for weekly calendars.' ;
    rdfs:domain ind:AccountingCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:weekStartDay rdf:type rdf:Property ;
    rdfs:label 'Week Start Day' ;
    rdfs:comment 'Day of the week when accounting weeks begin. Relevant for weekly and 4-4-5 calendar structures.' ;
    rdfs:domain ind:AccountingCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yearEndClosePeriod rdf:type rdf:Property ;
    rdfs:label 'Year End Close Period' ;
    rdfs:comment 'Period number designated for year-end closing activities. Typically period 13 for adjustment entries and final reconciliations.' ;
    rdfs:domain ind:AccountingCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:advisingBankId rdf:type rdf:Property ;
    rdfs:label 'Advising Bank Id' ;
    rdfs:comment 'Reference to the bank that advises the beneficiary of the issuance of the trade finance instrument without undertaking payment obligation.' ;
    rdfs:domain ind:TradeFinanceTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CorrespondentBank .

ind:confirmingBankId rdf:type rdf:Property ;
    rdfs:label 'Confirming Bank Id' ;
    rdfs:comment 'Reference to the bank that adds its confirmation to the trade finance instrument, thereby undertaking payment obligation in addition to the issuing bank.' ;
    rdfs:domain ind:TradeFinanceTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CorrespondentBank .

ind:issuingBankId rdf:type rdf:Property ;
    rdfs:label 'Issuing Bank Id' ;
    rdfs:comment 'Reference to the bank that issues the trade finance instrument on behalf of the applicant.' ;
    rdfs:domain ind:TradeFinanceTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CorrespondentBank .

ind:reimbursementBankId rdf:type rdf:Property ;
    rdfs:label 'Reimbursement Bank Id' ;
    rdfs:comment 'Reference to the bank authorized to reimburse the claiming bank after compliant documents have been honored.' ;
    rdfs:domain ind:TradeFinanceTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CorrespondentBank .

ind:applicableLaw rdf:type rdf:Property ;
    rdfs:label 'Applicable Law' ;
    rdfs:comment 'Jurisdiction and legal framework under which disputes related to this trade finance transaction will be resolved.' ;
    rdfs:domain ind:TradeFinanceTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availableBy rdf:type rdf:Property ;
    rdfs:label 'Available By' ;
    rdfs:comment 'Method by which the trade finance instrument is available for payment (sight payment, deferred payment, acceptance, negotiation, or mixed payment).' ;
    rdfs:domain ind:TradeFinanceTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargesForAccountOf rdf:type rdf:Property ;
    rdfs:label 'Charges For Account Of' ;
    rdfs:comment 'Indicates which party (applicant, beneficiary, or shared) is responsible for bearing the banking charges and fees associated with the trade finance transaction.' ;
    rdfs:domain ind:TradeFinanceTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discrepanciesNoted rdf:type rdf:Property ;
    rdfs:label 'Discrepancies Noted' ;
    rdfs:comment 'Detailed description of any discrepancies or non-compliance issues identified during the examination of presented documents.' ;
    rdfs:domain ind:TradeFinanceTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentExaminationStatus rdf:type rdf:Property ;
    rdfs:label 'Document Examination Status' ;
    rdfs:comment 'Result of the banks examination of presented documents indicating whether they comply with the terms and conditions of the trade finance instrument.' ;
    rdfs:domain ind:TradeFinanceTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentPresentationDate rdf:type rdf:Property ;
    rdfs:label 'Document Presentation Date' ;
    rdfs:comment 'Actual date when the beneficiary or presenting bank submitted the required documents for examination under the trade finance instrument.' ;
    rdfs:domain ind:TradeFinanceTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentsRequired rdf:type rdf:Property ;
    rdfs:label 'Documents Required' ;
    rdfs:comment 'Comprehensive list of documents that must be presented to comply with the terms of the trade finance instrument (e.g., bill of lading, commercial invoice, packing list, certificate of origin).' ;
    rdfs:domain ind:TradeFinanceTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingRules rdf:type rdf:Property ;
    rdfs:label 'Governing Rules' ;
    rdfs:comment 'International Chamber of Commerce (ICC) rules and uniform customs that govern the interpretation and application of this trade finance instrument.' ;
    rdfs:domain ind:TradeFinanceTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incotermsCode rdf:type rdf:Property ;
    rdfs:label 'Incoterms Code' ;
    rdfs:comment 'Standard three-letter Incoterms code defining the responsibilities, costs, and risks between buyer and seller in the international transaction.' ;
    rdfs:domain ind:TradeFinanceTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tolerancePercentageNegative rdf:type rdf:Property ;
    rdfs:label 'Tolerance Percentage Negative' ;
    rdfs:comment 'Percentage by which the transaction amount may be reduced, as permitted under the terms of the instrument (e.g., -5% tolerance).' ;
    rdfs:domain ind:TradeFinanceTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tolerancePercentagePositive rdf:type rdf:Property ;
    rdfs:label 'Tolerance Percentage Positive' ;
    rdfs:comment 'Percentage by which the transaction amount may be exceeded, as permitted under the terms of the instrument (e.g., +10% tolerance).' ;
    rdfs:domain ind:TradeFinanceTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:advisingBankPartyId rdf:type rdf:Property ;
    rdfs:label 'Advising Bank Party Id' ;
    rdfs:comment 'Reference to the bank that advised the letter of credit to the beneficiary.' ;
    rdfs:domain ind:DocumentPresentation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:approvalUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Approval User Employee Id' ;
    rdfs:comment 'Identifier of the authorized bank officer who approved the honor or refusal decision.' ;
    rdfs:domain ind:DocumentPresentation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:issuingBankPartyId rdf:type rdf:Property ;
    rdfs:label 'Issuing Bank Party Id' ;
    rdfs:comment 'Reference to the bank that issued the letter of credit.' ;
    rdfs:domain ind:DocumentPresentation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:nominatedBankPartyId rdf:type rdf:Property ;
    rdfs:label 'Nominated Bank Party Id' ;
    rdfs:comment 'Reference to the bank nominated to examine and/or honor the presentation.' ;
    rdfs:domain ind:DocumentPresentation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:presentingPartyId rdf:type rdf:Property ;
    rdfs:label 'Presenting Party Id' ;
    rdfs:comment 'Reference to the party (beneficiary, negotiating bank, or other authorized presenter) submitting the documents.' ;
    rdfs:domain ind:DocumentPresentation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:bankChargesAmount rdf:type rdf:Property ;
    rdfs:label 'Bank Charges Amount' ;
    rdfs:comment 'Total bank charges deducted from the presentation amount (examination fees, courier fees, SWIFT charges, etc.).' ;
    rdfs:domain ind:DocumentPresentation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceDetermination rdf:type rdf:Property ;
    rdfs:label 'Compliance Determination' ;
    rdfs:comment 'Banks determination of whether the presented documents comply with the letter of credit terms and conditions.' ;
    rdfs:domain ind:DocumentPresentation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discrepancyNoticeDate rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Notice Date' ;
    rdfs:comment 'Date on which the bank issued notice of refusal citing discrepancies to the presenter.' ;
    rdfs:domain ind:DocumentPresentation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:examinationCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Examination Completion Timestamp' ;
    rdfs:comment 'Date and time when the bank completed its examination and determined compliance or discrepancies.' ;
    rdfs:domain ind:DocumentPresentation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:examinationDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Examination Deadline Date' ;
    rdfs:comment 'Maximum date by which the bank must complete examination, typically 5 banking days from presentation date per UCP 600.' ;
    rdfs:domain ind:DocumentPresentation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:examinationStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Examination Start Timestamp' ;
    rdfs:comment 'Date and time when the bank commenced examination of the presented documents.' ;
    rdfs:domain ind:DocumentPresentation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:honorDate rdf:type rdf:Property ;
    rdfs:label 'Honor Date' ;
    rdfs:comment 'Date on which the bank honored the presentation by making payment, accepting a draft, or incurring a deferred payment undertaking.' ;
    rdfs:domain ind:DocumentPresentation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paidAmount rdf:type rdf:Property ;
    rdfs:label 'Paid Amount' ;
    rdfs:comment 'Actual amount paid to the beneficiary, which may differ from claimed amount due to discrepancies, charges, or partial acceptance.' ;
    rdfs:domain ind:DocumentPresentation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:presentationLocation rdf:type rdf:Property ;
    rdfs:label 'Presentation Location' ;
    rdfs:comment 'Physical or electronic location where documents were presented (bank branch, SWIFT address, electronic platform).' ;
    rdfs:domain ind:DocumentPresentation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:presentationMethod rdf:type rdf:Property ;
    rdfs:label 'Presentation Method' ;
    rdfs:comment 'Method by which documents were presented: physical delivery, electronic platform, SWIFT messaging, or other channel.' ;
    rdfs:domain ind:DocumentPresentation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:presentationReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Presentation Reference Number' ;
    rdfs:comment 'Externally-known unique reference number assigned to this document presentation by the presenting bank or beneficiary.' ;
    rdfs:domain ind:DocumentPresentation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:presentationStatus rdf:type rdf:Property ;
    rdfs:label 'Presentation Status' ;
    rdfs:comment 'Current lifecycle status of the document presentation in the examination and settlement workflow.' ;
    rdfs:domain ind:DocumentPresentation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:presentationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Presentation Timestamp' ;
    rdfs:comment 'Precise date and time when the document presentation was received by the bank, critical for calculating examination periods.' ;
    rdfs:domain ind:DocumentPresentation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:presentationType rdf:type rdf:Property ;
    rdfs:label 'Presentation Type' ;
    rdfs:comment 'Classification of the presentation based on payment terms: sight payment, deferred payment, acceptance, or negotiation.' ;
    rdfs:domain ind:DocumentPresentation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reimbursementClaimDate rdf:type rdf:Property ;
    rdfs:label 'Reimbursement Claim Date' ;
    rdfs:comment 'Date on which the reimbursement claim was submitted to the issuing or reimbursing bank.' ;
    rdfs:domain ind:DocumentPresentation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reimbursementClaimSentFlag rdf:type rdf:Property ;
    rdfs:label 'Reimbursement Claim Sent Flag' ;
    rdfs:comment 'Indicates whether the nominated bank has sent a reimbursement claim to the issuing bank or reimbursing bank.' ;
    rdfs:domain ind:DocumentPresentation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transportDocumentDate rdf:type rdf:Property ;
    rdfs:label 'Transport Document Date' ;
    rdfs:comment 'Date of the transport document (bill of lading, airway bill, etc.) presented, critical for determining timely shipment.' ;
    rdfs:domain ind:DocumentPresentation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:waiverRequestedFlag rdf:type rdf:Property ;
    rdfs:label 'Waiver Requested Flag' ;
    rdfs:comment 'Indicates whether the bank has sought waiver of discrepancies from the applicant.' ;
    rdfs:domain ind:DocumentPresentation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:predecessorPackageId rdf:type rdf:Property ;
    rdfs:label 'Predecessor Package Id' ;
    rdfs:comment 'Reference to the previous version of this covenant package if this is a revised or updated version.' ;
    rdfs:domain ind:CovenantPackage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CovenantPackage .

ind:borrowerSegment rdf:type rdf:Property ;
    rdfs:label 'Borrower Segment' ;
    rdfs:comment 'Target borrower segment for which this covenant package is designed, aligning with the bank\'s credit risk appetite and portfolio strategy.' ;
    rdfs:domain ind:CovenantPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachRatePercent rdf:type rdf:Property ;
    rdfs:label 'Breach Rate Percent' ;
    rdfs:comment 'Historical percentage of loans using this package that have experienced covenant breaches, used for package effectiveness assessment.' ;
    rdfs:domain ind:CovenantPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:covenantCount rdf:type rdf:Property ;
    rdfs:label 'Covenant Count' ;
    rdfs:comment 'Total number of individual covenant clauses included in this package.' ;
    rdfs:domain ind:CovenantPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:crossDefaultIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Cross Default Included Flag' ;
    rdfs:comment 'Indicates whether the package includes cross-default provisions that trigger default if the borrower defaults on other obligations.' ;
    rdfs:domain ind:CovenantPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:curePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Cure Period Days' ;
    rdfs:comment 'Standard number of days allowed for borrowers to cure covenant breaches before default provisions are triggered.' ;
    rdfs:domain ind:CovenantPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:financialCovenantCount rdf:type rdf:Property ;
    rdfs:label 'Financial Covenant Count' ;
    rdfs:comment 'Number of financial covenants (e.g., debt-to-equity ratio, interest coverage ratio) included in the package.' ;
    rdfs:domain ind:CovenantPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:legalTemplateReference rdf:type rdf:Property ;
    rdfs:label 'Legal Template Reference' ;
    rdfs:comment 'Reference identifier to the standard legal documentation template associated with this covenant package.' ;
    rdfs:domain ind:CovenantPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialAdverseChangeIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Material Adverse Change Included Flag' ;
    rdfs:comment 'Indicates whether the package includes material adverse change clauses allowing lender action upon significant negative changes in borrower circumstances.' ;
    rdfs:domain ind:CovenantPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operationalCovenantCount rdf:type rdf:Property ;
    rdfs:label 'Operational Covenant Count' ;
    rdfs:comment 'Number of operational or business conduct covenants included in the package.' ;
    rdfs:domain ind:CovenantPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:packageCode rdf:type rdf:Property ;
    rdfs:label 'Package Code' ;
    rdfs:comment 'Externally-known unique business identifier for the covenant package used in loan documentation and regulatory reporting.' ;
    rdfs:domain ind:CovenantPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageName rdf:type rdf:Property ;
    rdfs:label 'Package Name' ;
    rdfs:comment 'Human-readable name of the covenant package describing its purpose or target borrower segment.' ;
    rdfs:domain ind:CovenantPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:syndicationEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Syndication Eligible Flag' ;
    rdfs:comment 'Indicates whether loans using this covenant package are eligible for syndication in the secondary loan market.' ;
    rdfs:domain ind:CovenantPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waiverAuthorityLevel rdf:type rdf:Property ;
    rdfs:label 'Waiver Authority Level' ;
    rdfs:comment 'Organizational level required to approve waivers or amendments to covenants within this package.' ;
    rdfs:domain ind:CovenantPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByScheduleId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Schedule Id' ;
    rdfs:comment 'Reference to the commission schedule that replaces this one, maintaining version lineage.' ;
    rdfs:domain ind:CommissionSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CommissionSchedule .

ind:baseCommissionRate rdf:type rdf:Property ;
    rdfs:label 'Base Commission Rate' ;
    rdfs:comment 'The base commission rate applied before any adjustments, expressed as a decimal or basis points depending on schedule type.' ;
    rdfs:domain ind:CommissionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discountPercentage rdf:type rdf:Property ;
    rdfs:label 'Discount Percentage' ;
    rdfs:comment 'Percentage discount applied to the base commission rate for promotional or relationship-based pricing.' ;
    rdfs:domain ind:CommissionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:executionVenueCode rdf:type rdf:Property ;
    rdfs:label 'Execution Venue Code' ;
    rdfs:comment 'Four-character Market Identifier Code (MIC) of the execution venue to which this schedule applies.' ;
    rdfs:domain ind:CommissionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frequencyThresholdCount rdf:type rdf:Property ;
    rdfs:label 'Frequency Threshold Count' ;
    rdfs:comment 'Number of trades within a period that triggers volume-based commission adjustments.' ;
    rdfs:domain ind:CommissionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maximumCommissionAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Commission Amount' ;
    rdfs:comment 'Maximum commission amount charged per trade regardless of calculated commission, providing cap protection.' ;
    rdfs:domain ind:CommissionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumCommissionAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Commission Amount' ;
    rdfs:comment 'Minimum commission amount charged per trade regardless of calculated commission, ensuring floor pricing.' ;
    rdfs:domain ind:CommissionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rebateEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Rebate Eligible Flag' ;
    rdfs:comment 'Indicates whether trades under this schedule are eligible for commission rebates or volume incentives.' ;
    rdfs:domain ind:CommissionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryFeeIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Fee Included Flag' ;
    rdfs:comment 'Indicates whether regulatory fees and levies are included in the commission or charged separately.' ;
    rdfs:domain ind:CommissionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduleCode rdf:type rdf:Property ;
    rdfs:label 'Schedule Code' ;
    rdfs:comment 'Business identifier code for the commission schedule, used for external reference and reporting.' ;
    rdfs:domain ind:CommissionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleName rdf:type rdf:Property ;
    rdfs:label 'Schedule Name' ;
    rdfs:comment 'Human-readable name of the commission schedule describing its purpose or target segment.' ;
    rdfs:domain ind:CommissionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleType rdf:type rdf:Property ;
    rdfs:label 'Schedule Type' ;
    rdfs:comment 'Classification of the commission calculation methodology used in this schedule.' ;
    rdfs:domain ind:CommissionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierStructureJson rdf:type rdf:Property ;
    rdfs:label 'Tier Structure Json' ;
    rdfs:comment 'JSON representation of tiered commission structure defining breakpoints and rates for tiered schedules.' ;
    rdfs:domain ind:CommissionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeDirection rdf:type rdf:Property ;
    rdfs:label 'Trade Direction' ;
    rdfs:comment 'Trade direction to which this commission schedule applies, allowing asymmetric buy/sell pricing.' ;
    rdfs:domain ind:CommissionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Volume Threshold Amount' ;
    rdfs:comment 'Trading volume threshold amount that triggers preferential commission rates or tier changes.' ;
    rdfs:domain ind:CommissionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clearingHouseType rdf:type rdf:Property ;
    rdfs:label 'Clearing House Type' ;
    rdfs:comment 'Classification of the clearing house based on the asset classes and services it provides.' ;
    rdfs:domain ind:ClearingHouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingModel rdf:type rdf:Property ;
    rdfs:label 'Clearing Model' ;
    rdfs:comment 'The clearing and settlement model employed by the clearing house.' ;
    rdfs:domain ind:ClearingHouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:connectivityProtocol rdf:type rdf:Property ;
    rdfs:label 'Connectivity Protocol' ;
    rdfs:comment 'Primary technical connectivity protocol used for trade submission and clearing (e.g., FIX, SWIFT, proprietary API).' ;
    rdfs:domain ind:Trade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultFundRequired rdf:type rdf:Property ;
    rdfs:label 'Default Fund Required' ;
    rdfs:comment 'Indicates whether clearing members are required to contribute to a default fund or guarantee fund.' ;
    rdfs:domain ind:ClearingHouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:headquartersCountry rdf:type rdf:Property ;
    rdfs:label 'Headquarters Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for the country where the clearing house headquarters is located.' ;
    rdfs:domain ind:Trade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marginModel rdf:type rdf:Property ;
    rdfs:label 'Margin Model' ;
    rdfs:comment 'The margin calculation methodology used by the clearing house for risk management.' ;
    rdfs:domain ind:ClearingHouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:membershipRequired rdf:type rdf:Property ;
    rdfs:label 'Membership Required' ;
    rdfs:comment 'Indicates whether direct membership is required to clear trades through this clearing house.' ;
    rdfs:domain ind:ClearingHouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minimumCapitalRequirement rdf:type rdf:Property ;
    rdfs:label 'Minimum Capital Requirement' ;
    rdfs:comment 'Minimum capital requirement for clearing members in the settlement currency.' ;
    rdfs:domain ind:ClearingHouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:name rdf:type rdf:Property ;
    rdfs:label 'Name' ;
    rdfs:comment 'Full legal name of the clearing house organization.' ;
    rdfs:domain ind:ClearingHouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nettingEligible rdf:type rdf:Property ;
    rdfs:label 'Netting Eligible' ;
    rdfs:comment 'Indicates whether the clearing house supports multilateral netting of trades.' ;
    rdfs:domain ind:ClearingHouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operatingHours rdf:type rdf:Property ;
    rdfs:label 'Operating Hours' ;
    rdfs:comment 'Standard operating hours of the clearing house, including time zone.' ;
    rdfs:domain ind:ClearingHouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentOrganization rdf:type rdf:Property ;
    rdfs:label 'Parent Organization' ;
    rdfs:comment 'Name of the parent company or holding entity that owns or operates the clearing house.' ;
    rdfs:domain ind:ClearingHouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportedAssetClasses rdf:type rdf:Property ;
    rdfs:label 'Supported Asset Classes' ;
    rdfs:comment 'Comma-separated list of asset classes supported by the clearing house (e.g., equities, fixed income, derivatives, commodities, FX).' ;
    rdfs:domain ind:ClearingHouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeReportingRequired rdf:type rdf:Property ;
    rdfs:label 'Trade Reporting Required' ;
    rdfs:comment 'Indicates whether trades cleared through this clearing house must be reported to trade repositories.' ;
    rdfs:domain ind:ClearingHouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvalDeadlineTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approval Deadline Timestamp' ;
    rdfs:comment 'Date and time by which participants must approve or reject compression results. Applicable only when approval is required.' ;
    rdfs:domain ind:CompressionCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:compressedNotionalAmount rdf:type rdf:Property ;
    rdfs:label 'Compressed Notional Amount' ;
    rdfs:comment 'Total gross notional amount eliminated through compression, expressed in the base currency. Represents the reduction in notional exposure.' ;
    rdfs:domain ind:CompressionCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compressionAlgorithmVersion rdf:type rdf:Property ;
    rdfs:label 'Compression Algorithm Version' ;
    rdfs:comment 'Version identifier of the compression algorithm or methodology used for this cycle. Important for audit trail and reproducibility.' ;
    rdfs:domain ind:CompressionCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compressionMethodology rdf:type rdf:Property ;
    rdfs:label 'Compression Methodology' ;
    rdfs:comment 'Detailed description of the compression methodology applied, including algorithm type, optimization constraints, and calculation approach.' ;
    rdfs:domain ind:CompressionCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compressionRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Compression Rate Percentage' ;
    rdfs:comment 'Percentage of notional amount successfully compressed relative to the total submitted notional. Key performance indicator for compression efficiency.' ;
    rdfs:domain ind:CompressionCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cycleStatus rdf:type rdf:Property ;
    rdfs:label 'Cycle Status' ;
    rdfs:comment 'Current lifecycle status of the compression cycle. Draft indicates initial setup, scheduled means planned for future execution, open allows participant submissions, in_progress indicates active processing, completed means successfully finished, cancelled indicates termination before completion, and failed indicates unsuccessful execution.' ;
    rdfs:domain ind:CompressionCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Execution End Timestamp' ;
    rdfs:comment 'Date and time when the compression algorithm completes processing and final results are available.' ;
    rdfs:domain ind:CompressionCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:executionStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Execution Start Timestamp' ;
    rdfs:comment 'Date and time when the compression algorithm begins processing submitted trades and calculating optimal compression results.' ;
    rdfs:domain ind:CompressionCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:optimizationObjective rdf:type rdf:Property ;
    rdfs:label 'Optimization Objective' ;
    rdfs:comment 'Primary goal of the compression algorithm. Maximize notional reduction prioritizes largest gross notional elimination, minimize cash payments reduces settlement amounts, minimize replacement trades reduces new trade count, and balanced optimizes across multiple objectives.' ;
    rdfs:domain ind:CompressionCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:participantCount rdf:type rdf:Property ;
    rdfs:label 'Participant Count' ;
    rdfs:comment 'Total number of distinct counterparties or legal entities participating in this compression cycle.' ;
    rdfs:domain ind:CompressionCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:remainingNotionalAmount rdf:type rdf:Property ;
    rdfs:label 'Remaining Notional Amount' ;
    rdfs:comment 'Total gross notional amount remaining after compression, expressed in the base currency. Calculated as submitted notional minus compressed notional.' ;
    rdfs:domain ind:CompressionCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:riskToleranceLevel rdf:type rdf:Property ;
    rdfs:label 'Risk Tolerance Level' ;
    rdfs:comment 'Risk appetite setting for the compression cycle. Conservative maintains strict economic equivalence, moderate allows minor deviations within tolerance, and aggressive maximizes compression with higher tolerance for economic changes.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submission End Timestamp' ;
    rdfs:comment 'Date and time when the compression cycle closes for participant submissions. No further trade nominations are accepted after this time.' ;
    rdfs:domain ind:CompressionCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:submissionStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submission Start Timestamp' ;
    rdfs:comment 'Date and time when the compression cycle opens for participant submissions and trade nominations.' ;
    rdfs:domain ind:CompressionCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:submittedNotionalAmount rdf:type rdf:Property ;
    rdfs:label 'Submitted Notional Amount' ;
    rdfs:comment 'Total gross notional amount of all trades submitted for compression, expressed in the base currency.' ;
    rdfs:domain ind:CompressionCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCompressedTrades rdf:type rdf:Property ;
    rdfs:label 'Total Compressed Trades' ;
    rdfs:comment 'Total number of trades successfully compressed or eliminated as a result of this compression cycle.' ;
    rdfs:domain ind:CompressionCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalReplacementTrades rdf:type rdf:Property ;
    rdfs:label 'Total Replacement Trades' ;
    rdfs:comment 'Total number of new replacement trades created as a result of the compression to maintain economic equivalence.' ;
    rdfs:domain ind:CompressionCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalSubmittedTrades rdf:type rdf:Property ;
    rdfs:label 'Total Submitted Trades' ;
    rdfs:comment 'Total number of trades submitted by all participants for inclusion in this compression cycle.' ;
    rdfs:domain ind:CompressionCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:activeParticipantCount rdf:type rdf:Property ;
    rdfs:label 'Active Participant Count' ;
    rdfs:comment 'Number of active reporting entities or participants currently submitting trade reports to this repository.' ;
    rdfs:domain ind:TradeRepository ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assetClassesSupported rdf:type rdf:Property ;
    rdfs:label 'Asset Classes Supported' ;
    rdfs:comment 'Comma-separated list of asset classes that the trade repository is authorized to accept for reporting (e.g., interest rate derivatives, credit derivatives, equity derivatives, FX, commodities).' ;
    rdfs:domain ind:TradeRepository ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageProcessingTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Average Processing Time Seconds' ;
    rdfs:comment 'Average time in seconds taken by the repository to process and acknowledge a trade report submission.' ;
    rdfs:domain ind:TradeRepository ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:businessContinuityPlanTestedDate rdf:type rdf:Property ;
    rdfs:label 'Business Continuity Plan Tested Date' ;
    rdfs:comment 'Date on which the trade repository\'s business continuity and disaster recovery plan was last tested.' ;
    rdfs:domain ind:TradeRepository ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationIso27001 rdf:type rdf:Property ;
    rdfs:label 'Certification Iso 27001' ;
    rdfs:comment 'Indicates whether the trade repository holds ISO 27001 certification for information security management.' ;
    rdfs:domain ind:TradeRepository ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificationSoc2 rdf:type rdf:Property ;
    rdfs:label 'Certification Soc2' ;
    rdfs:comment 'Indicates whether the trade repository has achieved SOC 2 Type II certification for security, availability, and confidentiality controls.' ;
    rdfs:domain ind:TradeRepository ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:feesPerTransaction rdf:type rdf:Property ;
    rdfs:label 'Fees Per Transaction' ;
    rdfs:comment 'Fee charged by the trade repository per trade report submission, typically in the repository\'s billing currency.' ;
    rdfs:domain ind:TradeRepository ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:headquartersAddress rdf:type rdf:Property ;
    rdfs:label 'Headquarters Address' ;
    rdfs:comment 'Physical address of the trade repository\'s headquarters or principal place of business.' ;
    rdfs:domain ind:TradeRepository ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumDailySubmissionVolume rdf:type rdf:Property ;
    rdfs:label 'Maximum Daily Submission Volume' ;
    rdfs:comment 'Maximum number of trade reports that the repository can process in a single business day based on capacity planning.' ;
    rdfs:domain ind:TradeRepository ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextAuditScheduledDate rdf:type rdf:Property ;
    rdfs:label 'Next Audit Scheduled Date' ;
    rdfs:comment 'Scheduled date for the next regulatory or independent audit of the trade repository.' ;
    rdfs:domain ind:TradeRepository ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:publicAccessAvailable rdf:type rdf:Property ;
    rdfs:label 'Public Access Available' ;
    rdfs:comment 'Indicates whether the trade repository provides public access to aggregated or anonymized trade data for transparency purposes.' ;
    rdfs:domain ind:TradeRepository ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reconciliationToleranceThreshold rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Tolerance Threshold' ;
    rdfs:comment 'Percentage threshold used by the repository for matching and reconciling trade reports submitted by counterparties.' ;
    rdfs:domain ind:TradeRepository ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:registrationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Registration Expiry Date' ;
    rdfs:comment 'Date on which the current registration of the trade repository expires and requires renewal. Nullable for indefinite registrations.' ;
    rdfs:domain ind:TradeRepository ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:registrationStatus rdf:type rdf:Property ;
    rdfs:label 'Registration Status' ;
    rdfs:comment 'Current regulatory registration status of the trade repository with the relevant supervisory authority.' ;
    rdfs:domain ind:TradeRepository ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportingFrequency rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Frequency' ;
    rdfs:comment 'Frequency at which the trade repository must submit aggregated reports to regulatory authorities.' ;
    rdfs:domain ind:TradeRepository ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingObligationScope rdf:type rdf:Property ;
    rdfs:label 'Reporting Obligation Scope' ;
    rdfs:comment 'Scope of transactions that must be reported to this trade repository under applicable regulatory frameworks.' ;
    rdfs:domain ind:TradeRepository ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repositoryCode rdf:type rdf:Property ;
    rdfs:label 'Repository Code' ;
    rdfs:comment 'Unique alphanumeric code assigned to the trade repository by regulatory authorities for identification purposes.' ;
    rdfs:domain ind:TradeRepository ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repositoryName rdf:type rdf:Property ;
    rdfs:label 'Repository Name' ;
    rdfs:comment 'Official legal name of the trade repository entity.' ;
    rdfs:domain ind:TradeRepository ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repositoryType rdf:type rdf:Property ;
    rdfs:label 'Repository Type' ;
    rdfs:comment 'Classification of the trade repository based on the asset classes it supports for trade reporting.' ;
    rdfs:domain ind:TradeRepository ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceLevelAgreementUptimePct rdf:type rdf:Property ;
    rdfs:label 'Service Level Agreement Uptime Pct' ;
    rdfs:comment 'Contractual uptime percentage guaranteed by the trade repository for its reporting services.' ;
    rdfs:domain ind:TradeRepository ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:submissionEndpointUrl rdf:type rdf:Property ;
    rdfs:label 'Submission Endpoint Url' ;
    rdfs:comment 'Primary URL endpoint for submitting trade reports to the repository via electronic messaging.' ;
    rdfs:domain ind:TradeRepository ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalTradesReportedYtd rdf:type rdf:Property ;
    rdfs:label 'Total Trades Reported Ytd' ;
    rdfs:comment 'Cumulative number of trade reports submitted to the repository from the beginning of the current calendar year.' ;
    rdfs:domain ind:TradeRepository ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:uniqueTransactionIdentifierFormat rdf:type rdf:Property ;
    rdfs:label 'Unique Transaction Identifier Format' ;
    rdfs:comment 'Standard format used by the repository for Unique Transaction Identifiers to ensure global uniqueness of trade records.' ;
    rdfs:domain ind:TradeRepository ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableProducts rdf:type rdf:Property ;
    rdfs:label 'Applicable Products' ;
    rdfs:comment 'Comma-separated list of financial products or instruments for which this model is applicable.' ;
    rdfs:domain ind:ValuationModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backtestingFrequency rdf:type rdf:Property ;
    rdfs:label 'Backtesting Frequency' ;
    rdfs:comment 'The frequency at which the model undergoes backtesting to validate its predictive accuracy.' ;
    rdfs:domain ind:ValuationModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benchmarkModel rdf:type rdf:Property ;
    rdfs:label 'Benchmark Model' ;
    rdfs:comment 'The industry-standard or alternative model used as a benchmark for comparison and validation purposes.' ;
    rdfs:domain ind:ValuationModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inputParameters rdf:type rdf:Property ;
    rdfs:label 'Input Parameters' ;
    rdfs:comment 'Comma-separated list of required input parameters for the valuation model (e.g., spot price, strike price, volatility, risk-free rate).' ;
    rdfs:domain ind:ValuationModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRegulatoryApproved rdf:type rdf:Property ;
    rdfs:label 'Is Regulatory Approved' ;
    rdfs:comment 'Indicates whether the model has received formal regulatory approval for use in capital calculations and regulatory reporting.' ;
    rdfs:domain ind:ValuationModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isStressTestApproved rdf:type rdf:Property ;
    rdfs:label 'Is Stress Test Approved' ;
    rdfs:comment 'Indicates whether the model is approved for use in regulatory stress testing scenarios such as CCAR or DFAST.' ;
    rdfs:domain ind:ValuationModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mathematicalFormula rdf:type rdf:Property ;
    rdfs:label 'Mathematical Formula' ;
    rdfs:comment 'The core mathematical formula or algorithm used by the valuation model.' ;
    rdfs:domain ind:ValuationModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelComplexityScore rdf:type rdf:Property ;
    rdfs:label 'Model Complexity Score' ;
    rdfs:comment 'Quantitative score representing the complexity of the model, used for risk assessment and validation prioritization.' ;
    rdfs:domain ind:ValuationModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modelDeveloper rdf:type rdf:Property ;
    rdfs:label 'Model Developer' ;
    rdfs:comment 'The team or individual who developed the valuation model.' ;
    rdfs:domain ind:ValuationModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelLimitations rdf:type rdf:Property ;
    rdfs:label 'Model Limitations' ;
    rdfs:comment 'Known limitations, assumptions, and constraints of the valuation model that users must be aware of.' ;
    rdfs:domain ind:ValuationModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelOwner rdf:type rdf:Property ;
    rdfs:label 'Model Owner' ;
    rdfs:comment 'The business unit or department responsible for the ownership and governance of this valuation model.' ;
    rdfs:domain ind:ValuationModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outputMeasure rdf:type rdf:Property ;
    rdfs:label 'Output Measure' ;
    rdfs:comment 'The primary output measure produced by the model (e.g., fair value, present value, option price, credit valuation adjustment).' ;
    rdfs:domain ind:ValuationModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:useCase rdf:type rdf:Property ;
    rdfs:label 'Use Case' ;
    rdfs:comment 'The primary business use case for the model (e.g., mark-to-market valuation, CVA calculation, stress testing, regulatory capital).' ;
    rdfs:domain ind:ValuationModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationApproach rdf:type rdf:Property ;
    rdfs:label 'Valuation Approach' ;
    rdfs:comment 'The primary valuation approach as defined by IFRS 13: market approach, income approach, or cost approach.' ;
    rdfs:domain ind:ValuationModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:masterAgreementId rdf:type rdf:Property ;
    rdfs:label 'Master Agreement Id' ;
    rdfs:comment 'Reference to the parent ISDA Master Agreement under which this CSA operates as an annex.' ;
    rdfs:domain ind:CsaAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IsdaMasterAgreement .

ind:concentrationLimitsApplied rdf:type rdf:Property ;
    rdfs:label 'Concentration Limits Applied' ;
    rdfs:comment 'Indicates whether concentration limits are enforced on collateral composition to prevent over-reliance on specific asset types or issuers.' ;
    rdfs:domain ind:CsaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditRatingThreshold rdf:type rdf:Property ;
    rdfs:label 'Credit Rating Threshold' ;
    rdfs:comment 'Minimum credit rating required to maintain current threshold and minimum transfer amount terms. Downgrades may trigger term adjustments.' ;
    rdfs:domain ind:CsaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initialMarginRequired rdf:type rdf:Property ;
    rdfs:label 'Initial Margin Required' ;
    rdfs:comment 'Indicates whether initial margin is required under this CSA agreement, typically mandated for non-centrally cleared derivatives under regulatory reform.' ;
    rdfs:domain ind:CsaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interestRateBasisPoints rdf:type rdf:Property ;
    rdfs:label 'Interest Rate Basis Points' ;
    rdfs:comment 'Interest rate applied to cash collateral, expressed in basis points. Applicable when interest_rate_type is fixed or floating.' ;
    rdfs:domain ind:CsaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryInitialMarginModel rdf:type rdf:Property ;
    rdfs:label 'Regulatory Initial Margin Model' ;
    rdfs:comment 'Methodology used to calculate regulatory initial margin requirements. SIMM (Standard Initial Margin Model) is the industry standard for non-cleared derivatives.' ;
    rdfs:domain ind:CsaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipManager rdf:type rdf:Property ;
    rdfs:label 'Relationship Manager' ;
    rdfs:comment 'Name of the relationship manager responsible for the counterparty relationship and CSA agreement oversight.' ;
    rdfs:domain ind:CsaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substitutionRightsAllowed rdf:type rdf:Property ;
    rdfs:label 'Substitution Rights Allowed' ;
    rdfs:comment 'Indicates whether the posting party has the right to substitute posted collateral with other eligible assets.' ;
    rdfs:domain ind:CsaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:variationMarginRequired rdf:type rdf:Property ;
    rdfs:label 'Variation Margin Required' ;
    rdfs:comment 'Indicates whether variation margin is required to cover mark-to-market exposure fluctuations.' ;
    rdfs:domain ind:CsaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:custodianEntityId rdf:type rdf:Property ;
    rdfs:label 'Custodian Entity Id' ;
    rdfs:comment 'Identifier of the custodian entity responsible for safeguarding client assets, if custody is provided by a third party. Nullable if prime broker provides custody.' ;
    rdfs:domain ind:PrimeBrokerAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:primeBrokerEntityId rdf:type rdf:Property ;
    rdfs:label 'Prime Broker Entity Id' ;
    rdfs:comment 'Identifier of the legal entity within the banking organization acting as the prime broker under this agreement.' ;
    rdfs:domain ind:PrimeBrokerAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:amlKycStatus rdf:type rdf:Property ;
    rdfs:label 'Aml Kyc Status' ;
    rdfs:comment 'Status of the client\'s AML and KYC compliance documentation required to maintain the prime brokerage relationship.' ;
    rdfs:domain ind:PrimeBrokerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientClassification rdf:type rdf:Property ;
    rdfs:label 'Client Classification' ;
    rdfs:comment 'MiFID II classification of the client for the purposes of this agreement, determining the level of regulatory protection and disclosure requirements.' ;
    rdfs:domain ind:PrimeBrokerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collateralValuationFrequency rdf:type rdf:Property ;
    rdfs:label 'Collateral Valuation Frequency' ;
    rdfs:comment 'Frequency at which collateral pledged under the agreement is revalued for margin calculation purposes.' ;
    rdfs:domain ind:PrimeBrokerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:custodyArrangement rdf:type rdf:Property ;
    rdfs:label 'Custody Arrangement' ;
    rdfs:comment 'Structure for holding client assets, indicating whether custody is provided by the prime broker, a third-party custodian, or through a tri-party arrangement.' ;
    rdfs:domain ind:PrimeBrokerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultCurePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Default Cure Period Days' ;
    rdfs:comment 'Number of days the client has to remedy a default or breach before the prime broker may exercise termination rights.' ;
    rdfs:domain ind:PrimeBrokerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:financingRateBasis rdf:type rdf:Property ;
    rdfs:label 'Financing Rate Basis' ;
    rdfs:comment 'Benchmark interest rate basis used for calculating financing charges on margin loans and short positions under this agreement.' ;
    rdfs:domain ind:PrimeBrokerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financingSpreadBps rdf:type rdf:Property ;
    rdfs:label 'Financing Spread Bps' ;
    rdfs:comment 'Spread in basis points added to the financing rate basis to determine the total financing cost charged to the client.' ;
    rdfs:domain ind:PrimeBrokerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:leiRequired rdf:type rdf:Property ;
    rdfs:label 'Lei Required' ;
    rdfs:comment 'Indicates whether the client is required to maintain a valid Legal Entity Identifier for regulatory reporting under this agreement.' ;
    rdfs:domain ind:PrimeBrokerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marginRequirementPercentage rdf:type rdf:Property ;
    rdfs:label 'Margin Requirement Percentage' ;
    rdfs:comment 'Initial margin percentage required for leveraged positions under this agreement, expressed as a percentage of position value.' ;
    rdfs:domain ind:PrimeBrokerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:masterAgreementType rdf:type rdf:Property ;
    rdfs:label 'Master Agreement Type' ;
    rdfs:comment 'Type of master legal framework underpinning the prime brokerage relationship (ISDA for derivatives, GMRA for repo, GMSLA for securities lending).' ;
    rdfs:domain ind:PrimeBrokerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nettingArrangement rdf:type rdf:Property ;
    rdfs:label 'Netting Arrangement' ;
    rdfs:comment 'Type of netting agreement in place for offsetting obligations and exposures between the parties, critical for credit risk mitigation.' ;
    rdfs:domain ind:PrimeBrokerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noticePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Notice Period Days' ;
    rdfs:comment 'Number of days advance notice required by either party to terminate the agreement without cause.' ;
    rdfs:domain ind:PrimeBrokerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rehypothecationLimitPercentage rdf:type rdf:Property ;
    rdfs:label 'Rehypothecation Limit Percentage' ;
    rdfs:comment 'Maximum percentage of client collateral that may be rehypothecated, if rehypothecation is allowed. Nullable if rehypothecation is not permitted.' ;
    rdfs:domain ind:PrimeBrokerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:servicesScope rdf:type rdf:Property ;
    rdfs:label 'Services Scope' ;
    rdfs:comment 'Textual description of the prime brokerage services covered under this agreement (e.g., securities lending, trade execution, custody, reporting, financing).' ;
    rdfs:domain ind:PrimeBrokerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chairEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Chair Employee Id' ;
    rdfs:comment 'Identifier of the employee serving as the chairperson of the investment committee, responsible for leading meetings and decision-making processes.' ;
    rdfs:domain ind:InvestmentCommittee ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:escalationCommitteeId rdf:type rdf:Property ;
    rdfs:label 'Escalation Committee Id' ;
    rdfs:comment 'Identifier of the committee to which decisions exceeding this committee\'s authority are escalated for approval.' ;
    rdfs:domain ind:InvestmentCommittee ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InvestmentCommittee .

ind:reportingLineCommitteeId rdf:type rdf:Property ;
    rdfs:label 'Reporting Line Committee Id' ;
    rdfs:comment 'Identifier of the parent or oversight committee to which this investment committee reports, if applicable. Null for top-level committees.' ;
    rdfs:domain ind:InvestmentCommittee ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InvestmentCommittee .

ind:secretaryEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Secretary Employee Id' ;
    rdfs:comment 'Identifier of the employee serving as the secretary of the investment committee, responsible for documentation and administrative support.' ;
    rdfs:domain ind:InvestmentCommittee ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:approvalLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Approval Limit Amount' ;
    rdfs:comment 'Maximum monetary value of investment decisions that the committee is authorized to approve without escalation to higher authority.' ;
    rdfs:domain ind:InvestmentCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvalLimitCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Approval Limit Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the approval limit amount.' ;
    rdfs:domain ind:InvestmentCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetClassScope rdf:type rdf:Property ;
    rdfs:label 'Asset Class Scope' ;
    rdfs:comment 'Comma-separated list of asset classes (equities, fixed income, alternatives, real estate, etc.) that fall within the committee\'s purview.' ;
    rdfs:domain ind:InvestmentCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientSegmentScope rdf:type rdf:Property ;
    rdfs:label 'Client Segment Scope' ;
    rdfs:comment 'Client wealth segment(s) for which the committee makes investment decisions. HNW = High Net Worth, UHNW = Ultra High Net Worth.' ;
    rdfs:domain ind:InvestmentCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conflictOfInterestPolicyFlag rdf:type rdf:Property ;
    rdfs:label 'Conflict Of Interest Policy Flag' ;
    rdfs:comment 'Indicates whether the committee has a formal conflict of interest policy that members must adhere to.' ;
    rdfs:domain ind:InvestmentCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:decisionAuthorityLevel rdf:type rdf:Property ;
    rdfs:label 'Decision Authority Level' ;
    rdfs:comment 'Level of decision-making authority granted to the committee, indicating whether it has full autonomy or requires escalation for certain decisions.' ;
    rdfs:domain ind:InvestmentCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentationRetentionYears rdf:type rdf:Property ;
    rdfs:label 'Documentation Retention Years' ;
    rdfs:comment 'Number of years that committee meeting minutes, decisions, and supporting documentation must be retained per regulatory and internal policy requirements.' ;
    rdfs:domain ind:InvestmentCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:externalAdvisorAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'External Advisor Allowed Flag' ;
    rdfs:comment 'Indicates whether the committee is permitted to engage external advisors or consultants to support decision-making.' ;
    rdfs:domain ind:InvestmentCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:investmentPolicyStatementVersion rdf:type rdf:Property ;
    rdfs:label 'Investment Policy Statement Version' ;
    rdfs:comment 'Version number of the Investment Policy Statement that governs the committee\'s investment decisions and guidelines.' ;
    rdfs:domain ind:InvestmentCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastMeetingDate rdf:type rdf:Property ;
    rdfs:label 'Last Meeting Date' ;
    rdfs:comment 'Date of the most recent meeting held by the investment committee.' ;
    rdfs:domain ind:InvestmentCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mandateDescription rdf:type rdf:Property ;
    rdfs:label 'Mandate Description' ;
    rdfs:comment 'Detailed description of the committee\'s charter, responsibilities, and decision-making authority within the investment governance framework.' ;
    rdfs:domain ind:InvestmentCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextScheduledMeetingDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Meeting Date' ;
    rdfs:comment 'Date of the next scheduled meeting for the investment committee.' ;
    rdfs:domain ind:InvestmentCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:performanceBenchmark rdf:type rdf:Property ;
    rdfs:label 'Performance Benchmark' ;
    rdfs:comment 'Primary benchmark index or composite used to evaluate the performance of investment decisions made by the committee.' ;
    rdfs:domain ind:InvestmentCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryOversightBody rdf:type rdf:Property ;
    rdfs:label 'Regulatory Oversight Body' ;
    rdfs:comment 'Name of the regulatory authority or governing body that oversees the committee\'s activities and compliance requirements.' ;
    rdfs:domain ind:InvestmentCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalMemberCount rdf:type rdf:Property ;
    rdfs:label 'Total Member Count' ;
    rdfs:comment 'Current total number of members serving on the investment committee.' ;
    rdfs:domain ind:InvestmentCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acquirerBankId rdf:type rdf:Property ;
    rdfs:label 'Acquirer Bank Id' ;
    rdfs:comment 'Identifier of the acquiring bank or payment service provider sponsoring this merchant.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CorrespondentBank .

ind:merchantAgreementId rdf:type rdf:Property ;
    rdfs:label 'Merchant Agreement Id' ;
    rdfs:comment 'Identifier of the master merchant services agreement governing the relationship.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MerchantAgreement .

ind:annualTransactionVolume rdf:type rdf:Property ;
    rdfs:label 'Annual Transaction Volume' ;
    rdfs:comment 'Estimated or actual annual transaction volume processed by the merchant in settlement currency.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageTransactionAmount rdf:type rdf:Property ;
    rdfs:label 'Average Transaction Amount' ;
    rdfs:comment 'Average value of individual transactions processed by the merchant in settlement currency.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:businessCountryCode rdf:type rdf:Property ;
    rdfs:label 'Business Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code of the merchant\'s registered business address.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargebackThresholdPercentage rdf:type rdf:Property ;
    rdfs:label 'Chargeback Threshold Percentage' ;
    rdfs:comment 'Maximum allowable chargeback ratio (as percentage of total transactions) before merchant is flagged for review.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:doingBusinessAsName rdf:type rdf:Property ;
    rdfs:label 'Doing Business As Name' ;
    rdfs:comment 'The trade name or DBA name under which the merchant operates, if different from legal name.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isHighRisk rdf:type rdf:Property ;
    rdfs:label 'Is High Risk' ;
    rdfs:comment 'Boolean flag indicating whether the merchant is classified as high-risk based on industry, geography, or transaction patterns.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pciAttestationDate rdf:type rdf:Property ;
    rdfs:label 'Pci Attestation Date' ;
    rdfs:comment 'Date of the merchant\'s most recent PCI DSS compliance attestation or validation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pciComplianceLevel rdf:type rdf:Property ;
    rdfs:label 'Pci Compliance Level' ;
    rdfs:comment 'PCI DSS compliance level assigned to the merchant based on annual transaction volume.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportsCrossBorderPayments rdf:type rdf:Property ;
    rdfs:label 'Supports Cross Border Payments' ;
    rdfs:comment 'Boolean flag indicating whether the merchant is enabled to accept payments from international customers.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsRecurringPayments rdf:type rdf:Property ;
    rdfs:label 'Supports Recurring Payments' ;
    rdfs:comment 'Boolean flag indicating whether the merchant is enabled to process recurring or subscription-based payments.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:automaticEarlyTerminationFlag rdf:type rdf:Property ;
    rdfs:label 'Automatic Early Termination Flag' ;
    rdfs:comment 'Indicates whether automatic early termination provisions apply upon the occurrence of specified events of default or termination events.' ;
    rdfs:domain ind:IsdaMasterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clearingObligationFlag rdf:type rdf:Property ;
    rdfs:label 'Clearing Obligation Flag' ;
    rdfs:comment 'Indicates whether transactions under this agreement are subject to mandatory central clearing requirements under applicable regulations.' ;
    rdfs:domain ind:IsdaMasterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:collateralEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Collateral Eligible Flag' ;
    rdfs:comment 'Indicates whether this ISDA Master Agreement includes provisions for collateral posting (typically via a Credit Support Annex).' ;
    rdfs:domain ind:IsdaMasterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditEventUponMergerFlag rdf:type rdf:Property ;
    rdfs:label 'Credit Event Upon Merger Flag' ;
    rdfs:comment 'Indicates whether a merger or consolidation of either party that results in credit deterioration constitutes a termination event.' ;
    rdfs:domain ind:IsdaMasterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditSupportAnnexType rdf:type rdf:Property ;
    rdfs:label 'Credit Support Annex Type' ;
    rdfs:comment 'The type or jurisdiction of the Credit Support Annex attached to this ISDA Master Agreement, if applicable.' ;
    rdfs:domain ind:IsdaMasterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossDefaultApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Cross Default Applicable Flag' ;
    rdfs:comment 'Indicates whether cross-default provisions are included, allowing termination if either party defaults on other obligations.' ;
    rdfs:domain ind:IsdaMasterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crossDefaultThreshold rdf:type rdf:Property ;
    rdfs:label 'Cross Default Threshold' ;
    rdfs:comment 'The minimum amount of defaulted obligations that triggers a cross-default event under this agreement.' ;
    rdfs:domain ind:IsdaMasterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:documentCustodian rdf:type rdf:Property ;
    rdfs:label 'Document Custodian' ;
    rdfs:comment 'The party or entity responsible for maintaining the original executed copy of the ISDA Master Agreement and related documentation.' ;
    rdfs:domain ind:IsdaMasterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalEntityIdentifierPartyA rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Identifier Party A' ;
    rdfs:comment 'The 20-character ISO 17442 Legal Entity Identifier for Party A to this ISDA Master Agreement.' ;
    rdfs:domain ind:IsdaMasterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalEntityIdentifierPartyB rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Identifier Party B' ;
    rdfs:comment 'The 20-character ISO 17442 Legal Entity Identifier for Party B (the counterparty) to this ISDA Master Agreement.' ;
    rdfs:domain ind:IsdaMasterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:multibranchPartyFlag rdf:type rdf:Property ;
    rdfs:label 'Multibranch Party Flag' ;
    rdfs:comment 'Indicates whether either party is designated as a Multibranch Party, allowing multiple offices to enter into transactions under this agreement.' ;
    rdfs:domain ind:IsdaMasterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nettingEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Netting Eligible Flag' ;
    rdfs:comment 'Indicates whether close-out netting is permitted under this agreement, allowing offsetting of obligations upon termination.' ;
    rdfs:domain ind:IsdaMasterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentNettingFlag rdf:type rdf:Property ;
    rdfs:label 'Payment Netting Flag' ;
    rdfs:comment 'Indicates whether payment netting is enabled, allowing offsetting of payment obligations due on the same date in the same currency.' ;
    rdfs:domain ind:IsdaMasterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:setoffApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Setoff Applicable Flag' ;
    rdfs:comment 'Indicates whether setoff rights are included, allowing parties to offset amounts owed under this agreement against other obligations.' ;
    rdfs:domain ind:IsdaMasterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tradeReportingParty rdf:type rdf:Property ;
    rdfs:label 'Trade Reporting Party' ;
    rdfs:comment 'The party responsible for reporting derivative transactions to trade repositories under regulatory requirements.' ;
    rdfs:domain ind:IsdaMasterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualResolutionMinutes rdf:type rdf:Property ;
    rdfs:label 'Actual Resolution Minutes' ;
    rdfs:comment 'Actual time in minutes taken to resolve the override request from submission to final decision.' ;
    rdfs:domain ind:OverrideRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedByRole rdf:type rdf:Property ;
    rdfs:label 'Approved By Role' ;
    rdfs:comment 'Job role or position of the user who approved the override (e.g., branch manager, operations manager, compliance officer, senior manager).' ;
    rdfs:domain ind:OverrideRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedByUserId rdf:type rdf:Property ;
    rdfs:label 'Approved By User Id' ;
    rdfs:comment 'Identifier of the authorized user who approved the override request, if applicable.' ;
    rdfs:domain ind:OverrideRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceReviewRequired rdf:type rdf:Property ;
    rdfs:label 'Compliance Review Required' ;
    rdfs:comment 'Indicates whether the override request requires review by the compliance department before approval.' ;
    rdfs:domain ind:OverrideRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerId rdf:type rdf:Property ;
    rdfs:label 'Customer Id' ;
    rdfs:comment 'Identifier of the customer on whose behalf the override request is being made.' ;
    rdfs:domain ind:OverrideRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:effectiveEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Effective End Timestamp' ;
    rdfs:comment 'Date and time when the approved override expires and is no longer valid. Null indicates indefinite validity.' ;
    rdfs:domain ind:OverrideRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:effectiveStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Effective Start Timestamp' ;
    rdfs:comment 'Date and time when the approved override becomes effective and can be applied.' ;
    rdfs:domain ind:OverrideRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:expirationDurationDays rdf:type rdf:Property ;
    rdfs:label 'Expiration Duration Days' ;
    rdfs:comment 'Number of days the override remains valid from the effective start date, if time-limited.' ;
    rdfs:domain ind:OverrideRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requestedByRole rdf:type rdf:Property ;
    rdfs:label 'Requested By Role' ;
    rdfs:comment 'Job role or position of the user who requested the override (e.g., teller, relationship manager, branch manager, customer service representative).' ;
    rdfs:domain ind:OverrideRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedByUserId rdf:type rdf:Property ;
    rdfs:label 'Requested By User Id' ;
    rdfs:comment 'Identifier of the bank employee or system user who initiated the override request.' ;
    rdfs:domain ind:OverrideRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requestedLimitValue rdf:type rdf:Property ;
    rdfs:label 'Requested Limit Value' ;
    rdfs:comment 'The new limit or threshold value being requested through the override.' ;
    rdfs:domain ind:OverrideRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requestedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Requested Timestamp' ;
    rdfs:comment 'Date and time when the override request was submitted into the system.' ;
    rdfs:domain ind:OverrideRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requiresDualAuthorization rdf:type rdf:Property ;
    rdfs:label 'Requires Dual Authorization' ;
    rdfs:comment 'Indicates whether the override request requires approval from two authorized users for enhanced control.' ;
    rdfs:domain ind:OverrideRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:secondaryApprovalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Secondary Approval Timestamp' ;
    rdfs:comment 'Date and time when the second approval was granted for dual-authorization overrides.' ;
    rdfs:domain ind:OverrideRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:secondaryApproverUserId rdf:type rdf:Property ;
    rdfs:label 'Secondary Approver User Id' ;
    rdfs:comment 'Identifier of the second authorized user who approved the override, if dual authorization is required.' ;
    rdfs:domain ind:OverrideRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaTargetResolutionMinutes rdf:type rdf:Property ;
    rdfs:label 'Sla Target Resolution Minutes' ;
    rdfs:comment 'Target time in minutes within which the override request should be resolved according to service level agreements.' ;
    rdfs:domain ind:OverrideRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paymentProcessorId rdf:type rdf:Property ;
    rdfs:label 'Payment Processor Id' ;
    rdfs:comment 'Primary key for payment_processor' ;
    rdfs:domain ind:PaymentProcessor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:apiVersion rdf:type rdf:Property ;
    rdfs:label 'Api Version' ;
    rdfs:comment 'Version of the processor API currently integrated with the payment hub.' ;
    rdfs:domain ind:PaymentProcessor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingSystemCode rdf:type rdf:Property ;
    rdfs:label 'Clearing System Code' ;
    rdfs:comment 'Code identifying the clearing system or network the processor participates in (e.g., FEDWIRE, CHIPS, TARGET2).' ;
    rdfs:domain ind:PaymentProcessor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:messageFormat rdf:type rdf:Property ;
    rdfs:label 'Message Format' ;
    rdfs:comment 'Standard message format used for communication with this processor.' ;
    rdfs:domain ind:PaymentProcessor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingFeeStructure rdf:type rdf:Property ;
    rdfs:label 'Processing Fee Structure' ;
    rdfs:comment 'Type of fee structure applied by this processor for payment processing services.' ;
    rdfs:domain ind:PaymentProcessor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processorCode rdf:type rdf:Property ;
    rdfs:label 'Processor Code' ;
    rdfs:comment 'Unique business identifier code for the payment processor used in payment routing and reconciliation.' ;
    rdfs:domain ind:PaymentProcessor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processorName rdf:type rdf:Property ;
    rdfs:label 'Processor Name' ;
    rdfs:comment 'Full legal name of the payment processor organization.' ;
    rdfs:domain ind:PaymentProcessor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processorType rdf:type rdf:Property ;
    rdfs:label 'Processor Type' ;
    rdfs:comment 'Classification of the payment processor by the type of payment processing capability it provides.' ;
    rdfs:domain ind:PaymentProcessor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Regulatory License Number' ;
    rdfs:comment 'License or registration number issued by the relevant financial regulatory authority for this processor.' ;
    rdfs:domain ind:PaymentProcessor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaProcessingTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Sla Processing Time Minutes' ;
    rdfs:comment 'Target processing time in minutes as defined in the service level agreement with the processor.' ;
    rdfs:domain ind:PaymentProcessor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supportedPaymentMethods rdf:type rdf:Property ;
    rdfs:label 'Supported Payment Methods' ;
    rdfs:comment 'Comma-separated list of payment methods supported by this processor (e.g., CREDIT_TRANSFER, DEBIT_TRANSFER, CARD_PAYMENT).' ;
    rdfs:domain ind:PaymentProcessor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportsCrossBorder rdf:type rdf:Property ;
    rdfs:label 'Supports Cross Border' ;
    rdfs:comment 'Indicates whether this processor supports cross-border international payment processing.' ;
    rdfs:domain ind:PaymentProcessor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsFxConversion rdf:type rdf:Property ;
    rdfs:label 'Supports Fx Conversion' ;
    rdfs:comment 'Indicates whether this processor provides foreign exchange conversion services.' ;
    rdfs:domain ind:PaymentProcessor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:swiftBic rdf:type rdf:Property ;
    rdfs:label 'Swift Bic' ;
    rdfs:comment 'SWIFT BIC code for the processor if applicable for international wire and SWIFT message processing.' ;
    rdfs:domain ind:PaymentProcessor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allowsHalfPoints rdf:type rdf:Property ;
    rdfs:label 'Allows Half Points' ;
    rdfs:comment 'Indicates whether the rating scale permits half-point or fractional ratings (e.g., 3.5 on a 5-point scale).' ;
    rdfs:domain ind:RatingScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:applicableEmployeeTypes rdf:type rdf:Property ;
    rdfs:label 'Applicable Employee Types' ;
    rdfs:comment 'Types of employees for whom this rating scale is used (e.g., \'Full-Time\', \'Part-Time\', \'Contract\', \'Temporary\').' ;
    rdfs:domain ind:RatingScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableJobLevels rdf:type rdf:Property ;
    rdfs:label 'Applicable Job Levels' ;
    rdfs:comment 'Comma-separated list or description of job levels or grades to which this rating scale applies (e.g., \'Executive\', \'Manager\', \'Individual Contributor\').' ;
    rdfs:domain ind:RatingScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultMidpointValue rdf:type rdf:Property ;
    rdfs:label 'Default Midpoint Value' ;
    rdfs:comment 'The neutral or midpoint value on the scale, often representing \'meets expectations\' or \'satisfactory\' performance.' ;
    rdfs:domain ind:RatingScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incrementValue rdf:type rdf:Property ;
    rdfs:label 'Increment Value' ;
    rdfs:comment 'The step or increment between rating values (e.g., 0.5 for half-point increments, 1.0 for whole numbers).' ;
    rdfs:domain ind:RatingScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isBidirectional rdf:type rdf:Property ;
    rdfs:label 'Is Bidirectional' ;
    rdfs:comment 'Indicates whether the scale measures in both positive and negative directions (e.g., -2 to +2 for improvement/decline scales).' ;
    rdfs:domain ind:RatingScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDefaultScale rdf:type rdf:Property ;
    rdfs:label 'Is Default Scale' ;
    rdfs:comment 'Indicates whether this rating scale is the default scale used when no specific scale is assigned to an evaluation.' ;
    rdfs:domain ind:RatingScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isNumeric rdf:type rdf:Property ;
    rdfs:label 'Is Numeric' ;
    rdfs:comment 'Indicates whether the rating scale uses numeric values (true) or qualitative labels only (false).' ;
    rdfs:domain ind:RatingScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maximumValue rdf:type rdf:Property ;
    rdfs:label 'Maximum Value' ;
    rdfs:comment 'The highest numeric value on the rating scale (e.g., 5 for a 1-5 scale).' ;
    rdfs:domain ind:RatingScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumValue rdf:type rdf:Property ;
    rdfs:label 'Minimum Value' ;
    rdfs:comment 'The lowest numeric value on the rating scale (e.g., 1 for a 1-5 scale).' ;
    rdfs:domain ind:RatingScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:numberOfLevels rdf:type rdf:Property ;
    rdfs:label 'Number Of Levels' ;
    rdfs:comment 'Total count of distinct rating levels or points on the scale (e.g., 5 for a 5-point scale).' ;
    rdfs:domain ind:RatingScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scaleCode rdf:type rdf:Property ;
    rdfs:label 'Scale Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the rating scale for system integration and reporting (e.g., \'PERF_5PT\', \'LEAD_COMP\').' ;
    rdfs:domain ind:RatingScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scaleName rdf:type rdf:Property ;
    rdfs:label 'Scale Name' ;
    rdfs:comment 'The business name of the rating scale (e.g., \'5-Point Performance Scale\', \'Leadership Competency Scale\').' ;
    rdfs:domain ind:RatingScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scaleStatus rdf:type rdf:Property ;
    rdfs:label 'Scale Status' ;
    rdfs:comment 'Current lifecycle status of the rating scale indicating whether it is available for use in evaluations.' ;
    rdfs:domain ind:RatingScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scaleType rdf:type rdf:Property ;
    rdfs:label 'Scale Type' ;
    rdfs:comment 'The category or purpose of the rating scale (e.g., performance evaluation, competency assessment, behavioral rating).' ;
    rdfs:domain ind:RatingScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemId rdf:type rdf:Property ;
    rdfs:label 'Source System Id' ;
    rdfs:comment 'The unique identifier for this rating scale in the source system of record.' ;
    rdfs:domain ind:RatingScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competenciesCount rdf:type rdf:Property ;
    rdfs:label 'Competencies Count' ;
    rdfs:comment 'The total number of individual competencies defined within this framework.' ;
    rdfs:domain ind:CompetencyFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:externalReferenceId rdf:type rdf:Property ;
    rdfs:label 'External Reference Id' ;
    rdfs:comment 'The unique identifier for this competency framework in the source system or external HR platform.' ;
    rdfs:domain ind:CompetencyFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frameworkCategory rdf:type rdf:Property ;
    rdfs:label 'Framework Category' ;
    rdfs:comment 'Categorization indicating the scope and application context of the framework within the organization.' ;
    rdfs:domain ind:CompetencyFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frameworkCode rdf:type rdf:Property ;
    rdfs:label 'Framework Code' ;
    rdfs:comment 'Business identifier code for the competency framework, used for external reference and integration with HR systems.' ;
    rdfs:domain ind:CompetencyFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frameworkName rdf:type rdf:Property ;
    rdfs:label 'Framework Name' ;
    rdfs:comment 'The official name of the competency framework (e.g., Leadership Competencies, Technical Skills Framework, Risk Management Competencies).' ;
    rdfs:domain ind:CompetencyFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frameworkType rdf:type rdf:Property ;
    rdfs:label 'Framework Type' ;
    rdfs:comment 'Classification of the competency framework by its primary focus area.' ;
    rdfs:domain ind:CompetencyFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industryStandardAlignment rdf:type rdf:Property ;
    rdfs:label 'Industry Standard Alignment' ;
    rdfs:comment 'Reference to external industry standards or professional bodies that this competency framework aligns with (e.g., CFA Institute, GARP, ACCA).' ;
    rdfs:domain ind:CompetencyFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobFamilyId rdf:type rdf:Property ;
    rdfs:label 'Job Family Id' ;
    rdfs:comment 'Reference to the job family associated with this competency framework. Null if framework applies across multiple job families.' ;
    rdfs:domain ind:CompetencyFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:proficiencyLevelsCount rdf:type rdf:Property ;
    rdfs:label 'Proficiency Levels Count' ;
    rdfs:comment 'The number of proficiency levels defined within this competency framework (e.g., 3-level, 5-level, 7-level scale).' ;
    rdfs:domain ind:CompetencyFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedById rdf:type rdf:Property ;
    rdfs:label 'Approved By Id' ;
    rdfs:comment 'Reference to the bank employee who approved the merchant agreement.' ;
    rdfs:domain ind:MerchantAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:autoRenewalEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Enabled' ;
    rdfs:comment 'Indicates whether the agreement automatically renews upon expiration.' ;
    rdfs:domain ind:MerchantAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:chargebackFee rdf:type rdf:Property ;
    rdfs:label 'Chargeback Fee' ;
    rdfs:comment 'Fee charged to the merchant for each chargeback or dispute processed.' ;
    rdfs:domain ind:MerchantAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fxConversionEnabled rdf:type rdf:Property ;
    rdfs:label 'Fx Conversion Enabled' ;
    rdfs:comment 'Indicates whether dynamic currency conversion or multi-currency settlement is enabled.' ;
    rdfs:domain ind:MerchantAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentGatewayProvider rdf:type rdf:Property ;
    rdfs:label 'Payment Gateway Provider' ;
    rdfs:comment 'Name of the third-party payment gateway or processor used for transaction routing (e.g., ACI Worldwide, Volante).' ;
    rdfs:domain ind:MerchantAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentMethodsAccepted rdf:type rdf:Property ;
    rdfs:label 'Payment Methods Accepted' ;
    rdfs:comment 'Comma-separated list of payment methods enabled under this agreement (e.g., Visa, Mastercard, ACH, Wire). [ENUM-REF-CANDIDATE: visa|mastercard|amex|discover|ach|wire|sepa|swift|rtgs|faster_payments — promote to reference product]' ;
    rdfs:domain ind:MerchantAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipManagerId rdf:type rdf:Property ;
    rdfs:label 'Relationship Manager Id' ;
    rdfs:comment 'Reference to the bank employee responsible for managing the merchant relationship.' ;
    rdfs:domain ind:MerchantAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reserveHoldPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Reserve Hold Period Days' ;
    rdfs:comment 'Number of days that reserve funds are held before release to the merchant.' ;
    rdfs:domain ind:MerchantAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reserveRequirementPercentage rdf:type rdf:Property ;
    rdfs:label 'Reserve Requirement Percentage' ;
    rdfs:comment 'Percentage of transaction volume held in reserve to cover chargebacks and disputes.' ;
    rdfs:domain ind:MerchantAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementAccountId rdf:type rdf:Property ;
    rdfs:label 'Settlement Account Id' ;
    rdfs:comment 'Reference to the nostro or internal account used for settling funds to the merchant.' ;
    rdfs:domain ind:MerchantAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:settlementFrequency rdf:type rdf:Property ;
    rdfs:label 'Settlement Frequency' ;
    rdfs:comment 'Frequency at which payment settlements are processed and transferred to the merchant.' ;
    rdfs:domain ind:MerchantAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signedDate rdf:type rdf:Property ;
    rdfs:label 'Signed Date' ;
    rdfs:comment 'Date when the merchant agreement was executed and signed by all parties.' ;
    rdfs:domain ind:MerchantAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transactionFeeFixed rdf:type rdf:Property ;
    rdfs:label 'Transaction Fee Fixed' ;
    rdfs:comment 'Fixed fee amount charged per transaction in the settlement currency, independent of transaction value.' ;
    rdfs:domain ind:MerchantAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionLimitMonthly rdf:type rdf:Property ;
    rdfs:label 'Transaction Limit Monthly' ;
    rdfs:comment 'Maximum aggregate transaction value allowed per month under this agreement.' ;
    rdfs:domain ind:MerchantAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionLimitSingle rdf:type rdf:Property ;
    rdfs:label 'Transaction Limit Single' ;
    rdfs:comment 'Maximum value allowed for a single transaction under this agreement.' ;
    rdfs:domain ind:MerchantAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reversalDistributionEventId rdf:type rdf:Property ;
    rdfs:label 'Reversal Distribution Event Id' ;
    rdfs:comment 'Self-referencing FK on distribution_event (reversal_distribution_event_id)' ;
    rdfs:domain ind:DistributionEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionEvent .

ind:masterFundId rdf:type rdf:Property ;
    rdfs:label 'Master Fund Id' ;
    rdfs:comment 'Self-referencing FK on fund (master_fund_id)' ;
