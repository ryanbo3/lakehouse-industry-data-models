    rdfs:comment 'Code of the higher-level committee to which transactions exceeding this committee\'s authority are escalated.' ;
    rdfs:domain ind:ApprovalCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Geographic Jurisdiction' ;
    rdfs:comment 'Geographic scope of the committee\'s approval authority (e.g., Global, Americas, EMEA, APAC, specific country codes).' ;
    rdfs:domain ind:ApprovalCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumApprovalThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Approval Threshold Amount' ;
    rdfs:comment 'Maximum transaction value that this committee is authorized to approve without escalation, expressed in the base currency.' ;
    rdfs:domain ind:ApprovalCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:meetingFrequency rdf:type rdf:Property ;
    rdfs:label 'Meeting Frequency' ;
    rdfs:comment 'Standard frequency at which the committee convenes for approval reviews and decision-making sessions.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:memberCount rdf:type rdf:Property ;
    rdfs:label 'Member Count' ;
    rdfs:comment 'Total number of active members currently serving on the approval committee.' ;
    rdfs:domain ind:ApprovalCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumApprovalThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Approval Threshold Amount' ;
    rdfs:comment 'Minimum transaction value that requires approval from this committee, expressed in the base currency.' ;
    rdfs:domain ind:ApprovalCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minutesRetentionPeriodYears rdf:type rdf:Property ;
    rdfs:label 'Minutes Retention Period Years' ;
    rdfs:comment 'Number of years that committee meeting minutes and approval records must be retained per regulatory and corporate policy requirements.' ;
    rdfs:domain ind:ApprovalCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productLineCoverage rdf:type rdf:Property ;
    rdfs:label 'Product Line Coverage' ;
    rdfs:comment 'Investment banking product lines covered by this committee\'s approval authority (e.g., M&A Advisory, Equity Capital Markets, Debt Capital Markets, Leveraged Finance).' ;
    rdfs:domain ind:ApprovalCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quorumRequirement rdf:type rdf:Property ;
    rdfs:label 'Quorum Requirement' ;
    rdfs:comment 'Minimum number of committee members required to be present for a valid approval decision.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryOversightFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Oversight Flag' ;
    rdfs:comment 'Indicates whether this committee\'s decisions are subject to regulatory oversight or reporting requirements.' ;
    rdfs:domain ind:ApprovalCommittee ;
