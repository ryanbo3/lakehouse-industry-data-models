    rdfs:range xsd:string .

ind:delegationAuthorityFlag rdf:type rdf:Property ;
    rdfs:label 'Delegation Authority Flag' ;
    rdfs:comment 'Indicates whether this committee has the authority to delegate approval decisions to sub-committees or individual officers.' ;
    rdfs:domain ind:ApprovalCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalationCommitteeCode rdf:type rdf:Property ;
