# RDFS Schema for Business: Banking

@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix ind: <http://datamodel.lakehouse.org/business/banking#> .

# --- Root Business Class ---
ind:Business rdf:type rdfs:Class ;
    rdfs:label 'Business' ;
    rdfs:comment 'Root class for all business entities' .

# --- Specific Business: Banking ---
ind:Banking rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Business ;
    rdfs:label 'Banking' ;
    rdfs:comment 'Retail and Investment Banking is a cornerstone of the global financial system, providing commercial lending, investment banking, securities trading, asset management, and wealth advisory services to corporations, governments, and individuals.' .

# --- Domain Classes ---
ind:Customer rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Banking ;
    rdfs:label 'Customer' ;
    rdfs:comment 'Single source of truth for all client and counterparty identities across retail, corporate, institutional, and government segments. Owns KYC/CDD onboarding, customer lifecycle management, beneficial ownership, relationship hierarchies, customer segmentation, NPS tracking, and CLTV scoring. Supports CRM integration and serves as the FK reference for all other domains requiring party identification.' .

ind:Account rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Banking ;
    rdfs:label 'Account' ;
    rdfs:comment 'Authoritative registry of all deposit and transactional accounts including DDA, savings, money market, certificates of deposit, and custodial accounts. Manages account lifecycle, balance tracking, interest accrual parameters, IBAN/BIC assignment, account-level limits, and statement generation. Core system of record aligned with Temenos T24 / FIS Profile.' .

ind:Loan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Banking ;
    rdfs:label 'Loan' ;
    rdfs:comment 'End-to-end management of commercial lending, consumer loans, mortgages, revolving credit facilities, syndicated loans, and trade finance operations including letters of credit, documentary collections, bank guarantees, supply chain finance, export/import financing, and bill of lading management. Owns credit origination, underwriting, loan booking, covenant tracking, amortization, trade finance lifecycle, UCP 600/URDG 758 compliance, and all lending-related regulatory reporting.' .

ind:Payment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Banking ;
    rdfs:label 'Payment' ;
    rdfs:comment 'Payment processing and settlement covering ACH, wire transfers, RTGS, SWIFT messaging, FX transactions, card payments, and cross-border payments. Manages payment instructions, clearing, T+1 settlement cycles, payment routing, nostro/vostro reconciliation, and SWIFT message lifecycle. Primary system of record aligned with ACI Worldwide / Volante Payment Hub.' .

ind:Security rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Banking ;
    rdfs:label 'Security' ;
    rdfs:comment 'Master data for all securities and financial instruments including equities, fixed income, derivatives, MBS, ABS, CDS, CLO, CDO, and OTC instruments. Owns instrument master (ISIN, CUSIP, SEDOL), security classification, pricing, corporate actions, and security lifecycle. Provides the golden source instrument reference for trade, investment, and wealth domains.' .

ind:Trade rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Banking ;
    rdfs:label 'Trade' ;
    rdfs:comment 'Securities trading, order management, trade capture, execution, position management, P&L attribution, and post-trade processing for capital markets and trading book activities. Manages the full trade lifecycle from order entry through settlement, MTM valuation, trade confirmations, and FX/OTC derivative execution. Primary system of record aligned with Murex / Calypso.' .

ind:Investment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Banking ;
    rdfs:label 'Investment' ;
    rdfs:comment 'Investment banking advisory services including M&A, IPO underwriting, DCF valuation, debt and equity capital markets origination, syndicated lending mandates, and corporate finance. Manages deal pipelines, pitch books, mandate agreements, transaction structures, fee arrangements, and tombstone records.' .

ind:Wealth rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Banking ;
    rdfs:label 'Wealth' ;
    rdfs:comment 'Wealth management and private banking including portfolio construction, asset allocation, AUM tracking, NAV calculation, client reporting, rebalancing, and investment policy statements. Manages high-net-worth and ultra-high-net-worth client relationships and suitability assessments. Primary system of record aligned with SimCorp Dimension / BlackRock Aladdin.' .

ind:Risk rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Banking ;
    rdfs:label 'Risk' ;
    rdfs:comment 'Enterprise-wide risk measurement and management covering market risk (VaR, CVA), credit risk (RWA, ECL), operational risk (SMA), and liquidity risk (LCR, NSFR). Supports CCAR, DFAST stress testing, RAROC, KRI monitoring, IRB models, PD/LGD/EAD aggregation, and risk appetite framework. Primary system of record aligned with SAS Risk Management / Moodys RiskAuthority.' .

ind:Collateral rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Banking ;
    rdfs:label 'Collateral' ;
    rdfs:comment 'Collateral management for secured lending, derivatives (ISDA CSA), repo/reverse repo transactions, and margin requirements. Owns collateral valuation, haircut schedules, margin calls, substitution rights, CSA agreement tracking, collateral eligibility rules, and initial/variation margin calculations under Basel III.' .

ind:Treasury rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Banking ;
    rdfs:label 'Treasury' ;
    rdfs:comment 'Treasury operations including liquidity management, funds transfer pricing (FTP), ALM, ALCO reporting, interest rate risk management, and balance sheet optimization. Owns LCR, NSFR, CET1 capital ratios, interbank funding, repo/reverse repo funding strategies, and capital planning. Interfaces with ledger and regulatory reporting.' .

ind:Ledger rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Banking ;
    rdfs:label 'Ledger' ;
    rdfs:comment 'General ledger and financial accounting system of record covering chart of accounts, journal entries, subledgers, cost centers, intercompany eliminations, AP/AR, financial close, consolidation, and trial balance. Supports SOX financial controls and IFRS/GAAP reporting. Primary system of record aligned with Oracle Financials / SAP S/4HANA.' .

ind:Compliance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Banking ;
    rdfs:label 'Compliance' ;
    rdfs:comment 'Regulatory compliance governance including AML transaction monitoring, KYC/CDD refresh, SAR/CTR filing, OFAC/sanctions screening, FATCA/CRS reporting, SOX controls, financial crime case management, and regulatory examination support. Manages audit trails and regulatory correspondence. Primary system of record aligned with NICE Actimize / Oracle Financial Crime.' .

ind:Channel rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Banking ;
    rdfs:label 'Channel' ;
    rdfs:comment 'Customer interaction channels including digital banking (mobile/web), branch network, ATM, contact center, relationship managers, and API/open banking. Manages channel configuration, omnichannel orchestration, customer journey tracking, session management, SLA tracking, and channel-specific product offerings.' .

ind:Reference rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Banking ;
    rdfs:label 'Reference' ;
    rdfs:comment 'Centralized golden source for all enterprise reference and master data including currency codes (ISO 4217), country codes, interest rate benchmarks (SOFR, LIBOR transition), instrument classification codes (ISIN, CUSIP, SEDOL, FIGI), exchange rates, holiday calendars, BIC codes, market data, and regulatory reporting taxonomies.' .

ind:Fraud rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Banking ;
    rdfs:label 'Fraud' ;
    rdfs:comment 'Operational fraud case management covering fraud detection alerts, investigation workflows, case disposition, chargeback management, loss recovery, and SAR escalation. Manages fraud typologies, rule configurations, and case outcomes for retail, card, and wire fraud. Distinct from compliance AML monitoring.' .

ind:Asset rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Banking ;
    rdfs:label 'Asset' ;
    rdfs:comment 'Fund and asset management covering mutual funds, ETFs, hedge funds, pension funds, fund accounting, NAV calculation, fund distribution, investor servicing, transfer agency, and fund regulatory reporting. Manages the full fund lifecycle from launch through liquidation.' .

# --- Data Product Classes (Tables) ---
ind:Deal rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Investment ;
    rdfs:label 'Deal' ;
    rdfs:comment 'Core master entity representing an investment banking deal or transaction mandate. Captures the full lifecycle from origination through closing, including deal type (M&A buy-side/sell-side, ECM, DCM, LBO, restructuring), stage progression (origination, pitch, mandate, execution, pricing, closing, post-closing), deal size, target enterprise value, expected fee, mandate date, closing date, status, originating banker, pipeline probability, and key milestone dates. Serves as the primary anchor entity for all investment domain relationships — mandate, valuation, offering, syndication, tombstone, fee arrangement, regulatory filing, and deal participants all reference this entity.' .

ind:InvestmentMandate rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Investment ;
    rdfs:label 'Investment Mandate' ;
    rdfs:comment 'Formal mandate agreement record capturing the engagement between the bank and a client for a specific investment banking transaction. Records mandate type (exclusive, co-advisor, bookrunner, co-manager), mandate letter date, engagement scope, exclusivity period, termination rights, governing law, and signatory details. Distinct from the deal entity — a mandate is the contractual authorization to execute a deal.' .

ind:TransactionStructure rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Investment ;
    rdfs:label 'Transaction Structure' ;
    rdfs:comment 'Master entity defining the financial and legal structure of an investment banking transaction. Captures structure type (merger, acquisition, carve-out, spin-off, IPO, follow-on, rights issue, bond issuance, syndicated loan), consideration type (cash, stock, mixed), financing mix, leverage ratio, pro forma capital structure, regulatory approvals required, and structural conditions. Supports DCF valuation and deal execution planning.' .

ind:InvestmentValuation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Investment ;
    rdfs:label 'Investment Valuation' ;
    rdfs:comment 'Master record for financial valuations and fairness opinions performed in support of investment banking transactions. Captures valuation methodology (DCF, LBO, comparable company analysis, precedent transactions, sum-of-parts, NAV), valuation date, enterprise value range, equity value range, implied multiples (EV/EBITDA, P/E), discount rate (WACC), terminal growth rate, analyst, approval status, and — for fairness opinions — opinion type (fairness, solvency, valuation), opinion conclusion (fair, not fair, unable to opine), board presentation date, approval committee, and regulatory filing reference. Supports deal pricing, fiduciary duty compliance in public M&A, and investment committee approvals.' .

ind:FeeArrangement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Investment ;
    rdfs:label 'Fee Arrangement' ;
    rdfs:comment 'Master entity capturing the fee structure, economics, and all payment events for investment banking mandates. Records fee type (retainer, success fee, underwriting spread, advisory fee, break fee, tail fee), fee basis (fixed, percentage, tiered), fee amount, payment milestones, fee sharing with co-advisors, revenue recognition schedule, and individual fee payment event details including event type (retainer payment, success fee trigger, closing fee, break fee), event date, invoiced amount, received amount, payment status, reconciliation reference, and revenue recognition date. Critical for IB revenue management, P&L attribution, banker compensation, and finance reconciliation.' .

ind:Syndication rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Investment ;
    rdfs:label 'Syndication' ;
    rdfs:comment 'Master entity for syndicated lending and capital markets syndication activities. Captures syndication type (primary syndication, secondary sell-down, club deal), total facility size, bank\'s hold amount, target sell-down amount, syndication status, bookrunner role, co-arranger list, syndication launch date, and pricing flex. Supports loan syndication desk operations and CLO/ABS structuring activities.' .

ind:Underwriting rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Investment ;
    rdfs:label 'Underwriting' ;
    rdfs:comment 'Master entity representing the bank\'s underwriting commitment for equity or debt capital markets transactions. Captures commitment type (firm commitment, best efforts, standby), underwritten amount, underwriting spread, over-allotment option (greenshoe), commitment date, pricing date, settlement date, and syndicate role (lead bookrunner, joint bookrunner, co-manager). Tracks the bank\'s risk exposure during the underwriting period.' .

ind:InvestorOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Investment ;
    rdfs:label 'Investor Order' ;
    rdfs:comment 'Transactional record capturing individual investor orders received during the bookbuilding process for ECM and DCM transactions. Records investor name, order type (strike, limit, step), order size, price limit, order date and time, order status (active, filled, cancelled), allocation received, and investor tier classification. Enables bookrunner to manage the order book and determine final pricing and allocation.' .

ind:CoverageAssignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Investment ;
    rdfs:label 'Coverage Assignment' ;
    rdfs:comment 'Master entity tracking the assignment of investment banking coverage bankers to client relationships and industry sectors. Records coverage banker, client entity, sector (TMT, healthcare, energy, financials, industrials), geography, coverage role (primary, secondary, sector specialist), assignment dates, and deal origination attribution. Supports banker accountability, client relationship management, and revenue attribution for the IB division.' .

ind:DealParticipant rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Investment ;
    rdfs:label 'Deal Participant' ;
    rdfs:comment 'Association entity capturing all parties involved in an investment banking deal — including the client, target company, acquirer, co-advisors, legal counsel, auditors, regulators, and other deal counterparties. Records participant role, institution name, engagement start date, engagement end date, and conflict check status. Enables deal team management and conflict of interest screening.' .

ind:Offering rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Investment ;
    rdfs:label 'Offering' ;
    rdfs:comment 'Master entity for equity and debt capital markets offerings managed by the investment banking division. Captures offering type (IPO, follow-on, rights issue, convertible bond, investment grade bond, high yield bond, hybrid), issuer, offering size, pricing, currency, exchange listing, regulatory filing status (S-1, F-1, prospectus), settlement date, and ISIN/CUSIP assigned. The primary ECM/DCM transaction record.' .

ind:Factor rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Risk ;
    rdfs:label 'Factor' ;
    rdfs:comment 'Master registry of all enterprise risk factors used in quantitative risk models. Captures market risk drivers (interest rate curves, FX rates, equity indices, commodity prices, credit spreads), credit risk parameters (PD, LGD, EAD), and operational risk indicators. Each factor has a unique identifier, factor type, asset class, tenor/maturity, data source, calibration methodology, historical time series reference, and regulatory classification under Basel III/FRTB. Serves as the canonical SSOT for risk factor definitions and model linkage.' .

ind:Appetite rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Risk ;
    rdfs:label 'Appetite' ;
    rdfs:comment 'Enterprise risk appetite framework defining quantitative and qualitative thresholds, tolerances, and limits across all risk categories (credit, market, liquidity, operational). Captures board-approved risk appetite statements, metric definitions, breach escalation rules, and linkage to ALCO/CCAR governance. Serves as the authoritative source for enterprise-wide risk tolerance boundaries.' .

ind:RiskLimit rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Risk ;
    rdfs:label 'Risk Limit' ;
    rdfs:comment 'Operational risk limit registry, utilization tracking, and breach management record. Captures approved exposure limits by risk type (credit, market, liquidity, concentration), counterparty, portfolio, desk, LOB, and geography. Includes limit amount, currency, effective/expiry dates, approval authority, utilization basis, and breach action rules. Records limit breach events including breach date/time, limit type, breached threshold, actual value, excess amount, severity classification, responsible desk/LOB, escalation chain, remediation actions, and resolution status. Supports real-time limit monitoring, breach governance, and regulatory capital constraint management under Basel III/FRTB.' .

ind:CreditExposure rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Risk ;
    rdfs:label 'Credit Exposure' ;
    rdfs:comment 'Transactional record of credit exposure measurement, risk-weighted asset (RWA) calculation, and counterparty credit valuation adjustment (CVA) for obligors, counterparties, and portfolios. For exposure measurement: captures current exposure, potential future exposure (PFE), expected exposure (EE), EAD, netting set identifiers, collateral offsets, and exposure by regulatory approach (SA and IRB). For RWA: captures credit, market, and operational RWA by portfolio, asset class, and regulatory framework (Basel III/CRR2), with capital ratios (CET1, Tier 1, Total Capital) and Pillar 3 disclosure metadata. For CVA: captures CVA, DVA, FVA for OTC derivative counterparty credit risk including counterparty PD, LGD, expected exposure profile, netting set, CSA terms, hedging instruments, and regulatory CVA capital charge under SA-CVA/BA-CVA. Includes concentration risk metrics: single-name, sector, geographic, and product concentration exposures, HHI, and regulatory large exposure reporting under CRR Article 395. Primary input to CCAR/DFAST stress testing, ECL provisioning, and concentration limit monitoring. Sourced from Murex/Calypso and SAS Risk Management.' .

ind:MarketRiskPosition rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Risk ;
    rdfs:label 'Market Risk Position' ;
    rdfs:comment 'Daily mark-to-market risk position record for trading book and banking book instruments. For trading book: captures MTM value, VaR (historical simulation, Monte Carlo, parametric), stressed VaR, IRC, sensitivity measures (DV01, CS01, delta, gamma, vega), P&L attribution, and FRTB IMA/SA capital charges. For banking book (IRRBB): captures repricing gap analysis, NII sensitivity, EVE sensitivity, basis risk, optionality risk, yield curve shock scenarios (parallel shift, twist, steepener, flattener), NII at risk, EVE at risk, and BCBS IRRBB standard compliance metrics. Sourced from Murex/Calypso trading system and SAS Risk Management. Supports ALCO reporting, treasury ALM coordination, FRTB regulatory submissions, and IRRBB supervisory outlier test compliance.' .

ind:RiskEclProvision rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Risk ;
    rdfs:label 'Risk Ecl Provision' ;
    rdfs:comment 'Expected Credit Loss (ECL) provisioning and credit quality classification record under IFRS 9 and CECL frameworks. For ECL calculation: captures stage classification (Stage 1/2/3), 12-month ECL, lifetime ECL, PD term structure, LGD estimates, EAD, discount rate, forward-looking macroeconomic overlays, and provision movement. For NPL classification: captures NPL stage (substandard, doubtful, loss), days past due, forbearance flag, cure status, write-off amount, recovery expectation, EBA NPL definition compliance, and NPL ratio reporting. Supports regulatory reporting to FASB, IASB, OCC, EBA, and prudential regulators. Primary output for credit risk provisioning and impairment reporting.' .

ind:CounterpartyRating rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Risk ;
    rdfs:label 'Counterparty Rating' ;
    rdfs:comment 'Internal and external credit rating record for counterparties, obligors, and issuers. Captures internal rating grade, external agency ratings (S&P, Moody\'s, Fitch), rating outlook, watch status, PD mapping, rating migration history, rating methodology, analyst override flags, and regulatory risk weight mapping under CRR/Basel III. Supports credit underwriting and RWA calculation.' .

ind:StressScenario rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Risk ;
    rdfs:label 'Stress Scenario' ;
    rdfs:comment 'Stress testing scenario master record for CCAR, DFAST, ICAAP, and internal stress programs. Captures scenario name, regulatory program (CCAR/DFAST/EBA), scenario severity (baseline, adverse, severely adverse), macroeconomic variable shocks (GDP, unemployment, HPI, interest rates), scenario vintage, approval status, and linkage to stress run results. Sourced from AxiomSL/OneSumX regulatory reporting platform.' .

ind:StressTestRun rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Risk ;
    rdfs:label 'Stress Test Run' ;
    rdfs:comment 'Stress test execution record capturing results of a specific stress scenario applied to a portfolio or enterprise. Captures run date, scenario reference, portfolio scope, stressed capital ratios (CET1, Tier 1, Total Capital), stressed RWA, stressed ECL, stressed NII/NIM impact, LCR/NSFR impact, and regulatory submission metadata. Primary output for CCAR/DFAST regulatory submissions.' .

ind:LiquidityMetric rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Risk ;
    rdfs:label 'Liquidity Metric' ;
    rdfs:comment 'Daily liquidity risk measurement record capturing LCR (Liquidity Coverage Ratio), NSFR (Net Stable Funding Ratio), intraday liquidity positions, survival horizon, HQLA (High Quality Liquid Assets) buffer, net cash outflows, and available stable funding. Supports ALCO reporting, regulatory LCR/NSFR submissions to Fed/OCC/PRA, and internal liquidity stress testing.' .

ind:OperationalRiskEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Risk ;
    rdfs:label 'Operational Risk Event' ;
    rdfs:comment 'Operational risk loss event record capturing actual losses and near-miss incidents across the enterprise. Captures event date, discovery date, Basel event type category (internal fraud, external fraud, EPWS, CPBP, EDPM, BDSF, EFLF), affected business line, gross loss amount, recovery amount, net loss, root cause analysis, causal factors, control failure classification, insurance recovery, and legal/regulatory action status. Feeds SMA capital charge calculation and supports regulatory reporting to OCC/Fed/PRA. Sourced from GRC platform and internal loss database.' .

ind:KriMeasurement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Risk ;
    rdfs:label 'Kri Measurement' ;
    rdfs:comment 'Key Risk Indicator (KRI) master registry and periodic measurement record. Captures KRI definitions (name, risk category, calculation methodology, measurement frequency, data source, green/amber/red thresholds, owner, escalation path) and periodic readings (measurement date, actual value, threshold breach status, trend direction, owning business unit, escalation status). Links to risk appetite framework for threshold derivation. Provides the authoritative KRI taxonomy and monitoring data for enterprise risk dashboards, GRC reporting, and board risk committee oversight.' .

ind:Assessment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Risk ;
    rdfs:label 'Assessment' ;
    rdfs:comment 'Enterprise risk assessment and Risk and Control Self-Assessment (RCSA) record capturing periodic and event-driven evaluations across all risk categories. Assessment type (enterprise_risk_assessment, rcsa, thematic_review) distinguishes evaluation methodology. For enterprise assessments: captures assessment date, risk category, inherent risk rating, control effectiveness, residual risk rating, risk owner, methodology, findings, and action plan. For RCSAs: captures process name, risk event type, control description, control type (preventive/detective), control effectiveness rating, residual risk score, testing frequency, last test date, and remediation plan. Supports ICAAP, ORSA, board risk committee reporting, operational risk management framework, and GRC platform integration.' .

ind:Facility rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Loan ;
    rdfs:label 'Facility' ;
    rdfs:comment 'Master record for every credit facility extended by the bank, covering commercial loans, revolving credit lines, term loans, mortgages, consumer loans, and syndicated loan tranches. Captures facility type, committed and drawn amounts, undrawn availability, currency, interest rate basis and spread, maturity date, origination date, internal risk rating, LTV ratio, DSCR, syndication flag, agent bank indicator, and facility status (active, matured, defaulted, written-off). Hub entity for the loan domain — all transactional and monitoring products reference facility. Primary system-of-record entity aligned with Finastra Fusion Loan IQ facility master.' .

ind:CreditApplication rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Loan ;
    rdfs:label 'Credit Application' ;
    rdfs:comment 'End-to-end credit origination and underwriting record for all loan types. Captures applicant reference, requested facility amount and type, purpose of borrowing, collateral offered, financial statement submission dates, credit analyst assigned, credit scoring model output, underwriting decision (approved, declined, referred, withdrawn), approved terms and conditions, conditions precedent checklist, credit committee approval timestamps, and pipeline stage tracking. Supports regulatory reporting (HMDA, CRA) and origination funnel analytics.' .

ind:LoanAccount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Loan ;
    rdfs:label 'Loan Account' ;
    rdfs:comment 'Operational loan account record representing the active borrower position for a booked facility. Tracks outstanding principal balance, accrued interest, fees payable, payment schedule, day-count convention, current interest rate, rate reset date, loan status (current, delinquent, NPL, charged-off), delinquency bucket (DPD), NPL classification (substandard, doubtful, loss), classification trigger events, regulatory classification basis (OCC, Basel), watch-list flag, cure dates, and interest accrual calculations. Distinct from the account domain\'s deposit accounts; this is the SSOT for loan balance positions, credit quality classification, and NPL lifecycle management including regulatory NPL reporting.' .

ind:AmortizationSchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Loan ;
    rdfs:label 'Amortization Schedule' ;
    rdfs:comment 'Contractual repayment schedule for each loan facility, detailing every scheduled installment with its due date, beginning principal balance, scheduled principal payment, scheduled interest payment, total payment amount, remaining balance after payment, and actual payment status. Supports interest accrual calculations, cash flow forecasting, and ALM/treasury liquidity projections. Generated at origination and regenerated on restructuring or rate resets.' .

ind:Drawdown rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Loan ;
    rdfs:label 'Drawdown' ;
    rdfs:comment 'Records each individual drawdown (disbursement) event against a committed credit facility, capturing drawdown date, drawdown amount, currency, applicable interest rate at drawdown, drawdown purpose, funding account, value date, and settlement reference. For revolving facilities, tracks multiple drawdowns and repayments over the facility lifecycle. Key transactional event in Loan IQ\'s drawdown module.' .

ind:Repayment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Loan ;
    rdfs:label 'Repayment' ;
    rdfs:comment 'Records each principal and interest repayment transaction against a loan account, including payment date, payment amount, principal component, interest component, fee component, penalty interest (if any), payment method (ACH, wire, RTGS), payment source account, outstanding balance post-payment, and whether the payment was on-time, early, or late. Feeds NPL classification and delinquency tracking.' .

ind:Covenant rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Loan ;
    rdfs:label 'Covenant' ;
    rdfs:comment 'Master record of all financial and non-financial covenants attached to credit facilities, including complete periodic compliance test history. Captures covenant type (financial ratio, reporting, affirmative, negative), threshold value or condition, measurement frequency, grace period, waiver flag, and for each test period: test date, actual measured value, compliance status (pass, breach, waiver granted), breach severity, remediation deadline, and analyst notes. Provides complete covenant lifecycle from definition through ongoing monitoring with full audit trail for regulatory examination and credit review.' .

ind:LoanEclProvision rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Loan ;
    rdfs:label 'Loan Ecl Provision' ;
    rdfs:comment 'Expected Credit Loss (ECL) impairment provisioning records under CECL (ASC 326) and IFRS 9 frameworks. Captures staging classification (Stage 1, 2, 3 under IFRS 9 or lifetime/12-month under CECL), provision amount, ECL model used, PD, LGD, EAD inputs, discount rate, forward-looking macroeconomic overlays, provision movement (new, release, increase), and reporting period. SSOT for loan loss reserve calculations.' .

ind:Modification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Loan ;
    rdfs:label 'Modification' ;
    rdfs:comment 'Records all material amendments and restructurings to existing loan facilities, including modification type (maturity extension, rate reduction, principal forgiveness, payment deferral, forbearance), modification date, original terms, modified terms, TDR (Troubled Debt Restructuring) classification flag, regulatory reporting flag, approving authority, and modification rationale. Supports NPL workout management and CECL staging reassessment.' .

ind:CollateralLink rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Loan ;
    rdfs:label 'Collateral Link' ;
    rdfs:comment 'Association entity linking loan facilities to pledged collateral assets managed in the collateral domain. Records lien position (first, second, subordinate), pledged value at origination, current collateral value, LTV ratio at origination and current, collateral coverage ratio, perfection status (UCC filing, mortgage registration), and cross-collateralization flags. This entity owns the loan-side relationship data only; the collateral master record and valuation history remain in the collateral domain.' .

ind:WriteOff rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Loan ;
    rdfs:label 'Write Off' ;
    rdfs:comment 'Records formal write-off, charge-off, and all subsequent post-charge-off recovery events for uncollectable loan balances. Captures write-off date, written-off principal, accrued interest and fees, write-off approval authority, regulatory classification at write-off, and for each recovery event: recovery date, amount, source (borrower payment, collateral liquidation, guarantor call, debt sale), recovery channel, cumulative recovery to date, net loss after recovery, and GL posting references. Supports CECL reserve release accounting, LGD (Loss Given Default) model calibration, and regulatory net charge-off reporting to OCC/FDIC.' .

ind:CreditReview rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Loan ;
    rdfs:label 'Credit Review' ;
    rdfs:comment 'Annual and periodic credit review records for active loan facilities, capturing review date, review type (annual, interim, triggered), credit analyst, relationship manager, updated internal risk rating, updated PD/LGD estimates, financial performance assessment, covenant compliance summary, collateral revaluation flag, recommended action (maintain, upgrade, downgrade, watchlist, exit), and credit committee sign-off date. Supports ongoing portfolio credit quality management.' .

ind:Instruction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Payment ;
    rdfs:label 'Instruction' ;
    rdfs:comment 'Core master record for every payment instruction initiated across all payment rails (ACH, wire, RTGS, SWIFT, FX, card, cross-border). Captures originator, beneficiary, amount, currency, value date, payment type, priority, routing details, IBAN/BIC/SWIFT identifiers, and instruction lifecycle status. Primary entity sourced from ACI Worldwide / Volante Payment Hub. SSOT for payment intent before execution.' .

ind:PaymentTransaction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Payment ;
    rdfs:label 'Payment Transaction' ;
    rdfs:comment 'Transactional record capturing the execution of a payment instruction through the clearing and settlement lifecycle. Records actual debit/credit entries, settlement date, settlement amount, exchange rate applied, net settlement position, T+1 cycle tracking, clearing house reference, and final settlement status. One instruction may produce one or more transactions (e.g., FX legs). SSOT for executed payment events.' .

ind:StatusEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Payment ;
    rdfs:label 'Status Event' ;
    rdfs:comment 'Immutable event log capturing every status transition, exception, and STP failure in the payment lifecycle. Records prior status, new status, event timestamp, reason code, originating system, operator identity, and — for exception events — exception type (format error, sanctions hit, duplicate detection, routing failure, insufficient funds), exception severity, assigned queue, handler identity, resolution action taken, resolution timestamp, and SLA breach indicator. Serves as the single source of truth for payment audit trail, STP failure management, exception resolution tracking, and SLA compliance monitoring. Sourced from ACI Worldwide payment hub and exception management module.' .

ind:Return rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Payment ;
    rdfs:label 'Return' ;
    rdfs:comment 'Records payment returns and reversals initiated by the receiving bank or clearing house, including R-transaction codes (NSF, account closed, invalid account), return reason, original payment reference, return amount, return date, and resubmission eligibility. Covers ACH returns (R01–R85), SWIFT returns (MT192/MT196), and RTGS reversals. SSOT for return and reversal lifecycle.' .

ind:ClearingRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Payment ;
    rdfs:label 'Clearing Record' ;
    rdfs:comment 'Represents the clearing-house submission, netting, and resulting settlement obligation for a payment or batch of payments. Captures clearing house identifier (ACH operator, CHIPS, Fedwire, CHAPS, TARGET2, CLS), clearing cycle, net settlement obligation amount, multilateral netting position, clearing confirmation reference, clearing timestamp, settlement date, funding account, settlement method, settlement confirmation reference, and final settlement status. Bridges payment instructions through clearing to final funds movement. SSOT for the complete clearing-to-settlement lifecycle including CLS for FX settlement.' .

ind:Routing rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Payment ;
    rdfs:label 'Routing' ;
    rdfs:comment 'Defines the routing rules and correspondent banking paths used to direct payments to their destination across all supported payment rails. Captures routing rule identifier, payment rail code (ACH/wire/RTGS/SWIFT/card), rail settlement model (gross/net), settlement cycle, cut-off times, destination country/currency, correspondent bank BIC, intermediary bank BIC, routing priority, velocity limits, approval thresholds, effective date range, and rule status. Sourced from SWIFT Reference Data (BIC directory, SSI registry) and Volante payment hub routing engine. Enables dynamic routing decisions based on cost, speed, liquidity position, and regulatory requirements.' .

ind:Beneficiary rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Payment ;
    rdfs:label 'Beneficiary' ;
    rdfs:comment 'Master registry of payment beneficiaries (individuals, corporations, and financial institutions) to whom the bank\'s customers direct payments. Captures beneficiary name, account number, IBAN, BIC/SWIFT code, bank name, bank address, country, currency, beneficiary type, verification status, and sanctions screening result. SSOT for beneficiary identity in the payment domain, distinct from the customer domain which owns payer identity.' .

ind:PaymentMandate rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Payment ;
    rdfs:label 'Payment Mandate' ;
    rdfs:comment 'Standing payment mandate or direct debit authorization granted by a customer to a creditor, enabling recurring or one-time pull payments. Captures mandate reference, mandate type (SEPA Core, SEPA B2B, ACH PPD/CCD), creditor identifier, debtor account, maximum amount, frequency, start date, end date, mandate status, and presentment sequence (first/recurring/final/one-off/re-presentment). Supports mandate amendment, cancellation, and dispute workflows. SSOT for pre-authorized payment agreements and direct debit lifecycle management.' .

ind:CardTransaction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Payment ;
    rdfs:label 'Card Transaction' ;
    rdfs:comment 'Transactional record for card-based payments including debit, credit, and prepaid card transactions processed through card networks (Visa, Mastercard, Amex). Captures card number (masked PAN), merchant ID, merchant category code (MCC), transaction amount, authorization code, acquirer BIC, network reference, transaction type (purchase/refund/chargeback), and settlement status. Sourced from card processing module of ACI Worldwide.' .

ind:SanctionScreening rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Payment ;
    rdfs:label 'Sanction Screening' ;
    rdfs:comment 'Records the OFAC/sanctions screening result for each payment instruction against watchlists (OFAC SDN, EU Consolidated List, UN Sanctions, PEP lists). Captures screening timestamp, list version, match score, match type (exact/fuzzy/partial), matched entity name, screening decision (pass/hold/block), analyst review outcome, and regulatory reporting obligation. Supports BSA/AML compliance for payment processing.' .

ind:DepositAccount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Account ;
    rdfs:label 'Deposit Account' ;
    rdfs:comment 'Authoritative master record for all deposit and transactional accounts including DDA (Demand Deposit Accounts), savings, money market, and NOW accounts. Captures account number, IBAN, BIC, currency, branch/sort code, opening date, account status (active, dormant, closed, frozen), ownership type, and product reference. Includes embedded child record sets for: (1) overdraft facility configuration — approved limit, linked protection source, transfer fee, opt-in/opt-out status per Reg E, utilization tracking; (2) account-level operational limits — daily withdrawal, transfer, ATM, wire, ACH debit limits with approval authority and override flags; (3) dormancy and escheatment tracking — last activity date, dormancy classification date, dormancy period, state escheatment threshold, outreach log, escheatment filing date, amount escheated, jurisdiction; (4) document registry — signature cards, account agreements, beneficial ownership certifications, W-9/W-8BEN, POA, court orders with version, status, and storage reference; (5) immutable status transition history — previous/new status, effective datetime, reason code, initiating channel, authorizing officer. Interest accrual method, compounding frequency, statement cycle, and regulatory classification round out the record. Core system-of-record entity aligned with Temenos T24 ACCOUNT.ARRANGEMENT / FIS Profile deposit module.' .

ind:Holder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Account ;
    rdfs:label 'Holder' ;
    rdfs:comment 'Association entity linking customers (individuals or legal entities from the customer domain) to deposit, CD, and custodial accounts with role-based ownership, beneficiary, and fiduciary semantics. Captures ownership role (primary owner, joint owner, authorized signer, power of attorney, trustee), ownership percentage for joint accounts, signing authority level, effective date, expiry date, and designation/revocation dates. Includes embedded beneficiary designation records for payable-on-death (POD) and transfer-on-death (TOD) roles: beneficiary type (individual, trust, estate, charity), allocation percentage, designation date, revocation date, and supporting documentation reference. Beneficiary roles are legally distinct from ownership roles — beneficiaries have no access rights during the account holder\'s lifetime but receive proceeds upon death, governed by state law and FDIC insurance rules. Enables multi-party account ownership modeling required for KYC, AML, estate processing, FDIC insurance coverage calculation across ownership categories, and probate/succession workflows. Single source of truth for all account-to-person associations including both ownership and beneficiary designations.' .

ind:Balance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Account ;
    rdfs:label 'Balance' ;
    rdfs:comment 'Daily snapshot of account balance positions including ledger balance, available balance, collected balance, float balance, and hold balance. Tracks as-of date, currency, overdraft utilization, minimum balance threshold breach flag, average daily balance for the statement period, and interest-bearing balance. Used for NIM calculation, reserve requirement compliance (Reg D), and FDIC insurance limit monitoring. Sourced from Temenos T24 end-of-day balance file.' .

ind:AccountTransaction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Account ;
    rdfs:label 'Account Transaction' ;
    rdfs:comment 'Granular record of every debit and credit posting to a deposit account. Captures transaction date, value date, posting date, transaction type code, channel (branch, ATM, ACH, wire, card, online), amount, currency, running balance after posting, reference number, counterparty account, narrative/memo, reversal flag, and originating payment system reference. Primary audit trail for account activity; feeds statement generation, AML transaction monitoring, and GL subledger reconciliation.' .

ind:Statement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Account ;
    rdfs:label 'Statement' ;
    rdfs:comment 'Periodic account statement record representing a formally generated statement cycle for a deposit account. Captures statement period start and end dates, statement date, opening balance, closing balance, total credits, total debits, interest earned, fees charged, statement delivery channel (paper, e-statement, secure message), delivery status, and regulatory disclosure flags (Reg E, Reg DD). Distinct from individual transactions — represents the aggregated billing document sent to the account holder.' .

ind:InterestAccrual rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Account ;
    rdfs:label 'Interest Accrual' ;
    rdfs:comment 'Daily interest accrual record for interest-bearing deposit accounts. Tracks accrual date, accrual basis (ACT/360, ACT/365, 30/360), applicable interest rate tier, accrued interest amount, cumulative accrued interest for the period, interest posting frequency, next interest payment date, and withholding tax amount for applicable accounts (FATCA/CRS). Supports NII (Net Interest Income) reporting, ALCO analytics, and regulatory interest disclosure under Reg DD.' .

ind:AccountFee rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Account ;
    rdfs:label 'Account Fee' ;
    rdfs:comment 'Record of fees assessed against deposit accounts including monthly maintenance fees, overdraft fees (NSF), wire transfer fees, ATM surcharge fees, early account closure fees, and dormancy fees. Captures fee type, assessed amount, waiver flag, waiver reason, waiver authority, assessment date, billing cycle, and regulatory disclosure requirement. Supports fee income reporting, CFPB compliance monitoring, and customer profitability analysis.' .

ind:Hold rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Account ;
    rdfs:label 'Hold' ;
    rdfs:comment 'Record of funds holds and restrictions placed on deposit account balances. Captures hold type (check hold, legal hold, administrative hold, garnishment, levy, fraud hold), hold amount, hold currency, placement date, expected release date, actual release date, placing authority (branch, legal, compliance, court order), hold reason narrative, and regulatory basis (Reg CC for check holds). Critical for available balance calculation and legal/compliance workflows.' .

ind:OverdraftFacility rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Account ;
    rdfs:label 'Overdraft Facility' ;
    rdfs:comment 'Master record defining the overdraft protection arrangement attached to a deposit account. Captures approved overdraft limit, linked protection source (savings account, line of credit, credit card), transfer fee per use, interest rate on overdraft balance, opt-in/opt-out status per Reg E, effective date, expiry date, and utilization tracking. Distinct from the loan domain\'s revolving credit — this is the deposit-side overdraft configuration owned by the account domain.' .

ind:AccountLimit rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Account ;
    rdfs:label 'Account Limit' ;
    rdfs:comment 'Configurable account-level operational limits governing transaction behavior. Captures limit type (daily withdrawal limit, daily transfer limit, ATM cash limit, wire transfer limit, ACH debit limit, minimum balance requirement), limit amount, currency, effective date, expiry date, approval authority, and override flag. Supports risk controls, fraud prevention, and regulatory compliance for consumer protection.' .

ind:StatusHistory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Account ;
    rdfs:label 'Status History' ;
    rdfs:comment 'Immutable audit log of all account lifecycle status transitions for deposit accounts. Captures previous status, new status, effective date and time, reason code, initiating channel, authorizing officer, and supporting documentation reference. Status transitions include: pending activation → active → dormant → reactivated → closed → written off. Required for regulatory examination, AML dormancy monitoring, and FDIC insurance claim processing.' .

ind:InterestRate rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Account ;
    rdfs:label 'Interest Rate' ;
    rdfs:comment 'Effective interest rate configuration and complete tiered rate structure applied to deposit accounts and products. Captures base rate type (fixed, variable, tiered), benchmark index (SOFR, Fed Funds, Prime), spread over benchmark in BPS, effective date, expiry date, promotional rate flag, and promotional expiry date. Includes embedded tier-level detail: tier sequence number, minimum and maximum balance thresholds, annual percentage yield (APY), annual percentage rate (APR), and product applicability per tier. Tiered structures enable the bank to offer higher rates for larger balances on savings and money market accounts. Single source of truth for ALL rate configuration including tiered breakpoints — no separate rate tier reference table exists. Supports NIM reporting, ALCO rate sensitivity analysis, Reg DD APY disclosure requirements, and product pricing governance.' .

ind:StandingOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Account ;
    rdfs:label 'Standing Order' ;
    rdfs:comment 'Recurring payment instruction established by an account holder to make regular fixed-amount transfers from a deposit account. Captures beneficiary account details, transfer amount, currency, frequency (weekly, monthly, quarterly), start date, end date, next execution date, payment reference, execution channel (ACH, internal transfer, SWIFT), and status (active, suspended, cancelled). Distinct from one-time payment instructions — represents a persistent, repeating mandate.' .

ind:DirectDebitMandate rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Account ;
    rdfs:label 'Direct Debit Mandate' ;
    rdfs:comment 'Authorization record permitting a third-party originator to initiate ACH debit entries against a deposit account. Captures mandate reference number, originator company ID, originator name, authorized debit amount (fixed or variable), authorization date, authorization channel, revocation date, and NACHA SEC code (PPD, CCD, WEB, TEL). Supports Reg E dispute resolution, ACH return processing, and unauthorized debit claim management.' .

ind:Order rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Trade ;
    rdfs:label 'Order' ;
    rdfs:comment 'Core master record for all trade orders entered into the Trading and Order Management System (Murex/Calypso). Captures the full order lifecycle from entry through execution including order type (market, limit, stop, IOC, FOK), asset class (equity, fixed income, FX, OTC derivative), side (buy/sell/short), quantity, price, order status, trader ID, desk, book, counterparty, venue, time-in-force, and origination channel. Supports parent/child order hierarchies for algorithmic and smart order routing. SSOT for trade order identity across capital markets.' .

ind:Execution rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Trade ;
    rdfs:label 'Execution' ;
    rdfs:comment 'Transactional record of each individual fill or partial fill against a trade order. Captures execution price, executed quantity, execution venue (exchange, ECN, OTC), execution timestamp, counterparty BIC/LEI, broker, commission, execution type (full/partial), and market microstructure data. Supports T+1 settlement initiation and best-execution regulatory reporting (MiFID II, SEC Rule 606). One order may have multiple executions.' .

ind:Capture rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Trade ;
    rdfs:label 'Capture' ;
    rdfs:comment 'Authoritative trade booking record and single system of record in the trading platform (Murex/Calypso). Represents the confirmed, booked trade after execution, capturing trade date, value date, settlement date, notional amount, price/rate, accrued interest, trade currency, settlement currency, counterparty LEI, legal entity, trading book, and booking status. Supports all asset classes and product types including cash equities, bonds, IRS, CDS, FX spot/forward/swap/NDF, OTC options, equity swaps, and swaptions with product-type-specific attributes (e.g., UTI/USI for OTC derivatives, currency pair/forward points for FX, fixed/floating legs for swaps). Maintains full amendment and versioning history as lifecycle events on the trade record, including amendment type (economic amendment, administrative correction, novation, compression), amended fields with before/after values, amendment reason, approval workflow status, approver, amendment timestamp, and regulatory re-reporting flags for EMIR/Dodd-Frank/MiFID II. Each amendment creates a versioned snapshot preserving the complete audit trail. SSOT for the confirmed trade event, its full amendment audit trail, and all product types across capital markets.' .

ind:TradePosition rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Trade ;
    rdfs:label 'Trade Position' ;
    rdfs:comment 'Real-time and end-of-day position record per trading book, instrument, and legal entity. Tracks long/short quantity, average cost, market value, unrealized P&L, realized P&L, accrued income, dirty/clean price, and Greek sensitivities (DV01, delta, gamma, vega, theta). Supports intraday position keeping, risk limit monitoring, regulatory capital calculations (FRTB), and serves as the base record for MTM revaluation and P&L attribution. Updated on each trade capture event, corporate action adjustment, and MTM revaluation cycle. Maintains position history for end-of-day snapshots enabling T-1 comparison and position break investigation.' .

ind:MtmValuation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Trade ;
    rdfs:label 'Mtm Valuation' ;
    rdfs:comment 'Mark-to-Market valuation record for each position or trade at a given valuation date and time. Captures fair value, valuation methodology (mark-to-market, mark-to-model, NAV), pricing source (Bloomberg, Reuters, internal model), clean price, dirty price, accrued interest, FX rate applied, discount curve, and valuation adjustments (CVA, DVA, FVA). Supports IFRS 9 fair value hierarchy disclosures and daily P&L calculation.' .

ind:SettlementInstruction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Trade ;
    rdfs:label 'Settlement Instruction' ;
    rdfs:comment 'Settlement instruction record generated post-trade for delivery versus payment (DVP), free of payment (FOP), or FX settlement. Captures settlement date, settlement amount, settlement currency, IBAN/SWIFT BIC of custodian, CSD/ICSD (DTC, Euroclear, Clearstream), settlement status (pending, matched, settled, failed), settlement agent, and nostro account. Includes fail tracking attributes: fail date, fail reason (counterparty default, insufficient securities, cash shortfall, matching discrepancy), fail duration, CSDR cash penalty charges, buy-in status, and resolution actions. Supports T+1/T+2 settlement cycles, SWIFT MT54x messaging, CSDR mandatory buy-in compliance, and settlement efficiency reporting.' .

ind:Confirmation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Trade ;
    rdfs:label 'Confirmation' ;
    rdfs:comment 'Trade confirmation record exchanged with counterparties for OTC derivatives and securities trades. Captures confirmation method (electronic via DTCC/MarkitWire, paper, SWIFT MT3xx), confirmation status (unconfirmed, confirmed, disputed, cancelled), confirmation timestamp, ISDA master agreement reference, CSA reference, and any economic terms discrepancies. Supports Dodd-Frank and EMIR timely confirmation requirements.' .

ind:TradingBook rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Trade ;
    rdfs:label 'Trading Book' ;
    rdfs:comment 'Master record for each trading book (desk-level portfolio) within the bank\'s trading organization. Captures book name, book code, asset class, trading strategy, responsible desk, head trader, legal entity, regulatory classification (trading book vs banking book per FRTB), risk limits (VaR limit, DV01 limit, notional limit), base currency, and book status. SSOT for trading book hierarchy and limit framework.' .

ind:Allocation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Trade ;
    rdfs:label 'Allocation' ;
    rdfs:comment 'Post-execution trade allocation record distributing a block trade across multiple accounts, funds, or sub-portfolios. Captures block trade reference, allocated account, allocated quantity, allocated price, allocation method (pro-rata, manual, step-out), allocation percentage, allocation status (pending, affirmed, rejected), give-up broker, and settlement instruction reference. Supports institutional client give-up workflows, fund accounting, OASYS/ALERT affirmation processes, and average price allocation for multi-fill block trades.' .

ind:TradeFee rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Trade ;
    rdfs:label 'Trade Fee' ;
    rdfs:comment 'Fee and commission record associated with trade execution and post-trade services. Captures fee type (brokerage commission, exchange fee, clearing fee, settlement fee, custody fee, prime brokerage fee, regulatory levy), fee amount, fee currency, fee basis (per trade, per share, notional BPS, flat), fee status (accrued, invoiced, paid, waived), counterparty/broker, and fee agreement reference. Supports trade cost analysis (TCA), P&L attribution, MiFID II cost and charges disclosure (ex-ante and ex-post), PRIIPs cost reporting, and best-execution cost benchmarking. SSOT for all trade-related fees and commissions.' .

ind:Party rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Party' ;
    rdfs:comment 'Golden master record for every legal entity or natural person the bank interacts with — retail clients, corporate borrowers, institutional counterparties, government entities, and internal legal entities. Stores canonical identity attributes: full legal name, date of birth / incorporation date, entity type (individual, corporation, partnership, trust, government), domicile country, residency status, citizenship, and lifecycle status (prospect, active, dormant, deceased, closed). Also captures: universal operational preferences (preferred language, preferred branch, statement delivery method, currency preference, time zone, accessibility requirements); external and internal identifiers (TIN, EIN, SSN, LEI, SWIFT BIC, DUNS, CIF number, passport number, national ID, Bloomberg BUID, Reuters PERM ID, legacy system IDs) with identifier type, issuing authority, effective/expiry dates, and is_primary flag per type; and lifecycle event audit log (prior status, new status, event type such as onboarded/activated/dormancy-flagged/reactivated/relationship-exited/deceased/merged/deduped, event timestamp, triggering system, initiating employee_id, approval employee_id, event notes). SINGLE SOURCE OF TRUTH for party identity, party identifiers, and party lifecycle events — no separate identifier or lifecycle event tables exist. Serves as the authoritative FK anchor for all other domains requiring party identification. Sourced from Core Banking System (Temenos T24 / FIS Profile — Customer Master).' .

ind:IndividualProfile rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Individual Profile' ;
    rdfs:comment 'Extended personal profile for natural-person parties (retail and private banking clients). Captures demographic and lifestyle attributes beyond core identity: gender, marital status, number of dependents, education level, employment status, employer name, annual income, net worth band, primary occupation (NAICS/SIC code), politically exposed person (PEP) flag, US person flag (FATCA), tax residency countries (CRS), preferred contact method, and digital banking enrollment status. One-to-one with party where entity_type = individual.' .

ind:CorporateProfile rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Corporate Profile' ;
    rdfs:comment 'Extended organizational profile for non-natural-person parties (corporations, partnerships, trusts, SPVs, government agencies). Captures: legal form, jurisdiction of incorporation, registered address, operating address, SIC/NAICS industry code, number of employees band, annual revenue band, publicly listed flag, stock exchange and ticker, parent company party_id, ultimate beneficial owner (UBO) flag, FATCA entity classification (NFFE/FFI), CRS reporting status, credit rating (S&P / Moody\'s / Fitch), and relationship manager employee_id. One-to-one with party where entity_type != individual.' .

ind:KycRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Kyc Record' ;
    rdfs:comment 'KYC/CDD (Know Your Customer / Customer Due Diligence) master record encompassing current KYC state, review event history, and consolidated AML/financial-crime risk rating for each party. Current KYC state: KYC tier (simplified, standard, enhanced EDD), onboarding date, last review date, next scheduled review date, AML risk rating (low/medium/high/very-high), risk rating rationale, CDD/EDD completion status, source of funds/wealth verification, PEP screening result, sanctions screening result, adverse media screening result, KYC analyst and approver employee_ids, and overall KYC status (pending, approved, expired, rejected). Review event history (time-series): review trigger type (periodic, risk-triggered, regulatory, client-initiated), review date, prior and new risk ratings, review outcome (no change, upgraded, downgraded, escalated to EDD, relationship exited), EDD required flag, EDD completion date, reviewer and approver employee_ids, and next review due date. SINGLE SOURCE OF TRUTH for AML/financial-crime risk rating and KYC review events — no separate review event or AML risk rating tables exist. Credit risk and operational risk ratings are owned by the risk domain. Provides the complete audit trail required for regulatory examination. Sourced from AML/Financial Crime System (NICE Actimize / Oracle Financial Crime).' .

ind:PartyAddress rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Party Address' ;
    rdfs:comment 'Unified contact point registry for all physical addresses and electronic contact details associated with a party. For physical addresses: address type (registered, mailing, residential, business, branch, billing), address lines, city, state/province, postal code, country (ISO 3166-1), geocode, effective/expiry dates, is_primary flag, verification status. For electronic contacts: contact type (mobile, home phone, work phone, fax, primary email, secondary email, digital identifier), contact value, country code, is_verified flag, verification date, opt-in status for marketing/e-statements, do-not-call flag. All entries carry effective/expiry dates and primary/verified flags. Supports regulatory domicile determination (FATCA/CRS situs rules), AML geographic risk scoring, omnichannel CRM integration, and regulatory notification obligations. SINGLE SOURCE OF TRUTH for all party contact information — both physical addresses and electronic contact details. No separate contact table exists.' .

ind:PartyContact rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Party Contact' ;
    rdfs:comment 'Contact details for a party across all communication channels: phone (mobile, home, work, fax), email (primary, secondary, business), and digital identifiers. Captures: contact type, contact value, country code, is_primary flag, is_verified flag, verification date, opt-in status for marketing, opt-in status for e-statements, do-not-call flag, and effective/expiry dates. Supports omnichannel CRM integration and regulatory notification obligations.' .

ind:PartyDocument rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Party Document' ;
    rdfs:comment 'Identity and supporting documents collected during KYC onboarding and periodic reviews. Captures: document type (passport, national ID, driver\'s license, articles of incorporation, certificate of good standing, audited financials, utility bill), issuing country, document number, issue date, expiry date, verification status (unverified, verified, expired), verification method (manual, biometric, third-party bureau), document storage reference (vault URI), and collecting employee_id. Supports CDD evidence chain and regulatory audit trail.' .

ind:RelationshipHierarchy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Relationship Hierarchy' ;
    rdfs:comment 'Unified registry of all inter-party relationships including hierarchical structures (parent-subsidiary, branch, household, ownership chains) and bilateral/reciprocal associations (guarantor-borrower, co-applicant, authorized signatory, power of attorney, referral source, introducer, joint account holder). Captures: party_a_id, party_b_id, relationship type, relationship direction (hierarchical, bilateral, reciprocal), role_a, role_b, hierarchy level (for tree structures), effective date, expiry date, is_active flag, and supporting document reference. Enables corporate group structure traversal, consolidated exposure calculation (Basel III large exposure framework), group-level KYC, household-level cross-sell analytics, relationship-aware credit aggregation, and CRM relationship mapping. SINGLE SOURCE OF TRUTH for all party-to-party relationships — both hierarchical and bilateral. No separate bilateral relationship table exists. Sourced from Core Banking System and CRM.' .

ind:Segment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Segment' ;
    rdfs:comment 'Segment definition and time-series party assignment record supporting product targeting, pricing tiers, and service-level determination. Segment definitions: segment code (mass market, mass affluent, HNW, UHNW, SME, mid-market, large corporate, institutional, government), sub-segment, LOB, and segment criteria. Party-level assignments: party_id, segment_id, effective date, expiry date, assignment method (rule-based, manual override, model-driven), model run_id, assigned_by employee_id, is_current flag, override flag with rationale. Supports CLTV cohort analysis, segment migration reporting, segment transition analysis, FTP pricing tier determination, and targeted campaign eligibility. SINGLE SOURCE OF TRUTH for both segment definitions and party-to-segment assignments — no separate assignment table exists. Sourced from CRM and segmentation engine.' .

ind:PartySegmentAssignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Party Segment Assignment' ;
    rdfs:comment 'Time-series assignment of segment classifications to parties, enabling segment history tracking and transition analysis. Captures: party_id, customer_segment_id, effective date, expiry date, assignment method (rule-based, manual override, model-driven), model run_id, assigned_by employee_id, and is_current flag. Supports CLTV cohort analysis, segment migration reporting, and targeted campaign eligibility.' .

ind:OnboardingCase rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Onboarding Case' ;
    rdfs:comment 'End-to-end onboarding workflow record for new party acquisition, tracking the full lifecycle from prospect to active client. Captures: onboarding channel (branch, digital, RM-assisted, API), product applied for, onboarding type (new-to-bank, new-to-product, existing-party-new-segment), current workflow stage (application, document collection, KYC review, credit check, approval, account opening), stage entry timestamps, SLA breach flag, assigned analyst employee_id, approver employee_id, rejection reason code, and completion date. Sourced from Core Banking System onboarding module.' .

ind:KycReviewEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Kyc Review Event' ;
    rdfs:comment 'Periodic and event-driven KYC/CDD review events triggered by scheduled refresh cycles, risk-rating changes, transaction alerts, or regulatory mandates. Captures: review trigger type (periodic, risk-triggered, regulatory, client-initiated), review date, prior risk rating, new risk rating, review outcome (no change, upgraded, downgraded, escalated to EDD, relationship exited), EDD required flag, EDD completion date, reviewer employee_id, approver employee_id, and next review due date. Provides full audit trail for regulatory examination.' .

ind:PartyRelationship rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Party Relationship' ;
    rdfs:comment 'Bilateral relationship registry between two parties capturing non-hierarchical associations such as guarantor-borrower, co-applicant, authorized signatory, power of attorney, referral source, and introducer relationships. Distinct from relationship_hierarchy (which models ownership/control trees). Captures: party_a_id, party_b_id, relationship role_a, relationship role_b, effective date, expiry date, is_active flag, and supporting document reference. Enables relationship-aware credit exposure aggregation and CRM relationship mapping.' .

ind:PartyIdentifier rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Party Identifier' ;
    rdfs:comment 'Registry of all external and internal identifiers associated with a party, enabling cross-system reconciliation and deduplication. Captures: party_id, identifier type (LEI, SWIFT BIC, DUNS, CIF number, tax ID, passport number, national ID, ISIN issuer code, Bloomberg BUID, Reuters PERM ID, internal legacy system ID), identifier value, issuing authority, effective date, expiry date, and is_primary flag per type. Supports golden record management, cross-domain FK resolution, and regulatory reporting identifier requirements.' .

ind:Instrument rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Security ;
    rdfs:label 'Instrument' ;
    rdfs:comment 'Golden source master record for all financial instruments and securities including equities, fixed income, derivatives, structured products (MBS, ABS, CLO, CDO), FX, and OTC instruments. Stores the authoritative instrument identity with ISIN, CUSIP, SEDOL, FIGI, and Bloomberg/Reuters identifiers. Captures instrument type, asset class, sub-asset class, issuer, currency, country of issuance, exchange listing, face value, lot size, settlement convention (T+1, T+2), day count convention, and current lifecycle status. Includes a complete lifecycle status history as an immutable append-only audit trail tracking every status transition (pre-issuance, active, suspended, called, defaulted, matured, redeemed, delisted) with effective dates, reason codes, triggering event references, and source systems. This is the enterprise-wide SSOT for instrument reference data consumed by trade, investment, wealth, risk, collateral, and compliance domains.' .

ind:Equity rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Security ;
    rdfs:label 'Equity' ;
    rdfs:comment 'Master data for equity instruments including common stock, preferred stock, ADRs, GDRs, ETFs, and REITs. Captures equity-specific attributes such as share class, voting rights, par value, shares outstanding, float, dividend eligibility, index membership (S&P 500, MSCI), sector (GICS), industry group, market capitalization tier, and listing exchange. Links to the parent instrument master and issuer entity. Supports securities trading, portfolio management, and corporate actions processing.' .

ind:FixedIncome rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Security ;
    rdfs:label 'Fixed Income' ;
    rdfs:comment 'Master data for fixed income instruments including government bonds, corporate bonds, municipal bonds, treasury bills, notes, and inflation-linked securities, with embedded detailed coupon payment schedules. Captures bond-specific attributes: coupon rate, coupon frequency, coupon type (fixed/floating/zero), maturity date, first coupon date, last coupon date, day count convention (ACT/360, 30/360), yield basis, call/put provisions, sinking fund schedule, credit rating (Moodys, S&P, Fitch), rating date, and bond covenants. Includes the full coupon schedule as embedded detail with accrual start/end dates, payment dates, coupon period number, coupon rate (fixed or floating reset), day count fraction, projected and actual coupon amounts (post-reset for floaters), payment currency, and payment status (scheduled/paid/missed/deferred). Supports NII calculation, cash flow projection, ALM gap analysis, bond analytics (duration, convexity, DV01), IFRS 9 ECL modeling, and NII forecasting.' .

ind:Derivative rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Security ;
    rdfs:label 'Derivative' ;
    rdfs:comment 'Master data for derivative instruments including exchange-traded and OTC derivatives: interest rate swaps, FX forwards, FX options, equity options, futures, CDS, total return swaps, and swaptions. Captures derivative-specific attributes: underlying instrument, derivative type, notional amount, notional currency, strike price, barrier levels, expiry date, exercise style (European/American/Bermudan), settlement type (cash/physical), ISDA master agreement reference, CSA linkage, clearing eligibility (CCP cleared vs bilateral), and trade repository reporting obligation. Supports CVA calculation, FRTB capital, and ISDA/CSA margin management.' .

ind:Issuer rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Security ;
    rdfs:label 'Issuer' ;
    rdfs:comment 'Master data for security issuers including corporations, sovereign governments, municipalities, supranational entities, and special purpose vehicles (SPVs). Captures issuer legal name, LEI (Legal Entity Identifier), issuer type, domicile country, incorporation jurisdiction, parent entity, ultimate parent, credit ratings by agency, sector classification (GICS/SIC/NAICS), Bloomberg issuer ID, and regulatory classification (financial/non-financial). Serves as the authoritative issuer reference for fixed income, structured products, and credit risk domains. Distinct from the customer domain which owns client/counterparty identity.' .

ind:Price rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Security ;
    rdfs:label 'Price' ;
    rdfs:comment 'Immutable append-only time-series of all security price observations for all instruments, serving as the single source of truth for both current and historical pricing. Records bid, ask, mid, last trade, official closing, open, high, low, close, volume, VWAP, and adjusted close (for corporate actions). Stores price source (Bloomberg, Reuters/Refinitiv, exchange feed, broker quote, internal model), price type (market/model/indicative/official), pricing date and time, currency, price basis (clean/dirty for bonds), accrued interest, yield, spread to benchmark, price quality flag, and source system. Prices are never overwritten — corrections are appended with reason codes and supersession flags. Retains the complete historical price archive for all instruments across all time periods. Supports MTM valuation, NAV calculation, portfolio P&L attribution, IFRS 9 fair value measurement, backtesting, VaR historical simulation, performance attribution, regulatory stress testing (CCAR/DFAST), historical trend analysis, and time-series analytics.' .

ind:CorporateAction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Security ;
    rdfs:label 'Corporate Action' ;
    rdfs:comment 'Master record for corporate action events affecting securities, including event details, voluntary election options, and beneficial owner election responses. Covers dividends, mergers, tender offers, rights issues, and all election processing.' .

ind:Classification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Security ;
    rdfs:label 'Classification' ;
    rdfs:comment 'Standardized classification and taxonomy mappings for financial instruments across multiple industry frameworks including CFI (Classification of Financial Instruments ISO 10962), ISDA product taxonomy, ESMA EMIR classification, SFDR sustainability classification, MiFID II product governance classification, and internal asset class hierarchy. Captures classification scheme, classification code, classification description, effective date, expiry date, and the authoritative source. Supports multiple concurrent classification schemes per instrument with full history. Enables regulatory reporting (MiFID II, EMIR, SFDR), risk bucketing (FRTB SA sensitivities-based approach), cross-domain instrument categorization, and investment policy compliance screening.' .

ind:Identifier rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Security ;
    rdfs:label 'Identifier' ;
    rdfs:comment 'Comprehensive cross-reference table mapping all known external identifiers for each instrument including ISIN, CUSIP, SEDOL, FIGI (Financial Instrument Global Identifier), Bloomberg ID (BBGID), Reuters RIC, Valoren, WKN, CINS, and exchange-specific ticker symbols. Captures identifier type, identifier value, issuing authority, effective date, expiry date, and primary flag. Enables instrument lookup and reconciliation across trading systems (Murex/Calypso), data vendors (Bloomberg/Refinitiv), and regulatory reporting platforms (AxiomSL). Critical for golden source instrument resolution.' .

ind:Listing rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Security ;
    rdfs:label 'Listing' ;
    rdfs:comment 'Exchange listing records for securities capturing where and how each instrument is listed and traded across global exchanges. Stores exchange MIC code (ISO 10383), listing date, delisting date, trading currency, lot size, tick size, trading hours, trading status (active/suspended/halted/delisted), primary listing flag, and exchange-specific instrument code. A single instrument may have multiple listings across different exchanges (e.g., dual-listed equities, cross-listed ADRs). Supports order routing, best execution analysis (MiFID II RTS 27/28), market data subscription management, and regulatory transaction reporting (MiFIR).' .

ind:Benchmark rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Security ;
    rdfs:label 'Benchmark' ;
    rdfs:comment 'Master data for financial benchmarks, reference rates, and market indices with embedded daily rate observations and index constituent membership records. Covers SOFR, EURIBOR, SONIA, Fed Funds Rate, LIBOR (legacy), Treasury yield curves, credit spread indices (CDX, iTraxx), and equity indices (S&P 500, MSCI World, Bloomberg Barclays Aggregate). Captures benchmark name, administrator, IOSCO compliance status, publication frequency, currency, tenor, fallback rate provisions (LIBOR transition), and regulatory status. Includes daily published rate observations by tenor (overnight, 1M, 3M, 6M, 12M) with compounded rates, spread adjustments (for LIBOR-SOFR transition), and publication source. For indices, records constituent instruments with inclusion/exclusion dates, weights (market cap, par), rebalancing frequency, and rebalancing events. Supports floating rate coupon resets, swap valuation, FTP curve construction, passive portfolio management, index tracking, ETF basket construction, benchmark attribution, and ALM interest rate risk modeling.' .

ind:YieldCurve rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Security ;
    rdfs:label 'Yield Curve' ;
    rdfs:comment 'Constructed yield curves and their constituent tenor-rate nodes used for instrument valuation, discounting, and risk measurement. Captures curve name, curve type (government, swap, credit spread, OIS), base currency, construction date, construction methodology (bootstrapping, interpolation method), and the complete set of tenor-rate nodes defining the curve shape. Each embedded node includes tenor label (1M, 3M, 6M, 1Y, 2Y, 5Y, 10Y, 30Y), tenor in days, zero rate, par rate, forward rate, discount factor, and interpolation method applied between nodes. Supports bond pricing, derivative valuation (IRS, CDS), FTP curve construction, IFRS 9 ECL discount rate determination, DV01 sensitivity by tenor bucket, key rate duration analysis, and regulatory stress scenario application across the full term structure.' .

ind:CreditRating rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Security ;
    rdfs:label 'Credit Rating' ;
    rdfs:comment 'Credit rating records assigned to instruments and issuers by external rating agencies (Moody\'s, S&P, Fitch, DBRS, Kroll) and internal credit assessment models. Captures rated entity type (instrument or issuer), rating agency, rating scale, long-term rating, short-term rating, outlook (positive/stable/negative/watch), rating action type (initial/upgrade/downgrade/affirm/withdraw), rating date, effective date, and regulatory mapping (Basel III standardized approach risk weight bucket). Supports RWA calculation, ECL staging (IFRS 9/CECL), and investment policy compliance.' .

ind:Currency rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Reference ;
    rdfs:label 'Currency' ;
    rdfs:comment 'ISO 4217 currency master — authoritative golden record for all currencies used across the enterprise. Captures currency code, numeric code, minor unit (decimal places), currency name, issuing country, active/inactive status, and effective dates. Used by payments, FX, GL, and all financial domains for currency denomination and conversion.' .

ind:Country rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Reference ;
    rdfs:label 'Country' ;
    rdfs:comment 'ISO 3166-1 country master — golden source for all country codes, country names, alpha-2, alpha-3, and numeric codes. Includes region, sub-region, sovereign status, FATCA jurisdiction flag, CRS jurisdiction flag, OFAC sanctions flag, and EU membership indicator. Referenced by KYC, AML, regulatory reporting, and customer onboarding.' .

ind:RateBenchmark rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Reference ;
    rdfs:label 'Rate Benchmark' ;
    rdfs:comment 'Interest rate benchmark master covering SOFR, LIBOR (legacy), EURIBOR, SONIA, ESTR, Fed Funds, and other reference rates. Stores benchmark name, administrator, currency, tenor conventions, publication source, IBOR transition status, fallback rate linkage, and regulatory recognition status. Critical for loan pricing, derivatives valuation, and ALM.' .

ind:BenchmarkRateFixing rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Reference ;
    rdfs:label 'Benchmark Rate Fixing' ;
    rdfs:comment 'Daily published fixing values for interest rate benchmarks by tenor and fixing date. Each record links to its parent rate_benchmark (SOFR, EURIBOR, SONIA, etc.) and captures fixing date, tenor (O/N, 1M, 3M, 6M, 12M), published rate value, source authority, publication timestamp, revision indicator, and superseded rate (for corrections). Serves as the transactional time-series complement to the rate_benchmark master. Used for loan interest accrual, derivative settlement, mark-to-market calculations, and regulatory rate audit trails across trading, loan, and treasury domains.' .

ind:ExchangeRate rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Reference ;
    rdfs:label 'Exchange Rate' ;
    rdfs:comment 'FX spot and forward exchange rate records published daily (or intraday) for all currency pairs. Captures base currency, quote currency, rate type (spot, forward, mid, bid, ask), tenor, rate value, source provider, effective timestamp, and ECB/Fed publication flag. Used by payments, treasury, GL revaluation, and risk domains.' .

ind:HolidayCalendar rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Reference ;
    rdfs:label 'Holiday Calendar' ;
    rdfs:comment 'Business day holiday calendar master defining non-business days for financial centers, exchanges, and clearing systems (e.g., TARGET2, SIFMA, NYSE, LME). Captures calendar name, financial center, calendar type, governing authority, applicable currency or market, and all individual holiday date entries (specific non-business dates, holiday names, holiday types — public, exchange, settlement — and partial day indicators). Used for settlement date calculation (T+1, T+2), accrual period computation, payment scheduling, and coupon date adjustment across loan, payment, trade, and treasury domains.' .

ind:HolidayDate rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Reference ;
    rdfs:label 'Holiday Date' ;
    rdfs:comment 'Individual holiday date entries within a holiday calendar. Captures the specific non-business date, holiday name, calendar reference, holiday type (public, exchange, settlement), and whether it is a partial day. Enables precise settlement date and accrual period calculations across loan, payment, and trade domains.' .

ind:BicDirectory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Reference ;
    rdfs:label 'Bic Directory' ;
    rdfs:comment 'SWIFT BIC (Bank Identifier Code) directory — golden source for all BIC codes used in SWIFT messaging and correspondent banking. Captures BIC8/BIC11, institution name, branch name, city, country, address, connectivity status (live/test), and SWIFT service profile. Used by payment processing, correspondent banking, and trade finance domains.' .

ind:LeiRegistry rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Reference ;
    rdfs:label 'Lei Registry' ;
    rdfs:comment 'Legal Entity Identifier (LEI) registry — authoritative source for LEI codes assigned to legal entities under the GLEIF framework. Captures LEI code, legal entity name, legal address, headquarters country, registration authority, LEI status, renewal date, and ultimate parent LEI. Required for MiFID II, EMIR, and Dodd-Frank regulatory reporting.' .

ind:ProductType rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Reference ;
    rdfs:label 'Product Type' ;
    rdfs:comment 'Enterprise-wide banking product type taxonomy — authoritative classification of all financial products offered by the bank (term loans, revolving credit, demand deposits, time deposits, interest rate swaps, FX forwards, letters of credit, guarantees, etc.). Captures product type code, product family, asset class, sub-product type, regulatory product category (Basel, IFRS 9), line of business ownership, booking model, and applicable fee schedule type. Used for regulatory reporting bucketing, risk aggregation, product catalog management, and cross-domain product identification.' .

ind:Jurisdiction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Reference ;
    rdfs:label 'Jurisdiction' ;
    rdfs:comment 'Legal and regulatory jurisdiction master covering national, sub-national (state/province), and supranational (EU, Basel Committee) jurisdictions relevant to banking operations. Captures jurisdiction code, jurisdiction name, jurisdiction level (national, state, supranational), governing law system (common law, civil law, Sharia), applicable regulatory frameworks (Basel III/IV, MiFID II, Dodd-Frank, MAS), close-out netting enforceability flag, insolvency regime type, data privacy regime (GDPR, CCPA), and withholding tax treaty status. Used by compliance, legal, collateral (netting opinions), tax, and cross-border transaction processing.' .

ind:Channel rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Channel ;
    rdfs:label 'Channel' ;
    rdfs:comment 'Master registry of all customer interaction channels operated by the bank, serving as the SSOT for channel identity, classification, and configuration. Covers digital channels (mobile app, web banking), branch network, ATM network, contact center, relationship manager, and API/open banking channels, with support for emerging channel types including embedded finance and Banking-as-a-Service (BaaS). Captures channel type (aligned with ISO 20022 channel type codes where applicable), channel status, capabilities, supported products and services, operating hours, geographic coverage, regulatory classification, and channel-specific configuration parameters. Each channel sub-type (branch, ATM, digital_channel, contact_center) maintains its own detailed master record that FKs back to this registry for unified channel governance, omnichannel orchestration, and enterprise channel performance reporting.' .

ind:Branch rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Channel ;
    rdfs:label 'Branch' ;
    rdfs:comment 'Master record for each physical branch location in the bank\'s network. Captures branch code, name, address, geographic coordinates, branch type (full-service, limited-service, drive-through, in-store), operating hours, staffing capacity, ATM count, safe deposit box availability, accessibility features, regulatory jurisdiction, BSA/AML designation, and branch performance tier. Serves as the SSOT for branch identity and physical network management.' .

ind:Atm rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Channel ;
    rdfs:label 'Atm' ;
    rdfs:comment 'Master record for each ATM unit in the bank\'s owned and managed network. Captures ATM ID, serial number, model, manufacturer, location (branch-attached or off-premise), address, geographic coordinates, network affiliations (Visa/Mastercard/STAR/Allpoint), supported transaction types, cash cassette configuration, surcharge policy, accessibility compliance (ADA), operational status, last maintenance date, and cash replenishment schedule.' .

ind:DigitalChannel rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Channel ;
    rdfs:label 'Digital Channel' ;
    rdfs:comment 'Master configuration record for each digital banking channel instance, registered API consumer, and third-party provider (TPP) application — mobile banking app (iOS/Android), web banking portal, open banking API endpoints, aggregator integrations, and embedded finance/BaaS API consumers. Captures platform type, version, authentication methods (biometric, MFA, OTP), supported transaction limits, session timeout policies, feature flags, API gateway endpoint, OAuth2/OIDC client credentials (hashed), rate limit tier, environment (sandbox/UAT/production), PSD2/open banking compliance status, TPP regulatory registration (license number, jurisdiction), eIDAS certificate reference, developer/organization identity, API product subscriptions (account information, payment initiation, funds confirmation), data access scope, terms of service version accepted, onboarding approval status, and channel-specific SLA parameters. SSOT for digital channel configuration, API consumer identity, access governance, and TPP lifecycle management.' .

ind:Session rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Channel ;
    rdfs:label 'Session' ;
    rdfs:comment 'Transactional record capturing each authenticated or anonymous customer session across all channels — mobile app, web banking, branch visit, ATM interaction, and contact center call. Captures session ID, channel reference, customer identifier, device fingerprint, IP address, geolocation, authentication method and level, session start/end timestamps, session duration, pages/screens visited, transaction count within session, session outcome (completed, abandoned, timed-out), and termination reason. Serves as the primary grain for fraud detection behavioral models, omnichannel journey tracking, and session-level SLA measurement. Links to channel_interaction for detailed event-level analysis.' .

ind:Interaction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Channel ;
    rdfs:label 'Interaction' ;
    rdfs:comment 'Transactional record of each discrete customer interaction event across any channel, serving as the single source of truth for all channel-originated transaction and engagement activity. Uses a channel_type discriminator to capture channel-specific attributes: ATM transactions (withdrawal, deposit, balance inquiry, cardless cash, PIN change — with network, authorization/response codes, surcharge, cash dispensed flag), branch teller transactions (cash deposit, withdrawal, check cashing, wire initiation, cashiers checks, foreign currency exchange, safe deposit box access — with teller ID, CTR threshold flag for BSA/FinCEN $10K reporting, override approvals), digital banking actions (login, transfer, bill pay, account inquiry), contact center interactions (IVR path, agent interaction, chat, email), and API calls (endpoint, response code, payload size). Captures interaction type, channel reference, timestamp, duration, amount (where applicable), currency, outcome, associated product/service, staff member (for branch/RM), resolution status, and session reference. Enables omnichannel journey reconstruction, SLA measurement, regulatory transaction reporting (CTR/SAR), and channel performance analytics.' .

ind:AtmTransaction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Channel ;
    rdfs:label 'Atm Transaction' ;
    rdfs:comment 'Transactional record of each ATM transaction event — cash withdrawal, deposit, balance inquiry, PIN change, cardless cash, and inter-bank transfers. Captures ATM ID, card number (tokenized), customer reference, transaction type, amount, currency, network used (Visa/Mastercard/STAR), authorization code, response code, surcharge applied, cash dispensed flag, timestamp, and transaction status. Distinct from payment domain wire/ACH — this is ATM-channel-specific card-present transaction capture.' .

ind:ManagedPortfolio rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Wealth ;
    rdfs:label 'Managed Portfolio' ;
    rdfs:comment 'Core master entity representing a discretionary or advisory investment portfolio managed on behalf of a high-net-worth (HNW) or ultra-high-net-worth (UHNW) client. Captures portfolio strategy, benchmark assignment, base currency, AUM, inception date, mandate type (discretionary/advisory), risk profile, investment horizon, fee structure reference, and portfolio status (active/suspended/closed/terminated). Links to client_mandate for contractual terms, investment_policy_statement for investment strategy and pre-mandate proposals, model_portfolio for template allocation and asset allocation targets, and custodian_account for safekeeping. Primary system of record aligned with SimCorp Dimension / BlackRock Aladdin portfolio master.' .

ind:InvestmentPolicyStatement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Wealth ;
    rdfs:label 'Investment Policy Statement' ;
    rdfs:comment 'Formal Investment Policy Statement (IPS) and pre-mandate investment proposal governing a managed portfolio or client relationship. Captures the full advisory lifecycle from initial proposal (recommended strategy, projected return scenarios, risk metrics, fee illustration, client acceptance status) through approved IPS (asset class ranges, return objectives, risk tolerance, liquidity requirements, time horizon, tax considerations, ESG constraints, prohibited securities, concentration limits, sector exclusions, geographic restrictions, regulatory restrictions, rebalancing triggers, and IPS version history). Serves as the authoritative mandate document for portfolio construction, suitability compliance, and restriction enforcement.' .

ind:AssetAllocation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Wealth ;
    rdfs:label 'Asset Allocation' ;
    rdfs:comment 'Strategic and tactical asset allocation targets for a managed portfolio or model portfolio. Records target weights, minimum and maximum bands, actual weights, drift thresholds, asset class hierarchy (equities, fixed income, alternatives, cash), currency allocation, geographic allocation, and effective date. Supports rebalancing workflows and IPS compliance monitoring.' .

ind:PortfolioHolding rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Wealth ;
    rdfs:label 'Portfolio Holding' ;
    rdfs:comment 'Point-in-time and current holdings record for each security position within a managed portfolio, including tax lot-level detail. Captures security identifier (ISIN/CUSIP/SEDOL), quantity held, cost basis, market value, MTM price, unrealized gain/loss, weight in portfolio, settlement date, custodian account, as-of date, and lot-level attributes (acquisition date, acquisition price, lot quantity, cost basis method — FIFO/LIFO/specific identification/average cost, short-term vs long-term classification, wash sale flag, lot status). Primary source for AUM calculation, performance attribution, tax-loss harvesting, and capital gains optimization.' .

ind:PortfolioTransaction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Wealth ;
    rdfs:label 'Portfolio Transaction' ;
    rdfs:comment 'Transactional record of all investment activity and corporate action events within a managed portfolio. Captures trade transactions (buys, sells, subscriptions, redemptions, dividend reinvestments, fee deductions, transfers), corporate action events and their portfolio impact (dividends, stock splits, mergers, rights issues, spin-offs, tender offers — with ex-date, record date, payment date, action ratio, cash/stock election, processing status, SWIFT CA messaging source), and common attributes (trade date, settlement date, security, quantity, price, gross/net amount, transaction type, broker, commission, tax lot impact, settlement status). Feeds performance calculation, holdings reconciliation, client reporting, and automated portfolio_holding updates.' .

ind:NavCalculation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Wealth ;
    rdfs:label 'Nav Calculation' ;
    rdfs:comment 'Net Asset Value (NAV) calculation record for a managed portfolio or fund at a specific valuation date. Captures gross asset value, total liabilities, NAV per unit/share, number of units outstanding, pricing source, valuation methodology, accrued income, management fee accrual, performance fee accrual, and calculation status. Supports daily NAV publication and client statement generation.' .

ind:RebalancingOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Wealth ;
    rdfs:label 'Rebalancing Order' ;
    rdfs:comment 'Portfolio rebalancing instruction and execution record triggered by drift from target asset allocation, IPS mandate changes, model portfolio updates, or client instructions. Captures rebalancing trigger type, target vs actual weights by asset class, proposed trade list (security, direction, quantity, estimated value), approval workflow status, execution date, pre- and post-rebalance drift metrics, tax-loss harvesting flags, and wash sale avoidance checks. Links to portfolio_transaction records upon execution completion.' .

ind:PerformanceReturn rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Wealth ;
    rdfs:label 'Performance Return' ;
    rdfs:comment 'Time-weighted return (TWR) and money-weighted return (MWR/IRR) calculation records for a managed portfolio over defined measurement periods (daily, MTD, QTD, YTD, since inception). Captures gross return, net-of-fee return, benchmark return, active return (alpha), tracking error, Sharpe ratio, Sortino ratio, information ratio, and GIPS-compliant composite membership flag. Supports client reporting and performance attribution.' .

ind:ClientMandate rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Wealth ;
    rdfs:label 'Client Mandate' ;
    rdfs:comment 'Wealth management client mandate defining the scope, terms, and conditions of the advisory or discretionary relationship. Captures mandate type (discretionary/advisory/execution-only), fee schedule, base currency, reporting frequency, custodian details, authorized signatories, mandate start/end dates, termination conditions, and regulatory classification (MiFID II, UHNW suitability tier). Distinct from IPS which governs investment strategy.' .

ind:SuitabilityAssessment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Wealth ;
    rdfs:label 'Suitability Assessment' ;
    rdfs:comment 'Regulatory suitability and appropriateness assessment for a wealth management client. Records assessment date, client risk tolerance score, investment knowledge and experience level, financial situation (income, net worth, liquid assets), investment objectives, time horizon, loss capacity, ESG preferences, assessment outcome (suitable/not suitable), regulatory framework (MiFID II, SEC), assessor ID, and next review date. Mandatory for regulatory compliance.' .

ind:ModelPortfolio rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Wealth ;
    rdfs:label 'Model Portfolio' ;
    rdfs:comment 'Standardized model portfolio template and asset allocation framework used as a reference for client portfolio construction and rebalancing. Captures model name, risk category (conservative/balanced/growth/aggressive), benchmark index, strategic and tactical asset allocation targets (target weights, minimum and maximum bands, actual weights, drift thresholds), asset class hierarchy (equities, fixed income, alternatives, cash), currency allocation, geographic allocation, constituent securities with target weights, model version, effective date, retirement date, and approval status. Supports centralized investment committee governance, rebalancing workflows, and IPS compliance monitoring.' .

ind:FeeSchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Wealth ;
    rdfs:label 'Fee Schedule' ;
    rdfs:comment 'Fee schedule master and billing record governing all charges applied to wealth management client mandates and managed portfolios. Captures the full fee lifecycle: schedule definition (fee type — management, performance, advisory, custody, transaction; fee basis — AUM percentage, flat, tiered; tier breakpoints; performance fee hurdle rate and high-water mark; fee currency; billing frequency; effective date range), billing execution (billing period, applied fee rate, AUM basis for calculation, gross and net fee amounts, tax withholding, invoice reference, payment date, fee waivers, billing status), and accrual/revenue recognition (accrual status, revenue recognition date, general ledger posting reference). Supports client invoicing, management fee reconciliation, and regulatory fee disclosure.' .

ind:FeeBilling rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Wealth ;
    rdfs:label 'Fee Billing' ;
    rdfs:comment 'Actual fee billing and accrual records for wealth management clients. Captures billing period, fee type, AUM basis for calculation, applied fee rate, gross fee amount, tax withholding, net fee charged, billing status, invoice reference, payment date, and fee waiver details. Supports revenue recognition, client invoicing, and management fee reconciliation against the general ledger.' .

ind:CustodianAccount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Wealth ;
    rdfs:label 'Custodian Account' ;
    rdfs:comment 'Custodian account record linking a managed portfolio to its securities safekeeping and settlement account at a custodian bank or prime broker. Captures custodian institution, custodian account number, account type (custody, settlement, cash, margin), base currency, IBAN/BIC, account status (active, frozen, closed), opening and closing dates, authorized signatories, and sub-custodian chain. Distinct from deposit accounts in the account domain — this entity represents the securities custody relationship required for trade settlement, corporate action processing, and regulatory asset segregation (CASS, SEC Rule 15c3-3).' .

ind:TaxLot rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Wealth ;
    rdfs:label 'Tax Lot' ;
    rdfs:comment 'Tax lot record tracking the acquisition cost, holding period, and tax basis for each lot of a security held within a managed portfolio. Captures acquisition date, acquisition price, quantity, cost basis method (FIFO/LIFO/specific identification/average cost), short-term vs long-term classification, unrealized gain/loss, wash sale flag, and lot status. Supports tax-loss harvesting, capital gains optimization, and tax reporting.' .

ind:ChartOfAccounts rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ledger ;
    rdfs:label 'Chart Of Accounts' ;
    rdfs:comment 'Master registry of all general ledger account codes used across the enterprise, defining the financial reporting structure including account number, account name, account type (asset, liability, equity, revenue, expense), normal balance direction, financial statement mapping (balance sheet, income statement, cash flow), IFRS/GAAP classification, consolidation group, and active status. Sourced from Oracle Financials / SAP S/4HANA Chart of Accounts module. Serves as the foundational reference for all journal entries and financial reporting.' .

ind:GlAccount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ledger ;
    rdfs:label 'Gl Account' ;
    rdfs:comment 'Individual general ledger account instance within a specific ledger set and legal entity, representing the operational account used for posting. Captures account code, account description, account category, currency, ledger assignment, cost center linkage, intercompany flag, revaluation flag, reconciliation flag, budget control flag, and effective date range. Distinct from chart_of_accounts (the template) — this is the instantiated account within a specific legal entity and ledger context in Oracle Financials / SAP S/4HANA.' .

ind:JournalEntry rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ledger ;
    rdfs:label 'Journal Entry' ;
    rdfs:comment 'Header record for a general ledger journal entry representing a balanced debit/credit accounting transaction posted to the GL. Captures journal number, source (manual, subledger, intercompany, accrual, revaluation, reversal, recurring, reclassification, top-side adjustment, statistical), category, accounting date, period, ledger, legal entity, currency, total debits/credits, functional currency equivalent, description, preparer, approver, approval status, posting status, reversal indicator, reversal date, batch reference, and SOX control reference. Accruals, FX revaluations, reclassifications, recurring entries, and top-side adjustments are subtypes distinguished by journal source — not separate products. Primary transactional entity of the ledger domain supporting the full GL posting lifecycle including automated posting rules, approval workflows, and audit trail for SOX Section 302/404 compliance.' .

ind:JournalEntryLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ledger ;
    rdfs:label 'Journal Entry Line' ;
    rdfs:comment 'Individual debit or credit line within a journal entry, representing the atomic posting to a specific GL account. Captures line number, GL account code, cost center, profit center, segment, project code, intercompany entity, debit amount, credit amount, functional currency amount, entered currency, exchange rate, exchange rate type, description, tax code, and subledger reference. Supports full dimensional analysis for IFRS/GAAP reporting and SOX audit trail requirements.' .

ind:AccountingPeriod rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ledger ;
    rdfs:label 'Accounting Period' ;
    rdfs:comment 'Definition and status of each financial accounting period within a fiscal calendar, governing when journal entries can be posted. Captures period name, period number, fiscal year, period start date, period end date, period status (open, closed, permanently closed, future enterable), ledger set, legal entity, close sequence, and period type (standard, adjustment, year-end). Controls the financial close process and period-end reporting cycle in Oracle Financials / SAP S/4HANA.' .

ind:CostCenter rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ledger ;
    rdfs:label 'Cost Center' ;
    rdfs:comment 'Organizational accounting unit used for cost allocation, revenue attribution, profitability measurement, and management accounting within the bank. Represents any discrete area of financial responsibility — functioning as a cost center, revenue center, or profit center (including banking segment, product line, geographic region, or shared service unit). Captures unit code, name, type (cost, revenue, profit, shared service), responsible manager/executive, legal entity, business unit, line of business (LOB), geographic region, hierarchy level, parent unit, FTP rate assignment, revenue allocation method, cost allocation method, transfer pricing method, effective date range, and active status. Supports FTP allocation, RAROC reporting, PnL attribution, IFRS 8 segment reporting, Basel III business line mapping, and management accounting across Oracle Financials / SAP S/4HANA. This product is the single source of truth for all organizational accounting units regardless of whether they are measured on cost, revenue, or profit.' .

ind:LegalEntity rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ledger ;
    rdfs:label 'Legal Entity' ;
    rdfs:comment 'Master record for each legal entity within the banking group that maintains its own set of books and financial statements. Captures legal entity code, legal entity name, registration number, jurisdiction, country of incorporation, functional currency, reporting currency, GAAP standard (IFRS/US GAAP), consolidation method (full, equity, proportional), parent entity, intercompany elimination flag, regulatory reporting entity flag, and active status. Foundational for intercompany eliminations, consolidation, and regulatory reporting.' .

ind:Subledger rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ledger ;
    rdfs:label 'Subledger' ;
    rdfs:comment 'Registry of subledger modules that feed into the general ledger, combined with the operational reconciliation records that verify subledger-to-GL integrity each period. Captures subledger configuration: name, type (accounts payable, accounts receivable, fixed assets, loans, securities, payroll, derivatives), source system, GL transfer method, posting frequency, and control account mapping. Also captures period-end reconciliation execution: reconciliation run ID, accounting period, GL account range, subledger aggregate balance, GL posted balance, variance amount, variance root cause, reconciliation status (reconciled, in-progress, exception, escalated), auto-reconciliation flag, preparer, reviewer, approval date, resolution actions, and SOX control evidence reference. This product is the single source of truth for both subledger configuration and subledger-to-GL reconciliation governance, supporting period-end close compliance for SOX Section 302/404 and external audit requirements.' .

ind:TrialBalance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ledger ;
    rdfs:label 'Trial Balance' ;
    rdfs:comment 'Period-end trial balance snapshot capturing the debit and credit balances for every active GL account within a ledger and legal entity for a specific accounting period. Captures ledger, legal entity, accounting period, GL account, cost center, currency, opening balance, period debit activity, period credit activity, closing balance, functional currency equivalent, and balance type (actual, budget, forecast). Serves as the foundation for financial statement preparation under IFRS/GAAP.' .

ind:IntercompanyTransaction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ledger ;
    rdfs:label 'Intercompany Transaction' ;
    rdfs:comment 'Record of a financial transaction between two legal entities within the banking group requiring intercompany elimination during consolidation. Captures transaction reference, originating legal entity, counterparty legal entity, transaction type (loan, fee, dividend, transfer, recharge), transaction date, accounting period, currency, transaction amount, GL account (originating), GL account (counterparty), elimination status, elimination period, and netting agreement reference. Supports IFRS 10 consolidation and intercompany reconciliation.' .

ind:ProfitCenter rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ledger ;
    rdfs:label 'Profit Center' ;
    rdfs:comment 'Management accounting unit representing a discrete business segment or line of business (LOB) that is measured on profitability, enabling PnL attribution and RAROC reporting. Captures profit center code, profit center name, profit center type (banking segment, product line, geographic region), responsible executive, legal entity, LOB classification, FTP rate assignment, revenue allocation method, cost allocation method, parent profit center, hierarchy level, and active status. Supports segment reporting under IFRS 8 and management accounting.' .

ind:Lc rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Loan ;
    rdfs:label 'Lc' ;
    rdfs:comment 'Master record for Letters of Credit (Documentary Credits) issued, advised, or confirmed by the bank under ICC Uniform Customs and Practice rules (UCP 600, eUCP). Captures LC type (sight, usance, deferred payment, acceptance, standby, transferable, revolving, back-to-back, red/green clause), applicant and beneficiary references, issuing and confirming bank identifiers (BIC/SWIFT), LC amount and currency (ISO 4217), expiry date and place of expiry, tolerance percentage, partial shipment and transhipment permissions, applicable Incoterm, ports of loading and discharge, latest shipment date, presentation period (default 21 days per UCP 600 Art. 14c), special conditions, reimbursement instructions, and current lifecycle status (draft, issued, advised, confirmed, amended, partially utilized, fully utilized, expired, cancelled). Serves as the central reference entity for all LC-related amendments, drawings, document examinations, and settlements.' .

ind:LcDrawing rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Loan ;
    rdfs:label 'Lc Drawing' ;
    rdfs:comment 'Unified transactional record capturing all lifecycle activity against a Letter of Credit, including amendments and drawings/presentations. For amendments: records amendment sequence number, amendment type (amount increase/decrease, expiry extension, condition change, document requirement modification), amended field name and prior/new values, amendment request date, issuing bank approval date, beneficiary acceptance status (accepted/rejected/pending per UCP 600 Art. 10), and amendment compliance flag. For drawings: captures drawing sequence number, presentation date, drawing amount and currency, document set reference, discrepancy flags and descriptions (per ISBP 745 standards), waiver status, honour/negotiation decision, payment due date, and settlement status. Discriminated by transaction_type (amendment/drawing). Tracks partial and full drawings against the LC available balance and maintains full amendment audit trail. Serves as the single source of truth for all LC transactional activity in compliance with UCP 600 and ICC regulatory requirements.' .

ind:DocumentaryCollection rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Loan ;
    rdfs:label 'Documentary Collection' ;
    rdfs:comment 'Master record for Documentary Collections (D/P and D/A) processed under URC 522 rules. Captures collection type (documents against payment, documents against acceptance), remitting bank and collecting bank BIC/SWIFT codes, drawer and drawee identities, collection amount and currency, tenor, document set description, protest instructions, case-of-need details, and current status (lodged, presented, paid, accepted, dishonoured, returned). Supports both import and export collection workflows.' .

ind:BankGuarantee rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Loan ;
    rdfs:label 'Bank Guarantee' ;
    rdfs:comment 'Master record for Bank Guarantees and Standby Letters of Credit issued or received, with integrated claim lifecycle management. Captures guarantee type (bid bond, performance bond, advance payment guarantee, retention money guarantee, financial guarantee, standby LC, counter-guarantee), applicant and beneficiary references, issuing and counter-guaranteeing bank details (BIC/SWIFT), guarantee amount and currency, effective and expiry dates, claim period, governing law, auto-extension clause, reduction schedule, demand indicator (on-demand vs conditional), and current status (draft, issued, extended, reduced, claimed, expired, cancelled). For claims against the guarantee: records claim sequence number, claim receipt date, claimed amount, claimant identity, claim documents received, URDG 758 Article 20 compliance assessment result, payment decision (honour/reject with extend-or-pay handling), rejection reason and notification timeline, payment date, and residual guarantee balance post-claim. Serves as the single source of truth for the full guarantee and claim lifecycle from issuance through expiry or claim settlement, governed by URDG 758 and ISP98.' .

ind:TradeDocument rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Loan ;
    rdfs:label 'Trade Document' ;
    rdfs:comment 'Repository of all trade finance documents associated with LC drawings, documentary collections, and guarantees. Captures document type (bill of lading, commercial invoice, packing list, certificate of origin, insurance certificate, inspection certificate, bill of exchange, draft), document reference number, issuer, issue date, document status (received, examined, compliant, discrepant, waived, rejected), discrepancy codes, and storage reference. Supports UCP 600 Article 14 document examination and eUCP electronic document workflows.' .

ind:AmlAlert rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Aml Alert' ;
    rdfs:comment 'AML transaction monitoring alert generated by the financial crime detection engine (NICE Actimize, Oracle Financial Crime, or equivalent) when a customer transaction pattern, behavior anomaly, or network relationship triggers a detection rule, scenario, or machine learning model threshold. Captures alert type (structuring, rapid movement, high-risk geography, unusual activity), risk score, triggering rule/scenario ID, entity under review (customer, account, counterparty), alert status (new, assigned, under-review, escalated, closed), disposition (true positive, false positive, escalated to case), assigned analyst, assignment date, and SLA deadline. Primary operational record driving the Level 1 alert review workflow in AML transaction monitoring.' .

ind:AmlCase rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Aml Case' ;
    rdfs:comment 'Financial crime investigation case opened when one or more AML alerts are escalated for deeper review. Tracks case type (AML, fraud, sanctions), assigned investigator, case status, priority, linked entities (customers, accounts, transactions), investigation narrative, disposition outcome, and regulatory filing obligations. Serves as the primary case management record aligned with NICE Actimize Case Manager.' .

ind:KycReview rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Kyc Review' ;
    rdfs:comment 'Know Your Customer (KYC) / Customer Due Diligence (CDD) periodic review record capturing the review cycle, due diligence level (SDD/CDD/EDD), review trigger (periodic, event-driven, risk-based), assigned analyst, completion date, risk rating outcome, and approval workflow state. Includes documentary evidence collected during the review: document type (passport, utility bill, articles of incorporation, audited financials), document reference number, issuing authority, issue/expiry dates, verification method, and verification status. Tracks the full lifecycle of each KYC refresh event including documentation completeness. Authoritative record for all CDD/EDD review activity and supporting documentation.' .

ind:SanctionsScreeningEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Sanctions Screening Event' ;
    rdfs:comment 'OFAC and international sanctions screening event record capturing the screened entity (customer, counterparty, payment beneficiary, correspondent bank), screening list(s) consulted (OFAC SDN, EU Consolidated, UN Security Council, HMT, internal high-risk), match results including match score, match type (exact, fuzzy, alias), match status (no-match, potential-match, confirmed-match), blocking action taken, disposition, analyst review notes, escalation status, regulatory hold details, and screening timestamp. Includes watchlist reference metadata (list name, type, issuing authority, version, last refresh date) and detailed match artifacts (matched entity name, matched list entry, match confidence score, blocking action, escalation status). Supports real-time payment screening, batch customer screening, and event-driven screening workflows. Authoritative record for all screening events, match results, and watchlist references.' .

ind:RegulatoryExam rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Regulatory Exam' ;
    rdfs:comment 'Regulatory examination or supervisory review record initiated by a governing body (Fed, OCC, FDIC, CFPB, FINRA). Captures examiner agency, examination type (safety and soundness, BSA/AML, consumer compliance, capital adequacy), examination period, scope, lead examiner, status, findings count, and exit meeting date. Master record for managing regulatory examination engagements.' .

ind:RegulatoryFiling rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Regulatory Filing' ;
    rdfs:comment 'Master record for all periodic and event-driven regulatory filings submitted to governing bodies (FinCEN, Fed, OCC, FDIC, SEC, FINRA, CFTC, IRS). Captures filing type (SAR, CTR, Call Report, FR Y-9C, CCAR, DFAST, Form PF, TIC, FATCA/CRS), regulatory agency, reporting period, submission deadline, actual submission date, filing status, and submission reference number. For BSA filings (SAR): subject entity, activity type, suspicious activity description, dollar amount, FinCEN tracking number, and underlying case reference. For BSA filings (CTR): transaction date, amount, currency, conducting party, branch location, exemption status, and FinCEN acknowledgment number. For FATCA/CRS: reporting year, jurisdiction, account holder tax identification, account balance, and income amounts. Single authoritative registry of all regulatory submissions with type-discriminated attributes.' .

ind:Obligation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Obligation' ;
    rdfs:comment 'Master record for a specific regulatory or legal obligation the bank must comply with, derived from laws, regulations, rules, or supervisory guidance (e.g., BSA, Dodd-Frank, GDPR, FATCA, Basel III). Captures obligation source, regulatory body, effective date, applicability scope (LOB, geography, product type), obligation owner, and compliance status. Serves as the regulatory obligation inventory underpinning the GRC framework.' .

ind:RiskRating rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Risk Rating' ;
    rdfs:comment 'AML/BSA customer risk rating assigned to a customer, counterparty, or beneficial owner based on their composite risk profile encompassing customer type, product/service usage, geographic risk (country, jurisdiction), transaction behavior, and adverse information. Captures risk tier (low/medium/high/very-high/prohibited), rating methodology (rule-based, model-based, hybrid), effective date, next scheduled review date, rating rationale narrative, contributing risk factor scores, override indicator, override justification, and approving officer. Drives CDD/EDD requirements, transaction monitoring rule intensity, and KYC review frequency. Distinct from credit risk ratings (risk domain) and fraud risk scores (fraud domain).' .

ind:Case rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fraud ;
    rdfs:label 'Case' ;
    rdfs:comment 'Core master entity representing an operational fraud case opened against a customer, account, or transaction. Captures the full lifecycle from initial alert escalation through investigation, disposition, and closure. Key attributes include case type (card fraud, wire fraud, identity theft, account takeover, check fraud), case status and status history, assigned investigator, priority/severity, channel of occurrence, estimated and confirmed loss amounts, recovery amount, disposition outcome, and regulatory escalation flags. Serves as the central hub linking alerts, incidents, investigations, chargebacks, claims, SARs, evidence, and loss records. Managed within NICE Actimize or Oracle Financial Crime case management platforms.' .

ind:Alert rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fraud ;
    rdfs:label 'Alert' ;
    rdfs:comment 'Transactional record capturing individual fraud detection alerts generated by real-time transaction monitoring rules, machine learning models, or behavioral analytics engines. Each alert references the triggering transaction or event, the detection rule or model that fired, alert severity, alert status (new, reviewed, escalated, closed), and the disposition action taken by the analyst. Feeds the fraud case creation workflow when alerts are confirmed or escalated. Sourced from NICE Actimize transaction monitoring.' .

ind:Investigation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fraud ;
    rdfs:label 'Investigation' ;
    rdfs:comment 'Operational entity tracking the investigation workflow associated with a fraud case within the bank\'s case management platform (NICE Actimize, Oracle Financial Crime). Captures investigation phase (initial review, deep investigation, legal referral, SAR escalation), assigned investigator employee ID, investigation start and end dates, methodology applied (transaction analysis, device forensics, customer interview, surveillance review), evidence items gathered, interview records, findings narrative, recommended disposition (confirmed fraud, no fraud, inconclusive, referred to compliance), and escalation flags. Supports multi-phase investigations where a single case may require sequential investigation stages with different investigators or skill sets. Feeds SAR narrative generation and law enforcement referral packages.' .

ind:Incident rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fraud ;
    rdfs:label 'Incident' ;
    rdfs:comment 'Transactional record capturing a confirmed or suspected fraudulent event at the transaction or account level. Represents the specific fraudulent act (unauthorized transaction, counterfeit card use, wire fraud attempt, check fraud, identity theft event) linked to a fraud case. Captures incident date and time, incident channel (ATM, online, branch, wire, ACH), fraud typology code, transaction reference, monetary amount involved, currency, and whether the incident was customer-reported or system-detected. Multiple incidents may be linked to a single fraud case.' .

ind:Chargeback rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fraud ;
    rdfs:label 'Chargeback' ;
    rdfs:comment 'Master entity managing the full lifecycle of payment card chargebacks initiated in response to disputed or fraudulent transactions. Captures chargeback reason code (per Visa/Mastercard/Amex network rules), dispute amount, original transaction reference, chargeback stage (first chargeback, representment, pre-arbitration, arbitration), network case number, merchant ID, acquirer BIN, response deadlines, and final resolution outcome. Includes the complete audit trail of lifecycle events: network messages, representment filings, arbitration submissions, and resolution events with timestamps and responsible parties. Supports merchant fraud risk assessment including chargeback ratios and network monitoring program enrollment. Linked to fraud cases where chargebacks arise from confirmed fraud.' .

ind:SarFiling rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fraud ;
    rdfs:label 'Sar Filing' ;
    rdfs:comment 'Master entity representing a Suspicious Activity Report (SAR) filed with FinCEN under BSA obligations arising from fraud investigations. Captures SAR type (fraud-related vs AML-related — this entity covers fraud-originated SARs distinct from compliance AML SARs), filing date, subject information, activity description, suspicious activity type codes, monetary amounts, filing status (draft, filed, amended, withdrawn), FinCEN acknowledgment reference, and the originating fraud case reference. Managed within NICE Actimize SAR filing module.' .

ind:LossRecovery rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fraud ;
    rdfs:label 'Loss Recovery' ;
    rdfs:comment 'Transactional entity tracking the complete fraud loss lifecycle from initial loss recognition through recovery activities for confirmed fraud cases. Captures loss event details (loss date, loss category, Basel event type code, gross loss amount, business line, GL account reference) and recovery activities (recovery method — insurance, merchant, network, legal judgment, write-off; recovery amount, recovery date, recovery status). Calculates net loss after recovery. Supports financial reconciliation against the general ledger, regulatory loss reporting under Basel III SMA framework, CCAR/DFAST stress testing loss history, operational risk loss data collection, and internal management reporting on fraud financial impact.' .

ind:DetectionRule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fraud ;
    rdfs:label 'Detection Rule' ;
    rdfs:comment 'Master entity defining fraud detection rules, thresholds, and ML model configurations within the transaction monitoring engine. Captures rule name, category (velocity check, amount threshold, geographic anomaly, device fingerprint, behavioral pattern), rule logic, threshold parameters, channel and product applicability, rule status (active, inactive, testing), effective date, and last tuning date. Includes periodic performance measurement records: true positive rate, false positive rate, alert volume, case conversion rate, detection effectiveness metrics, and measurement period. Supports the complete operational rule tuning lifecycle from initial configuration through performance measurement, governance review, and retirement decisions.' .

ind:Evidence rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fraud ;
    rdfs:label 'Evidence' ;
    rdfs:comment 'Operational entity capturing evidence items collected and attached to fraud investigations and cases within the bank\'s fraud case management system. Tracks evidence type (transaction log extract, device fingerprint record, IP geolocation data, call recording, surveillance footage, document image, network traffic log, customer correspondence, witness statement, third-party verification response), evidence source system (core banking, card processor, digital banking platform, telephony, physical security), collection date and time, collecting analyst, chain of custody status (collected, secured, transferred, archived, destroyed), secure storage reference, admissibility classification, and retention period per the bank\'s evidence retention policy. Supports legal referrals, law enforcement evidence packages, regulatory examination responses, and internal audit reviews.' .

ind:Claim rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fraud ;
    rdfs:label 'Claim' ;
    rdfs:comment 'Master entity representing a customer-initiated fraud claim or dispute submitted through any channel (branch, contact center, digital banking, written notice). Captures claim receipt date, channel, type (unauthorized transaction, identity theft, account takeover, card fraud), claimed amount, customer attestation status, and final resolution. Includes full provisional credit lifecycle tracking: provisional credit amount, issuance date, account credited, regulatory basis (Reg E 10-day rule, Reg Z 5-day rule), reversal date, reversal reason, and final credit confirmation status. Ensures compliance with Regulation E and Regulation Z consumer protection timelines. Distinct from chargeback — a claim is the customer-facing intake record; a chargeback is the network-level dispute.' .

ind:NetworkLink rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fraud ;
    rdfs:label 'Network Link' ;
    rdfs:comment 'Association entity capturing identified relationships between fraud subjects, accounts, devices, and entities that indicate coordinated or organized fraud activity. Tracks link type (shared device fingerprint, shared IP address, shared physical address, shared phone number, common beneficiary account, mule account network, shared employer, velocity pattern match), link strength score, discovery method (automated graph analysis, manual investigation, tip/referral), discovery date, confirming analyst, and linkage to the fraud cases and subjects involved. Supports fraud ring detection and visualization, organized fraud investigation, Suspicious Activity Report narrative enrichment, and law enforcement referral evidence packages. Integrates with graph analytics platforms for network topology analysis.' .

ind:Subject rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fraud ;
    rdfs:label 'Subject' ;
    rdfs:comment 'Master entity representing individuals or entities identified as subjects of fraud investigations — including perpetrators, mule account holders, and suspected organized fraud ring members. Captures subject type (internal employee, external third party, customer, unknown), subject identification details, known aliases, associated accounts and devices, watchlist status, law enforcement referral status, and prior fraud history. Distinct from the customer master — a fraud subject may not be a bank customer and may represent an external threat actor.' .

ind:CollateralAsset rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Collateral ;
    rdfs:label 'Collateral Asset' ;
    rdfs:comment 'Master registry of all collateral assets pledged or eligible for pledging across secured lending, derivatives (ISDA CSA), repo/reverse repo, and margin arrangements. Captures asset type (real estate, securities, cash, commodities, receivables, letters of credit, bank guarantees), legal description, ownership details, lien position, encumbrance status, jurisdiction, custody location, asset condition, and eligibility flags per Basel III, EMIR, and internal credit policy. This is the SSOT for collateral asset identity across the bank — every valuation, pledge, position, transfer, and lifecycle event references this master.' .

ind:Pledge rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Collateral ;
    rdfs:label 'Pledge' ;
    rdfs:comment 'Operational record of a collateral pledge — the formal assignment of a specific collateral asset to secure a specific credit exposure, derivative obligation, or repo transaction. Tracks pledge date, pledge amount/quantity, lien rank (first, second, subordinate), pledge status (active, released, substituted, enforced, defaulted), legal perfection status, obligor, secured party, and the governing collateral agreement. Links collateral assets to the underlying credit or trading obligation. Supports LTV monitoring, collateral coverage calculations, and regulatory capital recognition of credit risk mitigation under Basel III CRM framework.' .

ind:MarginCall rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Collateral ;
    rdfs:label 'Margin Call' ;
    rdfs:comment 'Transactional record of all margin activity — margin calls, initial margin (IM) requirements and balances, and variation margin (VM) daily settlements — under CSA, CCP, and bilateral margin arrangements. Captures call/settlement date, margin type (IM requirement, IM posted/received, VM call, VM settlement), call direction (issued, received), amount, currency, delivery deadline, IM calculation methodology (ISDA SIMM, schedule-based), IM segregation status and custodian details, VM settlement status, netting set reference, dispute flag, dispute reason, dispute resolution status, settlement confirmation, UMR phase compliance, and regulatory flags (UMR, EMIR, Dodd-Frank daily VM). Tracks the full margin lifecycle from requirement calculation through call issuance, delivery, dispute resolution, and settlement confirmation per BCBS/IOSCO margin rules. This is the SSOT for all margin activity including IM balances and VM settlements.' .

ind:CollateralValuation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Collateral ;
    rdfs:label 'Collateral Valuation' ;
    rdfs:comment 'Time-series record of collateral asset valuations used for margin calculations, LTV monitoring, and regulatory reporting. Captures valuation date, valuation method (MTM, appraisal, model-based, index-based), gross market value, haircut applied, net collateral value, valuation source (internal model, third-party appraiser, exchange price), currency, and confidence interval. Supports daily MTM for derivatives and periodic appraisal for real estate and illiquid assets.' .

ind:HaircutSchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Collateral ;
    rdfs:label 'Haircut Schedule' ;
    rdfs:comment 'Reference table defining haircut percentages applied to collateral asset categories for margin and exposure calculations. Covers Basel III standardized approach supervisory haircuts, internal model-based haircuts (own-estimate approach), CCP-specific haircuts, and bilateral CSA-negotiated haircuts. Captures asset class, credit quality step (CQS), residual maturity bucket, currency mismatch add-on, liquidity category, volatility adjustment methodology, regulatory framework (Basel III, EMIR, Dodd-Frank), effective date, and expiry date. Governs the reduction in collateral value recognized for credit risk mitigation and regulatory capital purposes.' .

ind:EligibilityRule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Collateral ;
    rdfs:label 'Eligibility Rule' ;
    rdfs:comment 'Business rules, eligibility criteria, and concentration limits defining what collateral is acceptable and how diversified collateral portfolios must be across all arrangements (CSA, repo, secured lending, CCP). Captures rule type (eligibility criterion, concentration limit, jurisdiction restriction), asset type, minimum credit rating, issuer type, currency, maturity constraints, concentration limit thresholds (issuer, asset class, currency, counterparty — percentage or absolute), limit scope (portfolio-wide, agreement-specific), breach action (hard stop, soft warning), regulatory framework applicability (EMIR, UMR, Basel III, internal credit policy), and effective/expiry dates. Used by the collateral optimization engine to determine eligible collateral pools, enforce portfolio diversification requirements, and prevent over-reliance on any single issuer, asset class, or currency. SSOT for all collateral constraint and eligibility rules.' .

ind:MarginAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Collateral ;
    rdfs:label 'Margin Agreement' ;
    rdfs:comment 'Unified master record for ALL collateral-governing legal agreements across the bank — ISDA Credit Support Annexes (CSA, bilateral and unilateral), CCP clearing agreements, GMRA for repo, GMSLA for securities lending, pledge agreements, security agreements, hypothecation agreements, and charge agreements for secured commercial lending. Captures agreement type, governing law (English, New York, local), jurisdiction, counterparty, threshold amounts, minimum transfer amounts (MTA), independent amounts (IA), IM methodology (ISDA SIMM, schedule-based, CCP grid), VM settlement currency, eligible collateral schedules, rounding conventions, valuation agent, dispute resolution terms, rehypothecation rights, perfection method (UCC filing, mortgage registration, charge registration), lien priority, cross-default provisions, acceleration clauses, regulatory margin regime (UMR phase 1-6, EMIR, Dodd-Frank), and review/renewal dates. SSOT for all collateral agreement terms across secured lending, derivatives, and securities financing. Replaces separate CSA and pledge agreement records with a single type-discriminated master.' .

ind:CollateralPosition rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Collateral ;
    rdfs:label 'Collateral Position' ;
    rdfs:comment 'Current inventory snapshot, calculated exposure record, and margin exposure view for collateral held, posted, or received across all arrangements. Captures position date, collateral asset, arrangement reference, position type (held, posted, received, pledged, rehypothecated, exposure), quantity, face value, market value, haircut value, net collateral value, settlement status, custodian, and — for exposure positions — exposure date, gross positive exposure (GPE), gross negative exposure (GNE), net current exposure (NCE), potential future exposure (PFE), threshold breach amount, collateral already posted/received, net margin requirement, and regulatory capital impact (CVA, RWA). Provides the real-time collateral inventory, margin exposure view feeding margin call generation, and regulatory reporting view (LCR HQLA pool, Basel III SA-CCR). SSOT for collateral positions and margin exposures.' .

ind:MarginExposure rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Collateral ;
    rdfs:label 'Margin Exposure' ;
    rdfs:comment 'Calculated exposure record representing the net mark-to-market exposure under a margin agreement or CSA, used to determine margin call obligations. Captures exposure date, gross positive exposure (GPE), gross negative exposure (GNE), net current exposure (NCE), potential future exposure (PFE), threshold breach amount, collateral already posted/received, net margin requirement, and regulatory capital impact (CVA, RWA). Feeds the margin call generation process.' .

ind:PledgeAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Collateral ;
    rdfs:label 'Pledge Agreement' ;
    rdfs:comment 'Umbrella master record for all types of collateral legal agreements (pledge agreements, security agreements, hypothecation agreements, charge agreements) governing secured lending relationships. Captures agreement type, governing law, jurisdiction, perfection method (UCC filing, mortgage registration, charge registration), lien priority, cross-default provisions, acceleration clauses, and review/renewal dates. Distinct from CSA (derivatives) and GMRA (repo) — covers secured commercial lending collateral.' .

ind:NettingSet rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Collateral ;
    rdfs:label 'Netting Set' ;
    rdfs:comment 'Master record defining netting sets — groups of derivative transactions with a single counterparty subject to legally enforceable close-out netting under an ISDA Master Agreement. Captures netting set identifier, governing ISDA agreement, counterparty, netting enforceability legal opinion status, jurisdiction, product scope (rates, FX, credit, equity, commodities), and regulatory recognition status for capital purposes (Basel III SA-CCR, IMM). Fundamental to exposure calculation, CVA computation, RWA determination, and margin call netting. The netting set is the atomic unit for margin agreement exposure aggregation.' .

ind:LiquidityPosition rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Treasury ;
    rdfs:label 'Liquidity Position' ;
    rdfs:comment 'Daily intraday and end-of-day liquidity position and forward cash flow forecast for the bank, capturing available liquid assets, cash balances across nostro accounts, central bank reserves, undrawn committed facilities, and projected inflows/outflows by currency and tenor bucket (intraday, overnight, 1W, 2W, 1M, 3M). Distinguishes contractual cash flows (loan repayments, bond maturities, coupon payments) from behavioral cash flows (deposit runoff, credit line drawdowns) under base and stress scenarios. Includes forward-looking cash flow forecast by business line for liquidity stress testing and contingency funding planning. Serves as the operational heartbeat for ALCO and treasury desk liquidity monitoring. Tracks LCR and NSFR buffer positions against regulatory minimums (Basel III / BCBS). Supports intraday liquidity monitoring per BCBS 248 and contingency funding trigger assessment. Post-merge: this is the single source of truth for liquidity positions and cash flow forecasting — replaces former separate cash_flow_forecast product.' .

ind:LiquidityRatio rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Treasury ;
    rdfs:label 'Liquidity Ratio' ;
    rdfs:comment 'Unified regulatory liquidity ratio record capturing both Liquidity Coverage Ratio (LCR) and Net Stable Funding Ratio (NSFR) calculations per legal entity and consolidated group. For LCR: captures HQLA stock, total net cash outflows over a 30-day stress horizon, and resulting LCR percentage. For NSFR: captures Available Stable Funding (ASF), Required Stable Funding (RSF) by asset/liability category, and resulting NSFR percentage. Supports daily and quarterly regulatory reporting to the Federal Reserve and OCC under Basel III. Tracks breaches, buffers, and trends against the 100% minimum thresholds for both ratios. Includes ratio type discriminator (LCR, NSFR) for unified compliance monitoring.' .

ind:HqlaInventory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Treasury ;
    rdfs:label 'Hqla Inventory' ;
    rdfs:comment 'Master inventory of High-Quality Liquid Assets (HQLA) held by the treasury for LCR compliance and liquidity buffer management. Captures Level 1 (central bank reserves, sovereign bonds), Level 2A (agency MBS, covered bonds), and Level 2B (corporate bonds, equities) assets with ISIN, market value, haircut percentage, encumbrance status, custodian, and eligibility classification per BCBS 238 criteria. Tracks asset movements (additions, disposals, substitutions, encumbrance changes) and maintains real-time unencumbered HQLA totals by level for intraday LCR monitoring. Feeds directly into liquidity_position and liquidity_ratio calculations.' .

ind:InterbankPlacement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Treasury ;
    rdfs:label 'Interbank Placement' ;
    rdfs:comment 'Transactional record of unsecured interbank money market placements and borrowings (overnight, term, call money) with correspondent banks, central banks, and money market counterparties. Captures counterparty BIC/SWIFT, notional amount, currency, tenor, benchmark rate reference (SOFR, Fed Funds, ESTR), spread, all-in rate, value date, maturity date, rollover status, and settlement status. Feeds into daily liquidity gap analysis, FTP cost-of-funds calculations, and counterparty concentration monitoring. Distinct from repo transactions which are secured funding.' .

ind:RepoPosition rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Treasury ;
    rdfs:label 'Repo Position' ;
    rdfs:comment 'Master and transactional record for repurchase agreement (repo) and reverse repo operations used for short-term secured funding and liquidity management. Master attributes: repo type (classic, sell/buy-back, tri-party), counterparty, GMRA reference, collateral ISIN, haircut, repo rate, open/term flag, start/end dates, margin call status. Transaction-level attributes: individual opening and closing leg records, settlement amounts, accrued interest, MTM valuation, margin call amounts, settlement status (T+1/T+2), and daily P&L attribution for the repo book. Feeds into treasury funding cost ledger and funding plan execution tracking. Interfaces with collateral domain for substitution and margin management. Post-merge: this is the single source of truth for all repo master and transaction data — replaces former separate repo_transaction product.' .

ind:RepoTransaction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Treasury ;
    rdfs:label 'Repo Transaction' ;
    rdfs:comment 'Individual repo and reverse repo transaction leg records under a repo agreement, capturing opening and closing legs, settlement amounts, accrued interest, MTM valuation, margin call amounts, and settlement status (T+1/T+2). Tracks daily P&L attribution for the repo book and feeds into the treasury funding cost ledger.' .

ind:FtpRate rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Treasury ;
    rdfs:label 'Ftp Rate' ;
    rdfs:comment 'Comprehensive Funds Transfer Pricing (FTP) product covering the full FTP lifecycle: internal transfer pricing curve construction, rate definition, and account-level allocation. Curve construction: term structure of internal transfer rates by currency, tenor, and curve type (base rate, liquidity spread, credit spread), built from market benchmarks (SOFR, OIS, swap rates) adjusted for bank-specific liquidity premiums, versioned by effective date and ALCO approval. Rate definition: FTP rates assigned to asset and liability products by tenor bucket, currency, and product type, capturing methodology (matched-maturity, pooled, hybrid), base rate index, spread components (liquidity premium, optionality charge, basis adjustment). Allocation: transactional FTP charge/credit records applied to individual loan, deposit, and investment accounts with notional balance, FTP rate, FTP amount, calculation date, and business line cost center. Enables NIM decomposition and RAROC calculation at product, segment, and LOB level. Post-merge: this is the single source of truth for all FTP methodology, curves, rates, and allocations — replaces former separate transfer_pricing_curve and ftp_allocation products.' .

ind:FtpAllocation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Treasury ;
    rdfs:label 'Ftp Allocation' ;
    rdfs:comment 'Transactional FTP charge and credit allocation records applied to individual loan, deposit, and investment accounts. Captures the account reference, allocated FTP rate, notional balance, FTP charge or credit amount, tenor bucket, currency, calculation date, and business line cost center. Enables NIM decomposition and RAROC calculation at product, segment, and LOB level.' .

ind:InterestRateRiskPosition rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Treasury ;
    rdfs:label 'Interest Rate Risk Position' ;
    rdfs:comment 'Interest rate risk (IRR) position record capturing the bank\'s repricing gap, duration of equity, Economic Value of Equity (EVE) sensitivity, and Net Interest Income (NII) sensitivity across rate shock scenarios (+/-100bps, +/-200bps, +/-300bps). Produced at legal entity and consolidated level for ALCO review and regulatory reporting under BCBS 368 (IRRBB). Tracks basis risk, yield curve risk, and optionality risk components.' .

ind:CapitalRatio rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Treasury ;
    rdfs:label 'Capital Ratio' ;
    rdfs:comment 'Regulatory capital adequacy and planning record capturing current capital ratios (CET1, Tier 1, Total Capital), Risk-Weighted Assets by risk type (credit, market, operational), leverage ratio, and capital buffers (conservation, countercyclical, G-SIB surcharge) at legal entity and consolidated level. Includes multi-year capital planning: projected CET1 trajectories, RWA growth assumptions, dividend/buyback plans, stress scenario capital paths, and capital actions (issuance, redemption, AT1 triggers) under base and adverse scenarios. Produced for CCAR, DFAST, and Basel III Pillar 1 regulatory submissions. Tracks ALCO-approved capital targets and management buffers above regulatory minimums. Post-merge: this is the single source of truth for capital ratios and capital planning — replaces former separate capital_plan product. Note: potential SSOT overlap with risk domain capital/RWA products requires global architect adjudication.' .

ind:CapitalPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Treasury ;
    rdfs:label 'Capital Plan' ;
    rdfs:comment 'Multi-year capital planning record capturing projected CET1 ratios, RWA growth assumptions, dividend and buyback plans, stress scenario capital trajectories, and capital actions (issuance, redemption, AT1 triggers) under base and adverse scenarios. Submitted to the Federal Reserve as part of CCAR/DFAST annual capital planning cycle. Tracks ALCO-approved capital targets and management buffers above regulatory minimums.' .

ind:FundingPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Treasury ;
    rdfs:label 'Funding Plan' ;
    rdfs:comment 'Treasury funding strategy, execution, and debt issuance record capturing the banks wholesale and retail funding plan by instrument type (senior unsecured, covered bonds, FHLB advances, repo, deposits, commercial paper, CDs), target issuance volumes, maturity profile, currency mix, and cost-of-funds targets. Includes individual debt issuance execution records: ISIN/CUSIP, issuance date, maturity, coupon type/rate, currency, notional outstanding, underwriter, listing exchange, call/put features, and outstanding balance tracking. Tracks actual vs. planned funding execution, concentration limits by counterparty and instrument, and feeds into the funding maturity profile and capital structure reporting. Approved by ALCO and updated quarterly. Post-merge: this is the single source of truth for funding strategy and debt issuance — replaces former separate debt_issuance product.' .

ind:DebtIssuance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Treasury ;
    rdfs:label 'Debt Issuance' ;
    rdfs:comment 'Record of wholesale debt instruments issued by the bank for funding purposes, including senior unsecured notes, subordinated debt, covered bonds, FHLB advances, commercial paper, and certificates of deposit. Captures ISIN/CUSIP, issuance date, maturity date, coupon type (fixed/floating), coupon rate, currency, notional outstanding, underwriter, listing exchange, and call/put option features. Feeds into the funding maturity profile and capital structure reporting.' .

ind:NostroAccount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Treasury ;
    rdfs:label 'Nostro Account' ;
    rdfs:comment 'Master record and daily reconciliation for the banks nostro accounts held at correspondent banks globally. Master attributes: account number, correspondent bank BIC/SWIFT, currency, account purpose (settlement, FX, securities), authorized signatories, overdraft limit, account status. Reconciliation attributes: daily matching of internal ledger balances against correspondent bank statements (MT940/MT950), matched/unmatched items (breaks), break aging by category, reconciliation status, resolution actions, and escalation triggers. Critical for RTGS and SWIFT payment settlement, FX position management, and intraday liquidity monitoring (BCBS 248). Regulatory requirement under OCC guidance on correspondent banking controls. Post-merge: this is the single source of truth for nostro master data and reconciliation — replaces former separate nostro_reconciliation product.' .

ind:CashFlowForecast rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Treasury ;
    rdfs:label 'Cash Flow Forecast' ;
    rdfs:comment 'Forward-looking cash flow forecast record capturing projected inflows and outflows by currency, tenor bucket (intraday, overnight, 1W, 2W, 1M, 3M), and business line for liquidity stress testing and contingency funding planning. Distinguishes contractual cash flows (loan repayments, bond maturities, coupon payments) from behavioral cash flows (deposit runoff, credit line drawdowns) under base and stress scenarios.' .

ind:FxTransaction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Payment ;
    rdfs:label 'Fx Transaction' ;
    rdfs:comment 'Foreign exchange transaction record for spot, forward, and swap FX trades executed through the payments function. Captures currency pair, deal rate, value date, settlement instructions, and counterparty.' .

ind:CorrespondentBank rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Payment ;
    rdfs:label 'Correspondent Bank' ;
    rdfs:comment 'Master registry of correspondent banking relationships used for cross-border payment routing. Captures correspondent BIC, relationship type, supported currencies, credit limits, and due diligence status.' .

ind:Guarantee rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Loan ;
    rdfs:label 'Guarantee' ;
    rdfs:comment 'Master record for loan guarantees provided by third parties (personal guarantees, corporate guarantees, government guarantees). Captures guarantor, guarantee type, coverage amount, expiry date, and enforceability status.' .

ind:Disbursement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Loan ;
    rdfs:label 'Disbursement' ;
    rdfs:comment 'Record of loan fund disbursement events capturing disbursement method, destination account, amount, currency, and disbursement conditions satisfied. Distinct from drawdown which is the facility-level event.' .

ind:Pricing rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Loan ;
    rdfs:label 'Pricing' ;
    rdfs:comment 'Loan pricing and rate structure record capturing the interest rate terms, spread, margin, floor, cap, and repricing frequency for each facility. Tracks rate type (fixed, floating, hybrid) and benchmark reference.' .

ind:CtrFiling rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Ctr Filing' ;
    rdfs:comment 'Currency Transaction Report (CTR) filing record for cash transactions exceeding $10,000 as required by BSA. Captures transaction details, filing date, FinCEN BSA ID, and filing status.' .

ind:Policy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Policy' ;
    rdfs:comment 'Compliance policy and procedure master record defining the banks internal policies implementing regulatory requirements. Captures policy name, effective date, review cycle, owner, and approval status.' .

ind:MonitoringRule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Monitoring Rule' ;
    rdfs:comment 'AML/BSA transaction monitoring rule and threshold configuration record. Captures rule logic, detection scenario, threshold parameters, tuning history, and model validation status.' .

ind:CounterpartyAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Trade ;
    rdfs:label 'Counterparty Agreement' ;
    rdfs:comment 'Master record for trading counterparty legal agreements including ISDA Master Agreements, GMRA, GMSLA, and prime brokerage agreements. Captures agreement type, execution date, governing law, and netting provisions.' .

ind:Broker rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Trade ;
    rdfs:label 'Broker' ;
    rdfs:comment 'Master registry of executing brokers, prime brokers, and clearing brokers used for trade execution and post-trade services. Captures broker ID, BIC, relationship type, commission schedule, and regulatory status.' .

ind:IndustryCode rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Reference ;
    rdfs:label 'Industry Code' ;
    rdfs:comment 'Industry classification code reference table covering SIC, NAICS, GICS, and ICB classification systems. Captures code, description, hierarchy level, and cross-mapping between systems.' .

ind:TrustAccount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Wealth ;
    rdfs:label 'Trust Account' ;
    rdfs:comment 'Trust and fiduciary account record for wealth management clients. Captures trust type, grantor, trustee, beneficiaries, trust terms, distribution provisions, and fiduciary duty classification.' .

ind:Fund rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Asset ;
    rdfs:label 'Fund' ;
    rdfs:comment 'Golden source master record for every investment fund managed, administered, or distributed by the bank. Captures fund type (mutual fund, ETF, hedge fund, pension fund, UCITS, SICAV, closed-end), legal structure, domicile jurisdiction, base currency, inception date, target AUM, investment objective, benchmark index, regulatory classification (UCITS, AIF, 40 Act), fund status (active, soft-closed, liquidating, terminated), fiscal year end, and fund manager assignment. Serves as the SSOT for fund identity across NAV calculation, distribution, and regulatory reporting.' .

ind:FundClass rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Asset ;
    rdfs:label 'Fund Class' ;
    rdfs:comment 'Master record for each share class or unit class within a fund. Captures class code, class name, currency, distribution policy (accumulating vs distributing), minimum investment, management fee, performance fee, entry/exit load, ISIN, CUSIP, Bloomberg ticker, hedged/unhedged flag, investor eligibility (retail, institutional, professional), and class inception date. A fund may have multiple classes with different fee structures and currencies targeting different investor segments.' .

ind:NavRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Asset ;
    rdfs:label 'Nav Record' ;
    rdfs:comment 'Authoritative Net Asset Value (NAV) calculation record for each fund class at each valuation date. Captures gross asset value, total liabilities, net asset value, NAV per unit/share, number of units outstanding, total subscriptions and redemptions processed, accrued income, accrued expenses, management fee accrual, performance fee accrual, valuation frequency (daily, weekly, monthly), pricing basis (forward/historic), and NAV publication timestamp. Serves as the SSOT for fund pricing used in investor transactions and regulatory reporting.' .

ind:FundHolding rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Asset ;
    rdfs:label 'Fund Holding' ;
    rdfs:comment 'Point-in-time portfolio holding record for each security or asset position held within a fund at a specific valuation date. Captures instrument identifier, asset class, quantity held, market price, market value in local and base currency, percentage of NAV, cost basis, unrealized gain/loss, accrued income, country of risk, sector classification, credit rating, duration (for fixed income), and liquidity classification. Drives NAV calculation, regulatory reporting (UCITS, AIFMD), and portfolio analytics.' .

ind:FundTransaction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Asset ;
    rdfs:label 'Fund Transaction' ;
    rdfs:comment 'Transactional record of all fund-level accounting entries and portfolio transactions including security purchases, sales, maturities, corporate action receipts, dividend income, interest income, expense payments, and FX transactions. Captures transaction type, trade date, settlement date, instrument, quantity, price, gross amount, net amount, currency, FX rate, broker, settlement status, and accounting treatment. Feeds fund accounting subledger and NAV calculation.' .

ind:InvestorAccount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Asset ;
    rdfs:label 'Investor Account' ;
    rdfs:comment 'Master record for each investor account registered in the fund\'s transfer agency system. Captures investor type (retail, institutional, nominee), account status, registration details, tax residency, FATCA/CRS classification, AML status, distribution preference (reinvestment vs cash), bank account for distributions, preferred currency, account opening date, and relationship manager. Serves as the SSOT for investor identity within the fund administration and transfer agency function.' .

ind:Subscription rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Asset ;
    rdfs:label 'Subscription' ;
    rdfs:comment 'Transactional record of investor subscription (purchase) orders for fund units or shares. Captures investor account, fund class, order date, settlement date, subscription amount or units requested, dealing NAV applied, gross subscription amount, entry load, net investment amount, units allotted, payment method, payment status, source of funds declaration, and AML clearance status. Represents the primary investor inflow event in the fund lifecycle.' .

ind:Redemption rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Asset ;
    rdfs:label 'Redemption' ;
    rdfs:comment 'Transactional record of investor redemption (sale) orders for fund units or shares. Captures investor account, fund class, order date, settlement date, redemption units or amount requested, dealing NAV applied, gross redemption proceeds, exit load, net proceeds payable, payment destination account, redemption type (full/partial), lock-up period compliance check, gate restriction flag, and settlement status. Represents the primary investor outflow event in the fund lifecycle.' .

ind:DistributionEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Asset ;
    rdfs:label 'Distribution Event' ;
    rdfs:comment 'Record of fund income distribution events (dividends, interest distributions, capital gain distributions) declared and paid to investors. Captures fund class, ex-dividend date, record date, payment date, distribution type (income/capital gain/return of capital), distribution rate per unit, total distribution amount, reinvestment NAV, withholding tax rate, net distribution per unit, and payment method. Drives investor tax reporting and unit register updates.' .

ind:UnitRegister rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Asset ;
    rdfs:label 'Unit Register' ;
    rdfs:comment 'Authoritative unit/share register record maintaining the current and historical unit holdings for each investor account in each fund class. Captures investor account, fund class, units held, average cost per unit, total cost basis, unrealized gain/loss, first investment date, last transaction date, and register status. Serves as the legal record of fund ownership and is the SSOT for investor unit balances used in redemption processing and distribution calculations.' .

ind:FundMandate rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Asset ;
    rdfs:label 'Fund Mandate' ;
    rdfs:comment 'Investment mandate and policy record governing the investment strategy, constraints, and guidelines for a fund. Captures investment objective, permitted asset classes, geographic restrictions, sector limits, issuer concentration limits, credit quality minimums, duration range, liquidity requirements, leverage limits, derivative usage policy, ESG/SRI constraints, benchmark, and mandate review date. Serves as the compliance reference for portfolio construction and investment restriction monitoring.' .

ind:InvestmentRestriction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Asset ;
    rdfs:label 'Investment Restriction' ;
    rdfs:comment 'Operational record of investment restriction rules and compliance checks applied to fund portfolios. Captures restriction type (regulatory, mandate, internal), rule description, threshold value, breach tolerance, monitoring frequency, pre-trade vs post-trade flag, breach status, breach date, breach magnitude, remediation deadline, and responsible portfolio manager. Supports UCITS investment restriction monitoring, AIFMD compliance, and internal mandate adherence.' .

ind:FundPerformance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Asset ;
    rdfs:label 'Fund Performance' ;
    rdfs:comment 'Periodic fund performance record capturing time-weighted returns (TWR) and money-weighted returns (MWR/IRR) for each fund class over standard reporting periods (1M, 3M, 6M, YTD, 1Y, 3Y, 5Y, since inception). Captures gross and net returns, benchmark return, active return (alpha), tracking error, Sharpe ratio, information ratio, maximum drawdown, volatility, and GIPS compliance flag. Used for investor reporting, fund factsheets, and regulatory disclosures.' .

ind:PaymentChannel rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Payment ;
    rdfs:label 'Payment Channel' ;
    rdfs:comment 'Master record defining the payment channels and rails available for payment processing — ACH, Fedwire, CHIPS, SWIFT, SEPA, card networks (Visa/Mastercard), real-time payment networks (RTP, FedNow). Captures channel code, channel name, operating hours, cut-off times, settlement cycle, and supported currencies.' .

ind:Reconciliation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Payment ;
    rdfs:label 'Reconciliation' ;
    rdfs:comment 'Operational record of payment reconciliation activities matching internal payment records against external clearing house confirmations, correspondent bank statements, and card network settlement files. Captures reconciliation date, matched/unmatched counts, break items, and resolution status.' .

ind:AccountHolder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Account Holder' ;
    rdfs:comment 'This association product represents the ownership and signing authority relationship between parties and deposit accounts. It captures the legal and operational relationship that defines who owns, controls, and has authority over deposit accounts. Each record links one party to one deposit account with attributes that define the nature of ownership (primary owner, joint owner, authorized signer), ownership percentage for joint accounts, signing authority levels and limits, beneficiary designations, and the temporal validity of the relationship. This is the canonical banking M:N pattern that enables joint accounts, corporate accounts with multiple signatories, and accounts with authorized representatives.. Existence Justification: In banking operations, parties and deposit accounts have a true many-to-many relationship. One party (customer) can own or have authority over multiple deposit accounts (checking, savings, money market, CDs), and one deposit account can have multiple parties associated with it (joint account owners, authorized signers, corporate signatories, beneficiaries, trustees). This relationship is actively managed by banking operations teams who add/remove account holders, modify signing authority, update beneficiary designations, and track ownership percentages.' .

ind:Card rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Payment ;
    rdfs:label 'Card' ;
    rdfs:comment 'Master reference table for card. Referenced by card_id.' .

ind:SanctionsListEntry rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Sanctions List Entry' ;
    rdfs:comment 'Master reference table for sanctions_list_entry. Referenced by matched_list_entry_id.' .

ind:Tranche rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Investment ;
    rdfs:label 'Tranche' ;
    rdfs:comment 'Master reference table for tranche. Referenced by tranche_id.' .

ind:Merchant rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Payment ;
    rdfs:label 'Merchant' ;
    rdfs:comment 'Master reference table for merchant. Referenced by merchant_id.' .

ind:ClearingHouse rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Trade ;
    rdfs:label 'Clearing House' ;
    rdfs:comment 'Master reference table for clearing_house. Referenced by clearing_house_id.' .

ind:ScenarioAppetiteResult rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Risk ;
    rdfs:label 'Scenario Appetite Result' ;
    rdfs:comment 'This association product represents the formal stress test result event between a stress_scenario and a risk appetite statement. It captures the outcome of evaluating a specific stress scenario against a specific appetite metric — including the stressed metric value, breach status, and delta to threshold. Each record is a governance-grade result produced during CCAR, DFAST, ICAAP, or internal stress cycles, reviewed by ALCO and the Board. Attributes exist only in the context of this scenario-appetite intersection and cannot reside on either parent entity.. Existence Justification: In enterprise risk management, stress testing scenarios are formally evaluated against each risk appetite statement as part of CCAR/DFAST/ICAAP governance processes. A single stress scenario (e.g., \'Severely Adverse 2024\') is tested against MULTIPLE appetite metrics (CET1 floor, LCR, credit loss tolerance, etc.), and each appetite statement is evaluated under MULTIPLE scenarios (baseline, adverse, severely adverse). The business actively manages and reports on these per-scenario, per-appetite results as a formal governance deliverable — this is not an analytical derivation but an operationally produced record reviewed by ALCO and the Board.' .

ind:ReconciliationItem rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Payment ;
    rdfs:label 'Reconciliation Item' ;
    rdfs:comment 'This association product represents the matching Event between a reconciliation run and a specific payment transaction. It captures the operational outcome of matching one payment transaction within one reconciliation cycle, including match status, matched amount, sequence, and exception indicators. Each record is created by the reconciliation engine when it processes a transaction against an external statement, and is updated as breaks are investigated and resolved. This is the SSOT for per-transaction reconciliation outcomes.. Existence Justification: In payment operations, reconciliation is a batch process that matches multiple payment transactions against external clearing/settlement statements. A single reconciliation run covers many transactions, and critically, the same transaction can appear across multiple reconciliation cycles (initial, amended, final) — meaning the relationship is genuinely bidirectional and many-to-many. The business actively manages \'reconciliation items\' — named operational records that capture the matching result (match_status, exception_flag, matched_amount, reconciliation_sequence) for each specific transaction within each specific reconciliation run.' .

# --- Attribute Properties ---
ind:dealId rdf:type rdf:Property ;
    rdfs:label 'Deal Id' ;
    rdfs:comment 'Unique surrogate identifier for the investment banking deal or transaction mandate. Primary key for the deal entity, referenced by all downstream investment domain entities including mandate, valuation, offering, syndication, tombstone, and fee arrangement.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Deal .

ind:capitalPlanId rdf:type rdf:Property ;
    rdfs:label 'Capital Plan Id' ;
    rdfs:comment 'Foreign key linking to treasury.capital_plan. Business justification: Large deals impact projected RWA growth and capital consumption in forward capital planning. Business process: capital planning incorporates investment banking pipeline to forecast RWA growth and ensu' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CapitalPlan .

ind:corporateProfileId rdf:type rdf:Property ;
    rdfs:label 'Corporate Profile Id' ;
    rdfs:comment 'Foreign key linking to customer.corporate_profile. Business justification: Investment deals are executed for corporate clients; deal teams require direct access to corporate_profile for credit ratings, industry classification, and KYC attributes during deal origination and c' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CorporateProfile .

ind:costCenterId rdf:type rdf:Property ;
    rdfs:label 'Cost Center Id' ;
    rdfs:comment 'Foreign key linking to ledger.cost_center. Business justification: Deals are attributed to cost centers (coverage teams, product groups) for P&L tracking, resource allocation, banker compensation, and management reporting. Core requirement for segment profitability a' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:counterpartyRatingId rdf:type rdf:Property ;
    rdfs:label 'Counterparty Rating Id' ;
    rdfs:comment 'Foreign key linking to risk.counterparty_rating. Business justification: Deals require counterparty credit ratings for client risk assessment, credit approval workflows, pricing decisions, and regulatory capital allocation. Standard practice in investment banking to link d' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CounterpartyRating .

ind:currencyId rdf:type rdf:Property ;
    rdfs:label 'Currency Id' ;
    rdfs:comment 'Foreign key linking to reference.currency. Business justification: Investment deals are denominated in a specific currency; FX reporting, cross-border deal analytics, regulatory capital calculations (RWA), and league table reporting all require a proper currency refe' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:ftpRateId rdf:type rdf:Property ;
    rdfs:label 'Ftp Rate Id' ;
    rdfs:comment 'Foreign key linking to treasury.ftp_rate. Business justification: Investment banking deals require FTP rates for profitability analysis and internal pricing of capital allocated to transactions. Real business process: deal economics modeling calculates net revenue a' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FtpRate .

ind:holidayCalendarId rdf:type rdf:Property ;
    rdfs:label 'Holiday Calendar Id' ;
    rdfs:comment 'Foreign key linking to reference.holiday_calendar. Business justification: Deal closing date calculations, pricing date scheduling, and expected vs. actual closing date reconciliation require a holiday calendar. Banking operations teams use holiday calendars to determine val' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HolidayCalendar .

ind:issuerId rdf:type rdf:Property ;
    rdfs:label 'Issuer Id' ;
    rdfs:comment 'Foreign key linking to security.issuer. Business justification: Every investment banking deal (M&A, ECM, DCM) is associated with an issuer entity in the security master. deal.counterparty_name and target_company_name are denormalized issuer references. Linking to ' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Issuer .

ind:kycRecordId rdf:type rdf:Property ;
    rdfs:label 'Kyc Record Id' ;
    rdfs:comment 'Foreign key linking to customer.kyc_record. Business justification: Deals require documented KYC clearance before execution; regulators (FCA, SEC) require banks to evidence which KYC record cleared each deal. Direct deal→kyc_record FK supports deal-level AML/KYC audit' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:KycRecord .

ind:legalEntityId rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Id' ;
    rdfs:comment 'Foreign key linking to ledger.legal_entity. Business justification: Investment banking deals must be booked to specific legal entities for regulatory capital calculation, financial statement consolidation, and tax reporting. Core requirement for Basel III, IFRS 10 con' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:originationBranchId rdf:type rdf:Property ;
    rdfs:label 'Origination Branch Id' ;
    rdfs:comment 'Foreign key linking to channel.branch. Business justification: Deal origination at a specific branch drives branch-level P&L attribution, banker incentive compensation, and regulatory jurisdiction assignment. The existing origination_channel_id captures channel t' ;
    rdfs:domain ind:Deal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Branch .

ind:originationChannelId rdf:type rdf:Property ;
    rdfs:label 'Origination Channel Id' ;
    rdfs:comment 'Foreign key linking to channel.channel. Business justification: Investment deals are originated through specific banking channels (branch, digital, RM). Deal capture systems track origination channel for revenue attribution, channel profitability analysis, and reg' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:partyId rdf:type rdf:Property ;
    rdfs:label 'Party Id' ;
    rdfs:comment 'FK to customer.party.party_id — MUST-HAVE: Investment banking deals must link to the client party for relationship management, conflict checking, and revenue attribution.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:profitCenterId rdf:type rdf:Property ;
    rdfs:label 'Profit Center Id' ;
    rdfs:comment 'Foreign key linking to ledger.profit_center. Business justification: Investment banking deals are attributed to profit centers for P&L reporting, revenue attribution, and banker compensation calculations. Management accounting requires deal-level profit center assignme' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProfitCenter .

ind:riskLimitId rdf:type rdf:Property ;
    rdfs:label 'Risk Limit Id' ;
    rdfs:comment 'Foreign key linking to risk.risk_limit. Business justification: Investment banking deal approval workflows require explicit risk limit checks (single-name exposure, country, sector concentration limits). The deal credit committee approval process references the go' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RiskLimit .

ind:stressScenarioId rdf:type rdf:Property ;
    rdfs:label 'Stress Scenario Id' ;
    rdfs:comment 'Foreign key linking to risk.stress_scenario. Business justification: Investment banking deals require stress testing under CCAR/DFAST regulatory scenarios to assess capital impact, deal viability under adverse conditions, and regulatory approval requirements. Essential' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StressScenario .

ind:targetCountryId rdf:type rdf:Property ;
    rdfs:label 'Target Country Id' ;
    rdfs:comment 'Foreign key linking to reference.country. Business justification: Cross-border deal tracking, OFAC/sanctions screening, regulatory approval workflows, and FATF risk assessment require linking the deal\'s target country to the canonical country reference. Role-prefixe' ;
    rdfs:domain ind:Investment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:targetIndustryCodeId rdf:type rdf:Property ;
    rdfs:label 'Target Industry Code Id' ;
    rdfs:comment 'Foreign key linking to reference.industry_code. Business justification: Industry classification drives sector concentration limits, credit portfolio segmentation, CECL modeling, and league table rankings. Target_industry_sector is denormalized industry name.' ;
    rdfs:domain ind:Deal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IndustryCode .

ind:actualClosingDate rdf:type rdf:Property ;
    rdfs:label 'Actual Closing Date' ;
    rdfs:comment 'The actual date on which the transaction legally closed and was completed. Populated upon deal closure; used for revenue recognition, tombstone generation, and post-deal performance analysis.' ;
    rdfs:domain ind:Deal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:announcementDate rdf:type rdf:Property ;
    rdfs:label 'Announcement Date' ;
    rdfs:comment 'The date on which the transaction was publicly announced to the market. Relevant for M&A and ECM transactions; triggers regulatory disclosure obligations and market impact analysis.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complexity rdf:type rdf:Property ;
    rdfs:label 'Complexity' ;
    rdfs:comment 'Qualitative assessment of the deal\'s structural and execution complexity, used for resource allocation, staffing decisions, and risk committee escalation thresholds. Assessed at origination and updated as deal structure evolves.' ;
    rdfs:domain ind:Deal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityLevel rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Level' ;
    rdfs:comment 'Information barrier and confidentiality classification of the deal. STRICTLY_CONFIDENTIAL deals trigger Chinese Wall protocols, restricted list management, and information barrier controls to prevent insider trading.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdTimestamp rdf:type rdf:Property ;
    rdfs:label 'Created Timestamp' ;
    rdfs:comment 'The timestamp when the deal record was first created in the system, in ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX). Provides audit trail for record creation; used for data lineage, SOX compliance, and pipeline aging calculations.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dealCode rdf:type rdf:Property ;
    rdfs:label 'Deal Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier assigned to the deal at origination, used in pitch books, mandate letters, and client communications. Typically follows the investment bank\'s internal deal numbering convention (e.g., IB-2024-00123).' ;
    rdfs:domain ind:Deal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealDescription rdf:type rdf:Property ;
    rdfs:label 'Deal Description' ;
    rdfs:comment 'Free-text narrative description of the deal structure, strategic rationale, and key transaction terms. Used in pitch books, deal committee memos, and tombstone records. Contains sensitive deal information subject to information barrier controls.' ;
    rdfs:domain ind:Deal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealName rdf:type rdf:Property ;
    rdfs:label 'Deal Name' ;
    rdfs:comment 'Human-readable name or working title of the deal, often referencing the target company or project codename (e.g., \'Project Falcon — Acquisition of XYZ Corp\'). Used in internal pipeline reporting and pitch book headers.' ;
    rdfs:domain ind:Deal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealStatus rdf:type rdf:Property ;
    rdfs:label 'Deal Status' ;
    rdfs:comment 'Current operational status of the deal record. ACTIVE indicates the deal is in progress; CLOSED_WON indicates successful completion; CLOSED_LOST or WITHDRAWN indicates the deal did not proceed. Used for pipeline management and revenue forecasting.' ;
    rdfs:domain ind:Deal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealType rdf:type rdf:Property ;
    rdfs:label 'Deal Type' ;
    rdfs:comment 'Classification of the investment banking transaction by strategic category. Drives workflow, fee structure, and regulatory treatment. [ENUM-REF-CANDIDATE: M&A_BUY_SIDE|M&A_SELL_SIDE|ECM|DCM|LBO|RESTRUCTURING|SYNDICATED_LENDING|LEVERAGED_FINANCE|PROJECT_FINANCE|SPIN_OFF — promote to reference product]' ;
    rdfs:domain ind:Deal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedClosingDate rdf:type rdf:Property ;
    rdfs:label 'Expected Closing Date' ;
    rdfs:comment 'Projected date on which the transaction is expected to close or complete. Used for pipeline probability weighting, revenue forecasting, and resource scheduling. Updated as deal progresses through execution stages.' ;
    rdfs:domain ind:Deal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expectedFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Expected Fee Amount' ;
    rdfs:comment 'The estimated total advisory or underwriting fee expected to be earned upon deal completion, expressed in the deal currency. Used for revenue pipeline forecasting, banker incentive compensation, and ALCO revenue planning.' ;
    rdfs:domain ind:Deal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feeRateBps rdf:type rdf:Property ;
    rdfs:label 'Fee Rate Bps' ;
    rdfs:comment 'The advisory or underwriting fee expressed as a rate in basis points (BPS) of the deal size or enterprise value. Standard investment banking fee metric; used for benchmarking against market comparables and mandate negotiation.' ;
    rdfs:domain ind:Investment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isCrossBorder rdf:type rdf:Property ;
    rdfs:label 'Is Cross Border' ;
    rdfs:comment 'Flag indicating whether the transaction involves parties or assets in more than one country. Triggers additional regulatory review, FATCA/CRS reporting obligations, and cross-border M&A regulatory approval tracking.' ;
    rdfs:domain ind:Deal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPublicCompany rdf:type rdf:Property ;
    rdfs:label 'Is Public Company' ;
    rdfs:comment 'Flag indicating whether the target or issuer is a publicly listed company. Determines applicability of SEC disclosure requirements, public M&A rules (e.g., Williams Act), and public company audit standards.' ;
    rdfs:domain ind:Deal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lobCode rdf:type rdf:Property ;
    rdfs:label 'Lob Code' ;
    rdfs:comment 'Code identifying the investment banking line of business responsible for the deal (e.g., M&A Advisory, Equity Capital Markets, Debt Capital Markets, Leveraged Finance, Restructuring). Used for P&L attribution and management reporting.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mandateDate rdf:type rdf:Property ;
    rdfs:label 'Mandate Date' ;
    rdfs:comment 'The date on which the client formally awarded the mandate to the bank, typically evidenced by a signed engagement letter or mandate agreement. Triggers formal deal execution resourcing and fee accrual commencement.' ;
    rdfs:domain ind:Investment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originationDate rdf:type rdf:Property ;
    rdfs:label 'Origination Date' ;
    rdfs:comment 'The date on which the deal opportunity was first identified and entered into the pipeline system. Marks the start of the deal lifecycle and is used for pipeline aging analysis and banker performance attribution.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pipelineProbabilityPct rdf:type rdf:Property ;
    rdfs:label 'Pipeline Probability Pct' ;
    rdfs:comment 'Estimated probability (0.00–100.00%) that the deal will successfully close, assigned by the coverage banker and reviewed by deal committee. Used to compute probability-weighted revenue in pipeline forecasting and ALCO reporting.' ;
    rdfs:domain ind:Deal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pitchDate rdf:type rdf:Property ;
    rdfs:label 'Pitch Date' ;
    rdfs:comment 'The date on which the formal pitch or proposal was presented to the client. Marks the transition from origination to active pursuit; used for pipeline conversion rate analysis and banker activity tracking.' ;
    rdfs:domain ind:Deal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pricingDate rdf:type rdf:Property ;
    rdfs:label 'Pricing Date' ;
    rdfs:comment 'The date on which the transaction was priced (applicable to ECM and DCM transactions). For IPOs and bond issuances, this is the date the final offer price or coupon is set; triggers T+1 or T+2 settlement obligations.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rationale rdf:type rdf:Property ;
    rdfs:label 'Rationale' ;
    rdfs:comment 'Summary of the strategic rationale for the transaction from the client\'s perspective (e.g., market expansion, synergy realization, capital structure optimization). Used in deal committee presentations and regulatory filings.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionCode rdf:type rdf:Property ;
    rdfs:label 'Region Code' ;
    rdfs:comment 'Geographic region responsible for the deal coverage and execution (Americas, EMEA, Asia-Pacific). Used for regional P&L attribution, pipeline reporting, and regulatory jurisdiction mapping.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryApprovalRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Required' ;
    rdfs:comment 'Flag indicating whether the transaction requires regulatory approval (e.g., antitrust/HSR filing, CFIUS review, FCA approval, ECB notification). Triggers compliance workflow and deal timeline adjustment.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:restrictedListFlag rdf:type rdf:Property ;
    rdfs:label 'Restricted List Flag' ;
    rdfs:comment 'Indicates whether the deal has triggered placement of the target or issuer on the bank\'s restricted trading list, preventing proprietary trading and research publication. Enforces information barrier compliance.' ;
    rdfs:domain ind:Deal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:size rdf:type rdf:Property ;
    rdfs:label 'Size' ;
    rdfs:comment 'The total transaction size or notional value of the deal (e.g., total equity raised for ECM, total debt issued for DCM, total consideration for M&A). Distinct from enterprise value; represents the actual capital markets transaction amount.' ;
    rdfs:domain ind:Deal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceSystemDealRef rdf:type rdf:Property ;
    rdfs:label 'Source System Deal Ref' ;
    rdfs:comment 'The deal identifier as recorded in the originating system of record (e.g., Murex deal ID, Loan IQ deal number, or internal CRM opportunity ID). Enables lineage tracing and reconciliation between the lakehouse silver layer and operational systems.' ;
    rdfs:domain ind:Deal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subtype rdf:type rdf:Property ;
    rdfs:label 'Subtype' ;
    rdfs:comment 'Further granular classification within the deal type. For ECM: IPO, Follow-On, Rights Issue, SPAC. For DCM: Investment Grade Bond, High Yield Bond, Convertible Note. For M&A: Strategic, Financial Sponsor. [ENUM-REF-CANDIDATE: IPO|FOLLOW_ON|RIGHTS_ISSUE|SPAC|IG_BOND|HY_BOND|CONVERTIBLE|STRATEGIC_MA|FINANCIAL_SPONSOR — promote to reference product]' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetEnterpriseValue rdf:type rdf:Property ;
    rdfs:label 'Target Enterprise Value' ;
    rdfs:comment 'The estimated total enterprise value of the target company or transaction, expressed in the deal currency. Used as the primary sizing metric for M&A transactions, LBO analysis, and DCF valuation benchmarking. Basis for fee calculation in many mandate structures.' ;
    rdfs:domain ind:Deal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:updatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Updated Timestamp' ;
    rdfs:comment 'The timestamp of the most recent modification to the deal record, in ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX). Used for change data capture, audit trail maintenance, and detecting stale pipeline records.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:investmentMandateId rdf:type rdf:Property ;
    rdfs:label 'Investment Mandate Id' ;
    rdfs:comment 'Unique surrogate identifier for the investment banking mandate record in the lakehouse silver layer. Primary key for this entity.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InvestmentMandate .

ind:accountingPeriodId rdf:type rdf:Property ;
    rdfs:label 'Accounting Period Id' ;
    rdfs:comment 'Foreign key linking to ledger.accounting_period. Business justification: Mandate effective_date and expiry_date determine the accounting period for retainer fee recognition and mandate revenue accrual under IFRS 15 / ASC 606. Period-end close requires mandates to be mapped' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccountingPeriod .

ind:dealSizeCurrencyId rdf:type rdf:Property ;
    rdfs:label 'Deal Size Currency Id' ;
    rdfs:comment 'Foreign key linking to reference.currency. Business justification: Estimated deal size is expressed in a specific currency; cross-currency mandate comparison, revenue forecasting, and regulatory capital planning require a proper currency reference. Role-prefixed \'dea' ;
    rdfs:domain ind:InvestmentMandate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:engagementChannelId rdf:type rdf:Property ;
    rdfs:label 'Engagement Channel Id' ;
    rdfs:comment 'Foreign key linking to channel.channel. Business justification: Client mandates for advisory services are signed through specific channels. MiFID II and Dodd-Frank require tracking client engagement channel for suitability and best execution compliance. Mandate ma' ;
    rdfs:domain ind:InvestmentMandate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:governingLawJurisdictionId rdf:type rdf:Property ;
    rdfs:label 'Governing Law Jurisdiction Id' ;
    rdfs:comment 'Foreign key linking to reference.jurisdiction. Business justification: Governing law jurisdiction required for legal enforceability assessment, netting opinion validation, and dispute resolution framework per ISDA Master Agreement standards.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Jurisdiction .

ind:industryCodeId rdf:type rdf:Property ;
    rdfs:label 'Industry Code Id' ;
    rdfs:comment 'Foreign key linking to reference.industry_code. Business justification: Mandate scope is defined by industry sector for conflict-of-interest checks, league table reporting, and sector-specialist coverage assignment. Banking compliance requires linking mandates to canonica' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IndustryCode .

ind:marginAgreementId rdf:type rdf:Property ;
    rdfs:label 'Margin Agreement Id' ;
    rdfs:comment 'Foreign key linking to collateral.margin_agreement. Business justification: Investment banking mandates for derivatives and structured products reference CSA/margin agreements governing collateral terms. Real process: ISDA master agreement negotiation, collateral schedule doc' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MarginAgreement .

ind:bankSignatoryName rdf:type rdf:Property ;
    rdfs:label 'Bank Signatory Name' ;
    rdfs:comment 'Full name of the authorized bank representative who executed the mandate letter on behalf of the bank. Required for legal enforceability and audit trail.' ;
    rdfs:domain ind:InvestmentMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientSignatoryName rdf:type rdf:Property ;
    rdfs:label 'Client Signatory Name' ;
    rdfs:comment 'Full name of the authorized client representative who executed the mandate letter on behalf of the client entity. Required for legal enforceability and Know Your Customer (KYC) documentation.' ;
    rdfs:domain ind:InvestmentMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientSignatoryTitle rdf:type rdf:Property ;
    rdfs:label 'Client Signatory Title' ;
    rdfs:comment 'Job title or designation of the client signatory (e.g., Chief Financial Officer, Managing Director) confirming their authority to bind the client entity under the mandate.' ;
    rdfs:domain ind:InvestmentMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionDate rdf:type rdf:Property ;
    rdfs:label 'Completion Date' ;
    rdfs:comment 'Date on which the mandated transaction was successfully completed and closed (e.g., IPO pricing date, M&A closing date, bond settlement date). Triggers final fee recognition and tombstone eligibility.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conflictCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Conflict Check Status' ;
    rdfs:comment 'Status of the bank\'s internal conflict of interest review for this mandate. Mandates cannot be activated until conflicts are cleared or formally waived per Governance, Risk and Compliance (GRC) policy.' ;
    rdfs:domain ind:Investment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeResolutionMechanism rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Mechanism' ;
    rdfs:comment 'Contractually agreed mechanism for resolving disputes arising under the mandate agreement (e.g., litigation in courts, arbitration under ICC/LCIA rules, mediation).' ;
    rdfs:domain ind:InvestmentMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveDate rdf:type rdf:Property ;
    rdfs:label 'Effective Date' ;
    rdfs:comment 'Date from which the mandate becomes binding and the bank is authorized to commence advisory or underwriting activities on behalf of the client.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:engagementScope rdf:type rdf:Property ;
    rdfs:label 'Engagement Scope' ;
    rdfs:comment 'Narrative description of the services the bank is mandated to provide, including advisory scope, underwriting obligations, distribution responsibilities, and any carve-outs or limitations agreed in the mandate letter.' ;
    rdfs:domain ind:InvestmentMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedDealSize rdf:type rdf:Property ;
    rdfs:label 'Estimated Deal Size' ;
    rdfs:comment 'Estimated gross transaction value or deal size as agreed at mandate signing. Used for pipeline valuation, fee estimation, and Discounted Cash Flow (DCF) modelling. Expressed in deal_size_currency.' ;
    rdfs:domain ind:InvestmentMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exclusivityEndDate rdf:type rdf:Property ;
    rdfs:label 'Exclusivity End Date' ;
    rdfs:comment 'End date of the exclusivity period. After this date, the client may engage competing advisors unless the mandate is renewed or the exclusivity is extended.' ;
    rdfs:domain ind:InvestmentMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exclusivityStartDate rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Start Date' ;
    rdfs:comment 'Start date of the exclusivity period during which the client is contractually restricted from engaging other advisors for the same transaction.' ;
    rdfs:domain ind:InvestmentMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expiryDate rdf:type rdf:Property ;
    rdfs:label 'Expiry Date' ;
    rdfs:comment 'Date on which the mandate agreement expires if the transaction has not been completed. Nullable for open-ended mandates. Distinct from the exclusivity end date.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:feeCurrency rdf:type rdf:Property ;
    rdfs:label 'Fee Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which mandate fees (retainer, success fee, minimum fee) are denominated and payable. May differ from deal_size_currency for cross-border transactions.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingLawState rdf:type rdf:Property ;
    rdfs:label 'Governing Law State' ;
    rdfs:comment 'State or province within the governing law jurisdiction (e.g., New York, England and Wales) where sub-national law applies. Relevant for US and federal jurisdictions.' ;
    rdfs:domain ind:InvestmentMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investmentMandateStatus rdf:type rdf:Property ;
    rdfs:label 'Investment Mandate Status' ;
    rdfs:comment 'Current lifecycle state of the mandate agreement. Drives pipeline reporting, fee accrual eligibility, and deal team resource allocation. Valid states: draft (under negotiation), active (signed and in force), suspended (temporarily paused), terminated (cancelled before completion), completed (transaction closed), lapsed (exclusivity expired without execution).' ;
    rdfs:domain ind:InvestmentMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isExclusive rdf:type rdf:Property ;
    rdfs:label 'Is Exclusive' ;
    rdfs:comment 'Indicates whether the mandate grants the bank exclusive advisory rights for the transaction, preventing the client from engaging competing advisors during the exclusivity period.' ;
    rdfs:domain ind:InvestmentMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent modification to the mandate record, in ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX). Required for change data capture, audit trail, and regulatory record-keeping.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:leagueTableEligible rdf:type rdf:Property ;
    rdfs:label 'League Table Eligible' ;
    rdfs:comment 'Indicates whether this mandate and its associated transaction qualify for submission to investment banking league table rankings (e.g., Bloomberg, Dealogic, Thomson Reuters). Drives competitive positioning analytics.' ;
    rdfs:domain ind:InvestmentMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:letterDate rdf:type rdf:Property ;
    rdfs:label 'Letter Date' ;
    rdfs:comment 'Date on which the mandate letter was formally signed and executed by both the bank and the client. This is the principal business event date establishing the contractual engagement.' ;
    rdfs:domain ind:InvestmentMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mandateType rdf:type rdf:Property ;
    rdfs:label 'Mandate Type' ;
    rdfs:comment 'Classification of the bank\'s role under the mandate agreement. Determines fee entitlement, exclusivity rights, and regulatory disclosure obligations. [ENUM-REF-CANDIDATE: exclusive_advisor|co_advisor|bookrunner|co_manager|lead_manager|arranger — promote to reference product]' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Fee Amount' ;
    rdfs:comment 'Minimum guaranteed fee payable to the bank regardless of final transaction size, providing a floor on advisory compensation. Expressed in deal_size_currency.' ;
    rdfs:domain ind:Investment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pitchBookReference rdf:type rdf:Property ;
    rdfs:label 'Pitch Book Reference' ;
    rdfs:comment 'Document management system reference or identifier for the pitch book or information memorandum presented to the client prior to mandate award. Supports audit trail and deal origination tracking.' ;
    rdfs:domain ind:InvestmentMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reference rdf:type rdf:Property ;
    rdfs:label 'Reference' ;
    rdfs:comment 'Externally-known alphanumeric reference code assigned to the mandate, used in client correspondence, pitch books, and regulatory filings. Format: LOB-MND-YYYY-NNNNNNNN.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retainerFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Retainer Fee Amount' ;
    rdfs:comment 'Fixed upfront or periodic retainer fee payable by the client to the bank upon mandate signing, independent of transaction completion. Expressed in deal_size_currency.' ;
    rdfs:domain ind:InvestmentMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:successFeeBps rdf:type rdf:Property ;
    rdfs:label 'Success Fee Bps' ;
    rdfs:comment 'Contingent success fee expressed in Basis Points (BPS) of the final transaction value, payable upon successful completion of the mandated transaction. Drives revenue recognition and Profit and Loss (PnL) attribution.' ;
    rdfs:domain ind:InvestmentMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tailPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Tail Period Months' ;
    rdfs:comment 'Number of months following mandate termination or expiry during which the bank retains the right to a success fee if the transaction is completed with a counterparty introduced during the mandate period.' ;
    rdfs:domain ind:Investment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetCompanyName rdf:type rdf:Property ;
    rdfs:label 'Target Company Name' ;
    rdfs:comment 'Name of the target company or issuer in the transaction (e.g., acquisition target in M&A, issuer in an IPO or bond offering). May be confidential prior to public announcement.' ;
    rdfs:domain ind:Investment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationDate rdf:type rdf:Property ;
    rdfs:label 'Termination Date' ;
    rdfs:comment 'Date on which the mandate was formally terminated prior to transaction completion, if applicable. Populated only when status is \'terminated\'. Distinct from expiry_date (natural end) and completion_date (successful close).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:terminationRights rdf:type rdf:Property ;
    rdfs:label 'Termination Rights' ;
    rdfs:comment 'Description of the contractual termination rights available to either party, including notice periods, termination for convenience clauses, material adverse change (MAC) provisions, and tail fee obligations upon termination.' ;
    rdfs:domain ind:InvestmentMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tombstoneEligible rdf:type rdf:Property ;
    rdfs:label 'Tombstone Eligible' ;
    rdfs:comment 'Indicates whether the completed transaction is eligible for tombstone advertisement publication, subject to client consent and regulatory requirements. Tombstones are used for marketing and league table submissions.' ;
    rdfs:domain ind:Investment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transactionType rdf:type rdf:Property ;
    rdfs:label 'Transaction Type' ;
    rdfs:comment 'Category of the investment banking transaction covered by this mandate (e.g., Initial Public Offering (IPO), Mergers and Acquisitions (M&A) buy-side, Debt Capital Markets (DCM)). Drives workflow, fee structure, and regulatory treatment. [ENUM-REF-CANDIDATE: ipo|follow_on|m_and_a_buy_side|m_and_a_sell_side|debt_capital_markets|equity_capital_markets|syndicated_loan|restructuring — promote to reference product]' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionStructureId rdf:type rdf:Property ;
    rdfs:label 'Transaction Structure Id' ;
    rdfs:comment 'Unique surrogate identifier for the investment banking transaction structure record. Primary key for this entity in the Silver Layer lakehouse.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TransactionStructure .

ind:capitalRatioId rdf:type rdf:Property ;
    rdfs:label 'Capital Ratio Id' ;
    rdfs:comment 'Foreign key linking to treasury.capital_ratio. Business justification: M&A transaction structures require capital ratio impact analysis — regulators and ALCO require pro-forma CET1 assessment before deal approval. transaction_structure already stores pro_forma_cet1_ratio' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CapitalRatio .

ind:dealValueCurrencyId rdf:type rdf:Property ;
    rdfs:label 'Deal Value Currency Id' ;
    rdfs:comment 'Foreign key linking to reference.currency. Business justification: Transaction deal value, cash consideration, and equity value amounts are denominated in a specific currency; fairness opinion preparation, regulatory filing, and cross-border deal FX conversion requir' ;
    rdfs:domain ind:TransactionStructure ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:regulatoryExamId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Exam Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_exam. Business justification: Regulatory examiners (OCC, Fed, SEC) directly review transaction structures for capital adequacy, Volcker Rule compliance, and structural risk. A direct FK enables examiners to pull all structures rev' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryExam .

ind:actualCloseDate rdf:type rdf:Property ;
    rdfs:label 'Actual Close Date' ;
    rdfs:comment 'Actual date on which the transaction closed and legal title or consideration was transferred. Null until the transaction is completed. Used for fee billing and tombstone records.' ;
    rdfs:domain ind:TransactionStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:advisoryFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Advisory Fee Amount' ;
    rdfs:comment 'Total investment banking advisory fee earned or expected for this transaction structure, including retainer, announcement fee, and success fee components. Used for revenue recognition and league table credit.' ;
    rdfs:domain ind:TransactionStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:breakupFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Breakup Fee Amount' ;
    rdfs:comment 'Termination or breakup fee payable by the target or acquirer if the transaction is terminated under specified conditions. Typically 1-4% of deal value; disclosed in merger agreement and proxy statement.' ;
    rdfs:domain ind:TransactionStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cashConsiderationAmount rdf:type rdf:Property ;
    rdfs:label 'Cash Consideration Amount' ;
    rdfs:comment 'Cash portion of the total consideration payable to target shareholders or security holders. Used in mixed-consideration deal structuring and tax analysis.' ;
    rdfs:domain ind:TransactionStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confidentialityAgreementDate rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Agreement Date' ;
    rdfs:comment 'Date on which the non-disclosure agreement (NDA) or confidentiality agreement was executed between the parties. Establishes the start of the restricted information-sharing period and wall-crossing obligations.' ;
    rdfs:domain ind:TransactionStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:considerationType rdf:type rdf:Property ;
    rdfs:label 'Consideration Type' ;
    rdfs:comment 'Form of consideration offered in the transaction (e.g., cash, stock, mixed cash-and-stock, debt assumption, or earnout). Critical for M&A valuation, tax structuring, and shareholder approval requirements.' ;
    rdfs:domain ind:TransactionStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossBorderFlag rdf:type rdf:Property ;
    rdfs:label 'Cross Border Flag' ;
    rdfs:comment 'Indicates whether the transaction involves parties or assets in more than one country. Triggers additional regulatory, tax, and FX structuring considerations including CFIUS review for US transactions.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dcfEnterpriseValue rdf:type rdf:Property ;
    rdfs:label 'Dcf Enterprise Value' ;
    rdfs:comment 'Intrinsic enterprise value derived from the DCF valuation model underpinning the transaction structure. Represents the present value of projected free cash flows discounted at the WACC.' ;
    rdfs:domain ind:TransactionStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dealValueAmount rdf:type rdf:Property ;
    rdfs:label 'Deal Value Amount' ;
    rdfs:comment 'Gross enterprise value or total deal consideration amount as agreed in the transaction structure. Represents the headline deal size used in pitch books, tombstones, and league table reporting.' ;
    rdfs:domain ind:TransactionStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:debtAssumedAmount rdf:type rdf:Property ;
    rdfs:label 'Debt Assumed Amount' ;
    rdfs:comment 'Total net debt assumed or refinanced as part of the transaction structure. Used in the enterprise-to-equity value bridge and leverage ratio calculations.' ;
    rdfs:domain ind:TransactionStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:equityValueAmount rdf:type rdf:Property ;
    rdfs:label 'Equity Value Amount' ;
    rdfs:comment 'Equity value (market capitalisation or offer price times diluted shares) component of the transaction structure. Distinct from enterprise value; used in DCF valuation bridge and per-share consideration calculations.' ;
    rdfs:domain ind:TransactionStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exchangeRatio rdf:type rdf:Property ;
    rdfs:label 'Exchange Ratio' ;
    rdfs:comment 'Number of acquirer shares offered per target share in a stock-for-stock or mixed-consideration transaction. Null for cash-only deals. Used in merger proxy statements and SEC Form S-4 filings.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedCloseDate rdf:type rdf:Property ;
    rdfs:label 'Expected Close Date' ;
    rdfs:comment 'Anticipated date on which the transaction is expected to close and consideration is transferred. Used for deal pipeline forecasting and fee recognition scheduling.' ;
    rdfs:domain ind:TransactionStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fairnessOpinionRequired rdf:type rdf:Property ;
    rdfs:label 'Fairness Opinion Required' ;
    rdfs:comment 'Indicates whether the board of directors requires a fairness opinion from an independent financial advisor to support the transaction. Typically required for related-party transactions and large public M&A.' ;
    rdfs:domain ind:TransactionStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:financingMixDebtPct rdf:type rdf:Property ;
    rdfs:label 'Financing Mix Debt Pct' ;
    rdfs:comment 'Percentage of total transaction financing sourced from debt instruments (senior secured, mezzanine, high-yield bonds). Used in leverage ratio analysis and pro forma capital structure modelling.' ;
    rdfs:domain ind:TransactionStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financingMixEquityPct rdf:type rdf:Property ;
    rdfs:label 'Financing Mix Equity Pct' ;
    rdfs:comment 'Percentage of total transaction financing sourced from equity (sponsor equity, management rollover, public equity issuance). Complements debt percentage to form the full financing mix.' ;
    rdfs:domain ind:TransactionStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leadArrangerRole rdf:type rdf:Property ;
    rdfs:label 'Lead Arranger Role' ;
    rdfs:comment 'Role of the bank in this transaction structure (e.g., sole bookrunner, joint bookrunner, lead-left, financial advisor). Determines league table credit allocation and fee entitlement.' ;
    rdfs:domain ind:TransactionStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leverageRatio rdf:type rdf:Property ;
    rdfs:label 'Leverage Ratio' ;
    rdfs:comment 'Pro forma leverage ratio expressed as total debt divided by EBITDA at transaction close. Key credit metric used by rating agencies, lenders, and regulators to assess transaction risk. Aligns with Basel III leverage ratio monitoring.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:offerPremiumPct rdf:type rdf:Property ;
    rdfs:label 'Offer Premium Pct' ;
    rdfs:comment 'Percentage premium offered over the target\'s unaffected share price (typically 30-day VWAP prior to announcement). Key M&A valuation metric used in fairness opinions and board presentations.' ;
    rdfs:domain ind:TransactionStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryApprovalBodies rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Bodies' ;
    rdfs:comment 'Comma-separated list of regulatory bodies whose approval is required for this transaction (e.g., \'Fed, OCC, DOJ, EC\'). Drives compliance workflow and deal timeline planning.' ;
    rdfs:domain ind:TransactionStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shareholderApprovalRequired rdf:type rdf:Property ;
    rdfs:label 'Shareholder Approval Required' ;
    rdfs:comment 'Indicates whether the transaction requires shareholder or bondholder approval (e.g., merger vote, rights issue prospectus approval). Triggers proxy statement and SEC Schedule 14A filing obligations.' ;
    rdfs:domain ind:TransactionStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stockConsiderationAmount rdf:type rdf:Property ;
    rdfs:label 'Stock Consideration Amount' ;
    rdfs:comment 'Equity (stock) portion of the total consideration, valued at the exchange ratio applied to the acquirer\'s share price. Used in share-for-share merger structuring and dilution analysis.' ;
    rdfs:domain ind:TransactionStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:structuralConditionType rdf:type rdf:Property ;
    rdfs:label 'Structural Condition Type' ;
    rdfs:comment 'Primary structural condition or protective mechanism embedded in the transaction agreement (e.g., MAC clause, financing condition, no-shop provision, breakup fee). [ENUM-REF-CANDIDATE: material_adverse_change|regulatory_condition|financing_condition|no_shop|go_shop|breakup_fee|other — promote to reference product]' ;
    rdfs:domain ind:TransactionStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:structureName rdf:type rdf:Property ;
    rdfs:label 'Structure Name' ;
    rdfs:comment 'Human-readable name or working title for the transaction structure (e.g., \'Project Falcon — Leveraged Buyout Structure\'). Treated as confidential pre-announcement deal information.' ;
    rdfs:domain ind:TransactionStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:structureReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Structure Reference Code' ;
    rdfs:comment 'Externally-known alphanumeric reference code assigned to this transaction structure, used in pitch books, mandate letters, and regulatory filings (e.g., IB-2024-ACQX001).' ;
    rdfs:domain ind:TransactionStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:structureStatus rdf:type rdf:Property ;
    rdfs:label 'Structure Status' ;
    rdfs:comment 'Current lifecycle status of the transaction structure from initial drafting through execution or termination. Drives workflow routing and deal pipeline reporting.' ;
    rdfs:domain ind:TransactionStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:structureType rdf:type rdf:Property ;
    rdfs:label 'Structure Type' ;
    rdfs:comment 'Classification of the investment banking transaction structure type. Drives applicable regulatory approvals, valuation methodology, and capital markets execution approach. [ENUM-REF-CANDIDATE: merger|acquisition|carve_out|spin_off|ipo|follow_on|rights_issue|bond_issuance|syndicated_loan|leveraged_buyout — promote to reference product]' ;
    rdfs:domain ind:TransactionStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:syndicationRequired rdf:type rdf:Property ;
    rdfs:label 'Syndication Required' ;
    rdfs:comment 'Indicates whether the financing component of this transaction requires syndication to a group of lenders or underwriters (e.g., syndicated loan, bond roadshow). Triggers syndicate desk involvement.' ;
    rdfs:domain ind:TransactionStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transactionDate rdf:type rdf:Property ;
    rdfs:label 'Transaction Date' ;
    rdfs:comment 'The principal real-world date on which the transaction structure was formally agreed, signed, or announced. Used as the primary business event date for deal timeline tracking and regulatory reporting.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:underwritingFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Underwriting Fee Amount' ;
    rdfs:comment 'Gross underwriting spread or fee for capital markets transactions (IPO, follow-on, bond issuance). Expressed as a total dollar amount; gross spread percentage is derived analytically.' ;
    rdfs:domain ind:Investment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waccRate rdf:type rdf:Property ;
    rdfs:label 'Wacc Rate' ;
    rdfs:comment 'Weighted average cost of capital rate used as the discount rate in the DCF valuation model for this transaction structure. Expressed as a decimal (e.g., 0.0850 = 8.50%).' ;
    rdfs:domain ind:TransactionStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:investmentValuationId rdf:type rdf:Property ;
    rdfs:label 'Investment Valuation Id' ;
    rdfs:comment 'Unique surrogate identifier for each investment valuation or fairness opinion record in the investment banking advisory platform. Primary key for the investment_valuation data product.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InvestmentValuation .

ind:fundId rdf:type rdf:Property ;
    rdfs:label 'Fund Id' ;
    rdfs:comment 'Foreign key linking to asset.fund. Business justification: Fairness opinions and M&A valuations on asset manager acquisitions or fund stake transactions require direct reference to the fund being valued. Cross-referencing fund attributes (strategy, AUM, struc' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fund .

ind:instrumentId rdf:type rdf:Property ;
    rdfs:label 'Instrument Id' ;
    rdfs:comment 'Foreign key linking to security.instrument. Business justification: Fairness opinions reference specific securities (target stock, comparable securities for trading multiples). Links valuation to instrument for audit trail of comparables selection, methodology documen' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Instrument .

ind:managedPortfolioId rdf:type rdf:Property ;
    rdfs:label 'Managed Portfolio Id' ;
    rdfs:comment 'Foreign key linking to wealth.managed_portfolio. Business justification: Fair-value marking of illiquid/private holdings: IB-produced DCF and comparable-company valuations are consumed by wealth management to mark private equity and pre-IPO positions in managed portfolios ' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ManagedPortfolio .

ind:navRecordId rdf:type rdf:Property ;
    rdfs:label 'Nav Record Id' ;
    rdfs:comment 'Foreign key linking to asset.nav_record. Business justification: When performing fairness opinions or valuations on fund stakes or asset manager M&A, the valuation anchors to a specific NAV record as the reference point. Auditors and regulators require traceability' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NavRecord .

ind:pledgeId rdf:type rdf:Property ;
    rdfs:label 'Pledge Id' ;
    rdfs:comment 'Foreign key linking to collateral.collateral_pledge. Business justification: Fairness opinions and investment valuations in secured M&A and leveraged buyouts must assess collateral pledge value for LTV analysis, recovery value estimation, and net debt calculation. Valuation te' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Pledge .

ind:rateBenchmarkId rdf:type rdf:Property ;
    rdfs:label 'Rate Benchmark Id' ;
    rdfs:comment 'Foreign key linking to reference.rate_benchmark. Business justification: WACC calculations in DCF valuations reference a specific risk-free rate benchmark (e.g., SOFR, Treasury rate); audit trail for valuation assumptions, fairness opinion documentation, and regulatory rev' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RateBenchmark .

ind:approvalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approval Timestamp' ;
    rdfs:comment 'Date and time at which the valuation or fairness opinion was formally approved by the designated investment committee or approval authority. Marks the transition from in_review to approved status and is a key compliance milestone.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:boardPresentationDate rdf:type rdf:Property ;
    rdfs:label 'Board Presentation Date' ;
    rdfs:comment 'Date on which the valuation analysis or fairness opinion was formally presented to the client\'s board of directors. Required for fairness opinion compliance documentation and proxy statement disclosure. Distinct from the valuation date.' ;
    rdfs:domain ind:InvestmentValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Delivery Timestamp' ;
    rdfs:comment 'Date and time at which the valuation analysis or fairness opinion letter was formally delivered to the client or their board of directors. Marks the transition to delivered status and is referenced in the engagement letter and regulatory filings.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:enterpriseValueHigh rdf:type rdf:Property ;
    rdfs:label 'Enterprise Value High' ;
    rdfs:comment 'Upper bound of the enterprise value range derived from the valuation analysis, expressed in the deal currency. The EV range reflects sensitivity analysis across key assumptions such as WACC and terminal growth rate.' ;
    rdfs:domain ind:InvestmentValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enterpriseValueLow rdf:type rdf:Property ;
    rdfs:label 'Enterprise Value Low' ;
    rdfs:comment 'Lower bound of the enterprise value range derived from the valuation analysis, expressed in the deal currency. Enterprise Value represents the total value of the business including debt and excluding cash. Used for deal pricing and fairness opinion conclusions.' ;
    rdfs:domain ind:InvestmentValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:equityValueHigh rdf:type rdf:Property ;
    rdfs:label 'Equity Value High' ;
    rdfs:comment 'Upper bound of the implied equity value range, calculated by deducting net debt from the enterprise value high. Used in conjunction with shares outstanding to derive implied per-share value ranges for board presentations and proxy filings.' ;
    rdfs:domain ind:InvestmentValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:equityValueLow rdf:type rdf:Property ;
    rdfs:label 'Equity Value Low' ;
    rdfs:comment 'Lower bound of the implied equity value range, calculated by deducting net debt from the enterprise value low. Represents the value attributable to equity holders and is used to derive implied share price ranges for M&A and IPO pricing.' ;
    rdfs:domain ind:InvestmentValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evEbitdaMultipleHigh rdf:type rdf:Property ;
    rdfs:label 'Ev Ebitda Multiple High' ;
    rdfs:comment 'Upper bound of the implied EV/EBITDA multiple derived from the valuation range. Together with the low multiple, defines the EV/EBITDA range used in board presentations, fairness opinion analyses, and investment committee materials.' ;
    rdfs:domain ind:InvestmentValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evEbitdaMultipleLow rdf:type rdf:Property ;
    rdfs:label 'Ev Ebitda Multiple Low' ;
    rdfs:comment 'Lower bound of the implied EV/EBITDA multiple derived from the valuation range, calculated as enterprise value low divided by the target company\'s EBITDA. Used to benchmark the valuation against comparable company trading multiples and precedent transaction multiples.' ;
    rdfs:domain ind:InvestmentValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastPeriodYears rdf:type rdf:Property ;
    rdfs:label 'Forecast Period Years' ;
    rdfs:comment 'Number of years in the explicit cash flow forecast period used in the DCF or LBO model. Typically 5 to 10 years for investment banking valuations. Determines the horizon over which detailed financial projections are modeled before applying the terminal value.' ;
    rdfs:domain ind:InvestmentValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:impliedSharePriceHigh rdf:type rdf:Property ;
    rdfs:label 'Implied Share Price High' ;
    rdfs:comment 'Upper bound of the implied per-share equity value derived from the equity value high divided by fully diluted shares outstanding. Together with the low, defines the implied share price range disclosed in fairness opinion proxy materials.' ;
    rdfs:domain ind:InvestmentValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impliedSharePriceLow rdf:type rdf:Property ;
    rdfs:label 'Implied Share Price Low' ;
    rdfs:comment 'Lower bound of the implied per-share equity value derived from the equity value low divided by fully diluted shares outstanding. Used in fairness opinion analyses to compare the implied price range against the proposed transaction consideration.' ;
    rdfs:domain ind:InvestmentValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isFairnessOpinion rdf:type rdf:Property ;
    rdfs:label 'Is Fairness Opinion' ;
    rdfs:comment 'Indicates whether this valuation record constitutes a formal fairness opinion (True) or an internal valuation analysis (False). Fairness opinions carry additional regulatory obligations under SEC Rule 14a-9 and FINRA Rule 5150, including board presentation and proxy disclosure requirements.' ;
    rdfs:domain ind:InvestmentValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ltmEbitda rdf:type rdf:Property ;
    rdfs:label 'Ltm Ebitda' ;
    rdfs:comment 'Earnings Before Interest, Taxes, Depreciation, and Amortization (EBITDA) for the last twelve months (LTM) period used as the primary financial metric in the valuation analysis. Denominator for EV/EBITDA multiple calculations and key input to DCF normalization.' ;
    rdfs:domain ind:InvestmentValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:materialRelationshipDisclosure rdf:type rdf:Property ;
    rdfs:label 'Material Relationship Disclosure' ;
    rdfs:comment 'Narrative description of any material relationships between the investment bank and the parties to the transaction that must be disclosed in the fairness opinion letter or proxy statement, as required by FINRA Rule 5150. Includes prior advisory mandates, lending relationships, and equity holdings.' ;
    rdfs:domain ind:InvestmentValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:methodology rdf:type rdf:Property ;
    rdfs:label 'Methodology' ;
    rdfs:comment 'Primary valuation methodology applied in this analysis. Common investment banking methodologies include Discounted Cash Flow (DCF), Leveraged Buyout (LBO), Comparable Company Analysis, Precedent Transaction Analysis, Sum-of-Parts (SOTP), Net Asset Value (NAV), Dividend Discount Model (DDM), and Asset-Based valuation. [ENUM-REF-CANDIDATE: DCF|LBO|comparable_company|precedent_transaction|sum_of_parts|NAV|dividend_discount|asset_based — promote to reference product]' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelFileReference rdf:type rdf:Property ;
    rdfs:label 'Model File Reference' ;
    rdfs:comment 'Document management system reference or file path to the underlying financial model (Excel/Python workbook) supporting this valuation. Enables auditors and reviewers to trace the valuation conclusion back to the source model and assumptions.' ;
    rdfs:domain ind:InvestmentValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netDebt rdf:type rdf:Property ;
    rdfs:label 'Net Debt' ;
    rdfs:comment 'Total financial debt less cash and cash equivalents of the target company as of the valuation date, used to bridge from enterprise value to equity value. A negative net debt (net cash) position increases equity value relative to enterprise value.' ;
    rdfs:domain ind:InvestmentValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:opinionConclusion rdf:type rdf:Property ;
    rdfs:label 'Opinion Conclusion' ;
    rdfs:comment 'The formal conclusion of the fairness or solvency opinion as rendered by the investment bank. Applicable when is_fairness_opinion is True. The conclusion is disclosed in the proxy statement or offering document and is subject to SEC and FINRA scrutiny.' ;
    rdfs:domain ind:InvestmentValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opinionType rdf:type rdf:Property ;
    rdfs:label 'Opinion Type' ;
    rdfs:comment 'Classification of the formal opinion rendered, applicable when is_fairness_opinion is True. Fairness opinions address whether consideration is fair from a financial point of view; solvency opinions address the target\'s ability to meet obligations post-transaction; valuation opinions provide a point estimate of value; adequacy opinions address whether consideration is adequate.' ;
    rdfs:domain ind:InvestmentValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:peMultipleHigh rdf:type rdf:Property ;
    rdfs:label 'Pe Multiple High' ;
    rdfs:comment 'Upper bound of the implied Price-to-Earnings (P/E) multiple derived from the equity value range. Together with the low multiple, defines the P/E range used in fairness opinion analyses and investment committee presentations.' ;
    rdfs:domain ind:InvestmentValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:peMultipleLow rdf:type rdf:Property ;
    rdfs:label 'Pe Multiple Low' ;
    rdfs:comment 'Lower bound of the implied Price-to-Earnings (P/E) multiple derived from the equity value range divided by the target company\'s net income. Used as a cross-check valuation metric, particularly relevant for IPO pricing and public M&A transactions.' ;
    rdfs:domain ind:InvestmentValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:referenceNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Number' ;
    rdfs:comment 'Externally-known alphanumeric reference number assigned to the valuation engagement, used in client deliverables, pitch books, and regulatory filings. Follows the format VAL-YYYY-NNNNNN.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sharesOutstanding rdf:type rdf:Property ;
    rdfs:label 'Shares Outstanding' ;
    rdfs:comment 'Fully diluted shares outstanding of the target company as of the valuation date, including common shares, in-the-money options, warrants, and convertible securities on a treasury stock method basis. Used to derive implied per-share equity value.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminalGrowthRate rdf:type rdf:Property ;
    rdfs:label 'Terminal Growth Rate' ;
    rdfs:comment 'Perpetuity growth rate applied in the DCF terminal value calculation, expressed as a decimal (e.g., 0.025 for 2.5%). Represents the assumed long-term sustainable growth rate of the target company\'s free cash flows beyond the explicit forecast period.' ;
    rdfs:domain ind:InvestmentValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valuationDate rdf:type rdf:Property ;
    rdfs:label 'Valuation Date' ;
    rdfs:comment 'The as-of date on which the valuation analysis is anchored. All market data, financial projections, and comparable benchmarks are referenced as of this date. Critical for fairness opinion compliance and deal pricing.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:valuationStatus rdf:type rdf:Property ;
    rdfs:label 'Valuation Status' ;
    rdfs:comment 'Current lifecycle state of the valuation record, tracking progression from initial draft through internal review, committee approval, client delivery, and potential supersession or withdrawal. [ENUM-REF-CANDIDATE: draft|in_review|approved|delivered|superseded|withdrawn — promote to reference product if additional states are required]' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionNumber rdf:type rdf:Property ;
    rdfs:label 'Version Number' ;
    rdfs:comment 'Sequential version number of the valuation model, incremented each time the analysis is materially revised (e.g., updated financial projections, revised WACC, new comparable set). Enables version control and audit trail for deal pricing decisions.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wacc rdf:type rdf:Property ;
    rdfs:label 'Wacc' ;
    rdfs:comment 'Weighted Average Cost of Capital expressed as a decimal (e.g., 0.085 for 8.5%) used as the discount rate in DCF valuation. Reflects the blended cost of equity and debt financing, adjusted for the target company\'s capital structure and risk profile.' ;
    rdfs:domain ind:InvestmentValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feeArrangementId rdf:type rdf:Property ;
    rdfs:label 'Fee Arrangement Id' ;
    rdfs:comment 'Unique surrogate identifier for the fee arrangement record in the investment banking mandate fee management system. Primary key for this entity.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FeeArrangement .

ind:cashFlowForecastId rdf:type rdf:Property ;
    rdfs:label 'Cash Flow Forecast Id' ;
    rdfs:comment 'Foreign key linking to treasury.cash_flow_forecast. Business justification: Investment banking fee receivables (retainers, success fees) are material inflows included in treasury cash flow forecasts for liquidity management and LCR reporting. Treasury incorporates expected fe' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CashFlowForecast .

ind:clientMandateId rdf:type rdf:Property ;
    rdfs:label 'Client Mandate Id' ;
    rdfs:comment 'Foreign key linking to wealth.client_mandate. Business justification: Cross-domain fee disclosure and bundled billing: IB advisory fee arrangements for UHNW clients are governed by and disclosed under the wealth client mandate per MiFID II Article 24 and SEC Regulation ' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClientMandate .

ind:feeScheduleId rdf:type rdf:Property ;
    rdfs:label 'Fee Schedule Id' ;
    rdfs:comment 'Foreign key linking to wealth.wealth_fee_schedule. Business justification: Bundled fee pricing and IB-to-wealth fee offset: for UHNW private banking clients, IB advisory fees are offset against or coordinated with wealth management fee schedules. Revenue recognition, fee wai' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FeeSchedule .

ind:glAccountId rdf:type rdf:Property ;
    rdfs:label 'Gl Account Id' ;
    rdfs:comment 'Foreign key linking to ledger.gl_account. Business justification: Investment banking fees are posted to specific GL accounts for revenue recognition. Replaces denormalized gl_account_code with proper FK to enable drill-down from financial statements to deal-level fe' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:approvalDate rdf:type rdf:Property ;
    rdfs:label 'Approval Date' ;
    rdfs:comment 'The date on which the fee arrangement received final internal approval. Part of the SOX-compliant audit trail for revenue recognition and mandate governance.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvalStatus rdf:type rdf:Property ;
    rdfs:label 'Approval Status' ;
    rdfs:comment 'Internal approval workflow status for the fee arrangement, reflecting sign-off by IB management, finance, and legal prior to client engagement. Required for SOX compliance and revenue recognition.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arrangementNumber rdf:type rdf:Property ;
    rdfs:label 'Arrangement Number' ;
    rdfs:comment 'Externally-known unique alphanumeric reference code for the fee arrangement, used in client-facing engagement letters, mandate agreements, and finance reconciliation. Format: FA-{LOB}-{YEAR}-{SEQUENCE}.' ;
    rdfs:domain ind:FeeArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arrangementStatus rdf:type rdf:Property ;
    rdfs:label 'Arrangement Status' ;
    rdfs:comment 'Current lifecycle state of the fee arrangement. Draft: under negotiation; Active: binding and in effect; Suspended: temporarily paused; Terminated: cancelled before completion; Completed: all fees settled; Expired: lapsed without completion.' ;
    rdfs:domain ind:FeeArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankFeeSharePct rdf:type rdf:Property ;
    rdfs:label 'Bank Fee Share Pct' ;
    rdfs:comment 'The percentage of the total fee retained by this bank after co-advisor fee sharing. Equals 100% minus co_advisor_fee_sharing_pct for simple two-party splits, or the bank\'s specific allocation in multi-party syndicates.' ;
    rdfs:domain ind:FeeArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:breakFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Break Fee Amount' ;
    rdfs:comment 'The contractual fee payable to the bank if the deal is terminated by the client before completion. Compensates the bank for work performed and opportunity cost.' ;
    rdfs:domain ind:FeeArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coAdvisorFeeSharingPct rdf:type rdf:Property ;
    rdfs:label 'Co Advisor Fee Sharing Pct' ;
    rdfs:comment 'The percentage of the total fee to be shared with co-advisors or syndicate members on the mandate. Used for fee split calculations and revenue attribution in multi-bank advisory or underwriting syndicates.' ;
    rdfs:domain ind:FeeArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dealValueBasis rdf:type rdf:Property ;
    rdfs:label 'Deal Value Basis' ;
    rdfs:comment 'The transaction or deal value (e.g., enterprise value, equity value, issuance proceeds) used as the basis for computing percentage-based fees. Critical for success fee and underwriting spread calculations.' ;
    rdfs:domain ind:FeeArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeDescription rdf:type rdf:Property ;
    rdfs:label 'Dispute Description' ;
    rdfs:comment 'Description of the fee dispute raised by the client, including the disputed amount and grounds for dispute. Populated when payment_status is \'disputed\'. Used for legal and collections management.' ;
    rdfs:domain ind:FeeArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementLetterRef rdf:type rdf:Property ;
    rdfs:label 'Engagement Letter Ref' ;
    rdfs:comment 'The document reference number of the signed engagement letter or mandate agreement that governs this fee arrangement. Used for legal and compliance audit trail.' ;
    rdfs:domain ind:FeeArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeAmount rdf:type rdf:Property ;
    rdfs:label 'Fee Amount' ;
    rdfs:comment 'The gross base fee amount in the arrangement currency. For fixed-basis arrangements, this is the total contractual fee. For percentage-basis arrangements, this is the computed fee amount once the deal value is known. Used for P&L attribution and revenue recognition.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feeBasis rdf:type rdf:Property ;
    rdfs:label 'Fee Basis' ;
    rdfs:comment 'The computational basis on which the fee is calculated. Fixed: flat dollar amount; Percentage: applied to transaction value or deal size; Tiered: percentage varies by deal size bracket; Blended: combination of fixed and percentage; Minimum Plus Percentage: floor amount plus variable component.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeType rdf:type rdf:Property ;
    rdfs:label 'Fee Type' ;
    rdfs:comment 'Classification of the fee by its commercial nature within the investment banking mandate. Retainer: periodic engagement fee; Success Fee: contingent on deal close; Underwriting Spread: difference between issue price and proceeds; Advisory Fee: M&A or capital markets advisory; Break Fee: payable on deal termination; Tail Fee: post-termination success fee within tail period.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeWaiverReason rdf:type rdf:Property ;
    rdfs:label 'Fee Waiver Reason' ;
    rdfs:comment 'Free-text description of the business reason for waiving or reducing the contractual fee, required for management approval and audit trail when payment_status is \'waived\'. Null when no waiver applies.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Invoice Number' ;
    rdfs:comment 'The accounts receivable invoice number issued to the client for fees due under this arrangement. Links to the AR module in the General Ledger system (Oracle Financials / SAP S4HANA) for payment tracking.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoicedAmount rdf:type rdf:Property ;
    rdfs:label 'Invoiced Amount' ;
    rdfs:comment 'The total fee amount invoiced to the client under this arrangement. May differ from fee_amount due to adjustments, credits, or partial invoicing.' ;
    rdfs:domain ind:FeeArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentDueDate rdf:type rdf:Property ;
    rdfs:label 'Payment Due Date' ;
    rdfs:comment 'The contractual date by which the client must remit payment for the invoiced fee. Used for AR aging, collections management, and overdue fee tracking.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Payment Received Date' ;
    rdfs:comment 'The date on which the fee payment was actually received from the client. Used for cash reconciliation, days-sales-outstanding (DSO) calculation, and revenue recognition confirmation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Status' ;
    rdfs:comment 'Current payment collection status for the fee arrangement. Pending: invoice issued, payment not yet due; Partially Paid: partial receipt; Paid: fully settled; Overdue: past due date; Waived: fee forgiven; Disputed: client has raised a dispute.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivedAmount rdf:type rdf:Property ;
    rdfs:label 'Received Amount' ;
    rdfs:comment 'The total fee amount actually received from the client as of the most recent payment event. Used for cash reconciliation, outstanding receivables tracking, and revenue recognition confirmation.' ;
    rdfs:domain ind:FeeArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reconciliationReference rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Reference' ;
    rdfs:comment 'The payment or wire transfer reference number used to match the received fee payment to the invoice in the GL/AR system. Supports finance reconciliation and audit trail requirements.' ;
    rdfs:domain ind:FeeArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retainerAmount rdf:type rdf:Property ;
    rdfs:label 'Retainer Amount' ;
    rdfs:comment 'The periodic retainer fee amount payable by the client during the engagement period, typically monthly or quarterly. May be credited against the success fee upon deal close.' ;
    rdfs:domain ind:FeeArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retainerCreditable rdf:type rdf:Property ;
    rdfs:label 'Retainer Creditable' ;
    rdfs:comment 'Indicates whether retainer payments made during the engagement are creditable (offset) against the success fee upon deal completion. True = retainer amounts reduce the success fee payable.' ;
    rdfs:domain ind:FeeArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retainerFrequency rdf:type rdf:Property ;
    rdfs:label 'Retainer Frequency' ;
    rdfs:comment 'The frequency at which retainer fee payments are due from the client during the engagement period.' ;
    rdfs:domain ind:FeeArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRecognitionDate rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Date' ;
    rdfs:comment 'The date on which the fee revenue is recognized in the General Ledger per the applicable revenue recognition method (IFRS 15 / ASC 606). Critical for period-end financial close and P&L attribution.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revenueRecognitionMethod rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Method' ;
    rdfs:comment 'The accounting method applied to recognize revenue from this fee arrangement per IFRS 15 / ASC 606. Point in Time: recognized at deal close; Over Time: recognized ratably over engagement period; Milestone Based: recognized upon achievement of defined milestones; Contingent: deferred until contingency resolved.' ;
    rdfs:domain ind:FeeArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:syndicationId rdf:type rdf:Property ;
    rdfs:label 'Syndication Id' ;
    rdfs:comment 'Unique surrogate identifier for the syndicated lending or capital markets syndication record. Primary key for the syndication master entity.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Syndication .

ind:fundingPlanId rdf:type rdf:Property ;
    rdfs:label 'Funding Plan Id' ;
    rdfs:comment 'Foreign key linking to treasury.funding_plan. Business justification: Large syndications require dedicated funding plans to ensure the bank can honor underwriting commitments. Business process: treasury funding planning coordinates with capital markets to pre-arrange fu' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FundingPlan .

ind:marketingChannelId rdf:type rdf:Property ;
    rdfs:label 'Marketing Channel Id' ;
    rdfs:comment 'Foreign key linking to channel.channel. Business justification: Loan syndications are marketed through specific channels - institutional sales desks, digital loan platforms (LoanIQ, SyndTrak), RM networks. Syndicate desks track marketing channel for lender reach a' ;
    rdfs:domain ind:Syndication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:productTypeId rdf:type rdf:Property ;
    rdfs:label 'Product Type Id' ;
    rdfs:comment 'Foreign key linking to reference.product_type. Business justification: Syndicated facility type classification drives RWA calculation approach, CECL portfolio segmentation, regulatory reporting category, and leveraged loan designation. Banking credit risk and regulatory ' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductType .

ind:roadshowBranchId rdf:type rdf:Property ;
    rdfs:label 'Roadshow Branch Id' ;
    rdfs:comment 'Foreign key linking to channel.branch. Business justification: Syndication roadshows are physically hosted at specific branch offices. Branch-level roadshow tracking drives branch revenue credit, investor meeting logistics, and league table attribution. Investmen' ;
    rdfs:domain ind:Syndication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Branch .

ind:actualSelldownAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Selldown Amount' ;
    rdfs:comment 'The amount actually distributed to third-party lenders at close of syndication. May differ from target_selldown_amount due to market conditions, pricing flex, or investor demand shortfall.' ;
    rdfs:domain ind:Syndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:arrangementFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Arrangement Fee Amount' ;
    rdfs:comment 'The total arrangement fee earned by the bank for structuring and executing the syndication, expressed in deal currency. Recognized as fee income upon close per IFRS 15 / FASB ASC 606.' ;
    rdfs:domain ind:Syndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assetClass rdf:type rdf:Property ;
    rdfs:label 'Asset Class' ;
    rdfs:comment 'Broad asset class of the syndicated instrument: leveraged_loan, investment_grade, Collateralized Loan Obligation (CLO), Asset-Backed Security (ABS), Mortgage-Backed Security (MBS), or project_finance. Drives regulatory capital treatment and investor eligibility.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankHoldAmount rdf:type rdf:Property ;
    rdfs:label 'Bank Hold Amount' ;
    rdfs:comment 'The portion of the total facility that the arranging bank intends to retain on its own balance sheet after syndication. Reflects the bank\'s final hold position and drives RWA and capital consumption calculations.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bookrunnerRole rdf:type rdf:Property ;
    rdfs:label 'Bookrunner Role' ;
    rdfs:comment 'The bank\'s role in the syndication as bookrunner or arranger: sole_bookrunner, joint_bookrunner, co_bookrunner, mandated_lead_arranger (MLA), or lead_arranger. Determines fee entitlement and decision-making authority in the syndicate.' ;
    rdfs:domain ind:Syndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closeDate rdf:type rdf:Property ;
    rdfs:label 'Close Date' ;
    rdfs:comment 'The date on which the syndication was formally closed and the credit agreement was executed with the final lender group. Corresponds to the effective date of the facility.' ;
    rdfs:domain ind:Syndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coArrangerList rdf:type rdf:Property ;
    rdfs:label 'Co Arranger List' ;
    rdfs:comment 'Comma-separated list of co-arranger bank names or BIC codes participating in the syndication alongside the bookrunner. Captures the arranger group composition for tombstone records, fee sharing, and regulatory reporting.' ;
    rdfs:domain ind:Syndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentDeadline rdf:type rdf:Property ;
    rdfs:label 'Commitment Deadline' ;
    rdfs:comment 'The deadline by which prospective lenders must submit their commitments during the bookbuilding phase. Drives the syndication desk\'s investor outreach timeline.' ;
    rdfs:domain ind:Syndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditRatingMoodys rdf:type rdf:Property ;
    rdfs:label 'Credit Rating Moodys' ;
    rdfs:comment 'The Moody\'s Investors Service credit rating assigned to the syndicated facility or borrower at the time of syndication (e.g., Ba1, B2, Caa1). Used alongside S&P rating for dual-rating requirements in leveraged loan markets.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditRatingSp rdf:type rdf:Property ;
    rdfs:label 'Credit Rating Sp' ;
    rdfs:comment 'The Standard & Poor\'s credit rating assigned to the syndicated facility or the borrower at the time of syndication (e.g., BB+, B, CCC). Drives investor eligibility, pricing, and regulatory capital treatment.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentationStandard rdf:type rdf:Property ;
    rdfs:label 'Documentation Standard' ;
    rdfs:comment 'The market documentation standard used for the syndicated loan agreement: LMA (Loan Market Association — EMEA), LSTA (Loan Syndication and Trading Association — US), APLMA (Asia Pacific), or bespoke. Governs transferability, voting thresholds, and secondary market conventions.' ;
    rdfs:domain ind:Syndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esgFlag rdf:type rdf:Property ;
    rdfs:label 'Esg Flag' ;
    rdfs:comment 'Indicates whether the syndicated facility is structured as an ESG-linked loan or sustainability-linked loan (SLL), where pricing is tied to the borrower\'s ESG performance targets. Supports green finance reporting and investor ESG mandates.' ;
    rdfs:domain ind:Syndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:flexAmountBps rdf:type rdf:Property ;
    rdfs:label 'Flex Amount Bps' ;
    rdfs:comment 'The magnitude of the pricing flex applied, expressed in basis points. Positive value indicates widening; negative value indicates tightening. Captures the delta between initial price talk and final pricing.' ;
    rdfs:domain ind:Syndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:launchDate rdf:type rdf:Property ;
    rdfs:label 'Launch Date' ;
    rdfs:comment 'The date on which the syndication was formally launched to the market, i.e., when the information memorandum and term sheet were distributed to prospective lenders.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leagueTableCredit rdf:type rdf:Property ;
    rdfs:label 'League Table Credit' ;
    rdfs:comment 'Determines how this syndication is credited in investment banking league tables: full_credit (sole bookrunner), pro_rata (shared among joint bookrunners), or no_credit (co-arranger only). Drives competitive ranking and business development reporting.' ;
    rdfs:domain ind:Investment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lenderCount rdf:type rdf:Property ;
    rdfs:label 'Lender Count' ;
    rdfs:comment 'The total number of lenders in the final syndicate at close. Indicates syndication breadth and diversification of the lender group; used in post-deal analytics and tombstone records.' ;
    rdfs:domain ind:Syndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:leveragedLoanFlag rdf:type rdf:Property ;
    rdfs:label 'Leveraged Loan Flag' ;
    rdfs:comment 'Indicates whether the syndicated facility meets the OCC/Fed/FDIC definition of a leveraged loan (typically total debt/EBITDA > 4x or borrower rated below investment grade). Triggers enhanced regulatory scrutiny and reporting under interagency leveraged lending guidance.' ;
    rdfs:domain ind:Syndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:oidBps rdf:type rdf:Property ;
    rdfs:label 'Oid Bps' ;
    rdfs:comment 'The original issue discount expressed in basis points, representing the upfront discount to par at which the loan is issued to lenders. Common in leveraged loan syndications; impacts lender yield and borrower all-in cost.' ;
    rdfs:domain ind:Syndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oversubscriptionAmount rdf:type rdf:Property ;
    rdfs:label 'Oversubscription Amount' ;
    rdfs:comment 'The amount by which investor commitments exceeded the target syndication amount during bookbuilding. A positive value indicates strong market demand; used for pricing flex decisions and greenshoe allocation.' ;
    rdfs:domain ind:Syndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricingFlexType rdf:type rdf:Property ;
    rdfs:label 'Pricing Flex Type' ;
    rdfs:comment 'Indicates the direction of pricing flex applied during bookbuilding: tightened (spread reduced due to oversubscription), held (no change), flexed_wider (spread increased due to weak demand), oid_added, oid_increased, or structure_changed. Key indicator of market reception.' ;
    rdfs:domain ind:Syndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purposeCode rdf:type rdf:Property ;
    rdfs:label 'Purpose Code' ;
    rdfs:comment 'The stated purpose of the syndicated facility: acquisition_finance, leveraged_buyout (LBO), refinancing, general_corporate, capital_expenditure (capex), or working_capital. Used for regulatory classification, OCC leveraged lending identification, and portfolio analytics.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spreadBps rdf:type rdf:Property ;
    rdfs:label 'Spread Bps' ;
    rdfs:comment 'The credit spread over the reference rate expressed in basis points (BPS) at which the syndicated facility is priced. Core pricing parameter for lender economics and secondary market trading.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:syndicationStatus rdf:type rdf:Property ;
    rdfs:label 'Syndication Status' ;
    rdfs:comment 'Current lifecycle state of the syndication process: mandate_awarded (bank selected as arranger), launched (syndication formally opened to market), bookbuilding (collecting lender commitments), priced (spread and terms finalized), closed (facility fully allocated), withdrawn (deal pulled from market), failed (insufficient demand). [ENUM-REF-CANDIDATE: mandate_awarded|launched|bookbuilding|priced|closed|withdrawn|failed|post_close — promote to reference product]' ;
    rdfs:domain ind:Syndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:syndicationType rdf:type rdf:Property ;
    rdfs:label 'Syndication Type' ;
    rdfs:comment 'Classification of the syndication structure: primary_syndication (initial distribution to lender group), secondary_sell_down (post-close transfer of hold), club_deal (small bilateral group), best_efforts (no underwriting commitment), underwritten (bank commits full amount). [ENUM-REF-CANDIDATE: primary_syndication|secondary_sell_down|club_deal|best_efforts|underwritten|participation — promote to reference product]' ;
    rdfs:domain ind:Syndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetSelldownAmount rdf:type rdf:Property ;
    rdfs:label 'Target Selldown Amount' ;
    rdfs:comment 'The target amount the bank aims to distribute to third-party lenders through the syndication process. Equals total_facility_amount minus bank_hold_amount at deal inception; may be revised during bookbuilding.' ;
    rdfs:domain ind:Syndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tenorMonths rdf:type rdf:Property ;
    rdfs:label 'Tenor Months' ;
    rdfs:comment 'The contractual tenor of the syndicated facility expressed in months from the close date to final maturity. Key parameter for duration risk, regulatory capital, and investor suitability assessment.' ;
    rdfs:domain ind:Syndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalFacilityAmount rdf:type rdf:Property ;
    rdfs:label 'Total Facility Amount' ;
    rdfs:comment 'Gross size of the syndicated credit facility or capital markets transaction in the deal currency. Represents the full commitment amount before any sell-down or hold reduction.' ;
    rdfs:domain ind:Syndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:upfrontFeeBps rdf:type rdf:Property ;
    rdfs:label 'Upfront Fee Bps' ;
    rdfs:comment 'The upfront participation fee paid to lenders expressed in basis points of their commitment. Incentivizes early commitment during bookbuilding and is a key component of lender all-in yield.' ;
    rdfs:domain ind:Syndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:underwritingId rdf:type rdf:Property ;
    rdfs:label 'Underwriting Id' ;
    rdfs:comment 'Primary key for underwriting' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Underwriting .

ind:anchorInvestorFundId rdf:type rdf:Property ;
    rdfs:label 'Anchor Investor Fund Id' ;
    rdfs:comment 'Foreign key linking to asset.fund. Business justification: Institutional funds are cornerstone investors in underwritten equity and debt offerings, often receiving anchor allocations. Real business process: pre-marketing to anchor investors, allocation manage' ;
    rdfs:domain ind:Underwriting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fund .

ind:bookingBranchId rdf:type rdf:Property ;
    rdfs:label 'Booking Branch Id' ;
    rdfs:comment 'Foreign key linking to channel.branch. Business justification: Underwriting commitments for municipal bonds, regional offerings, or private placements are booked through specific branch locations (regional/community banking underwriting desks). Required for branc' ;
    rdfs:domain ind:Underwriting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Branch .

ind:capitalMarketsOfferingId rdf:type rdf:Property ;
    rdfs:label 'Capital Markets Offering Id' ;
    rdfs:comment 'Foreign key linking to investment.offering. Business justification: Underwriting commitments are made for specific capital markets offerings. While both underwriting and offering reference deal_id, one deal can have multiple offerings (e.g., primary offering + greensh' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Offering .

ind:commitmentJournalEntryId rdf:type rdf:Property ;
    rdfs:label 'Commitment Journal Entry Id' ;
    rdfs:comment 'Foreign key linking to ledger.journal_entry. Business justification: Underwriting commitments generate journal entries for RWA recognition, fee accruals, and settlement accounting. Linking to the primary journal entry supports audit trail, SOX controls, and reconciliat' ;
    rdfs:domain ind:Underwriting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntry .

ind:obligationId rdf:type rdf:Property ;
    rdfs:label 'Obligation Id' ;
    rdfs:comment 'Foreign key linking to compliance.obligation. Business justification: Underwriting is governed by specific regulatory obligations (Securities Act Section 11 liability, FINRA Rule 5110, Basel III capital requirements for underwriting risk). FK to obligation enables compl' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Obligation .

ind:regulatoryJurisdictionId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Jurisdiction Id' ;
    rdfs:comment 'Foreign key linking to reference.jurisdiction. Business justification: Regulatory jurisdiction determines prospectus requirements (SEC S-1, EU Prospectus Regulation), underwriting agreement enforceability, and securities law compliance framework.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Jurisdiction .

ind:agreementDate rdf:type rdf:Property ;
    rdfs:label 'Agreement Date' ;
    rdfs:comment 'The date on which the formal underwriting agreement between the bank (and co-underwriters) and the issuer was executed. This is the legally binding contract governing the terms of the underwriting commitment.' ;
    rdfs:domain ind:Underwriting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bankAllocationPct rdf:type rdf:Property ;
    rdfs:label 'Bank Allocation Pct' ;
    rdfs:comment 'The percentage of the total offering size allocated to this bank as its underwriting commitment share within the syndicate. Determines the bank\'s proportional fee entitlement and risk exposure.' ;
    rdfs:domain ind:Underwriting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bookRunnerFlag rdf:type rdf:Property ;
    rdfs:label 'Book Runner Flag' ;
    rdfs:comment 'Indicates whether the bank is acting as a bookrunner (lead or joint) for this offering, responsible for managing the order book during the book-building process. True if the bank has bookrunner responsibilities; False for co-manager or selling group roles.' ;
    rdfs:domain ind:Underwriting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commitmentDate rdf:type rdf:Property ;
    rdfs:label 'Commitment Date' ;
    rdfs:comment 'The date on which the bank formally committed to underwrite the offering, typically coinciding with the signing of the mandate letter or underwriting agreement. Marks the start of the bank\'s underwriting risk exposure period.' ;
    rdfs:domain ind:Underwriting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:commitmentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Commitment Reference Number' ;
    rdfs:comment 'Externally-known alphanumeric reference number assigned to this underwriting commitment, used in mandate letters, syndicate agreements, and regulatory filings. Format: LOB-UW-YYYY-NNNNNN.' ;
    rdfs:domain ind:Underwriting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentStatus rdf:type rdf:Property ;
    rdfs:label 'Commitment Status' ;
    rdfs:comment 'Current lifecycle state of the underwriting commitment. Mandated: bank has received the mandate; Active: commitment is live during the offering period; Priced: pricing has been set; Closed: transaction has settled; Withdrawn: issuer withdrew the offering; Terminated: commitment cancelled prior to pricing.' ;
    rdfs:domain ind:Underwriting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentType rdf:type rdf:Property ;
    rdfs:label 'Commitment Type' ;
    rdfs:comment 'Classification of the underwriting commitment structure. Firm commitment means the bank purchases all securities and resells them; best efforts means the bank sells as much as possible without guaranteeing the full amount; standby is used in rights offerings; all-or-none requires full subscription or cancellation; mini-max sets a minimum threshold.' ;
    rdfs:domain ind:Underwriting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedFeeRevenue rdf:type rdf:Property ;
    rdfs:label 'Expected Fee Revenue' ;
    rdfs:comment 'The bank\'s expected gross fee revenue from this underwriting commitment, calculated as the bank\'s allocated underwriting spread applied to its committed underwriting amount. Used for revenue forecasting, deal profitability analysis, and RAROC (Risk-Adjusted Return on Capital) calculations.' ;
    rdfs:domain ind:Underwriting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feeBps rdf:type rdf:Property ;
    rdfs:label 'Fee Bps' ;
    rdfs:comment 'The portion of the underwriting spread allocated as the underwriting fee, expressed in basis points. Compensates syndicate members for bearing the underwriting risk during the offering period.' ;
    rdfs:domain ind:Underwriting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:greenshoeOptionAmount rdf:type rdf:Property ;
    rdfs:label 'Greenshoe Option Amount' ;
    rdfs:comment 'The maximum additional amount (in base currency) that the underwriters may purchase from the issuer under the over-allotment (greenshoe) option, typically up to 15% of the base offering size. Exercised to stabilize the aftermarket price. Named after the Green Shoe Manufacturing Company, the first company to use this mechanism.' ;
    rdfs:domain ind:Underwriting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:greenshoeOptionFlag rdf:type rdf:Property ;
    rdfs:label 'Greenshoe Option Flag' ;
    rdfs:comment 'Indicates whether an over-allotment (greenshoe) option has been granted to the underwriters in this transaction. True if a greenshoe option exists; False if no over-allotment option is included.' ;
    rdfs:domain ind:Underwriting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leagueTableEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'League Table Eligible Flag' ;
    rdfs:comment 'Indicates whether this transaction qualifies for inclusion in investment banking league table rankings (e.g., Bloomberg, Dealogic, Thomson Reuters). Transactions may be excluded due to size thresholds, role limitations, or issuer type restrictions.' ;
    rdfs:domain ind:Underwriting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lockUpPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Lock Up Period Days' ;
    rdfs:comment 'The number of days following the offering during which existing shareholders and insiders are contractually prohibited from selling their shares. Typically 90 or 180 days for IPOs. Relevant for aftermarket risk management and secondary trading restrictions.' ;
    rdfs:domain ind:Investment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:managementFeeBps rdf:type rdf:Property ;
    rdfs:label 'Management Fee Bps' ;
    rdfs:comment 'The portion of the underwriting spread allocated as the management fee, expressed in basis points. Compensates the lead manager(s) for structuring, due diligence, and transaction management responsibilities.' ;
    rdfs:domain ind:Underwriting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mandateLetterDate rdf:type rdf:Property ;
    rdfs:label 'Mandate Letter Date' ;
    rdfs:comment 'The date on which the issuer formally awarded the underwriting mandate to the bank via a signed mandate letter. Precedes the commitment date and marks the formal engagement of the bank as underwriter.' ;
    rdfs:domain ind:Underwriting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:offeringPrice rdf:type rdf:Property ;
    rdfs:label 'Offering Price' ;
    rdfs:comment 'The final public offering price per unit (share or bond face value) at which securities are sold to investors. For equity, expressed as price per share; for debt, expressed as a percentage of par value. Determined at pricing date.' ;
    rdfs:domain ind:Underwriting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:offeringSize rdf:type rdf:Property ;
    rdfs:label 'Offering Size' ;
    rdfs:comment 'The total gross proceeds of the offering at the offering price, representing the full transaction size including any greenshoe option if exercised. Distinct from underwritten_amount which reflects only the bank\'s committed portion.' ;
    rdfs:domain ind:Underwriting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prospectusType rdf:type rdf:Property ;
    rdfs:label 'Prospectus Type' ;
    rdfs:comment 'The type of SEC registration statement or offering document filed for this transaction. S-1 is the standard IPO registration; S-3 is for seasoned issuers; F-1 is for foreign private issuers; 424B is the final prospectus; offering memorandum is used for 144A/Reg S private placements. [ENUM-REF-CANDIDATE: s1|f1|s3|s11|424b|offering_memorandum|prospectus_supplement|base_prospectus — promote to reference product]' ;
    rdfs:domain ind:Underwriting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roadshowStartDate rdf:type rdf:Property ;
    rdfs:label 'Roadshow Start Date' ;
    rdfs:comment 'The date on which the investor roadshow commenced for this offering. The roadshow is the marketing period during which management presents to institutional investors prior to pricing.' ;
    rdfs:domain ind:Investment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rwaAmount rdf:type rdf:Property ;
    rdfs:label 'Rwa Amount' ;
    rdfs:comment 'The Risk-Weighted Assets (RWA) amount attributable to this underwriting commitment, calculated per Basel III standardized or internal ratings-based (IRB) approach. Drives capital charge allocation and CET1 (Common Equity Tier 1) consumption reporting.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:secFileNumber rdf:type rdf:Property ;
    rdfs:label 'Sec File Number' ;
    rdfs:comment 'The Securities and Exchange Commission (SEC) file number assigned to the registration statement for this offering (e.g., 333-XXXXXX for Securities Act registrations). Used for regulatory tracking and EDGAR cross-referencing.' ;
    rdfs:domain ind:Underwriting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sellingConcessionBps rdf:type rdf:Property ;
    rdfs:label 'Selling Concession Bps' ;
    rdfs:comment 'The portion of the underwriting spread allocated as the selling concession, expressed in basis points. Paid to dealers and selling group members for distributing securities to end investors.' ;
    rdfs:domain ind:Underwriting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementDate rdf:type rdf:Property ;
    rdfs:label 'Settlement Date' ;
    rdfs:comment 'The date on which the securities are delivered to investors and proceeds are remitted to the issuer. Typically T+1 for US equity offerings and T+2 or T+3 for debt. Marks the completion of the underwriting commitment.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceSystemCode rdf:type rdf:Property ;
    rdfs:label 'Source System Code' ;
    rdfs:comment 'Code identifying the operational system of record from which this underwriting commitment record originated (e.g., MUREX or CALYPSO for trading/deal capture, DEALOGIC for deal tracking, LOAN_IQ for syndicated lending mandates). Required for data lineage and ETL reconciliation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemRecordCode rdf:type rdf:Property ;
    rdfs:label 'Source System Record Code' ;
    rdfs:comment 'The native primary key or record identifier of this underwriting commitment in the originating operational system of record (e.g., Murex deal ID, Calypso transaction ID, Dealogic deal reference). Enables bi-directional traceability between the lakehouse silver layer and the source system.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stabilizationFlag rdf:type rdf:Property ;
    rdfs:label 'Stabilization Flag' ;
    rdfs:comment 'Indicates whether the bank is acting as stabilizing manager for this offering, authorized to conduct price stabilization transactions in the aftermarket to support the offering price. True if the bank has stabilization responsibilities.' ;
    rdfs:domain ind:Investment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:syndicateRole rdf:type rdf:Property ;
    rdfs:label 'Syndicate Role' ;
    rdfs:comment 'The bank\'s role within the underwriting syndicate. Lead bookrunner has primary responsibility for book building and allocation; joint bookrunner shares that responsibility; co-manager has a smaller participation; selling group members distribute but do not underwrite. Determines fee economics and regulatory obligations.' ;
    rdfs:domain ind:Underwriting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tombstoneFlag rdf:type rdf:Property ;
    rdfs:label 'Tombstone Flag' ;
    rdfs:comment 'Indicates whether a tombstone advertisement has been published for this completed transaction. Tombstones are formal announcements of completed capital markets transactions and serve as marketing credentials for the bank\'s league table rankings.' ;
    rdfs:domain ind:Underwriting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:underwrittenAmount rdf:type rdf:Property ;
    rdfs:label 'Underwritten Amount' ;
    rdfs:comment 'The gross principal amount (in base currency) that the bank has committed to underwrite for this transaction. For firm commitment deals, this represents the bank\'s maximum financial exposure prior to distribution. Key input for RWA (Risk-Weighted Assets) and capital charge calculations under Basel III.' ;
    rdfs:domain ind:Underwriting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:investorOrderId rdf:type rdf:Property ;
    rdfs:label 'Investor Order Id' ;
    rdfs:comment 'Unique surrogate identifier for each investor order record in the bookbuilding order book. Primary key for the investor_order data product.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InvestorOrder .

ind:branchId rdf:type rdf:Property ;
    rdfs:label 'Branch Id' ;
    rdfs:comment 'Foreign key linking to channel.branch. Business justification: Investor orders in capital markets offerings placed through branch locations (retail IPO participation, regional institutional desks) require branch tracking for regulatory reporting (SEC Rule 15c2-8,' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Branch .

ind:coverageAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Coverage Assignment Id' ;
    rdfs:comment 'Reference to the sales professional or relationship manager who solicited or managed this investor order on behalf of the bookrunner. Used for sales credit attribution, commission calculation, and investor relationship tracking.' ;
    rdfs:domain ind:Investment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CoverageAssignment .

ind:digitalChannelId rdf:type rdf:Property ;
    rdfs:label 'Digital Channel Id' ;
    rdfs:comment 'Foreign key linking to channel.digital_channel. Business justification: MiFID II and SEC best-execution rules require recording the specific digital channel (electronic order book, client portal, API) through which an investor order was placed. The existing branch_id cove' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DigitalChannel .

ind:fundClassId rdf:type rdf:Property ;
    rdfs:label 'Fund Class Id' ;
    rdfs:comment 'Foreign key linking to asset.fund_class. Business justification: Investor orders in fund share offerings are placed for a specific share class, determining applicable fees, minimum investment thresholds, and investor eligibility. Allocation and settlement processes' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FundClass .

ind:investorFundId rdf:type rdf:Property ;
    rdfs:label 'Investor Fund Id' ;
    rdfs:comment 'Foreign key linking to asset.fund. Business justification: Institutional book-building tracks orders by fund entity for allocation decisions, 13F regulatory reporting, and investor relationship management. party_id covers the legal entity but fund_id is neede' ;
    rdfs:domain ind:InvestorOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fund .

ind:investorGeographyCountryId rdf:type rdf:Property ;
    rdfs:label 'Investor Geography Country Id' ;
    rdfs:comment 'Foreign key linking to reference.country. Business justification: Investor geography required for Reg S/144A eligibility determination, geographic allocation analysis, and cross-border securities offering compliance.' ;
    rdfs:domain ind:InvestorOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:kycReviewId rdf:type rdf:Property ;
    rdfs:label 'Kyc Review Id' ;
    rdfs:comment 'Foreign key linking to compliance.kyc_review. Business justification: Investor orders in capital markets require KYC clearance before allocation. investment_investor_order.kyc_status is a denormalization of kyc_review status. Direct FK enables compliance to confirm whic' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:KycReview .

ind:orderCurrencyId rdf:type rdf:Property ;
    rdfs:label 'Order Currency Id' ;
    rdfs:comment 'Foreign key linking to reference.currency. Business justification: Investor order book management, allocation sizing, and settlement require a proper currency reference for the order denomination. Banking capital markets teams use currency reference for cross-currenc' ;
    rdfs:domain ind:InvestorOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:sanctionsScreeningEventId rdf:type rdf:Property ;
    rdfs:label 'Sanctions Screening Event Id' ;
    rdfs:comment 'Foreign key linking to compliance.sanctions_screening_event. Business justification: Every investor order must be screened against OFAC/sanctions lists before allocation. Mandatory compliance control for capital markets offerings. Screening event records match status, disposition, and' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SanctionsScreeningEvent .

ind:sessionId rdf:type rdf:Property ;
    rdfs:label 'Session Id' ;
    rdfs:comment 'Foreign key linking to channel.session. Business justification: Electronically placed investor orders must be linked to the authenticated session for audit trail, fraud detection, and regulatory compliance (MiFID II order record-keeping). Banking operations requir' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Session .

ind:settlementAccountDepositAccountId rdf:type rdf:Property ;
    rdfs:label 'Settlement Account Deposit Account Id' ;
    rdfs:comment 'Foreign key linking to account.deposit_account. Business justification: Capital markets investor orders settle cash through specific deposit accounts. Settlement operations require validated account linkage for payment processing, reconciliation, and regulatory reporting ' ;
    rdfs:domain ind:InvestorOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DepositAccount .

ind:allocationAmount rdf:type rdf:Property ;
    rdfs:label 'Allocation Amount' ;
    rdfs:comment 'Total monetary value of the allocation received by the investor, calculated as allocation_size multiplied by allocation_price. Represents the investor\'s financial commitment to the transaction. Used for settlement, fee calculation, and regulatory reporting.' ;
    rdfs:domain ind:InvestorOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationPrice rdf:type rdf:Property ;
    rdfs:label 'Allocation Price' ;
    rdfs:comment 'The final deal price per share or per unit at which the investor\'s allocation was confirmed. Typically the IPO offer price or bond issue price. Used for settlement and P&L attribution.' ;
    rdfs:domain ind:InvestorOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationSize rdf:type rdf:Property ;
    rdfs:label 'Allocation Size' ;
    rdfs:comment 'The number of shares or face value amount actually allocated to the investor following the bookrunner\'s allocation decision at deal pricing. Zero if the order was not filled. Compared against order_size to determine fill ratio.' ;
    rdfs:domain ind:InvestorOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Allocation Timestamp' ;
    rdfs:comment 'Date and time at which the allocation decision was communicated to the investor following deal pricing. Marks the transition from bookbuilding to allocation phase. Used for settlement timeline tracking (T+1, T+2).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cancellationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cancellation Timestamp' ;
    rdfs:comment 'Date and time at which the investor cancelled or withdrew the order from the book. Null if the order was not cancelled. Used for demand attrition analysis and bookbuilding audit trail.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:custodianName rdf:type rdf:Property ;
    rdfs:label 'Custodian Name' ;
    rdfs:comment 'Name of the custodian bank or prime broker responsible for holding the allocated securities on behalf of the investor. Used for settlement instruction routing and corporate trust/custody services coordination.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demandMultiple rdf:type rdf:Property ;
    rdfs:label 'Demand Multiple' ;
    rdfs:comment 'Ratio of the investor\'s order size to the investor\'s expected or target allocation, indicating the degree of oversubscription at the individual investor level. Used by the bookrunner to assess investor conviction and calibrate allocation decisions.' ;
    rdfs:domain ind:InvestorOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:greenshoeEligible rdf:type rdf:Property ;
    rdfs:label 'Greenshoe Eligible' ;
    rdfs:comment 'Indicates whether this investor order is eligible to be filled from the overallotment (greenshoe) option, allowing the bookrunner to allocate up to 15% additional shares beyond the base offering size to cover excess demand.' ;
    rdfs:domain ind:InvestorOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:investorName rdf:type rdf:Property ;
    rdfs:label 'Investor Name' ;
    rdfs:comment 'Legal name of the investor or institution placing the order. Used for order book management, allocation decisions, and regulatory reporting. May represent an institutional fund, asset manager, or individual investor.' ;
    rdfs:domain ind:InvestorOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investorTier rdf:type rdf:Property ;
    rdfs:label 'Investor Tier' ;
    rdfs:comment 'Classification of the investor by tier, which influences allocation priority and deal economics. \'anchor\' investors commit pre-IPO with lock-up; \'cornerstone\' investors receive guaranteed allocations; \'institutional\' covers qualified institutional buyers (QIBs); \'retail\' covers individual investors; \'strategic\' covers corporate or government investors with strategic interest.' ;
    rdfs:domain ind:InvestorOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investorType rdf:type rdf:Property ;
    rdfs:label 'Investor Type' ;
    rdfs:comment 'Categorization of the investor by institutional type. Drives regulatory treatment, allocation policy, and suitability assessment. [ENUM-REF-CANDIDATE: asset_manager|hedge_fund|pension_fund|sovereign_wealth|insurance|bank|family_office|retail|corporate|endowment — promote to reference product]' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAnchorInvestor rdf:type rdf:Property ;
    rdfs:label 'Is Anchor Investor' ;
    rdfs:comment 'Indicates whether this investor has been designated as an anchor investor for the transaction, committing to a pre-IPO allocation with a lock-up period. Anchor investors receive guaranteed allocations in exchange for early commitment and price support.' ;
    rdfs:domain ind:InvestorOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCoveredShort rdf:type rdf:Property ;
    rdfs:label 'Is Covered Short' ;
    rdfs:comment 'Indicates whether the investor\'s order includes a covered short sale component, typically associated with the greenshoe/overallotment option exercise. Relevant for stabilization and price support analysis post-IPO.' ;
    rdfs:domain ind:InvestorOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orderAmendmentCount rdf:type rdf:Property ;
    rdfs:label 'Order Amendment Count' ;
    rdfs:comment 'Number of times the investor has amended this order during the bookbuilding period (e.g., size increases, price limit changes). Tracks investor conviction and demand evolution. Used for bookbuilding analytics and investor behavior analysis.' ;
    rdfs:domain ind:InvestorOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:orderChannel rdf:type rdf:Property ;
    rdfs:label 'Order Channel' ;
    rdfs:comment 'The channel through which the investor submitted the order to the bookrunner. \'electronic\' covers order management system portals; \'voice\' covers telephone orders; \'email\' covers written email instructions; \'roadshow\' covers orders placed during investor roadshow meetings; \'bloomberg\' covers Bloomberg order management system submissions.' ;
    rdfs:domain ind:InvestorOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderDate rdf:type rdf:Property ;
    rdfs:label 'Order Date' ;
    rdfs:comment 'Calendar date on which the investor submitted the order during the bookbuilding period. Used for day-level reporting and analysis of demand build-up over the bookbuilding timeline.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:orderNotes rdf:type rdf:Property ;
    rdfs:label 'Order Notes' ;
    rdfs:comment 'Free-text field capturing additional instructions, conditions, or commentary provided by the investor or the sales coverage team regarding this order. May include special allocation requests, investment rationale, or bookrunner observations.' ;
    rdfs:domain ind:InvestorOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderReference rdf:type rdf:Property ;
    rdfs:label 'Order Reference' ;
    rdfs:comment 'Externally-known alphanumeric reference number assigned to this investor order, used for communication between the bookrunner and the investor during the bookbuilding process. Corresponds to the order ticket number in the Trading and Order Management System (e.g., Murex/Calypso).' ;
    rdfs:domain ind:InvestorOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderSize rdf:type rdf:Property ;
    rdfs:label 'Order Size' ;
    rdfs:comment 'The total number of shares (for ECM) or face value amount (for DCM) that the investor has requested in this order. Represents the gross demand submitted by the investor before any allocation decision.' ;
    rdfs:domain ind:InvestorOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderStatus rdf:type rdf:Property ;
    rdfs:label 'Order Status' ;
    rdfs:comment 'Current lifecycle state of the investor order within the bookbuilding process. \'active\' indicates the order is live in the book; \'filled\' indicates full allocation received; \'partially_filled\' indicates partial allocation; \'cancelled\' indicates investor withdrew the order; \'expired\' indicates the order lapsed at book close.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderTimestamp rdf:type rdf:Property ;
    rdfs:label 'Order Timestamp' ;
    rdfs:comment 'The precise date and time (with timezone) at which the investor submitted the order to the bookrunner. This is the principal real-world business event timestamp for the order, critical for time-priority allocation and regulatory audit trail.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:orderType rdf:type rdf:Property ;
    rdfs:label 'Order Type' ;
    rdfs:comment 'Classification of the investor order by pricing instruction: \'strike\' (accept final IPO/deal price), \'limit\' (maximum price the investor will pay), \'step\' (tiered quantity at different price levels), \'capped\' (maximum size cap), \'uncapped\' (no size restriction). Drives bookrunner pricing and allocation logic.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceCurrency rdf:type rdf:Property ;
    rdfs:label 'Price Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code in which the price limit is expressed. May differ from order_currency in cross-border transactions where the security is priced in a different currency than the order denomination.' ;
    rdfs:domain ind:InvestorOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceLimit rdf:type rdf:Property ;
    rdfs:label 'Price Limit' ;
    rdfs:comment 'The maximum price per share or per unit that the investor is willing to pay for a limit order. Null for strike orders where the investor accepts the final deal price. Used by the bookrunner to determine price sensitivity and construct the demand curve.' ;
    rdfs:domain ind:InvestorOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryCategory rdf:type rdf:Property ;
    rdfs:label 'Regulatory Category' ;
    rdfs:comment 'Regulatory classification of the investor order under applicable securities law. \'qib\' = Qualified Institutional Buyer under SEC Rule 144A; \'reg_s\' = offshore investor under SEC Regulation S; \'retail\' = retail investor under applicable prospectus rules; \'employee\' = employee share plan participant; \'directed\' = directed share program recipient.' ;
    rdfs:domain ind:InvestorOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystem rdf:type rdf:Property ;
    rdfs:label 'Source System' ;
    rdfs:comment 'Identifier of the operational system of record from which this investor order was originated or captured. Supports data lineage and ETL audit trail in the Databricks Silver Layer. Typical sources include Murex, Calypso, iPreo (bookbuilding platform), Dealogic, Bloomberg OMS, or manual entry.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stepPrice1 rdf:type rdf:Property ;
    rdfs:label 'Step Price 1' ;
    rdfs:comment 'First price level for a step order, representing the price at which the investor commits to the quantity specified in step_size_1. Applicable only for order_type = \'step\'. Null for non-step orders.' ;
    rdfs:domain ind:InvestorOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stepPrice2 rdf:type rdf:Property ;
    rdfs:label 'Step Price 2' ;
    rdfs:comment 'Second price level for a step order, representing the price at which the investor commits to the quantity specified in step_size_2. Null for non-step orders or step orders with only one tier.' ;
    rdfs:domain ind:InvestorOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stepSize1 rdf:type rdf:Property ;
    rdfs:label 'Step Size 1' ;
    rdfs:comment 'Quantity (shares or face value) the investor will take at step_price_1 in a step order. Represents the first tier of a tiered demand schedule. Null for non-step orders.' ;
    rdfs:domain ind:InvestorOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stepSize2 rdf:type rdf:Property ;
    rdfs:label 'Step Size 2' ;
    rdfs:comment 'Quantity (shares or face value) the investor will take at step_price_2 in a step order. Represents the second tier of a tiered demand schedule. Null for non-step orders.' ;
    rdfs:domain ind:InvestorOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coverageBranchId rdf:type rdf:Property ;
    rdfs:label 'Coverage Branch Id' ;
    rdfs:comment 'Foreign key linking to channel.branch. Business justification: coverage_assignment.coverage_office is a denormalized text field. Normalizing to branch_id enables branch-level revenue attribution, headcount reporting, and regulatory jurisdiction mapping. Banking o' ;
    rdfs:domain ind:CoverageAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Branch .

ind:coverageChannelId rdf:type rdf:Property ;
    rdfs:label 'Coverage Channel Id' ;
    rdfs:comment 'Foreign key linking to channel.channel. Business justification: CRM and revenue attribution reporting requires knowing which channel (digital portal, phone, in-person) a coverage banker uses to engage a client. Banking CRM systems track coverage channel for client' ;
    rdfs:domain ind:CoverageAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:geographyCountryId rdf:type rdf:Property ;
    rdfs:label 'Geography Country Id' ;
    rdfs:comment 'Foreign key linking to reference.country. Business justification: Coverage territory management, client segmentation by geography, AML risk rating by country, and regulatory reporting of cross-border client relationships require linking coverage assignments to the c' ;
    rdfs:domain ind:CoverageAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:segmentId rdf:type rdf:Property ;
    rdfs:label 'Segment Id' ;
    rdfs:comment 'Foreign key linking to customer.segment. Business justification: IB coverage assignments are organized by client segment/tier. client_tier on coverage_assignment is a denormalized copy of customer.segment data. Direct FK enables coverage reporting by segment, suppo' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:amlRiskRating rdf:type rdf:Property ;
    rdfs:label 'Aml Risk Rating' ;
    rdfs:comment 'The Anti-Money Laundering (AML) risk rating assigned to the client entity for this coverage relationship. Determines the frequency and depth of enhanced due diligence (EDD) reviews required. Sourced from the AML/Financial Crime system.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentCode rdf:type rdf:Property ;
    rdfs:label 'Assignment Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the coverage assignment, used in pitch books, mandate letters, and CRM systems to uniquely reference this banker-client relationship.' ;
    rdfs:domain ind:CoverageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentDate rdf:type rdf:Property ;
    rdfs:label 'Assignment Date' ;
    rdfs:comment 'The business event date on which the coverage assignment decision was formally made and recorded, which may differ from the effective_from_date if there is a future-dated assignment.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assignment Status' ;
    rdfs:comment 'Current lifecycle state of the coverage assignment. Active indicates the banker is currently covering the client; transferred indicates ownership has moved to another banker; terminated indicates the relationship has ended.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankerTitle rdf:type rdf:Property ;
    rdfs:label 'Banker Title' ;
    rdfs:comment 'The seniority title of the assigned coverage banker at the time of assignment (e.g., Analyst, Associate, Vice President, Director, Managing Director). Relevant for deal origination credit allocation and client relationship governance.' ;
    rdfs:domain ind:CoverageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageNotes rdf:type rdf:Property ;
    rdfs:label 'Coverage Notes' ;
    rdfs:comment 'Free-text notes recorded by the coverage banker or coverage manager regarding the client relationship, strategic priorities, or special circumstances of this assignment. Contains sensitive business development information.' ;
    rdfs:domain ind:CoverageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageRole rdf:type rdf:Property ;
    rdfs:label 'Coverage Role' ;
    rdfs:comment 'The functional role of the assigned banker in the client coverage model. Primary bankers own the overall relationship; secondary bankers provide support; sector and product specialists contribute domain expertise. [ENUM-REF-CANDIDATE: primary|secondary|sector_specialist|product_specialist|co_coverage|advisory — promote to reference product]' ;
    rdfs:domain ind:CoverageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageTeamName rdf:type rdf:Property ;
    rdfs:label 'Coverage Team Name' ;
    rdfs:comment 'Name of the investment banking coverage team or group responsible for this assignment (e.g., \'Global TMT Coverage\', \'Healthcare Investment Banking\'). Supports team-level performance reporting and deal pipeline management.' ;
    rdfs:domain ind:CoverageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveFromDate rdf:type rdf:Property ;
    rdfs:label 'Effective From Date' ;
    rdfs:comment 'The date on which the coverage assignment became effective and the banker formally assumed responsibility for the client relationship. Used for revenue attribution and accountability tracking.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveUntilDate rdf:type rdf:Property ;
    rdfs:label 'Effective Until Date' ;
    rdfs:comment 'The date on which the coverage assignment is scheduled to end or was terminated. Null for open-ended assignments. Used for historical coverage analysis and transition planning.' ;
    rdfs:domain ind:CoverageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isActive rdf:type rdf:Property ;
    rdfs:label 'Is Active' ;
    rdfs:comment 'Boolean flag indicating whether this coverage assignment is currently active. Derived from assignment_status but maintained as an explicit field to support efficient filtering in analytics queries and reporting dashboards without requiring status string comparisons.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLeadCoverage rdf:type rdf:Property ;
    rdfs:label 'Is Lead Coverage' ;
    rdfs:comment 'Flag indicating whether this banker is the designated lead coverage officer for the client relationship. Only one banker per client should have this flag set to True at any given time. Drives primary accountability and escalation routing.' ;
    rdfs:domain ind:CoverageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSectorSpecialist rdf:type rdf:Property ;
    rdfs:label 'Is Sector Specialist' ;
    rdfs:comment 'Flag indicating whether the assigned banker is acting in a sector specialist capacity rather than a generalist relationship management role. Sector specialists provide deep industry expertise and are typically engaged on specific transaction types.' ;
    rdfs:domain ind:CoverageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastClientInteractionDate rdf:type rdf:Property ;
    rdfs:label 'Last Client Interaction Date' ;
    rdfs:comment 'The most recent date on which the coverage banker had a documented interaction with the client (meeting, call, pitch presentation). Used for CRM activity monitoring and relationship health assessment.' ;
    rdfs:domain ind:CoverageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lobName rdf:type rdf:Property ;
    rdfs:label 'Lob Name' ;
    rdfs:comment 'The investment banking Line of Business (LOB) associated with this coverage assignment, indicating the primary product focus area (e.g., M&A Advisory, Equity Capital Markets (ECM), Debt Capital Markets (DCM), Leveraged Finance, Syndicated Lending). [ENUM-REF-CANDIDATE: M&A_advisory|ECM|DCM|leveraged_finance|syndicated_lending|restructuring|corporate_finance — promote to reference product]' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mandateCount rdf:type rdf:Property ;
    rdfs:label 'Mandate Count' ;
    rdfs:comment 'The number of active IB mandates (M&A, IPO, DCM, etc.) currently associated with this coverage assignment at the time of record. Provides a snapshot of deal pipeline depth for this banker-client relationship.' ;
    rdfs:domain ind:CoverageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Review Date' ;
    rdfs:comment 'Scheduled date for the next periodic review of this coverage assignment, at which point the assignment may be renewed, transferred, or terminated. Supports coverage governance and banker accountability cycles.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originationCreditPct rdf:type rdf:Property ;
    rdfs:label 'Origination Credit Pct' ;
    rdfs:comment 'The percentage of deal origination credit allocated to this banker for revenue attribution purposes. Multiple bankers may share credit across a single client relationship; percentages across all active assignments for a client should sum to 100. Used in RAROC and banker performance measurement.' ;
    rdfs:domain ind:CoverageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pitchBookCount rdf:type rdf:Property ;
    rdfs:label 'Pitch Book Count' ;
    rdfs:comment 'The number of pitch books or marketing presentations delivered to this client under this coverage assignment. Tracks business development activity intensity and supports pipeline conversion analysis.' ;
    rdfs:domain ind:CoverageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recordCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Created Timestamp' ;
    rdfs:comment 'The timestamp when this coverage assignment record was first created in the data platform. Follows ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX). Used for audit trail and data lineage tracking.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Updated Timestamp' ;
    rdfs:comment 'The timestamp when this coverage assignment record was last modified in the data platform. Follows ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX). Used for change tracking, SCD processing, and audit compliance.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:relationshipSinceDate rdf:type rdf:Property ;
    rdfs:label 'Relationship Since Date' ;
    rdfs:comment 'The date on which the bank first established a formal investment banking relationship with this client entity. Distinct from the coverage assignment effective date; reflects the longevity of the overall client relationship.' ;
    rdfs:domain ind:CoverageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revenueAttributionPct rdf:type rdf:Property ;
    rdfs:label 'Revenue Attribution Pct' ;
    rdfs:comment 'The percentage of total client-generated IB revenue attributed to this specific coverage assignment. Distinct from origination_credit_pct as it may reflect ongoing relationship management credit rather than deal origination credit alone.' ;
    rdfs:domain ind:CoverageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sectorName rdf:type rdf:Property ;
    rdfs:label 'Sector Name' ;
    rdfs:comment 'Human-readable name of the industry sector under which this coverage assignment is classified (e.g., TMT, Healthcare, Energy, Financials, Industrials). Aligns with GICS sector taxonomy. [ENUM-REF-CANDIDATE: TMT|healthcare|energy|financials|industrials|consumer|real_estate|utilities|materials — promote to reference product]' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subSectorName rdf:type rdf:Property ;
    rdfs:label 'Sub Sector Name' ;
    rdfs:comment 'More granular sub-sector classification within the primary sector (e.g., within TMT: Software, Semiconductors, Media; within Healthcare: Pharma, MedTech, Biotech). Supports specialist banker routing and deal origination attribution.' ;
    rdfs:domain ind:CoverageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationReason rdf:type rdf:Property ;
    rdfs:label 'Termination Reason' ;
    rdfs:comment 'Reason code explaining why the coverage assignment was terminated or transferred. Supports workforce planning, client retention analysis, and coverage continuity management.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealParticipantId rdf:type rdf:Property ;
    rdfs:label 'Deal Participant Id' ;
    rdfs:comment 'Unique surrogate identifier for each deal participant record in the investment banking deal association entity. Primary key for the deal_participant table.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DealParticipant .

ind:jurisdictionId rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Id' ;
    rdfs:comment 'Foreign key linking to reference.jurisdiction. Business justification: Deal participant jurisdiction is required for sanctions screening, regulatory approval tracking, cross-border deal compliance, and netting enforceability assessment. Banking legal and compliance teams' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Jurisdiction .

ind:leiRegistryId rdf:type rdf:Property ;
    rdfs:label 'Lei Registry Id' ;
    rdfs:comment 'Foreign key linking to reference.lei_registry. Business justification: LEI code required for EMIR/Dodd-Frank trade reporting, counterparty due diligence, and legal entity identification in syndication and capital markets transactions.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LeiRegistry .

ind:primaryDealPartyId rdf:type rdf:Property ;
    rdfs:label 'Primary Deal Party Id' ;
    rdfs:comment 'Reference to the institution or counterparty entity representing the participating organization (e.g., client, co-advisor, legal counsel, auditor, regulator).' ;
    rdfs:domain ind:DealParticipant ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:agreedFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Agreed Fee Amount' ;
    rdfs:comment 'Contractually agreed fee amount payable to or by this participant for their role in the deal, expressed in the deal currency. For success fees, this represents the agreed percentage or fixed amount at deal close.' ;
    rdfs:domain ind:DealParticipant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bicCode rdf:type rdf:Property ;
    rdfs:label 'Bic Code' ;
    rdfs:comment 'SWIFT Bank Identifier Code (BIC) of the participating institution, used for SWIFT messaging, payment settlement, and cross-border transaction identification in investment banking deal communications.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conflictCheckDate rdf:type rdf:Property ;
    rdfs:label 'Conflict Check Date' ;
    rdfs:comment 'Date on which the conflict of interest screening was last performed or updated for this participant. Used to ensure checks are current and within required review cycles.' ;
    rdfs:domain ind:DealParticipant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conflictCheckNotes rdf:type rdf:Property ;
    rdfs:label 'Conflict Check Notes' ;
    rdfs:comment 'Free-text notes documenting the outcome of the conflict of interest review, including nature of any identified conflict, waiver rationale, or escalation details. Maintained for regulatory audit trail purposes.' ;
    rdfs:domain ind:DealParticipant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealTeamLead rdf:type rdf:Property ;
    rdfs:label 'Deal Team Lead' ;
    rdfs:comment 'Indicates whether this participant is designated as the lead institution or lead advisor for their role in the deal (e.g., lead left bookrunner, lead financial advisor). True = lead; False = co-participant or supporting role.' ;
    rdfs:domain ind:DealParticipant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:engagementEndDate rdf:type rdf:Property ;
    rdfs:label 'Engagement End Date' ;
    rdfs:comment 'Date on which the participant\'s engagement in the deal formally concluded, either through deal close, withdrawal, termination, or completion of advisory mandate. Null if engagement is ongoing.' ;
    rdfs:domain ind:DealParticipant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:engagementLetterDate rdf:type rdf:Property ;
    rdfs:label 'Engagement Letter Date' ;
    rdfs:comment 'Date on which the formal engagement letter was signed between the bank and this participant, establishing the legal basis for the advisory or service relationship within the deal.' ;
    rdfs:domain ind:DealParticipant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:engagementStartDate rdf:type rdf:Property ;
    rdfs:label 'Engagement Start Date' ;
    rdfs:comment 'Date on which the participant formally commenced engagement in the deal, typically aligned with the execution of a mandate letter, engagement letter, or non-disclosure agreement (NDA).' ;
    rdfs:domain ind:DealParticipant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:feeArrangementType rdf:type rdf:Property ;
    rdfs:label 'Fee Arrangement Type' ;
    rdfs:comment 'Type of fee arrangement agreed with this participant: retainer (periodic fixed fee), success_fee (contingent on deal close), hourly (time-based billing), fixed (lump sum), or no_fee (pro bono or regulatory participant). Drives revenue recognition and deal economics.' ;
    rdfs:domain ind:DealParticipant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeBasisPoints rdf:type rdf:Property ;
    rdfs:label 'Fee Basis Points' ;
    rdfs:comment 'Fee expressed in basis points (BPS) as a proportion of the total deal value, applicable for success fees and underwriting fees in capital markets transactions. One basis point equals 0.01%.' ;
    rdfs:domain ind:DealParticipant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:informationBarrierGroup rdf:type rdf:Property ;
    rdfs:label 'Information Barrier Group' ;
    rdfs:comment 'Identifier of the information barrier (Chinese Wall) group to which this participant has been assigned, controlling access to material non-public information (MNPI) about the deal. Used for insider trading prevention and regulatory compliance.' ;
    rdfs:domain ind:DealParticipant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:institutionType rdf:type rdf:Property ;
    rdfs:label 'Institution Type' ;
    rdfs:comment 'Classification of the type of institution participating in the deal: investment_bank, commercial_bank, law_firm, accounting_firm, regulator, private_equity, or hedge_fund. Supports deal team composition analysis and conflict screening. [ENUM-REF-CANDIDATE: investment_bank|commercial_bank|law_firm|accounting_firm|regulator|private_equity|hedge_fund — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kycReviewDate rdf:type rdf:Property ;
    rdfs:label 'Kyc Review Date' ;
    rdfs:comment 'Date on which the most recent KYC (Know Your Customer) review was completed for this participant. Used to track review currency and trigger periodic refresh cycles per AML compliance requirements.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mandateLetterRef rdf:type rdf:Property ;
    rdfs:label 'Mandate Letter Ref' ;
    rdfs:comment 'Reference number or identifier of the mandate letter or engagement letter governing this participant\'s involvement in the deal. Links to the formal contractual document establishing scope, fees, and obligations.' ;
    rdfs:domain ind:DealParticipant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ndaExecuted rdf:type rdf:Property ;
    rdfs:label 'Nda Executed' ;
    rdfs:comment 'Indicates whether a Non-Disclosure Agreement (NDA) has been executed with this participant prior to sharing confidential deal information. True = NDA in place; False = NDA not yet executed.' ;
    rdfs:domain ind:DealParticipant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ndaExecutionDate rdf:type rdf:Property ;
    rdfs:label 'Nda Execution Date' ;
    rdfs:comment 'Date on which the Non-Disclosure Agreement (NDA) was formally executed between the bank and this deal participant. Null if NDA has not been executed.' ;
    rdfs:domain ind:DealParticipant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:participantCategory rdf:type rdf:Property ;
    rdfs:label 'Participant Category' ;
    rdfs:comment 'High-level classification grouping participant roles into: principal (client, target, acquirer), advisor (financial advisor, legal counsel, auditor, co-advisor), regulatory (regulator, compliance body), or support (escrow agent, trustee, paying agent).' ;
    rdfs:domain ind:DealParticipant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:participantRefNumber rdf:type rdf:Property ;
    rdfs:label 'Participant Ref Number' ;
    rdfs:comment 'Externally-known alphanumeric reference number assigned to this participant engagement within the deal, used in mandate letters, pitch books, and tombstone records for cross-system identification.' ;
    rdfs:domain ind:DealParticipant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:participantRole rdf:type rdf:Property ;
    rdfs:label 'Participant Role' ;
    rdfs:comment 'Functional role of the participant in the investment banking deal. Common roles include: client, target, acquirer, co-advisor, financial advisor, legal counsel, auditor, underwriter, syndicate member, regulator, escrow agent, trustee, fairness opinion provider. [ENUM-REF-CANDIDATE: client|target|acquirer|co_advisor|financial_advisor|legal_counsel|auditor|underwriter|syndicate_member|regulator|escrow_agent|trustee|fairness_opinion_provider — promote to reference product]' ;
    rdfs:domain ind:DealParticipant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:participantSide rdf:type rdf:Property ;
    rdfs:label 'Participant Side' ;
    rdfs:comment 'Indicates which side of the transaction the participant represents: buy_side (acquirer/investor), sell_side (target/issuer), neutral (independent advisor, auditor, fairness opinion), or regulatory (governing body). Critical for conflict of interest screening.' ;
    rdfs:domain ind:DealParticipant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:participantStatus rdf:type rdf:Property ;
    rdfs:label 'Participant Status' ;
    rdfs:comment 'Current lifecycle status of the participant\'s engagement in the deal: active (currently engaged), withdrawn (voluntarily exited), terminated (engagement ended by counterparty), completed (deal closed with participant fulfilling role), suspended (engagement paused pending resolution).' ;
    rdfs:domain ind:DealParticipant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Email' ;
    rdfs:comment 'Business email address of the primary contact person at the participating institution. Used for deal communications, document distribution, and regulatory correspondence.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactName rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Name' ;
    rdfs:comment 'Full name of the primary contact person at the participating institution responsible for deal communications and execution. Captured for deal team management and correspondence tracking.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Phone' ;
    rdfs:comment 'Direct phone number of the primary contact person at the participating institution for deal-related communications.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Status' ;
    rdfs:comment 'Current status of any required regulatory approval for this participant\'s deal involvement: not_required, pending (application submitted), approved (clearance received), rejected (approval denied), or conditional (approved with conditions).' ;
    rdfs:domain ind:DealParticipant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:syndicateRank rdf:type rdf:Property ;
    rdfs:label 'Syndicate Rank' ;
    rdfs:comment 'Numeric ranking of this participant within the deal syndicate or advisory group, where 1 indicates the lead/senior position. Used for tombstone ordering, fee allocation, and league table credit attribution in capital markets transactions.' ;
    rdfs:domain ind:DealParticipant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tombstoneCreditLine rdf:type rdf:Property ;
    rdfs:label 'Tombstone Credit Line' ;
    rdfs:comment 'The exact credit line text to be used for this participant in the deal tombstone advertisement, specifying the institution name and role as it should appear in the published announcement.' ;
    rdfs:domain ind:DealParticipant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wallCrossDate rdf:type rdf:Property ;
    rdfs:label 'Wall Cross Date' ;
    rdfs:comment 'Date on which this participant was formally \'wall-crossed\' — i.e., brought over the information barrier and made aware of material non-public information (MNPI) about the deal. Critical for insider trading compliance and information barrier management.' ;
    rdfs:domain ind:DealParticipant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:withdrawalReason rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Reason' ;
    rdfs:comment 'Reason for the participant\'s withdrawal or termination from the deal, if applicable. Captures business rationale such as conflict of interest, regulatory objection, commercial disagreement, or deal collapse. Populated only when participant_status is withdrawn or terminated.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offeringId rdf:type rdf:Property ;
    rdfs:label 'Offering Id' ;
    rdfs:comment 'Primary key for offering' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Offering .

ind:listingId rdf:type rdf:Property ;
    rdfs:label 'Listing Id' ;
    rdfs:comment 'Foreign key linking to security.listing. Business justification: A public equity or debt offering results in the security being listed on an exchange. Post-IPO/follow-on workflows require linking the offering to the resulting exchange listing for settlement, market' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Listing .

ind:primaryDistributionChannelId rdf:type rdf:Property ;
    rdfs:label 'Primary Distribution Channel Id' ;
    rdfs:comment 'Foreign key linking to channel.channel. Business justification: Capital markets offerings are distributed through channels - retail tranches via branches/digital, institutional via RM networks. Syndicate desks track primary distribution channel for allocation deci' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:referencePriceId rdf:type rdf:Property ;
    rdfs:label 'Reference Price Id' ;
    rdfs:comment 'Foreign key linking to security.price. Business justification: Equity and debt offerings are priced relative to the security\'s prevailing market price (bookbuilding, greenshoe exercise, stabilization). Linking offering to security.price records the reference mark' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Price .

ind:suitabilityAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Suitability Assessment Id' ;
    rdfs:comment 'Foreign key linking to wealth.suitability_assessment. Business justification: MiFID II / SEC Reg BI suitability at offering level: before allocating a capital markets offering to a wealth client, a product-level suitability assessment is required. Linking the offering to the go' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SuitabilityAssessment .

ind:yieldCurveId rdf:type rdf:Property ;
    rdfs:label 'Yield Curve Id' ;
    rdfs:comment 'Foreign key linking to security.yield_curve. Business justification: Debt offerings (bonds, notes) are priced as a spread to a reference yield curve (e.g., on-the-run Treasury curve, swap curve). Linking offering to security.yield_curve records the pricing benchmark cu' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:YieldCurve .

ind:bookrunnerName rdf:type rdf:Property ;
    rdfs:label 'Bookrunner Name' ;
    rdfs:comment 'Name of the lead bookrunner (global coordinator) investment bank responsible for managing the bookbuilding process, allocating securities to investors, and stabilizing the aftermarket. For syndicated offerings, this is the primary bookrunner.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:couponRate rdf:type rdf:Property ;
    rdfs:label 'Coupon Rate' ;
    rdfs:comment 'Annual interest rate (coupon) expressed as a percentage of par value for debt offerings (investment grade bonds, high yield bonds, convertible bonds). Null for equity offerings. Key pricing term for DCM transactions.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditRating rdf:type rdf:Property ;
    rdfs:label 'Credit Rating' ;
    rdfs:comment 'Credit rating assigned to the debt offering by a Nationally Recognized Statistical Rating Organization (NRSRO) such as Moody\'s, S&P, or Fitch at time of issuance (e.g., AAA, Baa2, BB+). Null for unrated or equity offerings. [ENUM-REF-CANDIDATE: AAA|AA+|AA|AA-|A+|A|A-|BBB+|BBB|BBB-|BB+|BB|BB-|B+|B|B-|CCC|CC|C|D — promote to reference product]' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketSegment rdf:type rdf:Property ;
    rdfs:label 'Market Segment' ;
    rdfs:comment 'Identifies whether the offering belongs to Equity Capital Markets (ECM) or Debt Capital Markets (DCM), leveraged finance, or structured finance. Drives divisional P&L attribution and regulatory reporting classification.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maturityDate rdf:type rdf:Property ;
    rdfs:label 'Maturity Date' ;
    rdfs:comment 'Date on which the principal amount of a debt security is due for repayment to bondholders. Applicable to bond and note offerings (investment grade, high yield, convertible). Null for equity offerings.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:offerPrice rdf:type rdf:Property ;
    rdfs:label 'Offer Price' ;
    rdfs:comment 'Final price per share or per unit at which securities are offered to investors, set at pricing date. For debt offerings, expressed as a percentage of par value (e.g., 99.50). Central pricing fact for the ECM/DCM transaction.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:offeringNumber rdf:type rdf:Property ;
    rdfs:label 'Offering Number' ;
    rdfs:comment 'Externally-known alphanumeric reference code assigned by the investment banking division to uniquely identify this offering across deal management, regulatory filing, and syndication systems (e.g., ECM-2024-00123).' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offeringStatus rdf:type rdf:Property ;
    rdfs:label 'Offering Status' ;
    rdfs:comment 'Current lifecycle state of the capital markets offering, tracking progression from deal pipeline through regulatory filing, investor roadshow, pricing, and final closing or withdrawal. [ENUM-REF-CANDIDATE: pipeline|mandated|filed|roadshow|priced|closed|withdrawn|postponed — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallotmentAmount rdf:type rdf:Property ;
    rdfs:label 'Overallotment Amount' ;
    rdfs:comment 'Additional securities amount available under the overallotment (greenshoe) option, typically up to 15% of the base offering size. Exercisable by the stabilizing manager to cover excess demand and support post-listing price stability.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceRangeHigh rdf:type rdf:Property ;
    rdfs:label 'Price Range High' ;
    rdfs:comment 'Upper bound of the indicative price range communicated to investors during the roadshow and bookbuilding process, prior to final pricing. Used in preliminary prospectus and investor marketing materials.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceRangeLow rdf:type rdf:Property ;
    rdfs:label 'Price Range Low' ;
    rdfs:comment 'Lower bound of the indicative price range communicated to investors during the roadshow and bookbuilding process, prior to final pricing. Used in preliminary prospectus and investor marketing materials.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ratingAgency rdf:type rdf:Property ;
    rdfs:label 'Rating Agency' ;
    rdfs:comment 'Name of the Nationally Recognized Statistical Rating Organization (NRSRO) that assigned the credit rating to this debt offering. NR indicates the offering is not rated. Null for equity offerings.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regSEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Reg S Eligible Flag' ;
    rdfs:comment 'Indicates whether the offering is eligible for distribution to non-US investors under SEC Regulation S (offshore transactions), enabling international tranche distribution without full SEC registration.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:roadshowEndDate rdf:type rdf:Property ;
    rdfs:label 'Roadshow End Date' ;
    rdfs:comment 'Date on which the investor roadshow and bookbuilding process concluded, immediately preceding the pricing date. Used to measure roadshow duration and investor engagement analytics.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rule144aEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Rule 144a Eligible Flag' ;
    rdfs:comment 'Indicates whether the offering qualifies for resale to Qualified Institutional Buyers (QIBs) under SEC Rule 144A, enabling a private placement tranche alongside or instead of a registered public offering.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sharesOffered rdf:type rdf:Property ;
    rdfs:label 'Shares Offered' ;
    rdfs:comment 'Total number of shares or units offered in the transaction (base offering, excluding overallotment). Applicable to equity offerings (IPO, follow-on, rights issue). For debt offerings, represents face value units.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sizeAmount rdf:type rdf:Property ;
    rdfs:label 'Size Amount' ;
    rdfs:comment 'Total gross proceeds targeted to be raised in the offering, expressed in the offering currency. Represents the base deal size before any overallotment (greenshoe) exercise. Core monetary fact for ECM/DCM transaction records.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:syndicateSize rdf:type rdf:Property ;
    rdfs:label 'Syndicate Size' ;
    rdfs:comment 'Total number of investment banks participating in the underwriting syndicate for this offering, including bookrunners, co-managers, and selling group members. Indicates deal complexity and distribution breadth.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tombstonePublishedFlag rdf:type rdf:Property ;
    rdfs:label 'Tombstone Published Flag' ;
    rdfs:comment 'Indicates whether the tombstone announcement (deal announcement advertisement) has been published following successful closing of the offering. Tombstones serve as the official public record of completed capital markets transactions.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalProceedsAmount rdf:type rdf:Property ;
    rdfs:label 'Total Proceeds Amount' ;
    rdfs:comment 'Actual total gross proceeds raised at closing, including any overallotment option exercised. Represents the final deal size and is the primary monetary outcome metric for the offering.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:underwritingDiscountBps rdf:type rdf:Property ;
    rdfs:label 'Underwriting Discount Bps' ;
    rdfs:comment 'Gross underwriting spread expressed in basis points (BPS) as a percentage of total offering proceeds. Represents the total fee paid to the underwriting syndicate, covering management fee, underwriting fee, and selling concession.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:useOfProceeds rdf:type rdf:Property ;
    rdfs:label 'Use Of Proceeds' ;
    rdfs:comment 'Narrative description of how the issuer intends to deploy the capital raised from the offering (e.g., debt repayment, capital expenditure, working capital, acquisitions). Required disclosure in the prospectus under SEC Regulation S-K Item 504.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:factorId rdf:type rdf:Property ;
    rdfs:label 'Factor Id' ;
    rdfs:comment 'Unique surrogate identifier for each risk factor record in the enterprise risk factor master registry. Serves as the primary key for all downstream model linkages and risk calculations.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Factor .

ind:calibrationMethod rdf:type rdf:Property ;
    rdfs:label 'Calibration Method' ;
    rdfs:comment 'Statistical methodology used to calibrate the risk factor\'s shock distribution and volatility parameters for VaR, stressed VaR, and ECL models. Governs model validation requirements and regulatory approval under IRB and IMA frameworks.' ;
    rdfs:domain ind:Factor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ccarScenarioFlag rdf:type rdf:Property ;
    rdfs:label 'Ccar Scenario Flag' ;
    rdfs:comment 'Indicates whether this risk factor is included in the Federal Reserve\'s CCAR/DFAST stress testing scenario framework. True for factors that are shocked in supervisory adverse and severely adverse scenarios. Governs inclusion in stress testing data submissions to the Federal Reserve.' ;
    rdfs:domain ind:Factor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditQuality rdf:type rdf:Property ;
    rdfs:label 'Credit Quality' ;
    rdfs:comment 'Credit quality classification of the reference entity or issuer underlying a credit spread risk factor. Determines the applicable FRTB risk weight and correlation parameters. \'investment_grade\' corresponds to IG-rated issuers (BBB- and above); \'sub_investment_grade\' to HY/NR issuers.' ;
    rdfs:domain ind:Factor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:factorCode rdf:type rdf:Property ;
    rdfs:label 'Factor Code' ;
    rdfs:comment 'Externally-known, human-readable unique code identifying the risk factor across systems (e.g., \'IR_USD_SOFR_3M\', \'FX_EURUSD\', \'EQ_SPX\'). Used as the canonical business identifier in model configurations, regulatory submissions, and cross-system references.' ;
    rdfs:domain ind:Factor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:factorDescription rdf:type rdf:Property ;
    rdfs:label 'Factor Description' ;
    rdfs:comment 'Free-text narrative description of the risk factor, including its economic interpretation, model usage context, known limitations, and any special handling instructions. Supports model documentation requirements under SR 11-7 and provides context for risk analysts and model validators.' ;
    rdfs:domain ind:Factor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:factorName rdf:type rdf:Property ;
    rdfs:label 'Factor Name' ;
    rdfs:comment 'Full descriptive name of the risk factor as used in business communications, model documentation, and regulatory reports (e.g., \'USD SOFR 3-Month Swap Rate\', \'EUR/USD Spot FX Rate\', \'S&P 500 Equity Index\').' ;
    rdfs:domain ind:Factor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:factorStatus rdf:type rdf:Property ;
    rdfs:label 'Factor Status' ;
    rdfs:comment 'Current lifecycle status of the risk factor in the enterprise model inventory. \'active\' factors are used in live production models; \'deprecated\' factors are retained for historical audit; \'under_review\' factors are undergoing model validation or regulatory review.' ;
    rdfs:domain ind:Factor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:factorType rdf:type rdf:Property ;
    rdfs:label 'Factor Type' ;
    rdfs:comment 'Primary classification of the risk factor by its economic nature. Drives model selection, regulatory capital treatment, and VaR/CVA calculation methodology. [ENUM-REF-CANDIDATE: interest_rate|fx_rate|equity|commodity|credit_spread|volatility|inflation|real_estate|pd|lgd|ead — promote to reference product]' ;
    rdfs:domain ind:Factor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frtbBucket rdf:type rdf:Property ;
    rdfs:label 'Frtb Bucket' ;
    rdfs:comment 'FRTB Sensitivity-Based Method (SBM) bucket assignment for this risk factor as defined in BCBS FRTB Article 325. Determines the applicable risk weight and intra-bucket/inter-bucket correlation parameters for regulatory capital computation (e.g., \'GIRR_Bucket_1\', \'CSR_non_sec_Bucket_3\', \'EQ_Bucket_7\').' ;
    rdfs:domain ind:Factor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geography rdf:type rdf:Property ;
    rdfs:label 'Geography' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country or region code indicating the geographic jurisdiction of the risk factor (e.g., \'USA\' for US rates, \'GBR\' for UK gilts, \'EMU\' for Eurozone). Used for geographic concentration analysis, country risk reporting, and regulatory capital bucketing.' ;
    rdfs:domain ind:Factor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdingPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Holding Period Days' ;
    rdfs:comment 'Regulatory or internal holding period in calendar days used for VaR and Expected Shortfall (ES) calculations for this risk factor (e.g., 10 days for market risk under Basel, 1 day for internal daily VaR). Determines the time horizon over which potential losses are measured.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ifrs9EclFlag rdf:type rdf:Property ;
    rdfs:label 'Ifrs9 Ecl Flag' ;
    rdfs:comment 'Indicates whether this risk factor is used as a macroeconomic variable or credit parameter in IFRS 9 Expected Credit Loss (ECL) models. True for factors such as GDP growth, unemployment rate, PD term structures, and LGD curves used in forward-looking ECL projections.' ;
    rdfs:domain ind:Factor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isProxyFactor rdf:type rdf:Property ;
    rdfs:label 'Is Proxy Factor' ;
    rdfs:comment 'Indicates whether this risk factor is used as a proxy for another illiquid or unobservable factor. True when the factor substitutes for a non-modellable risk factor (NMRF) in model calculations. Proxy relationships require additional model validation documentation under SR 11-7.' ;
    rdfs:domain ind:Factor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastObservationDate rdf:type rdf:Property ;
    rdfs:label 'Last Observation Date' ;
    rdfs:comment 'Most recent date on which a real market price observation was recorded for this risk factor. Used in RFET assessment to verify that the factor has sufficient recent observations to qualify as modellable under FRTB IMA. Critical for daily data quality monitoring.' ;
    rdfs:domain ind:Factor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastValidationDate rdf:type rdf:Property ;
    rdfs:label 'Last Validation Date' ;
    rdfs:comment 'Date of the most recent independent model validation review for this risk factor\'s calibration and methodology. Required under SR 11-7 to ensure ongoing model fitness. Triggers re-validation workflow when the elapsed period exceeds the validation frequency threshold.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:liquidityHorizonDays rdf:type rdf:Property ;
    rdfs:label 'Liquidity Horizon Days' ;
    rdfs:comment 'FRTB-prescribed liquidity horizon in days assigned to this risk factor, reflecting the time required to exit or hedge the risk position in stressed market conditions (e.g., 10, 20, 40, 60, or 120 days per FRTB asset class). Used in ES scaling for IMA capital calculations.' ;
    rdfs:domain ind:Factor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:marketDataSource rdf:type rdf:Property ;
    rdfs:label 'Market Data Source' ;
    rdfs:comment 'Name of the primary market data vendor or internal source from which this risk factor\'s time series is sourced (e.g., \'Bloomberg\', \'Refinitiv\', \'ICE Data Services\', \'Federal Reserve H.15\', \'Internal Pricing Model\'). Governs data lineage and RFEТ (Risk Factor Eligibility Test) compliance under FRTB IMA.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketDataTicker rdf:type rdf:Property ;
    rdfs:label 'Market Data Ticker' ;
    rdfs:comment 'Vendor-specific ticker or field identifier used to retrieve this risk factor\'s market data from the designated source system (e.g., Bloomberg ticker \'USGG10YR Index\', Refinitiv RIC \'.SPX\'). Enables automated data feed mapping and reconciliation.' ;
    rdfs:domain ind:Factor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextValidationDate rdf:type rdf:Property ;
    rdfs:label 'Next Validation Date' ;
    rdfs:comment 'Scheduled date for the next independent model validation review of this risk factor. Computed based on the validation frequency policy (e.g., annual for Tier 1 models, biennial for Tier 2). Drives the model validation calendar and resource planning.' ;
    rdfs:domain ind:Factor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:observationWindowDays rdf:type rdf:Property ;
    rdfs:label 'Observation Window Days' ;
    rdfs:comment 'Length of the historical data observation window in calendar days used for calibrating this risk factor\'s shock distribution (e.g., 250 days for 1-year VaR, 1260 days for 5-year stressed VaR). Governs the backtesting and RFET assessment period.' ;
    rdfs:domain ind:Factor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:proxyFactorCode rdf:type rdf:Property ;
    rdfs:label 'Proxy Factor Code' ;
    rdfs:comment 'Factor code of the observable proxy risk factor used when is_proxy_factor is True. Documents the substitution relationship for model validation, audit, and NMRF capital add-on calculations. Null when the factor is directly observable.' ;
    rdfs:domain ind:Factor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryClassification rdf:type rdf:Property ;
    rdfs:label 'Regulatory Classification' ;
    rdfs:comment 'FRTB IMA classification of the risk factor as \'modellable\' (RFET passed — sufficient real price observations) or \'non_modellable\' (NMRF — requires stressed scenario capital add-on). Directly impacts IMA capital calculation and must be reported to regulators. \'not_applicable\' for SA-only factors.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfetObservationCount rdf:type rdf:Property ;
    rdfs:label 'Rfet Observation Count' ;
    rdfs:comment 'Number of real price observations recorded for this risk factor over the RFET assessment period (typically 12 months). A minimum of 24 observations (or 100 for the alternative test) is required for the factor to be classified as modellable under FRTB IMA. Populated by the market data quality process.' ;
    rdfs:domain ind:Factor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:riskClass rdf:type rdf:Property ;
    rdfs:label 'Risk Class' ;
    rdfs:comment 'Enterprise risk classification indicating which risk management pillar this factor belongs to: market risk (VaR, CVA), credit risk (PD/LGD/EAD, ECL, RWA), operational risk (SMA), or liquidity risk (LCR, NSFR). Governs routing to the appropriate risk engine and regulatory reporting stream.' ;
    rdfs:domain ind:Factor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sector rdf:type rdf:Property ;
    rdfs:label 'Sector' ;
    rdfs:comment 'Industry sector classification of the risk factor\'s underlying issuer or reference entity (e.g., \'financials\', \'energy\', \'technology\', \'sovereign\', \'covered_bond\'). Applies primarily to credit spread and equity risk factors. Aligns with FRTB SBM sector buckets for correlation and risk weight assignment. [ENUM-REF-CANDIDATE: financials|energy|technology|sovereign|covered_bond|consumer_discretionary|industrials|utilities|real_estate|materials — promote to reference product]' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shockType rdf:type rdf:Property ;
    rdfs:label 'Shock Type' ;
    rdfs:comment 'Convention used to express risk factor shocks in sensitivity and scenario analyses: \'absolute\' (additive shift in units), \'relative\' (percentage change), \'log_return\' (log-normal return), or \'basis_point\' (1bp = 0.0001 shift for rates). Determines how sensitivities (delta, vega) are computed and reported.' ;
    rdfs:domain ind:Factor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stressPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Stress Period End Date' ;
    rdfs:comment 'End date of the identified historical stress period used for stressed VaR and FRTB stressed ES calibration. Together with stress_period_start_date, defines the calibration window that produces the most adverse 12-month stressed scenario for this risk factor.' ;
    rdfs:domain ind:Factor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:stressPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Stress Period Start Date' ;
    rdfs:comment 'Start date of the identified historical stress period used for stressed VaR (sVaR) and FRTB stressed ES calibration for this risk factor. Must correspond to a period of significant financial stress relevant to the factor\'s asset class (e.g., 2008-09-01 for the Global Financial Crisis).' ;
    rdfs:domain ind:Factor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:subRiskClass rdf:type rdf:Property ;
    rdfs:label 'Sub Risk Class' ;
    rdfs:comment 'Granular sub-classification within the primary risk class (e.g., \'general_interest_rate_risk\', \'specific_risk\', \'counterparty_credit_risk\', \'settlement_risk\', \'concentration_risk\'). Used for detailed regulatory reporting and internal risk appetite segmentation. [ENUM-REF-CANDIDATE: general_interest_rate_risk|specific_risk|counterparty_credit_risk|settlement_risk|concentration_risk|basis_risk|vega_risk|curvature_risk — promote to reference product]' ;
    rdfs:domain ind:Factor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tenor rdf:type rdf:Property ;
    rdfs:label 'Tenor' ;
    rdfs:comment 'Maturity or tenor of the risk factor along the yield curve or term structure (e.g., \'3M\', \'1Y\', \'10Y\'). Applicable to interest rate, credit spread, and volatility surface factors. Null for spot FX rates and equity spot factors. Aligns with FRTB prescribed tenor vertices for delta sensitivity calculations.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tenorDays rdf:type rdf:Property ;
    rdfs:label 'Tenor Days' ;
    rdfs:comment 'Numeric representation of the risk factor tenor expressed in calendar days (e.g., 90 for 3M, 365 for 1Y). Enables precise interpolation between tenor vertices in risk model calculations and facilitates sorting and bucketing of term structure factors.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:timeSeriesCode rdf:type rdf:Property ;
    rdfs:label 'Time Series Code' ;
    rdfs:comment 'Reference to the historical time series record in the market data repository that stores the daily observations for this risk factor. Enables direct linkage from the factor definition to its underlying data for backtesting, calibration, and RFET assessment.' ;
    rdfs:domain ind:Factor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Unit Of Measure' ;
    rdfs:comment 'Unit in which the risk factor value is expressed (e.g., \'percent\', \'basis_points\', \'USD_per_barrel\', \'index_points\', \'USD_per_troy_oz\'). Essential for correct interpretation of factor values, shock magnitudes, and sensitivity calculations across heterogeneous risk factor types.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varConfidenceLevel rdf:type rdf:Property ;
    rdfs:label 'Var Confidence Level' ;
    rdfs:comment 'Statistical confidence level used when computing Value at Risk (VaR) for this risk factor (e.g., 0.9900 for 99%, 0.9750 for 97.5% ES under FRTB). Stored as a decimal fraction. Governs the tail risk threshold for internal risk limits and regulatory capital calculations.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varContributionPct rdf:type rdf:Property ;
    rdfs:label 'Var Contribution Pct' ;
    rdfs:comment 'Percentage contribution of this risk factor to the total portfolio VaR as of the last calculation date. Expressed as a decimal (e.g., 0.0523 = 5.23%). Used for risk attribution reporting, limit monitoring, and identification of dominant risk drivers in the trading book.' ;
    rdfs:domain ind:Factor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:appetiteId rdf:type rdf:Property ;
    rdfs:label 'Appetite Id' ;
    rdfs:comment 'Unique surrogate identifier for each risk appetite statement or threshold record within the enterprise risk appetite framework.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Appetite .

ind:supersededByAppetiteId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Appetite Id' ;
    rdfs:comment 'Reference to the risk_appetite_id of the newer version that supersedes this record when approval_status is \'superseded\'. Enables forward-chaining of the version history for audit and regulatory review purposes.' ;
    rdfs:domain ind:Appetite ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Appetite .

ind:appetiteLevel rdf:type rdf:Property ;
    rdfs:label 'Appetite Level' ;
    rdfs:comment 'Qualitative board-approved appetite level indicating the degree of risk the institution is willing to accept in pursuit of its strategic objectives. Ranges from low (minimal risk tolerance) to high (aggressive risk-taking within regulatory bounds).' ;
    rdfs:domain ind:Appetite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachEscalationLevel rdf:type rdf:Property ;
    rdfs:label 'Breach Escalation Level' ;
    rdfs:comment 'Defines the escalation tier that must be notified upon breach of this appetite threshold. Establishes the governance response chain from management-level notification through CRO to Board Risk Committee escalation.' ;
    rdfs:domain ind:Appetite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachResponseTimeframeDays rdf:type rdf:Property ;
    rdfs:label 'Breach Response Timeframe Days' ;
    rdfs:comment 'Maximum number of calendar days within which a formal remediation plan must be submitted to the designated escalation body following a breach of this appetite threshold.' ;
    rdfs:domain ind:Appetite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:direction rdf:type rdf:Property ;
    rdfs:label 'Direction' ;
    rdfs:comment 'Indicates whether the appetite threshold represents a minimum floor (e.g., CET1 ratio must be at least X%), a maximum ceiling (e.g., NPL ratio must not exceed Y%), a target value, or a permissible range.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governanceBody rdf:type rdf:Property ;
    rdfs:label 'Governance Body' ;
    rdfs:comment 'The governing body that approved this risk appetite statement (e.g., Board of Directors, Board Risk Committee, ALCO, Executive Risk Committee). Establishes the authority level and escalation chain for breach management. [ENUM-REF-CANDIDATE: board|board_risk_committee|alco|executive_risk_committee|credit_committee|audit_committee|cro_office — promote to reference product]' ;
    rdfs:domain ind:Appetite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBoardApproved rdf:type rdf:Property ;
    rdfs:label 'Is Board Approved' ;
    rdfs:comment 'Indicates whether this risk appetite statement has received formal Board of Directors or Board Risk Committee approval (True) or is still in draft/management-approved status (False). Required for regulatory examination and SOX attestation.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isQuantitative rdf:type rdf:Property ;
    rdfs:label 'Is Quantitative' ;
    rdfs:comment 'Indicates whether this risk appetite statement is expressed as a quantitative metric with a numeric threshold (True) or as a qualitative statement without a numeric bound (False). Qualitative statements include zero-tolerance policies for regulatory violations or reputational risk.' ;
    rdfs:domain ind:Appetite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRegulatoryMinimum rdf:type rdf:Property ;
    rdfs:label 'Is Regulatory Minimum' ;
    rdfs:comment 'Indicates whether this appetite threshold is set at or derived from a regulatory minimum requirement (True) or represents an internally-set management buffer above the regulatory floor (False). Critical for distinguishing regulatory compliance floors from internal risk management buffers.' ;
    rdfs:domain ind:Appetite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kriCode rdf:type rdf:Property ;
    rdfs:label 'Kri Code' ;
    rdfs:comment 'Reference code linking this risk appetite statement to the corresponding Key Risk Indicator (KRI) in the enterprise GRC system. Enables automated monitoring of appetite utilization against real-time KRI readings from SAS Risk Management / Moodys RiskAuthority.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Review Date' ;
    rdfs:comment 'Date on which this risk appetite statement was most recently reviewed and reaffirmed or amended by the governing body. Provides audit evidence of ongoing governance oversight.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:limitValue rdf:type rdf:Property ;
    rdfs:label 'Limit Value' ;
    rdfs:comment 'Hard operational limit assigned to a specific business line, desk, or portfolio that must not be exceeded. Derived from and subordinate to the enterprise-level appetite threshold. Used in daily risk limit monitoring within the Trading and Order Management System (Murex/Calypso).' ;
    rdfs:domain ind:Appetite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineOfBusiness rdf:type rdf:Property ;
    rdfs:label 'Line Of Business' ;
    rdfs:comment 'The specific Line of Business (LOB) to which this appetite statement applies (e.g., \'Commercial Lending\', \'Investment Banking\', \'Retail Banking\', \'Securities Trading\', \'Wealth Management\'). Null if the statement applies enterprise-wide.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metricDefinition rdf:type rdf:Property ;
    rdfs:label 'Metric Definition' ;
    rdfs:comment 'Formal definition of how the risk metric is calculated or assessed, including the numerator, denominator, observation period, and data sources. Ensures consistent measurement across business lines and regulatory submissions.' ;
    rdfs:domain ind:Appetite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metricName rdf:type rdf:Property ;
    rdfs:label 'Metric Name' ;
    rdfs:comment 'Name of the quantitative or qualitative metric used to measure risk against this appetite statement (e.g., \'CET1 Ratio\', \'VaR 99% 10-day\', \'LCR\', \'NSFR\', \'NPL Ratio\', \'ECL Coverage Ratio\').' ;
    rdfs:domain ind:Appetite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metricUnit rdf:type rdf:Property ;
    rdfs:label 'Metric Unit' ;
    rdfs:comment 'Unit in which the risk metric is expressed (e.g., percentage for CET1 ratio, currency_usd for VaR dollar amount, basis_points for credit spread limits, days for LCR horizon). [ENUM-REF-CANDIDATE: percentage|ratio|currency_usd|currency_local|basis_points|count|score|days — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Appetite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualitativeStatement rdf:type rdf:Property ;
    rdfs:label 'Qualitative Statement' ;
    rdfs:comment 'Full text of the board-approved qualitative risk appetite statement for non-quantifiable risk types (e.g., \'The Bank has zero tolerance for breaches of AML/BSA regulations\' or \'The Bank will not engage in activities that materially damage its reputation\'). Populated when is_quantitative is False.' ;
    rdfs:domain ind:Appetite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rangeLowerBound rdf:type rdf:Property ;
    rdfs:label 'Range Lower Bound' ;
    rdfs:comment 'Lower boundary of the acceptable risk range when direction is \'range\'. Applicable for metrics such as NIM targets or LCR operating ranges where both a floor and ceiling are defined.' ;
    rdfs:domain ind:Appetite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rangeUpperBound rdf:type rdf:Property ;
    rdfs:label 'Range Upper Bound' ;
    rdfs:comment 'Upper boundary of the acceptable risk range when direction is \'range\'. Used alongside range_lower_bound to define the full operating corridor for metrics managed within a band.' ;
    rdfs:domain ind:Appetite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rarocHurdleRate rdf:type rdf:Property ;
    rdfs:label 'Raroc Hurdle Rate' ;
    rdfs:comment 'Minimum Risk-Adjusted Return on Capital (RAROC) threshold that business activities must meet to be consistent with this risk appetite statement. Used in capital allocation decisions and new product approval processes.' ;
    rdfs:domain ind:Appetite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reviewFrequency rdf:type rdf:Property ;
    rdfs:label 'Review Frequency' ;
    rdfs:comment 'Mandated frequency at which this risk appetite statement must be formally reviewed and reaffirmed by the governing body. Drives the governance calendar for ALCO and Board Risk Committee scheduling.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskCategory rdf:type rdf:Property ;
    rdfs:label 'Risk Category' ;
    rdfs:comment 'Primary risk category to which this appetite statement applies. Aligns with the enterprise risk taxonomy: credit, market, liquidity, operational, reputational, or strategic. [ENUM-REF-CANDIDATE: credit|market|liquidity|operational|reputational|strategic|compliance|model|concentration — promote to reference product if taxonomy expands]' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskSubCategory rdf:type rdf:Property ;
    rdfs:label 'Risk Sub Category' ;
    rdfs:comment 'Granular sub-classification within the primary risk category (e.g., \'Counterparty Credit Risk\', \'Interest Rate Risk in the Banking Book (IRRBB)\', \'Intraday Liquidity Risk\', \'Cyber Operational Risk\'). Supports drill-down analytics in CCAR and DFAST reporting.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rwaLimit rdf:type rdf:Property ;
    rdfs:label 'Rwa Limit' ;
    rdfs:comment 'Maximum Risk-Weighted Assets (RWA) allocated to the applicable business line or portfolio under this appetite statement. Expressed in the institution\'s reporting currency. Supports capital adequacy management under Basel III Standardized Approach (SA) and Internal Ratings-Based (IRB) Approach.' ;
    rdfs:domain ind:Appetite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:statementCode rdf:type rdf:Property ;
    rdfs:label 'Statement Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the risk appetite statement, used in board documentation, ALCO packs, and regulatory submissions (e.g., RA-CREDIT-2024-001).' ;
    rdfs:domain ind:Appetite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statementName rdf:type rdf:Property ;
    rdfs:label 'Statement Name' ;
    rdfs:comment 'Human-readable name of the risk appetite statement as approved by the Board Risk Committee (e.g., \'Maximum Credit Risk Concentration — Single Obligor\').' ;
    rdfs:domain ind:Appetite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stressScenarioApplicability rdf:type rdf:Property ;
    rdfs:label 'Stress Scenario Applicability' ;
    rdfs:comment 'Indicates which stress testing scenario(s) this appetite threshold applies to: baseline (normal conditions), adverse (moderate stress), severely adverse (severe stress), or all scenarios. Directly maps to CCAR/DFAST scenario definitions.' ;
    rdfs:domain ind:Appetite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:threshold rdf:type rdf:Property ;
    rdfs:label 'Threshold' ;
    rdfs:comment 'Board-approved quantitative value representing the maximum level of risk the institution is willing to accept under normal operating conditions. For example, a CET1 ratio floor of 11.5% or a VaR limit of USD 50 million.' ;
    rdfs:domain ind:Appetite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:toleranceThreshold rdf:type rdf:Property ;
    rdfs:label 'Tolerance Threshold' ;
    rdfs:comment 'Maximum acceptable deviation from the risk appetite threshold before mandatory escalation is triggered. Represents the outer boundary of acceptable risk exposure (e.g., CET1 floor of 10.5% as the tolerance boundary below the 11.5% appetite).' ;
    rdfs:domain ind:Appetite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warningThreshold rdf:type rdf:Property ;
    rdfs:label 'Warning Threshold' ;
    rdfs:comment 'Early-warning trigger level set between the appetite threshold and tolerance threshold. Breaching this level initiates management-level monitoring and pre-emptive action before the tolerance boundary is reached. Supports KRI monitoring frameworks.' ;
    rdfs:domain ind:Appetite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depositAccountId rdf:type rdf:Property ;
    rdfs:label 'Deposit Account Id' ;
    rdfs:comment 'Foreign key linking to account.deposit_account. Business justification: Risk limits are set at account level for concentration monitoring and transaction limits. Treasury and ALCO teams track account-level exposure limits for liquidity risk management and regulatory compl' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DepositAccount .

ind:nettingSetId rdf:type rdf:Property ;
    rdfs:label 'Netting Set Id' ;
    rdfs:comment 'Foreign key linking to collateral.netting_set. Business justification: Counterparty credit limits set at netting set level for derivatives portfolios. Monitors net exposure post-collateral against approved limits. Essential for pre-trade credit checks and limit utilizati' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NettingSet .

ind:amount rdf:type rdf:Property ;
    rdfs:label 'Amount' ;
    rdfs:comment 'The approved maximum exposure threshold expressed as an absolute monetary or notional amount in the limit currency. Represents the binding constraint against which utilization is measured. For VaR limits this is the maximum permissible loss; for credit limits this is the maximum Exposure at Default (EAD).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvalAuthority rdf:type rdf:Property ;
    rdfs:label 'Approval Authority' ;
    rdfs:comment 'Name or title of the governance body or individual who approved this risk limit (e.g., \'ALCO\', \'Board Risk Committee\', \'CRO\', \'Head of Market Risk\'). Required for governance audit trail and escalation chain documentation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachActionRule rdf:type rdf:Property ;
    rdfs:label 'Breach Action Rule' ;
    rdfs:comment 'Prescribed remediation action protocol to be executed upon a breach event (e.g., \'Immediate escalation to CRO and ALCO; position reduction within 24 hours; SAR filing if AML threshold exceeded\'). Codifies the breach governance framework for operational consistency.' ;
    rdfs:domain ind:RiskLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachCount rdf:type rdf:Property ;
    rdfs:label 'Breach Count' ;
    rdfs:comment 'Cumulative number of breach events recorded against this limit since its effective date. Used for trend analysis, KRI monitoring, and regulatory reporting on limit governance effectiveness.' ;
    rdfs:domain ind:RiskLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:currency rdf:type rdf:Property ;
    rdfs:label 'Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the limit amount is denominated (e.g., \'USD\', \'EUR\', \'GBP\'). Required for multi-currency limit consolidation and FX-adjusted utilization calculations.' ;
    rdfs:domain ind:RiskLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentUtilizationAmount rdf:type rdf:Property ;
    rdfs:label 'Current Utilization Amount' ;
    rdfs:comment 'The most recently calculated utilization of the limit expressed in the limit currency. Represents the current exposure measured on the utilization_basis (e.g., current VaR, current EAD, current RWA). Updated by the risk management platform on the monitoring frequency cycle.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deskCode rdf:type rdf:Property ;
    rdfs:label 'Desk Code' ;
    rdfs:comment 'Identifier of the trading desk or business unit responsible for the positions subject to this limit. Aligns with desk hierarchy in Murex/Calypso trading and order management systems. Required for FRTB desk-level capital attribution.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationLevel1 rdf:type rdf:Property ;
    rdfs:label 'Escalation Level 1' ;
    rdfs:comment 'Name or role title of the first-level escalation contact notified upon a limit warning or breach event (e.g., \'Head of Market Risk\', \'Senior Credit Officer\'). Defines the escalation chain for breach governance.' ;
    rdfs:domain ind:RiskLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationLevel2 rdf:type rdf:Property ;
    rdfs:label 'Escalation Level 2' ;
    rdfs:comment 'Name or role title of the second-level escalation contact notified if the breach is not remediated within the prescribed timeframe (e.g., \'Chief Risk Officer\', \'Board Risk Committee Chair\'). Supports multi-tier breach governance.' ;
    rdfs:domain ind:RiskLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographyCode rdf:type rdf:Property ;
    rdfs:label 'Geography Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country or region code identifying the geographic scope of the limit (e.g., \'USA\', \'GBR\', \'DEU\'). Used for country risk concentration limits and cross-border exposure management.' ;
    rdfs:domain ind:RiskLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hardStopFlag rdf:type rdf:Property ;
    rdfs:label 'Hard Stop Flag' ;
    rdfs:comment 'Indicates whether the limit enforces a hard stop (True) that prevents new transactions from being booked once the limit is reached, or a soft limit (False) that triggers alerts and escalation but does not block transactions. Critical for real-time limit monitoring integration with trading and order management systems.' ;
    rdfs:domain ind:RiskLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastBreachDate rdf:type rdf:Property ;
    rdfs:label 'Last Breach Date' ;
    rdfs:comment 'Date of the most recent breach event recorded against this limit. Null if no breach has occurred. Used for recency analysis in KRI dashboards and regulatory examination responses.' ;
    rdfs:domain ind:RiskLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:limitCode rdf:type rdf:Property ;
    rdfs:label 'Limit Code' ;
    rdfs:comment 'Externally-known, human-readable business identifier for the risk limit (e.g., \'CRED-CORP-001\', \'MKT-VAR-DESK-FX-002\'). Used in regulatory submissions, audit trails, and cross-system references. Aligns with the limit reference code maintained in SAS Risk Management / Moody\'s RiskAuthority.' ;
    rdfs:domain ind:RiskLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limitDescription rdf:type rdf:Property ;
    rdfs:label 'Limit Description' ;
    rdfs:comment 'Free-text narrative describing the business rationale, scope, and any special conditions or exclusions applicable to this risk limit. Provides context for governance reviews, regulatory examinations, and audit inquiries.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limitName rdf:type rdf:Property ;
    rdfs:label 'Limit Name' ;
    rdfs:comment 'Descriptive business name of the risk limit (e.g., \'FX Trading Desk Daily VaR Limit\', \'Corporate Credit Concentration Limit — Technology Sector\'). Used in dashboards, governance reports, and ALCO presentations.' ;
    rdfs:domain ind:RiskLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limitStatus rdf:type rdf:Property ;
    rdfs:label 'Limit Status' ;
    rdfs:comment 'Current lifecycle state of the risk limit record. \'active\' indicates the limit is in force and being monitored; \'suspended\' indicates temporary hold pending review; \'breached\' indicates the limit is currently in excess; \'pending_approval\' indicates awaiting governance sign-off.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limitType rdf:type rdf:Property ;
    rdfs:label 'Limit Type' ;
    rdfs:comment 'Classification of the risk limit by risk category. Drives applicable measurement methodology and regulatory capital treatment. [ENUM-REF-CANDIDATE: credit|market|liquidity|concentration|operational|counterparty|country|sector|settlement|intraday — promote to reference product]' ;
    rdfs:domain ind:RiskLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringFrequency rdf:type rdf:Property ;
    rdfs:label 'Monitoring Frequency' ;
    rdfs:comment 'Frequency at which utilization is recalculated and compared against the limit threshold (e.g., \'real_time\' for trading desk VaR limits, \'daily\' for credit concentration limits, \'monthly\' for LCR/NSFR limits). Drives the monitoring schedule in the risk management platform.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryCapitalFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Capital Flag' ;
    rdfs:comment 'Indicates whether this limit is directly tied to a regulatory capital constraint (True) under Basel III/FRTB (e.g., RWA limit, CET1 buffer limit, LCR minimum). Flags limits that require regulatory reporting upon breach.' ;
    rdfs:domain ind:RiskLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scopeEntityType rdf:type rdf:Property ;
    rdfs:label 'Scope Entity Type' ;
    rdfs:comment 'The type of business entity to which this limit applies. Determines the dimension of risk aggregation (e.g., \'counterparty\' for single-name credit limits, \'desk\' for trading desk VaR limits, \'lob\' for Line of Business concentration limits, \'geography\' for country risk limits). [ENUM-REF-CANDIDATE: counterparty|portfolio|desk|lob|geography|sector|instrument|legal_entity — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RiskLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stressTestLimitFlag rdf:type rdf:Property ;
    rdfs:label 'Stress Test Limit Flag' ;
    rdfs:comment 'Indicates whether this limit is a stress-scenario limit (True) applied under CCAR/DFAST stress testing frameworks, as opposed to a business-as-usual (BAU) limit. Stress limits typically have higher thresholds and different breach protocols.' ;
    rdfs:domain ind:RiskLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:utilizationAsOfTimestamp rdf:type rdf:Property ;
    rdfs:label 'Utilization As Of Timestamp' ;
    rdfs:comment 'The precise date and time at which the current utilization amount was calculated or sourced from the risk management platform. Critical for intraday limit monitoring and audit trail integrity. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:RiskLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:utilizationBasis rdf:type rdf:Property ;
    rdfs:label 'Utilization Basis' ;
    rdfs:comment 'The measurement methodology used to calculate current utilization against the limit. Determines which risk metric is compared to the limit amount (e.g., \'var\' for Value at Risk limits, \'ead\' for Exposure at Default credit limits, \'rwa\' for Risk-Weighted Asset limits, \'lcr_outflow\' for liquidity limits). [ENUM-REF-CANDIDATE: notional|mtm|ead|var|rwa|ecl|nii_impact|lcr_outflow|cva|pv01|dv01 — promote to reference product]' ;
    rdfs:domain ind:RiskLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utilizationPct rdf:type rdf:Property ;
    rdfs:label 'Utilization Pct' ;
    rdfs:comment 'Current utilization expressed as a percentage of the approved limit amount (current_utilization_amount / limit_amount × 100). Enables threshold-based alerting and trend analysis. Values above 100 indicate a breach condition.' ;
    rdfs:domain ind:RiskLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varHoldingPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Var Holding Period Days' ;
    rdfs:comment 'The holding period in calendar days used in the VaR calculation for market risk limits (e.g., 1 for daily VaR, 10 for 10-day regulatory VaR under Basel III). Applicable only for market risk limit types.' ;
    rdfs:domain ind:RiskLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:warningThresholdPct rdf:type rdf:Property ;
    rdfs:label 'Warning Threshold Pct' ;
    rdfs:comment 'Percentage of the limit amount at which an early-warning alert is triggered (e.g., 80.00 for 80%). Enables proactive escalation before a formal breach occurs. Expressed as a percentage (0–100). Configured per limit in SAS Risk Management / Moody\'s RiskAuthority.' ;
    rdfs:domain ind:RiskLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditExposureId rdf:type rdf:Property ;
    rdfs:label 'Credit Exposure Id' ;
    rdfs:comment 'Unique surrogate identifier for each credit exposure measurement record in the silver layer lakehouse. Primary key for the credit_exposure data product.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CreditExposure .

ind:correspondentBankId rdf:type rdf:Property ;
    rdfs:label 'Correspondent Bank Id' ;
    rdfs:comment 'Foreign key linking to payment.correspondent_bank. Business justification: Correspondent banking relationships create Nostro credit exposure that must be tracked under large exposure rules (CRR Article 395) and Basel III. Credit risk teams measure and limit exposure to each ' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CorrespondentBank .

ind:counterpartyAgreementId rdf:type rdf:Property ;
    rdfs:label 'Counterparty Agreement Id' ;
    rdfs:comment 'Foreign key linking to trade.counterparty_agreement. Business justification: Credit exposure calculation under ISDA/CSA netting agreements requires linking exposure records to the governing counterparty agreement for netting benefit recognition. SA-CCR and IMM both require the' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CounterpartyAgreement .

ind:countryId rdf:type rdf:Property ;
    rdfs:label 'Country Id' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the counterparty\'s country of domicile or incorporation. Used for geographic concentration risk analysis and sovereign risk weighting under CRR2 Article 395.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:interbankPlacementId rdf:type rdf:Property ;
    rdfs:label 'Interbank Placement Id' ;
    rdfs:comment 'Foreign key linking to treasury.interbank_placement. Business justification: Interbank placements create credit exposure to the counterparty bank. Credit risk teams measure PD, LGD, EAD on interbank placements for large exposure reporting (CRR Article 395) and counterparty cre' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InterbankPlacement .

ind:repoPositionId rdf:type rdf:Property ;
    rdfs:label 'Repo Position Id' ;
    rdfs:comment 'Foreign key linking to treasury.repo_position. Business justification: Credit exposure calculations incorporate repo positions for counterparty credit risk measurement and CVA calculation under Basel III SA-CCR. Repo positions are collateralized exposures requiring speci' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RepoPosition .

ind:riskEclProvisionId rdf:type rdf:Property ;
    rdfs:label 'Risk Ecl Provision Id' ;
    rdfs:comment 'Foreign key linking to risk.risk_ecl_provision. Business justification: credit_exposure embeds ecl_provision (DECIMAL) and ecl_stage (STRING) as denormalized values. risk_ecl_provision is the authoritative ECL provisioning record under IFRS 9/CECL. Adding risk_ecl_provisi' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RiskEclProvision .

ind:tradePositionId rdf:type rdf:Property ;
    rdfs:label 'Trade Position Id' ;
    rdfs:comment 'Foreign key linking to trade.trade_position. Business justification: Basel III IMM requires mapping credit exposures to source trade positions for EAD calculation, netting set aggregation, and CVA capital charge computation. Risk teams must trace each credit_exposure r' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TradePosition .

ind:collateralValue rdf:type rdf:Property ;
    rdfs:label 'Collateral Value' ;
    rdfs:comment 'Current market value of eligible financial collateral posted against this exposure after applicable haircuts under the Financial Collateral Comprehensive Method (FCCM). Reduces EAD and RWA.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:concentrationHhi rdf:type rdf:Property ;
    rdfs:label 'Concentration Hhi' ;
    rdfs:comment 'Herfindahl-Hirschman Index score measuring the degree of concentration of this exposure within its sector, geography, or single-name bucket. Used for concentration risk monitoring and regulatory large exposure limit compliance.' ;
    rdfs:domain ind:CreditExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:counterpartyType rdf:type rdf:Property ;
    rdfs:label 'Counterparty Type' ;
    rdfs:comment 'Classification of the counterparty for regulatory capital and large exposure reporting purposes. Determines applicable risk weight under SA and eligibility for IRB treatment. [ENUM-REF-CANDIDATE: corporate|financial_institution|sovereign|central_bank|retail|sme|fund — promote to reference product]' ;
    rdfs:domain ind:CreditExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentExposure rdf:type rdf:Property ;
    rdfs:label 'Current Exposure' ;
    rdfs:comment 'Current mark-to-market (MTM) replacement cost of the exposure as of the measurement date, before netting and collateral. For derivatives, represents the positive MTM value. For loans, represents the outstanding principal balance.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cva rdf:type rdf:Property ;
    rdfs:label 'Cva' ;
    rdfs:comment 'Market value of counterparty credit risk embedded in OTC derivative positions, representing the expected loss due to counterparty default. Calculated under SA-CVA or BA-CVA regulatory framework. Impacts P&L and regulatory capital.' ;
    rdfs:domain ind:CreditExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cvaApproach rdf:type rdf:Property ;
    rdfs:label 'Cva Approach' ;
    rdfs:comment 'Regulatory methodology used to calculate the CVA capital charge: Standardised Approach for CVA (SA-CVA), Basic Approach for CVA (BA-CVA), or exempted (for transactions with non-financial counterparties below threshold).' ;
    rdfs:domain ind:CreditExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cvaCapitalCharge rdf:type rdf:Property ;
    rdfs:label 'Cva Capital Charge' ;
    rdfs:comment 'Regulatory capital requirement for CVA risk calculated under SA-CVA or BA-CVA methodology as prescribed by BCBS CRE51. Represents the RWA equivalent for counterparty credit valuation adjustment risk.' ;
    rdfs:domain ind:CreditExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dva rdf:type rdf:Property ;
    rdfs:label 'Dva' ;
    rdfs:comment 'Adjustment to derivative fair value reflecting the bank\'s own credit risk, representing the benefit to the bank from its own potential default. Reported under IFRS 13 but excluded from regulatory CVA capital charge.' ;
    rdfs:domain ind:CreditExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ead rdf:type rdf:Property ;
    rdfs:label 'Ead' ;
    rdfs:comment 'Estimated total exposure amount outstanding at the time of default, expressed in the reporting currency. Incorporates credit conversion factors (CCF) for off-balance-sheet items and SA-CCR replacement cost for derivatives. Core input to RWA and ECL calculation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:effectiveMaturityYears rdf:type rdf:Property ;
    rdfs:label 'Effective Maturity Years' ;
    rdfs:comment 'Effective maturity parameter (M) in years as defined under the IRB Advanced approach, capped at 5 years and floored at 1 year. Adjusts the IRB capital formula for longer-dated exposures via the maturity adjustment factor.' ;
    rdfs:domain ind:CreditExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedExposure rdf:type rdf:Property ;
    rdfs:label 'Expected Exposure' ;
    rdfs:comment 'Average exposure across all simulation paths at a future time horizon, used as the basis for CVA calculation and expected credit loss (ECL) provisioning under IFRS 9.' ;
    rdfs:domain ind:CreditExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exposureClass rdf:type rdf:Property ;
    rdfs:label 'Exposure Class' ;
    rdfs:comment 'Regulatory asset class of the exposure under Basel III/CRR2 framework, determining the applicable risk weight and capital treatment. [ENUM-REF-CANDIDATE: corporate|sovereign|institution|retail|equity|securitisation|other — promote to reference product]' ;
    rdfs:domain ind:CreditExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exposureReference rdf:type rdf:Property ;
    rdfs:label 'Exposure Reference' ;
    rdfs:comment 'Externally-known business reference number for this credit exposure record, as assigned by the risk management platform (SAS Risk Management / Moodys RiskAuthority) or trading system (Murex/Calypso). Used for reconciliation and regulatory reporting.' ;
    rdfs:domain ind:CreditExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exposureStatus rdf:type rdf:Property ;
    rdfs:label 'Exposure Status' ;
    rdfs:comment 'Current lifecycle status of the credit exposure. Drives provisioning, regulatory classification, and workout processes. [ENUM-REF-CANDIDATE: active|closed|defaulted|restructured|watch_list|written_off — promote to reference product if additional states required]' ;
    rdfs:domain ind:CreditExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fva rdf:type rdf:Property ;
    rdfs:label 'Fva' ;
    rdfs:comment 'Adjustment to derivative fair value reflecting the cost or benefit of funding uncollateralised derivative positions. Captures the funding spread between the bank\'s borrowing cost and the risk-free rate.' ;
    rdfs:domain ind:CreditExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fxRate rdf:type rdf:Property ;
    rdfs:label 'Fx Rate' ;
    rdfs:comment 'Exchange rate applied to translate the exposure from its original currency to the reporting currency as of the measurement date. Sourced from the bank\'s official FX rate feed.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:largeExposureFlag rdf:type rdf:Property ;
    rdfs:label 'Large Exposure Flag' ;
    rdfs:comment 'Indicates whether this exposure meets or exceeds the large exposure threshold (10% of eligible capital) requiring regulatory reporting under CRR2 Article 395. Triggers enhanced monitoring and reporting obligations.' ;
    rdfs:domain ind:CreditExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lgd rdf:type rdf:Property ;
    rdfs:label 'Lgd' ;
    rdfs:comment 'Estimated fraction of the Exposure at Default (EAD) that would be lost in the event of default, expressed as a decimal (e.g., 0.45 = 45%). Reflects collateral, seniority, and recovery assumptions under IRB Advanced approach.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementDate rdf:type rdf:Property ;
    rdfs:label 'Measurement Date' ;
    rdfs:comment 'The as-of date on which the credit exposure was measured and calculated. Represents the principal business event date for this record. Used for point-in-time regulatory reporting (CCAR, DFAST, Pillar 3).' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:netExposure rdf:type rdf:Property ;
    rdfs:label 'Net Exposure' ;
    rdfs:comment 'Credit exposure after applying netting agreements and eligible collateral offsets (EAD minus collateral value). Represents the bank\'s actual economic risk position used for limit monitoring and large exposure reporting.' ;
    rdfs:domain ind:CreditExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pd rdf:type rdf:Property ;
    rdfs:label 'Pd' ;
    rdfs:comment 'Estimated probability that the obligor will default within a one-year horizon, expressed as a decimal (e.g., 0.00250 = 0.25%). Core IRB parameter used in RWA and ECL calculation under IFRS 9 and CECL.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pillar3DisclosureFlag rdf:type rdf:Property ;
    rdfs:label 'Pillar3 Disclosure Flag' ;
    rdfs:comment 'Indicates whether this exposure record is included in the bank\'s Pillar 3 public disclosure reporting under Basel III. Drives the regulatory reporting extract for AxiomSL/Wolters Kluwer OneSumX.' ;
    rdfs:domain ind:CreditExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:potentialFutureExposure rdf:type rdf:Property ;
    rdfs:label 'Potential Future Exposure' ;
    rdfs:comment 'Estimated maximum exposure at a specified confidence level (typically 95%) over the remaining life of the transaction, capturing future market movements. Used in counterparty credit limit monitoring and CVA calculation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryApproach rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approach' ;
    rdfs:comment 'Regulatory methodology applied to calculate risk-weighted assets (RWA) for this exposure: Standardised Approach (SA), Foundation Internal Ratings-Based (F-IRB), Advanced IRB (A-IRB), Standardised Approach for Counterparty Credit Risk (SA-CCR), or Internal Model Method (IMM).' ;
    rdfs:domain ind:CreditExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Reporting Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code of the bank\'s reporting currency into which all exposure amounts are translated for regulatory capital and Pillar 3 reporting (typically USD or EUR).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskWeight rdf:type rdf:Property ;
    rdfs:label 'Risk Weight' ;
    rdfs:comment 'Risk weight percentage applied to the exposure to derive credit RWA, expressed as a decimal (e.g., 1.00 = 100%). Determined by exposure class, counterparty rating, and regulatory approach (SA or IRB).' ;
    rdfs:domain ind:CreditExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rwaCredit rdf:type rdf:Property ;
    rdfs:label 'Rwa Credit' ;
    rdfs:comment 'Risk-weighted asset amount for credit risk calculated for this exposure under the applicable regulatory approach (SA or IRB). Primary input to CET1 capital ratio calculation and Pillar 3 disclosure.' ;
    rdfs:domain ind:CreditExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketRiskPositionId rdf:type rdf:Property ;
    rdfs:label 'Market Risk Position Id' ;
    rdfs:comment 'Unique surrogate identifier for each daily mark-to-market risk position record in the trading book or banking book. Primary key for this entity.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MarketRiskPosition .

ind:stressTestRunId rdf:type rdf:Property ;
    rdfs:label 'Stress Test Run Id' ;
    rdfs:comment 'Foreign key linking to risk.stress_test_run. Business justification: market_risk_position links to stress_scenario (EXISTS) but not to the specific stress_test_run execution. Stressed VaR, stressed CVA, and FRTB capital charges computed during a stress test run need to' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StressTestRun .

ind:tradingBookId rdf:type rdf:Property ;
    rdfs:label 'Trading Book Id' ;
    rdfs:comment 'Reference to the trading desk or business unit responsible for this position. Under FRTB, trading desks are the primary unit for IMA approval and P&L attribution testing.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TradingBook .

ind:bookType rdf:type rdf:Property ;
    rdfs:label 'Book Type' ;
    rdfs:comment 'Regulatory classification of the position as either trading book (subject to market risk capital under FRTB) or banking book (subject to IRRBB framework). Determines applicable capital treatment and risk measurement methodology.' ;
    rdfs:domain ind:MarketRiskPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cs01 rdf:type rdf:Property ;
    rdfs:label 'Cs01' ;
    rdfs:comment 'Credit Spread sensitivity — the change in MTM value for a 1 basis point widening in the credit spread of the underlying issuer or reference entity. Key measure for credit risk management and FRTB CSR (Credit Spread Risk) capital charge.' ;
    rdfs:domain ind:MarketRiskPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cvaCharge rdf:type rdf:Property ;
    rdfs:label 'Cva Charge' ;
    rdfs:comment 'Credit Valuation Adjustment representing the market value of counterparty default risk embedded in OTC derivative positions. Reflects the expected loss due to counterparty credit deterioration or default. Required under Basel III CVA framework.' ;
    rdfs:domain ind:MarketRiskPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:delta rdf:type rdf:Property ;
    rdfs:label 'Delta' ;
    rdfs:comment 'First-order sensitivity of the position\'s MTM value to a unit change in the underlying risk factor price (e.g., equity price, FX spot rate, commodity price). Used for delta hedging and FRTB SA delta risk charge calculation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dv01 rdf:type rdf:Property ;
    rdfs:label 'Dv01' ;
    rdfs:comment 'Dollar Value of a 01 (one basis point) shift in interest rates — the change in MTM value for a 1 basis point (0.01%) parallel upward shift in the yield curve. Primary interest rate sensitivity measure used for hedging and risk limit monitoring.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eveSensitivity rdf:type rdf:Property ;
    rdfs:label 'Eve Sensitivity' ;
    rdfs:comment 'Sensitivity of the Economic Value of Equity to standardised interest rate shock scenarios under IRRBB. Measures the long-term impact of rate changes on the present value of banking book assets and liabilities. Used in IRRBB supervisory outlier test.' ;
    rdfs:domain ind:MarketRiskPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedShortfall rdf:type rdf:Property ;
    rdfs:label 'Expected Shortfall' ;
    rdfs:comment 'Expected Shortfall (Conditional VaR) at 97.5% confidence level as required under FRTB IMA. Measures the average loss in the worst 2.5% of scenarios, replacing VaR as the primary IMA risk measure under FRTB.' ;
    rdfs:domain ind:MarketRiskPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:frtbApproach rdf:type rdf:Property ;
    rdfs:label 'Frtb Approach' ;
    rdfs:comment 'Indicates whether the FRTB capital charge for this position is computed under the Internal Models Approach (IMA), Standardised Approach (SA), or IMA with SA fallback for non-modellable risk factors (NMRFs).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frtbCapitalCharge rdf:type rdf:Property ;
    rdfs:label 'Frtb Capital Charge' ;
    rdfs:comment 'Total FRTB market risk capital charge for this position, representing the higher of the IMA (Internal Models Approach) or SA (Standardised Approach) capital requirement as applicable. Reported to regulators under FRTB framework.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gamma rdf:type rdf:Property ;
    rdfs:label 'Gamma' ;
    rdfs:comment 'Second-order (curvature) sensitivity of the position\'s MTM value to changes in the underlying risk factor. Captures non-linear risk for options and structured products. Used in FRTB SA curvature risk charge calculation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hedgeDesignation rdf:type rdf:Property ;
    rdfs:label 'Hedge Designation' ;
    rdfs:comment 'Accounting hedge designation for the position under IFRS 9 or ASC 815. Determines whether hedge accounting is applied and the treatment of fair value changes in OCI vs P&L. Relevant for banking book hedges of interest rate and FX risk.' ;
    rdfs:domain ind:MarketRiskPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hypotheticalPnl rdf:type rdf:Property ;
    rdfs:label 'Hypothetical Pnl' ;
    rdfs:comment 'Hypothetical P&L computed by revaluing the prior day\'s portfolio using current day\'s market prices, holding positions constant. Used in VaR backtesting and FRTB IMA P&L attribution test to validate risk model accuracy.' ;
    rdfs:domain ind:MarketRiskPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:instrumentType rdf:type rdf:Property ;
    rdfs:label 'Instrument Type' ;
    rdfs:comment 'Specific instrument type classification (e.g., bond, equity, interest_rate_swap, fx_forward, credit_default_swap, option, futures, mortgage_backed_security). Used for product-level risk aggregation and regulatory reporting. [ENUM-REF-CANDIDATE: bond|equity|interest_rate_swap|fx_forward|credit_default_swap|option|futures|mortgage_backed_security|other — promote to reference product]' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ircCharge rdf:type rdf:Property ;
    rdfs:label 'Irc Charge' ;
    rdfs:comment 'Incremental Risk Charge capturing default and migration risk for credit-sensitive positions in the trading book over a one-year capital horizon at 99.9% confidence. Applicable to non-securitisation credit positions under Basel 2.5.' ;
    rdfs:domain ind:MarketRiskPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isModellableRiskFactor rdf:type rdf:Property ;
    rdfs:label 'Is Modellable Risk Factor' ;
    rdfs:comment 'Indicates whether the primary risk factor for this position passes the FRTB Risk Factor Eligibility Test (RFET) and is classified as modellable. Non-modellable risk factors (NMRFs) attract a separate stress scenario capital add-on under FRTB IMA.' ;
    rdfs:domain ind:MarketRiskPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mtmValue rdf:type rdf:Property ;
    rdfs:label 'Mtm Value' ;
    rdfs:comment 'Current mark-to-market fair value of the position in the reporting currency as of the position date. Represents the present value of future cash flows discounted at current market rates. Core input for P&L attribution and capital calculations.' ;
    rdfs:domain ind:MarketRiskPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:niiSensitivity rdf:type rdf:Property ;
    rdfs:label 'Nii Sensitivity' ;
    rdfs:comment 'Sensitivity of Net Interest Income to a standardised interest rate shock scenario (e.g., +200bps parallel shift). Applicable to banking book positions under IRRBB framework. Measures short-term earnings impact of rate changes.' ;
    rdfs:domain ind:MarketRiskPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:notionalAmount rdf:type rdf:Property ;
    rdfs:label 'Notional Amount' ;
    rdfs:comment 'The face value or contractual notional amount of the position in the instrument\'s native currency. For derivatives, this is the reference principal used to compute cash flows and risk sensitivities.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pnlDaily rdf:type rdf:Property ;
    rdfs:label 'Pnl Daily' ;
    rdfs:comment 'Daily P&L for the position representing the change in MTM value from the prior business day. Used for P&L attribution analysis, backtesting of VaR models, and FRTB IMA P&L attribution test (PLAT) compliance.' ;
    rdfs:domain ind:MarketRiskPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:positionDate rdf:type rdf:Property ;
    rdfs:label 'Position Date' ;
    rdfs:comment 'The business date (valuation date) for which this risk position snapshot is captured. Represents the as-of date for all MTM values, sensitivities, and risk measures on this record.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:positionReference rdf:type rdf:Property ;
    rdfs:label 'Position Reference' ;
    rdfs:comment 'Externally-known business identifier for the risk position as assigned by the source trading or risk system (e.g., Murex position ID or Calypso deal reference). Used for reconciliation with the system of record.' ;
    rdfs:domain ind:MarketRiskPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionStatus rdf:type rdf:Property ;
    rdfs:label 'Position Status' ;
    rdfs:comment 'Current lifecycle state of the risk position indicating whether it is actively open, closed out, suspended pending review, awaiting settlement, or cancelled.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repricingBucket rdf:type rdf:Property ;
    rdfs:label 'Repricing Bucket' ;
    rdfs:comment 'Time bucket classification for the repricing gap analysis (e.g., overnight, 1M, 3M, 6M, 1Y, 2Y, 5Y, 10Y+). Indicates when the position\'s interest rate resets or matures, driving IRRBB gap analysis and NII sensitivity computation. [ENUM-REF-CANDIDATE: overnight|1M|3M|6M|1Y|2Y|5Y|10Y_plus — promote to reference product]' ;
    rdfs:domain ind:MarketRiskPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repricingGap rdf:type rdf:Property ;
    rdfs:label 'Repricing Gap' ;
    rdfs:comment 'The net difference between rate-sensitive assets and rate-sensitive liabilities repricing within a given time bucket. Used in IRRBB repricing gap analysis to identify mismatches that create NII at risk. Applicable to banking book positions.' ;
    rdfs:domain ind:MarketRiskPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rwaMarketRisk rdf:type rdf:Property ;
    rdfs:label 'Rwa Market Risk' ;
    rdfs:comment 'Risk-Weighted Assets attributable to market risk for this position, computed as the capital charge multiplied by 12.5 (reciprocal of the 8% minimum capital ratio). Used in CET1 ratio and CCAR/DFAST capital adequacy reporting.' ;
    rdfs:domain ind:MarketRiskPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stressedVar rdf:type rdf:Property ;
    rdfs:label 'Stressed Var' ;
    rdfs:comment 'Stressed VaR computed using a continuous 12-month historical stress period calibrated to significant financial stress (e.g., 2008 financial crisis). Required under Basel 2.5 and used as a multiplier component in market risk capital calculation.' ;
    rdfs:domain ind:MarketRiskPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:var10d99 rdf:type rdf:Property ;
    rdfs:label 'Var 10d 99' ;
    rdfs:comment 'Ten-day Value at Risk at 99% confidence level, scaled from the 1-day VaR using the square-root-of-time rule or direct simulation. Used for regulatory capital calculation under Basel 2.5 market risk framework.' ;
    rdfs:domain ind:MarketRiskPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:var1d99 rdf:type rdf:Property ;
    rdfs:label 'Var 1d 99' ;
    rdfs:comment 'One-day Value at Risk at 99% confidence level computed using historical simulation methodology. Represents the maximum expected loss over a one-day horizon with 99% probability. Primary regulatory VaR metric under Basel 2.5 and FRTB IMA.' ;
    rdfs:domain ind:MarketRiskPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vega rdf:type rdf:Property ;
    rdfs:label 'Vega' ;
    rdfs:comment 'Sensitivity of the position\'s MTM value to a 1% change in implied volatility of the underlying. Applicable to options and volatility-sensitive instruments. Used in FRTB SA vega risk charge calculation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collateralValuationId rdf:type rdf:Property ;
    rdfs:label 'Collateral Valuation Id' ;
    rdfs:comment 'Foreign key linking to collateral.collateral_valuation. Business justification: IFRS9 ECL LGD estimation requires the current collateral valuation to compute recoverable amounts. risk_ecl_provision.collateral_value is a denormalized copy of collateral_valuation.net_collateral_val' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CollateralValuation .

ind:loanAccountId rdf:type rdf:Property ;
    rdfs:label 'Loan Account Id' ;
    rdfs:comment 'Reference to the underlying loan or credit facility for which the ECL provision is calculated. Links to the loan master record in the Core Banking System (Temenos T24 / FIS Profile) or Loan Origination System (Finastra Fusion Loan IQ).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LoanAccount .

ind:ceclPoolClassification rdf:type rdf:Property ;
    rdfs:label 'Cecl Pool Classification' ;
    rdfs:comment 'FASB ASC 326 (CECL) pool or segment classification used for collective assessment of expected credit losses. Identifies the homogeneous risk pool to which the instrument is assigned for CECL measurement purposes. [ENUM-REF-CANDIDATE: commercial_real_estate|commercial_industrial|consumer_mortgage|consumer_auto|consumer_unsecured|credit_card|other — promote to reference product]' ;
    rdfs:domain ind:RiskEclProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectiveAssessmentFlag rdf:type rdf:Property ;
    rdfs:label 'Collective Assessment Flag' ;
    rdfs:comment 'Indicates whether the ECL provision was calculated on a collective (pooled) basis rather than an individual (specific) basis. Collective assessment is applied when individual assessment is not practicable, typically for homogeneous retail portfolios.' ;
    rdfs:domain ind:RiskEclProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cureStatus rdf:type rdf:Property ;
    rdfs:label 'Cure Status' ;
    rdfs:comment 'Indicates the cure or exit status of a previously defaulted or forborne exposure. Tracks whether the borrower has exited NPL/forbearance status, is in the probation period, has been fully cured, or has re-defaulted.' ;
    rdfs:domain ind:RiskEclProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysPastDue rdf:type rdf:Property ;
    rdfs:label 'Days Past Due' ;
    rdfs:comment 'Number of calendar days the credit obligation is past its contractual due date as of the reporting date. Key trigger for stage migration (>30 DPD for Stage 2, >90 DPD for Stage 3 / NPL under EBA definition) and NPL classification.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:defaultFlag rdf:type rdf:Property ;
    rdfs:label 'Default Flag' ;
    rdfs:comment 'Indicates whether the obligor is in default as defined under Basel III IRB framework (>90 DPD or unlikely-to-pay criteria). Triggers Stage 3 classification under IFRS 9 and NPL status under EBA definition.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discountRate rdf:type rdf:Property ;
    rdfs:label 'Discount Rate' ;
    rdfs:comment 'The effective interest rate used to discount future expected credit loss cash flows to present value as of the reporting date. Per IFRS 9, this is the original effective interest rate (or credit-adjusted EIR for POCI assets).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eadAmount rdf:type rdf:Property ;
    rdfs:label 'Ead Amount' ;
    rdfs:comment 'Estimated gross exposure of the credit facility at the point of default, expressed in the instrument currency. Represents the outstanding balance plus expected drawdowns on undrawn commitments used as the base for ECL calculation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ecl12monthAmount rdf:type rdf:Property ;
    rdfs:label 'Ecl 12month Amount' ;
    rdfs:comment 'Calculated 12-month ECL provision amount representing the probability-weighted credit loss from default events expected within 12 months of the reporting date. Applied to Stage 1 exposures. Computed as PD_12month × LGD × EAD discounted at the effective interest rate.' ;
    rdfs:domain ind:RiskEclProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eclLifetimeAmount rdf:type rdf:Property ;
    rdfs:label 'Ecl Lifetime Amount' ;
    rdfs:comment 'Calculated lifetime ECL provision amount representing the probability-weighted credit loss over the remaining life of the instrument. Applied to Stage 2 and Stage 3 exposures under IFRS 9 and all exposures under CECL.' ;
    rdfs:domain ind:RiskEclProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forbearanceFlag rdf:type rdf:Property ;
    rdfs:label 'Forbearance Flag' ;
    rdfs:comment 'Indicates whether the credit exposure has been subject to forbearance measures (concessions granted to a borrower experiencing financial difficulty). Forbearance status affects stage classification and NPL reporting under EBA guidelines.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ifrs9Stage rdf:type rdf:Property ;
    rdfs:label 'Ifrs9 Stage' ;
    rdfs:comment 'IFRS 9 credit impairment stage classification: Stage 1 (performing, 12-month ECL), Stage 2 (significant increase in credit risk, lifetime ECL), Stage 3 (credit-impaired, lifetime ECL). Drives the ECL measurement horizon and provision methodology.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lgdEstimate rdf:type rdf:Property ;
    rdfs:label 'Lgd Estimate' ;
    rdfs:comment 'Estimated proportion of the EAD that would be lost in the event of default, expressed as a decimal (e.g., 0.45 = 45%). Reflects collateral coverage, seniority, and recovery expectations. Key input to ECL and IRB RWA calculation.' ;
    rdfs:domain ind:RiskEclProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ltvRatio rdf:type rdf:Property ;
    rdfs:label 'Ltv Ratio' ;
    rdfs:comment 'Ratio of the outstanding loan balance to the current collateral value, expressed as a decimal (e.g., 0.75 = 75% LTV). Key risk indicator for secured lending provisions, particularly mortgage portfolios. Influences LGD and stage classification.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:macroOverlayFactor rdf:type rdf:Property ;
    rdfs:label 'Macro Overlay Factor' ;
    rdfs:comment 'Forward-looking macroeconomic adjustment factor applied to the base ECL model output to incorporate point-in-time economic conditions (e.g., GDP growth, unemployment rate, house price index scenarios). Reflects IFRS 9 requirement for unbiased, probability-weighted forward-looking information.' ;
    rdfs:domain ind:RiskEclProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:macroScenarioWeight rdf:type rdf:Property ;
    rdfs:label 'Macro Scenario Weight' ;
    rdfs:comment 'Probability weight assigned to the macroeconomic scenario (base, upside, downside) used in the probability-weighted ECL calculation. The sum of scenario weights across all scenarios for a given exposure must equal 1.0.' ;
    rdfs:domain ind:RiskEclProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nplClassification rdf:type rdf:Property ;
    rdfs:label 'Npl Classification' ;
    rdfs:comment 'Regulatory asset quality classification of the credit exposure per OCC and EBA NPL frameworks: performing, watch list, substandard, doubtful, or loss. Drives regulatory capital and provisioning requirements under the standardized approach.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nplEntryDate rdf:type rdf:Property ;
    rdfs:label 'Npl Entry Date' ;
    rdfs:comment 'Date on which the credit exposure was first classified as non-performing under the EBA NPL definition. Used for NPL vintage analysis, cure period tracking, and EBA NPL ratio reporting.' ;
    rdfs:domain ind:RiskEclProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pd12month rdf:type rdf:Property ;
    rdfs:label 'Pd 12month' ;
    rdfs:comment 'Estimated probability that the obligor will default within the next 12 months, expressed as a decimal (e.g., 0.00250 = 0.25%). Used for Stage 1 ECL calculation and IRB capital requirement computation.' ;
    rdfs:domain ind:RiskEclProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pdLifetime rdf:type rdf:Property ;
    rdfs:label 'Pd Lifetime' ;
    rdfs:comment 'Estimated probability that the obligor will default over the remaining contractual life of the instrument. Used for Stage 2 and Stage 3 lifetime ECL calculation under IFRS 9.' ;
    rdfs:domain ind:RiskEclProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pociFlag rdf:type rdf:Property ;
    rdfs:label 'Poci Flag' ;
    rdfs:comment 'Indicates whether the financial instrument was purchased or originated as credit-impaired (POCI). POCI assets use a credit-adjusted effective interest rate and lifetime ECL from initial recognition under IFRS 9.' ;
    rdfs:domain ind:RiskEclProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:portfolioSegment rdf:type rdf:Property ;
    rdfs:label 'Portfolio Segment' ;
    rdfs:comment 'High-level portfolio segment classification of the credit exposure for ECL modeling and regulatory reporting purposes. Determines the applicable IRB sub-model (retail, corporate, sovereign, etc.) and CECL pool assignment.' ;
    rdfs:domain ind:RiskEclProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:provisionAmount rdf:type rdf:Property ;
    rdfs:label 'Provision Amount' ;
    rdfs:comment 'The recognized ECL provision balance recorded on the balance sheet as of the reporting date. Equals ecl_12month_amount for Stage 1 or ecl_lifetime_amount for Stage 2/3. This is the gross provision before any write-offs.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:provisionMovementAmount rdf:type rdf:Property ;
    rdfs:label 'Provision Movement Amount' ;
    rdfs:comment 'Net change in the provision balance during the reporting period (current period provision minus prior period provision). Positive values indicate an increase (charge to P&L); negative values indicate a release (credit to P&L). Used for income statement impairment charge reporting.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:provisionReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Provision Reference Number' ;
    rdfs:comment 'Externally-known business identifier for the ECL provision record, used for cross-system reconciliation and regulatory reporting. Typically sourced from the Risk Management Platform (SAS Risk Management / Moodys RiskAuthority).' ;
    rdfs:domain ind:RiskEclProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:provisionStatus rdf:type rdf:Property ;
    rdfs:label 'Provision Status' ;
    rdfs:comment 'Current lifecycle status of the ECL provision record. Indicates whether the provision is active, has been reversed upon cure, transferred to another stage, written off, or is under review.' ;
    rdfs:domain ind:RiskEclProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recoveryExpectationAmount rdf:type rdf:Property ;
    rdfs:label 'Recovery Expectation Amount' ;
    rdfs:comment 'Estimated amount expected to be recovered from a written-off or defaulted exposure through collateral realization, guarantees, or workout proceedings. Informs the net LGD estimate and provision adequacy assessment.' ;
    rdfs:domain ind:RiskEclProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportingDate rdf:type rdf:Property ;
    rdfs:label 'Reporting Date' ;
    rdfs:comment 'The balance sheet or reporting reference date as of which the ECL provision is measured and staged. Represents the principal business event date for this record, used for period-end regulatory and financial reporting.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sicrFlag rdf:type rdf:Property ;
    rdfs:label 'Sicr Flag' ;
    rdfs:comment 'Indicates whether a significant increase in credit risk has been identified for this exposure since initial recognition, triggering migration from Stage 1 to Stage 2 under IFRS 9. Based on quantitative and qualitative SICR criteria.' ;
    rdfs:domain ind:RiskEclProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stageMigrationDate rdf:type rdf:Property ;
    rdfs:label 'Stage Migration Date' ;
    rdfs:comment 'Date on which the most recent IFRS 9 stage migration occurred (e.g., Stage 1 to Stage 2, Stage 2 to Stage 3, or back-migration). Supports stage migration analysis, provision volatility monitoring, and audit trail requirements.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:writeOffAmount rdf:type rdf:Property ;
    rdfs:label 'Write Off Amount' ;
    rdfs:comment 'Cumulative amount of the credit exposure that has been written off against the provision balance, reducing both the gross loan balance and the provision. Triggered when there is no reasonable expectation of recovery.' ;
    rdfs:domain ind:RiskEclProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:analystOverrideFlag rdf:type rdf:Property ;
    rdfs:label 'Analyst Override Flag' ;
    rdfs:comment 'Indicates whether a credit analyst has manually overridden the model-generated rating. True = override applied. Overrides must be documented and approved per credit policy. Supports model performance monitoring and governance.' ;
    rdfs:domain ind:CounterpartyRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:defaultDate rdf:type rdf:Property ;
    rdfs:label 'Default Date' ;
    rdfs:comment 'The date on which the counterparty was classified as in default per the Basel III definition (CRR Article 178). Null if the counterparty has never defaulted. Used for LGD estimation and historical default analysis.' ;
    rdfs:domain ind:CounterpartyRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eclStage rdf:type rdf:Property ;
    rdfs:label 'Ecl Stage' ;
    rdfs:comment 'The IFRS 9 / CECL impairment stage assigned to this counterparty: Stage 1 (performing, 12-month ECL), Stage 2 (significant increase in credit risk, lifetime ECL), Stage 3 (credit-impaired, lifetime ECL). Drives provisioning and financial reporting.' ;
    rdfs:domain ind:CounterpartyRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalRatingDate rdf:type rdf:Property ;
    rdfs:label 'External Rating Date' ;
    rdfs:comment 'The date of the most recent external agency rating action (S&P, Moody\'s, or Fitch). Used to assess the currency of external ratings for regulatory and credit purposes.' ;
    rdfs:domain ind:CounterpartyRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fitchRating rdf:type rdf:Property ;
    rdfs:label 'Fitch Rating' ;
    rdfs:comment 'The most recent long-term issuer credit rating assigned by Fitch Ratings (e.g., AAA, A+, BBB-, BB). Used for external benchmark comparison, regulatory SA risk weight mapping, and credit underwriting.' ;
    rdfs:domain ind:CounterpartyRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moodysRating rdf:type rdf:Property ;
    rdfs:label 'Moodys Rating' ;
    rdfs:comment 'The most recent long-term issuer credit rating assigned by Moody\'s Investors Service (e.g., Aaa, Aa1, Baa2, Ba3). Used for external benchmark comparison, regulatory SA risk weight mapping, and credit underwriting.' ;
    rdfs:domain ind:CounterpartyRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideDirection rdf:type rdf:Property ;
    rdfs:label 'Override Direction' ;
    rdfs:comment 'Indicates whether the analyst override resulted in an upgrade or downgrade relative to the model-generated rating. Null if no override is in effect. Used for override tracking and model performance analysis.' ;
    rdfs:domain ind:CounterpartyRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideReason rdf:type rdf:Property ;
    rdfs:label 'Override Reason' ;
    rdfs:comment 'Free-text justification provided by the credit analyst for the rating override. Required when analyst_override_flag is True. Supports audit trail and credit governance review.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorRatingCode rdf:type rdf:Property ;
    rdfs:label 'Prior Rating Code' ;
    rdfs:comment 'The internal rating grade code assigned to this counterparty immediately prior to the current rating. Enables rating migration analysis and transition matrix construction for credit risk modelling.' ;
    rdfs:domain ind:CounterpartyRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorRatingDate rdf:type rdf:Property ;
    rdfs:label 'Prior Rating Date' ;
    rdfs:comment 'The date on which the prior internal rating grade was assigned. Used in conjunction with prior_rating_code to construct rating migration history and transition matrices.' ;
    rdfs:domain ind:CounterpartyRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ratingApproach rdf:type rdf:Property ;
    rdfs:label 'Rating Approach' ;
    rdfs:comment 'Regulatory capital approach under which this rating is used: Internal Ratings-Based (IRB), Standardized Approach (SA), Foundation IRB (FIRB), or Advanced IRB (AIRB). Determines RWA calculation methodology.' ;
    rdfs:domain ind:CounterpartyRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingCode rdf:type rdf:Property ;
    rdfs:label 'Rating Code' ;
    rdfs:comment 'The internal credit rating grade code assigned to the counterparty under the bank\'s Internal Ratings-Based (IRB) model (e.g., 1A, 2B, CG3). Represents the bank\'s own assessment of creditworthiness.' ;
    rdfs:domain ind:CounterpartyRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingCommitteeApproval rdf:type rdf:Property ;
    rdfs:label 'Rating Committee Approval' ;
    rdfs:comment 'Indicates whether this rating was reviewed and approved by a formal credit rating committee (as opposed to individual analyst approval). True = committee-approved. Required for large or complex exposures per credit policy.' ;
    rdfs:domain ind:CounterpartyRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ratingDate rdf:type rdf:Property ;
    rdfs:label 'Rating Date' ;
    rdfs:comment 'The date on which the current internal credit rating was formally assigned or last affirmed by the credit analyst or rating committee. Represents the principal business event date for this rating record.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ratingDescription rdf:type rdf:Property ;
    rdfs:label 'Rating Description' ;
    rdfs:comment 'Human-readable description of the internal rating grade (e.g., \'Investment Grade — Strong\', \'Sub-Investment Grade — Speculative\'). Provides qualitative context for the rating code.' ;
    rdfs:domain ind:CounterpartyRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingMethodology rdf:type rdf:Property ;
    rdfs:label 'Rating Methodology' ;
    rdfs:comment 'The name or code of the credit rating methodology applied to derive this rating (e.g., \'Corporate Scorecard v3.2\', \'Financial Institution Model v2.1\', \'Sovereign Rating Framework\'). Supports model governance and audit trail.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingModelVersion rdf:type rdf:Property ;
    rdfs:label 'Rating Model Version' ;
    rdfs:comment 'The version identifier of the rating model or scorecard used to produce this rating (e.g., \'v3.2\', \'2024.1\'). Supports model lifecycle management, backtesting, and SR 11-7 model inventory compliance.' ;
    rdfs:domain ind:CounterpartyRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingOutlook rdf:type rdf:Property ;
    rdfs:label 'Rating Outlook' ;
    rdfs:comment 'The rating outlook indicating the likely direction of the credit rating over the medium term (12–24 months). Applies to both internal and external ratings. Values: positive, stable, negative, developing.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingStatus rdf:type rdf:Property ;
    rdfs:label 'Rating Status' ;
    rdfs:comment 'Current lifecycle status of the rating record. \'active\' indicates the rating is in force; \'under_review\' indicates a rating action is pending; \'withdrawn\' indicates the rating has been formally removed; \'override\' indicates an analyst override is in effect.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingTriggerEvent rdf:type rdf:Property ;
    rdfs:label 'Rating Trigger Event' ;
    rdfs:comment 'The business event that triggered this rating action or review. [ENUM-REF-CANDIDATE: annual_review|financial_update|covenant_breach|market_event|acquisition|analyst_initiated|regulatory_requirement|credit_deterioration|other — promote to reference product]' ;
    rdfs:domain ind:CounterpartyRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingType rdf:type rdf:Property ;
    rdfs:label 'Rating Type' ;
    rdfs:comment 'Classifies whether this rating applies to the obligor/counterparty as a whole, a specific facility, an issuer, or a specific debt issue. Determines the scope of the rating assignment.' ;
    rdfs:domain ind:CounterpartyRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rwaRiskWeight rdf:type rdf:Property ;
    rdfs:label 'Rwa Risk Weight' ;
    rdfs:comment 'The regulatory risk weight percentage assigned to this counterparty under the applicable Basel III approach (IRB or SA), expressed as a decimal (e.g., 0.75 = 75%). Directly drives Risk-Weighted Assets (RWA) calculation for capital adequacy.' ;
    rdfs:domain ind:CounterpartyRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spRating rdf:type rdf:Property ;
    rdfs:label 'Sp Rating' ;
    rdfs:comment 'The most recent long-term issuer credit rating assigned by S&P Global Ratings (e.g., AAA, AA+, BBB-, BB). Used for external benchmark comparison, regulatory SA risk weight mapping, and credit underwriting.' ;
    rdfs:domain ind:CounterpartyRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:watchStatus rdf:type rdf:Property ;
    rdfs:label 'Watch Status' ;
    rdfs:comment 'Indicates whether the counterparty\'s rating is currently on a rating watch list, and the direction of the potential rating action. \'none\' indicates no active watch. Signals near-term rating change risk.' ;
    rdfs:domain ind:CounterpartyRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primarySupersededByStressScenarioId rdf:type rdf:Property ;
    rdfs:label 'Primary Superseded By Stress Scenario Id' ;
    rdfs:comment 'Reference to the stress_scenario_id of the newer scenario that supersedes this record when approval_status = \'superseded\'. Enables scenario lineage tracking and version chain navigation for audit and regulatory review purposes.' ;
    rdfs:domain ind:StressScenario ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StressScenario .

ind:sourceScenarioStressScenarioId rdf:type rdf:Property ;
    rdfs:label 'Source Scenario Stress Scenario Id' ;
    rdfs:comment 'The native identifier of this stress scenario in the originating source system (e.g., AxiomSL scenario ID, OneSumX scenario reference). Enables traceability from the lakehouse silver layer back to the operational system of record.' ;
    rdfs:domain ind:StressScenario ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StressScenario .

ind:approvedBy rdf:type rdf:Property ;
    rdfs:label 'Approved By' ;
    rdfs:comment 'Name or identifier of the governance body or senior officer who formally approved the stress scenario (e.g., \'Board Risk Committee\', \'ALCO\', \'Chief Risk Officer\'). Supports model risk governance and regulatory audit requirements.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cet1FloorPct rdf:type rdf:Property ;
    rdfs:label 'Cet1 Floor Pct' ;
    rdfs:comment 'The minimum CET1 capital ratio floor assumed or targeted under this stress scenario, expressed as a percentage. Used to assess whether the bank maintains adequate capital buffers above regulatory minimums (4.5% CET1 minimum under Basel III) throughout the stress horizon.' ;
    rdfs:domain ind:StressScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:crePriceShockPct rdf:type rdf:Property ;
    rdfs:label 'Cre Price Shock Pct' ;
    rdfs:comment 'The peak-to-trough decline in commercial real estate prices assumed under this scenario, expressed as a percentage. Key driver for CRE loan portfolio stress testing, collateral valuation, and LTV-based ECL estimation under CECL/IFRS 9.' ;
    rdfs:domain ind:StressScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditSpreadShockBps rdf:type rdf:Property ;
    rdfs:label 'Credit Spread Shock Bps' ;
    rdfs:comment 'The widening of corporate/sovereign credit spreads assumed under this scenario, expressed in basis points. Drives mark-to-market losses on bond portfolios, CVA stress, and CDS pricing in trading book stress tests under FRTB.' ;
    rdfs:domain ind:StressScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:equityPriceShockPct rdf:type rdf:Property ;
    rdfs:label 'Equity Price Shock Pct' ;
    rdfs:comment 'The percentage decline in broad equity market indices (e.g., S&P 500) assumed under this scenario (e.g., -50.00 for a 50% market decline). Drives mark-to-market losses on equity portfolios, CVA stress, and trading book VaR under FRTB.' ;
    rdfs:domain ind:StressScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fxShockPct rdf:type rdf:Property ;
    rdfs:label 'Fx Shock Pct' ;
    rdfs:comment 'The percentage depreciation or appreciation of the USD (or base currency) against major foreign currencies assumed under this scenario. Drives FX translation losses, cross-currency swap valuation, and international portfolio stress.' ;
    rdfs:domain ind:StressScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gdpGrowthShockPct rdf:type rdf:Property ;
    rdfs:label 'Gdp Growth Shock Pct' ;
    rdfs:comment 'The peak-to-trough or annualized GDP growth rate shock applied under this scenario, expressed as a percentage (e.g., -8.50 for an 8.5% contraction). A key macroeconomic variable in CCAR/DFAST scenarios used to drive credit loss and revenue projections.' ;
    rdfs:domain ind:StressScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geographicScope rdf:type rdf:Property ;
    rdfs:label 'Geographic Scope' ;
    rdfs:comment 'The geographic coverage of the stress scenario. \'global\' = worldwide macroeconomic shock; \'domestic\' = US-only scenario; \'regional\' = specific geographic region (e.g., Europe, Asia-Pacific); \'legal_entity_specific\' = applies to a specific legal entity or subsidiary.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hpiShockPct rdf:type rdf:Property ;
    rdfs:label 'Hpi Shock Pct' ;
    rdfs:comment 'The peak-to-trough decline in the House Price Index (HPI) assumed under this scenario, expressed as a percentage (e.g., -25.00 for a 25% decline). Critical for mortgage portfolio stress testing and LTV-based credit loss estimation.' ;
    rdfs:domain ind:StressScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inflationRateShockPct rdf:type rdf:Property ;
    rdfs:label 'Inflation Rate Shock Pct' ;
    rdfs:comment 'The peak inflation rate (CPI/PCE) assumed under this scenario, expressed as a percentage. Used in real rate calculations, ALM stress testing, and cost-of-funds projections under CCAR/DFAST and ICAAP.' ;
    rdfs:domain ind:StressScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isRegulatoryPrescribed rdf:type rdf:Property ;
    rdfs:label 'Is Regulatory Prescribed' ;
    rdfs:comment 'Indicates whether this scenario was prescribed by a regulatory authority (True) or developed internally by the bank (False). Regulatory-prescribed scenarios (e.g., Fed CCAR scenarios) have mandatory use requirements and cannot be modified by the bank.' ;
    rdfs:domain ind:StressScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReverseStress rdf:type rdf:Property ;
    rdfs:label 'Is Reverse Stress' ;
    rdfs:comment 'Indicates whether this scenario is a reverse stress test (True), i.e., a scenario designed to identify conditions that would cause the bank to fail or breach critical thresholds, working backwards from the outcome. Required under PRA SS3/13 and BCBS stress testing principles.' ;
    rdfs:domain ind:StressScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lcrFloorPct rdf:type rdf:Property ;
    rdfs:label 'Lcr Floor Pct' ;
    rdfs:comment 'The minimum Liquidity Coverage Ratio (LCR) floor assumed under this stress scenario, expressed as a percentage. Used in liquidity stress testing to assess whether the bank maintains sufficient high-quality liquid assets (HQLA) under the scenario conditions.' ;
    rdfs:domain ind:StressScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lgdMultiplier rdf:type rdf:Property ;
    rdfs:label 'Lgd Multiplier' ;
    rdfs:comment 'The scalar multiplier applied to baseline Loss Given Default (LGD) estimates under this scenario to derive stressed LGD inputs for ECL/CECL and RWA stress calculations. Reflects collateral value deterioration and recovery rate compression under stress.' ;
    rdfs:domain ind:StressScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineOfBusinessScope rdf:type rdf:Property ;
    rdfs:label 'Line Of Business Scope' ;
    rdfs:comment 'The line of business or portfolio segment to which this scenario applies (e.g., \'All LOBs\', \'Commercial Lending\', \'Trading Book\', \'Retail Banking\'). Null or \'All LOBs\' indicates enterprise-wide applicability. Supports LOB-level stress attribution.' ;
    rdfs:domain ind:StressScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:longTermRateShockBps rdf:type rdf:Property ;
    rdfs:label 'Long Term Rate Shock Bps' ;
    rdfs:comment 'The shock to long-term interest rates (e.g., 10-year Treasury yield) applied under this scenario, expressed in basis points (BPS). Used in bond portfolio valuation, NII stress testing, and duration/convexity analysis under CCAR/DFAST.' ;
    rdfs:domain ind:StressScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pdMultiplier rdf:type rdf:Property ;
    rdfs:label 'Pd Multiplier' ;
    rdfs:comment 'The scalar multiplier applied to baseline Probability of Default (PD) estimates under this scenario to derive stressed PD inputs for ECL/CECL calculations and RWA stress testing. A value of 2.50 means stressed PD = 2.5x baseline PD. Used in IRB model stress testing.' ;
    rdfs:domain ind:StressScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryProgram rdf:type rdf:Property ;
    rdfs:label 'Regulatory Program' ;
    rdfs:comment 'The regulatory or internal stress testing program under which this scenario is defined. CCAR = Comprehensive Capital Analysis and Review (Fed); DFAST = Dodd-Frank Act Stress Testing (OCC/Fed); ICAAP = Internal Capital Adequacy Assessment Process; EBA = European Banking Authority stress test; ILAAP = Internal Liquidity Adequacy Assessment Process; INTERNAL = bank-defined internal stress program; CECL = Current Expected Credit Losses scenario; IFRS9 = IFRS 9 forward-looking scenario. [ENUM-REF-CANDIDATE: CCAR|DFAST|ICAAP|EBA|ILAAP|INTERNAL|CECL|IFRS9 — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rwaScalar rdf:type rdf:Property ;
    rdfs:label 'Rwa Scalar' ;
    rdfs:comment 'The scalar factor applied to baseline Risk-Weighted Assets (RWA) under this scenario to project stressed RWA for capital adequacy assessment. Used in CCAR/DFAST capital ratio projections and CET1 depletion analysis.' ;
    rdfs:domain ind:StressScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scenarioCode rdf:type rdf:Property ;
    rdfs:label 'Scenario Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the stress scenario within the regulatory program or internal stress framework (e.g., CCAR-2024-SA, DFAST-2024-ADV, ICAAP-2024-BL). Used as the business key for cross-system referencing in AxiomSL/OneSumX.' ;
    rdfs:domain ind:StressScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scenarioDescription rdf:type rdf:Property ;
    rdfs:label 'Scenario Description' ;
    rdfs:comment 'Narrative description of the macroeconomic and financial conditions assumed under the stress scenario, including the economic story, key assumptions, and the nature of the shock being modeled.' ;
    rdfs:domain ind:StressScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scenarioHorizonQuarters rdf:type rdf:Property ;
    rdfs:label 'Scenario Horizon Quarters' ;
    rdfs:comment 'The projection horizon of the stress scenario expressed in quarters. Standard CCAR/DFAST horizon is 9 quarters (13 quarters for certain programs). Determines the length of the macroeconomic variable path and the stress run projection period.' ;
    rdfs:domain ind:StressScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scenarioName rdf:type rdf:Property ;
    rdfs:label 'Scenario Name' ;
    rdfs:comment 'Human-readable descriptive name of the stress scenario (e.g., \'2024 CCAR Severely Adverse\', \'2024 DFAST Adverse\', \'Internal Recession Scenario Q1-2024\'). Used in regulatory submissions, board presentations, and risk reporting.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scenarioSeverity rdf:type rdf:Property ;
    rdfs:label 'Scenario Severity' ;
    rdfs:comment 'Severity classification of the stress scenario per regulatory and internal taxonomy. \'baseline\' = expected/central economic path; \'adverse\' = moderate stress; \'severely_adverse\' = severe recession/crisis conditions; \'reverse_stress\' = scenario designed to cause failure; \'exploratory\' = ad-hoc sensitivity analysis.' ;
    rdfs:domain ind:StressScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scenarioSource rdf:type rdf:Property ;
    rdfs:label 'Scenario Source' ;
    rdfs:comment 'The originating authority or institution that published or defined the stress scenario. \'federal_reserve\' = Fed-prescribed CCAR/DFAST scenario; \'occ\' = OCC-prescribed scenario; \'eba\' = European Banking Authority; \'pra\' = Prudential Regulation Authority; \'internal\' = bank-developed scenario; \'imf\' = IMF FSAP scenario; \'bis\' = BIS/BCBS scenario. [ENUM-REF-CANDIDATE: federal_reserve|occ|fdic|eba|pra|internal|imf|bis — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StressScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scenarioType rdf:type rdf:Property ;
    rdfs:label 'Scenario Type' ;
    rdfs:comment 'Classification of the primary risk driver modeled in the scenario. \'macroeconomic\' = GDP/unemployment/inflation shocks; \'market_risk\' = interest rate/FX/equity shocks; \'credit_risk\' = credit spread/default rate shocks; \'liquidity\' = funding/liquidity stress; \'operational\' = operational risk events; \'combined\' = multi-risk-factor scenario; \'idiosyncratic\' = firm-specific stress. [ENUM-REF-CANDIDATE: macroeconomic|market_risk|credit_risk|liquidity|operational|combined|idiosyncratic — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scenarioVintage rdf:type rdf:Property ;
    rdfs:label 'Scenario Vintage' ;
    rdfs:comment 'The publication or reference vintage of the scenario, typically expressed as a year (e.g., \'2024\') or year-quarter (e.g., \'2024Q1\'). Identifies the cycle in which the scenario was issued by the regulator or approved internally. Critical for tracking scenario evolution across CCAR/DFAST cycles.' ;
    rdfs:domain ind:StressScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortTermRateShockBps rdf:type rdf:Property ;
    rdfs:label 'Short Term Rate Shock Bps' ;
    rdfs:comment 'The shock to short-term interest rates (e.g., 3-month Treasury, Fed Funds Rate) applied under this scenario, expressed in basis points (BPS). Used in NII/NIM stress testing and ALM analysis. Positive = rate increase; negative = rate decrease.' ;
    rdfs:domain ind:StressScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unemploymentRateShockPct rdf:type rdf:Property ;
    rdfs:label 'Unemployment Rate Shock Pct' ;
    rdfs:comment 'The peak unemployment rate assumed under this stress scenario, expressed as a percentage (e.g., 12.50 for 12.5% peak unemployment). A primary macroeconomic driver for consumer credit loss models in CCAR/DFAST stress testing.' ;
    rdfs:domain ind:StressScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:asOfDate rdf:type rdf:Property ;
    rdfs:label 'As Of Date' ;
    rdfs:comment 'The reference balance sheet date from which the stress test projects forward. All starting positions (exposures, capital, liquidity) are measured as of this date.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capitalActionRestrictionFlag rdf:type rdf:Property ;
    rdfs:label 'Capital Action Restriction Flag' ;
    rdfs:comment 'Indicates whether this stress test result triggered restrictions on capital distributions (dividends, share buybacks) under the stress capital buffer framework or CCAR objection process.' ;
    rdfs:domain ind:StressTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:executedBy rdf:type rdf:Property ;
    rdfs:label 'Executed By' ;
    rdfs:comment 'The name or system identifier of the team, user, or automated process that initiated and executed this stress test run. Used for governance and audit trail purposes.' ;
    rdfs:domain ind:StressTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irbApproachFlag rdf:type rdf:Property ;
    rdfs:label 'Irb Approach Flag' ;
    rdfs:comment 'Indicates whether the Internal Ratings-Based (IRB) approach was used for credit risk RWA calculation in this stress test run. If False, the Standardized Approach (SA) was applied.' ;
    rdfs:domain ind:StressTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:modelVersion rdf:type rdf:Property ;
    rdfs:label 'Model Version' ;
    rdfs:comment 'Version identifier of the risk model suite (PD/LGD/EAD, market risk, liquidity models) used to generate the stress test results. Critical for model governance, backtesting, and regulatory model validation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portfolioScopeCode rdf:type rdf:Property ;
    rdfs:label 'Portfolio Scope Code' ;
    rdfs:comment 'Code identifying the portfolio or sub-portfolio subjected to this stress test run (e.g., \'ENTERPRISE\', \'COMMERCIAL_LENDING\', \'TRADING_BOOK\', \'RETAIL_MORTGAGE\'). Defines the boundary of exposure included.' ;
    rdfs:domain ind:StressTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectionEndDate rdf:type rdf:Property ;
    rdfs:label 'Projection End Date' ;
    rdfs:comment 'The final date of the stress projection horizon, calculated as as_of_date plus the stress horizon. Defines the terminal point for all stressed capital and liquidity metrics.' ;
    rdfs:domain ind:StressTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryOutcome rdf:type rdf:Property ;
    rdfs:label 'Regulatory Outcome' ;
    rdfs:comment 'The regulatory determination resulting from this stress test submission. \'no_objection\' and \'pass\' indicate capital plan approval; \'objection\' or \'fail\' require remediation. \'pending\' indicates awaiting regulatory response.' ;
    rdfs:domain ind:StressTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runCode rdf:type rdf:Property ;
    rdfs:label 'Run Code' ;
    rdfs:comment 'Externally-known business identifier for this stress test execution, used in regulatory submissions and internal reporting (e.g., CCAR-2024-ADV-001). Unique within a submission cycle.' ;
    rdfs:domain ind:StressTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runNotes rdf:type rdf:Property ;
    rdfs:label 'Run Notes' ;
    rdfs:comment 'Free-text field for qualitative commentary on this stress test run, including methodology overrides, data quality issues, management adjustments, or explanations of material deviations from prior runs.' ;
    rdfs:domain ind:StressTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runStatus rdf:type rdf:Property ;
    rdfs:label 'Run Status' ;
    rdfs:comment 'Current lifecycle state of the stress test execution. \'draft\' indicates setup not finalized; \'in_progress\' indicates computation running; \'completed\' indicates results available; \'failed\' indicates execution error; \'submitted\' indicates filed with regulator; \'superseded\' indicates replaced by a rerun.' ;
    rdfs:domain ind:StressTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runTimestamp rdf:type rdf:Property ;
    rdfs:label 'Run Timestamp' ;
    rdfs:comment 'The date and time at which the stress test computation was initiated. This is the principal business event timestamp representing when the scenario was applied to the portfolio.' ;
    rdfs:domain ind:StressTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:runType rdf:type rdf:Property ;
    rdfs:label 'Run Type' ;
    rdfs:comment 'Classification of the stress test run by its purpose. \'regulatory\' is a mandated submission run; \'internal\' is management-initiated; \'parallel\' is a shadow run alongside regulatory; \'ad_hoc\' is event-driven; \'restatement\' corrects a prior submission.' ;
    rdfs:domain ind:StressTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stressCapitalBufferPct rdf:type rdf:Property ;
    rdfs:label 'Stress Capital Buffer Pct' ;
    rdfs:comment 'The stress capital buffer (SCB) requirement derived from this stress test run, expressed as a percentage. Calculated as the maximum decline in CET1 ratio under the severely adverse scenario, subject to a 2.5% floor.' ;
    rdfs:domain ind:StressTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stressHorizonQuarters rdf:type rdf:Property ;
    rdfs:label 'Stress Horizon Quarters' ;
    rdfs:comment 'The number of quarters over which the stress scenario is projected. Standard CCAR/DFAST horizon is 9 quarters; internal stress tests may use shorter or longer horizons.' ;
    rdfs:domain ind:StressTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stressedCet1Ratio rdf:type rdf:Property ;
    rdfs:label 'Stressed Cet1 Ratio' ;
    rdfs:comment 'The minimum projected Common Equity Tier 1 (CET1) capital ratio under the stress scenario over the projection horizon, expressed as a percentage. Key regulatory output for CCAR/DFAST pass/fail determination. CET1 minimum regulatory threshold is 4.5% under Basel III.' ;
    rdfs:domain ind:StressTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stressedCvaAmount rdf:type rdf:Property ;
    rdfs:label 'Stressed Cva Amount' ;
    rdfs:comment 'The projected Credit Valuation Adjustment (CVA) on OTC derivatives under the stress scenario, in reporting currency. Represents the market value of counterparty credit risk under stressed conditions.' ;
    rdfs:domain ind:StressTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stressedEclAmount rdf:type rdf:Property ;
    rdfs:label 'Stressed Ecl Amount' ;
    rdfs:comment 'Total Expected Credit Loss (ECL) projected under the stress scenario over the full horizon, in reporting currency. Represents cumulative credit impairment charges under CECL/IFRS 9 stressed conditions.' ;
    rdfs:domain ind:StressTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stressedLcrRatio rdf:type rdf:Property ;
    rdfs:label 'Stressed Lcr Ratio' ;
    rdfs:comment 'The minimum projected Liquidity Coverage Ratio (LCR) under the stress scenario, expressed as a percentage. LCR measures the bank\'s ability to survive a 30-day liquidity stress event. Regulatory minimum is 100% under Basel III.' ;
    rdfs:domain ind:StressTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stressedLeverageRatio rdf:type rdf:Property ;
    rdfs:label 'Stressed Leverage Ratio' ;
    rdfs:comment 'The minimum projected Tier 1 leverage ratio under the stress scenario, expressed as a percentage. Calculated as Tier 1 capital divided by average total consolidated assets. Regulatory minimum is 4% for bank holding companies.' ;
    rdfs:domain ind:StressTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stressedNiiImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Stressed Nii Impact Amount' ;
    rdfs:comment 'The cumulative change in Net Interest Income (NII) projected under the stress scenario relative to the baseline over the horizon, in reporting currency. Negative values indicate NII compression under stress.' ;
    rdfs:domain ind:StressTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stressedNimBps rdf:type rdf:Property ;
    rdfs:label 'Stressed Nim Bps' ;
    rdfs:comment 'The change in Net Interest Margin (NIM) under the stress scenario relative to baseline, expressed in basis points (BPS). Captures the spread compression effect of the stress scenario on the bank\'s interest-earning assets.' ;
    rdfs:domain ind:StressTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stressedNsfrRatio rdf:type rdf:Property ;
    rdfs:label 'Stressed Nsfr Ratio' ;
    rdfs:comment 'The minimum projected Net Stable Funding Ratio (NSFR) under the stress scenario, expressed as a percentage. NSFR measures the bank\'s stable funding relative to required stable funding over a one-year horizon. Regulatory minimum is 100% under Basel III.' ;
    rdfs:domain ind:StressTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stressedPpnrAmount rdf:type rdf:Property ;
    rdfs:label 'Stressed Ppnr Amount' ;
    rdfs:comment 'Cumulative Pre-Provision Net Revenue (PPNR) projected under the stress scenario over the full horizon, in reporting currency. PPNR is a key CCAR metric representing revenue before credit loss provisions.' ;
    rdfs:domain ind:StressTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stressedRwaAmount rdf:type rdf:Property ;
    rdfs:label 'Stressed Rwa Amount' ;
    rdfs:comment 'Total Risk-Weighted Assets (RWA) projected under the stress scenario at the end of the horizon, in reporting currency. Encompasses credit RWA, market RWA, and operational RWA under stressed conditions.' ;
    rdfs:domain ind:StressTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stressedTier1Ratio rdf:type rdf:Property ;
    rdfs:label 'Stressed Tier1 Ratio' ;
    rdfs:comment 'The minimum projected Tier 1 capital ratio under the stress scenario over the projection horizon, expressed as a percentage. Includes CET1 plus Additional Tier 1 instruments. Regulatory minimum is 6% under Basel III.' ;
    rdfs:domain ind:StressTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stressedTotalCapitalRatio rdf:type rdf:Property ;
    rdfs:label 'Stressed Total Capital Ratio' ;
    rdfs:comment 'The minimum projected Total Capital ratio (Tier 1 + Tier 2) under the stress scenario over the projection horizon, expressed as a percentage. Regulatory minimum is 8% under Basel III.' ;
    rdfs:domain ind:StressTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stressedVarAmount rdf:type rdf:Property ;
    rdfs:label 'Stressed Var Amount' ;
    rdfs:comment 'The projected Value at Risk (VaR) for the trading book under the stress scenario, in reporting currency. Represents the maximum expected loss at a defined confidence level under stressed market conditions.' ;
    rdfs:domain ind:StressTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:submissionDate rdf:type rdf:Property ;
    rdfs:label 'Submission Date' ;
    rdfs:comment 'The date on which this stress test run was submitted to the relevant regulatory authority (e.g., Federal Reserve for CCAR/DFAST). Null if not yet submitted or if this is an internal run.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:submissionReference rdf:type rdf:Property ;
    rdfs:label 'Submission Reference' ;
    rdfs:comment 'The reference number or acknowledgement ID assigned by the regulatory authority upon receipt of the stress test submission (e.g., Federal Reserve submission tracking number). Null if not yet submitted.' ;
    rdfs:domain ind:StressTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liquidityMetricId rdf:type rdf:Property ;
    rdfs:label 'Liquidity Metric Id' ;
    rdfs:comment 'Unique surrogate identifier for each daily liquidity risk measurement record. Primary key for the liquidity_metric data product in the risk domain.' ;
    rdfs:domain ind:LiquidityMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:liquidityRatioId rdf:type rdf:Property ;
    rdfs:label 'Liquidity Ratio Id' ;
    rdfs:comment 'Foreign key linking to treasury.liquidity_ratio. Business justification: Risk monitoring references treasury-calculated LCR/NSFR ratios for limit monitoring, breach detection, and regulatory reporting. Risk appetite framework requires tracking actual treasury-calculated ra' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LiquidityRatio .

ind:primaryLiquidityLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Primary Liquidity Legal Entity Id' ;
    rdfs:comment 'Reference to the legal entity for which this liquidity metric record is calculated. Supports entity-level regulatory reporting to Fed, OCC, and PRA.' ;
    rdfs:domain ind:LiquidityMetric ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:alcoReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Alco Review Status' ;
    rdfs:comment 'Status of the ALCO review process for this liquidity metric record. Tracks whether the metric has been reviewed, escalated for breach, or approved by the Asset-Liability Committee for regulatory submission.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approved Timestamp' ;
    rdfs:comment 'The date and time when the liquidity metric record was formally approved by the ALCO or risk officer for regulatory submission or internal reporting. Supports governance and audit trail requirements.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:availableStableFundingAmount rdf:type rdf:Property ;
    rdfs:label 'Available Stable Funding Amount' ;
    rdfs:comment 'Total Available Stable Funding (ASF) representing the portion of capital and liabilities expected to be reliable over a one-year horizon. Numerator of the NSFR ratio.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:breachSeverity rdf:type rdf:Property ;
    rdfs:label 'Breach Severity' ;
    rdfs:comment 'Severity classification of a regulatory liquidity breach based on the magnitude of the shortfall relative to the minimum threshold. Drives escalation level and remediation response timeframe per the institution\'s liquidity contingency plan.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculationRunTimestamp rdf:type rdf:Property ;
    rdfs:label 'Calculation Run Timestamp' ;
    rdfs:comment 'The date and time when the liquidity metric calculation was executed in the risk management platform. Supports audit trail, reprocessing identification, and T+1 regulatory submission deadlines.' ;
    rdfs:domain ind:LiquidityMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:calculationStatus rdf:type rdf:Property ;
    rdfs:label 'Calculation Status' ;
    rdfs:comment 'Current workflow status of the liquidity metric record indicating whether the calculation is preliminary, final, restated, under review, or approved for regulatory submission.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:centralBankEligibleAmount rdf:type rdf:Property ;
    rdfs:label 'Central Bank Eligible Amount' ;
    rdfs:comment 'Total value of assets eligible for central bank repo or discount window operations (e.g., Fed discount window, Bank of England repo). Represents the ultimate liquidity backstop available to the institution.' ;
    rdfs:domain ind:LiquidityMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:comments rdf:type rdf:Property ;
    rdfs:label 'Comments' ;
    rdfs:comment 'Free-text commentary provided by the risk officer or ALCO analyst explaining material movements, breaches, restatements, or methodology changes for this liquidity metric record. Supports regulatory examination and internal audit.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:committedFacilityOutflowAmount rdf:type rdf:Property ;
    rdfs:label 'Committed Facility Outflow Amount' ;
    rdfs:comment 'Expected cash outflows from drawdowns on committed credit and liquidity facilities extended to customers and counterparties over the 30-day LCR stress horizon. Includes undrawn revolving credit facilities.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consolidationScope rdf:type rdf:Property ;
    rdfs:label 'Consolidation Scope' ;
    rdfs:comment 'Indicates whether the liquidity metric is calculated on a solo (single legal entity), consolidated (group-wide), or sub-consolidated basis. Determines the perimeter of assets and liabilities included in LCR/NSFR calculations.' ;
    rdfs:domain ind:LiquidityMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:encumberedAssetsAmount rdf:type rdf:Property ;
    rdfs:label 'Encumbered Assets Amount' ;
    rdfs:comment 'Total value of assets pledged as collateral or otherwise encumbered (e.g., repo, covered bonds, central bank pledges) and therefore excluded from the HQLA buffer. Critical for accurate HQLA calculation.' ;
    rdfs:domain ind:LiquidityMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossCashInflowAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Cash Inflow Amount' ;
    rdfs:comment 'Total expected gross cash inflows over the 30-day LCR stress horizon, capped at 75% of gross outflows per Basel III rules. Includes contractual loan repayments and securities maturities.' ;
    rdfs:domain ind:LiquidityMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossCashOutflowAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Cash Outflow Amount' ;
    rdfs:comment 'Total expected gross cash outflows over the 30-day LCR stress horizon before netting of inflows. Includes retail deposit runoff, wholesale funding outflows, and off-balance-sheet commitments.' ;
    rdfs:domain ind:LiquidityMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hqlaAmount rdf:type rdf:Property ;
    rdfs:label 'Hqla Amount' ;
    rdfs:comment 'Total stock of High Quality Liquid Assets (HQLA) after applicable haircuts, expressed in the reporting currency. Comprises Level 1, Level 2A, and Level 2B assets as defined under the Basel III LCR framework.' ;
    rdfs:domain ind:LiquidityMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hqlaLevel1Amount rdf:type rdf:Property ;
    rdfs:label 'Hqla Level1 Amount' ;
    rdfs:comment 'Stock of Level 1 HQLA assets (e.g., central bank reserves, sovereign bonds with 0% risk weight) with no haircut applied. Highest quality component of the HQLA buffer.' ;
    rdfs:domain ind:LiquidityMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hqlaLevel2aAmount rdf:type rdf:Property ;
    rdfs:label 'Hqla Level2a Amount' ;
    rdfs:comment 'Stock of Level 2A HQLA assets (e.g., agency MBS, covered bonds, sovereign bonds with 20% risk weight) subject to a 15% haircut. Capped at 40% of total HQLA.' ;
    rdfs:domain ind:LiquidityMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hqlaLevel2bAmount rdf:type rdf:Property ;
    rdfs:label 'Hqla Level2b Amount' ;
    rdfs:comment 'Stock of Level 2B HQLA assets (e.g., non-agency RMBS, corporate bonds, equities) subject to haircuts of 25–50%. Capped at 15% of total HQLA.' ;
    rdfs:domain ind:LiquidityMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:intradayAvailableLiquidityAmount rdf:type rdf:Property ;
    rdfs:label 'Intraday Available Liquidity Amount' ;
    rdfs:comment 'Total liquidity resources available intraday at the start of the business day, including central bank reserves, committed intraday credit facilities, and unencumbered liquid assets accessible within the day.' ;
    rdfs:domain ind:LiquidityMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:intradayPeakLiquidityAmount rdf:type rdf:Property ;
    rdfs:label 'Intraday Peak Liquidity Amount' ;
    rdfs:comment 'Maximum intraday liquidity requirement observed during the reporting day, representing the peak net cumulative position across all payment systems (RTGS, ACH, SWIFT). Supports intraday liquidity monitoring per BCBS monitoring tools.' ;
    rdfs:domain ind:LiquidityMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isBreach rdf:type rdf:Property ;
    rdfs:label 'Is Breach' ;
    rdfs:comment 'Flag indicating whether the liquidity metric breaches the applicable regulatory minimum threshold (LCR < 100% or NSFR < 100%). Triggers escalation to ALCO and regulatory notification procedures.' ;
    rdfs:domain ind:LiquidityMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lcrBufferAmount rdf:type rdf:Property ;
    rdfs:label 'Lcr Buffer Amount' ;
    rdfs:comment 'Excess HQLA above the regulatory minimum LCR requirement, representing the institution\'s liquidity cushion. Calculated as HQLA minus (net cash outflows × regulatory minimum LCR). Used in ALCO reporting and internal liquidity stress testing.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lcrRatio rdf:type rdf:Property ;
    rdfs:label 'Lcr Ratio' ;
    rdfs:comment 'The Liquidity Coverage Ratio expressed as a decimal (e.g., 1.25 = 125%). Calculated as HQLA divided by total net cash outflows over a 30-day stress period. Regulatory minimum is 100% (1.00) under Basel III / Fed LCR Rule.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lcrRegulatoryMinimum rdf:type rdf:Property ;
    rdfs:label 'Lcr Regulatory Minimum' ;
    rdfs:comment 'The applicable regulatory minimum LCR threshold for this entity as of the metric date (e.g., 1.00 for 100%). May vary by jurisdiction (Fed, OCC, PRA) and entity classification (GSIB, non-GSIB).' ;
    rdfs:domain ind:LiquidityMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:liquidityTransferRestriction rdf:type rdf:Property ;
    rdfs:label 'Liquidity Transfer Restriction' ;
    rdfs:comment 'Indicates whether there are legal, regulatory, or operational restrictions on the transfer of liquidity between entities within the group (e.g., ring-fencing, local regulatory requirements). Affects consolidated vs. solo LCR/NSFR calculations.' ;
    rdfs:domain ind:LiquidityMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metricDate rdf:type rdf:Property ;
    rdfs:label 'Metric Date' ;
    rdfs:comment 'The business date (as-of date) for which the liquidity metrics are calculated. Represents the daily snapshot date used for LCR, NSFR, and intraday liquidity reporting.' ;
    rdfs:domain ind:LiquidityMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:metricType rdf:type rdf:Property ;
    rdfs:label 'Metric Type' ;
    rdfs:comment 'Classification of the liquidity metric record indicating which regulatory or internal liquidity measure is captured. Values: LCR (Liquidity Coverage Ratio), NSFR (Net Stable Funding Ratio), INTRADAY (intraday liquidity position), SURVIVAL_HORIZON, STRESS (internal stress test metric).' ;
    rdfs:domain ind:LiquidityMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netCashOutflowAmount rdf:type rdf:Property ;
    rdfs:label 'Net Cash Outflow Amount' ;
    rdfs:comment 'Total net cash outflows over the 30-calendar-day stress period, calculated as total expected cash outflows minus the minimum of total expected cash inflows and 75% of total expected cash outflows. Denominator of the LCR ratio.' ;
    rdfs:domain ind:LiquidityMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nsfrRatio rdf:type rdf:Property ;
    rdfs:label 'Nsfr Ratio' ;
    rdfs:comment 'The Net Stable Funding Ratio expressed as a decimal (e.g., 1.10 = 110%). Calculated as Available Stable Funding (ASF) divided by Required Stable Funding (RSF). Regulatory minimum is 100% (1.00) under Basel III.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nsfrRegulatoryMinimum rdf:type rdf:Property ;
    rdfs:label 'Nsfr Regulatory Minimum' ;
    rdfs:comment 'The applicable regulatory minimum NSFR threshold for this entity as of the metric date (e.g., 1.00 for 100%). Supports compliance monitoring against Fed/OCC/EBA NSFR rules.' ;
    rdfs:domain ind:LiquidityMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportingFrequency rdf:type rdf:Property ;
    rdfs:label 'Reporting Frequency' ;
    rdfs:comment 'Frequency at which this liquidity metric is calculated and reported. Daily for LCR/intraday; monthly or quarterly for NSFR and internal stress metrics. Drives scheduling in the regulatory reporting platform.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredStableFundingAmount rdf:type rdf:Property ;
    rdfs:label 'Required Stable Funding Amount' ;
    rdfs:comment 'Total Required Stable Funding (RSF) representing the amount of stable funding required to support assets and off-balance-sheet exposures over a one-year horizon. Denominator of the NSFR ratio.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retailDepositOutflowAmount rdf:type rdf:Property ;
    rdfs:label 'Retail Deposit Outflow Amount' ;
    rdfs:comment 'Expected cash outflows from retail deposits (stable and less stable) over the 30-day LCR stress horizon, applying Basel III run-off rates (3–10% for stable, 10–15% for less stable deposits).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:survivalHorizonDays rdf:type rdf:Property ;
    rdfs:label 'Survival Horizon Days' ;
    rdfs:comment 'The number of calendar days the institution can survive under a combined idiosyncratic and market-wide stress scenario without accessing wholesale funding markets. Key internal liquidity risk metric reported to ALCO.' ;
    rdfs:domain ind:LiquidityMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unencumberedAssetsAmount rdf:type rdf:Property ;
    rdfs:label 'Unencumbered Assets Amount' ;
    rdfs:comment 'Total value of assets that are free from legal, regulatory, or contractual restrictions and available to be monetized or pledged as collateral. Supports HQLA eligibility assessment.' ;
    rdfs:domain ind:LiquidityMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wholesaleFundingOutflowAmount rdf:type rdf:Property ;
    rdfs:label 'Wholesale Funding Outflow Amount' ;
    rdfs:comment 'Expected cash outflows from wholesale funding sources (e.g., interbank deposits, commercial paper, repo) over the 30-day LCR stress horizon. Key component of gross cash outflow calculation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operationalRiskEventId rdf:type rdf:Property ;
    rdfs:label 'Operational Risk Event Id' ;
    rdfs:comment 'Unique surrogate identifier for the operational risk loss event or near-miss incident record within the enterprise internal loss database. Primary key for the silver-layer data product.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OperationalRiskEvent .

ind:affectedChannelId rdf:type rdf:Property ;
    rdfs:label 'Affected Channel Id' ;
    rdfs:comment 'Foreign key linking to channel.channel. Business justification: Operational risk events (outages, fraud, process failures) must track the affected channel for root cause analysis, regulatory reporting, and remediation. Banks report operational losses by channel. R' ;
    rdfs:domain ind:OperationalRiskEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:affectedPartyId rdf:type rdf:Property ;
    rdfs:label 'Affected Party Id' ;
    rdfs:comment 'Foreign key linking to customer.party. Business justification: Basel II/III operational risk frameworks require tracking which customer was affected by an operational loss event (fraud, mis-selling, unauthorized transactions). Role prefix \'affected_\' distinguishe' ;
    rdfs:domain ind:OperationalRiskEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:amlCaseId rdf:type rdf:Property ;
    rdfs:label 'Aml Case Id' ;
    rdfs:comment 'Foreign key linking to compliance.aml_case. Business justification: Basel II/III operational risk taxonomy requires banks to track when op risk events (internal fraud, unauthorized transactions) are linked to AML investigations. Risk and compliance teams jointly revie' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AmlCase .

ind:assessmentId rdf:type rdf:Property ;
    rdfs:label 'Assessment Id' ;
    rdfs:comment 'Foreign key linking to risk.risk_assessment. Business justification: Operational risk events are often identified through RCSA (Risk and Control Self-Assessment) processes. The risk_assessment table captures RCSA records; operational_risk_event captures actual loss eve' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Assessment .

ind:atmId rdf:type rdf:Property ;
    rdfs:label 'Atm Id' ;
    rdfs:comment 'Foreign key linking to channel.atm. Business justification: ATM-specific operational risk events (card skimming, cash theft, vandalism, network fraud) require direct ATM attribution for SAR filing, insurance recovery, and network fraud reporting to Visa/Master' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Atm .

ind:captureId rdf:type rdf:Property ;
    rdfs:label 'Capture Id' ;
    rdfs:comment 'Foreign key linking to trade.capture. Business justification: Trade booking errors and amendment failures are a primary operational risk event category in trading operations. Linking operational_risk_event to the triggering trade capture enables Basel SMA/AMA lo' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Capture .

ind:executionId rdf:type rdf:Property ;
    rdfs:label 'Execution Id' ;
    rdfs:comment 'Foreign key linking to trade.execution. Business justification: Execution errors (fat-finger trades, mis-bookings, best execution failures) are a major operational risk loss category. Linking operational_risk_event to the triggering execution record enables MiFID ' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Execution .

ind:nostroAccountId rdf:type rdf:Property ;
    rdfs:label 'Nostro Account Id' ;
    rdfs:comment 'Foreign key linking to treasury.nostro_account. Business justification: Operational risk events frequently occur in nostro account operations: reconciliation breaks, settlement failures, unauthorized transactions, and fraud. Linking operational_risk_event to nostro_accoun' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NostroAccount .

ind:settlementInstructionId rdf:type rdf:Property ;
    rdfs:label 'Settlement Instruction Id' ;
    rdfs:comment 'Foreign key linking to trade.settlement_instruction. Business justification: Settlement failures are a major operational risk category under CSDR penalty regime. Linking operational_risk_event to the failed settlement_instruction enables CSDR penalty loss tracking, Basel SMA o' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SettlementInstruction .

ind:statusEventId rdf:type rdf:Property ;
    rdfs:label 'Status Event Id' ;
    rdfs:comment 'Foreign key linking to payment.status_event. Business justification: Payment status exceptions, SLA breaches, and system-generated error events are operational risk events under Basel \'Business Disruption and System Failures\' category. This link enables operational ris' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StatusEvent .

ind:accountingDate rdf:type rdf:Property ;
    rdfs:label 'Accounting Date' ;
    rdfs:comment 'The date on which the operational risk loss was recognized in the general ledger and financial statements. Used for IFRS 9 / CECL provisioning alignment and financial reporting reconciliation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:baselEventTypeCategory rdf:type rdf:Property ;
    rdfs:label 'Basel Event Type Category' ;
    rdfs:comment 'Basel III Level 1 operational risk event type category classification. Values: \'internal_fraud\' (Internal Fraud), \'external_fraud\' (External Fraud), \'epws\' (Employment Practices and Workplace Safety), \'cpbp\' (Clients Products and Business Practices), \'edpm\' (Execution Delivery and Process Management), \'bdsf\' (Business Disruption and System Failures), \'eflf\' (Damage to Physical Assets). Mandatory for SMA capital charge calculation and regulatory reporting. [ENUM-REF-CANDIDATE: internal_fraud|external_fraud|epws|cpbp|edpm|bdsf|eflf — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:OperationalRiskEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselEventTypeLevel2 rdf:type rdf:Property ;
    rdfs:label 'Basel Event Type Level2' ;
    rdfs:comment 'Basel III Level 2 sub-category providing granular classification within the Level 1 event type (e.g., \'Unauthorized Activity\' under Internal Fraud, \'Theft and Fraud\' under External Fraud, \'Suitability Disclosure and Fiduciary\' under CPBP). Supports detailed root cause analysis and trend reporting. [ENUM-REF-CANDIDATE: promote to reference product aligned with BCBS Annex 9 taxonomy]' ;
    rdfs:domain ind:OperationalRiskEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:causalFactorCode rdf:type rdf:Property ;
    rdfs:label 'Causal Factor Code' ;
    rdfs:comment 'Standardized code from the enterprise causal factor taxonomy identifying the specific contributing factor(s) to the operational risk event (e.g., inadequate segregation of duties, system configuration error, third-party vendor failure, inadequate staff training). Used for trend analysis and KRI calibration.' ;
    rdfs:domain ind:OperationalRiskEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ccarDfastApplicableIndicator rdf:type rdf:Property ;
    rdfs:label 'Ccar Dfast Applicable Indicator' ;
    rdfs:comment 'Flag indicating whether this operational risk event is included in the operational risk loss scenario library used for CCAR and DFAST stress testing submissions to the Federal Reserve. Supports capital adequacy assessment under stressed conditions.' ;
    rdfs:domain ind:OperationalRiskEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:controlFailureType rdf:type rdf:Property ;
    rdfs:label 'Control Failure Type' ;
    rdfs:comment 'Classification of the internal control failure that contributed to the operational risk event. \'design_failure\' indicates the control was inadequately designed; \'operating_failure\' indicates the control existed but did not operate effectively; \'no_control\' indicates absence of a required control; \'override\' indicates management override of controls; \'circumvention\' indicates deliberate bypass of controls.' ;
    rdfs:domain ind:OperationalRiskEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionDueDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Due Date' ;
    rdfs:comment 'Target completion date for the corrective action plan associated with this operational risk event. Used for management escalation tracking and regulatory examination readiness.' ;
    rdfs:domain ind:OperationalRiskEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionStatus rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Status' ;
    rdfs:comment 'Status of the corrective action plan (CAP) initiated in response to the operational risk event to remediate the identified control failure. \'not_required\' for near-miss events with no control gap; \'planned\' for CAP defined but not started; \'in_progress\' for active remediation; \'completed\' for fully remediated; \'overdue\' for past target completion date.' ;
    rdfs:domain ind:OperationalRiskEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discoveryDate rdf:type rdf:Property ;
    rdfs:label 'Discovery Date' ;
    rdfs:comment 'The date on which the operational risk event was first identified or discovered by the bank, which may differ significantly from the event date for latent losses. Used to measure detection lag and assess control effectiveness.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eventDate rdf:type rdf:Property ;
    rdfs:label 'Event Date' ;
    rdfs:comment 'The date on which the operational risk loss event actually occurred or commenced. This is the principal real-world event date used for SMA capital charge period allocation and regulatory reporting. Distinct from discovery date and accounting date.' ;
    rdfs:domain ind:OperationalRiskEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eventDescription rdf:type rdf:Property ;
    rdfs:label 'Event Description' ;
    rdfs:comment 'Detailed narrative description of the operational risk event, including what happened, how it was identified, and the immediate impact. Supports root cause analysis, regulatory examination responses, and internal audit reviews.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Event Reference Number' ;
    rdfs:comment 'Externally-known, human-readable unique reference number assigned to the operational risk event by the GRC platform or internal loss database (e.g., ORE-2024-00123). Used for cross-system reconciliation and regulatory reporting submissions to OCC/Fed/PRA.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventStatus rdf:type rdf:Property ;
    rdfs:label 'Event Status' ;
    rdfs:comment 'Current lifecycle status of the operational risk event record. \'open\' indicates active loss event under investigation; \'under_review\' indicates root cause analysis in progress; \'closed\' indicates fully resolved and signed off; \'near_miss\' indicates no financial loss but control failure identified; \'pending_recovery\' indicates awaiting insurance or third-party recovery.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventTitle rdf:type rdf:Property ;
    rdfs:label 'Event Title' ;
    rdfs:comment 'Short, descriptive title summarizing the nature of the operational risk event (e.g., \'Unauthorized Wire Transfer — Treasury Operations\', \'System Outage — Payment Processing Hub\'). Used for management reporting and GRC dashboard display.' ;
    rdfs:domain ind:OperationalRiskEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalLossDatabaseReference rdf:type rdf:Property ;
    rdfs:label 'External Loss Database Reference' ;
    rdfs:comment 'Reference identifier linking this internal loss event to a corresponding record in an external operational risk loss data consortium (e.g., ORX — Operational Riskdata eXchange Association). Supports benchmarking of internal loss experience against industry peers.' ;
    rdfs:domain ind:OperationalRiskEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossLossAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Loss Amount' ;
    rdfs:comment 'Total gross financial loss incurred from the operational risk event before any recoveries, expressed in the reporting currency. This is the primary input to the SMA capital charge calculation and must meet the BCBS minimum loss threshold for regulatory reporting (typically USD 20,000 for internal data collection).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceRecoveryAmount rdf:type rdf:Property ;
    rdfs:label 'Insurance Recovery Amount' ;
    rdfs:comment 'Portion of the total recovery amount attributable specifically to insurance policy payouts (e.g., fidelity bond, professional indemnity, cyber insurance). Tracked separately per BCBS guidance on insurance recognition in operational risk capital.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:legalActionStatus rdf:type rdf:Property ;
    rdfs:label 'Legal Action Status' ;
    rdfs:comment 'Status of any legal proceedings or litigation associated with the operational risk event. \'none\' indicates no legal action; \'threatened\' indicates potential litigation notified; \'filed\' indicates lawsuit filed; \'settled\' indicates out-of-court settlement reached; \'judgment\' indicates court judgment rendered; \'dismissed\' indicates case dismissed.' ;
    rdfs:domain ind:OperationalRiskEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalProvisionAmount rdf:type rdf:Property ;
    rdfs:label 'Legal Provision Amount' ;
    rdfs:comment 'Financial provision or reserve established in the general ledger for potential legal liability arising from the operational risk event. Recognized per IFRS IAS 37 or FASB ASC 450 when outflow is probable and estimable.' ;
    rdfs:domain ind:OperationalRiskEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lossRecoveryDate rdf:type rdf:Property ;
    rdfs:label 'Loss Recovery Date' ;
    rdfs:comment 'Date on which the recovery amount was received or recognized, whether from insurance, legal settlement, or third-party reimbursement. Used for cash flow timing analysis and SMA recovery component allocation.' ;
    rdfs:domain ind:OperationalRiskEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lossThresholdMetIndicator rdf:type rdf:Property ;
    rdfs:label 'Loss Threshold Met Indicator' ;
    rdfs:comment 'Flag indicating whether the gross loss amount meets or exceeds the minimum loss data threshold (typically USD 20,000 per BCBS guidance) required for inclusion in the SMA Loss Component calculation and external loss data consortium submissions.' ;
    rdfs:domain ind:OperationalRiskEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nearMissIndicator rdf:type rdf:Property ;
    rdfs:label 'Near Miss Indicator' ;
    rdfs:comment 'Flag indicating whether this record represents a near-miss incident (potential loss that was averted) rather than an actual realized loss event. Near-miss events have zero gross loss but are captured for control environment assessment and KRI monitoring.' ;
    rdfs:domain ind:OperationalRiskEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netLossAmount rdf:type rdf:Property ;
    rdfs:label 'Net Loss Amount' ;
    rdfs:comment 'Net financial loss after deducting all recoveries from the gross loss amount (gross_loss_amount minus recovery_amount). This is the final economic impact figure used for P&L attribution, RAROC calculation, and management reporting.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recoveryAmount rdf:type rdf:Property ;
    rdfs:label 'Recovery Amount' ;
    rdfs:comment 'Total amount recovered from all sources (insurance, legal settlements, third-party reimbursements, collateral liquidation) following the operational risk loss event. Subtracted from gross loss to derive net loss.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryReportableIndicator rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reportable Indicator' ;
    rdfs:comment 'Flag indicating whether this operational risk event meets the threshold or criteria requiring mandatory regulatory reporting to OCC, Federal Reserve, PRA, or other supervisory authorities (e.g., significant operational events, cyber incidents, large losses).' ;
    rdfs:domain ind:OperationalRiskEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rootCauseCategory rdf:type rdf:Property ;
    rdfs:label 'Root Cause Category' ;
    rdfs:comment 'High-level root cause classification of the operational risk event following root cause analysis (RCA). Standard taxonomy: \'people\' (human error, misconduct, inadequate training), \'process\' (process failure, inadequate controls, procedural breach), \'system\' (IT system failure, data quality, cybersecurity), \'external_event\' (natural disaster, third-party failure, fraud by external party).' ;
    rdfs:domain ind:OperationalRiskEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseDescription rdf:type rdf:Property ;
    rdfs:label 'Root Cause Description' ;
    rdfs:comment 'Detailed narrative of the root cause analysis findings, identifying the specific underlying cause(s) of the operational risk event. Supports corrective action planning, control remediation, and regulatory examination responses.' ;
    rdfs:domain ind:OperationalRiskEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:smaLossComponent rdf:type rdf:Property ;
    rdfs:label 'Sma Loss Component' ;
    rdfs:comment 'Classification of how this event contributes to the SMA capital charge calculation under Basel III. \'loss_component\' indicates the event feeds the Loss Component (LC) of the SMA formula; \'recovery_component\' indicates a recovery adjustment; \'timing_adjustment\' indicates a multi-year loss requiring temporal allocation per BCBS guidance.' ;
    rdfs:domain ind:OperationalRiskEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kriMeasurementId rdf:type rdf:Property ;
    rdfs:label 'Kri Measurement Id' ;
    rdfs:comment 'Unique surrogate identifier for each KRI measurement record in the enterprise risk monitoring registry. Primary key for the kri_measurement data product.' ;
    rdfs:domain ind:KriMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:channelId rdf:type rdf:Property ;
    rdfs:label 'Channel Id' ;
    rdfs:comment 'Foreign key linking to channel.channel. Business justification: Key Risk Indicators are measured per channel (ATM downtime %, digital fraud rate, branch error rate). Channel-level KRI monitoring is standard in banking risk management for operational risk oversight' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:fundPerformanceId rdf:type rdf:Property ;
    rdfs:label 'Fund Performance Id' ;
    rdfs:comment 'Foreign key linking to asset.fund_performance. Business justification: Investment risk KRIs (tracking error breach, maximum drawdown, Sharpe ratio threshold) are measured directly from fund performance records. Risk teams configure KRIs that trigger when fund_performance' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FundPerformance .

ind:liquidityPositionId rdf:type rdf:Property ;
    rdfs:label 'Liquidity Position Id' ;
    rdfs:comment 'Foreign key linking to treasury.liquidity_position. Business justification: KRIs monitor specific liquidity position metrics for early warning indicators in risk appetite framework. Liquidity KRIs track intraday positions, tenor gaps, and scenario-based positions for breach d' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LiquidityPosition .

ind:actualValue rdf:type rdf:Property ;
    rdfs:label 'Actual Value' ;
    rdfs:comment 'The observed or calculated numeric value of the KRI for the measurement period. Represents the raw measurement result before threshold comparison (e.g., NPL ratio of 0.0325, LCR of 1.42, VaR of 15000000). Unit of measure is defined in the unit_of_measure field.' ;
    rdfs:domain ind:KriMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amberThreshold rdf:type rdf:Property ;
    rdfs:label 'Amber Threshold' ;
    rdfs:comment 'The boundary defining the warning (amber) zone for the KRI. Values breaching this threshold trigger heightened monitoring and management attention but do not yet require board-level escalation. Derived from the risk appetite framework.' ;
    rdfs:domain ind:KriMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:breachStatus rdf:type rdf:Property ;
    rdfs:label 'Breach Status' ;
    rdfs:comment 'The RAG (Red-Amber-Green) status of the KRI measurement relative to defined thresholds. \'green\' indicates within appetite, \'amber\' indicates warning zone, \'red\' indicates limit breach. Drives escalation workflows and board risk committee reporting.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculationMethodology rdf:type rdf:Property ;
    rdfs:label 'Calculation Methodology' ;
    rdfs:comment 'Description of the methodology or formula used to calculate the KRI value (e.g., \'HQLA / Net Cash Outflows over 30 days\', \'NPL balance / Total Gross Loans\', \'99th percentile 10-day VaR using historical simulation\'). Supports model governance and audit requirements.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commentary rdf:type rdf:Property ;
    rdfs:label 'Commentary' ;
    rdfs:comment 'Free-text narrative commentary provided by the KRI owner explaining the measurement result, contextualising any threshold breaches, or noting exceptional circumstances affecting the value (e.g., market dislocation, one-off events, methodology changes).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataQualityFlag rdf:type rdf:Property ;
    rdfs:label 'Data Quality Flag' ;
    rdfs:comment 'Categorical data quality assessment for this KRI measurement record. \'passed\' indicates data meets quality standards, \'warning\' indicates minor data issues that do not invalidate the measurement, \'failed\' indicates the measurement should not be used, \'under_review\' indicates quality assessment is pending.' ;
    rdfs:domain ind:KriMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataQualityScore rdf:type rdf:Property ;
    rdfs:label 'Data Quality Score' ;
    rdfs:comment 'A numeric score (0.00 to 100.00) representing the assessed quality of the underlying data used to compute this KRI measurement. Supports BCBS 239 data quality attestation requirements and flags measurements with low data confidence for review.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Data Source System' ;
    rdfs:comment 'The operational system of record from which the KRI measurement data was sourced (e.g., \'SAS Risk Management\', \'Moodys RiskAuthority\', \'Murex\', \'Core Banking T24\', \'AxiomSL\'). Critical for data lineage and BCBS 239 data quality attestation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationAuthority rdf:type rdf:Property ;
    rdfs:label 'Escalation Authority' ;
    rdfs:comment 'The governance body or individual to whom the KRI breach has been escalated (e.g., \'ALCO\', \'Board Risk Committee\', \'CRO\', \'Risk Management Committee\'). Defines the escalation path for each breach severity level.' ;
    rdfs:domain ind:KriMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationDate rdf:type rdf:Property ;
    rdfs:label 'Escalation Date' ;
    rdfs:comment 'The date on which the KRI breach was formally escalated to the designated escalation authority. Null if no escalation was required. Used to measure escalation timeliness against SLA targets.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:escalationStatus rdf:type rdf:Property ;
    rdfs:label 'Escalation Status' ;
    rdfs:comment 'Current status of the escalation workflow triggered by a KRI breach. \'not_required\' for green-status KRIs, \'pending\' when escalation has been initiated but not yet actioned, \'in_progress\' when remediation is underway, \'resolved\' when breach is remediated, \'overdue\' when SLA has been breached.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:greenThreshold rdf:type rdf:Property ;
    rdfs:label 'Green Threshold' ;
    rdfs:comment 'The upper or lower boundary defining the acceptable (green) zone for the KRI. Values within this threshold indicate normal operating conditions and no escalation is required. Derived from the risk appetite framework.' ;
    rdfs:domain ind:KriMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isBoardReported rdf:type rdf:Property ;
    rdfs:label 'Is Board Reported' ;
    rdfs:comment 'Indicates whether this KRI is included in board risk committee reporting packs (True) or is management-level only (False). Board-reported KRIs require higher data quality standards and formal sign-off per governance policy.' ;
    rdfs:domain ind:KriMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRegulatoryKri rdf:type rdf:Property ;
    rdfs:label 'Is Regulatory Kri' ;
    rdfs:comment 'Indicates whether this KRI is mandated by a regulatory body (True) or is an internally-defined management KRI (False). Regulatory KRIs (e.g., LCR, CET1, NSFR) require formal regulatory reporting and have prescribed minimum thresholds.' ;
    rdfs:domain ind:KriMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kriName rdf:type rdf:Property ;
    rdfs:label 'Kri Name' ;
    rdfs:comment 'Human-readable name of the KRI being measured (e.g., \'Non-Performing Loan Ratio\', \'Liquidity Coverage Ratio\', \'Value at Risk Utilisation\'). Sourced from the KRI master registry.' ;
    rdfs:domain ind:KriMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kriOwnerName rdf:type rdf:Property ;
    rdfs:label 'Kri Owner Name' ;
    rdfs:comment 'Full name of the individual accountable for the KRI measurement, remediation, and escalation. Typically a senior risk officer or business unit head. Classified confidential as it identifies internal accountability assignments.' ;
    rdfs:domain ind:KriMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kriOwnerRole rdf:type rdf:Property ;
    rdfs:label 'Kri Owner Role' ;
    rdfs:comment 'The job title or role designation of the KRI owner (e.g., \'Chief Risk Officer\', \'Head of Credit Risk\', \'Treasury Risk Manager\'). Supports role-based escalation routing and governance reporting.' ;
    rdfs:domain ind:KriMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementFrequency rdf:type rdf:Property ;
    rdfs:label 'Measurement Frequency' ;
    rdfs:comment 'The prescribed frequency at which this KRI is measured and reported. Determines the cadence of data collection and dashboard refresh cycles (e.g., LCR is measured daily, NSFR monthly, ICAAP KRIs quarterly).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Measurement Period End' ;
    rdfs:comment 'The end date of the measurement period over which the KRI value was calculated. For point-in-time KRIs this equals measurement_date; for flow-based KRIs this defines the close of the accumulation window.' ;
    rdfs:domain ind:KriMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Measurement Period Start' ;
    rdfs:comment 'The start date of the measurement period over which the KRI value was calculated. For point-in-time KRIs this equals measurement_date; for flow-based KRIs (e.g., monthly loss events) this defines the beginning of the accumulation window.' ;
    rdfs:domain ind:KriMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:owningBusinessUnit rdf:type rdf:Property ;
    rdfs:label 'Owning Business Unit' ;
    rdfs:comment 'The line of business (LOB) or organisational unit responsible for managing and remediating this KRI (e.g., \'Commercial Lending\', \'Treasury\', \'Retail Banking\', \'Trading\'). Used for accountability assignment in GRC reporting and board risk committee packs.' ;
    rdfs:domain ind:KriMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorPeriodValue rdf:type rdf:Property ;
    rdfs:label 'Prior Period Value' ;
    rdfs:comment 'The KRI actual value from the immediately preceding measurement period. Stored on the record to support period-over-period variance analysis and trend computation without requiring a self-join. Expressed in the same unit_of_measure as actual_value.' ;
    rdfs:domain ind:KriMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:redThreshold rdf:type rdf:Property ;
    rdfs:label 'Red Threshold' ;
    rdfs:comment 'The boundary defining the breach (red) zone for the KRI. Values exceeding this threshold indicate a material risk limit breach requiring immediate escalation to senior management or the board risk committee.' ;
    rdfs:domain ind:KriMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remediationAction rdf:type rdf:Property ;
    rdfs:label 'Remediation Action' ;
    rdfs:comment 'Free-text description of the management action plan or remediation steps being taken to address a KRI breach or amber warning. Captured for audit trail and board risk committee reporting purposes.' ;
    rdfs:domain ind:KriMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationDueDate rdf:type rdf:Property ;
    rdfs:label 'Remediation Due Date' ;
    rdfs:comment 'The target date by which the remediation action for a KRI breach must be completed. Used to track SLA compliance and flag overdue escalations in GRC dashboards.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:stressScenarioFlag rdf:type rdf:Property ;
    rdfs:label 'Stress Scenario Flag' ;
    rdfs:comment 'Indicates whether this measurement record represents a stress scenario value (True) rather than a base-case actual measurement (False). Stress scenario KRI readings are used in CCAR, DFAST, and ICAAP submissions.' ;
    rdfs:domain ind:KriMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:thresholdDirection rdf:type rdf:Property ;
    rdfs:label 'Threshold Direction' ;
    rdfs:comment 'Indicates the directionality of the KRI thresholds. \'higher_is_worse\' means increasing values are adverse (e.g., NPL ratio, VaR). \'lower_is_worse\' means decreasing values are adverse (e.g., LCR, CET1 ratio). \'range_bound\' means both extremes are adverse.' ;
    rdfs:domain ind:KriMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trendDirection rdf:type rdf:Property ;
    rdfs:label 'Trend Direction' ;
    rdfs:comment 'The directional trend of the KRI value relative to the prior measurement period. \'improving\' indicates movement toward lower risk, \'deteriorating\' indicates movement toward higher risk, \'stable\' indicates no material change. Used for forward-looking risk dashboard indicators.' ;
    rdfs:domain ind:KriMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionPlan rdf:type rdf:Property ;
    rdfs:label 'Action Plan' ;
    rdfs:comment 'Documented plan of remediation actions to address identified control gaps or elevated risk ratings. Includes action steps, responsible parties, and target completion dates. Tracked in the GRC platform for management information reporting.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentCode rdf:type rdf:Property ;
    rdfs:label 'Assessment Code' ;
    rdfs:comment 'Externally-known business identifier for the assessment, used in GRC platform references, board risk committee reports, and regulatory submissions. Format: RA-{CATEGORY}-{YEAR}-{SEQUENCE}.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Date' ;
    rdfs:comment 'The principal business event date on which the risk assessment was conducted or formally initiated. Used as the reference date for inherent risk and control effectiveness ratings.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assessment Status' ;
    rdfs:comment 'Current lifecycle state of the risk assessment record within the GRC workflow. Drives escalation, approval routing, and reporting eligibility.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentType rdf:type rdf:Property ;
    rdfs:label 'Assessment Type' ;
    rdfs:comment 'Discriminator identifying the methodology and scope of the assessment. \'enterprise_risk_assessment\' covers holistic enterprise-wide evaluations; \'rcsa\' denotes Risk and Control Self-Assessment; \'thematic_review\' covers targeted deep-dives; \'icaap\' aligns with Internal Capital Adequacy Assessment Process; \'orsa\' aligns with Own Risk and Solvency Assessment.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlDescription rdf:type rdf:Property ;
    rdfs:label 'Control Description' ;
    rdfs:comment 'Narrative description of the key control(s) in place to mitigate the identified risk. Captures control design, automation level, and frequency of operation. Used in RCSA documentation and internal audit evidence packages.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlEffectivenessRating rdf:type rdf:Property ;
    rdfs:label 'Control Effectiveness Rating' ;
    rdfs:comment 'Assessment of how effectively the existing controls mitigate the identified inherent risk. Derived from control design adequacy and operating effectiveness testing. Drives residual risk calculation and remediation prioritization.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlType rdf:type rdf:Property ;
    rdfs:label 'Control Type' ;
    rdfs:comment 'Classification of the primary control mechanism associated with the assessed risk. \'preventive\' controls stop risk events from occurring; \'detective\' controls identify events after occurrence; \'corrective\' controls remediate impact; \'directive\' controls establish required behaviors.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingsSummary rdf:type rdf:Property ;
    rdfs:label 'Findings Summary' ;
    rdfs:comment 'Narrative summary of key findings identified during the risk assessment, including control gaps, risk drivers, and significant observations. Used in board risk committee packs, ICAAP documentation, and regulatory examination responses.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactRating rdf:type rdf:Property ;
    rdfs:label 'Impact Rating' ;
    rdfs:comment 'Qualitative assessment of the severity of financial, operational, reputational, or regulatory impact if the risk event materializes. Combined with likelihood to derive the inherent risk score.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inherentRiskRating rdf:type rdf:Property ;
    rdfs:label 'Inherent Risk Rating' ;
    rdfs:comment 'Risk rating reflecting the gross level of risk before considering the effect of controls. Assessed based on likelihood and impact of the risk materializing in the absence of mitigating controls. Core input to the risk appetite framework and ICAAP capital assessment.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isMaterialRisk rdf:type rdf:Property ;
    rdfs:label 'Is Material Risk' ;
    rdfs:comment 'Flag indicating whether the assessed risk has been classified as material under the enterprise risk appetite framework or ICAAP materiality assessment. Material risks receive enhanced monitoring, board-level reporting, and dedicated capital allocation consideration.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRegulatoryFinding rdf:type rdf:Property ;
    rdfs:label 'Is Regulatory Finding' ;
    rdfs:comment 'Flag indicating whether this risk assessment was initiated or escalated as a result of a regulatory examination finding, Matters Requiring Attention (MRA), or supervisory letter. Drives priority handling and regulatory response tracking.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastTestDate rdf:type rdf:Property ;
    rdfs:label 'Last Test Date' ;
    rdfs:comment 'Date on which the most recent formal test of the associated control was completed. Used to assess control currency, identify overdue testing, and support internal audit scheduling.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:likelihoodRating rdf:type rdf:Property ;
    rdfs:label 'Likelihood Rating' ;
    rdfs:comment 'Qualitative assessment of the probability that the identified risk event will materialize within the assessment horizon. Combined with impact rating to derive the inherent risk score on the risk heat map.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processName rdf:type rdf:Property ;
    rdfs:label 'Process Name' ;
    rdfs:comment 'Name of the business process or activity being assessed, primarily used in RCSA assessments (e.g., \'Loan Origination\', \'Trade Settlement\', \'AML Transaction Monitoring\'). Provides process-level granularity for operational risk management.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationStatus rdf:type rdf:Property ;
    rdfs:label 'Remediation Status' ;
    rdfs:comment 'Current status of the remediation action plan associated with this risk assessment. Drives escalation workflows, management reporting, and regulatory commitment tracking in the GRC platform.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualRiskRating rdf:type rdf:Property ;
    rdfs:label 'Residual Risk Rating' ;
    rdfs:comment 'Net risk rating after accounting for the effectiveness of existing controls. Represents the remaining risk exposure and is the primary metric for risk appetite comparison and escalation decisions.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualRiskScore rdf:type rdf:Property ;
    rdfs:label 'Residual Risk Score' ;
    rdfs:comment 'Quantitative residual risk score (typically on a 1–25 or 1–100 scale) derived from the product of likelihood and impact ratings after control adjustment. Used for risk heat map positioning and quantitative risk aggregation in the GRC platform.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:riskEventType rdf:type rdf:Property ;
    rdfs:label 'Risk Event Type' ;
    rdfs:comment 'Basel II/III operational risk event type classification applicable primarily to RCSA assessments. Maps to the seven Basel operational risk event categories used in Standardized Measurement Approach (SMA) capital calculations. [ENUM-REF-CANDIDATE: internal_fraud|external_fraud|employment_practices|clients_products_business|damage_physical_assets|business_disruption|execution_delivery — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskOwnerName rdf:type rdf:Property ;
    rdfs:label 'Risk Owner Name' ;
    rdfs:comment 'Full name of the designated risk owner accountable for the assessed risk. Retained as a denormalized field for reporting and audit trail purposes independent of HR system changes.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testingFrequency rdf:type rdf:Property ;
    rdfs:label 'Testing Frequency' ;
    rdfs:comment 'Frequency at which the effectiveness of the identified control is formally tested. Drives the control testing schedule in the GRC platform and informs the assurance calendar for internal audit and compliance functions.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:threeLinesDefenceLayer rdf:type rdf:Property ;
    rdfs:label 'Three Lines Defence Layer' ;
    rdfs:comment 'Identifies which line of defence conducted or is responsible for this risk assessment. \'first_line\' is the business unit; \'second_line\' is risk management or compliance; \'third_line\' is internal audit. Supports governance framework reporting and assurance mapping.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityId rdf:type rdf:Property ;
    rdfs:label 'Facility Id' ;
    rdfs:comment 'Unique surrogate identifier for the credit facility record in the lakehouse. Primary key for the facility master entity, referenced by all transactional and monitoring products in the loan domain.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:collateralManagedPortfolioId rdf:type rdf:Property ;
    rdfs:label 'Collateral Managed Portfolio Id' ;
    rdfs:comment 'Foreign key linking to wealth.managed_portfolio. Business justification: Lombard lending structures a credit facility directly against a managed portfolio as primary collateral. Facility-level credit limits, LTV monitoring, and margin call triggers require a direct FK from' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ManagedPortfolio .

ind:facilityBorrowerPartyId rdf:type rdf:Property ;
    rdfs:label 'Facility Borrower Party Id' ;
    rdfs:comment 'FK to customer.party.party_id — MUST-HAVE: Cannot query loan facilities by borrower without this link. Fundamental for credit portfolio management, regulatory reporting (CCAR/DFAST), and customer 360 views.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:facilityPartyId rdf:type rdf:Property ;
    rdfs:label 'Facility Party Id' ;
    rdfs:comment 'Reference to the primary borrowing entity (customer or counterparty) obligated under this credit facility. Used for KYC/AML linkage, credit exposure aggregation, and regulatory reporting.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:investmentPolicyStatementId rdf:type rdf:Property ;
    rdfs:label 'Investment Policy Statement Id' ;
    rdfs:comment 'Foreign key linking to wealth.investment_policy_statement. Business justification: An IPS for a managed portfolio client explicitly governs permissible leverage and borrowing limits. Credit facilities must reference the IPS to validate that the facility is within IPS-permitted lever' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Banking .

ind:originatingBranchId rdf:type rdf:Property ;
    rdfs:label 'Originating Branch Id' ;
    rdfs:comment 'Foreign key linking to channel.branch. Business justification: Facilities are originated at specific branches, required for branch P&L attribution, CRA (Community Reinvestment Act) geographic reporting, and regulatory exam scoping. The existing `originating_branc' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Branch .

ind:underlyingSecurityInstrumentId rdf:type rdf:Property ;
    rdfs:label 'Underlying Security Instrument Id' ;
    rdfs:comment 'Foreign key linking to security.instrument. Business justification: Securities-backed credit facilities (margin lending, portfolio-based lines) require tracking the underlying security collateral. Core private banking and wealth management product. Supports collateral' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Instrument .

ind:valuationYieldCurveId rdf:type rdf:Property ;
    rdfs:label 'Valuation Yield Curve Id' ;
    rdfs:comment 'Foreign key linking to security.yield_curve. Business justification: IFRS 13 fair value measurement and FTP allocation require each loan facility to reference the yield curve used for discounting. ALM and treasury teams assign yield curves to facilities for valuation r' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:YieldCurve .

ind:agentBankFlag rdf:type rdf:Property ;
    rdfs:label 'Agent Bank Flag' ;
    rdfs:comment 'Indicates whether the bank acts as the administrative agent for this syndicated facility, responsible for coordinating drawdowns, payments, and covenant compliance on behalf of the lending syndicate.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allInRate rdf:type rdf:Property ;
    rdfs:label 'All In Rate' ;
    rdfs:comment 'Total effective interest rate applicable to the facility, combining the reference rate benchmark and the credit spread. Expressed as a decimal (e.g., 0.065 = 6.5%). Used for interest accrual, income recognition, and borrower billing.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amortizationType rdf:type rdf:Property ;
    rdfs:label 'Amortization Type' ;
    rdfs:comment 'Repayment structure of the facility principal. \'Bullet\' requires full repayment at maturity; \'amortizing\' schedules periodic principal reductions; \'interest_only\' defers principal; \'balloon\' combines periodic payments with a large final payment; \'revolving\' allows repeated drawdown and repayment.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:committedAmount rdf:type rdf:Property ;
    rdfs:label 'Committed Amount' ;
    rdfs:comment 'Total committed credit limit approved for the facility, representing the maximum exposure the bank has contractually agreed to extend. Used in RWA (Risk-Weighted Assets) calculation and EAD (Exposure at Default) estimation under Basel IRB/SA approaches.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:covenantBreachFlag rdf:type rdf:Property ;
    rdfs:label 'Covenant Breach Flag' ;
    rdfs:comment 'Indicates whether the borrower is currently in breach of one or more financial or non-financial covenants attached to the facility. A covenant breach may constitute an event of default or trigger accelerated repayment provisions.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:drawnAmount rdf:type rdf:Property ;
    rdfs:label 'Drawn Amount' ;
    rdfs:comment 'Outstanding principal balance currently drawn and outstanding under the facility. Represents the bank\'s actual on-balance-sheet credit exposure. Key input for ECL (Expected Credit Loss) provisioning under IFRS 9 and CECL.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dscr rdf:type rdf:Property ;
    rdfs:label 'Dscr' ;
    rdfs:comment 'Ratio of the borrower\'s net operating income to total debt service obligations (principal and interest). A DSCR below 1.0 indicates insufficient cash flow to service debt. Core covenant metric for commercial real estate and leveraged lending.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:facilityName rdf:type rdf:Property ;
    rdfs:label 'Facility Name' ;
    rdfs:comment 'Human-readable descriptive name of the credit facility as recorded in the Loan Origination System, typically reflecting the borrower name and facility type (e.g., \'Acme Corp — 5-Year Revolving Credit Facility\').' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityNumber rdf:type rdf:Property ;
    rdfs:label 'Facility Number' ;
    rdfs:comment 'Externally-known alphanumeric identifier assigned to the credit facility by the Loan Origination System (e.g., Finastra Fusion Loan IQ). Used in borrower communications, regulatory filings, and inter-system reconciliation.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityStatus rdf:type rdf:Property ;
    rdfs:label 'Facility Status' ;
    rdfs:comment 'Current lifecycle state of the credit facility. Drives downstream processing, provisioning, and regulatory classification. \'defaulted\' triggers NPL (Non-Performing Loan) reporting; \'written_off\' indicates full credit loss recognition under CECL/IFRS 9.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstDrawdownDate rdf:type rdf:Property ;
    rdfs:label 'First Drawdown Date' ;
    rdfs:comment 'Date of the first utilization or drawdown under the facility. Marks the transition from commitment to active exposure and is used for interest accrual commencement and IFRS 9 initial recognition of financial asset.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:interestRateBasis rdf:type rdf:Property ;
    rdfs:label 'Interest Rate Basis' ;
    rdfs:comment 'Reference rate benchmark underpinning the facility\'s floating interest rate (e.g., SOFR — Secured Overnight Financing Rate, EURIBOR). Reflects LIBOR transition requirements per ARRC/ISDA fallback protocols. Fixed-rate facilities carry \'fixed\' designation. [ENUM-REF-CANDIDATE: SOFR|LIBOR|EURIBOR|SONIA|fixed|prime|CDOR — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interestRateSpreadBps rdf:type rdf:Property ;
    rdfs:label 'Interest Rate Spread Bps' ;
    rdfs:comment 'Credit spread above the reference rate benchmark expressed in BPS (Basis Points), representing the bank\'s risk-adjusted margin on the facility. Key input for NIM (Net Interest Margin) and NII (Net Interest Income) reporting and FTP (Funds Transfer Pricing).' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loanPurposeCode rdf:type rdf:Property ;
    rdfs:label 'Loan Purpose Code' ;
    rdfs:comment 'Standardized code classifying the intended use of proceeds for the credit facility (e.g., working capital, capital expenditure, acquisition finance, real estate purchase). Required for HMDA, CRA, and Call Report regulatory filings. [ENUM-REF-CANDIDATE: working_capital|capex|acquisition|real_estate|trade_finance|refinancing|general_corporate|consumer_personal — promote to reference product]' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nplFlag rdf:type rdf:Property ;
    rdfs:label 'Npl Flag' ;
    rdfs:comment 'Indicates whether the facility is classified as a Non-Performing Loan (NPL) per regulatory definition (typically 90+ days past due or unlikely-to-pay). Triggers specific provisioning, income recognition suspension, and regulatory NPL ratio reporting.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatorySegment rdf:type rdf:Property ;
    rdfs:label 'Regulatory Segment' ;
    rdfs:comment 'Basel III regulatory exposure class assigned to the facility for RWA (Risk-Weighted Assets) calculation under the Standardized Approach (SA) or Internal Ratings-Based (IRB) approach. Determines applicable risk weight and capital treatment.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repaymentFrequency rdf:type rdf:Property ;
    rdfs:label 'Repayment Frequency' ;
    rdfs:comment 'Scheduled frequency of principal and/or interest repayment installments under the facility. Drives cash flow projection for ALM (Asset-Liability Management), liquidity gap analysis, and NSFR (Net Stable Funding Ratio) bucketing.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewDate rdf:type rdf:Property ;
    rdfs:label 'Review Date' ;
    rdfs:comment 'Scheduled date for the next annual or periodic credit review of the facility. Triggers credit underwriting reassessment, covenant compliance review, and internal risk rating refresh.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:syndicatedFlag rdf:type rdf:Property ;
    rdfs:label 'Syndicated Flag' ;
    rdfs:comment 'Indicates whether the facility is part of a syndicated loan arrangement involving multiple lender participants. Syndicated facilities require agent bank coordination, participation tracking, and specific regulatory reporting under OCC Shared National Credit (SNC) program.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:undrawnAmount rdf:type rdf:Property ;
    rdfs:label 'Undrawn Amount' ;
    rdfs:comment 'Available but unutilized portion of the committed facility (committed_amount minus drawn_amount). Attracts a credit conversion factor (CCF) for off-balance-sheet RWA calculation under Basel III standardized and IRB approaches.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditApplicationId rdf:type rdf:Property ;
    rdfs:label 'Credit Application Id' ;
    rdfs:comment 'Unique identifier for the credit application record. Primary key for the credit application entity.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CreditApplication .

ind:alertId rdf:type rdf:Property ;
    rdfs:label 'Alert Id' ;
    rdfs:comment 'Foreign key linking to fraud.fraud_alert. Business justification: Real-time fraud screening during credit underwriting: fraud detection rules fire alerts on credit applications (e.g., velocity checks, identity mismatch). Underwriters review alert disposition before ' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Alert .

ind:applicationChannelId rdf:type rdf:Property ;
    rdfs:label 'Application Channel Id' ;
    rdfs:comment 'Foreign key linking to channel.channel. Business justification: Credit applications are submitted through specific channels (branch, digital, mobile). Channel-level application volume, approval rate, and conversion reporting is a core origination analytics and reg' ;
    rdfs:domain ind:CreditApplication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:borrowerCountryId rdf:type rdf:Property ;
    rdfs:label 'Borrower Country Id' ;
    rdfs:comment 'Foreign key linking to reference.country. Business justification: Credit underwriting requires borrower country-of-domicile for AML risk rating, FATCA/CRS jurisdiction determination, and cross-border regulatory reporting. A credit analyst always records this on the ' ;
    rdfs:domain ind:CreditApplication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:collateralInstrumentId rdf:type rdf:Property ;
    rdfs:label 'Collateral Instrument Id' ;
    rdfs:comment 'Foreign key linking to security.instrument. Business justification: Credit applications offering securities as collateral (bonds, equities, portfolios) require instrument identification for underwriting, valuation, and eligibility assessment. Standard input for securi' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Instrument .

ind:investorAccountId rdf:type rdf:Property ;
    rdfs:label 'Investor Account Id' ;
    rdfs:comment 'Foreign key linking to asset.investor_account. Business justification: Private banking underwriting: credit applications for ultra-high-net-worth clients reference their investment accounts (fund holdings) as part of creditworthiness assessment. Underwriters evaluate the' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InvestorAccount .

ind:onboardingCaseId rdf:type rdf:Property ;
    rdfs:label 'Onboarding Case Id' ;
    rdfs:comment 'Foreign key linking to customer.onboarding_case. Business justification: Credit applications are initiated within onboarding cases (onboarding_case.product_applied_for confirms this). Linking credit_application to onboarding_case enables end-to-end origination pipeline rep' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OnboardingCase .

ind:primaryCreditPartyId rdf:type rdf:Property ;
    rdfs:label 'Primary Credit Party Id' ;
    rdfs:comment 'Reference to the primary applicant (customer or corporate entity) submitting the credit application.' ;
    rdfs:domain ind:CreditApplication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:trustAccountId rdf:type rdf:Property ;
    rdfs:label 'Trust Account Id' ;
    rdfs:comment 'Foreign key linking to wealth.trust_account. Business justification: Trust entities are common borrowers in private banking (trustee-directed loans, trust-owned property financing). Credit applications submitted on behalf of a trust require direct linkage to the trust ' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TrustAccount .

ind:annualRevenue rdf:type rdf:Property ;
    rdfs:label 'Annual Revenue' ;
    rdfs:comment 'Applicant\'s reported annual revenue from the most recent financial statements, used for debt service coverage and creditworthiness assessment.' ;
    rdfs:domain ind:CreditApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:applicationNumber rdf:type rdf:Property ;
    rdfs:label 'Application Number' ;
    rdfs:comment 'Externally-visible unique business identifier for the credit application, used in customer communications and regulatory reporting.' ;
    rdfs:domain ind:CreditApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationStatus rdf:type rdf:Property ;
    rdfs:label 'Application Status' ;
    rdfs:comment 'Current lifecycle status of the credit application in the underwriting workflow. [ENUM-REF-CANDIDATE: draft|submitted|under_review|pending_documents|approved|declined|withdrawn|referred — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CreditApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationSubmittedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Application Submitted Timestamp' ;
    rdfs:comment 'Date and time when the credit application was formally submitted by the applicant or on behalf of the applicant.' ;
    rdfs:domain ind:CreditApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:applicationType rdf:type rdf:Property ;
    rdfs:label 'Application Type' ;
    rdfs:comment 'Classification of the credit application based on the nature of the request: new facility, renewal of existing, refinancing, modification of terms, credit line increase, or debt restructuring.' ;
    rdfs:domain ind:CreditApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedAmount rdf:type rdf:Property ;
    rdfs:label 'Approved Amount' ;
    rdfs:comment 'Principal amount of credit approved by underwriting, which may differ from the requested amount. Nullable for declined or pending applications.' ;
    rdfs:domain ind:CreditApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedInterestRate rdf:type rdf:Property ;
    rdfs:label 'Approved Interest Rate' ;
    rdfs:comment 'Annual interest rate approved for the credit facility, expressed as a decimal (e.g., 0.0575 for 5.75%). Nullable for declined or pending applications.' ;
    rdfs:domain ind:CreditApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedTermMonths rdf:type rdf:Property ;
    rdfs:label 'Approved Term Months' ;
    rdfs:comment 'Duration of the approved credit facility in months, which may differ from the requested term. Nullable for declined or pending applications.' ;
    rdfs:domain ind:CreditApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:conditionsPrecedent rdf:type rdf:Property ;
    rdfs:label 'Conditions Precedent' ;
    rdfs:comment 'List of conditions that must be satisfied before loan disbursement, such as additional documentation, insurance requirements, or legal opinions. Nullable for declined applications.' ;
    rdfs:domain ind:CreditApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditCommitteeApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Credit Committee Approval Date' ;
    rdfs:comment 'Date when the credit committee formally approved the application, if committee approval was required. Nullable for applications within analyst authority or declined applications.' ;
    rdfs:domain ind:CreditApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditScore rdf:type rdf:Property ;
    rdfs:label 'Credit Score' ;
    rdfs:comment 'Numeric credit score assigned by the credit scoring model (e.g., FICO, internal proprietary model) at the time of application submission.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:declineReason rdf:type rdf:Property ;
    rdfs:label 'Decline Reason' ;
    rdfs:comment 'Detailed explanation for declined applications, including specific credit policy violations, insufficient collateral, adverse credit history, or regulatory restrictions. Nullable for approved applications.' ;
    rdfs:domain ind:CreditApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialStatementDate rdf:type rdf:Property ;
    rdfs:label 'Financial Statement Date' ;
    rdfs:comment 'Date of the most recent financial statements submitted by the applicant as part of the credit application package.' ;
    rdfs:domain ind:CreditApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:kycCompleted rdf:type rdf:Property ;
    rdfs:label 'Kyc Completed' ;
    rdfs:comment 'Indicates whether Know Your Customer due diligence has been completed for the applicant, required for regulatory compliance.' ;
    rdfs:domain ind:CreditApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loanPurpose rdf:type rdf:Property ;
    rdfs:label 'Loan Purpose' ;
    rdfs:comment 'Detailed description of the intended use of borrowed funds, such as working capital, capital expenditure, acquisition, real estate purchase, debt consolidation, or trade finance.' ;
    rdfs:domain ind:CreditApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pipelineStage rdf:type rdf:Property ;
    rdfs:label 'Pipeline Stage' ;
    rdfs:comment 'Current stage of the application in the credit origination pipeline, used for funnel analytics and conversion tracking. [ENUM-REF-CANDIDATE: prospect|application|underwriting|approval|documentation|closing|funded|declined — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CreditApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Flag' ;
    rdfs:comment 'Indicates whether this application must be included in regulatory reporting such as HMDA, CRA, or other jurisdiction-specific credit origination reports.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requestedAmount rdf:type rdf:Property ;
    rdfs:label 'Requested Amount' ;
    rdfs:comment 'Principal amount of credit requested by the applicant in the application currency.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requestedCurrency rdf:type rdf:Property ;
    rdfs:label 'Requested Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the requested credit amount.' ;
    rdfs:domain ind:CreditApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedTermMonths rdf:type rdf:Property ;
    rdfs:label 'Requested Term Months' ;
    rdfs:comment 'Duration of the requested credit facility expressed in months. Nullable for revolving facilities without fixed maturity.' ;
    rdfs:domain ind:CreditApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalAssets rdf:type rdf:Property ;
    rdfs:label 'Total Assets' ;
    rdfs:comment 'Applicant\'s total assets as reported in the most recent financial statements, used for balance sheet strength assessment.' ;
    rdfs:domain ind:CreditApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalLiabilities rdf:type rdf:Property ;
    rdfs:label 'Total Liabilities' ;
    rdfs:comment 'Applicant\'s total liabilities as reported in the most recent financial statements, used for leverage ratio calculation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:underwritingDecision rdf:type rdf:Property ;
    rdfs:label 'Underwriting Decision' ;
    rdfs:comment 'Final underwriting decision rendered by the credit analyst or credit committee: approved, declined, referred to senior committee, conditional approval pending additional requirements, or withdrawn by applicant.' ;
    rdfs:domain ind:CreditApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentMandateId rdf:type rdf:Property ;
    rdfs:label 'Payment Mandate Id' ;
    rdfs:comment 'Foreign key linking to payment.payment_mandate. Business justification: Loan accounts have direct debit mandates authorizing automated repayment collection. Banks link loan_account to payment_mandate for scheduled payment execution, mandate cancellation on payoff, and SEP' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentMandate .

ind:accountNumber rdf:type rdf:Property ;
    rdfs:label 'Account Number' ;
    rdfs:comment 'Externally visible account number used for customer communication, statements, and payment processing. Unique within the institution.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountStatus rdf:type rdf:Property ;
    rdfs:label 'Account Status' ;
    rdfs:comment 'Current operational status of the loan account. Reflects payment performance and lifecycle stage.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accruedFees rdf:type rdf:Property ;
    rdfs:label 'Accrued Fees' ;
    rdfs:comment 'Fees accrued but not yet paid, including late fees, servicing fees, and other charges.' ;
    rdfs:domain ind:LoanAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accruedInterest rdf:type rdf:Property ;
    rdfs:label 'Accrued Interest' ;
    rdfs:comment 'Interest accrued but not yet paid on the loan account. Calculated based on day-count convention and current interest rate.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chargeOffAmount rdf:type rdf:Property ;
    rdfs:label 'Charge Off Amount' ;
    rdfs:comment 'Total amount charged off including principal, interest, and fees. Used for loss reporting and recovery tracking.' ;
    rdfs:domain ind:LoanAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chargeOffDate rdf:type rdf:Property ;
    rdfs:label 'Charge Off Date' ;
    rdfs:comment 'Date when the loan was charged off as a loss. Triggers removal from performing assets and loss recognition.' ;
    rdfs:domain ind:LoanAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:collateralCoverageRatio rdf:type rdf:Property ;
    rdfs:label 'Collateral Coverage Ratio' ;
    rdfs:comment 'Ratio of collateral value to outstanding loan balance. Used for LTV (Loan-to-Value) monitoring and loss mitigation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cureDate rdf:type rdf:Property ;
    rdfs:label 'Cure Date' ;
    rdfs:comment 'Date when a previously delinquent or non-performing loan returned to current status. Used for NPL lifecycle tracking.' ;
    rdfs:domain ind:LoanAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:currentInterestRate rdf:type rdf:Property ;
    rdfs:label 'Current Interest Rate' ;
    rdfs:comment 'Current annual interest rate applied to the loan account, expressed as a decimal (e.g., 0.05250 for 5.25%).' ;
    rdfs:domain ind:LoanAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dayCountConvention rdf:type rdf:Property ;
    rdfs:label 'Day Count Convention' ;
    rdfs:comment 'Method used to calculate interest accrual. Determines how days are counted in interest period calculations.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delinquencyBucket rdf:type rdf:Property ;
    rdfs:label 'Delinquency Bucket' ;
    rdfs:comment 'Days past due classification bucket. Used for aging analysis, collection prioritization, and regulatory reporting.' ;
    rdfs:domain ind:LoanAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eclProvisionAmount rdf:type rdf:Property ;
    rdfs:label 'Ecl Provision Amount' ;
    rdfs:comment 'Current provision amount for expected credit losses under CECL or IFRS 9. Updated quarterly based on credit risk models.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:firstPaymentDate rdf:type rdf:Property ;
    rdfs:label 'First Payment Date' ;
    rdfs:comment 'Date when the first scheduled payment was or will be due. Used for amortization schedule calculations.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:forbearanceEndDate rdf:type rdf:Property ;
    rdfs:label 'Forbearance End Date' ;
    rdfs:comment 'Scheduled date when forbearance or modification period ends. Null if not under forbearance.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:forbearanceStartDate rdf:type rdf:Property ;
    rdfs:label 'Forbearance Start Date' ;
    rdfs:comment 'Date when forbearance or modification period began. Null if not under forbearance.' ;
    rdfs:domain ind:LoanAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:interestRateType rdf:type rdf:Property ;
    rdfs:label 'Interest Rate Type' ;
    rdfs:comment 'Classification of interest rate structure. Determines whether rate is fixed for loan term or adjusts based on benchmark.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextPaymentDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Payment Due Date' ;
    rdfs:comment 'Date when the next scheduled payment is due. Used for delinquency tracking and collection workflows.' ;
    rdfs:domain ind:LoanAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nplClassificationDate rdf:type rdf:Property ;
    rdfs:label 'Npl Classification Date' ;
    rdfs:comment 'Date when the loan was first classified as non-performing. Triggers regulatory reporting and provisioning requirements.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nplTriggerEvent rdf:type rdf:Property ;
    rdfs:label 'Npl Trigger Event' ;
    rdfs:comment 'Event that caused the loan to be classified as non-performing. Used for root cause analysis and loss mitigation.' ;
    rdfs:domain ind:LoanAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalLoanAmount rdf:type rdf:Property ;
    rdfs:label 'Original Loan Amount' ;
    rdfs:comment 'Principal amount disbursed at loan origination. Used for LTV (Loan-to-Value) and amortization calculations.' ;
    rdfs:domain ind:LoanAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outstandingPrincipalBalance rdf:type rdf:Property ;
    rdfs:label 'Outstanding Principal Balance' ;
    rdfs:comment 'Current principal amount outstanding on the loan account. Excludes accrued interest and fees.' ;
    rdfs:domain ind:LoanAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentFrequency rdf:type rdf:Property ;
    rdfs:label 'Payment Frequency' ;
    rdfs:comment 'Scheduled frequency of principal and interest payments. Bullet indicates single payment at maturity.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateResetDate rdf:type rdf:Property ;
    rdfs:label 'Rate Reset Date' ;
    rdfs:comment 'Next scheduled date when the interest rate will be recalculated for floating rate loans.' ;
    rdfs:domain ind:LoanAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rateSpreadBps rdf:type rdf:Property ;
    rdfs:label 'Rate Spread Bps' ;
    rdfs:comment 'Credit spread added to the benchmark rate, expressed in basis points. Used for floating rate loan pricing.' ;
    rdfs:domain ind:LoanAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryClassificationBasis rdf:type rdf:Property ;
    rdfs:label 'Regulatory Classification Basis' ;
    rdfs:comment 'Regulatory framework used for loan classification and provisioning. Determines reporting requirements.' ;
    rdfs:domain ind:LoanAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskWeightPercent rdf:type rdf:Property ;
    rdfs:label 'Risk Weight Percent' ;
    rdfs:comment 'Basel III risk weight applied to this loan for RWA (Risk-Weighted Assets) calculation. Drives capital requirements.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalExposure rdf:type rdf:Property ;
    rdfs:label 'Total Exposure' ;
    rdfs:comment 'Total amount owed by the borrower including principal, accrued interest, and fees. Used for EAD (Exposure at Default) calculations.' ;
    rdfs:domain ind:LoanAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:watchListDate rdf:type rdf:Property ;
    rdfs:label 'Watch List Date' ;
    rdfs:comment 'Date when the loan was added to the credit watch list. Null if not on watch list.' ;
    rdfs:domain ind:LoanAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:watchListFlag rdf:type rdf:Property ;
    rdfs:label 'Watch List Flag' ;
    rdfs:comment 'Indicates whether the loan is on the credit watch list for heightened monitoring due to early warning signals.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:amortizationScheduleId rdf:type rdf:Property ;
    rdfs:label 'Amortization Schedule Id' ;
    rdfs:comment 'Unique identifier for each amortization schedule entry. Primary key for the amortization schedule product.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AmortizationSchedule .

ind:accrualDays rdf:type rdf:Property ;
    rdfs:label 'Accrual Days' ;
    rdfs:comment 'Number of days in the interest accrual period for this installment. Calculated based on the day count convention specified in the loan agreement (e.g., 30/360, Actual/365, Actual/Actual).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accrualEndDate rdf:type rdf:Property ;
    rdfs:label 'Accrual End Date' ;
    rdfs:comment 'End date of the interest accrual period for this installment. Typically the due date of this payment. Used to calculate the number of days for interest accrual.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accrualStartDate rdf:type rdf:Property ;
    rdfs:label 'Accrual Start Date' ;
    rdfs:comment 'Start date of the interest accrual period for this installment. Typically the day after the previous payment due date or the loan disbursement date for the first installment.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualInterestAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Interest Amount' ;
    rdfs:comment 'Actual interest amount applied from the received payment. May differ from scheduled interest due to payment timing, rate changes, or payment allocation rules.' ;
    rdfs:domain ind:AmortizationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Payment Amount' ;
    rdfs:comment 'Actual total amount received for this installment. May differ from scheduled amount due to partial payments, prepayments, or payment shortfalls. Null if no payment has been received.' ;
    rdfs:domain ind:AmortizationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Actual Payment Date' ;
    rdfs:comment 'Actual date on which the payment was received and applied to the loan. Null if payment has not yet been received. Used to calculate days past due and assess payment performance.' ;
    rdfs:domain ind:AmortizationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualPrincipalAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Principal Amount' ;
    rdfs:comment 'Actual principal reduction amount applied from the received payment. May differ from scheduled principal due to payment allocation rules, prepayments, or shortfalls.' ;
    rdfs:domain ind:AmortizationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:beginningBalance rdf:type rdf:Property ;
    rdfs:label 'Beginning Balance' ;
    rdfs:comment 'Outstanding principal balance at the start of this payment period, before the current installment is applied. Represents the loan balance carried forward from the previous period.' ;
    rdfs:domain ind:AmortizationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dueDate rdf:type rdf:Property ;
    rdfs:label 'Due Date' ;
    rdfs:comment 'Scheduled date on which this installment payment is contractually due. Used for payment processing, delinquency tracking, and cash flow forecasting.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:endingBalance rdf:type rdf:Property ;
    rdfs:label 'Ending Balance' ;
    rdfs:comment 'Outstanding principal balance remaining after this scheduled payment is applied. Calculated as beginning balance minus scheduled principal amount. Becomes the beginning balance for the next period.' ;
    rdfs:domain ind:AmortizationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:installmentNumber rdf:type rdf:Property ;
    rdfs:label 'Installment Number' ;
    rdfs:comment 'Sequential number of this payment installment within the loan\'s repayment schedule. Starts at 1 for the first payment and increments for each subsequent scheduled payment.' ;
    rdfs:domain ind:AmortizationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:interestRate rdf:type rdf:Property ;
    rdfs:label 'Interest Rate' ;
    rdfs:comment 'Annual interest rate in effect for this payment period, expressed as a decimal. May vary across installments for variable-rate loans or after rate resets. Used to calculate the scheduled interest amount.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isFinalPayment rdf:type rdf:Property ;
    rdfs:label 'Is Final Payment' ;
    rdfs:comment 'Indicates whether this is the final scheduled payment for the loan. True for the last installment that brings the ending balance to zero. Used to identify loan maturity and schedule completion.' ;
    rdfs:domain ind:AmortizationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRestructured rdf:type rdf:Property ;
    rdfs:label 'Is Restructured' ;
    rdfs:comment 'Indicates whether this installment is part of a restructured payment schedule. True if the loan has been modified after origination due to borrower hardship, forbearance, or other restructuring events. Critical for regulatory reporting and credit risk classification.' ;
    rdfs:domain ind:AmortizationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lateFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Late Fee Amount' ;
    rdfs:comment 'Late payment fee assessed for this installment if payment was received after the due date. Calculated according to the loan agreement\'s late fee provisions. Null if payment was on time or no late fee was assessed.' ;
    rdfs:domain ind:AmortizationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentMethod rdf:type rdf:Property ;
    rdfs:label 'Payment Method' ;
    rdfs:comment 'Method by which the actual payment was received for this installment. Includes ACH (Automated Clearing House), wire transfer, check, cash, card payment, or internal account transfer. Null if payment has not been received.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prepaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Prepayment Amount' ;
    rdfs:comment 'Additional principal amount paid beyond the scheduled principal for this installment. Represents voluntary prepayments that reduce the outstanding balance faster than scheduled. Null if no prepayment occurred.' ;
    rdfs:domain ind:AmortizationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:restructureDate rdf:type rdf:Property ;
    rdfs:label 'Restructure Date' ;
    rdfs:comment 'Date on which the loan restructuring became effective, if applicable. Null for non-restructured installments. Used to track troubled debt restructuring (TDR) events and assess credit quality.' ;
    rdfs:domain ind:AmortizationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduleGenerationDate rdf:type rdf:Property ;
    rdfs:label 'Schedule Generation Date' ;
    rdfs:comment 'Date on which this version of the amortization schedule was generated or regenerated. Updated whenever the schedule is recalculated due to loan modifications or rate changes.' ;
    rdfs:domain ind:AmortizationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduleVersion rdf:type rdf:Property ;
    rdfs:label 'Schedule Version' ;
    rdfs:comment 'Version number of this amortization schedule. Increments each time the schedule is regenerated due to loan modifications, restructuring, rate resets, or payment plan changes. Version 1 is the original schedule at loan origination.' ;
    rdfs:domain ind:AmortizationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scheduledFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Scheduled Fee Amount' ;
    rdfs:comment 'Any contractually scheduled fees or charges included in this installment, such as servicing fees, insurance premiums, or other recurring charges.' ;
    rdfs:domain ind:AmortizationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduledInterestAmount rdf:type rdf:Property ;
    rdfs:label 'Scheduled Interest Amount' ;
    rdfs:comment 'Contractually scheduled interest charge for this payment period. Calculated based on the beginning balance, interest rate, and accrual period. Represents the cost of borrowing for this period.' ;
    rdfs:domain ind:AmortizationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduledPrincipalAmount rdf:type rdf:Property ;
    rdfs:label 'Scheduled Principal Amount' ;
    rdfs:comment 'Contractually scheduled principal reduction amount for this installment. This portion of the payment reduces the outstanding loan balance.' ;
    rdfs:domain ind:AmortizationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Total Payment Amount' ;
    rdfs:comment 'Total amount due for this installment, calculated as the sum of scheduled principal, interest, and fees. This is the amount the borrower is contractually obligated to pay on the due date.' ;
    rdfs:domain ind:AmortizationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waivedAmount rdf:type rdf:Property ;
    rdfs:label 'Waived Amount' ;
    rdfs:comment 'Total amount of scheduled payment that was waived or forgiven for this installment. May include waived principal, interest, or fees due to loan modifications, hardship programs, or settlement agreements.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:drawdownId rdf:type rdf:Property ;
    rdfs:label 'Drawdown Id' ;
    rdfs:comment 'Unique identifier for the drawdown event. Primary key for the drawdown transaction record.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Drawdown .

ind:collateralAssetId rdf:type rdf:Property ;
    rdfs:label 'Collateral Asset Id' ;
    rdfs:comment 'Reference to the collateral package or security instrument pledged against this drawdown, if applicable. Used for secured lending and Loss Given Default (LGD) calculation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CollateralAsset .

ind:fxTransactionId rdf:type rdf:Property ;
    rdfs:label 'Fx Transaction Id' ;
    rdfs:comment 'Foreign key linking to payment.fx_transaction. Business justification: Cross-currency drawdowns require an FX transaction to convert disbursed funds. Banks link drawdown to fx_transaction for FX exposure reporting, hedge accounting under IFRS 9, and multi-currency loan p' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FxTransaction .

ind:trancheId rdf:type rdf:Property ;
    rdfs:label 'Tranche Id' ;
    rdfs:comment 'Foreign key linking to investment.tranche. Business justification: Syndicated loan operations: each drawdown is executed against a specific tranche (senior, mezzanine, etc.) that defines the applicable rate, seniority, and terms. Agent bank systems and loan accountin' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Tranche .

ind:availableCommitmentAmount rdf:type rdf:Property ;
    rdfs:label 'Available Commitment Amount' ;
    rdfs:comment 'The remaining undrawn commitment amount available under the facility after this drawdown. Calculated as facility limit minus total outstanding drawdowns.' ;
    rdfs:domain ind:Drawdown ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:benchmarkRate rdf:type rdf:Property ;
    rdfs:label 'Benchmark Rate' ;
    rdfs:comment 'The reference benchmark rate used for floating-rate drawdowns: SOFR (Secured Overnight Financing Rate), LIBOR (legacy), EURIBOR, SONIA, ESTR, PRIME, or BASE rate.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:beneficiaryAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Account Number' ;
    rdfs:comment 'The borrowers account number or IBAN to which the drawdown funds were credited. May be an internal DDA or an external account at another institution.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentUtilizationPct rdf:type rdf:Property ;
    rdfs:label 'Commitment Utilization Pct' ;
    rdfs:comment 'The percentage of the total facility commitment utilized after this drawdown, calculated as (total outstanding + this drawdown) / facility limit * 100. Used for covenant monitoring.' ;
    rdfs:domain ind:Drawdown ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disbursementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Disbursement Timestamp' ;
    rdfs:comment 'The precise date and time when the drawdown funds were released from the funding account. Critical for interest accrual calculation and operational reporting.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:drawdownDate rdf:type rdf:Property ;
    rdfs:label 'Drawdown Date' ;
    rdfs:comment 'The business date on which the borrower requested or executed the drawdown. This is the transaction date for accounting and interest accrual purposes.' ;
    rdfs:domain ind:Drawdown ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:drawdownStatus rdf:type rdf:Property ;
    rdfs:label 'Drawdown Status' ;
    rdfs:comment 'Current lifecycle status of the drawdown transaction: pending (awaiting approval), approved (authorized), disbursed (funds sent), settled (funds received), failed (payment failed), cancelled (voided), or reversed (unwound). [ENUM-REF-CANDIDATE: pending|approved|disbursed|settled|failed|cancelled|reversed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Drawdown ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drawdownType rdf:type rdf:Property ;
    rdfs:label 'Drawdown Type' ;
    rdfs:comment 'Classification of the drawdown event: scheduled (pre-agreed), unscheduled (ad-hoc), revolving (under revolving facility), term (under term loan), swing_line (short-term bridge), or overdraft (emergency).' ;
    rdfs:domain ind:Drawdown ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundingAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Funding Account Number' ;
    rdfs:comment 'The internal general ledger or nostro account number from which the drawdown funds were disbursed. Used for reconciliation and funds transfer pricing (FTP).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glPostingDate rdf:type rdf:Property ;
    rdfs:label 'Gl Posting Date' ;
    rdfs:comment 'The accounting date on which this drawdown transaction was posted to the general ledger. Used for financial reporting and period-end close processes.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:interestPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Interest Period Days' ;
    rdfs:comment 'The number of days in the interest period for this drawdown (e.g., 30, 90, 180). Determines the frequency of interest rate resets for floating-rate drawdowns.' ;
    rdfs:domain ind:Drawdown ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Modified Timestamp' ;
    rdfs:comment 'The date and time when this drawdown record was last updated. Tracks changes to status, amounts, or other mutable fields for audit purposes.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:purpose rdf:type rdf:Property ;
    rdfs:label 'Purpose' ;
    rdfs:comment 'Business purpose or use of funds for this drawdown as declared by the borrower. May be required for covenant compliance, regulatory reporting, or trade finance documentation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repaymentType rdf:type rdf:Property ;
    rdfs:label 'Repayment Type' ;
    rdfs:comment 'The repayment structure for this drawdown: bullet (single payment at maturity), amortizing (scheduled installments), revolving (flexible repayment and re-draw), or on_demand (callable).' ;
    rdfs:domain ind:Drawdown ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskWeightPct rdf:type rdf:Property ;
    rdfs:label 'Risk Weight Pct' ;
    rdfs:comment 'The Basel III risk weight percentage applied to this drawdown exposure for Risk-Weighted Assets (RWA) calculation. Varies by borrower credit rating and collateral.' ;
    rdfs:domain ind:Drawdown ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Settlement Timestamp' ;
    rdfs:comment 'The precise date and time when the drawdown funds were confirmed as received in the beneficiary account. Used for reconciliation and SLA tracking.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:swiftMessageReference rdf:type rdf:Property ;
    rdfs:label 'Swift Message Reference' ;
    rdfs:comment 'The SWIFT MT103 or MT202 message reference number for cross-border or interbank drawdown settlements. Used for payment tracking and reconciliation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:syndicationFlag rdf:type rdf:Property ;
    rdfs:label 'Syndication Flag' ;
    rdfs:comment 'Indicates whether this drawdown is part of a syndicated loan facility with multiple lender participants. True if syndicated, false if bilateral.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tradeFinanceReference rdf:type rdf:Property ;
    rdfs:label 'Trade Finance Reference' ;
    rdfs:comment 'Reference to the underlying trade finance instrument if this drawdown is linked to a letter of credit, documentary collection, or bill of lading. Used for UCP 600 compliance.' ;
    rdfs:domain ind:Drawdown ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valueDate rdf:type rdf:Property ;
    rdfs:label 'Value Date' ;
    rdfs:comment 'The effective date on which funds are made available to the borrower and interest accrual begins. May differ from drawdown_date due to settlement cycles.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:repaymentId rdf:type rdf:Property ;
    rdfs:label 'Repayment Id' ;
    rdfs:comment 'Unique identifier for the loan repayment transaction. Primary key for the repayment data product.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Repayment .

ind:ctrFilingId rdf:type rdf:Property ;
    rdfs:label 'Ctr Filing Id' ;
    rdfs:comment 'Foreign key linking to compliance.ctr_filing. Business justification: Large cash repayments exceeding $10,000 trigger CTR filings under BSA regulations. Banks must link CTR filings to specific repayment transactions that triggered the reporting requirement for audit tra' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CtrFiling .

ind:instructionId rdf:type rdf:Property ;
    rdfs:label 'Instruction Id' ;
    rdfs:comment 'Foreign key linking to payment.payment_instruction. Business justification: Core loan servicing process: every loan repayment (principal, interest, fees) is executed via a payment instruction through the bank\'s payment rails. Regulatory reporting (FFIEC 031/041) requires trac' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Instruction .

ind:paymentTransactionId rdf:type rdf:Property ;
    rdfs:label 'Payment Transaction Id' ;
    rdfs:comment 'Foreign key linking to payment.payment_transaction. Business justification: Loan repayments are executed as payment transactions. Banks link repayment to payment_transaction for delinquency monitoring, payment reconciliation, and regulatory reporting (e.g., CRR Article 178 de' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentTransaction .

ind:sourceAccountDepositAccountId rdf:type rdf:Property ;
    rdfs:label 'Source Account Deposit Account Id' ;
    rdfs:comment 'Foreign key linking to account.deposit_account. Business justification: Direct operational requirement: loan repayments are debited from specific customer deposit accounts. Existing source_account_number is denormalized string; proper FK enables automated ACH/direct debit' ;
    rdfs:domain ind:Repayment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DepositAccount .

ind:exchangeRate rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate' ;
    rdfs:comment 'Foreign Exchange (FX) rate applied if the repayment currency differs from the loan currency. Null if no currency conversion occurred.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interestAmount rdf:type rdf:Property ;
    rdfs:label 'Interest Amount' ;
    rdfs:comment 'Portion of the payment allocated to accrued interest charges on the loan. Contributes to Net Interest Income (NII) calculation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:notes rdf:type rdf:Property ;
    rdfs:label 'Notes' ;
    rdfs:comment 'Free-text field for additional comments or context about the repayment transaction. Used for customer service, dispute resolution, and audit purposes.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outstandingBalanceAfterPayment rdf:type rdf:Property ;
    rdfs:label 'Outstanding Balance After Payment' ;
    rdfs:comment 'Remaining principal balance on the loan immediately after this repayment is applied. Critical for Exposure at Default (EAD) and credit risk calculations.' ;
    rdfs:domain ind:Repayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentAmount rdf:type rdf:Property ;
    rdfs:label 'Payment Amount' ;
    rdfs:comment 'Total amount received in this repayment transaction, including principal, interest, fees, and penalties. Gross payment amount before allocation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentDate rdf:type rdf:Property ;
    rdfs:label 'Payment Date' ;
    rdfs:comment 'The date on which the repayment was received and applied to the loan account. This is the business event date for the repayment transaction.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentProcessorCode rdf:type rdf:Property ;
    rdfs:label 'Payment Processor Code' ;
    rdfs:comment 'Identifier of the payment processing system or hub that handled this transaction. References systems such as ACI Worldwide or Volante payment platforms.' ;
    rdfs:domain ind:Repayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Reference Number' ;
    rdfs:comment 'External payment reference number or transaction identifier provided by the payment system or customer. Used for reconciliation and customer inquiries.' ;
    rdfs:domain ind:Repayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTimeliness rdf:type rdf:Property ;
    rdfs:label 'Payment Timeliness' ;
    rdfs:comment 'Classification of whether the payment was received on-time, early, or late relative to the scheduled_payment_date. Critical for Non-Performing Loan (NPL) classification and delinquency tracking.' ;
    rdfs:domain ind:Repayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentType rdf:type rdf:Property ;
    rdfs:label 'Payment Type' ;
    rdfs:comment 'Classification of the repayment transaction type. Scheduled indicates a regular installment; prepayment indicates early principal reduction; partial indicates less than scheduled amount; balloon indicates large lump-sum; final indicates loan payoff.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyInterestAmount rdf:type rdf:Property ;
    rdfs:label 'Penalty Interest Amount' ;
    rdfs:comment 'Portion of the payment allocated to penalty interest charges for late payment or covenant breach. Tracked separately for regulatory reporting.' ;
    rdfs:domain ind:Repayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postingDate rdf:type rdf:Property ;
    rdfs:label 'Posting Date' ;
    rdfs:comment 'The date on which the repayment was posted to the General Ledger (GL) for accounting purposes. May differ from payment_date due to batch processing.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:prepaymentFlag rdf:type rdf:Property ;
    rdfs:label 'Prepayment Flag' ;
    rdfs:comment 'Indicates whether this repayment includes a prepayment component (principal paid ahead of schedule). True if prepayment occurred; false otherwise.' ;
    rdfs:domain ind:Repayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:principalAmount rdf:type rdf:Property ;
    rdfs:label 'Principal Amount' ;
    rdfs:comment 'Portion of the payment allocated to reduce the outstanding principal balance of the loan. Core component for amortization tracking.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reversalDate rdf:type rdf:Property ;
    rdfs:label 'Reversal Date' ;
    rdfs:comment 'The date on which the repayment transaction was reversed, if applicable. Null if the transaction has not been reversed.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reversalFlag rdf:type rdf:Property ;
    rdfs:label 'Reversal Flag' ;
    rdfs:comment 'Indicates whether this repayment transaction has been reversed due to insufficient funds, dispute, or error. True if reversed; false otherwise.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reversalReason rdf:type rdf:Property ;
    rdfs:label 'Reversal Reason' ;
    rdfs:comment 'Explanation for why the repayment was reversed, if applicable. Includes reasons such as insufficient funds, customer dispute, or processing error. Null if not reversed.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Payment Date' ;
    rdfs:comment 'The originally scheduled due date for this repayment installment per the loan amortization schedule. Used to determine if payment is on-time, early, or late.' ;
    rdfs:domain ind:Repayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transactionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transaction Timestamp' ;
    rdfs:comment 'Precise date and time when the repayment transaction was processed by the payment system. Used for audit trail and reconciliation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:waiverAmount rdf:type rdf:Property ;
    rdfs:label 'Waiver Amount' ;
    rdfs:comment 'Amount of fees or penalties waived by the bank as part of this repayment transaction. Used for customer relationship management and regulatory reporting.' ;
    rdfs:domain ind:Repayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waiverReason rdf:type rdf:Property ;
    rdfs:label 'Waiver Reason' ;
    rdfs:comment 'Business justification for waiving fees or penalties, if applicable. Includes reasons such as customer goodwill, hardship, or error correction. Null if no waiver applied.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:covenantId rdf:type rdf:Property ;
    rdfs:label 'Covenant Id' ;
    rdfs:comment 'Unique identifier for the covenant record. Primary key.' ;
    rdfs:domain ind:Covenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:amendmentCount rdf:type rdf:Property ;
    rdfs:label 'Amendment Count' ;
    rdfs:comment 'Number of times this covenant has been amended since origination, tracking the history of modifications to covenant terms.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:breachConsequence rdf:type rdf:Property ;
    rdfs:label 'Breach Consequence' ;
    rdfs:comment 'Description of the consequences if the covenant is breached, such as event of default, increased interest rate, mandatory prepayment, or requirement for additional collateral.' ;
    rdfs:domain ind:Covenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:covenantCategory rdf:type rdf:Property ;
    rdfs:label 'Covenant Category' ;
    rdfs:comment 'Detailed sub-classification of the covenant within its type, such as leverage ratio, interest coverage, debt service coverage, capital expenditure limit, dividend restriction, or asset sale restriction.' ;
    rdfs:domain ind:Covenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:covenantDescription rdf:type rdf:Property ;
    rdfs:label 'Covenant Description' ;
    rdfs:comment 'Detailed textual description of the covenant terms, conditions, and requirements as documented in the credit agreement.' ;
    rdfs:domain ind:Covenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:covenantName rdf:type rdf:Property ;
    rdfs:label 'Covenant Name' ;
    rdfs:comment 'Human-readable name or title of the covenant as stated in the credit agreement documentation.' ;
    rdfs:domain ind:Covenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:covenantStatus rdf:type rdf:Property ;
    rdfs:label 'Covenant Status' ;
    rdfs:comment 'Current lifecycle status of the covenant indicating whether it is actively monitored, temporarily suspended, waived, terminated, in breach, or breach has been cured.' ;
    rdfs:domain ind:Covenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:covenantType rdf:type rdf:Property ;
    rdfs:label 'Covenant Type' ;
    rdfs:comment 'Classification of the covenant based on its nature: financial (ratio-based), affirmative (actions required), negative (restrictions), reporting (disclosure obligations), or information (notification requirements).' ;
    rdfs:domain ind:Covenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdByUser rdf:type rdf:Property ;
    rdfs:label 'Created By User' ;
    rdfs:comment 'User identifier or system account that created this covenant record, supporting audit trail requirements.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossDefaultFlag rdf:type rdf:Property ;
    rdfs:label 'Cross Default Flag' ;
    rdfs:comment 'Indicates whether a breach of this covenant triggers cross-default provisions in other credit facilities or debt instruments of the borrower.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cureMechanism rdf:type rdf:Property ;
    rdfs:label 'Cure Mechanism' ;
    rdfs:comment 'Description of the permitted cure mechanism, such as equity contribution, asset sale proceeds application, or other remediation methods allowed under the credit agreement.' ;
    rdfs:domain ind:Covenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cureProvisionFlag rdf:type rdf:Property ;
    rdfs:label 'Cure Provision Flag' ;
    rdfs:comment 'Indicates whether the credit agreement includes a cure provision allowing the borrower to remedy a covenant breach through equity injection or other specified actions.' ;
    rdfs:domain ind:Covenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataClassification rdf:type rdf:Property ;
    rdfs:label 'Data Classification' ;
    rdfs:comment 'Classification level of this covenant record based on sensitivity, typically confidential due to commercial lending terms and borrower financial information.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expirationDate rdf:type rdf:Property ;
    rdfs:label 'Expiration Date' ;
    rdfs:comment 'Date on which the covenant obligation terminates, typically aligned with facility maturity or earlier if specified. Null for covenants that remain in effect for the life of the facility.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:financialStatementSource rdf:type rdf:Property ;
    rdfs:label 'Financial Statement Source' ;
    rdfs:comment 'Type of financial statements required for covenant testing, such as audited annual statements, unaudited quarterly statements, management-certified financials, or regulatory filings.' ;
    rdfs:domain ind:Covenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gracePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Grace Period Days' ;
    rdfs:comment 'Number of days allowed after a covenant breach before it constitutes an event of default, providing the borrower time to cure the breach.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastAmendmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Amendment Date' ;
    rdfs:comment 'Date of the most recent amendment to this covenant. Null if the covenant has never been amended.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:materialityClassification rdf:type rdf:Property ;
    rdfs:label 'Materiality Classification' ;
    rdfs:comment 'Risk-based classification of the covenants importance to credit risk management, with critical covenants triggering immediate escalation upon breach.' ;
    rdfs:domain ind:Covenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementBasis rdf:type rdf:Property ;
    rdfs:label 'Measurement Basis' ;
    rdfs:comment 'Accounting or calculation methodology used to measure covenant compliance, including definitions of terms like EBITDA, net debt, or tangible net worth as specified in the credit agreement.' ;
    rdfs:domain ind:Covenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Modified By User' ;
    rdfs:comment 'User identifier or system account that last modified this covenant record, supporting audit trail requirements.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Modified Timestamp' ;
    rdfs:comment 'Timestamp when this covenant record was last modified, tracking changes for audit and compliance purposes.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:regulatoryFramework rdf:type rdf:Property ;
    rdfs:label 'Regulatory Framework' ;
    rdfs:comment 'Name of the regulatory framework or requirement that mandates this covenant, such as Basel III, CCAR, DFAST, or CECL. Null for commercial covenants.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Requirement Flag' ;
    rdfs:comment 'Indicates whether this covenant is mandated by regulatory requirements such as Basel III capital adequacy, Dodd-Frank Act stress testing (DFAST), or Comprehensive Capital Analysis and Review (CCAR) rather than being a commercial lending term.' ;
    rdfs:domain ind:Covenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportingDeadlineDays rdf:type rdf:Property ;
    rdfs:label 'Reporting Deadline Days' ;
    rdfs:comment 'Number of days after the measurement period end by which the borrower must report covenant compliance results to the lender, typically 30-45 days for quarterly financial covenants.' ;
    rdfs:domain ind:Covenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responsibleParty rdf:type rdf:Property ;
    rdfs:label 'Responsible Party' ;
    rdfs:comment 'Entity responsible for maintaining compliance with this covenant, which may be the borrower, a guarantor, parent company, or specific subsidiary.' ;
    rdfs:domain ind:Covenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testingLevel rdf:type rdf:Property ;
    rdfs:label 'Testing Level' ;
    rdfs:comment 'Organizational level at which covenant compliance is measured, such as consolidated group, standalone borrower, guarantor group, or restricted subsidiary group.' ;
    rdfs:domain ind:Covenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdOperator rdf:type rdf:Property ;
    rdfs:label 'Threshold Operator' ;
    rdfs:comment 'Comparison operator that defines the compliance condition relative to the threshold value (e.g., must not exceed, must be greater than, must maintain at least). [ENUM-REF-CANDIDATE: greater_than|less_than|equal_to|greater_or_equal|less_or_equal|between|not_exceed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Covenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdUnit rdf:type rdf:Property ;
    rdfs:label 'Threshold Unit' ;
    rdfs:comment 'Unit of measurement for the threshold value, such as ratio (x), percentage (%), currency amount (USD), or basis points (BPS).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdValue rdf:type rdf:Property ;
    rdfs:label 'Threshold Value' ;
    rdfs:comment 'Numeric threshold or limit that defines compliance for financial covenants, such as maximum leverage ratio of 3.5x or minimum interest coverage of 2.0x.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waiverEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Waiver Effective Date' ;
    rdfs:comment 'Date from which the covenant waiver becomes effective. Null if no waiver has been granted.' ;
    rdfs:domain ind:Covenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:waiverExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Waiver Expiration Date' ;
    rdfs:comment 'Date on which the covenant waiver expires and normal compliance obligations resume. Null for permanent waivers or if no waiver has been granted.' ;
    rdfs:domain ind:Covenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:waiverGrantedFlag rdf:type rdf:Property ;
    rdfs:label 'Waiver Granted Flag' ;
    rdfs:comment 'Indicates whether a waiver has been granted by the lender(s) for this covenant, temporarily or permanently relieving the borrower from compliance obligations.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loanEclProvisionId rdf:type rdf:Property ;
    rdfs:label 'Loan Ecl Provision Id' ;
    rdfs:comment 'Unique identifier for the expected credit loss provision record.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LoanEclProvision .

ind:creditReviewId rdf:type rdf:Property ;
    rdfs:label 'Credit Review Id' ;
    rdfs:comment 'Foreign key linking to loan.credit_review. Business justification: ECL stage classifications and provision amounts are frequently updated following credit reviews. Linking loan_ecl_provision to the credit_review_id that triggered the stage migration or provision upda' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CreditReview .

ind:accountingFramework rdf:type rdf:Property ;
    rdfs:label 'Accounting Framework' ;
    rdfs:comment 'The accounting standard under which this provision is calculated (IFRS 9, CECL/ASC 326, or Local GAAP).' ;
    rdfs:domain ind:LoanEclProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Calculation Timestamp' ;
    rdfs:comment 'The date and time when this ECL provision calculation was performed.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:creditImpairedIndicator rdf:type rdf:Property ;
    rdfs:label 'Credit Impaired Indicator' ;
    rdfs:comment 'Boolean flag indicating whether the loan is credit-impaired (Stage 3 under IFRS 9 or NPL status).' ;
    rdfs:domain ind:LoanEclProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cumulativeProvisionAmount rdf:type rdf:Property ;
    rdfs:label 'Cumulative Provision Amount' ;
    rdfs:comment 'The total accumulated provision balance for this loan as of the reporting date.' ;
    rdfs:domain ind:LoanEclProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eclModelCode rdf:type rdf:Property ;
    rdfs:label 'Ecl Model Code' ;
    rdfs:comment 'Identifier of the ECL calculation model or methodology used (e.g., PD/LGD/EAD model, vintage analysis, roll-rate model).' ;
    rdfs:domain ind:LoanEclProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forbearanceIndicator rdf:type rdf:Property ;
    rdfs:label 'Forbearance Indicator' ;
    rdfs:comment 'Boolean flag indicating whether the loan is under forbearance or modification due to borrower financial difficulty.' ;
    rdfs:domain ind:LoanEclProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overrideIndicator rdf:type rdf:Property ;
    rdfs:label 'Override Indicator' ;
    rdfs:comment 'Boolean flag indicating whether the provision amount was manually overridden by credit risk management.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:previousStageClassification rdf:type rdf:Property ;
    rdfs:label 'Previous Stage Classification' ;
    rdfs:comment 'The credit risk stage classification in the prior reporting period, used to track stage migrations.' ;
    rdfs:domain ind:LoanEclProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:provisionCurrency rdf:type rdf:Property ;
    rdfs:label 'Provision Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the provision amount.' ;
    rdfs:domain ind:LoanEclProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:provisionMovementType rdf:type rdf:Property ;
    rdfs:label 'Provision Movement Type' ;
    rdfs:comment 'The type of movement in the provision balance: New (initial provision), Increase (additional provision), Decrease (partial release), Release (full release), Write-Off (charge-off against provision), Transfer (stage migration).' ;
    rdfs:domain ind:LoanEclProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:provisionNumber rdf:type rdf:Property ;
    rdfs:label 'Provision Number' ;
    rdfs:comment 'Business identifier for the provision record, used for external reporting and audit trails.' ;
    rdfs:domain ind:LoanEclProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recoveryRate rdf:type rdf:Property ;
    rdfs:label 'Recovery Rate' ;
    rdfs:comment 'The expected recovery rate in the event of default, expressed as a decimal (1 - LGD).' ;
    rdfs:domain ind:LoanEclProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryReportingIndicator rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this provision record is included in regulatory capital and stress testing reports (Basel III, CCAR, DFAST).' ;
    rdfs:domain ind:LoanEclProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportingPeriodDate rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Date' ;
    rdfs:comment 'The financial reporting period end date for which this ECL provision is calculated (e.g., quarter-end, year-end).' ;
    rdfs:domain ind:LoanEclProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scenarioWeight rdf:type rdf:Property ;
    rdfs:label 'Scenario Weight' ;
    rdfs:comment 'The probability weight assigned to this macroeconomic scenario in the weighted-average ECL calculation, expressed as a decimal (e.g., 0.60 = 60%).' ;
    rdfs:domain ind:LoanEclProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:significantIncreaseIndicator rdf:type rdf:Property ;
    rdfs:label 'Significant Increase Indicator' ;
    rdfs:comment 'Boolean flag indicating whether there has been a significant increase in credit risk since initial recognition (triggers Stage 2 under IFRS 9).' ;
    rdfs:domain ind:LoanEclProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stageClassification rdf:type rdf:Property ;
    rdfs:label 'Stage Classification' ;
    rdfs:comment 'Credit risk staging under IFRS 9 (Stage 1, 2, 3) or CECL classification (12-Month ECL, Lifetime ECL, Credit-Impaired). Stage 1: performing loans with no significant increase in credit risk. Stage 2: significant increase in credit risk since origination. Stage 3: credit-impaired/non-performing.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeToDefaultMonths rdf:type rdf:Property ;
    rdfs:label 'Time To Default Months' ;
    rdfs:comment 'The estimated time horizon in months over which the default probability is measured (12 for Stage 1, lifetime for Stage 2/3).' ;
    rdfs:domain ind:LoanEclProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:modificationId rdf:type rdf:Property ;
    rdfs:label 'Modification Id' ;
    rdfs:comment 'Primary key for modification' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Modification .

ind:fraudCaseId rdf:type rdf:Property ;
    rdfs:label 'Fraud Case Id' ;
    rdfs:comment 'Foreign key linking to fraud.case. Business justification: Loan modification fraud: fraudulent modification requests (employee fraud, unauthorized rate changes, forged borrower consent) are a named fraud typology. Fraud cases are opened against specific modif' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Case .

ind:glJournalEntryId rdf:type rdf:Property ;
    rdfs:label 'Gl Journal Entry Id' ;
    rdfs:comment 'Foreign key linking to ledger.journal_entry. Business justification: Loan modifications generate journal entries for TDR classification, modification gain/loss recognition, and principal forgiveness accounting. Required for GAAP/IFRS compliance and regulatory TDR repor' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntry .

ind:approvingAuthority rdf:type rdf:Property ;
    rdfs:label 'Approving Authority' ;
    rdfs:comment 'The name or title of the credit authority (individual, committee, or board) that approved this modification.' ;
    rdfs:domain ind:Modification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvingAuthorityLevel rdf:type rdf:Property ;
    rdfs:label 'Approving Authority Level' ;
    rdfs:comment 'The hierarchical level of the approving authority. Indicates the escalation tier required for this modification based on risk and materiality.' ;
    rdfs:domain ind:Modification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ceclStageAfter rdf:type rdf:Property ;
    rdfs:label 'Cecl Stage After' ;
    rdfs:comment 'The CECL impairment stage classification of the loan after the modification is applied. Used to track stage migration resulting from the modification.' ;
    rdfs:domain ind:Modification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ceclStageBefore rdf:type rdf:Property ;
    rdfs:label 'Cecl Stage Before' ;
    rdfs:comment 'The CECL impairment stage classification of the loan immediately prior to the modification (Stage 1: performing, Stage 2: underperforming, Stage 3: credit-impaired).' ;
    rdfs:domain ind:Modification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collateralAdjustmentFlag rdf:type rdf:Property ;
    rdfs:label 'Collateral Adjustment Flag' ;
    rdfs:comment 'Indicates whether this modification involved changes to collateral requirements, pledges, or Loan-to-Value (LTV) ratios. True if collateral terms were adjusted.' ;
    rdfs:domain ind:Modification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:covenantWaiverFlag rdf:type rdf:Property ;
    rdfs:label 'Covenant Waiver Flag' ;
    rdfs:comment 'Indicates whether this modification includes a waiver of one or more financial or operational covenants. True if covenants were waived.' ;
    rdfs:domain ind:Modification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:executionDate rdf:type rdf:Property ;
    rdfs:label 'Execution Date' ;
    rdfs:comment 'The date the modification agreement was executed and legally binding documentation was completed.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gainLossAmount rdf:type rdf:Property ;
    rdfs:label 'Gain Loss Amount' ;
    rdfs:comment 'The accounting gain or loss recognized as a result of the modification, calculated as the difference between the present value of the original and modified cash flows. Positive for gain, negative for loss.' ;
    rdfs:domain ind:Modification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:internalNotes rdf:type rdf:Property ;
    rdfs:label 'Internal Notes' ;
    rdfs:comment 'Confidential internal notes and commentary regarding the modification decision, borrower negotiations, and risk considerations. Not shared externally.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRegulatoryReportable rdf:type rdf:Property ;
    rdfs:label 'Is Regulatory Reportable' ;
    rdfs:comment 'Indicates whether this modification must be reported to regulatory authorities (e.g., OCC, Fed, FDIC) under applicable reporting frameworks.' ;
    rdfs:domain ind:Modification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTdr rdf:type rdf:Property ;
    rdfs:label 'Is Tdr' ;
    rdfs:comment 'Indicates whether this modification qualifies as a Troubled Debt Restructuring under CECL and regulatory guidance. True if the borrower is experiencing financial difficulty and the lender granted a concession.' ;
    rdfs:domain ind:Modification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalDocumentationReference rdf:type rdf:Property ;
    rdfs:label 'Legal Documentation Reference' ;
    rdfs:comment 'Reference number or identifier for the legal amendment agreement or forbearance letter executed for this modification.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modificationDate rdf:type rdf:Property ;
    rdfs:label 'Modification Date' ;
    rdfs:comment 'The date on which the modification terms become effective and binding. This is the principal business event timestamp for the modification.' ;
    rdfs:domain ind:Modification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:modificationNumber rdf:type rdf:Property ;
    rdfs:label 'Modification Number' ;
    rdfs:comment 'Business-facing unique reference number assigned to this modification for tracking and reporting purposes.' ;
    rdfs:domain ind:Modification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modificationStatus rdf:type rdf:Property ;
    rdfs:label 'Modification Status' ;
    rdfs:comment 'Current lifecycle state of the modification request. Tracks the approval and execution workflow.' ;
    rdfs:domain ind:Modification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modificationType rdf:type rdf:Property ;
    rdfs:label 'Modification Type' ;
    rdfs:comment 'Classification of the modification action taken. Determines the nature of the amendment to the original loan terms.' ;
    rdfs:domain ind:Modification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedInterestRate rdf:type rdf:Property ;
    rdfs:label 'Modified Interest Rate' ;
    rdfs:comment 'The new interest rate applicable to the loan after this modification, expressed as a decimal. Null if rate was not changed.' ;
    rdfs:domain ind:Modification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modifiedMaturityDate rdf:type rdf:Property ;
    rdfs:label 'Modified Maturity Date' ;
    rdfs:comment 'The new maturity date of the loan after this modification is applied. Null if maturity was not changed.' ;
    rdfs:domain ind:Modification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:modifiedPrincipalAmount rdf:type rdf:Property ;
    rdfs:label 'Modified Principal Amount' ;
    rdfs:comment 'The principal balance after applying any forgiveness, capitalization, or other principal adjustments. Null if principal was not changed.' ;
    rdfs:domain ind:Modification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nplStatusAfter rdf:type rdf:Property ;
    rdfs:label 'Npl Status After' ;
    rdfs:comment 'The credit quality classification of the loan after modification. Tracks whether the modification successfully cured the NPL status.' ;
    rdfs:domain ind:Modification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nplStatusBefore rdf:type rdf:Property ;
    rdfs:label 'Npl Status Before' ;
    rdfs:comment 'The credit quality classification of the loan prior to modification. Used to assess whether the modification is part of NPL workout management.' ;
    rdfs:domain ind:Modification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalInterestRate rdf:type rdf:Property ;
    rdfs:label 'Original Interest Rate' ;
    rdfs:comment 'The interest rate applicable to the loan prior to this modification, expressed as a decimal (e.g., 0.0525 for 5.25%).' ;
    rdfs:domain ind:Modification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalMaturityDate rdf:type rdf:Property ;
    rdfs:label 'Original Maturity Date' ;
    rdfs:comment 'The maturity date of the loan prior to this modification. Retained for historical comparison and regulatory reporting.' ;
    rdfs:domain ind:Modification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originalPrincipalAmount rdf:type rdf:Property ;
    rdfs:label 'Original Principal Amount' ;
    rdfs:comment 'The outstanding principal balance of the loan at the time of modification request.' ;
    rdfs:domain ind:Modification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentDeferralMonths rdf:type rdf:Property ;
    rdfs:label 'Payment Deferral Months' ;
    rdfs:comment 'The number of months for which scheduled payments are deferred. Zero if no deferral was granted.' ;
    rdfs:domain ind:Modification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:principalForgivenessAmount rdf:type rdf:Property ;
    rdfs:label 'Principal Forgiveness Amount' ;
    rdfs:comment 'The amount of principal forgiven or written down as part of this modification. Zero if no forgiveness occurred.' ;
    rdfs:domain ind:Modification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requestDate rdf:type rdf:Property ;
    rdfs:label 'Request Date' ;
    rdfs:comment 'The date the borrower or lender initiated the modification request.' ;
    rdfs:domain ind:Modification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:updatedByUser rdf:type rdf:Property ;
    rdfs:label 'Updated By User' ;
    rdfs:comment 'The user ID or name of the individual who last updated this modification record.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collateralLinkId rdf:type rdf:Property ;
    rdfs:label 'Collateral Link Id' ;
    rdfs:comment 'Unique identifier for the collateral link record. Primary key for the association between a loan facility and pledged collateral asset.' ;
    rdfs:domain ind:CollateralLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:securityInstrumentId rdf:type rdf:Property ;
    rdfs:label 'Security Instrument Id' ;
    rdfs:comment 'Foreign key linking to security.instrument. Business justification: Collateral_link already has collateral_asset_id (physical/real assets). Securities pledged as collateral require separate instrument reference for market-based valuation, haircut application, and marg' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Instrument .

ind:allocationPercentage rdf:type rdf:Property ;
    rdfs:label 'Allocation Percentage' ;
    rdfs:comment 'The percentage of the collateral asset value allocated to this specific loan facility. Used when a single collateral asset secures multiple loans. Sum of allocation percentages across all links for a collateral asset should equal 1.0000 (100%).' ;
    rdfs:domain ind:CollateralLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:crossCollateralizationFlag rdf:type rdf:Property ;
    rdfs:label 'Cross Collateralization Flag' ;
    rdfs:comment 'Indicates whether this collateral secures multiple loan facilities under a cross-collateralization agreement. True means the collateral is pledged to secure more than one loan obligation.' ;
    rdfs:domain ind:CollateralLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currentValueAsOfDate rdf:type rdf:Property ;
    rdfs:label 'Current Value As Of Date' ;
    rdfs:comment 'The date on which the current collateral value was determined. Indicates the valuation date for the most recent appraisal or market assessment.' ;
    rdfs:domain ind:CollateralLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eligibleCollateralValueAmount rdf:type rdf:Property ;
    rdfs:label 'Eligible Collateral Value Amount' ;
    rdfs:comment 'The collateral value after applying regulatory haircuts and eligibility criteria. Used for Risk-Weighted Assets (RWA) calculation and regulatory capital reporting under Basel III.' ;
    rdfs:domain ind:CollateralLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:haircutPercentage rdf:type rdf:Property ;
    rdfs:label 'Haircut Percentage' ;
    rdfs:comment 'The discount applied to the collateral value for risk management and regulatory capital purposes. Expressed as a decimal (e.g., 0.2000 represents 20% haircut). Reflects potential loss in value during liquidation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Insurance Expiration Date' ;
    rdfs:comment 'The date on which the collateral insurance policy expires. Monitored to ensure continuous coverage and covenant compliance.' ;
    rdfs:domain ind:CollateralLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:insurancePolicyNumber rdf:type rdf:Property ;
    rdfs:label 'Insurance Policy Number' ;
    rdfs:comment 'The policy number for the insurance coverage on the pledged collateral. Used to verify insurance compliance and file claims in the event of loss or damage.' ;
    rdfs:domain ind:CollateralLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Insurance Required Flag' ;
    rdfs:comment 'Indicates whether the loan agreement requires the borrower to maintain insurance coverage on the pledged collateral. True means insurance is mandatory to protect the lenders security interest.' ;
    rdfs:domain ind:CollateralLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastRevaluationDate rdf:type rdf:Property ;
    rdfs:label 'Last Revaluation Date' ;
    rdfs:comment 'The date of the most recent collateral revaluation. Used to monitor compliance with revaluation frequency requirements and identify stale valuations.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lenderLossPayeeFlag rdf:type rdf:Property ;
    rdfs:label 'Lender Loss Payee Flag' ;
    rdfs:comment 'Indicates whether the lender is named as loss payee on the collateral insurance policy. True means insurance proceeds will be paid to the lender to protect the security interest.' ;
    rdfs:domain ind:CollateralLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lienPosition rdf:type rdf:Property ;
    rdfs:label 'Lien Position' ;
    rdfs:comment 'Priority ranking of the lien on the collateral asset. Determines the order of claim in the event of default and liquidation. First lien has highest priority, subordinate has lowest.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Link Effective Date' ;
    rdfs:comment 'The date on which the collateral was pledged to secure the loan. Marks the beginning of the collateral relationship and the start of lien priority.' ;
    rdfs:domain ind:CollateralLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:linkReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Link Reference Number' ;
    rdfs:comment 'Business-facing reference number for the collateral link relationship. Used in loan documentation and collateral agreements.' ;
    rdfs:domain ind:CollateralLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkStatus rdf:type rdf:Property ;
    rdfs:label 'Link Status' ;
    rdfs:comment 'Current lifecycle status of the collateral link relationship. Active indicates the collateral is currently securing the loan. Released indicates the lien has been discharged. Impaired indicates collateral value has deteriorated significantly.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkTerminationDate rdf:type rdf:Property ;
    rdfs:label 'Link Termination Date' ;
    rdfs:comment 'The date on which the collateral lien was released or the collateral relationship ended. Occurs upon loan payoff, collateral substitution, or lien release.' ;
    rdfs:domain ind:CollateralLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ltvRatioAtOrigination rdf:type rdf:Property ;
    rdfs:label 'Ltv Ratio At Origination' ;
    rdfs:comment 'The ratio of the loan amount to the pledged collateral value at the time of loan origination. Expressed as a decimal (e.g., 0.8000 represents 80%). Key credit risk metric used in underwriting decisions.' ;
    rdfs:domain ind:CollateralLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marginCallStatus rdf:type rdf:Property ;
    rdfs:label 'Margin Call Status' ;
    rdfs:comment 'Current status of any margin call on this collateral link. None indicates no margin call. Issued indicates a margin call has been sent to the borrower. Cured indicates the borrower has satisfied the margin call.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marginCallThresholdPercentage rdf:type rdf:Property ;
    rdfs:label 'Margin Call Threshold Percentage' ;
    rdfs:comment 'The Loan-to-Value (LTV) ratio threshold that triggers a margin call requiring the borrower to pledge additional collateral or pay down the loan. Expressed as a decimal (e.g., 0.8500 represents 85% LTV threshold).' ;
    rdfs:domain ind:CollateralLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextRevaluationDate rdf:type rdf:Property ;
    rdfs:label 'Next Revaluation Date' ;
    rdfs:comment 'The date on which the next collateral revaluation is scheduled or required. Used for operational planning and compliance monitoring.' ;
    rdfs:domain ind:CollateralLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:perfectionDate rdf:type rdf:Property ;
    rdfs:label 'Perfection Date' ;
    rdfs:comment 'The date on which the security interest was perfected through proper filing or registration. Establishes priority over competing claims.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:perfectionJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Perfection Jurisdiction' ;
    rdfs:comment 'Three-letter ISO country code indicating the jurisdiction where the security interest was perfected. Determines applicable legal framework and enforcement procedures.' ;
    rdfs:domain ind:CollateralLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:perfectionMethod rdf:type rdf:Property ;
    rdfs:label 'Perfection Method' ;
    rdfs:comment 'The legal mechanism used to perfect the security interest. UCC filing for personal property, mortgage registration for real estate, control agreements for securities, possession for physical assets.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:perfectionStatus rdf:type rdf:Property ;
    rdfs:label 'Perfection Status' ;
    rdfs:comment 'Legal status of the security interest in the collateral. Perfected indicates the lien has been properly filed and recorded (e.g., UCC-1 filing, mortgage registration). Unperfected liens may not be enforceable against third parties.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pledgedValueAmount rdf:type rdf:Property ;
    rdfs:label 'Pledged Value Amount' ;
    rdfs:comment 'The monetary value of the collateral pledged at the time of loan origination. Represents the initial collateral valuation used for underwriting and Loan-to-Value (LTV) calculation.' ;
    rdfs:domain ind:CollateralLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pledgedValueCurrency rdf:type rdf:Property ;
    rdfs:label 'Pledged Value Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the pledged value amount. Indicates the currency in which the collateral was valued at origination.' ;
    rdfs:domain ind:CollateralLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revaluationFrequency rdf:type rdf:Property ;
    rdfs:label 'Revaluation Frequency' ;
    rdfs:comment 'The required frequency for revaluing the pledged collateral. Determined by loan agreement terms, collateral type, and regulatory requirements. Event-driven revaluations occur upon material changes.' ;
    rdfs:domain ind:CollateralLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substitutionAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Substitution Allowed Flag' ;
    rdfs:comment 'Indicates whether the loan agreement permits the borrower to substitute alternative collateral for the currently pledged asset. True means substitution is permitted subject to lender approval.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:uccExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Ucc Expiration Date' ;
    rdfs:comment 'The date on which the UCC-1 financing statement expires. Typically five years from filing date. Requires continuation statement to maintain perfection beyond expiration.' ;
    rdfs:domain ind:CollateralLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:uccFilingNumber rdf:type rdf:Property ;
    rdfs:label 'Ucc Filing Number' ;
    rdfs:comment 'The official filing number assigned by the Secretary of State or other filing office for the UCC-1 financing statement. Used to search and verify the perfected security interest.' ;
    rdfs:domain ind:CollateralLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:writeOffId rdf:type rdf:Property ;
    rdfs:label 'Write Off Id' ;
    rdfs:comment 'Unique identifier for the write-off event. Primary key for the write-off record.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:callReportSchedule rdf:type rdf:Property ;
    rdfs:label 'Call Report Schedule' ;
    rdfs:comment 'The specific Call Report schedule and line item where this write-off is reported (e.g., Schedule RI-B Part II, Line 6a).' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeOffReasonCode rdf:type rdf:Property ;
    rdfs:label 'Charge Off Reason Code' ;
    rdfs:comment 'The primary reason for the charge-off: bankruptcy filing, borrower deceased, fraud, deemed uncollectable, statute of limitations expired, or other.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeOffReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Charge Off Reason Description' ;
    rdfs:comment 'Free-text narrative providing additional context and details about the reason for the charge-off.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collateralLiquidationFlag rdf:type rdf:Property ;
    rdfs:label 'Collateral Liquidation Flag' ;
    rdfs:comment 'Indicates whether collateral was liquidated prior to or as part of the write-off process (True) or not (False).' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:collateralLiquidationProceeds rdf:type rdf:Property ;
    rdfs:label 'Collateral Liquidation Proceeds' ;
    rdfs:comment 'The net proceeds received from liquidation of collateral prior to write-off, applied to reduce the write-off amount.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cumulativeRecoveryToDate rdf:type rdf:Property ;
    rdfs:label 'Cumulative Recovery To Date' ;
    rdfs:comment 'The total amount recovered from all sources (borrower payments, collateral liquidation, guarantor calls, debt sales) since the write-off date, updated with each recovery event.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daysPastDueAtWriteOff rdf:type rdf:Property ;
    rdfs:label 'Days Past Due At Write Off' ;
    rdfs:comment 'The number of days the loan was past due at the time of write-off, used for delinquency analysis and LGD modeling.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:debtSaleDate rdf:type rdf:Property ;
    rdfs:label 'Debt Sale Date' ;
    rdfs:comment 'The date on which the charged-off debt was sold to a third-party debt buyer, if applicable.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:debtSaleFlag rdf:type rdf:Property ;
    rdfs:label 'Debt Sale Flag' ;
    rdfs:comment 'Indicates whether the charged-off debt was sold to a third-party debt buyer (True) or retained for internal collection (False).' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:debtSaleProceeds rdf:type rdf:Property ;
    rdfs:label 'Debt Sale Proceeds' ;
    rdfs:comment 'The amount received from the sale of the charged-off debt to a third-party buyer, recorded as a recovery.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eadAtDefault rdf:type rdf:Property ;
    rdfs:label 'Ead At Default' ;
    rdfs:comment 'The total exposure at the time of default, used as the denominator in LGD calculation. Typically equals the total outstanding balance at default.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eclReserveReleasedAmount rdf:type rdf:Property ;
    rdfs:label 'Ecl Reserve Released Amount' ;
    rdfs:comment 'The amount of ECL (Expected Credit Loss) or ALLL (Allowance for Loan and Lease Losses) reserve released upon write-off, reducing the reserve balance.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feesWrittenOffAmount rdf:type rdf:Property ;
    rdfs:label 'Fees Written Off Amount' ;
    rdfs:comment 'The unpaid fees (late fees, penalty fees, servicing fees) that were charged off at the time of write-off.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:guarantorCallFlag rdf:type rdf:Property ;
    rdfs:label 'Guarantor Call Flag' ;
    rdfs:comment 'Indicates whether a guarantor was called upon for payment prior to or as part of the write-off process (True) or not (False).' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:guarantorRecoveryAmount rdf:type rdf:Property ;
    rdfs:label 'Guarantor Recovery Amount' ;
    rdfs:comment 'The amount recovered from guarantor(s) prior to write-off, applied to reduce the write-off amount.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interestWrittenOffAmount rdf:type rdf:Property ;
    rdfs:label 'Interest Written Off Amount' ;
    rdfs:comment 'The accrued but unpaid interest that was charged off at the time of write-off.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lgdRate rdf:type rdf:Property ;
    rdfs:label 'Lgd Rate' ;
    rdfs:comment 'The calculated Loss Given Default rate for this write-off: net loss after recovery divided by exposure at default (EAD). Expressed as a decimal (e.g., 0.4500 for 45%).' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netChargeOffAmount rdf:type rdf:Property ;
    rdfs:label 'Net Charge Off Amount' ;
    rdfs:comment 'The net loss recognized after applying reserve release: total write-off amount minus ECL reserve released. This is the P&L impact of the charge-off.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netLossAfterRecovery rdf:type rdf:Property ;
    rdfs:label 'Net Loss After Recovery' ;
    rdfs:comment 'The net loss remaining after all recoveries: total write-off amount minus cumulative recovery to date. Used for final LGD calculation.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:principalWrittenOffAmount rdf:type rdf:Property ;
    rdfs:label 'Principal Written Off Amount' ;
    rdfs:comment 'The outstanding principal balance of the loan that was charged off at the time of write-off.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recoveryPursuitStatus rdf:type rdf:Property ;
    rdfs:label 'Recovery Pursuit Status' ;
    rdfs:comment 'Current status of post-charge-off recovery efforts: active pursuit, suspended, closed with no recovery, closed with partial recovery, or closed with full recovery.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryClassificationAtWriteOff rdf:type rdf:Property ;
    rdfs:label 'Regulatory Classification At Write Off' ;
    rdfs:comment 'The regulatory asset classification of the loan at the time of write-off per OCC/FDIC guidelines: substandard, doubtful, or loss.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalWriteOffAmount rdf:type rdf:Property ;
    rdfs:label 'Total Write Off Amount' ;
    rdfs:comment 'The total amount written off, including principal, interest, and fees. Sum of all written-off components.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:writeOffDate rdf:type rdf:Property ;
    rdfs:label 'Write Off Date' ;
    rdfs:comment 'The date on which the loan balance was formally written off and removed from performing assets.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:writeOffNumber rdf:type rdf:Property ;
    rdfs:label 'Write Off Number' ;
    rdfs:comment 'Externally visible business identifier for the write-off transaction, used for audit trails and regulatory reporting.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:writeOffStatus rdf:type rdf:Property ;
    rdfs:label 'Write Off Status' ;
    rdfs:comment 'Current lifecycle status of the write-off record: pending approval, approved by credit committee, posted to general ledger, reversed due to error or recovery, or closed after final settlement.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:writeOffType rdf:type rdf:Property ;
    rdfs:label 'Write Off Type' ;
    rdfs:comment 'Classification of the write-off event: full charge-off (entire balance), partial charge-off (portion of balance), technical write-off (accounting treatment without legal discharge), or regulatory write-off (mandated by regulator).' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collateralInvestorAccountId rdf:type rdf:Property ;
    rdfs:label 'Collateral Investor Account Id' ;
    rdfs:comment 'Foreign key linking to asset.investor_account. Business justification: Ongoing credit monitoring: when loans are collateralized by fund holdings, periodic credit reviews assess the investor_account\'s current NAV, concentration risk, and liquidity. This link supports coll' ;
    rdfs:domain ind:CreditReview ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InvestorAccount .

ind:securityCreditRatingId rdf:type rdf:Property ;
    rdfs:label 'Security Credit Rating Id' ;
    rdfs:comment 'Foreign key linking to security.credit_rating. Business justification: Annual credit reviews incorporate external instrument/issuer ratings from security.credit_rating for SICR assessment under IFRS 9 and Basel IRB validation. credit_review has counterparty_rating_id→ris' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CreditRating .

ind:collateralRevaluationFlag rdf:type rdf:Property ;
    rdfs:label 'Collateral Revaluation Flag' ;
    rdfs:comment 'Indicates whether collateral supporting the facility was revalued as part of this credit review. True if revaluation was performed; false if existing valuations were deemed current.' ;
    rdfs:domain ind:CreditReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:covenantComplianceSummary rdf:type rdf:Property ;
    rdfs:label 'Covenant Compliance Summary' ;
    rdfs:comment 'Summary assessment of the borrower\'s compliance with financial and non-financial covenants. Compliant indicates all covenants met; minor_breach indicates technical violations with no material impact; material_breach indicates significant covenant violations; waived indicates breaches that have been formally waived by the lender; not_applicable indicates no covenants in place.' ;
    rdfs:domain ind:CreditReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditCommitteeDate rdf:type rdf:Property ;
    rdfs:label 'Credit Committee Date' ;
    rdfs:comment 'The date on which the credit committee formally reviewed and approved the credit review findings. Represents the official sign-off timestamp for governance and audit purposes.' ;
    rdfs:domain ind:CreditReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditCommitteeDecision rdf:type rdf:Property ;
    rdfs:label 'Credit Committee Decision' ;
    rdfs:comment 'Final decision rendered by the credit committee on the review findings and recommended action. Approved indicates acceptance of recommendations; approved_with_conditions indicates acceptance subject to specific requirements; rejected indicates committee disagreement; deferred indicates decision postponed; referred indicates escalation to higher authority.' ;
    rdfs:domain ind:CreditReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eclAmount rdf:type rdf:Property ;
    rdfs:label 'Ecl Amount' ;
    rdfs:comment 'The Expected Credit Loss (ECL) provision amount calculated for this facility based on the updated PD, LGD, and EAD estimates from this credit review. Represents the present value of expected credit losses over the relevant time horizon.' ;
    rdfs:domain ind:CreditReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financialPerformanceAssessment rdf:type rdf:Property ;
    rdfs:label 'Financial Performance Assessment' ;
    rdfs:comment 'Qualitative assessment of the borrower\'s financial performance since the last review. Considers revenue trends, profitability, cash flow generation, leverage ratios, and liquidity position.' ;
    rdfs:domain ind:CreditReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextReviewDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Review Due Date' ;
    rdfs:comment 'The scheduled date for the next periodic credit review. Typically set based on risk rating, with higher-risk credits requiring more frequent review.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:previousInternalRating rdf:type rdf:Property ;
    rdfs:label 'Previous Internal Rating' ;
    rdfs:comment 'The internal risk rating assigned to the borrower prior to this credit review. Used to track rating migration and credit quality trends.' ;
    rdfs:domain ind:CreditReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousLgd rdf:type rdf:Property ;
    rdfs:label 'Previous Lgd' ;
    rdfs:comment 'The Loss Given Default (LGD) estimate assigned to the facility prior to this review, expressed as a decimal (e.g., 0.45 for 45%). LGD represents the expected loss severity in the event of default, net of collateral recovery.' ;
    rdfs:domain ind:CreditReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:previousPd rdf:type rdf:Property ;
    rdfs:label 'Previous Pd' ;
    rdfs:comment 'The Probability of Default (PD) estimate assigned to the borrower prior to this review, expressed as a decimal (e.g., 0.025 for 2.5%). PD represents the likelihood of default over a one-year horizon under the IRB approach.' ;
    rdfs:domain ind:CreditReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recommendedAction rdf:type rdf:Property ;
    rdfs:label 'Recommended Action' ;
    rdfs:comment 'Credit analyst\'s recommended action based on review findings. Maintain indicates no change to risk rating or exposure; upgrade indicates improved credit quality; downgrade indicates deterioration; watchlist indicates heightened monitoring required; exit indicates recommendation to reduce or terminate exposure; restructure indicates need for amended terms.' ;
    rdfs:domain ind:CreditReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewComments rdf:type rdf:Property ;
    rdfs:label 'Review Comments' ;
    rdfs:comment 'Free-text field capturing key observations, concerns, mitigating factors, and qualitative insights from the credit review. Provides narrative context to support the quantitative assessment and rating decision.' ;
    rdfs:domain ind:CreditReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewStatus rdf:type rdf:Property ;
    rdfs:label 'Review Status' ;
    rdfs:comment 'Current lifecycle state of the credit review. Draft indicates work in progress; submitted means forwarded to credit committee; under_review indicates active assessment; approved means credit committee sign-off received; rejected means review findings require remediation; deferred means decision postponed pending additional information.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewType rdf:type rdf:Property ;
    rdfs:label 'Review Type' ;
    rdfs:comment 'Classification of the credit review based on its trigger and purpose. Annual reviews are scheduled periodic assessments; interim reviews occur mid-cycle; triggered reviews are event-driven (covenant breach, rating downgrade); special reviews are ad-hoc deep dives; renewal reviews support facility extension decisions; watchlist reviews monitor deteriorating credits.' ;
    rdfs:domain ind:CreditReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficiaryCountryId rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Country Id' ;
    rdfs:comment 'Foreign key linking to reference.country. Business justification: Beneficiary country drives sanctions screening (OFAC country-based sanctions), cross-border reporting (FFIEC 009), routing decisions (local rails vs correspondent), and AML risk scoring. Country maste' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:corporateActionId rdf:type rdf:Property ;
    rdfs:label 'Corporate Action Id' ;
    rdfs:comment 'Foreign key linking to security.corporate_action. Business justification: Corporate action STP: payment instructions for dividend disbursements, coupon payments, and redemptions are generated directly from corporate action events. Operations teams and regulatory reporting (' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CorporateAction .

ind:instructionBeneficiaryAccountDepositAccountId rdf:type rdf:Property ;
    rdfs:label 'Instruction Beneficiary Account Deposit Account Id' ;
    rdfs:comment 'Identifier of the account to which the payment is being credited (payee account).' ;
    rdfs:domain ind:Instruction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DepositAccount .

ind:instructionDepositAccountId rdf:type rdf:Property ;
    rdfs:label 'Instruction Deposit Account Id' ;
    rdfs:comment 'Identifier of the account from which the payment is being debited (payer account).' ;
    rdfs:domain ind:Instruction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DepositAccount .

ind:originatingBankingChannelId rdf:type rdf:Property ;
    rdfs:label 'Originating Banking Channel Id' ;
    rdfs:comment 'Foreign key linking to channel.channel. Business justification: Payment instructions originate through specific banking channels (branch, online banking, mobile app, relationship manager). Channel attribution is essential for operational analytics, channel-specifi' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:originatingDigitalChannelId rdf:type rdf:Property ;
    rdfs:label 'Originating Digital Channel Id' ;
    rdfs:comment 'Foreign key linking to channel.digital_channel. Business justification: Payment instructions originated via open banking/API channels must be linked to the specific digital channel (TPP) for PSD2 regulatory reporting, TPP liability attribution, and open banking audit trai' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DigitalChannel .

ind:originatorPartyId rdf:type rdf:Property ;
    rdfs:label 'Originator Party Id' ;
    rdfs:comment 'Foreign key linking to customer.party. Business justification: Payment origination tracking requires linking instruction to customer party for AML transaction monitoring, customer payment history reporting, and regulatory audit trails. Originator_name is denormal' ;
    rdfs:domain ind:Instruction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:paymentChannelId rdf:type rdf:Property ;
    rdfs:label 'Payment Channel Id' ;
    rdfs:comment 'Foreign key linking to payment.payment_channel. Business justification: payment_instruction has payment_rail_type which should reference payment_channel. payment_channel is the master registry of available payment rails (ACH, Fedwire, RTGS, SWIFT). This is a standard N:1 ' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentChannel .

ind:pledgeAgreementId rdf:type rdf:Property ;
    rdfs:label 'Pledge Agreement Id' ;
    rdfs:comment 'Foreign key linking to collateral.pledge_agreement. Business justification: Collateral transfer instructions are governed by pledge agreements that specify eligible collateral, transfer mechanics, and legal perfection requirements. Linking instruction to pledge_agreement enab' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PledgeAgreement .

ind:regulatoryReportingJurisdictionId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Jurisdiction Id' ;
    rdfs:comment 'Foreign key linking to reference.jurisdiction. Business justification: Payment instructions require jurisdiction-level regulatory reporting (FATCA, CRS, local tax authority filings, cross-border reporting). instruction has regulatory_reporting_flag but no jurisdiction FK' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Jurisdiction .

ind:settlementCurrencyId rdf:type rdf:Property ;
    rdfs:label 'Settlement Currency Id' ;
    rdfs:comment 'Foreign key linking to reference.currency. Business justification: Settlement currency validation against ISO 4217 master required for SWIFT message generation, nostro/vostro account selection, regulatory reporting (FFIEC 009, 031). Payment_currency denormalized text' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:amlScreeningStatus rdf:type rdf:Property ;
    rdfs:label 'Aml Screening Status' ;
    rdfs:comment 'Status of AML screening for this payment instruction (Pending, Cleared, Flagged, Blocked).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeBearer rdf:type rdf:Property ;
    rdfs:label 'Charge Bearer' ;
    rdfs:comment 'Indicates which party bears the transaction charges: OUR (originator pays all), BEN (beneficiary pays all), SHA (shared).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingSystemReference rdf:type rdf:Property ;
    rdfs:label 'Clearing System Reference' ;
    rdfs:comment 'Reference number assigned by the clearing system (e.g., ACH, RTGS) during payment processing.' ;
    rdfs:domain ind:Instruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instructionStatus rdf:type rdf:Property ;
    rdfs:label 'Instruction Status' ;
    rdfs:comment 'Current lifecycle status of the payment instruction (Pending, Validated, Submitted, In Clearing, Settled, Rejected, Cancelled). [ENUM-REF-CANDIDATE: PENDING|VALIDATED|SUBMITTED|IN_CLEARING|SETTLED|REJECTED|CANCELLED — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instructionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Instruction Timestamp' ;
    rdfs:comment 'The date and time when the payment instruction was created or initiated by the originator.' ;
    rdfs:domain ind:Instruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:intermediaryBankBic rdf:type rdf:Property ;
    rdfs:label 'Intermediary Bank Bic' ;
    rdfs:comment 'Bank Identifier Code of any intermediary or correspondent bank involved in routing this payment.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netSettlementAmount rdf:type rdf:Property ;
    rdfs:label 'Net Settlement Amount' ;
    rdfs:comment 'Net amount settled after deducting fees and charges from the gross payment amount.' ;
    rdfs:domain ind:Instruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentPriority rdf:type rdf:Property ;
    rdfs:label 'Payment Priority' ;
    rdfs:comment 'Priority level assigned to the payment instruction for processing sequence (Normal, High, Urgent).' ;
    rdfs:domain ind:Instruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentRailType rdf:type rdf:Property ;
    rdfs:label 'Payment Rail Type' ;
    rdfs:comment 'The payment rail or network through which this instruction will be executed (ACH, Wire, RTGS, SWIFT, FX, Card, Cross-Border). [ENUM-REF-CANDIDATE: ACH|WIRE|RTGS|SWIFT|FX|CARD|CROSS_BORDER — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for rejection if the payment instruction was rejected.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason Description' ;
    rdfs:comment 'Detailed textual description of why the payment instruction was rejected.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remittanceInformation rdf:type rdf:Property ;
    rdfs:label 'Remittance Information' ;
    rdfs:comment 'Unstructured or structured information provided by the originator to identify the payment to the beneficiary (e.g., invoice number, reference).' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sanctionsScreeningStatus rdf:type rdf:Property ;
    rdfs:label 'Sanctions Screening Status' ;
    rdfs:comment 'Status of sanctions screening against OFAC and other watchlists for this payment instruction.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementMethod rdf:type rdf:Property ;
    rdfs:label 'Settlement Method' ;
    rdfs:comment 'Method used for settling the payment: RTGS (Real-Time Gross Settlement), DNS (Deferred Net Settlement), BATCH (Batch Processing).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:swiftMessageType rdf:type rdf:Property ;
    rdfs:label 'Swift Message Type' ;
    rdfs:comment 'SWIFT message type code used for this payment instruction (e.g., MT103, MT202, pain.001).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:swiftUetr rdf:type rdf:Property ;
    rdfs:label 'Swift Uetr' ;
    rdfs:comment 'Unique end-to-end transaction reference assigned by SWIFT for tracking the payment across the correspondent banking chain.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:custodianAccountId rdf:type rdf:Property ;
    rdfs:label 'Custodian Account Id' ;
    rdfs:comment 'Foreign key linking to wealth.custodian_account. Business justification: Securities settlement requires cash movement through payment rails to/from custodian accounts. Treasury operations execute dividend payments, subscription/redemption settlements, and fee debits agains' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustodianAccount .

ind:customerSessionId rdf:type rdf:Property ;
    rdfs:label 'Customer Session Id' ;
    rdfs:comment 'Foreign key linking to channel.session. Business justification: Payment transactions initiated through digital/branch sessions require session linkage for fraud detection (device fingerprint, IP analysis), customer journey mapping, channel attribution for pricing/' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Session .

ind:exchangeRateId rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate Id' ;
    rdfs:comment 'Foreign key linking to reference.exchange_rate. Business justification: Payment transactions involving FX conversion must reference the authoritative exchange rate record for settlement amount audit and regulatory reporting. payment_transaction has exchange_rate as a plai' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ExchangeRate .

ind:interactionId rdf:type rdf:Property ;
    rdfs:label 'Interaction Id' ;
    rdfs:comment 'Foreign key linking to channel.interaction. Business justification: Payment transactions initiated through a channel interaction (contact center wire, branch teller, ATM non-card transaction) must link to the interaction record for end-to-end audit trail, operational ' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Interaction .

ind:primaryPaymentDepositAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Payment Deposit Account Id' ;
    rdfs:comment 'Reference to the account from which funds are debited in this transaction.' ;
    rdfs:domain ind:PaymentTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DepositAccount .

ind:primaryPaymentNostroAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Payment Nostro Account Id' ;
    rdfs:comment 'Reference to the nostro account (our account held at another bank) used for correspondent banking settlement.' ;
    rdfs:domain ind:PaymentTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NostroAccount .

ind:primaryPaymentPartyId rdf:type rdf:Property ;
    rdfs:label 'Primary Payment Party Id' ;
    rdfs:comment 'Reference to the customer initiating the payment transaction.' ;
    rdfs:domain ind:PaymentTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:routingId rdf:type rdf:Property ;
    rdfs:label 'Routing Id' ;
    rdfs:comment 'Foreign key linking to payment.routing. Business justification: A payment transaction is executed via a specific routing rule that determines the correspondent banking path, settlement cycle, and SLA. payment_transaction has routing_priority (string) which is a ro' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Routing .

ind:amlAlertId rdf:type rdf:Property ;
    rdfs:label 'Aml Alert Id' ;
    rdfs:comment 'Foreign key linking to compliance.aml_alert. Business justification: Transactions are primary detection point for AML alerts in transaction monitoring systems. Links transaction to alert for investigation workflow, SAR filing decisions, and regulatory examination evide' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AmlAlert .

ind:clearingHouseReference rdf:type rdf:Property ;
    rdfs:label 'Clearing House Reference' ;
    rdfs:comment 'Unique reference number assigned by the clearing house (e.g., ACH operator, SWIFT network) for tracking and reconciliation.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correspondentBankBic rdf:type rdf:Property ;
    rdfs:label 'Correspondent Bank Bic' ;
    rdfs:comment 'SWIFT Bank Identifier Code (BIC) of the correspondent bank involved in the payment routing.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Execution Timestamp' ;
    rdfs:comment 'The precise date and time when the payment transaction was executed and entered the clearing process.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:failureReasonCode rdf:type rdf:Property ;
    rdfs:label 'Failure Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for transaction failure or rejection (e.g., insufficient funds, invalid account, compliance hold).' ;
    rdfs:domain ind:PaymentTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netSettlementPosition rdf:type rdf:Property ;
    rdfs:label 'Net Settlement Position' ;
    rdfs:comment 'The net position of the transaction after multilateral netting with other transactions in the same settlement batch.' ;
    rdfs:domain ind:PaymentTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnReasonCode rdf:type rdf:Property ;
    rdfs:label 'Return Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for payment return (e.g., account closed, unauthorized, incorrect account number).' ;
    rdfs:domain ind:PaymentTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingPriority rdf:type rdf:Property ;
    rdfs:label 'Routing Priority' ;
    rdfs:comment 'Priority level assigned to the payment transaction for routing and processing (High, Normal, Low).' ;
    rdfs:domain ind:PaymentTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementAmount rdf:type rdf:Property ;
    rdfs:label 'Settlement Amount' ;
    rdfs:comment 'The final net amount settled after applying exchange rates, fees, and adjustments.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementCurrency rdf:type rdf:Property ;
    rdfs:label 'Settlement Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the settlement amount, which may differ from transaction currency in FX transactions.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementCycle rdf:type rdf:Property ;
    rdfs:label 'Settlement Cycle' ;
    rdfs:comment 'The settlement cycle designation indicating the number of business days between trade date and settlement date (T+0, T+1, T+2, T+3).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementStatus rdf:type rdf:Property ;
    rdfs:label 'Settlement Status' ;
    rdfs:comment 'Final settlement status indicating whether funds have been successfully transferred and reconciled.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionStatus rdf:type rdf:Property ;
    rdfs:label 'Transaction Status' ;
    rdfs:comment 'Current lifecycle status of the payment transaction in the clearing and settlement process.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentCurrencyId rdf:type rdf:Property ;
    rdfs:label 'Payment Currency Id' ;
    rdfs:comment 'Foreign key linking to reference.currency. Business justification: Status event reporting and exception dashboards aggregate by currency. SLA breach analysis and liquidity monitoring require currency master for multi-currency position aggregation and regulatory repor' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:assignedQueue rdf:type rdf:Property ;
    rdfs:label 'Assigned Queue' ;
    rdfs:comment 'Name of the exception handling queue to which this event was routed for manual resolution (e.g., Sanctions Review Queue, Format Validation Queue, High Value Queue). Null for non-exception events or auto-resolved exceptions.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditTrailReference rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Reference' ;
    rdfs:comment 'Reference identifier linking this event to the broader audit trail or compliance log. Used for regulatory audit and forensic investigation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventSourceModule rdf:type rdf:Property ;
    rdfs:label 'Event Source Module' ;
    rdfs:comment 'Specific module or component within the payment hub that generated this event (e.g., Payment Validation Engine, Routing Engine, Settlement Engine, Exception Handler, Sanctions Filter). More granular than originating_system.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event Timestamp' ;
    rdfs:comment 'Precise date and time when this status transition or exception event occurred in the payment processing lifecycle. Recorded in ISO 8601 format with timezone offset.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eventType rdf:type rdf:Property ;
    rdfs:label 'Event Type' ;
    rdfs:comment 'Classification of the event: STATUS_CHANGE (normal lifecycle transition), EXCEPTION (business rule violation or data issue), STP_FAILURE (Straight-Through Processing failure requiring manual intervention), MANUAL_INTERVENTION (operator action), RETRY (automated retry attempt), RESOLUTION (exception resolved).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionSeverity rdf:type rdf:Property ;
    rdfs:label 'Exception Severity' ;
    rdfs:comment 'Severity level of the exception for prioritization and SLA management. CRITICAL (regulatory or high-value payment), HIGH (material impact), MEDIUM (standard exception), LOW (informational). Null for non-exception events.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionType rdf:type rdf:Property ;
    rdfs:label 'Exception Type' ;
    rdfs:comment 'Classification of the exception when event_type is EXCEPTION or STP_FAILURE. FORMAT_ERROR (message format or field validation failure), SANCTIONS_HIT (AML/sanctions screening match), DUPLICATE_DETECTION (duplicate payment detected), ROUTING_FAILURE (unable to determine payment route), INSUFFICIENT_FUNDS (payer account balance insufficient), BENEFICIARY_VALIDATION_FAILURE (beneficiary account validation failed). Null for non-exception events.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxRetryLimit rdf:type rdf:Property ;
    rdfs:label 'Max Retry Limit' ;
    rdfs:comment 'Maximum number of automated retries allowed for this payment type before manual intervention is required. Configured per payment channel and exception type.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:newStatusCode rdf:type rdf:Property ;
    rdfs:label 'New Status Code' ;
    rdfs:comment 'The payment status after this event. Uses ISO 20022 external payment status codes. Represents the current state of the payment following this transition. [ENUM-REF-CANDIDATE: INIT|PNDG|ACCP|ACSC|ACSP|ACTC|ACWC|RJCT|CANC|PDNG|PART|ACCC — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originatingSystem rdf:type rdf:Property ;
    rdfs:label 'Originating System' ;
    rdfs:comment 'Name or identifier of the system component that generated this event (e.g., ACI Payment Engine, Volante Routing Module, SWIFT Gateway, Exception Management Module, Sanctions Screening Engine).' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentChannel rdf:type rdf:Property ;
    rdfs:label 'Payment Channel' ;
    rdfs:comment 'The payment rail or channel through which the payment is being processed: ACH (Automated Clearing House), WIRE (wire transfer), RTGS (Real-Time Gross Settlement), SWIFT (Society for Worldwide Interbank Financial Telecommunication), SEPA (Single Euro Payments Area), FASTER_PAYMENTS (UK Faster Payments), CARD (card payment network), INTERNAL_TRANSFER (intra-bank transfer). [ENUM-REF-CANDIDATE: ACH|WIRE|RTGS|SWIFT|SEPA|FASTER_PAYMENTS|CARD|INTERNAL_TRANSFER — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentDirection rdf:type rdf:Property ;
    rdfs:label 'Payment Direction' ;
    rdfs:comment 'Direction of the payment flow relative to the bank: OUTBOUND (payment sent from bank to external party), INBOUND (payment received from external party).' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorStatusCode rdf:type rdf:Property ;
    rdfs:label 'Prior Status Code' ;
    rdfs:comment 'The payment status immediately before this event. Uses ISO 20022 external payment status codes: INIT (Initiated), PNDG (Pending), ACCP (Accepted Customer Profile), ACSC (Accepted Settlement Completed), ACSP (Accepted Settlement In Process), ACTC (Accepted Technical Validation), ACWC (Accepted With Change), RJCT (Rejected), CANC (Cancelled), PDNG (Pending), PART (Partially Accepted), ACCC (Accepted Settlement Completed Creditor Account). [ENUM-REF-CANDIDATE: INIT|PNDG|ACCP|ACSC|ACSP|ACTC|ACWC|RJCT|CANC|PDNG|PART|ACCC — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonCode rdf:type rdf:Property ;
    rdfs:label 'Reason Code' ;
    rdfs:comment 'Standardized code explaining why the status transition or exception occurred. Aligns with ISO 20022 reason codes for payment status (e.g., AC01 for incorrect account number, AM05 for duplication, NARR for narrative reason).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonDescription rdf:type rdf:Property ;
    rdfs:label 'Reason Description' ;
    rdfs:comment 'Human-readable narrative explaining the reason for the status change or exception. Provides additional context beyond the standardized reason code.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionAction rdf:type rdf:Property ;
    rdfs:label 'Resolution Action' ;
    rdfs:comment 'Action taken to resolve the exception: APPROVED (exception cleared, payment proceeds), REJECTED (payment rejected), CORRECTED (data corrected and resubmitted), ESCALATED (escalated to higher authority), CANCELLED (payment cancelled), RESUBMITTED (resubmitted for processing). Null for unresolved exceptions or non-exception events.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Resolution Timestamp' ;
    rdfs:comment 'Date and time when the exception was resolved. Null for unresolved exceptions or non-exception events. Used to calculate exception handling duration and SLA compliance.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:retryCount rdf:type rdf:Property ;
    rdfs:label 'Retry Count' ;
    rdfs:comment 'Number of automated retry attempts made for this payment after an STP failure. Zero for first-time processing. Used to track retry logic and prevent infinite loops.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sanctionsScreeningResult rdf:type rdf:Property ;
    rdfs:label 'Sanctions Screening Result' ;
    rdfs:comment 'Result of AML and sanctions screening for this payment event: CLEAR (no match found), HIT (potential match requiring review), PENDING_REVIEW (screening in progress). Critical for regulatory compliance.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaActualMinutes rdf:type rdf:Property ;
    rdfs:label 'Sla Actual Minutes' ;
    rdfs:comment 'The actual time in minutes taken to resolve this event, calculated from event_timestamp to resolution_timestamp. Null for unresolved events. Used for SLA compliance analysis.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaBreachFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Flag' ;
    rdfs:comment 'Indicates whether this event resulted in a breach of the defined SLA for payment processing or exception resolution. True if SLA was breached, False otherwise. Used for SLA compliance monitoring and reporting.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaTargetMinutes rdf:type rdf:Property ;
    rdfs:label 'Sla Target Minutes' ;
    rdfs:comment 'The target resolution time in minutes defined by the SLA for this event type and severity. Used to calculate SLA breach status.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transactionReference rdf:type rdf:Property ;
    rdfs:label 'Transaction Reference' ;
    rdfs:comment 'End-to-end transaction reference provided by the payment originator. Used for reconciliation and customer inquiry. Also known as UETR (Unique End-to-End Transaction Reference) in SWIFT context.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnId rdf:type rdf:Property ;
    rdfs:label 'Return Id' ;
    rdfs:comment 'Unique identifier for the payment return record. Primary key for the payment return entity.' ;
    rdfs:domain ind:Return ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originatingChannelId rdf:type rdf:Property ;
    rdfs:label 'Originating Channel Id' ;
    rdfs:comment 'Foreign key linking to channel.channel. Business justification: Payment returns must be attributed to the originating channel (branch, digital, call center) for operational SLA reporting, channel-level return rate analysis, and fraud investigation. Banking ops tea' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:receivingBankCorrespondentBankId rdf:type rdf:Property ;
    rdfs:label 'Receiving Bank Correspondent Bank Id' ;
    rdfs:comment 'Identifier of the financial institution that received the original payment and is initiating the return. May be ABA routing number, SWIFT BIC, or internal bank identifier.' ;
    rdfs:domain ind:Return ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CorrespondentBank .

ind:returnCorrespondentBankId rdf:type rdf:Property ;
    rdfs:label 'Return Correspondent Bank Id' ;
    rdfs:comment 'Identifier of the financial institution that originated the payment being returned. May be ABA routing number, SWIFT BIC, or internal bank identifier.' ;
    rdfs:domain ind:Return ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CorrespondentBank .

ind:addendaInformation rdf:type rdf:Property ;
    rdfs:label 'Addenda Information' ;
    rdfs:comment 'Additional free-form information or notes provided with the return, such as detailed explanation of the return reason or instructions for resubmission.' ;
    rdfs:domain ind:Return ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingHouseName rdf:type rdf:Property ;
    rdfs:label 'Clearing House Name' ;
    rdfs:comment 'Name of the clearing house or payment network through which the return was processed (e.g., Federal Reserve ACH, The Clearing House, SWIFT, local RTGS system).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contestedReturnFlag rdf:type rdf:Property ;
    rdfs:label 'Contested Return Flag' ;
    rdfs:comment 'Indicates whether the return has been contested or disputed by the originating bank.' ;
    rdfs:domain ind:Return ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dishonoredReturnFlag rdf:type rdf:Property ;
    rdfs:label 'Dishonored Return Flag' ;
    rdfs:comment 'Indicates whether this is a dishonored return (return of a return), which occurs when the originating bank contests the return.' ;
    rdfs:domain ind:Return ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:feeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Fee Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the return fee amount.' ;
    rdfs:domain ind:Return ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudIndicatorFlag rdf:type rdf:Property ;
    rdfs:label 'Fraud Indicator Flag' ;
    rdfs:comment 'Indicates whether the return is associated with suspected fraudulent activity or unauthorized transactions.' ;
    rdfs:domain ind:Return ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationDate rdf:type rdf:Property ;
    rdfs:label 'Notification Date' ;
    rdfs:comment 'Date on which notification of the return was sent to the originator.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notificationSentFlag rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Flag' ;
    rdfs:comment 'Indicates whether notification of the return has been sent to the payment originator or relevant parties.' ;
    rdfs:domain ind:Return ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originalPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Original Payment Date' ;
    rdfs:comment 'Business date of the original payment transaction that is being returned.' ;
    rdfs:domain ind:Return ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originalPaymentReference rdf:type rdf:Property ;
    rdfs:label 'Original Payment Reference' ;
    rdfs:comment 'Business reference number or transaction identifier of the original payment being returned.' ;
    rdfs:domain ind:Return ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originatorAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Originator Account Number' ;
    rdfs:comment 'Account number of the payment originator to which the returned funds will be credited.' ;
    rdfs:domain ind:Return ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationStatus rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Status' ;
    rdfs:comment 'Status of nostro/vostro account reconciliation for this return transaction.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resubmissionCount rdf:type rdf:Property ;
    rdfs:label 'Resubmission Count' ;
    rdfs:comment 'Number of times this payment has been resubmitted after previous returns. NACHA rules limit resubmissions to two attempts for certain return codes.' ;
    rdfs:domain ind:Return ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:resubmissionEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Resubmission Eligible Flag' ;
    rdfs:comment 'Indicates whether the returned payment is eligible for resubmission based on the return reason code. Certain return codes (e.g., R01 NSF) allow resubmission while others (e.g., R02 Account Closed) do not.' ;
    rdfs:domain ind:Return ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:returnDate rdf:type rdf:Property ;
    rdfs:label 'Return Date' ;
    rdfs:comment 'Business date on which the return was initiated or processed by the receiving bank or clearing house.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:returnStatus rdf:type rdf:Property ;
    rdfs:label 'Return Status' ;
    rdfs:comment 'Current lifecycle status of the return transaction indicating its processing state.' ;
    rdfs:domain ind:Return ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnTimestamp rdf:type rdf:Property ;
    rdfs:label 'Return Timestamp' ;
    rdfs:comment 'Precise date and time when the return transaction was created or received in the payment processing system.' ;
    rdfs:domain ind:Return ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:returnType rdf:type rdf:Property ;
    rdfs:label 'Return Type' ;
    rdfs:comment 'Classification of the return transaction based on the payment rail or system through which it was processed.' ;
    rdfs:domain ind:Return ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:windowDays rdf:type rdf:Property ;
    rdfs:label 'Window Days' ;
    rdfs:comment 'Number of days from the original payment date within which the return was initiated. Different return reason codes have different allowable return windows (e.g., 2 banking days for R01, 60 days for unauthorized debits).' ;
    rdfs:domain ind:Return ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clearingRecordId rdf:type rdf:Property ;
    rdfs:label 'Clearing Record Id' ;
    rdfs:comment 'Unique identifier for the clearing record. Primary key for the clearing record entity.' ;
    rdfs:domain ind:ClearingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clearingCurrencyId rdf:type rdf:Property ;
    rdfs:label 'Clearing Currency Id' ;
    rdfs:comment 'Foreign key linking to reference.currency. Business justification: Clearing house settlement requires currency master for netting calculations, liquidity reserve requirements, and settlement finality rules. Clearing_currency_code denormalized text replaced by FK for ' ;
    rdfs:domain ind:ClearingRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:clearingHouseId rdf:type rdf:Property ;
    rdfs:label 'Clearing House Id' ;
    rdfs:comment 'Foreign key linking to trade.clearing_house. Business justification: Clearing records must reference the specific CCP through which payment clears for regulatory capital reporting, default fund exposure monitoring, and CCP concentration risk. clearing_house_identifier ' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClearingHouse .

ind:journalEntryId rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Id' ;
    rdfs:comment 'Foreign key linking to ledger.journal_entry. Business justification: Clearing settlements create accounting entries for net settlement obligations and nostro/vostro movements. Essential for financial reporting, liquidity management, and regulatory capital calculations.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntry .

ind:marginCallId rdf:type rdf:Property ;
    rdfs:label 'Margin Call Id' ;
    rdfs:comment 'Foreign key linking to collateral.collateral_margin_call. Business justification: Margin call settlements are processed through clearing. The clearing_record must reference the collateral_margin_call to support EMIR/Dodd-Frank settlement confirmation reporting and to reconcile net ' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MarginCall .

ind:repoTransactionId rdf:type rdf:Property ;
    rdfs:label 'Repo Transaction Id' ;
    rdfs:comment 'Foreign key linking to treasury.repo_transaction. Business justification: Repo transactions generate clearing records for their cash settlement legs. Linking clearing_record to repo_transaction enables operations to track the clearing status of each repo cash leg, a standar' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RepoTransaction .

ind:clearingConfirmationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Clearing Confirmation Timestamp' ;
    rdfs:comment 'Timestamp when the clearing house confirmed acceptance or rejection of the clearing submission. Marks the completion of the clearing validation phase.' ;
    rdfs:domain ind:ClearingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:clearingCycleIdentifier rdf:type rdf:Property ;
    rdfs:label 'Clearing Cycle Identifier' ;
    rdfs:comment 'Identifier of the specific clearing cycle or batch window in which this clearing record was processed. Clearing houses typically operate multiple cycles per day.' ;
    rdfs:domain ind:ClearingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Clearing Fee Amount' ;
    rdfs:comment 'Fee charged by the clearing house for processing this clearing record. May be a flat fee per transaction or a percentage of the cleared amount.' ;
    rdfs:domain ind:ClearingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clearingMessageType rdf:type rdf:Property ;
    rdfs:label 'Clearing Message Type' ;
    rdfs:comment 'Type of clearing message or instruction format used. Examples include SWIFT MT message types (MT103, MT202), ISO 20022 message types (pacs.008, pacs.009), or proprietary clearing formats.' ;
    rdfs:domain ind:ClearingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingParticipantIdentifier rdf:type rdf:Property ;
    rdfs:label 'Clearing Participant Identifier' ;
    rdfs:comment 'Unique identifier of the financial institution participating in the clearing process. May be a BIC (Bank Identifier Code), ABA routing number, or clearing house member identifier.' ;
    rdfs:domain ind:ClearingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Clearing Reference Number' ;
    rdfs:comment 'Unique reference number assigned by the clearing house to identify this clearing submission. Business identifier for external reconciliation and inquiry.' ;
    rdfs:domain ind:ClearingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingStatus rdf:type rdf:Property ;
    rdfs:label 'Clearing Status' ;
    rdfs:comment 'Current lifecycle status of the clearing record. Indicates whether the clearing submission has been accepted, rejected, is pending processing, or has progressed to settlement.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingSubmissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Clearing Submission Timestamp' ;
    rdfs:comment 'Timestamp when the payment instruction or batch was submitted to the clearing house for processing. Represents the business event time of clearing initiation.' ;
    rdfs:domain ind:ClearingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:collateralRequirementAmount rdf:type rdf:Property ;
    rdfs:label 'Collateral Requirement Amount' ;
    rdfs:comment 'Amount of collateral required to be posted to the clearing house to cover settlement risk exposure. Common in securities clearing and derivatives clearing.' ;
    rdfs:domain ind:ClearingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:counterpartyParticipantIdentifier rdf:type rdf:Property ;
    rdfs:label 'Counterparty Participant Identifier' ;
    rdfs:comment 'Identifier of the counterparty financial institution on the other side of the clearing transaction. Used in bilateral netting and settlement reconciliation.' ;
    rdfs:domain ind:ClearingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossBorderIndicator rdf:type rdf:Property ;
    rdfs:label 'Cross Border Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this clearing record involves cross-border payment flows between different countries or currency zones. Relevant for FATCA (Foreign Account Tax Compliance Act) and CRS (Common Reporting Standard) compliance.' ;
    rdfs:domain ind:ClearingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:foreignExchangeRate rdf:type rdf:Property ;
    rdfs:label 'Foreign Exchange Rate' ;
    rdfs:comment 'Exchange rate applied for cross-currency clearing and settlement, particularly relevant for CLS (Continuous Linked Settlement) FX transactions. Represents the rate at which one currency is converted to another.' ;
    rdfs:domain ind:ClearingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossClearingAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Clearing Amount' ;
    rdfs:comment 'Total gross amount of all payment instructions included in this clearing record before any netting or offsetting. Represents the sum of all individual payment values submitted.' ;
    rdfs:domain ind:ClearingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:liquidityReserveRequirementAmount rdf:type rdf:Property ;
    rdfs:label 'Liquidity Reserve Requirement Amount' ;
    rdfs:comment 'Amount of liquidity reserves that must be maintained to cover this clearing obligation. Relevant for regulatory liquidity management and LCR (Liquidity Coverage Ratio) calculations.' ;
    rdfs:domain ind:ClearingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:multilateralNettingPosition rdf:type rdf:Property ;
    rdfs:label 'Multilateral Netting Position' ;
    rdfs:comment 'Indicates whether the institution is a net payer (owes funds), net receiver (receives funds), or neutral (no net obligation) after multilateral netting across all participants in the clearing cycle.' ;
    rdfs:domain ind:ClearingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netSettlementObligationAmount rdf:type rdf:Property ;
    rdfs:label 'Net Settlement Obligation Amount' ;
    rdfs:comment 'Net settlement obligation amount after multilateral or bilateral netting has been applied by the clearing house. This is the actual amount that must be funded or will be received in the settlement phase.' ;
    rdfs:domain ind:ClearingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nettingGroupIdentifier rdf:type rdf:Property ;
    rdfs:label 'Netting Group Identifier' ;
    rdfs:comment 'Identifier of the netting group or pool to which this clearing record belongs. Used in multilateral netting arrangements where participants are grouped for offset calculation.' ;
    rdfs:domain ind:ClearingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nostroVostroIndicator rdf:type rdf:Property ;
    rdfs:label 'Nostro Vostro Indicator' ;
    rdfs:comment 'Indicates whether the settlement account is a nostro account (our account held at another bank), vostro account (their account held at our bank), or an internal account. Critical for correspondent banking reconciliation.' ;
    rdfs:domain ind:ClearingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentInstructionCount rdf:type rdf:Property ;
    rdfs:label 'Payment Instruction Count' ;
    rdfs:comment 'Number of individual payment instructions included in this clearing record. Relevant for batch clearing submissions where multiple payments are cleared together.' ;
    rdfs:domain ind:ClearingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priorityIndicator rdf:type rdf:Property ;
    rdfs:label 'Priority Indicator' ;
    rdfs:comment 'Priority level assigned to this clearing record. High-priority payments may be processed in earlier clearing cycles or given preferential treatment in settlement queues.' ;
    rdfs:domain ind:ClearingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementConfirmationReference rdf:type rdf:Property ;
    rdfs:label 'Settlement Confirmation Reference' ;
    rdfs:comment 'Unique reference number provided by the settlement system confirming that final funds movement has been completed. Used for reconciliation and audit trail.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementRiskExposureAmount rdf:type rdf:Property ;
    rdfs:label 'Settlement Risk Exposure Amount' ;
    rdfs:comment 'Calculated settlement risk exposure amount representing the potential loss if the counterparty fails to settle. Used for credit risk management and regulatory capital calculations.' ;
    rdfs:domain ind:ClearingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementWindowIdentifier rdf:type rdf:Property ;
    rdfs:label 'Settlement Window Identifier' ;
    rdfs:comment 'Identifier of the specific settlement window or time slot in which final settlement is scheduled. Clearing houses may operate multiple settlement windows throughout the day.' ;
    rdfs:domain ind:ClearingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemIdentifier rdf:type rdf:Property ;
    rdfs:label 'Source System Identifier' ;
    rdfs:comment 'Identifier of the source system that originated this clearing record. Examples include ACI Worldwide, Volante, or internal payment processing platforms. Used for data lineage and reconciliation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationCountryId rdf:type rdf:Property ;
    rdfs:label 'Destination Country Id' ;
    rdfs:comment 'Foreign key linking to reference.country. Business justification: Routing rules vary by destination country for cost optimization (local rails vs SWIFT), speed (RTGS availability), and regulatory compliance (sanctions screening, reporting thresholds). Country master' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:destinationCurrencyId rdf:type rdf:Property ;
    rdfs:label 'Destination Currency Id' ;
    rdfs:comment 'Foreign key linking to reference.currency. Business justification: Routing optimized per currency based on nostro liquidity, correspondent bank relationships, and clearing costs. Currency master provides convertibility status, restrictions, and settlement lag for rou' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:fallbackRoutingRuleRoutingId rdf:type rdf:Property ;
    rdfs:label 'Fallback Routing Rule Routing Id' ;
    rdfs:comment 'Identifier of an alternative routing rule to use if this primary routing path fails or is unavailable.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Routing .

ind:intermediaryBicDirectoryId rdf:type rdf:Property ;
    rdfs:label 'Intermediary Bic Directory Id' ;
    rdfs:comment 'Foreign key linking to reference.bic_directory. Business justification: Routing rules reference specific intermediary bank BICs that must be validated against the BIC directory for routing accuracy. routing has intermediary_bank_bic as plain text denormalized field. Banki' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BicDirectory .

ind:amlMonitoringLevel rdf:type rdf:Property ;
    rdfs:label 'Aml Monitoring Level' ;
    rdfs:comment 'Level of AML transaction monitoring applied to payments using this routing path, based on risk assessment.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Approval Threshold Amount' ;
    rdfs:comment 'Payment amount threshold above which manual approval or additional authorization is required before routing.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costBasisPoints rdf:type rdf:Property ;
    rdfs:label 'Cost Basis Points' ;
    rdfs:comment 'Cost of using this routing path expressed in basis points (BPS) of the payment amount. Used for cost-optimized routing decisions.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cutoffTimeLocal rdf:type rdf:Property ;
    rdfs:label 'Cutoff Time Local' ;
    rdfs:comment 'Daily cut-off time in local time zone (HH:MM:SS format) by which payment instructions must be received to be included in the current settlement cycle.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cutoffTimezone rdf:type rdf:Property ;
    rdfs:label 'Cutoff Timezone' ;
    rdfs:comment 'Time zone identifier for the cut-off time (e.g., EST, GMT, CET) to ensure accurate cross-border timing.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dailyAggregateLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Daily Aggregate Limit Amount' ;
    rdfs:comment 'Maximum cumulative amount allowed per day through this routing path. Used for liquidity management and risk control.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:effectiveToDate rdf:type rdf:Property ;
    rdfs:label 'Effective To Date' ;
    rdfs:comment 'Date until which this routing rule remains effective. Null indicates an open-ended rule with no expiration.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:engineVersion rdf:type rdf:Property ;
    rdfs:label 'Engine Version' ;
    rdfs:comment 'Version identifier of the payment routing engine configuration that created or last modified this rule.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intermediaryBankName rdf:type rdf:Property ;
    rdfs:label 'Intermediary Bank Name' ;
    rdfs:comment 'Legal name of the intermediary bank, if applicable, for operational transparency and audit trail.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liquidityReserveRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Liquidity Reserve Requirement Flag' ;
    rdfs:comment 'Indicates whether this routing path requires pre-funded liquidity reserves to be maintained for settlement assurance.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentRailCode rdf:type rdf:Property ;
    rdfs:label 'Payment Rail Code' ;
    rdfs:comment 'The payment rail or network through which the payment is routed. Determines the clearing and settlement infrastructure used. [ENUM-REF-CANDIDATE: ACH|WIRE|RTGS|SWIFT|CARD|SEPA|FASTER_PAYMENTS|TARGET2 — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityRank rdf:type rdf:Property ;
    rdfs:label 'Priority Rank' ;
    rdfs:comment 'Priority ranking for this routing rule when multiple rules match a payment instruction. Lower numbers indicate higher priority.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:railSettlementModel rdf:type rdf:Property ;
    rdfs:label 'Rail Settlement Model' ;
    rdfs:comment 'Settlement model used by the payment rail: gross settlement (transaction-by-transaction) or net settlement (batch netting).' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleCode rdf:type rdf:Property ;
    rdfs:label 'Rule Code' ;
    rdfs:comment 'Business identifier code for the routing rule used for operational reference and configuration management.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleName rdf:type rdf:Property ;
    rdfs:label 'Rule Name' ;
    rdfs:comment 'Human-readable name describing the purpose and scope of the routing rule.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleStatus rdf:type rdf:Property ;
    rdfs:label 'Rule Status' ;
    rdfs:comment 'Current lifecycle status of the routing rule. Only ACTIVE rules are used for live payment routing decisions.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sanctionsScreeningRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Sanctions Screening Required Flag' ;
    rdfs:comment 'Indicates whether payments routed via this path must undergo OFAC and sanctions screening before execution.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:settlementCycleCode rdf:type rdf:Property ;
    rdfs:label 'Settlement Cycle Code' ;
    rdfs:comment 'Settlement cycle indicating when funds are finalized. T+0 is same-day, T+1 is next business day, real-time is immediate.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:singleTransactionLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Single Transaction Limit Amount' ;
    rdfs:comment 'Maximum amount allowed for a single payment transaction through this routing path. Enforces per-transaction risk controls.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaTargetCompletionMinutes rdf:type rdf:Property ;
    rdfs:label 'Sla Target Completion Minutes' ;
    rdfs:comment 'Target completion time in minutes as defined in the service level agreement for this routing path.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:speedMinutes rdf:type rdf:Property ;
    rdfs:label 'Speed Minutes' ;
    rdfs:comment 'Expected end-to-end processing time in minutes for payments routed via this path, used for speed-optimized routing.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:velocityLimitCount rdf:type rdf:Property ;
    rdfs:label 'Velocity Limit Count' ;
    rdfs:comment 'Maximum number of payments allowed through this routing path within the velocity window. Used for risk management and fraud prevention.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:velocityWindowMinutes rdf:type rdf:Property ;
    rdfs:label 'Velocity Window Minutes' ;
    rdfs:comment 'Time window in minutes over which the velocity limit count is enforced. Supports sliding-window velocity checks.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vostroAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Vostro Account Number' ;
    rdfs:comment 'Account number of the correspondent banks vostro account held at this bank, if applicable for bilateral settlement.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficiaryId rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Id' ;
    rdfs:comment 'Unique identifier for the payment beneficiary record. Primary key.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Beneficiary .

ind:bankCountryId rdf:type rdf:Property ;
    rdfs:label 'Bank Country Id' ;
    rdfs:comment 'Foreign key linking to reference.country. Business justification: Beneficiary bank country drives payment routing (SWIFT vs local rails), sanctions screening (OFAC, EU), correspondent bank selection, and regulatory reporting (FFIEC 009 cross-border). Bank_country_co' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:registeredPartyId rdf:type rdf:Property ;
    rdfs:label 'Registered Party Id' ;
    rdfs:comment 'Foreign key linking to customer.party. Business justification: When beneficiary is existing customer, party link enables streamlined KYC (reuse existing due diligence), enhanced sanctions screening (leverage customer risk rating), and simplified beneficiary regis' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line1' ;
    rdfs:comment 'Primary address line of the beneficiary (street address, building number). Required for compliance and verification purposes.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line2' ;
    rdfs:comment 'Secondary address line of the beneficiary (suite, apartment, additional location details).' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Bank Address Line1' ;
    rdfs:comment 'Primary address line of the beneficiary\'s bank or branch (street address, building number).' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Bank Address Line2' ;
    rdfs:comment 'Secondary address line of the beneficiary\'s bank or branch (suite, floor, additional location details).' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankBranchName rdf:type rdf:Property ;
    rdfs:label 'Bank Branch Name' ;
    rdfs:comment 'Name or identifier of the specific branch where the beneficiary account is held, if applicable.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankCity rdf:type rdf:Property ;
    rdfs:label 'Bank City' ;
    rdfs:comment 'City where the beneficiary\'s bank or branch is located.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankPostalCode rdf:type rdf:Property ;
    rdfs:label 'Bank Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the beneficiary\'s bank or branch location.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankStateProvince rdf:type rdf:Property ;
    rdfs:label 'Bank State Province' ;
    rdfs:comment 'State, province, or region where the beneficiary\'s bank or branch is located.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficiaryStatus rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Status' ;
    rdfs:comment 'Current lifecycle status of the beneficiary record. Active beneficiaries can receive payments; suspended or blocked beneficiaries cannot.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficiaryType rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Type' ;
    rdfs:comment 'Classification of the beneficiary entity: individual person, corporate entity, financial institution, government body, non-profit organization, or trust.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:city rdf:type rdf:Property ;
    rdfs:label 'City' ;
    rdfs:comment 'City where the beneficiary is located or registered.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryCode rdf:type rdf:Property ;
    rdfs:label 'Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the beneficiary\'s residence or registration.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emailAddress rdf:type rdf:Property ;
    rdfs:label 'Email Address' ;
    rdfs:comment 'Primary email address for beneficiary communication and payment notifications.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iban rdf:type rdf:Property ;
    rdfs:label 'Iban' ;
    rdfs:comment 'International Bank Account Number for beneficiaries in IBAN-participating countries. Standardized format for cross-border payments.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intermediaryBankRequired rdf:type rdf:Property ;
    rdfs:label 'Intermediary Bank Required' ;
    rdfs:comment 'Indicates whether an intermediary (correspondent) bank is required to route payments to this beneficiary. True for certain cross-border payments.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Last Payment Date' ;
    rdfs:comment 'Date of the most recent payment successfully sent to this beneficiary.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalName rdf:type rdf:Property ;
    rdfs:label 'Legal Name' ;
    rdfs:comment 'Full legal name of the beneficiary as registered with their financial institution or government authority. For individuals, includes full given and family names; for entities, the registered business name.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pepStatus rdf:type rdf:Property ;
    rdfs:label 'Pep Status' ;
    rdfs:comment 'Indicates whether the beneficiary is a Politically Exposed Person (PEP), Relative or Close Associate (RCA) of a PEP, or non-PEP. Used for enhanced due diligence requirements.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phoneNumber rdf:type rdf:Property ;
    rdfs:label 'Phone Number' ;
    rdfs:comment 'Primary contact phone number for the beneficiary. Used for verification and communication purposes.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postalCode rdf:type rdf:Property ;
    rdfs:label 'Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the beneficiary\'s address.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationDate rdf:type rdf:Property ;
    rdfs:label 'Registration Date' ;
    rdfs:comment 'Date when the beneficiary was first registered in the payment system.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:routingCode rdf:type rdf:Property ;
    rdfs:label 'Routing Code' ;
    rdfs:comment 'Domestic routing code for the beneficiary\'s bank (e.g., ABA routing number, UK sort code, Australian BSB). Format varies by country.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingCodeType rdf:type rdf:Property ;
    rdfs:label 'Routing Code Type' ;
    rdfs:comment 'Type of domestic routing code used for the beneficiary bank: ABA (US), Sort Code (UK), BSB (Australia), IFSC (India), CLABE (Mexico), Transit Number (Canada), or other branch code. [ENUM-REF-CANDIDATE: aba|sort_code|bsb|ifsc|clabe|transit|branch_code — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateProvince rdf:type rdf:Property ;
    rdfs:label 'State Province' ;
    rdfs:comment 'State, province, or region where the beneficiary is located or registered.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxIdentificationNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Identification Number' ;
    rdfs:comment 'Tax identification number of the beneficiary (e.g., SSN, EIN, VAT number). Required for certain payment types and regulatory reporting.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationDate rdf:type rdf:Property ;
    rdfs:label 'Verification Date' ;
    rdfs:comment 'Date when the beneficiary account details were last successfully verified.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verificationStatus rdf:type rdf:Property ;
    rdfs:label 'Verification Status' ;
    rdfs:comment 'Status of beneficiary account verification. Indicates whether the account details have been validated through micro-deposits, API verification, or manual review.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizingAccountHolderId rdf:type rdf:Property ;
    rdfs:label 'Authorizing Account Holder Id' ;
    rdfs:comment 'Foreign key linking to customer.account_holder. Business justification: Direct debit mandate authorization requires knowing the specific account holder role and signing authority level. Mandate dispute resolution, regulatory audit trails (PSD2/NACHA), and mandate validity' ;
    rdfs:domain ind:PaymentMandate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccountHolder .

ind:creditorBeneficiaryId rdf:type rdf:Property ;
    rdfs:label 'Creditor Beneficiary Id' ;
    rdfs:comment 'Foreign key linking to payment.beneficiary. Business justification: payment_mandate has creditor_name and creditor_account_id. The creditor in a direct debit mandate is a beneficiary in the payment domain. This should be normalized to a FK to beneficiary.beneficiary_i' ;
    rdfs:domain ind:PaymentMandate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Beneficiary .

ind:debtorPartyId rdf:type rdf:Property ;
    rdfs:label 'Debtor Party Id' ;
    rdfs:comment 'Foreign key linking to customer.party. Business justification: Direct debit mandates require party-level authorization tracking for regulatory compliance (SEPA, NACHA rules), dispute resolution, and customer consent management. Debtor_name is denormalized party d' ;
    rdfs:domain ind:PaymentMandate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:originatingSessionId rdf:type rdf:Property ;
    rdfs:label 'Originating Session Id' ;
    rdfs:comment 'Foreign key linking to channel.session. Business justification: Mandate creation via digital channels must be tied to the authenticated customer session for PSD2 Strong Customer Authentication (SCA) audit trail. Regulators require proof of authenticated session at' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Session .

ind:primaryPaymentCreditorAccountDepositAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Payment Creditor Account Deposit Account Id' ;
    rdfs:comment 'Reference to the creditor account that will receive collected funds. Links to the account master data.' ;
    rdfs:domain ind:PaymentMandate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DepositAccount .

ind:amendmentDate rdf:type rdf:Property ;
    rdfs:label 'Amendment Date' ;
    rdfs:comment 'Date of the most recent amendment to the mandate terms. Null if mandate has never been amended.' ;
    rdfs:domain ind:PaymentMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:amendmentIndicator rdf:type rdf:Property ;
    rdfs:label 'Amendment Indicator' ;
    rdfs:comment 'Flag indicating whether this mandate has been amended since original signature. True if mandate terms have been modified with debtor consent.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:authorizationMethod rdf:type rdf:Property ;
    rdfs:label 'Authorization Method' ;
    rdfs:comment 'Channel through which the debtor authorized the mandate. PAPER for signed physical form, ELECTRONIC for e-signature, ONLINE for web portal, MOBILE for mobile app, TELEPHONE for phone banking, BRANCH for in-person at branch.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizationReference rdf:type rdf:Property ;
    rdfs:label 'Authorization Reference' ;
    rdfs:comment 'Reference number or identifier for the authorization event or document. Used for audit trail and dispute resolution.' ;
    rdfs:domain ind:PaymentMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationDate rdf:type rdf:Property ;
    rdfs:label 'Cancellation Date' ;
    rdfs:comment 'Date on which the mandate was cancelled or revoked. Populated when mandate status transitions to CANCELLED or REVOKED.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cancellationReason rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason' ;
    rdfs:comment 'Free-text explanation for mandate cancellation or revocation. Captures debtor request, creditor termination, or regulatory reason.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionFrequency rdf:type rdf:Property ;
    rdfs:label 'Collection Frequency' ;
    rdfs:comment 'Expected frequency of payment collections under this mandate. ONCE for one-time mandates, ADHOC for variable timing, or regular intervals for recurring mandates. [ENUM-REF-CANDIDATE: ONCE|DAILY|WEEKLY|MONTHLY|QUARTERLY|ANNUALLY|ADHOC — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PaymentMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditorIdentifier rdf:type rdf:Property ;
    rdfs:label 'Creditor Identifier' ;
    rdfs:comment 'Unique identifier assigned to the creditor by the national banking authority or scheme. Used to identify the party authorized to collect payments under this mandate. For SEPA, this is the Creditor Identifier issued by national central banks.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeFlag rdf:type rdf:Property ;
    rdfs:label 'Dispute Flag' ;
    rdfs:comment 'Indicates whether the mandate is currently subject to a dispute or chargeback claim by the debtor. True if active dispute exists.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:endDate rdf:type rdf:Property ;
    rdfs:label 'End Date' ;
    rdfs:comment 'Date on which the mandate expires and can no longer be used for collections. Null indicates open-ended mandate. After this date, mandate status transitions to EXPIRED.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastCollectionDate rdf:type rdf:Property ;
    rdfs:label 'Last Collection Date' ;
    rdfs:comment 'Date of the most recent payment collection executed under this mandate. Used to track mandate usage and identify dormant mandates.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mandateStatus rdf:type rdf:Property ;
    rdfs:label 'Mandate Status' ;
    rdfs:comment 'Current lifecycle status of the payment mandate. ACTIVE indicates mandate is valid and can be used for collections. SUSPENDED indicates temporary hold. CANCELLED indicates creditor-initiated termination. EXPIRED indicates mandate passed end date. PENDING indicates awaiting activation. REVOKED indicates debtor-initiated cancellation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Amount' ;
    rdfs:comment 'Maximum amount that can be collected in a single transaction under this mandate. Null indicates no limit. Used for debtor protection and validation of collection requests.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextScheduledCollectionDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Collection Date' ;
    rdfs:comment 'Date of the next planned payment collection under this mandate. Used for recurring mandate scheduling and debtor notification.' ;
    rdfs:domain ind:PaymentMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sequenceType rdf:type rdf:Property ;
    rdfs:label 'Sequence Type' ;
    rdfs:comment 'Indicates the position of the collection in the mandate lifecycle. FIRST for initial collection, RECURRING for subsequent collections, FINAL for last collection, ONEOFF for single-use mandates, REPRESENTMENT for retry after return.' ;
    rdfs:domain ind:PaymentMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatureDate rdf:type rdf:Property ;
    rdfs:label 'Signature Date' ;
    rdfs:comment 'Date on which the debtor signed or authorized the mandate. Used to determine mandate validity and for dispute resolution. Must precede first collection date.' ;
    rdfs:domain ind:PaymentMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:startDate rdf:type rdf:Property ;
    rdfs:label 'Start Date' ;
    rdfs:comment 'Date from which the mandate becomes effective and collections can be initiated. Cannot be earlier than signature date.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cardTransactionId rdf:type rdf:Property ;
    rdfs:label 'Card Transaction Id' ;
    rdfs:comment 'Unique identifier for the card transaction record. Primary key.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CardTransaction .

ind:cardId rdf:type rdf:Property ;
    rdfs:label 'Card Id' ;
    rdfs:comment 'Foreign key linking to payment.card. Business justification: Every card transaction is performed on a specific physical or virtual card. card_id FK normalizes the relationship to the card master record. card_token and masked_pan are retained as execution-specif' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Card .

ind:merchantCountryId rdf:type rdf:Property ;
    rdfs:label 'Merchant Country Id' ;
    rdfs:comment 'Foreign key linking to reference.country. Business justification: Merchant country determines interchange rates, fraud velocity rules, 3DS requirements (PSD2 SCA), and cross-border transaction fees. Country master provides sanctions status, AML risk rating, and regu' ;
    rdfs:domain ind:CardTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:merchantId rdf:type rdf:Property ;
    rdfs:label 'Merchant Id' ;
    rdfs:comment 'Unique identifier assigned to the merchant by the acquirer or card network.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Merchant .

ind:transactionCurrencyId rdf:type rdf:Property ;
    rdfs:label 'Transaction Currency Id' ;
    rdfs:comment 'Foreign key linking to reference.currency. Business justification: Card transaction currency (merchant currency) drives DCC eligibility, interchange calculation, and fraud scoring. Currency master provides minor unit for amount precision and cross-border indicator fo' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:acquirerBic rdf:type rdf:Property ;
    rdfs:label 'Acquirer Bic' ;
    rdfs:comment 'SWIFT BIC code of the acquiring bank that processed the merchant transaction.' ;
    rdfs:domain ind:CardTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizationCode rdf:type rdf:Property ;
    rdfs:label 'Authorization Code' ;
    rdfs:comment 'Approval code returned by the card issuer when the transaction is authorized.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Authorization Timestamp' ;
    rdfs:comment 'Date and time when the transaction authorization was received from the card issuer. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:avsResultCode rdf:type rdf:Property ;
    rdfs:label 'Avs Result Code' ;
    rdfs:comment 'Result code from address verification system comparing billing address with issuer records.' ;
    rdfs:domain ind:CardTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingAmount rdf:type rdf:Property ;
    rdfs:label 'Billing Amount' ;
    rdfs:comment 'Amount billed to the cardholder in the card account currency after foreign exchange conversion if applicable.' ;
    rdfs:domain ind:CardTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingCurrency rdf:type rdf:Property ;
    rdfs:label 'Billing Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the billing amount (card account currency).' ;
    rdfs:domain ind:CardTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardPresentFlag rdf:type rdf:Property ;
    rdfs:label 'Card Present Flag' ;
    rdfs:comment 'Indicates whether the physical card was present at the time of transaction (True) or not present for card-not-present transactions (False).' ;
    rdfs:domain ind:CardTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cardToken rdf:type rdf:Property ;
    rdfs:label 'Card Token' ;
    rdfs:comment 'Tokenized representation of the card number used for secure processing without exposing actual PAN.' ;
    rdfs:domain ind:CardTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardType rdf:type rdf:Property ;
    rdfs:label 'Card Type' ;
    rdfs:comment 'Type of card used for the transaction: debit, credit, prepaid, or charge card.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardholderPresentFlag rdf:type rdf:Property ;
    rdfs:label 'Cardholder Present Flag' ;
    rdfs:comment 'Indicates whether the cardholder was physically present at the point of sale (True) or not (False).' ;
    rdfs:domain ind:CardTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:channelType rdf:type rdf:Property ;
    rdfs:label 'Channel Type' ;
    rdfs:comment 'Channel through which the transaction was initiated: point of sale, ATM, e-commerce, mobile app, phone, or mail order.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cvvResultCode rdf:type rdf:Property ;
    rdfs:label 'Cvv Result Code' ;
    rdfs:comment 'Result of CVV verification: M=Match, N=No Match, P=Not Processed, S=Should be present, U=Unsupported.' ;
    rdfs:domain ind:CardTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declineReasonCode rdf:type rdf:Property ;
    rdfs:label 'Decline Reason Code' ;
    rdfs:comment 'Code indicating the reason for transaction decline if authorization was not approved (e.g., insufficient funds, invalid card, suspected fraud).' ;
    rdfs:domain ind:CardTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudFlag rdf:type rdf:Property ;
    rdfs:label 'Fraud Flag' ;
    rdfs:comment 'Indicates whether the transaction was flagged as potentially fraudulent by the fraud detection system (True) or not (False).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fraudScore rdf:type rdf:Property ;
    rdfs:label 'Fraud Score' ;
    rdfs:comment 'Risk score assigned by fraud detection system indicating likelihood of fraudulent activity, typically 0-100 scale.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interchangeFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Interchange Fee Amount' ;
    rdfs:comment 'Interchange fee charged by the card issuer to the acquirer for processing the transaction.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:issuerBic rdf:type rdf:Property ;
    rdfs:label 'Issuer Bic' ;
    rdfs:comment 'SWIFT BIC code of the card issuing bank.' ;
    rdfs:domain ind:CardTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maskedPan rdf:type rdf:Property ;
    rdfs:label 'Masked Pan' ;
    rdfs:comment 'Masked card number showing first 6 and last 4 digits with middle digits obscured for security. Format: 123456******7890.' ;
    rdfs:domain ind:CardTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:merchantCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Merchant Category Code' ;
    rdfs:comment 'Four-digit code classifying the merchants business type (e.g., 5411 for grocery stores, 5812 for restaurants).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:merchantCity rdf:type rdf:Property ;
    rdfs:label 'Merchant City' ;
    rdfs:comment 'City where the merchant is located or where the transaction occurred.' ;
    rdfs:domain ind:CardTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Network Reference Number' ;
    rdfs:comment 'Unique reference number assigned by the card network for tracking and reconciliation across the payment lifecycle.' ;
    rdfs:domain ind:CardTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:posEntryMode rdf:type rdf:Property ;
    rdfs:label 'Pos Entry Mode' ;
    rdfs:comment 'Method by which the card data was entered at the point of sale: chip, swipe, contactless, manual entry, e-commerce, or mobile wallet.' ;
    rdfs:domain ind:CardTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retrievalReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Retrieval Reference Number' ;
    rdfs:comment 'Reference number used to retrieve transaction details from the card network or processor.' ;
    rdfs:domain ind:CardTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:threeDSecureFlag rdf:type rdf:Property ;
    rdfs:label 'Three D Secure Flag' ;
    rdfs:comment 'Indicates whether 3D Secure authentication was used for this transaction (True) or not (False).' ;
    rdfs:domain ind:CardTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transactionAmount rdf:type rdf:Property ;
    rdfs:label 'Transaction Amount' ;
    rdfs:comment 'Original transaction amount in the transaction currency before any fees or adjustments.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Transaction Reference Number' ;
    rdfs:comment 'Unique external reference number assigned by the card network or acquiring system for this transaction.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sanctionScreeningId rdf:type rdf:Property ;
    rdfs:label 'Sanction Screening Id' ;
    rdfs:comment 'Unique identifier for the payment sanction screening record.' ;
    rdfs:domain ind:SanctionScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:monitoringRuleId rdf:type rdf:Property ;
    rdfs:label 'Monitoring Rule Id' ;
    rdfs:comment 'Foreign key linking to compliance.monitoring_rule. Business justification: Sanctions screening events are triggered by specific monitoring rules in banking compliance systems. Direct FK from sanction_screening to monitoring_rule supports audit trails showing which rule versi' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MonitoringRule .

ind:screenedPartyId rdf:type rdf:Property ;
    rdfs:label 'Screened Party Id' ;
    rdfs:comment 'Foreign key linking to customer.party. Business justification: AML compliance requires linking screening results to specific customer party for audit trail, regulatory examination, SAR filing decisions, and customer risk rating updates. Critical for OFAC/sanction' ;
    rdfs:domain ind:SanctionScreening ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:analystDecision rdf:type rdf:Property ;
    rdfs:label 'Analyst Decision' ;
    rdfs:comment 'Final decision made by the AML analyst after reviewing the sanctions alert: approve payment, reject payment, mark as false positive, or escalate to Money Laundering Reporting Officer (MLRO).' ;
    rdfs:domain ind:SanctionScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analystNotes rdf:type rdf:Property ;
    rdfs:label 'Analyst Notes' ;
    rdfs:comment 'Free-text notes and rationale documented by the AML analyst explaining their review findings and decision for audit and regulatory purposes.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analystReviewRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Analyst Review Required Flag' ;
    rdfs:comment 'Indicates whether the screening result requires manual review by an Anti-Money Laundering (AML) analyst due to potential match or high-risk indicators.' ;
    rdfs:domain ind:SanctionScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:analystReviewTimestamp rdf:type rdf:Property ;
    rdfs:label 'Analyst Review Timestamp' ;
    rdfs:comment 'Date and time when the AML analyst completed their review of the sanctions screening alert.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:autoDecisionFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Decision Flag' ;
    rdfs:comment 'Indicates whether the screening decision was made automatically by the system (true) or required manual analyst review (false).' ;
    rdfs:domain ind:SanctionScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:falsePositiveReason rdf:type rdf:Property ;
    rdfs:label 'False Positive Reason' ;
    rdfs:comment 'Reason code explaining why a sanctions match was determined to be a false positive: common name, different jurisdiction, different date of birth, different address, whitelist match, or other.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchScore rdf:type rdf:Property ;
    rdfs:label 'Match Score' ;
    rdfs:comment 'Numeric confidence score (0-100) indicating the strength of the match between the payment party and the watchlist entry, with higher scores indicating stronger matches.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:matchStatus rdf:type rdf:Property ;
    rdfs:label 'Match Status' ;
    rdfs:comment 'Overall result of the sanctions screening indicating whether a match was found: no match, potential match requiring review, confirmed match, or false positive after analyst review.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchType rdf:type rdf:Property ;
    rdfs:label 'Match Type' ;
    rdfs:comment 'Type of matching algorithm that identified the potential sanctions hit: exact name match, fuzzy match, partial match, phonetic match, or alias match.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchedEntityName rdf:type rdf:Property ;
    rdfs:label 'Matched Entity Name' ;
    rdfs:comment 'Name of the entity on the sanctions watchlist that matched or partially matched the payment party information.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchedField rdf:type rdf:Property ;
    rdfs:label 'Matched Field' ;
    rdfs:comment 'Specific field in the payment instruction that triggered the sanctions match: name, address, identifier, account number, Bank Identifier Code (BIC), or International Bank Account Number (IBAN).' ;
    rdfs:domain ind:SanctionScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchedPartyRole rdf:type rdf:Property ;
    rdfs:label 'Matched Party Role' ;
    rdfs:comment 'Role of the payment party that triggered the sanctions match: originator, beneficiary, intermediary bank, or correspondent bank.' ;
    rdfs:domain ind:SanctionScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ofacBlockingReportReference rdf:type rdf:Property ;
    rdfs:label 'Ofac Blocking Report Reference' ;
    rdfs:comment 'Reference number of the blocking report submitted to Office of Foreign Assets Control (OFAC) for confirmed sanctions matches requiring asset blocking.' ;
    rdfs:domain ind:SanctionScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ofacBlockingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Ofac Blocking Required Flag' ;
    rdfs:comment 'Indicates whether the payment must be blocked and reported to Office of Foreign Assets Control (OFAC) due to confirmed match with a sanctioned entity under United States sanctions programs.' ;
    rdfs:domain ind:SanctionScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryReportingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Required Flag' ;
    rdfs:comment 'Indicates whether this sanctions screening result requires regulatory reporting such as Suspicious Activity Report (SAR) filing to Financial Crimes Enforcement Network (FinCEN) or equivalent authority.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riskRating rdf:type rdf:Property ;
    rdfs:label 'Risk Rating' ;
    rdfs:comment 'Overall risk rating assigned to this sanctions screening result based on match score, watchlist type, party role, and other risk factors.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sarFilingDate rdf:type rdf:Property ;
    rdfs:label 'Sar Filing Date' ;
    rdfs:comment 'Date when the Suspicious Activity Report (SAR) was filed with the regulatory authority in response to this sanctions screening result.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sarFilingReference rdf:type rdf:Property ;
    rdfs:label 'Sar Filing Reference' ;
    rdfs:comment 'Reference number of the Suspicious Activity Report (SAR) filed with Financial Crimes Enforcement Network (FinCEN) or other regulatory authority if this screening triggered a filing obligation.' ;
    rdfs:domain ind:SanctionScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningDecision rdf:type rdf:Property ;
    rdfs:label 'Screening Decision' ;
    rdfs:comment 'Automated or manual decision resulting from the sanctions screening: pass (allow payment), hold (suspend for review), block (reject payment), or escalate (send to compliance officer).' ;
    rdfs:domain ind:SanctionScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningDurationMs rdf:type rdf:Property ;
    rdfs:label 'Screening Duration Ms' ;
    rdfs:comment 'Time taken to complete the sanctions screening process measured in milliseconds, used for system performance monitoring and Service Level Agreement (SLA) compliance.' ;
    rdfs:domain ind:SanctionScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:screeningErrorCode rdf:type rdf:Property ;
    rdfs:label 'Screening Error Code' ;
    rdfs:comment 'Error code returned by the sanctions screening system if the screening process failed or encountered technical issues.' ;
    rdfs:domain ind:SanctionScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningErrorMessage rdf:type rdf:Property ;
    rdfs:label 'Screening Error Message' ;
    rdfs:comment 'Detailed error message describing any technical issues encountered during the sanctions screening process.' ;
    rdfs:domain ind:SanctionScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Screening Reference Number' ;
    rdfs:comment 'External reference number assigned by the sanctions screening system for audit trail and case management.' ;
    rdfs:domain ind:SanctionScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningSystemName rdf:type rdf:Property ;
    rdfs:label 'Screening System Name' ;
    rdfs:comment 'Name of the Anti-Money Laundering (AML) and sanctions screening system that performed the check (e.g., NICE Actimize, Oracle Financial Crime).' ;
    rdfs:domain ind:SanctionScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningTimestamp rdf:type rdf:Property ;
    rdfs:label 'Screening Timestamp' ;
    rdfs:comment 'Date and time when the sanctions screening was performed against the payment instruction.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:watchlistType rdf:type rdf:Property ;
    rdfs:label 'Watchlist Type' ;
    rdfs:comment 'Type of sanctions or watchlist screened against: Office of Foreign Assets Control (OFAC) Specially Designated Nationals (SDN), European Union (EU) Consolidated List, United Nations (UN) Sanctions, Politically Exposed Persons (PEP), Her Majesty\'s Treasury (HMT) UK, or Department of Foreign Affairs and Trade (DFAT) Australia.' ;
    rdfs:domain ind:SanctionScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:watchlistVersion rdf:type rdf:Property ;
    rdfs:label 'Watchlist Version' ;
    rdfs:comment 'Version identifier or effective date of the sanctions watchlist used during screening to ensure audit trail and regulatory compliance.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escheatmentJurisdictionId rdf:type rdf:Property ;
    rdfs:label 'Escheatment Jurisdiction Id' ;
    rdfs:comment 'Foreign key linking to reference.jurisdiction. Business justification: Unclaimed property escheatment laws are jurisdiction-specific; banks must file dormant account funds with the correct state/jurisdiction authority. The escheatment_jurisdiction plain-text column is a ' ;
    rdfs:domain ind:DepositAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Jurisdiction .

ind:institutionBicDirectoryId rdf:type rdf:Property ;
    rdfs:label 'Institution Bic Directory Id' ;
    rdfs:comment 'Foreign key linking to reference.bic_directory. Business justification: The BIC on a deposit account identifies the booking institution/branch for SWIFT messaging, correspondent banking setup, and SEPA payment routing. The plain bic column is a denormalized string; a FK t' ;
    rdfs:domain ind:DepositAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BicDirectory .

ind:subledgerId rdf:type rdf:Property ;
    rdfs:label 'Subledger Id' ;
    rdfs:comment 'Foreign key linking to ledger.subledger. Business justification: Each deposit account is a source record in the deposit subledger. Banking core accounting architecture requires deposit accounts to reference their subledger for subledger-to-GL reconciliation, regula' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Subledger .

ind:accountType rdf:type rdf:Property ;
    rdfs:label 'Account Type' ;
    rdfs:comment 'Classification of the deposit account product type. DDA = Demand Deposit Account (checking), NOW = Negotiable Order of Withdrawal.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amountEscheated rdf:type rdf:Property ;
    rdfs:label 'Amount Escheated' ;
    rdfs:comment 'Total amount remitted to the state as unclaimed property. Null if not yet escheated.' ;
    rdfs:domain ind:DepositAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:atmWithdrawalLimit rdf:type rdf:Property ;
    rdfs:label 'Atm Withdrawal Limit' ;
    rdfs:comment 'Maximum amount that can be withdrawn via ATM in a single transaction or calendar day.' ;
    rdfs:domain ind:DepositAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:availableBalance rdf:type rdf:Property ;
    rdfs:label 'Available Balance' ;
    rdfs:comment 'Available balance for withdrawal or transfer, accounting for holds, pending transactions, and overdraft limits.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:closingDate rdf:type rdf:Property ;
    rdfs:label 'Closing Date' ;
    rdfs:comment 'Date the deposit account was officially closed. Null for active accounts.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:compoundingFrequency rdf:type rdf:Property ;
    rdfs:label 'Compounding Frequency' ;
    rdfs:comment 'Frequency at which accrued interest is capitalized and added to the principal balance.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crsReportableFlag rdf:type rdf:Property ;
    rdfs:label 'Crs Reportable Flag' ;
    rdfs:comment 'Indicates whether the account is reportable under OECD Common Reporting Standard for automatic exchange of financial account information.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currentBalance rdf:type rdf:Property ;
    rdfs:label 'Current Balance' ;
    rdfs:comment 'Current ledger balance of the deposit account, reflecting all posted transactions.' ;
    rdfs:domain ind:DepositAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dailyTransferLimit rdf:type rdf:Property ;
    rdfs:label 'Daily Transfer Limit' ;
    rdfs:comment 'Maximum amount that can be transferred out of the account in a single calendar day.' ;
    rdfs:domain ind:DepositAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dailyWithdrawalLimit rdf:type rdf:Property ;
    rdfs:label 'Daily Withdrawal Limit' ;
    rdfs:comment 'Maximum amount that can be withdrawn from the account in a single calendar day across all channels.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dormancyClassificationDate rdf:type rdf:Property ;
    rdfs:label 'Dormancy Classification Date' ;
    rdfs:comment 'Date the account was classified as dormant due to lack of customer-initiated activity for the defined dormancy period.' ;
    rdfs:domain ind:DepositAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dormancyPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Dormancy Period Months' ;
    rdfs:comment 'Number of months of inactivity required before the account is classified as dormant, per state or regulatory requirements.' ;
    rdfs:domain ind:DepositAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:escheatmentFilingDate rdf:type rdf:Property ;
    rdfs:label 'Escheatment Filing Date' ;
    rdfs:comment 'Date the account balance was reported and remitted to the state as unclaimed property. Null if not yet escheated.' ;
    rdfs:domain ind:DepositAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fatcaStatus rdf:type rdf:Property ;
    rdfs:label 'Fatca Status' ;
    rdfs:comment 'FATCA compliance status for foreign account tax reporting requirements.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fdicCoverageCategory rdf:type rdf:Property ;
    rdfs:label 'Fdic Coverage Category' ;
    rdfs:comment 'FDIC insurance coverage category determining the insurance limit applicable to this account. [ENUM-REF-CANDIDATE: single|joint|revocable_trust|irrevocable_trust|employee_benefit|corporation|government — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DepositAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fdicInsuredFlag rdf:type rdf:Property ;
    rdfs:label 'Fdic Insured Flag' ;
    rdfs:comment 'Indicates whether the account is covered by FDIC deposit insurance.' ;
    rdfs:domain ind:DepositAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interestAccrualMethod rdf:type rdf:Property ;
    rdfs:label 'Interest Accrual Method' ;
    rdfs:comment 'Method by which interest is calculated and accrued on the account balance.' ;
    rdfs:domain ind:DepositAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastActivityDate rdf:type rdf:Property ;
    rdfs:label 'Last Activity Date' ;
    rdfs:comment 'Date of the most recent customer-initiated transaction or activity on the account. Used for dormancy tracking.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastStatementDate rdf:type rdf:Property ;
    rdfs:label 'Last Statement Date' ;
    rdfs:comment 'Date of the most recent account statement generated for this account.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:openingDate rdf:type rdf:Property ;
    rdfs:label 'Opening Date' ;
    rdfs:comment 'Date the deposit account was officially opened and became active for transactions.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:overdraftLimit rdf:type rdf:Property ;
    rdfs:label 'Overdraft Limit' ;
    rdfs:comment 'Maximum approved overdraft amount for the account. Zero or null indicates no overdraft facility.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overdraftOptInStatus rdf:type rdf:Property ;
    rdfs:label 'Overdraft Opt In Status' ;
    rdfs:comment 'Customer election status for overdraft coverage on ATM and one-time debit card transactions, as required by Regulation E.' ;
    rdfs:domain ind:DepositAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overdraftProtectionSource rdf:type rdf:Property ;
    rdfs:label 'Overdraft Protection Source' ;
    rdfs:comment 'Source of funds for overdraft protection, if configured. Indicates the linked account or credit facility used to cover overdrafts.' ;
    rdfs:domain ind:DepositAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipType rdf:type rdf:Property ;
    rdfs:label 'Ownership Type' ;
    rdfs:comment 'Legal ownership structure of the deposit account. [ENUM-REF-CANDIDATE: individual|joint|corporate|trust|estate|custodial|government — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DepositAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statementCycle rdf:type rdf:Property ;
    rdfs:label 'Statement Cycle' ;
    rdfs:comment 'Frequency at which account statements are generated and delivered to the account holder.' ;
    rdfs:domain ind:DepositAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxReportingStatus rdf:type rdf:Property ;
    rdfs:label 'Tax Reporting Status' ;
    rdfs:comment 'Tax reporting classification for IRS Form 1099-INT reporting and FATCA compliance.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holderId rdf:type rdf:Property ;
    rdfs:label 'Holder Id' ;
    rdfs:comment 'Unique identifier for the account holder association record. Primary key.' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:onboardingChannelId rdf:type rdf:Property ;
    rdfs:label 'Onboarding Channel Id' ;
    rdfs:comment 'Foreign key linking to channel.channel. Business justification: KYC/AML regulations require documenting the channel through which a holder relationship (ownership, beneficiary designation) was established. CDD rules mandate recording how customer identity was veri' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:taxResidencyCountryId rdf:type rdf:Property ;
    rdfs:label 'Tax Residency Country Id' ;
    rdfs:comment 'Foreign key linking to reference.country. Business justification: CRS (OECD Common Reporting Standard) and FATCA require banks to identify and report account holders by their country of tax residence. This FK is a direct regulatory mandate — without it, automated CR' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:amlRiskRatingDate rdf:type rdf:Property ;
    rdfs:label 'Aml Risk Rating Date' ;
    rdfs:comment 'The date on which the current AML risk rating was assigned or last reviewed. Used to track compliance with periodic risk assessment requirements.' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:beneficiaryAllocationPercentage rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Allocation Percentage' ;
    rdfs:comment 'The percentage of account proceeds allocated to this beneficiary upon the death of the account owner. Must sum to 100.00 across all beneficiaries of the same account. Null for non-beneficiary roles.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:beneficiaryDesignationDate rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Designation Date' ;
    rdfs:comment 'The date on which the beneficiary designation was made by the account owner. Null if this holder is not a beneficiary.' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:beneficiaryRelationship rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Relationship' ;
    rdfs:comment 'The relationship of the beneficiary to the account owner. Used for estate planning, probate processing, and FDIC insurance coverage calculation. None if this holder is not a beneficiary. [ENUM-REF-CANDIDATE: spouse|child|parent|sibling|other_relative|friend|organization|none — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficiaryRevocationDate rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Revocation Date' ;
    rdfs:comment 'The date on which the beneficiary designation was revoked by the account owner. Null if the beneficiary designation is still active or was never revoked.' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:designationDate rdf:type rdf:Property ;
    rdfs:label 'Designation Date' ;
    rdfs:comment 'The date on which the customer was formally designated or added to the account in this role. May differ from effective_date if there is a lag between designation and activation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fdicInsuranceCategory rdf:type rdf:Property ;
    rdfs:label 'Fdic Insurance Category' ;
    rdfs:comment 'The FDIC insurance ownership category applicable to this account holder relationship. Determines insurance coverage limits and aggregation rules. Single for individual ownership; joint for joint ownership; revocable_trust for living trusts; irrevocable_trust for irrevocable trusts; employee_benefit for retirement accounts; corporation for business entities; government for public funds. [ENUM-REF-CANDIDATE: single|joint|revocable_trust|irrevocable_trust|employee_benefit|corporation|government — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationPreference rdf:type rdf:Property ;
    rdfs:label 'Notification Preference' ;
    rdfs:comment 'The preferred communication channel for account notifications and alerts for this holder. Email for electronic mail; SMS for text messages; phone for voice calls; mail for postal mail; none if notifications are suppressed.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipPercentage rdf:type rdf:Property ;
    rdfs:label 'Ownership Percentage' ;
    rdfs:comment 'The percentage of ownership interest held by this customer in the account. Applicable for joint accounts where ownership is divided. Must sum to 100.00 across all owners of the same account. Null for non-ownership roles (authorized signer, power of attorney).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ownershipRole rdf:type rdf:Property ;
    rdfs:label 'Ownership Role' ;
    rdfs:comment 'The role or capacity in which the customer holds rights to the account. Determines access rights, signing authority, and legal standing. Primary owner has full control; joint owner shares ownership; authorized signer can transact but does not own; power of attorney acts on behalf of owner; trustee manages for beneficiaries; custodian holds for minors or incapacitated persons.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipStatus rdf:type rdf:Property ;
    rdfs:label 'Relationship Status' ;
    rdfs:comment 'The current lifecycle status of this account holder relationship. Active indicates the relationship is in effect and the holder has the specified rights; inactive indicates temporary suspension; suspended indicates regulatory or compliance hold; terminated indicates the relationship has ended.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revocationDate rdf:type rdf:Property ;
    rdfs:label 'Revocation Date' ;
    rdfs:comment 'The date on which the account holder designation was revoked or terminated by the account owner or by operation of law. Null if the relationship is still active or was never revoked.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sanctionsScreeningDate rdf:type rdf:Property ;
    rdfs:label 'Sanctions Screening Date' ;
    rdfs:comment 'The date on which the most recent sanctions screening was performed for this account holder. Screening is typically performed at onboarding and periodically thereafter.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:signingAuthorityLevel rdf:type rdf:Property ;
    rdfs:label 'Signing Authority Level' ;
    rdfs:comment 'The level of transaction authority granted to this holder. Full authority allows all transactions without limits; limited authority is subject to transaction amount thresholds or approval requirements; none indicates no transactional rights (e.g., beneficiary-only role).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signingAuthorityLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Signing Authority Limit Amount' ;
    rdfs:comment 'The maximum transaction amount (in account currency) that this holder can authorize without additional approval. Applicable when signing_authority_level is limited. Null for full or none authority levels.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceSystemRecordReference rdf:type rdf:Property ;
    rdfs:label 'Source System Record Reference' ;
    rdfs:comment 'The unique identifier of this account holder record in the source system. Used for traceability and reconciliation back to the operational system of record.' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statementDeliveryPreference rdf:type rdf:Property ;
    rdfs:label 'Statement Delivery Preference' ;
    rdfs:comment 'The account holders preference for receiving account statements. Electronic for online/email delivery; paper for postal mail; both for dual delivery; none if statements are suppressed (e.g., for non-primary holders).' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportingDocumentationReference rdf:type rdf:Property ;
    rdfs:label 'Supporting Documentation Reference' ;
    rdfs:comment 'Reference identifier or file path to supporting legal documentation for this holder relationship. Examples include power of attorney documents, trust agreements, custodial orders, beneficiary designation forms, or court orders.' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxIdNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Id Number' ;
    rdfs:comment 'The tax identification number (TIN) for this account holder. Social Security Number (SSN) for US individuals; Employer Identification Number (EIN) for US entities; foreign tax ID for non-US persons. Used for tax reporting and compliance.' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxIdType rdf:type rdf:Property ;
    rdfs:label 'Tax Id Type' ;
    rdfs:comment 'The type of tax identification number provided. SSN for Social Security Number; EIN for Employer Identification Number; ITIN for Individual Taxpayer Identification Number; foreign_tin for non-US tax ID; none if not provided or not applicable.' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:w9W8FormReceivedDate rdf:type rdf:Property ;
    rdfs:label 'W9 W8 Form Received Date' ;
    rdfs:comment 'The date on which the IRS Form W-9 (for US persons) or Form W-8 (for foreign persons) was received from this account holder. Required for tax reporting compliance.' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:balanceId rdf:type rdf:Property ;
    rdfs:label 'Balance Id' ;
    rdfs:comment 'Unique identifier for the account balance snapshot record. Primary key for the account balance data product.' ;
    rdfs:domain ind:Balance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:statementId rdf:type rdf:Property ;
    rdfs:label 'Statement Id' ;
    rdfs:comment 'Foreign key linking to account.statement. Business justification: Daily balance snapshots are associated with a specific statement cycle. Adding balance.statement_id → statement.statement_id links each balance record to the statement period it belongs to, normalizin' ;
    rdfs:domain ind:Account ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Statement .

ind:availableOverdraft rdf:type rdf:Property ;
    rdfs:label 'Available Overdraft' ;
    rdfs:comment 'The remaining overdraft capacity available to the account holder, calculated as overdraft limit minus current overdraft balance utilized.' ;
    rdfs:domain ind:Balance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageDailyBalance rdf:type rdf:Property ;
    rdfs:label 'Average Daily Balance' ;
    rdfs:comment 'The average ledger balance for the statement period or month-to-date, calculated by summing daily balances and dividing by the number of days. Used for interest calculation and Net Interest Margin (NIM) analysis.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:balanceDate rdf:type rdf:Property ;
    rdfs:label 'Balance Date' ;
    rdfs:comment 'The business date for which this balance snapshot is recorded. Represents the end-of-day position for the specified date.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:balanceStatus rdf:type rdf:Property ;
    rdfs:label 'Balance Status' ;
    rdfs:comment 'The operational status of the account balance. Active indicates normal operations; frozen indicates temporary suspension; dormant indicates no activity for an extended period; closed indicates account closure; restricted indicates limited transaction capability.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collateralPledgedAmount rdf:type rdf:Property ;
    rdfs:label 'Collateral Pledged Amount' ;
    rdfs:comment 'The portion of the account balance that has been pledged as collateral for loans, letters of credit, or other obligations, reducing the available balance for withdrawal.' ;
    rdfs:domain ind:Balance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collectedBalance rdf:type rdf:Property ;
    rdfs:label 'Collected Balance' ;
    rdfs:comment 'The portion of the ledger balance that has cleared and is available for reserve requirement calculation. Excludes float and uncollected funds from deposited checks or transfers still in clearing.' ;
    rdfs:domain ind:Balance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daysInPeriod rdf:type rdf:Property ;
    rdfs:label 'Days In Period' ;
    rdfs:comment 'The number of calendar days in the current statement period, used as the denominator for average daily balance calculation.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:escheatmentEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Escheatment Eligible Flag' ;
    rdfs:comment 'Boolean indicator that is true if the account balance is eligible for escheatment to the state due to dormancy or abandonment under applicable unclaimed property laws.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fdicInsuredAmount rdf:type rdf:Property ;
    rdfs:label 'Fdic Insured Amount' ;
    rdfs:comment 'The portion of the account balance that is covered by FDIC deposit insurance, up to the standard maximum deposit insurance amount per depositor, per insured bank, for each account ownership category.' ;
    rdfs:domain ind:Balance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:floatBalance rdf:type rdf:Property ;
    rdfs:label 'Float Balance' ;
    rdfs:comment 'The amount of funds in transit or pending collection, representing deposits that have been credited to the ledger balance but have not yet cleared through the payment system.' ;
    rdfs:domain ind:Balance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holdBalance rdf:type rdf:Property ;
    rdfs:label 'Hold Balance' ;
    rdfs:comment 'The total amount of funds subject to holds, restrictions, or encumbrances that reduce the available balance. Includes administrative holds, legal holds, and collateral pledges.' ;
    rdfs:domain ind:Balance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interestBearingBalance rdf:type rdf:Property ;
    rdfs:label 'Interest Bearing Balance' ;
    rdfs:comment 'The portion of the account balance that is eligible for interest accrual based on the account type and interest calculation method. May differ from ledger balance due to minimum balance requirements or tiered rate structures.' ;
    rdfs:domain ind:Balance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastTransactionDate rdf:type rdf:Property ;
    rdfs:label 'Last Transaction Date' ;
    rdfs:comment 'The date of the most recent customer-initiated transaction on the account. Used to determine dormancy status and escheatment eligibility.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ledgerBalance rdf:type rdf:Property ;
    rdfs:label 'Ledger Balance' ;
    rdfs:comment 'The book balance of the account including all posted transactions as of the balance date. Represents the official accounting balance before adjustments for holds, floats, or uncollected funds.' ;
    rdfs:domain ind:Balance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumBalance rdf:type rdf:Property ;
    rdfs:label 'Maximum Balance' ;
    rdfs:comment 'The highest ledger balance recorded during the statement period or month-to-date. Used for FDIC insurance limit monitoring and liquidity analysis.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumBalance rdf:type rdf:Property ;
    rdfs:label 'Minimum Balance' ;
    rdfs:comment 'The lowest ledger balance recorded during the statement period or month-to-date. Used to determine minimum balance threshold breach and fee assessment.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumBalanceThresholdBreachFlag rdf:type rdf:Property ;
    rdfs:label 'Minimum Balance Threshold Breach Flag' ;
    rdfs:comment 'Boolean indicator that is true if the account balance fell below the contractual minimum balance threshold during the period, triggering potential fee assessment or service charge.' ;
    rdfs:domain ind:Balance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overdraftBalance rdf:type rdf:Property ;
    rdfs:label 'Overdraft Balance' ;
    rdfs:comment 'The amount by which the account is overdrawn if the ledger balance is negative. Zero if the account has a positive balance. Used for overdraft fee calculation and credit risk monitoring.' ;
    rdfs:domain ind:Balance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pendingCredits rdf:type rdf:Property ;
    rdfs:label 'Pending Credits' ;
    rdfs:comment 'The total amount of incoming transactions that have been authorized but not yet posted to the ledger balance. Includes pending deposits, transfers, and reversals.' ;
    rdfs:domain ind:Balance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pendingDebits rdf:type rdf:Property ;
    rdfs:label 'Pending Debits' ;
    rdfs:comment 'The total amount of outgoing transactions that have been authorized but not yet posted to the ledger balance. Includes pending withdrawals, payments, and fees.' ;
    rdfs:domain ind:Balance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reserveRequirementBalance rdf:type rdf:Property ;
    rdfs:label 'Reserve Requirement Balance' ;
    rdfs:comment 'The portion of the account balance subject to Federal Reserve reserve requirements under Regulation D. Used for Asset-Liability Management (ALM) and reserve calculation.' ;
    rdfs:domain ind:Balance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:snapshotTimestamp rdf:type rdf:Property ;
    rdfs:label 'Snapshot Timestamp' ;
    rdfs:comment 'The exact date and time when this balance snapshot was captured from the core banking system, typically during the end-of-day batch processing cycle.' ;
    rdfs:domain ind:Balance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:uninsuredAmount rdf:type rdf:Property ;
    rdfs:label 'Uninsured Amount' ;
    rdfs:comment 'The portion of the account balance that exceeds FDIC insurance limits and is therefore at risk in the event of bank failure. Used for depositor risk disclosure and liquidity stress testing.' ;
    rdfs:domain ind:Balance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accountTransactionId rdf:type rdf:Property ;
    rdfs:label 'Account Transaction Id' ;
    rdfs:comment 'Unique identifier for the account transaction record. Primary key for the account transaction entity.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccountTransaction .

ind:counterpartyBicDirectoryId rdf:type rdf:Property ;
    rdfs:label 'Counterparty Bic Directory Id' ;
    rdfs:comment 'Foreign key linking to reference.bic_directory. Business justification: Wire transfers and cross-border payments require counterparty bank BIC validation against the SWIFT BIC directory for routing, correspondent banking identification, and AML screening. The counterparty' ;
    rdfs:domain ind:AccountTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BicDirectory .

ind:counterpartyPartyId rdf:type rdf:Property ;
    rdfs:label 'Counterparty Party Id' ;
    rdfs:comment 'Foreign key linking to customer.party. Business justification: Internal transfers between customer accounts require counterparty identification for AML transaction monitoring, related-party transaction detection, and regulatory reporting (CTR, SAR). When counterp' ;
    rdfs:domain ind:AccountTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:disbursementId rdf:type rdf:Property ;
    rdfs:label 'Disbursement Id' ;
    rdfs:comment 'Foreign key linking to loan.disbursement. Business justification: Loan disbursements settle as credit transactions on the destination deposit account. Payment operations must link the account credit posting to the specific disbursement record for settlement confirma' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Disbursement .

ind:reversedTransactionAccountTransactionId rdf:type rdf:Property ;
    rdfs:label 'Reversed Transaction Account Transaction Id' ;
    rdfs:comment 'Reference to the original account transaction ID that this transaction reverses. Null if this is not a reversal transaction.' ;
    rdfs:domain ind:AccountTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccountTransaction .

ind:standingOrderId rdf:type rdf:Property ;
    rdfs:label 'Standing Order Id' ;
    rdfs:comment 'Foreign key linking to account.standing_order. Business justification: Recurring payment executions driven by standing orders generate account_transaction records. Linking account_transaction.standing_order_id → standing_order.standing_order_id allows tracing each transa' ;
    rdfs:domain ind:Account ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StandingOrder .

ind:achTraceNumber rdf:type rdf:Property ;
    rdfs:label 'Ach Trace Number' ;
    rdfs:comment '15-digit trace number assigned to ACH transactions for tracking and reconciliation purposes. Null for non-ACH transactions.' ;
    rdfs:domain ind:AccountTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amlAlertFlag rdf:type rdf:Property ;
    rdfs:label 'Aml Alert Flag' ;
    rdfs:comment 'Boolean indicator specifying whether this transaction triggered an AML alert requiring investigation. True if alert generated, False otherwise.' ;
    rdfs:domain ind:AccountTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:amlRiskScore rdf:type rdf:Property ;
    rdfs:label 'Aml Risk Score' ;
    rdfs:comment 'Numeric risk score assigned by the AML transaction monitoring system indicating the likelihood of money laundering or suspicious activity. Higher scores trigger enhanced review.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:balanceAfterTransaction rdf:type rdf:Property ;
    rdfs:label 'Balance After Transaction' ;
    rdfs:comment 'The running account balance immediately after this transaction was posted. Used for statement generation and overdraft detection.' ;
    rdfs:domain ind:AccountTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:branchCode rdf:type rdf:Property ;
    rdfs:label 'Branch Code' ;
    rdfs:comment 'The code of the branch or business unit where the transaction was initiated or processed. Used for profitability analysis and operational reporting.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardAuthorizationCode rdf:type rdf:Property ;
    rdfs:label 'Card Authorization Code' ;
    rdfs:comment 'Authorization code returned by the card network for approved card transactions. Null for non-card transactions.' ;
    rdfs:domain ind:AccountTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterpartyAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Counterparty Account Number' ;
    rdfs:comment 'The account number of the counterparty (originator or beneficiary) involved in the transaction. May be an internal account, external IBAN, or card number depending on transaction type.' ;
    rdfs:domain ind:AccountTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctrReportableFlag rdf:type rdf:Property ;
    rdfs:label 'Ctr Reportable Flag' ;
    rdfs:comment 'Boolean indicator specifying whether this transaction meets the threshold for Currency Transaction Report filing with FinCEN (typically cash transactions over $10,000).' ;
    rdfs:domain ind:AccountTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:glAccountCode rdf:type rdf:Property ;
    rdfs:label 'Gl Account Code' ;
    rdfs:comment 'The general ledger account code to which this transaction posts for financial accounting and regulatory reporting purposes.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdAmount rdf:type rdf:Property ;
    rdfs:label 'Hold Amount' ;
    rdfs:comment 'The amount of funds placed on hold or reserved as a result of this transaction (e.g., check hold, card authorization hold). Null if no hold applies.' ;
    rdfs:domain ind:AccountTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holdReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Hold Release Date' ;
    rdfs:comment 'The date on which any hold placed by this transaction will be released and funds will become available. Null if no hold applies.' ;
    rdfs:domain ind:AccountTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:narrative rdf:type rdf:Property ;
    rdfs:label 'Narrative' ;
    rdfs:comment 'Free-text description or memo field providing additional context about the transaction purpose, merchant name, or customer-entered notes. Appears on account statements.' ;
    rdfs:domain ind:AccountTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Posting Timestamp' ;
    rdfs:comment 'Precise timestamp when the transaction was committed to the account ledger, including time zone. Critical for intraday liquidity monitoring and real-time balance calculations.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:typeCode rdf:type rdf:Property ;
    rdfs:label 'Type Code' ;
    rdfs:comment 'Classification of the transaction indicating whether it is a debit, credit, fee charge, interest accrual, adjustment, or reversal posting.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wireImad rdf:type rdf:Property ;
    rdfs:label 'Wire Imad' ;
    rdfs:comment 'Input Message Accountability Data assigned to incoming wire transfers by the Federal Reserve or CHIPS. Null for non-wire transactions.' ;
    rdfs:domain ind:AccountTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wireOmad rdf:type rdf:Property ;
    rdfs:label 'Wire Omad' ;
    rdfs:comment 'Output Message Accountability Data assigned to outgoing wire transfers by the Federal Reserve or CHIPS. Null for non-wire transactions.' ;
    rdfs:domain ind:AccountTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryChannelId rdf:type rdf:Property ;
    rdfs:label 'Delivery Channel Id' ;
    rdfs:comment 'Foreign key linking to channel.channel. Business justification: Statement delivery channel tracking is required for regulatory proof of delivery (Reg E, Reg DD), customer preference management, and cost optimization. Links to channel for delivery method analytics ' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:interestRateId rdf:type rdf:Property ;
    rdfs:label 'Interest Rate Id' ;
    rdfs:comment 'Foreign key linking to account.interest_rate. Business justification: A periodic account statement captures the interest rate in effect during the statement cycle. Adding interest_rate_id FK links the statement to the authoritative interest_rate record, normalizing the ' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InterestRate .

ind:annualPercentageYield rdf:type rdf:Property ;
    rdfs:label 'Annual Percentage Yield' ;
    rdfs:comment 'The annualized rate of return on the account, expressed as a percentage, reflecting the effect of compounding interest. Disclosed per Regulation DD requirements.' ;
    rdfs:domain ind:Statement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:archivalDate rdf:type rdf:Property ;
    rdfs:label 'Archival Date' ;
    rdfs:comment 'The date when the statement was moved to archival storage or purged, if applicable. Used for compliance with record retention policies.' ;
    rdfs:domain ind:Statement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:archivalStatus rdf:type rdf:Property ;
    rdfs:label 'Archival Status' ;
    rdfs:comment 'Indicates the current archival state of the statement record. Active statements are readily accessible; archived statements are moved to long-term storage; purged statements have been deleted per retention policy.' ;
    rdfs:domain ind:Statement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bic rdf:type rdf:Property ;
    rdfs:label 'Bic' ;
    rdfs:comment 'The Bank Identifier Code (also known as SWIFT code) for the financial institution holding the account. Used for international wire transfers and SWIFT messaging.' ;
    rdfs:domain ind:Statement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closingBalance rdf:type rdf:Property ;
    rdfs:label 'Closing Balance' ;
    rdfs:comment 'The account balance at the end of the statement period (as of statement_period_end_date). Represents the final ledger balance after all transactions in this cycle.' ;
    rdfs:domain ind:Statement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cycleCode rdf:type rdf:Property ;
    rdfs:label 'Cycle Code' ;
    rdfs:comment 'Internal code representing the statement cycle configuration (e.g., monthly on the 1st, quarterly on the 15th). Used for batch processing and scheduling.' ;
    rdfs:domain ind:Statement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryStatus rdf:type rdf:Property ;
    rdfs:label 'Delivery Status' ;
    rdfs:comment 'Current status of the statement delivery process. Tracks whether the statement has been successfully delivered to the customer and, for electronic statements, whether it has been accessed.' ;
    rdfs:domain ind:Statement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escheatmentWarningFlag rdf:type rdf:Property ;
    rdfs:label 'Escheatment Warning Flag' ;
    rdfs:comment 'Indicates whether this statement includes a warning that the account is approaching dormancy and may be subject to escheatment (transfer to state unclaimed property). Required in certain jurisdictions.' ;
    rdfs:domain ind:Statement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:feesCharged rdf:type rdf:Property ;
    rdfs:label 'Fees Charged' ;
    rdfs:comment 'The total fees and service charges assessed against the account during the statement period, including maintenance fees, overdraft fees, and transaction fees.' ;
    rdfs:domain ind:Statement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:format rdf:type rdf:Property ;
    rdfs:label 'Format' ;
    rdfs:comment 'The file format or medium in which the statement is generated and delivered. PDF is standard for electronic statements; paper indicates physical print.' ;
    rdfs:domain ind:Statement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generatedBySystem rdf:type rdf:Property ;
    rdfs:label 'Generated By System' ;
    rdfs:comment 'The name or identifier of the core banking system or statement generation platform that produced this statement (e.g., Temenos T24, FIS Profile).' ;
    rdfs:domain ind:Statement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Generated Timestamp' ;
    rdfs:comment 'The date and time when the statement record was generated by the core banking system. Represents the system event time for audit and reconciliation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:interestEarned rdf:type rdf:Property ;
    rdfs:label 'Interest Earned' ;
    rdfs:comment 'The total interest accrued and credited to the account during the statement period. Calculated based on the account\'s interest rate and daily balance.' ;
    rdfs:domain ind:Statement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:language rdf:type rdf:Property ;
    rdfs:label 'Language' ;
    rdfs:comment 'Two-letter ISO 639-1 language code indicating the language in which the statement is generated (e.g., en for English, es for Spanish, fr for French).' ;
    rdfs:domain ind:Statement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noticeOfChangeFlag rdf:type rdf:Property ;
    rdfs:label 'Notice Of Change Flag' ;
    rdfs:comment 'Indicates whether this statement includes a notice of change to account terms, fees, or interest rates. Required for regulatory compliance and customer notification.' ;
    rdfs:domain ind:Statement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:openingBalance rdf:type rdf:Property ;
    rdfs:label 'Opening Balance' ;
    rdfs:comment 'The account balance at the beginning of the statement period (as of statement_period_start_date). Represents the starting ledger balance before any transactions in this cycle.' ;
    rdfs:domain ind:Statement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overdraftCount rdf:type rdf:Property ;
    rdfs:label 'Overdraft Count' ;
    rdfs:comment 'The number of times the account balance went negative (overdraft) during the statement period. Used for fee assessment and risk monitoring.' ;
    rdfs:domain ind:Statement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overdraftFees rdf:type rdf:Property ;
    rdfs:label 'Overdraft Fees' ;
    rdfs:comment 'The total overdraft and non-sufficient funds (NSF) fees charged during the statement period. Subset of total fees_charged, broken out for regulatory disclosure.' ;
    rdfs:domain ind:Statement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:periodEndDate rdf:type rdf:Property ;
    rdfs:label 'Period End Date' ;
    rdfs:comment 'The last date of the statement cycle period. Represents the end of the transaction window covered by this statement.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodStartDate rdf:type rdf:Property ;
    rdfs:label 'Period Start Date' ;
    rdfs:comment 'The first date of the statement cycle period. Represents the beginning of the transaction window covered by this statement.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regDdDisclosureFlag rdf:type rdf:Property ;
    rdfs:label 'Reg Dd Disclosure Flag' ;
    rdfs:comment 'Indicates whether Regulation DD disclosures (Truth in Savings Act - interest rates, fees, terms) are included on this statement. Required for deposit accounts.' ;
    rdfs:domain ind:Statement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regEDisclosureFlag rdf:type rdf:Property ;
    rdfs:label 'Reg E Disclosure Flag' ;
    rdfs:comment 'Indicates whether Regulation E disclosures (electronic fund transfer rights and liabilities) are included on this statement. Required for accounts with EFT activity.' ;
    rdfs:domain ind:Statement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:statementDate rdf:type rdf:Property ;
    rdfs:label 'Statement Date' ;
    rdfs:comment 'The official date on which the statement was generated and made available to the account holder. This is the date printed on the statement document.' ;
    rdfs:domain ind:Statement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:statementNumber rdf:type rdf:Property ;
    rdfs:label 'Statement Number' ;
    rdfs:comment 'Externally visible unique statement number assigned by the core banking system for customer reference and audit purposes. Typically follows a sequential or date-based numbering scheme.' ;
    rdfs:domain ind:Statement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statementType rdf:type rdf:Property ;
    rdfs:label 'Statement Type' ;
    rdfs:comment 'Classification of the statement based on its frequency or purpose. Monthly and quarterly are standard cycles; interim may be generated on demand; final indicates account closure.' ;
    rdfs:domain ind:Statement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suppressionFlag rdf:type rdf:Property ;
    rdfs:label 'Suppression Flag' ;
    rdfs:comment 'Indicates whether statement generation was suppressed for this cycle due to customer preference, account inactivity, or regulatory exemption.' ;
    rdfs:domain ind:Statement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:suppressionReason rdf:type rdf:Property ;
    rdfs:label 'Suppression Reason' ;
    rdfs:comment 'The reason why statement generation was suppressed, if suppression_flag is true. Provides audit trail for non-delivery.' ;
    rdfs:domain ind:Statement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCredits rdf:type rdf:Property ;
    rdfs:label 'Total Credits' ;
    rdfs:comment 'The sum of all credit transactions (deposits, interest credits, reversals) posted to the account during the statement period.' ;
    rdfs:domain ind:Statement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDebits rdf:type rdf:Property ;
    rdfs:label 'Total Debits' ;
    rdfs:comment 'The sum of all debit transactions (withdrawals, fees, charges, payments) posted to the account during the statement period.' ;
    rdfs:domain ind:Statement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionCount rdf:type rdf:Property ;
    rdfs:label 'Transaction Count' ;
    rdfs:comment 'The total number of transactions (both credits and debits) posted to the account during the statement period. Used for summary reporting and fee calculation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:viewedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Viewed Timestamp' ;
    rdfs:comment 'The date and time when the account holder first accessed or viewed the electronic statement. Null for paper statements or if not yet viewed.' ;
    rdfs:domain ind:Statement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:interestAccrualId rdf:type rdf:Property ;
    rdfs:label 'Interest Accrual Id' ;
    rdfs:comment 'Unique identifier for the daily interest accrual record. Primary key for the account interest accrual entity.' ;
    rdfs:domain ind:InterestAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:benchmarkRateFixingId rdf:type rdf:Property ;
    rdfs:label 'Benchmark Rate Fixing Id' ;
    rdfs:comment 'Foreign key linking to reference.benchmark_rate_fixing. Business justification: Variable-rate deposit accruals (SOFR-linked, post-IBOR transition) must trace the specific daily benchmark fixing used in each calculation for audit, IBOR transition compliance (ISDA protocols), and r' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BenchmarkRateFixing .

ind:interestIncomeGlAccountId rdf:type rdf:Property ;
    rdfs:label 'Interest Income Gl Account Id' ;
    rdfs:comment 'Foreign key linking to ledger.gl_account. Business justification: IFRS/GAAP interest income recognition requires direct mapping of accruals to the income GL account. Banking accrual accounting and regulatory income reporting (FINREP, Call Report) depend on this GL a' ;
    rdfs:domain ind:InterestAccrual ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:accrualBasisCode rdf:type rdf:Property ;
    rdfs:label 'Accrual Basis Code' ;
    rdfs:comment 'Day count convention used to calculate interest accrual. Determines how days are counted in the numerator and denominator of the interest calculation formula. ACT/360 is common for money market accounts, ACT/365 for savings, 30/360 for certain time deposits.' ;
    rdfs:domain ind:InterestAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accrualDate rdf:type rdf:Property ;
    rdfs:label 'Accrual Date' ;
    rdfs:comment 'The business date on which this interest accrual calculation was performed. Represents the principal business event timestamp for this daily accrual record.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accrualMethod rdf:type rdf:Property ;
    rdfs:label 'Accrual Method' ;
    rdfs:comment 'The mathematical method used to calculate interest accrual. Simple interest is calculated on principal only; compound interest includes previously accrued interest in the calculation base; continuous uses exponential compounding.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accrualReversalReason rdf:type rdf:Property ;
    rdfs:label 'Accrual Reversal Reason' ;
    rdfs:comment 'Code or description explaining why this accrual was reversed, if applicable. Common reasons include account closure, rate correction, system error, or NPL (Non-Performing Loan) classification requiring accrual suspension.' ;
    rdfs:domain ind:InterestAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accrualStatus rdf:type rdf:Property ;
    rdfs:label 'Accrual Status' ;
    rdfs:comment 'Current lifecycle status of this accrual record. Calculated indicates daily accrual computed but not yet posted; posted indicates interest has been capitalized to account; reversed indicates accrual was backed out; suspended indicates accrual is on hold (e.g., for NPL accounts).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accruedInterestAmount rdf:type rdf:Property ;
    rdfs:label 'Accrued Interest Amount' ;
    rdfs:comment 'The interest amount accrued for this specific accrual date, calculated as (principal_balance × applicable_interest_rate × days) / day_count_basis. This is the daily interest increment.' ;
    rdfs:domain ind:InterestAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cumulativeAccruedInterest rdf:type rdf:Property ;
    rdfs:label 'Cumulative Accrued Interest' ;
    rdfs:comment 'The total interest accrued from the last interest posting date through the current accrual date. Represents the running total of unpaid accrued interest for the current interest period.' ;
    rdfs:domain ind:InterestAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interestPayableGlAccount rdf:type rdf:Property ;
    rdfs:label 'Interest Payable Gl Account' ;
    rdfs:comment 'The general ledger account code for the accrued interest payable liability. Represents the contra-account for the interest expense accrual until interest is posted to the customer account.' ;
    rdfs:domain ind:InterestAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interestPostingFrequency rdf:type rdf:Property ;
    rdfs:label 'Interest Posting Frequency' ;
    rdfs:comment 'The frequency at which accrued interest is capitalized and posted to the account balance. Defines the cadence of interest payment or compounding per the account product terms. [ENUM-REF-CANDIDATE: daily|weekly|monthly|quarterly|semi-annually|annually|at_maturity — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InterestAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastInterestPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Last Interest Payment Date' ;
    rdfs:comment 'The most recent date on which interest was posted or paid to the account. Marks the beginning of the current accrual period.' ;
    rdfs:domain ind:InterestAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:netInterestAmount rdf:type rdf:Property ;
    rdfs:label 'Net Interest Amount' ;
    rdfs:comment 'The net interest amount after withholding tax deduction, calculated as accrued_interest_amount minus withholding_tax_amount. Represents the interest amount that will be credited to the customer.' ;
    rdfs:domain ind:InterestAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextInterestPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Next Interest Payment Date' ;
    rdfs:comment 'The scheduled date on which the cumulative accrued interest will be posted to the account or paid to the customer. Used for interest payment planning and customer disclosure.' ;
    rdfs:domain ind:InterestAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:postedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Posted Timestamp' ;
    rdfs:comment 'The system timestamp when the accrued interest was posted to the customer account or general ledger. Null if accrual status is calculated or pending_review.' ;
    rdfs:domain ind:InterestAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:principalBalance rdf:type rdf:Property ;
    rdfs:label 'Principal Balance' ;
    rdfs:comment 'The account balance amount on which interest is calculated for this accrual date. Represents the principal subject to interest computation, typically the end-of-day ledger balance.' ;
    rdfs:domain ind:InterestAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productCode rdf:type rdf:Property ;
    rdfs:label 'Product Code' ;
    rdfs:comment 'The deposit product code or account type code for the account earning this interest. Used to segment interest expense by product line for NII analysis and product profitability.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Reporting Flag' ;
    rdfs:comment 'Indicates whether this interest accrual must be included in tax reporting (e.g., 1099-INT for US customers, FATCA/CRS reporting for foreign accounts). True if tax reporting is required, False otherwise.' ;
    rdfs:domain ind:InterestAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:withholdingTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Amount' ;
    rdfs:comment 'The tax amount withheld from the accrued interest for this accrual date, calculated as accrued_interest_amount × withholding_tax_rate. Represents the portion of interest income remitted to tax authorities.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:withholdingTaxRate rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Rate' ;
    rdfs:comment 'The tax rate applied to withhold tax on interest income for applicable accounts, expressed as a decimal (e.g., 0.300000 for 30%). Applies to accounts subject to FATCA, CRS, or domestic tax withholding requirements.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yearBasisDays rdf:type rdf:Property ;
    rdfs:label 'Year Basis Days' ;
    rdfs:comment 'The number of days used in the denominator of the interest calculation (e.g., 360, 365, or actual days in year). Determined by the accrual_basis_code and used to annualize the interest rate.' ;
    rdfs:domain ind:InterestAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountFeeId rdf:type rdf:Property ;
    rdfs:label 'Account Fee Id' ;
    rdfs:comment 'Unique identifier for the account fee record. Primary key for the account fee entity.' ;
    rdfs:domain ind:AccountFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:disputeCaseId rdf:type rdf:Property ;
    rdfs:label 'Dispute Case Id' ;
    rdfs:comment 'Reference to the customer dispute case or complaint ticket associated with this fee, if applicable. Used for tracking dispute resolution.' ;
    rdfs:domain ind:AccountFee ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Case .

ind:waiverChannelId rdf:type rdf:Property ;
    rdfs:label 'Waiver Channel Id' ;
    rdfs:comment 'Foreign key linking to channel.channel. Business justification: Fee waiver requests are processed through specific channels for audit trails, customer service quality monitoring, and fraud prevention. Required for compliance reviews and dispute resolution. No exis' ;
    rdfs:domain ind:AccountFee ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:assessedAmount rdf:type rdf:Property ;
    rdfs:label 'Assessed Amount' ;
    rdfs:comment 'The gross amount of the fee assessed against the account before any waivers or adjustments, denominated in the account\'s base currency (typically USD for US operations).' ;
    rdfs:domain ind:AccountFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assessmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assessment Timestamp' ;
    rdfs:comment 'The precise date and time when the fee was assessed and recorded in the core banking system. Used for audit trail and transaction sequencing.' ;
    rdfs:domain ind:AccountFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:billingCycle rdf:type rdf:Property ;
    rdfs:label 'Billing Cycle' ;
    rdfs:comment 'The billing cycle or statement period during which the fee was assessed. Typically formatted as YYYYMM or a cycle sequence number.' ;
    rdfs:domain ind:AccountFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerNotificationFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Flag' ;
    rdfs:comment 'Boolean indicator of whether the customer was notified of this fee assessment through statement, email, SMS, or other communication channel.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disclosureStatementText rdf:type rdf:Property ;
    rdfs:label 'Disclosure Statement Text' ;
    rdfs:comment 'The standardized disclosure text that must be provided to the customer for this fee type, as required by CFPB Regulation DD or other applicable regulations.' ;
    rdfs:domain ind:AccountFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeDescription rdf:type rdf:Property ;
    rdfs:label 'Fee Description' ;
    rdfs:comment 'Detailed textual description of the fee assessed, including the reason and context for the charge. Used for customer statement generation and dispute resolution.' ;
    rdfs:domain ind:AccountFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Net Fee Amount' ;
    rdfs:comment 'The net fee amount charged to the account after waivers and adjustments (assessed_amount minus waived_amount). This is the amount that impacts the account balance and fee income.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:notificationChannel rdf:type rdf:Property ;
    rdfs:label 'Notification Channel' ;
    rdfs:comment 'The communication channel through which the customer was notified of the fee. STATEMENT=Account Statement, EMAIL=Email Notification, SMS=Text Message, MOBILE=Mobile App Push Notification, BRANCH=In-Branch Notification.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryDisclosureRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Disclosure Required Flag' ;
    rdfs:comment 'Boolean indicator of whether this fee type requires specific regulatory disclosure to the customer under CFPB Regulation DD or other consumer protection regulations.' ;
    rdfs:domain ind:AccountFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reversalReasonCode rdf:type rdf:Property ;
    rdfs:label 'Reversal Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for fee reversal. ERROR=System or Processing Error, DISPUTE=Customer Dispute Resolution, GOODWILL=Customer Service Goodwill, REGULATORY=Regulatory Compliance Requirement, FRAUD=Fraudulent Activity. Null if no reversal occurred.' ;
    rdfs:domain ind:AccountFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverFlag rdf:type rdf:Property ;
    rdfs:label 'Waiver Flag' ;
    rdfs:comment 'Boolean indicator of whether any portion of the fee was waived. True if waived_amount is greater than zero, False otherwise.' ;
    rdfs:domain ind:AccountFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waiverReasonCode rdf:type rdf:Property ;
    rdfs:label 'Waiver Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for fee waiver. CUST_REQ=Customer Request/Goodwill, SVC_FAIL=Service Failure, PROMO=Promotional Waiver, REL_MGMT=Relationship Management, REG_COMP=Regulatory Compliance, ERROR=System or Processing Error. Null if no waiver applied.' ;
    rdfs:domain ind:AccountFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Waiver Reason Description' ;
    rdfs:comment 'Free-text explanation providing additional context for the fee waiver decision. Used for audit and customer service documentation.' ;
    rdfs:domain ind:AccountFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverTimestamp rdf:type rdf:Property ;
    rdfs:label 'Waiver Timestamp' ;
    rdfs:comment 'The date and time when the fee waiver was authorized and processed. Null if no waiver was applied.' ;
    rdfs:domain ind:AccountFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:holdId rdf:type rdf:Property ;
    rdfs:label 'Hold Id' ;
    rdfs:comment 'Unique identifier for the account hold record. Primary key.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:placingChannelId rdf:type rdf:Property ;
    rdfs:label 'Placing Channel Id' ;
    rdfs:comment 'Foreign key linking to channel.channel. Business justification: Legal and regulatory holds are placed through specific channels for compliance audit trails, dispute resolution, and fraud investigation documentation. Required for regulatory examinations and litigat' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:actualReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Actual Release Date' ;
    rdfs:comment 'The business date on which the hold was actually released or cancelled. Null for active holds. May differ from expected release date if manually released early or extended.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualReleaseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Release Timestamp' ;
    rdfs:comment 'Precise date and time when the hold was released, including timezone offset. Used for audit and compliance reporting.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:beneficiaryName rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Name' ;
    rdfs:comment 'The name of the party entitled to receive the held funds, if applicable. Used for garnishments (e.g., creditor name), levies (e.g., IRS), or child support orders. Null for holds without a designated beneficiary.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficiaryReference rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Reference' ;
    rdfs:comment 'External reference number or account identifier for the beneficiary, such as a creditor account number or tax identification number. Null if not applicable.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkAmount rdf:type rdf:Property ;
    rdfs:label 'Check Amount' ;
    rdfs:comment 'The face value of the check that triggered the hold, if applicable. May differ from hold_amount if only a portion of the check is held. Null for non-check holds.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:checkSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Check Serial Number' ;
    rdfs:comment 'The serial number of the deposited check that triggered the hold, if applicable. Used for Reg CC check holds and exception case tracking. Null for non-check holds.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courtCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Court Case Number' ;
    rdfs:comment 'The docket or case number from the court order authorizing the hold, if applicable. Used for garnishments, levies, and legal holds. Null for non-legal holds.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courtJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Court Jurisdiction' ;
    rdfs:comment 'The name of the court or legal jurisdiction that issued the order, if applicable. Examples: \'Superior Court of California, County of Los Angeles\', \'U.S. District Court, Southern District of New York\'. Null for non-legal holds.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerNotificationSent rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Sent' ;
    rdfs:comment 'Indicates whether the account holder has been notified of the hold placement, as required by Reg CC for check holds and consumer protection regulations for other hold types.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disputeDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Date' ;
    rdfs:comment 'The date on which the customer filed a dispute regarding this hold. Null if no dispute has been filed.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disputeResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Date' ;
    rdfs:comment 'The date on which the dispute was resolved. Null if the dispute is still open or no dispute was filed.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expectedReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Expected Release Date' ;
    rdfs:comment 'The anticipated business date on which the hold will be automatically released, based on regulatory timelines (e.g., Reg CC hold periods) or court order expiration. Nullable for indefinite holds.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expirationAction rdf:type rdf:Property ;
    rdfs:label 'Expiration Action' ;
    rdfs:comment 'The action to be taken when the hold reaches its expected release date. Auto-release holds are lifted automatically; manual review holds require operations approval; extend holds are renewed for another period; escalate holds trigger compliance or legal review.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdStatus rdf:type rdf:Property ;
    rdfs:label 'Hold Status' ;
    rdfs:comment 'Current lifecycle status of the hold. Active holds reduce available balance; released holds have been lifted; expired holds passed their release date; cancelled holds were removed before maturity; partial release indicates a portion of the hold amount has been freed.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdType rdf:type rdf:Property ;
    rdfs:label 'Hold Type' ;
    rdfs:comment 'Classification of the hold based on its origin and purpose. Check holds are governed by Reg CC; legal holds include garnishments, levies, and court orders; fraud holds are placed by compliance or fraud teams; administrative holds are internal operational restrictions. [ENUM-REF-CANDIDATE: check_hold|legal_hold|administrative_hold|garnishment|levy|fraud_hold|regulatory_hold|collateral_hold — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCurrentRecord rdf:type rdf:Property ;
    rdfs:label 'Is Current Record' ;
    rdfs:comment 'Indicates whether this is the current active version of the hold record. True for the latest version; false for historical versions. Used for SCD Type 2 queries.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationMethod rdf:type rdf:Property ;
    rdfs:label 'Notification Method' ;
    rdfs:comment 'The channel through which the customer was notified of the hold. Null if no notification has been sent. [ENUM-REF-CANDIDATE: mail|email|sms|phone|in_person|online_banking|mobile_app — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partialReleaseAllowed rdf:type rdf:Property ;
    rdfs:label 'Partial Release Allowed' ;
    rdfs:comment 'Indicates whether the hold can be partially released before full maturity. True for holds that support incremental release (e.g., large check holds under Reg CC); false for all-or-nothing holds (e.g., fraud holds, court orders).' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:placementDate rdf:type rdf:Property ;
    rdfs:label 'Placement Date' ;
    rdfs:comment 'The business date on which the hold was placed on the account. This is the effective date from which the funds became unavailable.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:placementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Placement Timestamp' ;
    rdfs:comment 'Precise date and time when the hold was created in the system, including timezone offset. Used for audit trails and sequence resolution.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:placingAuthority rdf:type rdf:Property ;
    rdfs:label 'Placing Authority' ;
    rdfs:comment 'The organizational unit or external entity that initiated the hold. Court orders and external agencies (e.g., IRS, child support enforcement) are captured separately from internal departments. [ENUM-REF-CANDIDATE: branch|legal_department|compliance|court_order|fraud_team|operations|automated_system|external_agency — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priority rdf:type rdf:Property ;
    rdfs:label 'Priority' ;
    rdfs:comment 'Numeric priority ranking for this hold when multiple holds exist on the same account. Lower numbers indicate higher priority. Used to determine order of fund allocation when account balance is insufficient to cover all holds. Legal holds typically have higher priority than administrative holds.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonNarrative rdf:type rdf:Property ;
    rdfs:label 'Reason Narrative' ;
    rdfs:comment 'Free-text description providing additional context for the hold. May include check number, court case number, fraud case ID, or other supporting details for operational and customer service use.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Record Effective Date' ;
    rdfs:comment 'The business date from which this version of the hold record is effective. Used for slowly changing dimension (SCD) Type 2 historization in the lakehouse.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recordEndDate rdf:type rdf:Property ;
    rdfs:label 'Record End Date' ;
    rdfs:comment 'The business date on which this version of the hold record ceased to be effective. Null for the current active version. Used for slowly changing dimension (SCD) Type 2 historization.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryBasis rdf:type rdf:Property ;
    rdfs:label 'Regulatory Basis' ;
    rdfs:comment 'The primary regulatory or legal framework under which the hold is placed. Reg CC governs check holds; BSA/AML/OFAC govern compliance holds; court orders and tax levies are legal holds. \'None\' indicates an internal administrative hold. [ENUM-REF-CANDIDATE: reg_cc|bsa|aml|ofac|court_order|garnishment_order|tax_levy|none — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releasedAmount rdf:type rdf:Property ;
    rdfs:label 'Released Amount' ;
    rdfs:comment 'The cumulative amount of funds that have been released from this hold through partial releases. Zero for holds that have not been partially released. Equals hold_amount when the hold is fully released.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remainingHoldAmount rdf:type rdf:Property ;
    rdfs:label 'Remaining Hold Amount' ;
    rdfs:comment 'The current amount still held after any partial releases. Calculated as hold_amount minus released_amount. Used for real-time available balance calculation.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overdraftFacilityId rdf:type rdf:Property ;
    rdfs:label 'Overdraft Facility Id' ;
    rdfs:comment 'Unique identifier for the overdraft facility arrangement. Primary key for the overdraft facility record.' ;
    rdfs:domain ind:OverdraftFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryOverdraftDepositAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Overdraft Deposit Account Id' ;
    rdfs:comment 'Reference to the deposit account (DDA, savings, money market) to which this overdraft facility is attached.' ;
    rdfs:domain ind:OverdraftFacility ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DepositAccount .

ind:securingCollateralPledgeId rdf:type rdf:Property ;
    rdfs:label 'Securing Collateral Pledge Id' ;
    rdfs:comment 'Foreign key linking to collateral.collateral_pledge. Business justification: Secured overdraft facilities: an overdraft line secured by a formal pledge agreement requires the facility to reference the specific collateral_pledge (legal instrument), distinct from the collateral_' ;
    rdfs:domain ind:OverdraftFacility ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Pledge .

ind:approvedLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Approved Limit Amount' ;
    rdfs:comment 'Maximum overdraft amount approved by the bank for this facility. Represents the ceiling for negative balance coverage.' ;
    rdfs:domain ind:OverdraftFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:autoRepaymentEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Repayment Enabled' ;
    rdfs:comment 'Indicates whether automatic repayment of overdraft balance is enabled. True if incoming deposits automatically reduce the overdraft balance. False if manual repayment is required.' ;
    rdfs:domain ind:OverdraftFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dailyFeeCapAmount rdf:type rdf:Property ;
    rdfs:label 'Daily Fee Cap Amount' ;
    rdfs:comment 'Maximum total overdraft fees that can be charged in a single day. Used to limit customer exposure to excessive fees. Null if no daily cap applies.' ;
    rdfs:domain ind:OverdraftFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:facilityType rdf:type rdf:Property ;
    rdfs:label 'Facility Type' ;
    rdfs:comment 'Classification of the overdraft protection arrangement: standard (bank covers overdraft with fee), premium (enhanced coverage), linked to savings account, linked to line of credit, or linked to credit card.' ;
    rdfs:domain ind:OverdraftFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interestCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Interest Calculation Method' ;
    rdfs:comment 'Method used to calculate interest on the overdraft balance: daily balance, average daily balance, simple interest, compound interest, or none if no interest applies.' ;
    rdfs:domain ind:OverdraftFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastUsageDate rdf:type rdf:Property ;
    rdfs:label 'Last Usage Date' ;
    rdfs:comment 'Most recent date the overdraft facility was used (account balance went negative). Null if facility has never been used.' ;
    rdfs:domain ind:OverdraftFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lifetimeUsageCount rdf:type rdf:Property ;
    rdfs:label 'Lifetime Usage Count' ;
    rdfs:comment 'Total number of times the overdraft facility has been used (account went into negative balance) since facility inception. Used for customer behavior analysis.' ;
    rdfs:domain ind:OverdraftFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumTransferAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Transfer Amount' ;
    rdfs:comment 'Minimum amount that must be transferred from the linked protection source to cover an overdraft. Used to avoid multiple small transfers. Zero if no minimum applies.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:monthlyFeeCapAmount rdf:type rdf:Property ;
    rdfs:label 'Monthly Fee Cap Amount' ;
    rdfs:comment 'Maximum total overdraft fees that can be charged in a calendar month. Used to limit customer exposure to excessive fees. Null if no monthly cap applies.' ;
    rdfs:domain ind:OverdraftFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:optInDate rdf:type rdf:Property ;
    rdfs:label 'Opt In Date' ;
    rdfs:comment 'Date the customer provided opt-in consent for overdraft coverage per Regulation E. Null if customer has not opted in or opt-in is not applicable.' ;
    rdfs:domain ind:OverdraftFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:optInStatus rdf:type rdf:Property ;
    rdfs:label 'Opt In Status' ;
    rdfs:comment 'Customer opt-in status for overdraft coverage on ATM and one-time debit card transactions per Federal Reserve Regulation E. Opted in indicates customer consented. Opted out indicates customer declined. Pending indicates awaiting customer decision. Not applicable for non-Reg E overdraft types.' ;
    rdfs:domain ind:OverdraftFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optOutDate rdf:type rdf:Property ;
    rdfs:label 'Opt Out Date' ;
    rdfs:comment 'Date the customer revoked opt-in consent and opted out of overdraft coverage. Null if customer has not opted out.' ;
    rdfs:domain ind:OverdraftFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:overdraftFacilityStatus rdf:type rdf:Property ;
    rdfs:label 'Overdraft Facility Status' ;
    rdfs:comment 'Current lifecycle state of the overdraft facility. Active indicates the facility is operational and available for use. Suspended indicates temporary hold. Cancelled indicates customer or bank terminated the arrangement. Expired indicates the facility reached its end date. Pending activation indicates awaiting customer opt-in or bank approval.' ;
    rdfs:domain ind:OverdraftFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overdraftFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Overdraft Fee Amount' ;
    rdfs:comment 'Standard fee charged per overdraft occurrence when the account balance goes negative and bank coverage is used. Zero if no overdraft fee applies.' ;
    rdfs:domain ind:OverdraftFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:protectionSourceType rdf:type rdf:Property ;
    rdfs:label 'Protection Source Type' ;
    rdfs:comment 'Identifies the source of funds used to cover overdrafts: bank coverage (bank absorbs with fee), linked savings account, linked line of credit, linked credit card, or none (no protection).' ;
    rdfs:domain ind:OverdraftFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Transfer Fee Amount' ;
    rdfs:comment 'Fee charged per overdraft transfer event when funds are moved from the linked protection source to cover a negative balance. Zero if no per-transfer fee applies.' ;
    rdfs:domain ind:OverdraftFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transferIncrementAmount rdf:type rdf:Property ;
    rdfs:label 'Transfer Increment Amount' ;
    rdfs:comment 'Fixed increment amount for transfers from linked protection source (e.g., transfers occur in multiples of 50.00). Null if transfers match exact overdraft amount.' ;
    rdfs:domain ind:OverdraftFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:utilizationPercentage rdf:type rdf:Property ;
    rdfs:label 'Utilization Percentage' ;
    rdfs:comment 'Percentage of the approved limit currently utilized, calculated as (current_utilization_amount / approved_limit_amount) * 100. Used for credit risk monitoring.' ;
    rdfs:domain ind:OverdraftFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accountLimitId rdf:type rdf:Property ;
    rdfs:label 'Account Limit Id' ;
    rdfs:comment 'Unique identifier for the account limit record. Primary key for the account limit entity.' ;
    rdfs:domain ind:AccountLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:settingChannelId rdf:type rdf:Property ;
    rdfs:label 'Setting Channel Id' ;
    rdfs:comment 'Foreign key linking to channel.channel. Business justification: Fraud investigation and audit trails require knowing which channel set or last modified an account limit (ATM withdrawal cap, transfer limit). When a limit override precedes a fraud event, investigato' ;
    rdfs:domain ind:AccountLimit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:amlThresholdFlag rdf:type rdf:Property ;
    rdfs:label 'Aml Threshold Flag' ;
    rdfs:comment 'Indicates whether this limit is configured to support Anti-Money Laundering (AML) monitoring and Currency Transaction Report (CTR) thresholds. True if AML-related, False otherwise.' ;
    rdfs:domain ind:AccountLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:breachActionCode rdf:type rdf:Property ;
    rdfs:label 'Breach Action Code' ;
    rdfs:comment 'Action to be taken when a transaction would breach this limit. Values: BLOCK (reject transaction), WARN (alert but allow), ALLOW_WITH_FEE (permit with penalty charge), ESCALATE (require manual approval).' ;
    rdfs:domain ind:AccountLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerRequestedFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Requested Flag' ;
    rdfs:comment 'Indicates whether this limit was requested by the customer (e.g., self-imposed spending limit) rather than being bank-mandated. True if customer-initiated, False if bank-imposed.' ;
    rdfs:domain ind:AccountLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fraudPreventionFlag rdf:type rdf:Property ;
    rdfs:label 'Fraud Prevention Flag' ;
    rdfs:comment 'Indicates whether this limit is primarily configured for fraud prevention purposes. True if the limit is part of fraud controls, False otherwise.' ;
    rdfs:domain ind:AccountLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastResetTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Reset Timestamp' ;
    rdfs:comment 'Date and time when the utilization counters were last reset. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:AccountLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastUtilizationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Utilization Timestamp' ;
    rdfs:comment 'Date and time of the most recent transaction that utilized this limit. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:AccountLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:modifiedBy rdf:type rdf:Property ;
    rdfs:label 'Modified By' ;
    rdfs:comment 'Identifier of the user or system that last modified this limit record. May be a user ID, employee number, or system identifier.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Notification Threshold Amount' ;
    rdfs:comment 'The utilization amount at which the customer or bank should be notified (e.g., alert when 80% of limit is reached). Nullable if no notification threshold is configured.' ;
    rdfs:domain ind:AccountLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overrideFlag rdf:type rdf:Property ;
    rdfs:label 'Override Flag' ;
    rdfs:comment 'Indicates whether this limit can be overridden by authorized personnel during transaction processing. True if override is permitted, False otherwise.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resetFrequencyCode rdf:type rdf:Property ;
    rdfs:label 'Reset Frequency Code' ;
    rdfs:comment 'Frequency at which the utilization counters are reset to zero. Values: DAILY (reset at start of each day), WEEKLY (reset weekly), MONTHLY (reset monthly), QUARTERLY (reset quarterly), ANNUAL (reset annually), NONE (no automatic reset).' ;
    rdfs:domain ind:AccountLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utilizationAmount rdf:type rdf:Property ;
    rdfs:label 'Utilization Amount' ;
    rdfs:comment 'Current cumulative amount utilized against this limit within the applicable time period (e.g., daily, monthly). Reset frequency depends on limit type.' ;
    rdfs:domain ind:AccountLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:utilizationCount rdf:type rdf:Property ;
    rdfs:label 'Utilization Count' ;
    rdfs:comment 'Number of transactions that have been applied against this limit within the current period. Used for frequency-based limits.' ;
    rdfs:domain ind:AccountLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:createdBy rdf:type rdf:Property ;
    rdfs:label 'Created By' ;
    rdfs:comment 'Identifier of the user or system that created this limit record. May be a user ID, employee number, or system identifier.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusHistoryId rdf:type rdf:Property ;
    rdfs:label 'Status History Id' ;
    rdfs:comment 'Unique identifier for each account status transition record. Primary key for the immutable audit log of account lifecycle events.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:initiatingChannelId rdf:type rdf:Property ;
    rdfs:label 'Initiating Channel Id' ;
    rdfs:comment 'Foreign key linking to channel.channel. Business justification: BSA/AML and internal audit require tracing which channel initiated an account status change (freeze, dormancy, closure). Regulators expect this audit trail for suspicious activity investigations. \'ini' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:amlReviewRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Aml Review Required Flag' ;
    rdfs:comment 'Indicates whether this status transition triggers mandatory AML review procedures (e.g., dormant to active reactivation, sudden closure after large deposits). True if AML review is required, False otherwise.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:authorizingOfficerName rdf:type rdf:Property ;
    rdfs:label 'Authorizing Officer Name' ;
    rdfs:comment 'Full name of the bank officer who authorized the status change. Provides human-readable audit trail for regulatory examination.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:balanceAtTransition rdf:type rdf:Property ;
    rdfs:label 'Balance At Transition' ;
    rdfs:comment 'The account balance at the moment of status transition. Critical for FDIC insurance claim processing, escheatment reporting, and write-off calculations. Expressed in the account currency.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Hold Flag' ;
    rdfs:comment 'Indicates whether the status change was driven by a compliance or regulatory hold (e.g., OFAC match, court order, regulatory investigation). True if compliance-driven, False otherwise.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currencyCode rdf:type rdf:Property ;
    rdfs:label 'Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the balance at transition. Ensures accurate multi-currency reporting and regulatory compliance.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerNotificationSentFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Sent Flag' ;
    rdfs:comment 'Indicates whether the account holder was notified of the status change via the registered communication channels. True if notification was sent, False otherwise. Required for consumer protection compliance.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dormancyPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Dormancy Period Days' ;
    rdfs:comment 'Number of days the account remained inactive before transitioning to dormant status. Populated only for transitions to dormant status. Used for escheatment timeline calculations and regulatory dormancy reporting.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:effectiveTimestamp rdf:type rdf:Property ;
    rdfs:label 'Effective Timestamp' ;
    rdfs:comment 'The precise date and time when the new status became effective for the account. This is the business event timestamp, distinct from the record creation timestamp. Critical for regulatory timeline reconstruction and FDIC insurance claim processing.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:holdAuthority rdf:type rdf:Property ;
    rdfs:label 'Hold Authority' ;
    rdfs:comment 'Name of the regulatory authority or legal entity that mandated the hold or status change (e.g., OFAC, FBI, court name, state regulator). Populated only when compliance_hold_flag is True.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Hold Reference Number' ;
    rdfs:comment 'Official reference number or case identifier from the regulatory authority or court that issued the hold. Populated only when compliance_hold_flag is True.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newStatus rdf:type rdf:Property ;
    rdfs:label 'New Status' ;
    rdfs:comment 'The account lifecycle status after this transition was applied. Captures the to-state in the status change event. Required for regulatory examination and AML dormancy monitoring. [ENUM-REF-CANDIDATE: pending_activation|active|dormant|inactive|frozen|blocked|closed|written_off|reactivated — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Notification Timestamp' ;
    rdfs:comment 'The date and time when customer notification was sent regarding the status change. Null if no notification was sent or required.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:previousStatus rdf:type rdf:Property ;
    rdfs:label 'Previous Status' ;
    rdfs:comment 'The account lifecycle status immediately before this transition occurred. Captures the from-state in the status change event. [ENUM-REF-CANDIDATE: pending_activation|active|dormant|inactive|frozen|blocked|closed|written_off — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Reversal Reference Code' ;
    rdfs:comment 'Reference to the account_status_history_id of the reversing entry if this transition was reversed. Null if not reversed. Maintains bidirectional audit trail for corrections.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supportingDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Supporting Document Reference' ;
    rdfs:comment 'Reference identifier or URI to supporting documentation that justifies the status change (e.g., court order number, customer request ticket, AML case ID, death certificate reference). Critical for regulatory examination and dispute resolution.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:systemSource rdf:type rdf:Property ;
    rdfs:label 'System Source' ;
    rdfs:comment 'Identifier of the source system or application that recorded the status transition (e.g., Temenos T24, FIS Profile, batch job name, API service). Used for data lineage and troubleshooting.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benchmarkId rdf:type rdf:Property ;
    rdfs:label 'Benchmark Id' ;
    rdfs:comment 'Foreign key linking to security.benchmark. Business justification: Floating-rate deposit pricing and FTP calculations require linking deposit interest rates to the full security-domain benchmark entity (SOFR, EURIBOR). The existing rate_benchmark_id targets a referen' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Benchmark .

ind:supersededByRateInterestRateId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Rate Interest Rate Id' ;
    rdfs:comment 'Reference to the account_interest_rate_id that supersedes this rate configuration. Used to maintain rate change history and audit trail.' ;
    rdfs:domain ind:InterestRate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InterestRate .

ind:baseRate rdf:type rdf:Property ;
    rdfs:label 'Base Rate' ;
    rdfs:comment 'The base annual interest rate expressed as a decimal (e.g., 0.025000 for 2.5%). For fixed rates, this is the final rate. For variable rates, this is the starting point before spread adjustment.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ftpRate rdf:type rdf:Property ;
    rdfs:label 'Ftp Rate' ;
    rdfs:comment 'The internal Funds Transfer Pricing rate used to allocate funding costs or credits between business lines. Expressed as a decimal. Used for management accounting and profitability attribution.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interestPaymentFrequency rdf:type rdf:Property ;
    rdfs:label 'Interest Payment Frequency' ;
    rdfs:comment 'The frequency at which accrued interest is credited to the customer\'s account or paid out. Most deposit accounts credit interest monthly.' ;
    rdfs:domain ind:InterestRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPromotional rdf:type rdf:Property ;
    rdfs:label 'Is Promotional' ;
    rdfs:comment 'Indicates whether this is a promotional interest rate offered as part of a marketing campaign or customer acquisition strategy. True if promotional, False if standard rate.' ;
    rdfs:domain ind:InterestRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTaxAdvantaged rdf:type rdf:Property ;
    rdfs:label 'Is Tax Advantaged' ;
    rdfs:comment 'Indicates whether this rate applies to a tax-advantaged account type (e.g., IRA, HSA, 529 plan) where interest may be tax-deferred or tax-exempt. True if tax-advantaged, False otherwise.' ;
    rdfs:domain ind:InterestRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maximumBalanceCap rdf:type rdf:Property ;
    rdfs:label 'Maximum Balance Cap' ;
    rdfs:comment 'The maximum account balance on which interest is paid at this rate. Balances exceeding this cap may earn a different rate or no additional interest.' ;
    rdfs:domain ind:InterestRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumBalanceRequirement rdf:type rdf:Property ;
    rdfs:label 'Minimum Balance Requirement' ;
    rdfs:comment 'The minimum account balance required to earn the stated interest rate. Balances below this threshold may earn a lower rate or no interest.' ;
    rdfs:domain ind:InterestRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nimContributionBps rdf:type rdf:Property ;
    rdfs:label 'Nim Contribution Bps' ;
    rdfs:comment 'The estimated contribution of this rate configuration to the bank\'s Net Interest Margin (NIM), expressed in basis points. Used for profitability analysis and ALCO reporting.' ;
    rdfs:domain ind:InterestRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:promotionalExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Promotional Expiry Date' ;
    rdfs:comment 'The date on which the promotional rate expires and reverts to the standard rate. Only applicable when is_promotional is True.' ;
    rdfs:domain ind:InterestRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rateApprovalAuthority rdf:type rdf:Property ;
    rdfs:label 'Rate Approval Authority' ;
    rdfs:comment 'The governance body or role that approved this interest rate configuration. ALCO (Asset-Liability Committee), TREASURY, PRODUCT_MANAGEMENT, BRANCH_MANAGER, or EXECUTIVE_COMMITTEE.' ;
    rdfs:domain ind:InterestRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Rate Approval Date' ;
    rdfs:comment 'The date on which this interest rate configuration was formally approved by the designated approval authority.' ;
    rdfs:domain ind:InterestRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rateCeiling rdf:type rdf:Property ;
    rdfs:label 'Rate Ceiling' ;
    rdfs:comment 'The maximum interest rate that can be applied regardless of benchmark index movements. Caps the bank\'s interest expense exposure. Expressed as a decimal.' ;
    rdfs:domain ind:InterestRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateChangeFrequency rdf:type rdf:Property ;
    rdfs:label 'Rate Change Frequency' ;
    rdfs:comment 'The frequency at which variable interest rates are reviewed and potentially adjusted based on benchmark index movements. Fixed rates use \'at_maturity\' or \'as_needed\'. [ENUM-REF-CANDIDATE: daily|weekly|monthly|quarterly|annually|at_maturity|as_needed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InterestRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateChangeReason rdf:type rdf:Property ;
    rdfs:label 'Rate Change Reason' ;
    rdfs:comment 'Business justification or reason for this rate configuration or rate change. Examples: \'Benchmark index adjustment\', \'Competitive positioning\', \'Promotional campaign Q4 2024\', \'ALCO directive\'.' ;
    rdfs:domain ind:InterestRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateFloor rdf:type rdf:Property ;
    rdfs:label 'Rate Floor' ;
    rdfs:comment 'The minimum interest rate that can be applied regardless of benchmark index movements. Protects the bank from negative or excessively low rates. Expressed as a decimal.' ;
    rdfs:domain ind:InterestRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateStatus rdf:type rdf:Property ;
    rdfs:label 'Rate Status' ;
    rdfs:comment 'The current lifecycle status of this interest rate configuration. Active (currently in effect), Pending (approved but not yet effective), Expired (past expiry date), Superseded (replaced by newer rate), or Suspended (temporarily inactive).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateType rdf:type rdf:Property ;
    rdfs:label 'Rate Type' ;
    rdfs:comment 'Classification of the interest rate structure: fixed (constant rate), variable (indexed to benchmark), tiered (rate varies by balance threshold), or promotional (temporary marketing rate).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryDisclosureText rdf:type rdf:Property ;
    rdfs:label 'Regulatory Disclosure Text' ;
    rdfs:comment 'The standardized disclosure text required by Regulation DD for customer communication regarding this interest rate, including APY calculation methodology and any conditions or limitations.' ;
    rdfs:domain ind:InterestRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipBonusBps rdf:type rdf:Property ;
    rdfs:label 'Relationship Bonus Bps' ;
    rdfs:comment 'Additional basis points added to the base rate for customers meeting relationship pricing criteria. For example, 25 BPS = 0.25% rate bonus.' ;
    rdfs:domain ind:InterestRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:relationshipPricingEligible rdf:type rdf:Property ;
    rdfs:label 'Relationship Pricing Eligible' ;
    rdfs:comment 'Indicates whether this rate is eligible for relationship pricing adjustments based on the customer\'s total Assets Under Management (AUM) or product holdings with the bank. True if eligible, False otherwise.' ;
    rdfs:domain ind:InterestRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxWithholdingRate rdf:type rdf:Property ;
    rdfs:label 'Tax Withholding Rate' ;
    rdfs:comment 'The percentage of interest income subject to tax withholding, expressed as a decimal (e.g., 0.2400 for 24%). Applicable for certain account types and jurisdictions.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tierApr rdf:type rdf:Property ;
    rdfs:label 'Tier Apr' ;
    rdfs:comment 'The Annual Percentage Rate for this balance tier, expressed as a decimal (e.g., 0.024693 for 2.4693% APR). APR is the simple interest rate before compounding effects.' ;
    rdfs:domain ind:InterestRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tierApy rdf:type rdf:Property ;
    rdfs:label 'Tier Apy' ;
    rdfs:comment 'The Annual Percentage Yield for this balance tier, expressed as a decimal (e.g., 0.025000 for 2.5% APY). APY reflects the effect of compounding and is the rate disclosed to customers per Regulation DD.' ;
    rdfs:domain ind:InterestRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tierMaximumBalance rdf:type rdf:Property ;
    rdfs:label 'Tier Maximum Balance' ;
    rdfs:comment 'The maximum balance threshold for this rate tier. Balances above this amount move to the next tier. Null for the highest tier indicating no upper limit.' ;
    rdfs:domain ind:InterestRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tierMinimumBalance rdf:type rdf:Property ;
    rdfs:label 'Tier Minimum Balance' ;
    rdfs:comment 'The minimum balance threshold for this rate tier. Balances at or above this amount and below the tier maximum earn this tier\'s rate. Part of tiered rate structure.' ;
    rdfs:domain ind:InterestRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tierSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Tier Sequence Number' ;
    rdfs:comment 'The ordinal position of this rate tier within a tiered rate structure. Tier 1 is the lowest balance tier, incrementing for higher balance tiers. Null for non-tiered rates.' ;
    rdfs:domain ind:InterestRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:beneficiaryBicDirectoryId rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Bic Directory Id' ;
    rdfs:comment 'Foreign key linking to reference.bic_directory. Business justification: Recurring payment instructions (standing orders) reference a beneficiary bank that must be validated against the SWIFT BIC directory for SEPA, SWIFT, and domestic payment routing. The beneficiary_bank' ;
    rdfs:domain ind:StandingOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BicDirectory .

ind:beneficiaryPartyId rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Party Id' ;
    rdfs:comment 'Foreign key linking to customer.party. Business justification: Recurring payments to internal beneficiaries (customer-to-customer) require beneficiary validation, AML screening, and pre-population of beneficiary details from party master. Enables detection of pay' ;
    rdfs:domain ind:StandingOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:setupChannelId rdf:type rdf:Property ;
    rdfs:label 'Setup Channel Id' ;
    rdfs:comment 'Foreign key linking to channel.channel. Business justification: Standing order setup channel is tracked for fraud prevention, customer authentication verification, and service quality monitoring. Required for dispute resolution and regulatory compliance audits. Re' ;
    rdfs:domain ind:StandingOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:amlScreeningTimestamp rdf:type rdf:Property ;
    rdfs:label 'Aml Screening Timestamp' ;
    rdfs:comment 'Date and time of the most recent AML and sanctions screening for this standing order. Screening is typically performed at setup and periodically thereafter.' ;
    rdfs:domain ind:StandingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:approvalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Approval Required Flag' ;
    rdfs:comment 'Indicates whether the standing order setup or modification required managerial or compliance approval due to amount thresholds, risk profile, or regulatory requirements. True if approval was required.' ;
    rdfs:domain ind:StandingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:businessDayAdjustment rdf:type rdf:Property ;
    rdfs:label 'Business Day Adjustment' ;
    rdfs:comment 'Rule for adjusting execution date when scheduled date falls on a non-business day. Following moves to next business day; preceding moves to prior business day; modified following moves forward unless crossing month boundary.' ;
    rdfs:domain ind:StandingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationReasonCode rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for standing order cancellation. Used for operational reporting and customer service.' ;
    rdfs:domain ind:StandingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionCount rdf:type rdf:Property ;
    rdfs:label 'Execution Count' ;
    rdfs:comment 'Cumulative number of successful executions of the standing order since inception. Incremented after each successful payment.' ;
    rdfs:domain ind:StandingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:executionDay rdf:type rdf:Property ;
    rdfs:label 'Execution Day' ;
    rdfs:comment 'Day of the period on which the standing order should execute. For monthly frequency, represents day of month (1-31); for weekly, day of week (1-7). Adjusted for non-business days per bank policy.' ;
    rdfs:domain ind:StandingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:failedExecutionCount rdf:type rdf:Property ;
    rdfs:label 'Failed Execution Count' ;
    rdfs:comment 'Cumulative number of failed execution attempts due to insufficient funds, account restrictions, or system errors. Used for risk monitoring and customer notification.' ;
    rdfs:domain ind:StandingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:frequencyCode rdf:type rdf:Property ;
    rdfs:label 'Frequency Code' ;
    rdfs:comment 'Recurrence pattern for the standing order execution. Defines how often the payment instruction is executed. [ENUM-REF-CANDIDATE: daily|weekly|biweekly|monthly|quarterly|semiannual|annual — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instructionReference rdf:type rdf:Property ;
    rdfs:label 'Instruction Reference' ;
    rdfs:comment 'Externally visible unique reference number assigned to the standing order instruction by the customer or bank. Used for customer inquiries and statement reconciliation.' ;
    rdfs:domain ind:StandingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastExecutionDate rdf:type rdf:Property ;
    rdfs:label 'Last Execution Date' ;
    rdfs:comment 'Date of the most recent successful execution of the standing order. Null if the standing order has never executed.' ;
    rdfs:domain ind:StandingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextExecutionDate rdf:type rdf:Property ;
    rdfs:label 'Next Execution Date' ;
    rdfs:comment 'Next calendar date on which the standing order is scheduled to execute. Updated after each successful execution or when schedule is modified.' ;
    rdfs:domain ind:StandingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentReference rdf:type rdf:Property ;
    rdfs:label 'Payment Reference' ;
    rdfs:comment 'Free-text reference or remittance information included with each payment execution. Appears on beneficiary statement for payment identification and reconciliation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityCode rdf:type rdf:Property ;
    rdfs:label 'Priority Code' ;
    rdfs:comment 'Execution priority level for the standing order. High and urgent priorities may incur premium fees but ensure faster processing.' ;
    rdfs:domain ind:StandingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:setupTimestamp rdf:type rdf:Property ;
    rdfs:label 'Setup Timestamp' ;
    rdfs:comment 'Date and time when the standing order instruction was originally created in the system. Immutable audit field.' ;
    rdfs:domain ind:StandingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:transferAmount rdf:type rdf:Property ;
    rdfs:label 'Transfer Amount' ;
    rdfs:comment 'Fixed monetary amount to be transferred with each execution of the standing order. Amount remains constant unless modified by customer instruction.' ;
    rdfs:domain ind:StandingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:directDebitMandateId rdf:type rdf:Property ;
    rdfs:label 'Direct Debit Mandate Id' ;
    rdfs:comment 'Unique identifier for the direct debit mandate authorization record.' ;
    rdfs:domain ind:DirectDebitMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:authorizationChannelId rdf:type rdf:Property ;
    rdfs:label 'Authorization Channel Id' ;
    rdfs:comment 'Foreign key linking to channel.channel. Business justification: NACHA and Reg E require tracking the channel through which direct debit mandates are authorized for dispute resolution and compliance audits. Essential for unauthorized debit claim investigations. Rem' ;
    rdfs:domain ind:DirectDebitMandate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:amlReviewDate rdf:type rdf:Property ;
    rdfs:label 'Aml Review Date' ;
    rdfs:comment 'Date of the most recent AML review conducted for this mandate.' ;
    rdfs:domain ind:DirectDebitMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authorizationDate rdf:type rdf:Property ;
    rdfs:label 'Authorization Date' ;
    rdfs:comment 'Date on which the account holder authorized the direct debit mandate.' ;
    rdfs:domain ind:DirectDebitMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authorizedAmount rdf:type rdf:Property ;
    rdfs:label 'Authorized Amount' ;
    rdfs:comment 'Maximum amount authorized per debit transaction. Null for variable amount mandates.' ;
    rdfs:domain ind:DirectDebitMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collectionCount rdf:type rdf:Property ;
    rdfs:label 'Collection Count' ;
    rdfs:comment 'Total number of debit collections executed under this mandate to date.' ;
    rdfs:domain ind:DirectDebitMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:firstCollectionDate rdf:type rdf:Property ;
    rdfs:label 'First Collection Date' ;
    rdfs:comment 'Date of the first debit collection under this mandate.' ;
    rdfs:domain ind:DirectDebitMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mandateReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Mandate Reference Number' ;
    rdfs:comment 'Unique external reference number assigned to this mandate for identification in ACH and SEPA transactions.' ;
    rdfs:domain ind:DirectDebitMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originatorName rdf:type rdf:Property ;
    rdfs:label 'Originator Name' ;
    rdfs:comment 'Legal name of the company or entity authorized to originate ACH debit entries against the account.' ;
    rdfs:domain ind:DirectDebitMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preNotificationDays rdf:type rdf:Property ;
    rdfs:label 'Pre Notification Days' ;
    rdfs:comment 'Number of days advance notice required before each debit is executed.' ;
    rdfs:domain ind:DirectDebitMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:returnCount rdf:type rdf:Property ;
    rdfs:label 'Return Count' ;
    rdfs:comment 'Total number of ACH returns received for debits initiated under this mandate.' ;
    rdfs:domain ind:DirectDebitMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revocationChannel rdf:type rdf:Property ;
    rdfs:label 'Revocation Channel' ;
    rdfs:comment 'Channel through which the customer revoked the mandate.' ;
    rdfs:domain ind:DirectDebitMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revocationReasonCode rdf:type rdf:Property ;
    rdfs:label 'Revocation Reason Code' ;
    rdfs:comment 'Coded reason for mandate revocation.' ;
    rdfs:domain ind:DirectDebitMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secCode rdf:type rdf:Property ;
    rdfs:label 'Sec Code' ;
    rdfs:comment 'NACHA Standard Entry Class code indicating the type of ACH transaction authorized (PPD=Prearranged Payment and Deposit, CCD=Corporate Credit or Debit, WEB=Internet-Initiated, TEL=Telephone-Initiated). [ENUM-REF-CANDIDATE: PPD|CCD|WEB|TEL|POP|ARC|BOC|RCK — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DirectDebitMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatureDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Signature Document Reference' ;
    rdfs:comment 'Reference identifier to the stored authorization document or signature image.' ;
    rdfs:domain ind:DirectDebitMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatureOnFileFlag rdf:type rdf:Property ;
    rdfs:label 'Signature On File Flag' ;
    rdfs:comment 'Indicates whether a physical or digital signature authorizing the mandate is retained on file.' ;
    rdfs:domain ind:DirectDebitMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orderId rdf:type rdf:Property ;
    rdfs:label 'Order Id' ;
    rdfs:comment 'Unique system-generated identifier for the trade order. Primary key for the order entity. Serves as the single source of truth for order identity across all capital markets systems.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:originatingInteractionId rdf:type rdf:Property ;
    rdfs:label 'Originating Interaction Id' ;
    rdfs:comment 'Foreign key linking to channel.interaction. Business justification: MiFID II suitability and appropriateness obligations require documenting the client interaction (branch, contact center, or digital) that led to a trade order. Linking order to the originating interac' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Interaction .

ind:parentOrderId rdf:type rdf:Property ;
    rdfs:label 'Parent Order Id' ;
    rdfs:comment 'Reference to the parent order in hierarchical order structures. Used for algorithmic trading and smart order routing where a parent order is split into multiple child orders for execution. Null for top-level orders.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:averageExecutionPrice rdf:type rdf:Property ;
    rdfs:label 'Average Execution Price' ;
    rdfs:comment 'Volume-weighted average price at which the order was executed. For partially filled orders, average of fills to date. Used for P&L calculation, transaction cost analysis, and client reporting. Expressed in order currency per unit.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacity rdf:type rdf:Property ;
    rdfs:label 'Capacity' ;
    rdfs:comment 'Capacity in which the firm is acting for the order. Principal means trading for own account. Agency means acting as broker for client. Riskless principal means simultaneous offsetting trades. Required for regulatory reporting and best execution analysis.' ;
    rdfs:domain ind:Trade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionAmount rdf:type rdf:Property ;
    rdfs:label 'Commission Amount' ;
    rdfs:comment 'Total commission charged for order execution. Includes broker fees, exchange fees, and clearing fees. Expressed in order currency. Used for revenue recognition, client billing, and transaction cost analysis.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:entryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Entry Timestamp' ;
    rdfs:comment 'Precise date and time when the order was entered into the trading system. Recorded in UTC with microsecond precision. Critical for transaction cost analysis, market abuse surveillance, and regulatory reporting under MiFID II clock synchronization requirements.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:executionStrategy rdf:type rdf:Property ;
    rdfs:label 'Execution Strategy' ;
    rdfs:comment 'Name or identifier of the algorithmic execution strategy applied to the order. Examples include VWAP, TWAP, implementation shortfall, liquidity-seeking, dark pool aggregation. Null for manual execution. Used for strategy performance analysis and best execution compliance.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filledQuantity rdf:type rdf:Property ;
    rdfs:label 'Filled Quantity' ;
    rdfs:comment 'Cumulative quantity executed to date. Updated as partial fills occur. When filled_quantity equals quantity, order status transitions to filled. Used to calculate remaining open quantity and order completion percentage.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:instruction rdf:type rdf:Property ;
    rdfs:label 'Instruction' ;
    rdfs:comment 'Free-text field for special handling instructions or trader notes. May include client preferences, execution constraints, or operational notes. Not used for automated processing but valuable for audit trail and client service.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAlgorithmic rdf:type rdf:Property ;
    rdfs:label 'Is Algorithmic' ;
    rdfs:comment 'Indicates whether the order was generated or executed by an algorithmic trading system. True for algo orders, false for manual orders. Required for MiFID II algorithmic trading transparency and risk control reporting.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDiscretionary rdf:type rdf:Property ;
    rdfs:label 'Is Discretionary' ;
    rdfs:comment 'Indicates whether the order was placed under discretionary authority where the firm has latitude in execution timing and price. True for discretionary orders, false for non-discretionary. Impacts regulatory reporting and best execution obligations.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastUpdateTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Update Timestamp' ;
    rdfs:comment 'Date and time of the most recent modification to the order record. Updated on status changes, partial fills, amendments, or cancellations. Used for audit trail and change tracking.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:limitPrice rdf:type rdf:Property ;
    rdfs:label 'Limit Price' ;
    rdfs:comment 'Maximum price for buy orders or minimum price for sell orders. Only applicable for limit and stop-limit order types. Null for market orders. Expressed in currency per unit of the security.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderNumber rdf:type rdf:Property ;
    rdfs:label 'Order Number' ;
    rdfs:comment 'Human-readable business identifier for the order. Externally visible order reference used in confirmations, reports, and client communications. May follow desk-specific or system-specific numbering conventions.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantity rdf:type rdf:Property ;
    rdfs:label 'Quantity' ;
    rdfs:comment 'Total quantity of the security ordered. For equities, typically number of shares. For bonds, face value amount. For FX, base currency amount. For derivatives, number of contracts. Unit of measure depends on asset class and instrument type.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryTradeFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Trade Flag' ;
    rdfs:comment 'Indicator for special regulatory treatment or reporting requirements. Examples include short sale indicator, large in scale (LIS), pre-trade transparency waiver, algorithmic trading flag. Used for regulatory reporting to FINRA, SEC, ESMA.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionReason rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason' ;
    rdfs:comment 'Explanation for why the order was rejected. Includes system validations (insufficient margin, invalid security), risk limit breaches, compliance blocks, or venue rejections. Null for non-rejected orders. Used for operational issue resolution and client communication.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:side rdf:type rdf:Property ;
    rdfs:label 'Side' ;
    rdfs:comment 'Direction of the trade order. Buy increases position, sell decreases position. Short sell creates negative position. Buy to cover closes short position. Critical for position management and P&L calculation.' ;
    rdfs:domain ind:Trade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stopPrice rdf:type rdf:Property ;
    rdfs:label 'Stop Price' ;
    rdfs:comment 'Trigger price for stop and stop-limit orders. Order becomes active when market price reaches this level. Null for market and limit orders. Used for risk management and automated trading strategies.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:timeInForce rdf:type rdf:Property ;
    rdfs:label 'Time In Force' ;
    rdfs:comment 'Duration for which the order remains active. Day orders expire at market close. GTC (Good Till Cancelled) remains active until filled or cancelled. IOC (Immediate or Cancel) executes immediately or cancels. FOK (Fill or Kill) must fill completely or cancel. GTD (Good Till Date) expires on specified date.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brokerId rdf:type rdf:Property ;
    rdfs:label 'Broker Id' ;
    rdfs:comment 'FK to trade.broker' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Broker .

ind:redemptionId rdf:type rdf:Property ;
    rdfs:label 'Redemption Id' ;
    rdfs:comment 'Foreign key linking to asset.redemption. Business justification: When a fund redemption is executed (units redeemed at dealing NAV), the trade execution record corresponds to the redemption record. Fund administrators reconcile executions to redemptions for proceed' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Redemption .

ind:subscriptionId rdf:type rdf:Property ;
    rdfs:label 'Subscription Id' ;
    rdfs:comment 'Foreign key linking to asset.subscription. Business justification: When a fund subscription is executed (units allotted at dealing NAV), the trade execution record corresponds to the subscription record. Fund transfer agents reconcile executions to subscriptions for ' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Subscription .

ind:bestExecutionVenueRank rdf:type rdf:Property ;
    rdfs:label 'Best Execution Venue Rank' ;
    rdfs:comment 'Rank of this execution venue in the firms best-execution venue selection process. Used for MiFID II RTS 27 and SEC Rule 606 best-execution reporting.' ;
    rdfs:domain ind:Execution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clearingFee rdf:type rdf:Property ;
    rdfs:label 'Clearing Fee' ;
    rdfs:comment 'Fee charged by the clearinghouse for clearing and settlement of this execution. Denominated in execution_currency.' ;
    rdfs:domain ind:Execution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exchangeFee rdf:type rdf:Property ;
    rdfs:label 'Exchange Fee' ;
    rdfs:comment 'Fee charged by the trading venue or exchange for this execution. Denominated in execution_currency.' ;
    rdfs:domain ind:Execution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:executedQuantity rdf:type rdf:Property ;
    rdfs:label 'Executed Quantity' ;
    rdfs:comment 'The number of units (shares, contracts, bonds, etc.) filled in this execution. For partial fills, this is less than the order quantity.' ;
    rdfs:domain ind:Execution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:executionStatus rdf:type rdf:Property ;
    rdfs:label 'Execution Status' ;
    rdfs:comment 'Current lifecycle status of the execution record. Tracks progression from fill through settlement.' ;
    rdfs:domain ind:Execution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionType rdf:type rdf:Property ;
    rdfs:label 'Execution Type' ;
    rdfs:comment 'Classification of the execution method. Indicates whether this is a full fill, partial fill, block trade, program trade, algorithmic execution, or manual execution.' ;
    rdfs:domain ind:Execution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossTradeValue rdf:type rdf:Property ;
    rdfs:label 'Gross Trade Value' ;
    rdfs:comment 'Total value of the execution before commissions and fees, calculated as executed_quantity × execution_price. Denominated in execution_currency.' ;
    rdfs:domain ind:Execution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:liquidityIndicator rdf:type rdf:Property ;
    rdfs:label 'Liquidity Indicator' ;
    rdfs:comment 'Indicates whether this execution added liquidity to the market (maker), removed liquidity (taker), or was routed. Affects exchange fee rebates and best-execution analysis.' ;
    rdfs:domain ind:Execution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketMicrostructureIndicator rdf:type rdf:Property ;
    rdfs:label 'Market Microstructure Indicator' ;
    rdfs:comment 'Classification of the market microstructure where the execution occurred: lit exchange, dark pool, systematic internaliser, over-the-counter (OTC), or request-for-quote (RFQ). Required for MiFID II best-execution reporting.' ;
    rdfs:domain ind:Execution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netTradeValue rdf:type rdf:Property ;
    rdfs:label 'Net Trade Value' ;
    rdfs:comment 'Total value of the execution after all commissions and fees. Calculated as gross_trade_value ± commission_amount ± exchange_fee ± clearing_fee. Denominated in execution_currency.' ;
    rdfs:domain ind:Execution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:price rdf:type rdf:Property ;
    rdfs:label 'Price' ;
    rdfs:comment 'The price per unit at which this execution was filled. Used to calculate gross trade value and for Mark-to-Market (MTM) valuation.' ;
    rdfs:domain ind:Trade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tradeReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Trade Reporting Flag' ;
    rdfs:comment 'Indicates whether this execution has been reported to the relevant trade reporting facility (e.g., FINRA TRACE, EMIR trade repository). True if reported, False if pending.' ;
    rdfs:domain ind:Execution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tradeReportingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Trade Reporting Timestamp' ;
    rdfs:comment 'Date and time when this execution was reported to the trade reporting facility. Null if not yet reported. Used to verify compliance with T+1 reporting deadlines.' ;
    rdfs:domain ind:Execution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:tradeSide rdf:type rdf:Property ;
    rdfs:label 'Trade Side' ;
    rdfs:comment 'Indicates whether this execution is a buy or sell from the perspective of the reporting institution.' ;
    rdfs:domain ind:Execution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:venue rdf:type rdf:Property ;
    rdfs:label 'Venue' ;
    rdfs:comment 'Name or code of the trading venue where the execution occurred (e.g., NYSE, NASDAQ, LSE, OTC, ECN). Critical for best-execution reporting under MiFID II and SEC Rule 606.' ;
    rdfs:domain ind:Execution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionVenueBicDirectoryId rdf:type rdf:Property ;
    rdfs:label 'Execution Venue Bic Directory Id' ;
    rdfs:comment 'Foreign key linking to reference.bic_directory. Business justification: EMIR and MiFID II require the execution venue to be identified by BIC/MIC code in trade reports. execution_venue is a plain string denormalization; linking to bic_directory provides the authoritative ' ;
    rdfs:domain ind:Capture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BicDirectory .

ind:tradeCurrencyId rdf:type rdf:Property ;
    rdfs:label 'Trade Currency Id' ;
    rdfs:comment 'Foreign key linking to reference.currency. Business justification: Trade currency validation essential for booking, valuation, regulatory reporting, and FX risk calculation. Reference currency master provides ISO codes, central bank data, and convertibility restricti' ;
    rdfs:domain ind:Capture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:tradeProductTypeId rdf:type rdf:Property ;
    rdfs:label 'Trade Product Type Id' ;
    rdfs:comment 'Foreign key linking to reference.product_type. Business justification: Trade product type classification drives booking model, risk categorization, regulatory capital treatment, and P&L attribution. Reference product type master provides Basel, IFRS9, and regulatory repo' ;
    rdfs:domain ind:Capture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductType .

ind:amendedBy rdf:type rdf:Property ;
    rdfs:label 'Amended By' ;
    rdfs:comment 'The user ID of the person who submitted the amendment. Part of the audit trail for trade lifecycle changes and SOX compliance.' ;
    rdfs:domain ind:Capture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentReason rdf:type rdf:Property ;
    rdfs:label 'Amendment Reason' ;
    rdfs:comment 'Free-text explanation of why the trade was amended. Provides business context for audit trail and regulatory inquiries. Required for versions greater than 1.' ;
    rdfs:domain ind:Trade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Amendment Timestamp' ;
    rdfs:comment 'Precise timestamp when the amendment was applied to the trade record. Used for audit trail reconstruction and regulatory reporting of lifecycle events.' ;
    rdfs:domain ind:Capture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:amendmentType rdf:type rdf:Property ;
    rdfs:label 'Amendment Type' ;
    rdfs:comment 'Classification of the lifecycle event that created this version. Economic amendments change trade economics; administrative corrections fix errors; novations transfer to new counterparty; compressions reduce notional.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookingStatus rdf:type rdf:Property ;
    rdfs:label 'Booking Status' ;
    rdfs:comment 'The current lifecycle status of the trade booking record. Tracks progression from initial capture through confirmation, amendment, settlement, or cancellation.' ;
    rdfs:domain ind:Capture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ccpName rdf:type rdf:Property ;
    rdfs:label 'Ccp Name' ;
    rdfs:comment 'The name of the central counterparty clearing house if the trade is centrally cleared. Examples include LCH, CME, Eurex Clearing. Null for bilateral trades.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeAmount rdf:type rdf:Property ;
    rdfs:label 'Trade Amount' ;
    rdfs:comment 'The total monetary value of the trade in trade currency. For cash instruments, equals notional × price. For derivatives, may represent premium or initial margin.' ;
    rdfs:domain ind:Capture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tradeDate rdf:type rdf:Property ;
    rdfs:label 'Trade Date' ;
    rdfs:comment 'The date on which the trade was executed and agreed between counterparties. Critical for settlement cycle calculation and regulatory reporting.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tradeReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Trade Reference Number' ;
    rdfs:comment 'Internal business identifier for the trade used across front office, middle office, and back office systems. Human-readable reference for trade inquiries and reconciliation.' ;
    rdfs:domain ind:Capture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Trade Timestamp' ;
    rdfs:comment 'Precise timestamp when the trade was executed, including milliseconds. Required for MiFID II transaction reporting and best execution analysis.' ;
    rdfs:domain ind:Capture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:tradeVersion rdf:type rdf:Property ;
    rdfs:label 'Trade Version' ;
    rdfs:comment 'Sequential version number incremented with each amendment or lifecycle event. Version 1 represents the original trade; subsequent versions capture economic amendments, administrative corrections, novations, or compressions.' ;
    rdfs:domain ind:Capture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:usi rdf:type rdf:Property ;
    rdfs:label 'Usi' ;
    rdfs:comment 'US-specific unique identifier for swap transactions required under Dodd-Frank Act reporting rules. Used for CFTC and SEC swap data repository reporting.' ;
    rdfs:domain ind:Capture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uti rdf:type rdf:Property ;
    rdfs:label 'Uti' ;
    rdfs:comment 'Globally unique identifier for OTC derivative transactions as required by EMIR and Dodd-Frank regulatory reporting. Assigned at trade inception and maintained through lifecycle events.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interestRateRiskPositionId rdf:type rdf:Property ;
    rdfs:label 'Interest Rate Risk Position Id' ;
    rdfs:comment 'Foreign key linking to treasury.interest_rate_risk_position. Business justification: IRRBB framework requires aggregating individual trade positions into interest rate risk positions. Linking trade_position to interest_rate_risk_position supports EVE/NII sensitivity reporting, ALCO re' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InterestRateRiskPosition .

ind:priceId rdf:type rdf:Property ;
    rdfs:label 'Price Id' ;
    rdfs:comment 'Foreign key linking to security.price. Business justification: Trade positions are revalued using security prices for daily P&L, risk reporting, and regulatory capital (FRTB). Linking to the source price record supports valuation audit trails and IPV. trade_posit' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Price .

ind:accruedIncome rdf:type rdf:Property ;
    rdfs:label 'Accrued Income' ;
    rdfs:comment 'The accrued interest, dividends, or coupon income earned but not yet received on the position.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageCost rdf:type rdf:Property ;
    rdfs:label 'Average Cost' ;
    rdfs:comment 'The weighted average cost per unit at which the position was acquired. Used for realized P&L calculation.' ;
    rdfs:domain ind:TradePosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Base Currency Code' ;
    rdfs:comment 'The three-letter ISO currency code of the reporting entity\'s base currency for P&L and risk reporting.' ;
    rdfs:domain ind:TradePosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseCurrencyMarketValue rdf:type rdf:Property ;
    rdfs:label 'Base Currency Market Value' ;
    rdfs:comment 'The market value of the position converted to the base currency using the FX rate.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseCurrencyUnrealizedPnl rdf:type rdf:Property ;
    rdfs:label 'Base Currency Unrealized Pnl' ;
    rdfs:comment 'The unrealized P&L converted to the base currency for consolidated reporting.' ;
    rdfs:domain ind:TradePosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:breakFlag rdf:type rdf:Property ;
    rdfs:label 'Break Flag' ;
    rdfs:comment 'Indicates whether this position has a reconciliation break or discrepancy that requires investigation.' ;
    rdfs:domain ind:TradePosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:breakReason rdf:type rdf:Property ;
    rdfs:label 'Break Reason' ;
    rdfs:comment 'Description of the reason for the position break or reconciliation discrepancy, if applicable.' ;
    rdfs:domain ind:TradePosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cleanPrice rdf:type rdf:Property ;
    rdfs:label 'Clean Price' ;
    rdfs:comment 'The price of the instrument excluding accrued interest. Used for fixed income securities.' ;
    rdfs:domain ind:Trade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dirtyPrice rdf:type rdf:Property ;
    rdfs:label 'Dirty Price' ;
    rdfs:comment 'The price of the instrument including accrued interest. Used for fixed income securities.' ;
    rdfs:domain ind:Trade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastRevaluationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Revaluation Timestamp' ;
    rdfs:comment 'The timestamp of the most recent MTM revaluation cycle that updated this position\'s market value and P&L.' ;
    rdfs:domain ind:TradePosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:marketPrice rdf:type rdf:Property ;
    rdfs:label 'Market Price' ;
    rdfs:comment 'The current market price of the instrument used for MTM valuation. Updated during each revaluation cycle.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketValue rdf:type rdf:Property ;
    rdfs:label 'Market Value' ;
    rdfs:comment 'The total market value of the position calculated as quantity multiplied by market price. Represents the current MTM value.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:positionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Position Timestamp' ;
    rdfs:comment 'The precise timestamp when this position record was captured or updated. Used for intraday position keeping and real-time risk monitoring.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:positionType rdf:type rdf:Property ;
    rdfs:label 'Position Type' ;
    rdfs:comment 'Indicates whether the position is long (bought), short (sold), or flat (no position).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityUnit rdf:type rdf:Property ;
    rdfs:label 'Quantity Unit' ;
    rdfs:comment 'The unit of measure for the position quantity (e.g., shares for equities, contracts for futures, notional for swaps).' ;
    rdfs:domain ind:TradePosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:realizedPnl rdf:type rdf:Property ;
    rdfs:label 'Realized Pnl' ;
    rdfs:comment 'The cumulative realized profit or loss from closed or partially closed positions during the current period.' ;
    rdfs:domain ind:TradePosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rho rdf:type rdf:Property ;
    rdfs:label 'Rho' ;
    rdfs:comment 'The sensitivity of the position value to changes in the risk-free interest rate. Greek for interest rate sensitivity.' ;
    rdfs:domain ind:TradePosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:theta rdf:type rdf:Property ;
    rdfs:label 'Theta' ;
    rdfs:comment 'The rate of change of the position value with respect to the passage of time (time decay). Key Greek for options positions.' ;
    rdfs:domain ind:TradePosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unrealizedPnl rdf:type rdf:Property ;
    rdfs:label 'Unrealized Pnl' ;
    rdfs:comment 'The unrealized profit or loss on the position, calculated as the difference between market value and cost basis. Updated with each MTM revaluation.' ;
    rdfs:domain ind:Trade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valuationMethod rdf:type rdf:Property ;
    rdfs:label 'Valuation Method' ;
    rdfs:comment 'The method used to determine the market price for MTM valuation (e.g., market observable price, model-derived price, vendor pricing).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationSource rdf:type rdf:Property ;
    rdfs:label 'Valuation Source' ;
    rdfs:comment 'The source system or vendor providing the market price used for MTM valuation (e.g., Bloomberg, Reuters, internal model).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varAmount rdf:type rdf:Property ;
    rdfs:label 'Var Amount' ;
    rdfs:comment 'The estimated maximum loss for this position over a specified time horizon at a given confidence level. Used for market risk management.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mtmValuationId rdf:type rdf:Property ;
    rdfs:label 'Mtm Valuation Id' ;
    rdfs:comment 'Unique identifier for the mark-to-market valuation record.' ;
    rdfs:domain ind:MtmValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fundHoldingId rdf:type rdf:Property ;
    rdfs:label 'Fund Holding Id' ;
    rdfs:comment 'Foreign key linking to asset.fund_holding. Business justification: MTM valuations are performed on specific fund holdings. The valuation record must reference the holding being valued for IFRS 13 / ASC 820 fair value hierarchy reporting, independent price verificatio' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FundHolding .

ind:valuationCurrencyId rdf:type rdf:Property ;
    rdfs:label 'Valuation Currency Id' ;
    rdfs:comment 'Foreign key linking to reference.currency. Business justification: Valuation currency validation required for fair value hierarchy compliance, IFRS reporting, and FX revaluation. Reference currency master provides rounding rules, minor units, and regulatory reporting' ;
    rdfs:domain ind:MtmValuation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:correlationInput rdf:type rdf:Property ;
    rdfs:label 'Correlation Input' ;
    rdfs:comment 'The correlation parameter used in multi-asset or basket derivative valuations, expressed as a decimal between -1 and 1.' ;
    rdfs:domain ind:MtmValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cvaAdjustment rdf:type rdf:Property ;
    rdfs:label 'Cva Adjustment' ;
    rdfs:comment 'Credit Valuation Adjustment reflecting the market value of counterparty credit risk, reducing the fair value to account for the possibility of counterparty default.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dvaAdjustment rdf:type rdf:Property ;
    rdfs:label 'Dva Adjustment' ;
    rdfs:comment 'Debit Valuation Adjustment reflecting the market value of own credit risk, adjusting the fair value to account for the entity\'s own default risk.' ;
    rdfs:domain ind:MtmValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fairValue rdf:type rdf:Property ;
    rdfs:label 'Fair Value' ;
    rdfs:comment 'The mark-to-market fair value of the position or trade at the valuation date and time, representing the price that would be received to sell an asset or paid to transfer a liability in an orderly transaction.' ;
    rdfs:domain ind:MtmValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fairValueHierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Fair Value Hierarchy Level' ;
    rdfs:comment 'IFRS 9 and FASB ASC 820 fair value hierarchy classification: Level 1 (quoted prices in active markets), Level 2 (observable inputs other than quoted prices), Level 3 (unobservable inputs).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fvaAdjustment rdf:type rdf:Property ;
    rdfs:label 'Fva Adjustment' ;
    rdfs:comment 'Funding Valuation Adjustment reflecting the cost of funding uncollateralized derivatives, adjusting the fair value for funding costs.' ;
    rdfs:domain ind:MtmValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fxRateSource rdf:type rdf:Property ;
    rdfs:label 'Fx Rate Source' ;
    rdfs:comment 'The source of the FX rate used in the valuation (e.g., Bloomberg, Reuters, ECB, internal treasury rate).' ;
    rdfs:domain ind:MtmValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:independentPriceVerificationFlag rdf:type rdf:Property ;
    rdfs:label 'Independent Price Verification Flag' ;
    rdfs:comment 'Boolean flag indicating whether the valuation has undergone independent price verification by a separate control function, as required by regulatory standards.' ;
    rdfs:domain ind:MtmValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ipvVariance rdf:type rdf:Property ;
    rdfs:label 'Ipv Variance' ;
    rdfs:comment 'The variance between the trading desk valuation and the independent price verification valuation, used for control and escalation purposes.' ;
    rdfs:domain ind:MtmValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:previousFairValue rdf:type rdf:Property ;
    rdfs:label 'Previous Fair Value' ;
    rdfs:comment 'The fair value from the previous valuation date, used to calculate daily P&L movements.' ;
    rdfs:domain ind:MtmValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricingSource rdf:type rdf:Property ;
    rdfs:label 'Pricing Source' ;
    rdfs:comment 'The primary source of pricing data used for the valuation: Bloomberg, Reuters, ICE Data Services, Markit, internal model, broker quote, exchange, or vendor composite. [ENUM-REF-CANDIDATE: bloomberg|reuters|ice|markit|internal_model|broker_quote|exchange|vendor_composite — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalValuationAdjustments rdf:type rdf:Property ;
    rdfs:label 'Total Valuation Adjustments' ;
    rdfs:comment 'The sum of all valuation adjustments (CVA, DVA, FVA, and other XVA components) applied to the fair value.' ;
    rdfs:domain ind:MtmValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valuationMethodology rdf:type rdf:Property ;
    rdfs:label 'Valuation Methodology' ;
    rdfs:comment 'The methodology used to determine the fair value: mark-to-market (observable market prices), mark-to-model (internal valuation models), net asset value (NAV for funds), consensus pricing, vendor pricing, or internal model.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationRemarks rdf:type rdf:Property ;
    rdfs:label 'Valuation Remarks' ;
    rdfs:comment 'Free-text field for additional notes, explanations, or exceptions related to the valuation, supporting audit trails and control documentation.' ;
    rdfs:domain ind:MtmValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Valuation Source System' ;
    rdfs:comment 'The name of the source system that generated the valuation (e.g., Murex, Calypso, Bloomberg MARS, internal risk engine).' ;
    rdfs:domain ind:MtmValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Valuation Timestamp' ;
    rdfs:comment 'The precise date and time when the valuation was performed, supporting intraday revaluation and audit trails.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:volatilityInput rdf:type rdf:Property ;
    rdfs:label 'Volatility Input' ;
    rdfs:comment 'The volatility parameter used in option pricing models and derivative valuations, expressed as a decimal (e.g., 0.25 for 25% volatility).' ;
    rdfs:domain ind:MtmValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yieldRate rdf:type rdf:Property ;
    rdfs:label 'Yield Rate' ;
    rdfs:comment 'The yield to maturity or effective yield rate used in the valuation calculation for fixed income instruments.' ;
    rdfs:domain ind:MtmValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bicDirectoryId rdf:type rdf:Property ;
    rdfs:label 'Bic Directory Id' ;
    rdfs:comment 'Foreign key linking to reference.bic_directory. Business justification: Settlement instructions require BIC validation for SWIFT message routing, correspondent bank connectivity, and securities settlement. Reference BIC directory provides institution details, service prof' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BicDirectory .

ind:cashDepositAccountId rdf:type rdf:Property ;
    rdfs:label 'Cash Deposit Account Id' ;
    rdfs:comment 'Foreign key linking to account.deposit_account. Business justification: Trade settlement requires a specific deposit account for the cash leg — debiting/crediting upon settlement. Settlement desks must identify which deposit account funds each settlement instruction. Core' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DepositAccount .

ind:treasuryNostroAccountId rdf:type rdf:Property ;
    rdfs:label 'Treasury Nostro Account Id' ;
    rdfs:comment 'Foreign key linking to treasury.nostro_account. Business justification: Settlement instructions specify nostro accounts for cash settlement of trades. Required for trade settlement cash management, nostro liquidity forecasting, intraday liquidity monitoring, and nostro re' ;
    rdfs:domain ind:SettlementInstruction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NostroAccount .

ind:actualSettlementDate rdf:type rdf:Property ;
    rdfs:label 'Actual Settlement Date' ;
    rdfs:comment 'Actual date on which the settlement was completed. Null if settlement has not yet occurred.' ;
    rdfs:domain ind:SettlementInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:affirmationStatus rdf:type rdf:Property ;
    rdfs:label 'Affirmation Status' ;
    rdfs:comment 'Status indicating whether the institutional investor has affirmed the settlement details.' ;
    rdfs:domain ind:Trade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affirmationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Affirmation Timestamp' ;
    rdfs:comment 'Date and time when the settlement instruction was affirmed by the institutional investor.' ;
    rdfs:domain ind:Trade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:buyInExecutionDate rdf:type rdf:Property ;
    rdfs:label 'Buy In Execution Date' ;
    rdfs:comment 'Date on which the mandatory buy-in was executed to cover the failed settlement.' ;
    rdfs:domain ind:SettlementInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:buyInFlag rdf:type rdf:Property ;
    rdfs:label 'Buy In Flag' ;
    rdfs:comment 'Boolean indicator of whether a mandatory buy-in process has been initiated under CSDR settlement discipline regime.' ;
    rdfs:domain ind:SettlementInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:buyInStatus rdf:type rdf:Property ;
    rdfs:label 'Buy In Status' ;
    rdfs:comment 'Current status of the mandatory buy-in process if initiated.' ;
    rdfs:domain ind:SettlementInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cashCorrespondentBic rdf:type rdf:Property ;
    rdfs:label 'Cash Correspondent Bic' ;
    rdfs:comment 'SWIFT BIC of the cash correspondent bank handling the cash leg of the settlement.' ;
    rdfs:domain ind:SettlementInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:csdName rdf:type rdf:Property ;
    rdfs:label 'Csd Name' ;
    rdfs:comment 'Name of the Central Securities Depository or International Central Securities Depository handling the settlement.' ;
    rdfs:domain ind:SettlementInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:csdParticipantCode rdf:type rdf:Property ;
    rdfs:label 'Csd Participant Code' ;
    rdfs:comment 'Participant code identifying the entity within the CSD or ICSD system (e.g., DTC participant number, Euroclear participant ID).' ;
    rdfs:domain ind:SettlementInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:csdrPenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Csdr Penalty Amount' ;
    rdfs:comment 'Total cash penalty charges incurred under CSDR mandatory buy-in and penalty regime for settlement fails.' ;
    rdfs:domain ind:SettlementInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:csdrPenaltyCurrency rdf:type rdf:Property ;
    rdfs:label 'Csdr Penalty Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code in which CSDR penalties are denominated.' ;
    rdfs:domain ind:SettlementInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failDate rdf:type rdf:Property ;
    rdfs:label 'Fail Date' ;
    rdfs:comment 'Date on which the settlement instruction first failed to settle.' ;
    rdfs:domain ind:SettlementInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:failDurationDays rdf:type rdf:Property ;
    rdfs:label 'Fail Duration Days' ;
    rdfs:comment 'Number of business days the settlement instruction has been in a failed state.' ;
    rdfs:domain ind:SettlementInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:failFlag rdf:type rdf:Property ;
    rdfs:label 'Fail Flag' ;
    rdfs:comment 'Boolean indicator of whether this settlement instruction has failed to settle on the intended settlement date.' ;
    rdfs:domain ind:SettlementInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:failReasonCode rdf:type rdf:Property ;
    rdfs:label 'Fail Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for settlement failure: counterparty default (CPTY), insufficient securities (SECU), cash shortfall (CASH), matching discrepancy (MTCH), technical issue (TECH), or other (OTHR).' ;
    rdfs:domain ind:SettlementInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Fail Reason Description' ;
    rdfs:comment 'Detailed textual description of the reason for settlement failure.' ;
    rdfs:domain ind:SettlementInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instructionCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Instruction Created Timestamp' ;
    rdfs:comment 'Date and time when the settlement instruction record was first created in the system.' ;
    rdfs:domain ind:SettlementInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:instructionModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Instruction Modified Timestamp' ;
    rdfs:comment 'Date and time when the settlement instruction record was last modified.' ;
    rdfs:domain ind:SettlementInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:instructionReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Instruction Reference Number' ;
    rdfs:comment 'Externally visible unique reference number for this settlement instruction, used in SWIFT messaging and counterparty communication.' ;
    rdfs:domain ind:SettlementInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intendedSettlementDate rdf:type rdf:Property ;
    rdfs:label 'Intended Settlement Date' ;
    rdfs:comment 'Original intended settlement date before any amendments or fails occurred.' ;
    rdfs:domain ind:SettlementInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:matchingStatus rdf:type rdf:Property ;
    rdfs:label 'Matching Status' ;
    rdfs:comment 'Status indicating whether the settlement instruction has been matched with the counterparty instruction.' ;
    rdfs:domain ind:SettlementInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Matching Timestamp' ;
    rdfs:comment 'Date and time when the settlement instruction was successfully matched with the counterparty instruction.' ;
    rdfs:domain ind:SettlementInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:nostroAccountIban rdf:type rdf:Property ;
    rdfs:label 'Nostro Account Iban' ;
    rdfs:comment 'IBAN of the nostro account (our account held at another bank) used for cash settlement.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityQuantity rdf:type rdf:Property ;
    rdfs:label 'Security Quantity' ;
    rdfs:comment 'Quantity of securities to be delivered or received in this settlement instruction.' ;
    rdfs:domain ind:SettlementInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementAgentBic rdf:type rdf:Property ;
    rdfs:label 'Settlement Agent Bic' ;
    rdfs:comment 'SWIFT BIC of the settlement agent or intermediary bank facilitating the settlement.' ;
    rdfs:domain ind:Trade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementType rdf:type rdf:Property ;
    rdfs:label 'Settlement Type' ;
    rdfs:comment 'Type of settlement mechanism: Delivery Versus Payment (DVP), Receive Versus Payment (RVP), Free Of Payment (FOP), or Payment Free of Payment (PFP).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmationId rdf:type rdf:Property ;
    rdfs:label 'Confirmation Id' ;
    rdfs:comment 'Unique identifier for the trade confirmation record. Primary key for the trade confirmation entity.' ;
    rdfs:domain ind:Confirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocationId rdf:type rdf:Property ;
    rdfs:label 'Allocation Id' ;
    rdfs:comment 'Foreign key linking to trade.allocation. Business justification: Confirmations can be generated per allocation for allocated trades (each allocated account may receive a separate confirmation). This links confirmations to specific allocations for affirmation and ma' ;
    rdfs:domain ind:Trade ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Allocation .

ind:notionalCurrencyId rdf:type rdf:Property ;
    rdfs:label 'Notional Currency Id' ;
    rdfs:comment 'Foreign key linking to reference.currency. Business justification: Confirmation currency must validate for counterparty matching, discrepancy resolution, and regulatory reporting. Reference currency master provides ISO codes and rounding rules for confirmation tolera' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:confirmationMethod rdf:type rdf:Property ;
    rdfs:label 'Confirmation Method' ;
    rdfs:comment 'Method by which the trade confirmation was exchanged with the counterparty. Electronic methods include DTCC, MarkitWire, SWIFT MT3xx messages; manual methods include paper, email, fax. [ENUM-REF-CANDIDATE: electronic|paper|swift|dtcc|markit_wire|email|fax — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Confirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Confirmation Number' ;
    rdfs:comment 'Externally-known unique confirmation reference number exchanged with counterparties. Used for reconciliation and dispute resolution.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmationStatus rdf:type rdf:Property ;
    rdfs:label 'Confirmation Status' ;
    rdfs:comment 'Current lifecycle status of the trade confirmation. Tracks progression from initial unconfirmed state through final confirmed or disputed resolution. [ENUM-REF-CANDIDATE: unconfirmed|confirmed|disputed|cancelled|pending|matched|mismatched — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Confirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Confirmation Timestamp' ;
    rdfs:comment 'Date and time when the trade confirmation was successfully matched and confirmed by both parties. Critical for regulatory timely confirmation requirements under Dodd-Frank and EMIR.' ;
    rdfs:domain ind:Confirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:counterpartyConfirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Counterparty Confirmation Number' ;
    rdfs:comment 'The confirmation reference number assigned by the counterparty to this trade. Used for bilateral reconciliation and matching.' ;
    rdfs:domain ind:Confirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deadline rdf:type rdf:Property ;
    rdfs:label 'Deadline' ;
    rdfs:comment 'Regulatory deadline by which the trade must be confirmed to comply with Dodd-Frank and EMIR timely confirmation requirements. Varies by asset class and trade type.' ;
    rdfs:domain ind:Confirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:discrepancyDescription rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Description' ;
    rdfs:comment 'Detailed description of any economic terms discrepancies identified between internal trade records and counterparty confirmation. Includes field-level differences in price, quantity, dates, or other material terms.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discrepancyFlag rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Flag' ;
    rdfs:comment 'Indicates whether any economic terms discrepancies were identified during the confirmation matching process. True if discrepancies exist requiring resolution.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discrepancyResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Resolution Date' ;
    rdfs:comment 'The date on which any identified discrepancies were resolved and the confirmation was successfully matched. Null if discrepancies remain outstanding.' ;
    rdfs:domain ind:Confirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dtccConfirmationReference rdf:type rdf:Property ;
    rdfs:label 'Dtcc Confirmation Reference' ;
    rdfs:comment 'Unique confirmation identifier assigned by DTCC for electronically confirmed trades processed through DTCC Deriv/SERV or other DTCC confirmation platforms.' ;
    rdfs:domain ind:Confirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leiReportingEntity rdf:type rdf:Property ;
    rdfs:label 'Lei Reporting Entity' ;
    rdfs:comment '20-character Legal Entity Identifier of the reporting entity (the bank) for regulatory trade reporting purposes.' ;
    rdfs:domain ind:Confirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:markitWireReference rdf:type rdf:Property ;
    rdfs:label 'Markit Wire Reference' ;
    rdfs:comment 'Unique reference number assigned by MarkitWire electronic confirmation platform for OTC derivative confirmations processed through MarkitWire.' ;
    rdfs:domain ind:Confirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchingToleranceBreached rdf:type rdf:Property ;
    rdfs:label 'Matching Tolerance Breached' ;
    rdfs:comment 'Indicates whether the confirmation matching process identified differences that exceeded predefined tolerance thresholds for price, quantity, or other economic terms.' ;
    rdfs:domain ind:Confirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Received Timestamp' ;
    rdfs:comment 'Date and time when the counterparty confirmation was received for matching against internal trade records.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sent Timestamp' ;
    rdfs:comment 'Date and time when the confirmation was initially sent to the counterparty for matching and acknowledgment.' ;
    rdfs:domain ind:Confirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:tradePrice rdf:type rdf:Property ;
    rdfs:label 'Trade Price' ;
    rdfs:comment 'The execution price of the trade as confirmed by both parties. For securities, this is the per-unit price; for derivatives, may represent strike, rate, or spread.' ;
    rdfs:domain ind:Confirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseCurrencyId rdf:type rdf:Property ;
    rdfs:label 'Base Currency Id' ;
    rdfs:comment 'Foreign key linking to reference.currency. Business justification: Trading book base currency drives P&L aggregation, VaR calculation, and FRTB regulatory capital reporting. base_currency is a plain string denormalization; a proper FK to currency ensures referential ' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:parentBookTradingBookId rdf:type rdf:Property ;
    rdfs:label 'Parent Book Trading Book Id' ;
    rdfs:comment 'Identifier of the parent trading book in the book hierarchy. Null if this is a top-level book. Used for hierarchical risk aggregation.' ;
    rdfs:domain ind:TradingBook ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TradingBook .

ind:policyId rdf:type rdf:Property ;
    rdfs:label 'Policy Id' ;
    rdfs:comment 'Foreign key linking to compliance.policy. Business justification: Trading books must operate under specific compliance policies (Volcker Rule, proprietary trading restrictions, market-making exemptions). The governing policy must be traceable from the book for regul' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Policy .

ind:bookCode rdf:type rdf:Property ;
    rdfs:label 'Book Code' ;
    rdfs:comment 'Externally-known unique alphanumeric code identifying the trading book across systems and regulatory reports. Used in trade capture, risk reporting, and P&L attribution.' ;
    rdfs:domain ind:TradingBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookHierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Book Hierarchy Level' ;
    rdfs:comment 'Numeric level in the trading book hierarchy (1 = top level, 2 = sub-book, etc.). Used for roll-up and drill-down reporting.' ;
    rdfs:domain ind:TradingBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bookName rdf:type rdf:Property ;
    rdfs:label 'Book Name' ;
    rdfs:comment 'Human-readable name of the trading book, typically reflecting the desk, asset class, or strategy (e.g., \'USD Rates Desk\', \'Equity Derivatives EMEA\').' ;
    rdfs:domain ind:TradingBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookShortName rdf:type rdf:Property ;
    rdfs:label 'Book Short Name' ;
    rdfs:comment 'Abbreviated name or acronym for the trading book used in operational systems and trader screens.' ;
    rdfs:domain ind:TradingBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookStatus rdf:type rdf:Property ;
    rdfs:label 'Book Status' ;
    rdfs:comment 'Current operational status of the trading book. Only active books can accept new trades.' ;
    rdfs:domain ind:TradingBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:concentrationLimitPct rdf:type rdf:Property ;
    rdfs:label 'Concentration Limit Pct' ;
    rdfs:comment 'Maximum percentage of book exposure that can be concentrated in a single issuer, counterparty, or instrument. Expressed as percentage.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deskName rdf:type rdf:Property ;
    rdfs:label 'Desk Name' ;
    rdfs:comment 'Name of the trading desk or unit responsible for this book. Used for organizational hierarchy and P&L roll-up.' ;
    rdfs:domain ind:TradingBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dv01LimitAmount rdf:type rdf:Property ;
    rdfs:label 'Dv01 Limit Amount' ;
    rdfs:comment 'Maximum DV01 (dollar value of a one basis point move in interest rates) limit for the book, expressed in base currency. Applicable primarily to rates books.' ;
    rdfs:domain ind:TradingBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:imaApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Ima Approval Status' ;
    rdfs:comment 'Regulatory approval status for using Internal Models Approach (IMA) for this book. Only approved books can use IMA for capital calculation.' ;
    rdfs:domain ind:TradingBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isProprietaryTrading rdf:type rdf:Property ;
    rdfs:label 'Is Proprietary Trading' ;
    rdfs:comment 'Boolean flag indicating whether this book engages in proprietary trading (True) or client-facilitation trading (False). Relevant for Volcker Rule compliance.' ;
    rdfs:domain ind:TradingBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastLimitReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Limit Review Date' ;
    rdfs:comment 'Date when risk limits for this book were last reviewed and approved by the Asset-Liability Committee (ALCO) or risk committee.' ;
    rdfs:domain ind:TradingBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:locationCode rdf:type rdf:Property ;
    rdfs:label 'Location Code' ;
    rdfs:comment 'Three-letter code identifying the primary trading location or office for this book (e.g., NYC, LDN, HKG).' ;
    rdfs:domain ind:TradingBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextLimitReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Limit Review Date' ;
    rdfs:comment 'Scheduled date for the next risk limit review for this book.' ;
    rdfs:domain ind:TradingBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notionalLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Notional Limit Amount' ;
    rdfs:comment 'Maximum aggregate notional exposure limit for the book, expressed in base currency. Controls gross position size.' ;
    rdfs:domain ind:Trade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stressLossLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Stress Loss Limit Amount' ;
    rdfs:comment 'Maximum allowable loss under stress scenarios, expressed in base currency. Used for stress testing and CCAR/DFAST compliance.' ;
    rdfs:domain ind:TradingBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tradingStrategy rdf:type rdf:Property ;
    rdfs:label 'Trading Strategy' ;
    rdfs:comment 'Primary trading strategy employed by the book (e.g., market making, proprietary trading, client facilitation). Influences risk appetite and limit framework.' ;
    rdfs:domain ind:TradingBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Var Limit Amount' ;
    rdfs:comment 'Maximum Value at Risk (VaR) limit assigned to this trading book, expressed in base currency. Represents the maximum potential loss at a given confidence level.' ;
    rdfs:domain ind:TradingBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varTimeHorizonDays rdf:type rdf:Property ;
    rdfs:label 'Var Time Horizon Days' ;
    rdfs:comment 'Time horizon in days over which VaR is calculated, typically 1 day or 10 days.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:volckerRuleExemption rdf:type rdf:Property ;
    rdfs:label 'Volcker Rule Exemption' ;
    rdfs:comment 'Applicable Volcker Rule exemption category for this book, if any. Determines permissible trading activities under Dodd-Frank.' ;
    rdfs:domain ind:TradingBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationBlockTradeTradeCaptureId rdf:type rdf:Property ;
    rdfs:label 'Allocation Block Trade Trade Capture Id' ;
    rdfs:comment 'Reference to the parent block trade that is being allocated across multiple accounts or sub-portfolios.' ;
    rdfs:domain ind:Allocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Capture .

ind:allocationCaptureId rdf:type rdf:Property ;
    rdfs:label 'Allocation Capture Id' ;
    rdfs:comment 'Reference to the underlying trade execution record from the trading system.' ;
    rdfs:domain ind:Allocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Capture .

ind:allocationClearingBrokerId rdf:type rdf:Property ;
    rdfs:label 'Allocation Clearing Broker Id' ;
    rdfs:comment 'Reference to the broker responsible for clearing and settlement of this allocation.' ;
    rdfs:domain ind:Allocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Broker .

ind:allocationCustodianPartyId rdf:type rdf:Property ;
    rdfs:label 'Allocation Custodian Party Id' ;
    rdfs:comment 'Reference to the custodian bank holding the securities for the allocated account, used for settlement instruction routing.' ;
    rdfs:domain ind:Allocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:allocationExecutingBrokerId rdf:type rdf:Property ;
    rdfs:label 'Allocation Executing Broker Id' ;
    rdfs:comment 'Reference to the broker who executed the original block trade before allocation.' ;
    rdfs:domain ind:Allocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Broker .

ind:allocationGiveUpBrokerId rdf:type rdf:Property ;
    rdfs:label 'Allocation Give Up Broker Id' ;
    rdfs:comment 'Reference to the broker receiving the give-up allocation in step-out workflows, where execution is transferred to another broker for clearing.' ;
    rdfs:domain ind:Allocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Broker .

ind:allocationPartyId rdf:type rdf:Property ;
    rdfs:label 'Allocation Party Id' ;
    rdfs:comment 'Reference to the institutional client on whose behalf the allocation is made, used in prime brokerage and institutional trading.' ;
    rdfs:domain ind:Allocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:affirmationPlatform rdf:type rdf:Property ;
    rdfs:label 'Affirmation Platform' ;
    rdfs:comment 'The name of the affirmation platform used to confirm the allocation, such as OASYS, ALERT, Omgeo Central Trade Manager (CTM), or Bloomberg AIM.' ;
    rdfs:domain ind:Allocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocatedAmount rdf:type rdf:Property ;
    rdfs:label 'Allocated Amount' ;
    rdfs:comment 'The total notional value of the allocation, calculated as allocated quantity multiplied by allocated price.' ;
    rdfs:domain ind:Allocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocatedPrice rdf:type rdf:Property ;
    rdfs:label 'Allocated Price' ;
    rdfs:comment 'The price at which the allocated quantity is assigned to this account. May be average price or specific fill price depending on allocation method.' ;
    rdfs:domain ind:Allocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocatedQuantity rdf:type rdf:Property ;
    rdfs:label 'Allocated Quantity' ;
    rdfs:comment 'The quantity of the security or instrument allocated to this account or fund from the block trade.' ;
    rdfs:domain ind:Allocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationMethod rdf:type rdf:Property ;
    rdfs:label 'Allocation Method' ;
    rdfs:comment 'The method used to distribute the block trade across accounts. Pro-rata allocates proportionally, manual is trader-specified, step-out is give-up to another broker, average price uses weighted average, specific fill assigns exact executions, FIFO (First In First Out) uses order sequence.' ;
    rdfs:domain ind:Allocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationStatus rdf:type rdf:Property ;
    rdfs:label 'Allocation Status' ;
    rdfs:comment 'Current lifecycle status of the allocation. Pending awaits affirmation, affirmed is confirmed by counterparty, rejected is declined, cancelled is voided, amended is modified, settled is completed.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionCurrency rdf:type rdf:Property ;
    rdfs:label 'Commission Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the commission amount.' ;
    rdfs:domain ind:Allocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netAmount rdf:type rdf:Property ;
    rdfs:label 'Net Amount' ;
    rdfs:comment 'The net settlement amount for this allocation after commissions, fees, and accrued interest, representing the cash flow to or from the account.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:percentage rdf:type rdf:Property ;
    rdfs:label 'Percentage' ;
    rdfs:comment 'The percentage of the total block trade allocated to this account, expressed as a decimal (e.g., 25.50 for 25.5%).' ;
    rdfs:domain ind:Allocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tradeFeeId rdf:type rdf:Property ;
    rdfs:label 'Trade Fee Id' ;
    rdfs:comment 'Unique identifier for the trade fee record. Primary key for the trade fee entity.' ;
    rdfs:domain ind:TradeFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryFilingId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Id' ;
    rdfs:comment 'Foreign key linking to compliance.compliance_regulatory_filing. Business justification: Certain fees (inducements, research payments under MiFID II RTS 28) require regulatory disclosure filings. Traceability from trade fee to regulatory filing is required for MiFID II compliance and regu' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryFiling .

ind:basis rdf:type rdf:Property ;
    rdfs:label 'Basis' ;
    rdfs:comment 'Calculation methodology for the fee. Indicates whether fee is charged per trade, per share, as basis points on notional, flat rate, tiered structure, or ad valorem percentage.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookingEntity rdf:type rdf:Property ;
    rdfs:label 'Booking Entity' ;
    rdfs:comment 'Legal entity that books the fee for accounting and regulatory capital purposes. Supports multi-entity consolidation and regulatory reporting.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalFeeReference rdf:type rdf:Property ;
    rdfs:label 'External Fee Reference' ;
    rdfs:comment 'Fee identifier from the source system. Supports reconciliation and lineage tracking back to operational systems.' ;
    rdfs:domain ind:TradeFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeCategory rdf:type rdf:Property ;
    rdfs:label 'Fee Category' ;
    rdfs:comment 'High-level grouping of fee types for aggregated cost reporting and analysis. Supports PRIIPs cost disclosure and MiFID II ex-ante/ex-post cost reporting.' ;
    rdfs:domain ind:TradeFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeStatus rdf:type rdf:Property ;
    rdfs:label 'Fee Status' ;
    rdfs:comment 'Current lifecycle state of the fee. Tracks progression from accrual through invoicing, payment, or waiver. Supports accounts payable/receivable reconciliation.' ;
    rdfs:domain ind:TradeFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceDate rdf:type rdf:Property ;
    rdfs:label 'Invoice Date' ;
    rdfs:comment 'Date on which the fee was invoiced to the client or received from the counterparty. Supports accounts receivable and payable tracking.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pnlImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Pnl Impact Amount' ;
    rdfs:comment 'Impact of the fee on trading desk Profit and Loss (P&L). May differ from fee_amount due to allocation rules or internal transfer pricing.' ;
    rdfs:domain ind:TradeFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rate rdf:type rdf:Property ;
    rdfs:label 'Rate' ;
    rdfs:comment 'Rate or percentage applied to calculate the fee amount. For BPS-based fees, expressed in basis points. For percentage fees, expressed as decimal (e.g., 0.0025 for 0.25%).' ;
    rdfs:domain ind:TradeFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rebateAmount rdf:type rdf:Property ;
    rdfs:label 'Rebate Amount' ;
    rdfs:comment 'Rebate or discount applied to the gross fee. Supports volume-based rebate programs and fee negotiation tracking.' ;
    rdfs:domain ind:TradeFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Amount' ;
    rdfs:comment 'Tax or regulatory levy amount included in or added to the fee. Supports Value Added Tax (VAT), Goods and Services Tax (GST), and Financial Transaction Tax (FTT) reporting.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxRate rdf:type rdf:Property ;
    rdfs:label 'Tax Rate' ;
    rdfs:comment 'Tax rate applied to the fee, expressed as a decimal. Supports tax calculation verification and audit.' ;
    rdfs:domain ind:TradeFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tcaEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Tca Eligible Flag' ;
    rdfs:comment 'Indicates whether this fee is included in Transaction Cost Analysis (TCA) for best execution monitoring and broker performance evaluation.' ;
    rdfs:domain ind:TradeFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waiverApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Waiver Approved By' ;
    rdfs:comment 'Name or identifier of the person who approved the fee waiver. Supports governance and audit requirements.' ;
    rdfs:domain ind:TradeFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:domicileCountryId rdf:type rdf:Property ;
    rdfs:label 'Domicile Country Id' ;
    rdfs:comment 'Foreign key linking to reference.country. Business justification: KYC/AML regulatory requirement - party domicile country drives FATCA/CRS classification, sanctions screening jurisdiction, and country risk rating. Core compliance process requiring validated country ' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:preferredCurrencyId rdf:type rdf:Property ;
    rdfs:label 'Preferred Currency Id' ;
    rdfs:comment 'Foreign key linking to reference.currency. Business justification: Operational necessity - preferred currency drives statement generation, pricing display, FX conversion rules for multi-currency customers, and fee calculations. Real daily banking operations dependenc' ;
    rdfs:domain ind:Party ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:primaryLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Primary Legal Entity Id' ;
    rdfs:comment 'Foreign key linking to ledger.legal_entity. Business justification: Every banking customer relationship exists with a specific legal entity of the bank for regulatory capital allocation, financial statement consolidation, and legal entity P&L attribution. Required for' ;
    rdfs:domain ind:Party ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:cifNumber rdf:type rdf:Property ;
    rdfs:label 'Cif Number' ;
    rdfs:comment 'Core banking system Customer Information File number. Internal unique identifier from the source system (Temenos T24 / FIS Profile).' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:citizenshipCountryCode rdf:type rdf:Property ;
    rdfs:label 'Citizenship Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the party\'s citizenship. For individuals only. May be multi-valued in source systems but stored as primary citizenship here.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cltvScore rdf:type rdf:Property ;
    rdfs:label 'Cltv Score' ;
    rdfs:comment 'Calculated customer lifetime value score representing the predicted net profit attributed to the entire future relationship with the party. Used for relationship prioritization and resource allocation.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerSegment rdf:type rdf:Property ;
    rdfs:label 'Customer Segment' ;
    rdfs:comment 'Business segmentation classification of the party. Used for relationship management, pricing strategies, and service level differentiation.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dateOfBirth rdf:type rdf:Property ;
    rdfs:label 'Date Of Birth' ;
    rdfs:comment 'Date of birth for individual parties. Used for age verification, regulatory compliance, and customer segmentation. Null for non-individual party types.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dunsNumber rdf:type rdf:Property ;
    rdfs:label 'Duns Number' ;
    rdfs:comment 'Dun & Bradstreet DUNS number for corporate parties. 9-digit unique identifier for business entities.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incorporationDate rdf:type rdf:Property ;
    rdfs:label 'Incorporation Date' ;
    rdfs:comment 'Date of incorporation or registration for legal entity parties. Null for individual party types.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isPep rdf:type rdf:Property ;
    rdfs:label 'Is Pep' ;
    rdfs:comment 'Flag indicating whether the party is classified as a Politically Exposed Person. PEPs require enhanced due diligence under AML regulations.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSanctioned rdf:type rdf:Property ;
    rdfs:label 'Is Sanctioned' ;
    rdfs:comment 'Flag indicating whether the party appears on any sanctions lists (OFAC, UN, EU, etc.). Sanctioned parties are prohibited from transacting.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kycCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Kyc Completion Date' ;
    rdfs:comment 'Date when the most recent KYC verification was completed. Used to track periodic review requirements.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:kycNextReviewDate rdf:type rdf:Property ;
    rdfs:label 'Kyc Next Review Date' ;
    rdfs:comment 'Scheduled date for the next periodic KYC review. Review frequency is typically risk-based.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:kycStatus rdf:type rdf:Property ;
    rdfs:label 'Kyc Status' ;
    rdfs:comment 'Current status of the KYC (Know Your Customer) verification process. Indicates whether customer due diligence has been completed and is current.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lifecycleStatus rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Status' ;
    rdfs:comment 'Current state of the party in the customer lifecycle. Tracks the operational status from initial prospect through relationship termination or merger.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nationalIdNumber rdf:type rdf:Property ;
    rdfs:label 'National Id Number' ;
    rdfs:comment 'Government-issued national identification number for individuals. Format varies by country (e.g., Social Security Number in USA, National Insurance Number in UK).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npsScore rdf:type rdf:Property ;
    rdfs:label 'Nps Score' ;
    rdfs:comment 'Most recent Net Promoter Score for the party, ranging from -100 to +100. Measures customer loyalty and satisfaction.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:passportExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Passport Expiry Date' ;
    rdfs:comment 'Expiration date of the passport. Used to ensure identity documents remain current for compliance purposes.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:passportIssuingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Passport Issuing Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the authority that issued the passport.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passportNumber rdf:type rdf:Property ;
    rdfs:label 'Passport Number' ;
    rdfs:comment 'Passport number for individual parties. Used for identity verification and cross-border compliance.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredLanguageCode rdf:type rdf:Property ;
    rdfs:label 'Preferred Language Code' ;
    rdfs:comment 'ISO 639-1 two-letter language code representing the party\'s preferred language for communication and documentation.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipEndDate rdf:type rdf:Property ;
    rdfs:label 'Relationship End Date' ;
    rdfs:comment 'Date when the party\'s relationship with the bank was terminated. Null for active relationships.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:relationshipStartDate rdf:type rdf:Property ;
    rdfs:label 'Relationship Start Date' ;
    rdfs:comment 'Date when the party first established a relationship with the bank. Represents the initial onboarding or account opening date.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:residencyStatus rdf:type rdf:Property ;
    rdfs:label 'Residency Status' ;
    rdfs:comment 'Tax residency classification of the party. Critical for regulatory reporting under FATCA and CRS.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:individualProfileId rdf:type rdf:Property ;
    rdfs:label 'Individual Profile Id' ;
    rdfs:comment 'Unique identifier for the individual profile record. Primary key for natural-person parties in retail and private banking segments.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IndividualProfile .

ind:annualIncomeCurrencyId rdf:type rdf:Property ;
    rdfs:label 'Annual Income Currency Id' ;
    rdfs:comment 'Foreign key linking to reference.currency. Business justification: Annual income currency is used in credit decisioning, AML transaction monitoring, and FATCA/CRS income reporting. A proper FK to reference.currency enables FX normalization of income for cross-currenc' ;
    rdfs:domain ind:IndividualProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:enrolledDigitalChannelId rdf:type rdf:Property ;
    rdfs:label 'Enrolled Digital Channel Id' ;
    rdfs:comment 'Foreign key linking to channel.digital_channel. Business justification: individual_profile tracks digital_banking_enrollment_flag and digital_banking_enrollment_date, indicating enrollment in a specific digital channel (mobile app, web portal). Banks must track which digi' ;
    rdfs:domain ind:IndividualProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DigitalChannel .

ind:annualIncomeAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Income Amount' ;
    rdfs:comment 'Total gross annual income declared by the individual in the banks reporting currency. Core input for credit decisioning, loan-to-income ratio calculations, and wealth management suitability assessments.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:biometricAuthenticationEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Biometric Authentication Enabled Flag' ;
    rdfs:comment 'Indicates whether the individual has enabled biometric authentication (fingerprint, face recognition) for digital banking access. Used for security posture assessment and fraud risk scoring.' ;
    rdfs:domain ind:IndividualProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cltvCalculationDate rdf:type rdf:Property ;
    rdfs:label 'Cltv Calculation Date' ;
    rdfs:comment 'Date when the CLTV score was last calculated or refreshed. Used for model recency validation and refresh scheduling.' ;
    rdfs:domain ind:IndividualProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditBureauReportingConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Credit Bureau Reporting Consent Flag' ;
    rdfs:comment 'Indicates whether the individual has consented to the bank reporting their credit activity to credit bureaus. Required in jurisdictions with opt-in credit reporting regimes.' ;
    rdfs:domain ind:IndividualProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataSharingConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Consent Flag' ;
    rdfs:comment 'Indicates whether the individual has consented to sharing their data with third parties (affiliates, partners, credit bureaus). Required for GDPR and CCPA compliance.' ;
    rdfs:domain ind:IndividualProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:digitalBankingEnrollmentDate rdf:type rdf:Property ;
    rdfs:label 'Digital Banking Enrollment Date' ;
    rdfs:comment 'Date when the individual first enrolled in digital banking services. Used for cohort analysis, digital maturity scoring, and customer lifecycle stage determination.' ;
    rdfs:domain ind:IndividualProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:digitalBankingEnrollmentFlag rdf:type rdf:Property ;
    rdfs:label 'Digital Banking Enrollment Flag' ;
    rdfs:comment 'Indicates whether the individual has completed enrollment in the banks digital banking platform (online and mobile banking). Used for channel analytics, digital adoption tracking, and omnichannel strategy.' ;
    rdfs:domain ind:IndividualProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:educationLevel rdf:type rdf:Property ;
    rdfs:label 'Education Level' ;
    rdfs:comment 'Highest level of formal education attained by the individual. Used for customer segmentation, product targeting, and financial literacy program design. [ENUM-REF-CANDIDATE: high_school|associate|bachelor|master|doctorate|professional|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:IndividualProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employerName rdf:type rdf:Property ;
    rdfs:label 'Employer Name' ;
    rdfs:comment 'Legal name of the individuals current employer or business entity if self-employed. Used for income verification, employment stability assessment, and corporate banking cross-sell opportunities.' ;
    rdfs:domain ind:IndividualProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employmentStatus rdf:type rdf:Property ;
    rdfs:label 'Employment Status' ;
    rdfs:comment 'Current employment classification of the individual. Critical input for credit risk assessment, loan origination decisioning, and income verification workflows.' ;
    rdfs:domain ind:IndividualProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kycRefreshDueDate rdf:type rdf:Property ;
    rdfs:label 'Kyc Refresh Due Date' ;
    rdfs:comment 'Next scheduled date for periodic KYC refresh and customer due diligence update. Frequency is risk-based per AML regulations (typically annual for high-risk, biennial for medium-risk, triennial for low-risk).' ;
    rdfs:domain ind:IndividualProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maritalStatus rdf:type rdf:Property ;
    rdfs:label 'Marital Status' ;
    rdfs:comment 'Current marital or civil partnership status of the individual. Impacts credit assessment, joint account eligibility, and wealth planning strategies.' ;
    rdfs:domain ind:IndividualProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingConsentDate rdf:type rdf:Property ;
    rdfs:label 'Marketing Consent Date' ;
    rdfs:comment 'Date when the individual provided or last updated their marketing consent. Used for consent lifecycle management and regulatory audit trails.' ;
    rdfs:domain ind:IndividualProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:marketingConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Marketing Consent Flag' ;
    rdfs:comment 'Indicates whether the individual has provided explicit consent to receive marketing communications. Required for GDPR, CCPA, and CAN-SPAM compliance.' ;
    rdfs:domain ind:IndividualProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mobileAppUserFlag rdf:type rdf:Property ;
    rdfs:label 'Mobile App User Flag' ;
    rdfs:comment 'Indicates whether the individual has downloaded and activated the banks mobile banking application. Used for mobile engagement metrics and push notification eligibility.' ;
    rdfs:domain ind:IndividualProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netWorthBand rdf:type rdf:Property ;
    rdfs:label 'Net Worth Band' ;
    rdfs:comment 'Categorized range of the individuals total net worth (assets minus liabilities). Used for private banking eligibility, wealth management segmentation, and high-net-worth individual (HNWI) identification.' ;
    rdfs:domain ind:IndividualProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npsSurveyDate rdf:type rdf:Property ;
    rdfs:label 'Nps Survey Date' ;
    rdfs:comment 'Date when the most recent NPS score was collected. Used for trend analysis and survey recency validation.' ;
    rdfs:domain ind:IndividualProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:numberOfDependents rdf:type rdf:Property ;
    rdfs:label 'Number Of Dependents' ;
    rdfs:comment 'Count of financial dependents claimed by the individual. Used in credit underwriting, affordability assessments, and wealth management planning.' ;
    rdfs:domain ind:IndividualProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:occupationCode rdf:type rdf:Property ;
    rdfs:label 'Occupation Code' ;
    rdfs:comment 'Standardized occupation classification code (NAICS or SIC) representing the individuals primary profession. Enables industry-based risk segmentation and targeted product offerings.' ;
    rdfs:domain ind:IndividualProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:occupationDescription rdf:type rdf:Property ;
    rdfs:label 'Occupation Description' ;
    rdfs:comment 'Free-text description of the individuals job title or professional role. Complements occupation_code with human-readable context for relationship managers and underwriters.' ;
    rdfs:domain ind:IndividualProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pepClassification rdf:type rdf:Property ;
    rdfs:label 'Pep Classification' ;
    rdfs:comment 'Specific category of PEP status if pep_flag is true. Determines the level of enhanced due diligence and monitoring intensity required under AML frameworks.' ;
    rdfs:domain ind:IndividualProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pepFlag rdf:type rdf:Property ;
    rdfs:label 'Pep Flag' ;
    rdfs:comment 'Indicates whether the individual is classified as a Politically Exposed Person under AML regulations. Triggers enhanced due diligence, ongoing monitoring, and senior management approval for account opening.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferredContactMethod rdf:type rdf:Property ;
    rdfs:label 'Preferred Contact Method' ;
    rdfs:comment 'Individuals stated preference for primary communication channel. Used by CRM systems to optimize customer engagement, regulatory notifications, and marketing campaign delivery.' ;
    rdfs:domain ind:IndividualProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredLanguage rdf:type rdf:Property ;
    rdfs:label 'Preferred Language' ;
    rdfs:comment 'ISO 639-1 two-letter language code representing the individuals preferred language for communications and service delivery. Ensures compliance with language access requirements and enhances customer experience.' ;
    rdfs:domain ind:IndividualProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Profile Created Timestamp' ;
    rdfs:comment 'Timestamp when the individual profile record was first created in the system. Used for audit trails, data lineage, and customer tenure calculations.' ;
    rdfs:domain ind:IndividualProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:profileStatus rdf:type rdf:Property ;
    rdfs:label 'Profile Status' ;
    rdfs:comment 'Current lifecycle status of the individual profile. Controls access to banking services, reporting inclusion, and regulatory treatment.' ;
    rdfs:domain ind:IndividualProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Profile Updated Timestamp' ;
    rdfs:comment 'Timestamp when the individual profile record was last modified. Used for change tracking, data freshness assessment, and audit compliance.' ;
    rdfs:domain ind:IndividualProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:riskRatingDate rdf:type rdf:Property ;
    rdfs:label 'Risk Rating Date' ;
    rdfs:comment 'Date when the AML risk rating was last assessed or updated. Used for periodic review scheduling and regulatory examination evidence.' ;
    rdfs:domain ind:IndividualProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:taxResidencyCountries rdf:type rdf:Property ;
    rdfs:label 'Tax Residency Countries' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes representing all jurisdictions where the individual is a tax resident. Required for CRS (Common Reporting Standard) compliance and automatic exchange of information.' ;
    rdfs:domain ind:IndividualProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usPersonFlag rdf:type rdf:Property ;
    rdfs:label 'Us Person Flag' ;
    rdfs:comment 'Indicates whether the individual is classified as a US person under FATCA regulations (US citizen, green card holder, or US tax resident). Triggers IRS Form W-9 collection and FATCA reporting obligations.' ;
    rdfs:domain ind:IndividualProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bankingLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Banking Legal Entity Id' ;
    rdfs:comment 'Foreign key linking to ledger.legal_entity. Business justification: Corporate banking relationships are booked to specific bank legal entities for credit risk concentration limits, regulatory capital calculations, and legal entity financial reporting. Essential for Ba' ;
    rdfs:domain ind:CorporateProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:creditRatingId rdf:type rdf:Property ;
    rdfs:label 'Credit Rating Id' ;
    rdfs:comment 'Foreign key linking to security.credit_rating. Business justification: Corporate clients\' external credit ratings (Moody\'s, S&P, Fitch) are authoritatively stored in security.credit_rating. The denormalized rating columns on corporate_profile violate 3NF and drift from t' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CreditRating .

ind:jurisdictionCountryId rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Country Id' ;
    rdfs:comment 'Foreign key linking to reference.country. Business justification: Legal entity validation - incorporation jurisdiction determines regulatory treatment, tax obligations, legal enforceability of contracts, and credit risk assessment. Critical for corporate banking and' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:parentPartyId rdf:type rdf:Property ;
    rdfs:label 'Parent Party Id' ;
    rdfs:comment 'Foreign key reference to the party_id of the immediate parent company in the corporate hierarchy. Null if the entity is the ultimate parent or has no parent relationship. Used for consolidated reporting and group exposure management.' ;
    rdfs:domain ind:CorporateProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:primaryCorporatePartyId rdf:type rdf:Property ;
    rdfs:label 'Primary Corporate Party Id' ;
    rdfs:comment 'Foreign key reference to the party master table. Links this corporate profile to the corresponding party entity where entity_type is non-individual (corporation, partnership, trust, government agency, etc.).' ;
    rdfs:domain ind:CorporateProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:relationshipProfitCenterId rdf:type rdf:Property ;
    rdfs:label 'Relationship Profit Center Id' ;
    rdfs:comment 'Foreign key linking to ledger.profit_center. Business justification: Corporate banking relationship P&L reporting requires each corporate client to be attributed to a profit center (relationship manager\'s desk/business line). This drives revenue attribution, RM perform' ;
    rdfs:domain ind:CorporateProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProfitCenter .

ind:annualRevenueBand rdf:type rdf:Property ;
    rdfs:label 'Annual Revenue Band' ;
    rdfs:comment 'The revenue size band representing the entity\'s approximate annual revenue or turnover. Used for credit assessment, relationship pricing, and regulatory segmentation. [ENUM-REF-CANDIDATE: 0-1M|1M-10M|10M-50M|50M-100M|100M-500M|500M-1B|1B+ — promote to reference product]' ;
    rdfs:domain ind:CorporateProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crsJurisdictionOfTaxResidence rdf:type rdf:Property ;
    rdfs:label 'Crs Jurisdiction Of Tax Residence' ;
    rdfs:comment 'The ISO 3166-1 alpha-3 country code of the jurisdiction where the entity is tax resident for CRS purposes. May differ from jurisdiction of incorporation.' ;
    rdfs:domain ind:CorporateProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeCountBand rdf:type rdf:Property ;
    rdfs:label 'Employee Count Band' ;
    rdfs:comment 'The size band representing the approximate number of employees working for the entity. Used for segmentation, credit risk assessment, and regulatory reporting (e.g., SME classification).' ;
    rdfs:domain ind:CorporateProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fatcaClassification rdf:type rdf:Property ;
    rdfs:label 'Fatca Classification' ;
    rdfs:comment 'The entity classification under FATCA regulations: Active NFFE (Non-Financial Foreign Entity), Passive NFFE, FFI (Foreign Financial Institution), Exempt Beneficial Owner, or Non-Participating FFI. Determines FATCA reporting obligations.' ;
    rdfs:domain ind:CorporateProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industryClassificationSystem rdf:type rdf:Property ;
    rdfs:label 'Industry Classification System' ;
    rdfs:comment 'The classification system used for the industry_classification_code field (SIC, NAICS, or ISIC).' ;
    rdfs:domain ind:CorporateProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalCreditRating rdf:type rdf:Property ;
    rdfs:label 'Internal Credit Rating' ;
    rdfs:comment 'The bank\'s internal credit rating assigned to the entity based on proprietary credit risk models and assessment frameworks. Used for IRB (Internal Ratings-Based) approach under Basel III and internal risk management.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Operating Address Line 1' ;
    rdfs:comment 'The first line of the entity\'s primary operating or business address. This may differ from the registered address and represents where the entity conducts its day-to-day business operations.' ;
    rdfs:domain ind:CorporateProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Operating Address Line 2' ;
    rdfs:comment 'The second line of the entity\'s primary operating address (suite, floor, building name, etc.).' ;
    rdfs:domain ind:CorporateProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingCity rdf:type rdf:Property ;
    rdfs:label 'Operating City' ;
    rdfs:comment 'The city or municipality of the entity\'s primary operating address.' ;
    rdfs:domain ind:CorporateProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Operating Country Code' ;
    rdfs:comment 'The ISO 3166-1 alpha-3 country code of the entity\'s primary operating address (e.g., USA, GBR, DEU).' ;
    rdfs:domain ind:CorporateProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingPostalCode rdf:type rdf:Property ;
    rdfs:label 'Operating Postal Code' ;
    rdfs:comment 'The postal or ZIP code of the entity\'s primary operating address.' ;
    rdfs:domain ind:CorporateProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingStateProvince rdf:type rdf:Property ;
    rdfs:label 'Operating State Province' ;
    rdfs:comment 'The state, province, or administrative region of the entity\'s primary operating address.' ;
    rdfs:domain ind:CorporateProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publiclyListedFlag rdf:type rdf:Property ;
    rdfs:label 'Publicly Listed Flag' ;
    rdfs:comment 'Indicates whether the entity is publicly traded on a stock exchange (True) or privately held (False). Affects regulatory requirements, disclosure obligations, and credit risk assessment.' ;
    rdfs:domain ind:CorporateProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:registeredAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Registered Address Line 1' ;
    rdfs:comment 'The first line of the entity\'s registered legal address as filed with the corporate registry. This is the official address for legal correspondence and service of process.' ;
    rdfs:domain ind:CorporateProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Registered Address Line 2' ;
    rdfs:comment 'The second line of the entity\'s registered legal address (suite, floor, building name, etc.).' ;
    rdfs:domain ind:CorporateProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredCity rdf:type rdf:Property ;
    rdfs:label 'Registered City' ;
    rdfs:comment 'The city or municipality of the entity\'s registered legal address.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredCountryCode rdf:type rdf:Property ;
    rdfs:label 'Registered Country Code' ;
    rdfs:comment 'The ISO 3166-1 alpha-3 country code of the entity\'s registered legal address (e.g., USA, GBR, DEU).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredPostalCode rdf:type rdf:Property ;
    rdfs:label 'Registered Postal Code' ;
    rdfs:comment 'The postal or ZIP code of the entity\'s registered legal address.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredStateProvince rdf:type rdf:Property ;
    rdfs:label 'Registered State Province' ;
    rdfs:comment 'The state, province, or administrative region of the entity\'s registered legal address.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationNumber rdf:type rdf:Property ;
    rdfs:label 'Registration Number' ;
    rdfs:comment 'The official registration or incorporation number assigned by the jurisdiction\'s corporate registry (e.g., Companies House number in UK, EIN in USA). Used for legal identification and verification.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockExchangeCode rdf:type rdf:Property ;
    rdfs:label 'Stock Exchange Code' ;
    rdfs:comment 'The Market Identifier Code (MIC) of the primary stock exchange where the entity\'s shares are listed (e.g., XNYS for NYSE, XLON for London Stock Exchange). Null if not publicly listed.' ;
    rdfs:domain ind:CorporateProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockTickerSymbol rdf:type rdf:Property ;
    rdfs:label 'Stock Ticker Symbol' ;
    rdfs:comment 'The ticker symbol or trading symbol used to identify the entity\'s publicly traded shares on the stock exchange. Null if not publicly listed.' ;
    rdfs:domain ind:CorporateProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uboFlag rdf:type rdf:Property ;
    rdfs:label 'Ubo Flag' ;
    rdfs:comment 'Indicates whether this entity is itself an ultimate beneficial owner (True) or is owned by another entity (False). Used for AML/KYC compliance and ownership transparency.' ;
    rdfs:domain ind:CorporateProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:adverseMediaScreeningDate rdf:type rdf:Property ;
    rdfs:label 'Adverse Media Screening Date' ;
    rdfs:comment 'The date when the most recent adverse media screening was performed.' ;
    rdfs:domain ind:KycRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:adverseMediaScreeningResult rdf:type rdf:Property ;
    rdfs:label 'Adverse Media Screening Result' ;
    rdfs:comment 'Result of screening against adverse media sources for negative news related to financial crime, fraud, or reputational risk.' ;
    rdfs:domain ind:KycRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficialOwnershipVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Beneficial Ownership Verification Date' ;
    rdfs:comment 'The date when beneficial ownership information was last verified.' ;
    rdfs:domain ind:KycRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:beneficialOwnershipVerified rdf:type rdf:Property ;
    rdfs:label 'Beneficial Ownership Verified' ;
    rdfs:comment 'Indicates whether beneficial ownership information has been collected and verified for corporate or trust entities, as required by FinCEN CDD Rule.' ;
    rdfs:domain ind:KycRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cddCompletionStatus rdf:type rdf:Property ;
    rdfs:label 'Cdd Completion Status' ;
    rdfs:comment 'Status of the standard Customer Due Diligence process completion.' ;
    rdfs:domain ind:KycRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerRiskProfile rdf:type rdf:Property ;
    rdfs:label 'Customer Risk Profile' ;
    rdfs:comment 'Comprehensive narrative risk profile summarizing all risk factors, business activities, geographic exposure, and other considerations relevant to AML risk assessment.' ;
    rdfs:domain ind:KycRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eddCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Edd Completion Date' ;
    rdfs:comment 'The date when Enhanced Due Diligence procedures were completed, if applicable.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eddCompletionStatus rdf:type rdf:Property ;
    rdfs:label 'Edd Completion Status' ;
    rdfs:comment 'Status of the Enhanced Due Diligence process if required.' ;
    rdfs:domain ind:KycRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eddRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Edd Required Flag' ;
    rdfs:comment 'Indicates whether Enhanced Due Diligence is required for this party based on risk assessment.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jurisdictionRiskScore rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Risk Score' ;
    rdfs:comment 'Numeric risk score (0-100) based on the customer\'s operating jurisdictions and geographic risk factors, with higher scores indicating higher risk.' ;
    rdfs:domain ind:KycRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:kycDocumentationComplete rdf:type rdf:Property ;
    rdfs:label 'Kyc Documentation Complete' ;
    rdfs:comment 'Indicates whether all required KYC documentation (identity documents, proof of address, business registration, etc.) has been collected and verified.' ;
    rdfs:domain ind:KycRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastSarFilingDate rdf:type rdf:Property ;
    rdfs:label 'Last Sar Filing Date' ;
    rdfs:comment 'The date when the most recent Suspicious Activity Report was filed for this customer, if applicable. Highly confidential.' ;
    rdfs:domain ind:KycRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:overallRiskScore rdf:type rdf:Property ;
    rdfs:label 'Overall Risk Score' ;
    rdfs:comment 'Composite numeric risk score (0-100) aggregating all risk dimensions (jurisdiction, product, transaction, relationship) to produce the overall AML risk rating.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pepScreeningDate rdf:type rdf:Property ;
    rdfs:label 'Pep Screening Date' ;
    rdfs:comment 'The date when the most recent PEP screening was performed.' ;
    rdfs:domain ind:KycRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pepScreeningResult rdf:type rdf:Property ;
    rdfs:label 'Pep Screening Result' ;
    rdfs:comment 'Result of screening against Politically Exposed Person lists. Match identified requires enhanced scrutiny.' ;
    rdfs:domain ind:KycRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorRiskRating rdf:type rdf:Property ;
    rdfs:label 'Prior Risk Rating' ;
    rdfs:comment 'The AML risk rating assigned before the most recent review, used to track rating changes over time.' ;
    rdfs:domain ind:KycRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productServiceRiskScore rdf:type rdf:Property ;
    rdfs:label 'Product Service Risk Score' ;
    rdfs:comment 'Numeric risk score (0-100) based on the types of banking products and services the customer uses, with higher scores for higher-risk products.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:relationshipRiskScore rdf:type rdf:Property ;
    rdfs:label 'Relationship Risk Score' ;
    rdfs:comment 'Numeric risk score (0-100) based on the customer\'s business relationships, ownership structure, and counterparty network, with higher scores indicating higher risk.' ;
    rdfs:domain ind:KycRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reviewOutcome rdf:type rdf:Property ;
    rdfs:label 'Review Outcome' ;
    rdfs:comment 'The outcome of the most recent KYC review: no change to risk rating, risk upgraded, risk downgraded, escalated to Enhanced Due Diligence, or relationship terminated/exited.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewTriggerType rdf:type rdf:Property ;
    rdfs:label 'Review Trigger Type' ;
    rdfs:comment 'The event or condition that triggered the most recent KYC review: periodic scheduled review, risk-based trigger, regulatory requirement, client-initiated update, transaction pattern alert, or system-generated alert.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskRatingRationale rdf:type rdf:Property ;
    rdfs:label 'Risk Rating Rationale' ;
    rdfs:comment 'Detailed explanation and justification for the assigned AML risk rating, including contributing factors and risk indicators.' ;
    rdfs:domain ind:KycRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceOfFundsVerified rdf:type rdf:Property ;
    rdfs:label 'Source Of Funds Verified' ;
    rdfs:comment 'Indicates whether the source of funds for the customer has been verified and documented.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceOfWealthVerified rdf:type rdf:Property ;
    rdfs:label 'Source Of Wealth Verified' ;
    rdfs:comment 'Indicates whether the source of wealth for the customer has been verified and documented, typically required for high-risk or high-net-worth clients.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transactionRiskScore rdf:type rdf:Property ;
    rdfs:label 'Transaction Risk Score' ;
    rdfs:comment 'Numeric risk score (0-100) based on the customer\'s transaction patterns, volumes, and behaviors, with higher scores indicating higher risk.' ;
    rdfs:domain ind:KycRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partyAddressId rdf:type rdf:Property ;
    rdfs:label 'Party Address Id' ;
    rdfs:comment 'Unique identifier for the party address record. Primary key.' ;
    rdfs:domain ind:PartyAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line 1' ;
    rdfs:comment 'First line of the physical address (street number, street name, building name). Applicable only when contact_type is physical_address.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line 2' ;
    rdfs:comment 'Second line of the physical address (apartment, suite, floor, unit). Applicable only when contact_type is physical_address.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine3 rdf:type rdf:Property ;
    rdfs:label 'Address Line 3' ;
    rdfs:comment 'Third line of the physical address (additional location details). Applicable only when contact_type is physical_address.' ;
    rdfs:domain ind:PartyAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactType rdf:type rdf:Property ;
    rdfs:label 'Contact Type' ;
    rdfs:comment 'Type of contact information: physical_address (registered, mailing, residential, business, branch, billing), mobile, home_phone, work_phone, fax, primary_email, secondary_email, or digital identifier. [ENUM-REF-CANDIDATE: physical_address|mobile|home_phone|work_phone|fax|primary_email|secondary_email — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PartyAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactValue rdf:type rdf:Property ;
    rdfs:label 'Contact Value' ;
    rdfs:comment 'The actual contact detail value: phone number (with country code), email address, fax number, or digital identifier. Applicable for electronic contact types (mobile, home_phone, work_phone, fax, primary_email, secondary_email).' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:doNotCall rdf:type rdf:Property ;
    rdfs:label 'Do Not Call' ;
    rdfs:comment 'Flag indicating whether the party has requested not to be contacted via phone at this number. True if do-not-call requested, False otherwise. Applicable for phone contact types.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:doNotMail rdf:type rdf:Property ;
    rdfs:label 'Do Not Mail' ;
    rdfs:comment 'Flag indicating whether the party has requested not to receive physical mail at this address. True if do-not-mail requested, False otherwise. Applicable for physical address contact types.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geographicRiskScore rdf:type rdf:Property ;
    rdfs:label 'Geographic Risk Score' ;
    rdfs:comment 'AML (Anti-Money Laundering) risk score assigned to the geographic location of this address, based on jurisdiction risk ratings. Higher scores indicate higher risk. Applicable for physical address contact types.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isPrimary rdf:type rdf:Property ;
    rdfs:label 'Is Primary' ;
    rdfs:comment 'Flag indicating whether this is the primary contact point or address for the party. True if primary, False otherwise.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVerified rdf:type rdf:Property ;
    rdfs:label 'Is Verified' ;
    rdfs:comment 'Flag indicating whether this contact detail or address has been verified through a validation process. True if verified, False otherwise.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:latitude rdf:type rdf:Property ;
    rdfs:label 'Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of the physical address for geocoding and mapping. Applicable only when contact_type is physical_address.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:longitude rdf:type rdf:Property ;
    rdfs:label 'Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of the physical address for geocoding and mapping. Applicable only when contact_type is physical_address.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:optInEstatements rdf:type rdf:Property ;
    rdfs:label 'Opt In Estatements' ;
    rdfs:comment 'Flag indicating whether the party has consented to receive electronic statements at this contact point. True if opted in, False otherwise. Applicable for email contact types.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optInMarketing rdf:type rdf:Property ;
    rdfs:label 'Opt In Marketing' ;
    rdfs:comment 'Flag indicating whether the party has consented to receive marketing communications at this contact point. True if opted in, False otherwise. Applicable for electronic contact types.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:partyAddressStatus rdf:type rdf:Property ;
    rdfs:label 'Party Address Status' ;
    rdfs:comment 'Current lifecycle status of the contact detail or address: active (in use), inactive (not in use but valid), pending (awaiting verification), invalid (failed verification), expired (past expiry_date), or suspended (temporarily disabled).' ;
    rdfs:domain ind:PartyAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryNotificationFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Flag' ;
    rdfs:comment 'Flag indicating whether this contact point is designated for receiving regulatory and compliance notifications. True if designated, False otherwise.' ;
    rdfs:domain ind:PartyAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxDomicileFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Domicile Flag' ;
    rdfs:comment 'Flag indicating whether this address is used to determine the party\'s tax domicile for FATCA (Foreign Account Tax Compliance Act) and CRS (Common Reporting Standard) reporting. True if tax domicile, False otherwise. Applicable for physical address contact types.' ;
    rdfs:domain ind:PartyAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:usageContext rdf:type rdf:Property ;
    rdfs:label 'Usage Context' ;
    rdfs:comment 'Business context in which this contact detail or address is used: correspondence (general communication), service (account servicing), billing (invoices and statements), legal (regulatory notices), kyc (identity verification), or emergency (urgent contact).' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationMethod rdf:type rdf:Property ;
    rdfs:label 'Verification Method' ;
    rdfs:comment 'Method used to verify the contact detail or address: document (utility bill, bank statement), third_party (credit bureau, data vendor), customer_declaration, site_visit, or electronic (email link, SMS OTP).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partyContactId rdf:type rdf:Property ;
    rdfs:label 'Party Contact Id' ;
    rdfs:comment 'Unique identifier for the party contact record. Primary key for the party_contact data product.' ;
    rdfs:domain ind:PartyContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:areaCode rdf:type rdf:Property ;
    rdfs:label 'Area Code' ;
    rdfs:comment 'Geographic area code or regional prefix for phone numbers. Applicable to phone contact types only.' ;
    rdfs:domain ind:PartyContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bounceCount rdf:type rdf:Property ;
    rdfs:label 'Bounce Count' ;
    rdfs:comment 'The number of times an email sent to this contact has bounced (failed delivery). Used to identify invalid or inactive email addresses. Applicable to email contact types only.' ;
    rdfs:domain ind:PartyContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contactPreferenceRank rdf:type rdf:Property ;
    rdfs:label 'Contact Preference Rank' ;
    rdfs:comment 'Numeric ranking indicating the party\'s preference order for this contact method. Lower numbers indicate higher preference (1 = most preferred). Used for omnichannel communication routing.' ;
    rdfs:domain ind:PartyContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contactPurpose rdf:type rdf:Property ;
    rdfs:label 'Contact Purpose' ;
    rdfs:comment 'The intended purpose or use case for this contact information. Personal for personal communications, business for business-related communications, emergency for urgent notifications, billing for payment-related communications, correspondence for general account communications.' ;
    rdfs:domain ind:PartyContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactStatus rdf:type rdf:Property ;
    rdfs:label 'Contact Status' ;
    rdfs:comment 'Current operational status of the contact information. Active indicates the contact is valid and in use. Inactive indicates the contact is no longer in use. Bounced indicates email delivery failures. Invalid indicates the contact failed validation. Suspended indicates temporary restriction.' ;
    rdfs:domain ind:PartyContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doNotEmail rdf:type rdf:Property ;
    rdfs:label 'Do Not Email' ;
    rdfs:comment 'Boolean flag indicating whether the party has requested not to be contacted via email for marketing purposes. True if do-not-email is active, False otherwise. Required for CAN-SPAM compliance.' ;
    rdfs:domain ind:PartyContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:extension rdf:type rdf:Property ;
    rdfs:label 'Extension' ;
    rdfs:comment 'Internal phone extension number for work or business phone contacts. Applicable to work phone contact types only.' ;
    rdfs:domain ind:PartyContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageCode rdf:type rdf:Property ;
    rdfs:label 'Language Code' ;
    rdfs:comment 'Two-letter ISO 639-1 language code indicating the preferred language for communications via this contact method (e.g., en for English, es for Spanish, fr for French).' ;
    rdfs:domain ind:PartyContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastBounceDate rdf:type rdf:Property ;
    rdfs:label 'Last Bounce Date' ;
    rdfs:comment 'The date of the most recent email bounce. Null if no bounces have occurred. Format: yyyy-MM-dd. Applicable to email contact types only.' ;
    rdfs:domain ind:PartyContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastContactDate rdf:type rdf:Property ;
    rdfs:label 'Last Contact Date' ;
    rdfs:comment 'The date when this contact method was last used to communicate with the party. Null if never contacted. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:PartyContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:optInEstatementsDate rdf:type rdf:Property ;
    rdfs:label 'Opt In Estatements Date' ;
    rdfs:comment 'The date when the party provided consent for electronic statements. Null if not opted in. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:PartyContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:optInMarketingDate rdf:type rdf:Property ;
    rdfs:label 'Opt In Marketing Date' ;
    rdfs:comment 'The date when the party provided consent for marketing communications. Null if not opted in. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:PartyContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:timeZone rdf:type rdf:Property ;
    rdfs:label 'Time Zone' ;
    rdfs:comment 'The time zone associated with this contact information, using IANA time zone database format (e.g., America/New_York, Europe/London). Used to schedule communications at appropriate local times and comply with TCPA calling hour restrictions.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partyDocumentId rdf:type rdf:Property ;
    rdfs:label 'Party Document Id' ;
    rdfs:comment 'Unique identifier for the party document record. Primary key.' ;
    rdfs:domain ind:PartyDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:issuingCountryId rdf:type rdf:Property ;
    rdfs:label 'Issuing Country Id' ;
    rdfs:comment 'Foreign key linking to reference.country. Business justification: KYC/AML compliance - passport/ID issuing country must be validated for document verification, sanctions screening, and regulatory reporting. Core identity verification process.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:collectionDate rdf:type rdf:Property ;
    rdfs:label 'Collection Date' ;
    rdfs:comment 'Date on which the document was collected or received from the party during the KYC onboarding or periodic review process. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:destructionEligibleDate rdf:type rdf:Property ;
    rdfs:label 'Destruction Eligible Date' ;
    rdfs:comment 'Date on which the document becomes eligible for secure destruction or deletion based on retention policy and regulatory requirements. Nullable if document must be retained indefinitely. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:PartyDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentFormat rdf:type rdf:Property ;
    rdfs:label 'Document Format' ;
    rdfs:comment 'File format or MIME type of the stored document (e.g., PDF, JPEG, PNG, TIFF, DOCX, XML). Indicates the digital format in which the document is archived.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentLanguage rdf:type rdf:Property ;
    rdfs:label 'Document Language' ;
    rdfs:comment 'ISO 639-2 three-letter language code indicating the primary language in which the document is written (e.g., ENG for English, SPA for Spanish, FRA for French, DEU for German, CHI for Chinese).' ;
    rdfs:domain ind:PartyDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentNumber rdf:type rdf:Property ;
    rdfs:label 'Document Number' ;
    rdfs:comment 'The unique identification number or reference code printed on the document (e.g., passport number, national ID number, driver\'s license number, corporate registration number).' ;
    rdfs:domain ind:PartyDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentSizeKb rdf:type rdf:Property ;
    rdfs:label 'Document Size Kb' ;
    rdfs:comment 'Size of the stored document file in kilobytes. Used for storage management and audit purposes.' ;
    rdfs:domain ind:PartyDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:documentStorageUri rdf:type rdf:Property ;
    rdfs:label 'Document Storage Uri' ;
    rdfs:comment 'Secure storage location reference (URI, file path, or vault key) pointing to the digitized copy of the document in the bank\'s document management system or secure vault. Used to retrieve the document image or PDF for audit and review.' ;
    rdfs:domain ind:PartyDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPrimaryIdentityDocument rdf:type rdf:Property ;
    rdfs:label 'Is Primary Identity Document' ;
    rdfs:comment 'Boolean flag indicating whether this document is the primary identity document used for KYC verification (e.g., the main passport or national ID). True if primary, False otherwise.' ;
    rdfs:domain ind:PartyDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issueDate rdf:type rdf:Property ;
    rdfs:label 'Issue Date' ;
    rdfs:comment 'Date on which the document was originally issued by the authority. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:issuingAuthority rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority' ;
    rdfs:comment 'Name of the government agency, regulatory body, or institution that issued the document (e.g., U.S. Department of State, UK Home Office, Companies House, Ministry of Finance).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionPeriodYears rdf:type rdf:Property ;
    rdfs:label 'Retention Period Years' ;
    rdfs:comment 'Number of years the document must be retained in the bank\'s records to comply with regulatory requirements (e.g., 5 years for AML, 7 years for tax records). Drives document lifecycle and archival policies.' ;
    rdfs:domain ind:PartyDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewDueDate rdf:type rdf:Property ;
    rdfs:label 'Review Due Date' ;
    rdfs:comment 'Date by which the document must be reviewed or re-verified as part of periodic KYC refresh or regulatory compliance requirements. Nullable if no periodic review is required. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:translationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Translation Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether the document requires translation into the bank\'s primary operating language for compliance or operational purposes. True if translation is required, False otherwise.' ;
    rdfs:domain ind:PartyDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:translationStatus rdf:type rdf:Property ;
    rdfs:label 'Translation Status' ;
    rdfs:comment 'Status of the document translation process. Indicates whether translation is not required, pending, completed, or certified by a professional translator.' ;
    rdfs:domain ind:PartyDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipHierarchyId rdf:type rdf:Property ;
    rdfs:label 'Relationship Hierarchy Id' ;
    rdfs:comment 'Unique identifier for the party-to-party relationship record. Primary key for the relationship hierarchy entity.' ;
    rdfs:domain ind:RelationshipHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryRelationshipPartyId rdf:type rdf:Property ;
    rdfs:label 'Primary Relationship Party Id' ;
    rdfs:comment 'Identifier of the first party in the relationship. For hierarchical relationships, this is typically the parent, controlling entity, or primary party. For bilateral relationships, this is one side of the association.' ;
    rdfs:domain ind:RelationshipHierarchy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:consolidatedExposureFlag rdf:type rdf:Property ;
    rdfs:label 'Consolidated Exposure Flag' ;
    rdfs:comment 'Indicates whether this relationship should be included in consolidated exposure calculations for regulatory capital and large exposure reporting (Basel III). True for relationships that create economic dependency or control (e.g., parent-subsidiary, guarantor-borrower).' ;
    rdfs:domain ind:RelationshipHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:controlIndicator rdf:type rdf:Property ;
    rdfs:label 'Control Indicator' ;
    rdfs:comment 'Indicates whether Party A exercises control over Party B, as defined by accounting standards (IFRS 10) or regulatory frameworks (Basel III). Control may exist even without majority ownership (e.g., through voting rights, board representation, or contractual arrangements). Used for consolidated financial reporting and group-level risk aggregation.' ;
    rdfs:domain ind:RelationshipHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crossSellEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Cross Sell Eligibility Flag' ;
    rdfs:comment 'Indicates whether this relationship enables cross-sell opportunities (e.g., household members, corporate group entities). Used for CRM analytics, marketing campaigns, and customer lifetime value (CLTV) scoring.' ;
    rdfs:domain ind:RelationshipHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Level' ;
    rdfs:comment 'The depth or tier of this relationship within a hierarchical tree structure. Level 1 represents the top-most parent or ultimate controlling entity. Used for corporate group structure traversal and consolidated exposure calculation. Null for non-hierarchical (bilateral or reciprocal) relationships.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:kycLastReviewDate rdf:type rdf:Property ;
    rdfs:label 'Kyc Last Review Date' ;
    rdfs:comment 'The date on which this relationship was last reviewed or refreshed as part of KYC/CDD procedures. Used for tracking KYC refresh cycles and ensuring compliance with periodic review requirements.' ;
    rdfs:domain ind:RelationshipHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:kycVerificationStatus rdf:type rdf:Property ;
    rdfs:label 'Kyc Verification Status' ;
    rdfs:comment 'Indicates the KYC verification status of this relationship. Verified indicates the relationship has been validated through KYC/CDD procedures. Pending indicates verification is in progress. Expired indicates the relationship requires re-verification. Used for AML compliance and regulatory reporting.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pepIndicator rdf:type rdf:Property ;
    rdfs:label 'Pep Indicator' ;
    rdfs:comment 'Indicates whether either party in this relationship is classified as a Politically Exposed Person (PEP) or is associated with a PEP. Used for enhanced due diligence requirements and AML compliance.' ;
    rdfs:domain ind:RelationshipHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:relationshipDirection rdf:type rdf:Property ;
    rdfs:label 'Relationship Direction' ;
    rdfs:comment 'Indicates whether the relationship is directional (hierarchical, with a clear parent-child or controlling-controlled structure), bilateral (symmetric association where both parties have equal standing), or reciprocal (mutual obligations or roles).' ;
    rdfs:domain ind:RelationshipHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipSourceCode rdf:type rdf:Property ;
    rdfs:label 'Relationship Source Code' ;
    rdfs:comment 'The unique identifier of this relationship in the source system. Used for traceability, reconciliation, and bi-directional synchronization with operational systems.' ;
    rdfs:domain ind:RelationshipHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Relationship Source System' ;
    rdfs:comment 'The operational system of record from which this relationship was sourced (e.g., Core Banking System, CRM, Loan Origination System). Used for data lineage, reconciliation, and troubleshooting.' ;
    rdfs:domain ind:RelationshipHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleA rdf:type rdf:Property ;
    rdfs:label 'Role A' ;
    rdfs:comment 'The role or function that Party A plays in this relationship (e.g., parent, guarantor, account holder, introducer, controlling shareholder, trustee). Provides semantic context for Party A\'s position.' ;
    rdfs:domain ind:RelationshipHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleB rdf:type rdf:Property ;
    rdfs:label 'Role B' ;
    rdfs:comment 'The role or function that Party B plays in this relationship (e.g., subsidiary, borrower, co-applicant, authorized signatory, beneficial owner, beneficiary). Provides semantic context for Party B\'s position.' ;
    rdfs:domain ind:RelationshipHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sanctionsLastScreenedDate rdf:type rdf:Property ;
    rdfs:label 'Sanctions Last Screened Date' ;
    rdfs:comment 'The date on which this relationship was last screened against sanctions lists (e.g., OFAC, UN, EU). Used for tracking screening frequency and ensuring compliance with continuous monitoring requirements.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:thresholdCurrencyId rdf:type rdf:Property ;
    rdfs:label 'Threshold Currency Id' ;
    rdfs:comment 'Foreign key linking to reference.currency. Business justification: Segment AUM and revenue thresholds (aum_threshold_min/max, revenue_threshold_min/max) are currency-denominated. In multi-currency banking operations, segment eligibility assessment requires FX normali' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:assignmentMethod rdf:type rdf:Property ;
    rdfs:label 'Assignment Method' ;
    rdfs:comment 'The methodology used to assign the party to this segment. RULE_BASED: automated rule engine based on predefined criteria; MANUAL_OVERRIDE: manual assignment by relationship manager or operations; MODEL_DRIVEN: machine learning or statistical model output.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assignment Timestamp' ;
    rdfs:comment 'Timestamp when this segment assignment record was created in the system. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX. Supports audit trail and temporal analysis.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:aumThresholdMax rdf:type rdf:Property ;
    rdfs:label 'Aum Threshold Max' ;
    rdfs:comment 'Maximum Assets Under Management threshold for this segment assignment. Defines the upper bound of the segment tier. Expressed in base currency.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:aumThresholdMin rdf:type rdf:Property ;
    rdfs:label 'Aum Threshold Min' ;
    rdfs:comment 'Minimum Assets Under Management threshold required for this segment assignment. Used for wealth management and private banking segmentation. Expressed in base currency.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:campaignEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Campaign Eligibility Flag' ;
    rdfs:comment 'Boolean flag indicating whether customers in this segment are eligible for targeted marketing campaigns. False may indicate regulatory restrictions or opt-out status.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cltvCohort rdf:type rdf:Property ;
    rdfs:label 'Cltv Cohort' ;
    rdfs:comment 'CLTV-based cohort classification for segment analysis and targeted campaigns. Values: HIGH (top tier value), MEDIUM (mid tier value), LOW (entry tier value).' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criteria rdf:type rdf:Property ;
    rdfs:label 'Criteria' ;
    rdfs:comment 'Description of the business rules or criteria that qualified the party for this segment (e.g., AUM threshold, revenue tier, relationship tenure, product holdings). Supports transparency and audit.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCurrent rdf:type rdf:Property ;
    rdfs:label 'Is Current' ;
    rdfs:comment 'Boolean flag indicating whether this is the currently active segment assignment for the party. True for the active record, False for historical records.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:modelRunReference rdf:type rdf:Property ;
    rdfs:label 'Model Run Reference' ;
    rdfs:comment 'Identifier of the segmentation model execution run that produced this assignment. Enables traceability and model performance analysis. Populated only when assignment_method is MODEL_DRIVEN.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideRationale rdf:type rdf:Property ;
    rdfs:label 'Override Rationale' ;
    rdfs:comment 'Business justification for manual override of the system-recommended segment assignment. Required when override_flag is True. Supports audit and compliance review.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousSegmentCode rdf:type rdf:Property ;
    rdfs:label 'Previous Segment Code' ;
    rdfs:comment 'The segment code that was active immediately prior to this assignment. Enables segment migration analysis and transition tracking. Null for initial segment assignments.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordStatus rdf:type rdf:Property ;
    rdfs:label 'Record Status' ;
    rdfs:comment 'Current status of this segment assignment record in the data warehouse. ACTIVE: currently in effect; INACTIVE: expired or terminated; SUPERSEDED: replaced by a newer assignment; PENDING: awaiting approval or activation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueThresholdMax rdf:type rdf:Property ;
    rdfs:label 'Revenue Threshold Max' ;
    rdfs:comment 'Maximum annual revenue threshold for corporate and commercial customer segmentation. Defines the upper bound of the segment tier. Expressed in base currency.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueThresholdMin rdf:type rdf:Property ;
    rdfs:label 'Revenue Threshold Min' ;
    rdfs:comment 'Minimum annual revenue threshold for corporate and commercial customer segmentation. Used to classify SME, mid-market, and large corporate segments. Expressed in base currency.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:segmentCode rdf:type rdf:Property ;
    rdfs:label 'Segment Code' ;
    rdfs:comment 'Business code representing the customer segment classification. Values include: MASS_MARKET (mass market retail), MASS_AFFLUENT (mass affluent retail), HNW (High Net Worth), UHNW (Ultra High Net Worth), SME (Small and Medium Enterprise), MID_MARKET (mid-market corporate). [ENUM-REF-CANDIDATE: MASS_MARKET|MASS_AFFLUENT|HNW|UHNW|SME|MID_MARKET|LARGE_CORPORATE|INSTITUTIONAL|GOVERNMENT — promote to reference product]' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentName rdf:type rdf:Property ;
    rdfs:label 'Segment Name' ;
    rdfs:comment 'Human-readable name of the customer segment for reporting and display purposes.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceLevel rdf:type rdf:Property ;
    rdfs:label 'Service Level' ;
    rdfs:comment 'Service level entitlement associated with this segment. Determines access to relationship managers, priority servicing, and product offerings. Values: PREMIUM (dedicated RM, priority service), STANDARD (shared RM, standard service), BASIC (self-service, limited support).' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subSegment rdf:type rdf:Property ;
    rdfs:label 'Sub Segment' ;
    rdfs:comment 'Granular sub-classification within the primary segment, enabling more precise targeting and analysis (e.g., within HNW: emerging wealth, established wealth, legacy wealth).' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transitionDate rdf:type rdf:Property ;
    rdfs:label 'Transition Date' ;
    rdfs:comment 'The date on which the customer transitioned from the previous segment to the current segment. Used for segment migration reporting and trend analysis. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transitionReason rdf:type rdf:Property ;
    rdfs:label 'Transition Reason' ;
    rdfs:comment 'Business reason for the segment transition (e.g., AUM growth, revenue decline, relationship upgrade, regulatory reclassification). Supports root cause analysis of segment movements.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partySegmentAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Party Segment Assignment Id' ;
    rdfs:comment 'Unique identifier for each party segment assignment record. Primary key for the party segment assignment entity.' ;
    rdfs:domain ind:PartySegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:attributedProfitCenterId rdf:type rdf:Property ;
    rdfs:label 'Attributed Profit Center Id' ;
    rdfs:comment 'Foreign key linking to ledger.profit_center. Business justification: Customer segments are mapped to profit centers for revenue attribution, segment P&L reporting, RAROC calculation, and management reporting. Essential for line-of-business profitability analysis and st' ;
    rdfs:domain ind:PartySegmentAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProfitCenter .

ind:primaryPartySegmentId rdf:type rdf:Property ;
    rdfs:label 'Primary Party Segment Id' ;
    rdfs:comment 'Reference to the customer segment classification being assigned. Links to the customer segment reference entity.' ;
    rdfs:domain ind:PartySegmentAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:servicingCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Servicing Cost Center Id' ;
    rdfs:comment 'Foreign key linking to ledger.cost_center. Business justification: Segment profitability reporting requires both revenue attribution (profit_center already linked) and cost attribution. The servicing cost center tracks operational costs of serving a segment tier, ena' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:assignmentReason rdf:type rdf:Property ;
    rdfs:label 'Assignment Reason' ;
    rdfs:comment 'Business justification or rationale for the segment assignment, capturing why the party was placed in this particular segment.' ;
    rdfs:domain ind:PartySegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aumBand rdf:type rdf:Property ;
    rdfs:label 'Aum Band' ;
    rdfs:comment 'Assets Under Management band or range associated with the segment assignment, particularly relevant for wealth management and private banking segments.' ;
    rdfs:domain ind:PartySegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidenceLevel rdf:type rdf:Property ;
    rdfs:label 'Confidence Level' ;
    rdfs:comment 'Statistical confidence level (expressed as percentage) associated with the segment assignment, indicating the reliability of the classification.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicRegion rdf:type rdf:Property ;
    rdfs:label 'Geographic Region' ;
    rdfs:comment 'Geographic region or market associated with the segment assignment, supporting regional segmentation and market analysis.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelName rdf:type rdf:Property ;
    rdfs:label 'Model Name' ;
    rdfs:comment 'Name of the analytical or segmentation model used to determine the segment assignment (e.g., Customer Lifetime Value (CLTV) Model, Risk-Based Segmentation Model).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelScore rdf:type rdf:Property ;
    rdfs:label 'Model Score' ;
    rdfs:comment 'Numerical score produced by the segmentation model indicating the strength or confidence of the segment assignment.' ;
    rdfs:domain ind:PartySegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueBand rdf:type rdf:Property ;
    rdfs:label 'Revenue Band' ;
    rdfs:comment 'Revenue band or range associated with the segment assignment, supporting revenue-based segmentation strategies.' ;
    rdfs:domain ind:PartySegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Review Frequency Months' ;
    rdfs:comment 'Frequency in months at which the segment assignment should be reviewed and potentially updated, supporting ongoing segmentation accuracy.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:segmentTier rdf:type rdf:Property ;
    rdfs:label 'Segment Tier' ;
    rdfs:comment 'Hierarchical tier classification within the segment, supporting multi-level segmentation strategies (e.g., Tier 1 for highest value customers).' ;
    rdfs:domain ind:PartySegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookingLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Booking Legal Entity Id' ;
    rdfs:comment 'Foreign key linking to ledger.legal_entity. Business justification: Every onboarding case must be booked under a specific legal entity, which determines the applicable regulatory regime, product eligibility, and booking rules. This is operationally critical — the book' ;
    rdfs:domain ind:OnboardingCase ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:expectedBalanceCurrencyId rdf:type rdf:Property ;
    rdfs:label 'Expected Balance Currency Id' ;
    rdfs:comment 'Foreign key linking to reference.currency. Business justification: Expected account balance is a key AML risk indicator captured during onboarding for transaction monitoring baseline calibration. Without a currency FK, multi-currency expected balances cannot be norma' ;
    rdfs:domain ind:OnboardingCase ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:originationProfitCenterId rdf:type rdf:Property ;
    rdfs:label 'Origination Profit Center Id' ;
    rdfs:comment 'Foreign key linking to ledger.profit_center. Business justification: New customer origination is attributed to profit centers for customer acquisition revenue recognition, origination team performance measurement, and new business P&L tracking. Essential for growth str' ;
    rdfs:domain ind:OnboardingCase ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProfitCenter .

ind:applicationDate rdf:type rdf:Property ;
    rdfs:label 'Application Date' ;
    rdfs:comment 'Date when the onboarding application was initially submitted by the party or on behalf of the party.' ;
    rdfs:domain ind:OnboardingCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:applicationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Application Timestamp' ;
    rdfs:comment 'Precise timestamp when the onboarding application was submitted, capturing the exact moment of case initiation for audit and SLA tracking purposes.' ;
    rdfs:domain ind:OnboardingCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:beneficialOwnerVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Beneficial Owner Verified Flag' ;
    rdfs:comment 'Boolean indicator of whether beneficial ownership has been verified and documented for this onboarding case, required for corporate and institutional entities. True indicates verified, False indicates pending or not applicable.' ;
    rdfs:domain ind:OnboardingCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:caseNumber rdf:type rdf:Property ;
    rdfs:label 'Case Number' ;
    rdfs:comment 'Externally visible business identifier for the onboarding case, used for tracking and reference in customer communications and operational workflows.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseStatus rdf:type rdf:Property ;
    rdfs:label 'Case Status' ;
    rdfs:comment 'Current lifecycle status of the onboarding case workflow: initiated, document collection, KYC (Know Your Customer) review, AML (Anti-Money Laundering) screening, credit check, compliance approval, final approval, account opening, completed, rejected, withdrawn, or expired. [ENUM-REF-CANDIDATE: initiated|document_collection|kyc_review|aml_screening|credit_check|compliance_approval|final_approval|account_opening|completed|rejected|withdrawn|expired — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Credit Check Status' ;
    rdfs:comment 'Status of credit assessment for this onboarding case: not required (for non-credit products), pending, completed, approved, declined, or requiring manual review.' ;
    rdfs:domain ind:OnboardingCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crsStatus rdf:type rdf:Property ;
    rdfs:label 'Crs Status' ;
    rdfs:comment 'CRS compliance status for this onboarding case, applicable for international tax reporting: not applicable, pending review, compliant, non-compliant, or exempt.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentChecklistCompleteFlag rdf:type rdf:Property ;
    rdfs:label 'Document Checklist Complete Flag' ;
    rdfs:comment 'Boolean indicator of whether all required documentation has been collected and verified for this onboarding case. True indicates complete, False indicates pending documents.' ;
    rdfs:domain ind:OnboardingCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:expectedAccountBalance rdf:type rdf:Property ;
    rdfs:label 'Expected Account Balance' ;
    rdfs:comment 'Expected initial account balance or Assets Under Management (AUM) indicated by the applicant during onboarding, used for relationship planning and resource allocation.' ;
    rdfs:domain ind:OnboardingCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedMonthlyTransactionVolume rdf:type rdf:Property ;
    rdfs:label 'Expected Monthly Transaction Volume' ;
    rdfs:comment 'Expected number of transactions per month indicated by the applicant, used for account type recommendation and fee structure determination.' ;
    rdfs:domain ind:OnboardingCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:onboardingType rdf:type rdf:Property ;
    rdfs:label 'Onboarding Type' ;
    rdfs:comment 'Classification of the onboarding scenario: new-to-bank (first relationship), new-to-product (existing customer adding product), existing-party-new-segment (moving from retail to corporate), cross-sell, relationship upgrade, or entity conversion.' ;
    rdfs:domain ind:OnboardingCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityLevel rdf:type rdf:Property ;
    rdfs:label 'Priority Level' ;
    rdfs:comment 'Priority classification for processing this onboarding case: standard, high, urgent, or VIP (for high-value or strategic relationships).' ;
    rdfs:domain ind:OnboardingCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionDate rdf:type rdf:Property ;
    rdfs:label 'Rejection Date' ;
    rdfs:comment 'Date when the onboarding case was formally rejected and the applicant was notified.' ;
    rdfs:domain ind:OnboardingCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:slaTargetCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Sla Target Completion Date' ;
    rdfs:comment 'Target date by which the onboarding case should be completed according to the applicable SLA for the customer segment and product type.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:stageEntryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Stage Entry Timestamp' ;
    rdfs:comment 'Timestamp when the onboarding case entered the current workflow stage. Used for stage duration calculation and SLA (Service Level Agreement) monitoring.' ;
    rdfs:domain ind:OnboardingCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:withdrawalDate rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Date' ;
    rdfs:comment 'Date when the onboarding case was withdrawn by the applicant before completion.' ;
    rdfs:domain ind:OnboardingCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:workflowStage rdf:type rdf:Property ;
    rdfs:label 'Workflow Stage' ;
    rdfs:comment 'Detailed workflow stage within the onboarding process: application, document submission, identity verification, KYC/CDD (Customer Due Diligence), AML check, credit assessment, risk rating, compliance review, management approval, account setup, funding, or activation. [ENUM-REF-CANDIDATE: application|document_submission|identity_verification|kyc_cdd|aml_check|credit_assessment|risk_rating|compliance_review|management_approval|account_setup|funding|activation — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:OnboardingCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kycReviewEventId rdf:type rdf:Property ;
    rdfs:label 'Kyc Review Event Id' ;
    rdfs:comment 'Unique identifier for the KYC review event record.' ;
    rdfs:domain ind:KycReviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:resultingRiskRatingId rdf:type rdf:Property ;
    rdfs:label 'Resulting Risk Rating Id' ;
    rdfs:comment 'Foreign key linking to customer.risk_rating. Business justification: A KYC review event produces a formal risk rating determination. kyc_review_event currently stores new_risk_rating and prior_risk_rating as STRING denormalized values. Adding resulting_risk_rating_id a' ;
    rdfs:domain ind:KycReviewEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RiskRating .

ind:adverseMediaFindingsFlag rdf:type rdf:Property ;
    rdfs:label 'Adverse Media Findings Flag' ;
    rdfs:comment 'Indicates whether adverse media findings were identified during this review (True if adverse media found, False otherwise).' ;
    rdfs:domain ind:KycReviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:beneficialOwnershipVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Beneficial Ownership Verified Flag' ;
    rdfs:comment 'Indicates whether beneficial ownership information was verified during this review (True if verified, False otherwise). Applicable for legal entity customers.' ;
    rdfs:domain ind:KycReviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:documentsReviewedCount rdf:type rdf:Property ;
    rdfs:label 'Documents Reviewed Count' ;
    rdfs:comment 'The number of customer documents reviewed and validated during this KYC review event.' ;
    rdfs:domain ind:KycReviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:documentsUpdatedCount rdf:type rdf:Property ;
    rdfs:label 'Documents Updated Count' ;
    rdfs:comment 'The number of customer documents that were updated or refreshed as a result of this KYC review.' ;
    rdfs:domain ind:KycReviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:escalationReason rdf:type rdf:Property ;
    rdfs:label 'Escalation Reason' ;
    rdfs:comment 'Detailed reason for escalating this review to Enhanced Due Diligence or senior management, if applicable.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryMandateReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Mandate Reference' ;
    rdfs:comment 'Reference number or citation of the regulatory mandate or examination request that triggered this review, if applicable.' ;
    rdfs:domain ind:KycReviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipExitDate rdf:type rdf:Property ;
    rdfs:label 'Relationship Exit Date' ;
    rdfs:comment 'The date on which the customer relationship was exited or terminated as a result of this review, if applicable. Null if relationship continues.' ;
    rdfs:domain ind:KycReviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:relationshipExitReason rdf:type rdf:Property ;
    rdfs:label 'Relationship Exit Reason' ;
    rdfs:comment 'Detailed reason for exiting the customer relationship, if applicable.' ;
    rdfs:domain ind:KycReviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Review Completion Timestamp' ;
    rdfs:comment 'Timestamp when the KYC review process was completed.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reviewNotes rdf:type rdf:Property ;
    rdfs:label 'Review Notes' ;
    rdfs:comment 'Free-text notes and observations recorded by the reviewer during the KYC review process.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Review Reference Number' ;
    rdfs:comment 'Business-assigned unique reference number for this KYC review event, used for audit trail and regulatory reporting.' ;
    rdfs:domain ind:KycReviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewScope rdf:type rdf:Property ;
    rdfs:label 'Review Scope' ;
    rdfs:comment 'The scope or depth of the KYC review conducted (full comprehensive review, limited refresh, targeted investigation, or expedited review).' ;
    rdfs:domain ind:KycReviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Review Start Timestamp' ;
    rdfs:comment 'Timestamp when the KYC review process was initiated.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:riskRatingChangeFlag rdf:type rdf:Property ;
    rdfs:label 'Risk Rating Change Flag' ;
    rdfs:comment 'Indicates whether the risk rating changed as a result of this review (True if changed, False if no change).' ;
    rdfs:domain ind:KycReviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sarFiledFlag rdf:type rdf:Property ;
    rdfs:label 'Sar Filed Flag' ;
    rdfs:comment 'Indicates whether a Suspicious Activity Report was filed as a result of findings during this KYC review (True if SAR filed, False otherwise).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sarReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Sar Reference Number' ;
    rdfs:comment 'Reference number of the Suspicious Activity Report filed, if applicable. Null if no SAR was filed.' ;
    rdfs:domain ind:KycReviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceOfFundsVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Source Of Funds Verified Flag' ;
    rdfs:comment 'Indicates whether the source of funds was verified during this review (True if verified, False otherwise).' ;
    rdfs:domain ind:KycReviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceOfWealthVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Source Of Wealth Verified Flag' ;
    rdfs:comment 'Indicates whether the source of wealth was verified during this review (True if verified, False otherwise). Typically required for high-risk customers.' ;
    rdfs:domain ind:KycReviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:triggerReason rdf:type rdf:Property ;
    rdfs:label 'Trigger Reason' ;
    rdfs:comment 'Detailed explanation of the specific reason or event that triggered this KYC review (e.g., scheduled refresh, suspicious transaction alert, adverse media hit, regulatory request).' ;
    rdfs:domain ind:KycReviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partyRelationshipId rdf:type rdf:Property ;
    rdfs:label 'Party Relationship Id' ;
    rdfs:comment 'Unique identifier for the bilateral party relationship record. Primary key.' ;
    rdfs:domain ind:PartyRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryPartyId rdf:type rdf:Property ;
    rdfs:label 'Primary Party Id' ;
    rdfs:comment 'Foreign key reference to the first party in the bilateral relationship. This party holds the role defined in relationship_role_a.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:relationshipLimitCurrencyId rdf:type rdf:Property ;
    rdfs:label 'Relationship Limit Currency Id' ;
    rdfs:comment 'Foreign key linking to reference.currency. Business justification: Relationship credit limits (guarantor limits, exposure limits between related parties) are currency-denominated and require FX revaluation for consolidated exposure reporting and Basel large exposure ' ;
    rdfs:domain ind:PartyRelationship ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:documentType rdf:type rdf:Property ;
    rdfs:label 'Document Type' ;
    rdfs:comment 'Type of supporting document that establishes the relationship (e.g., guarantee agreement, power of attorney, authorization letter, trust deed, agency agreement, referral agreement).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kycVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Kyc Verification Date' ;
    rdfs:comment 'Date on which KYC verification for this relationship was last completed or updated.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:relationshipLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Relationship Limit Amount' ;
    rdfs:comment 'Monetary limit or cap associated with this relationship (e.g., maximum guarantee amount, authorization limit, credit exposure limit).' ;
    rdfs:domain ind:PartyRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:relationshipPercentage rdf:type rdf:Property ;
    rdfs:label 'Relationship Percentage' ;
    rdfs:comment 'Percentage value representing the extent or share of the relationship (e.g., guarantee coverage percentage, ownership percentage, authorization limit percentage). Range 0.00 to 100.00.' ;
    rdfs:domain ind:PartyRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:relationshipRoleA rdf:type rdf:Property ;
    rdfs:label 'Relationship Role A' ;
    rdfs:comment 'The role that Party A plays in this bilateral relationship (e.g., guarantor, borrower, co-applicant, authorized signatory, power of attorney, referral source, introducer). [ENUM-REF-CANDIDATE: guarantor|borrower|co_applicant|authorized_signatory|power_of_attorney|referral_source|introducer|beneficial_owner|trustee|custodian|nominee|agent|principal|counterparty|correspondent_bank — promote to reference product]' ;
    rdfs:domain ind:PartyRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipRoleB rdf:type rdf:Property ;
    rdfs:label 'Relationship Role B' ;
    rdfs:comment 'The role that Party B plays in this bilateral relationship (e.g., guarantor, borrower, co-applicant, authorized signatory, power of attorney, referral source, introducer). [ENUM-REF-CANDIDATE: guarantor|borrower|co_applicant|authorized_signatory|power_of_attorney|referral_source|introducer|beneficial_owner|trustee|custodian|nominee|agent|principal|counterparty|correspondent_bank — promote to reference product]' ;
    rdfs:domain ind:PartyRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipSource rdf:type rdf:Property ;
    rdfs:label 'Relationship Source' ;
    rdfs:comment 'Source or channel through which this relationship was established (e.g., direct, referral, branch, online, third party, data migration).' ;
    rdfs:domain ind:PartyRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipStrength rdf:type rdf:Property ;
    rdfs:label 'Relationship Strength' ;
    rdfs:comment 'Indicator of the relationship importance or priority level (e.g., primary, secondary, tertiary) for credit exposure aggregation and risk assessment.' ;
    rdfs:domain ind:PartyRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partyIdentifierId rdf:type rdf:Property ;
    rdfs:label 'Party Identifier Id' ;
    rdfs:comment 'Unique identifier for the party identifier record. Primary key for this entity.' ;
    rdfs:domain ind:PartyIdentifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deduplicationKey rdf:type rdf:Property ;
    rdfs:label 'Deduplication Key' ;
    rdfs:comment 'Normalized or hashed representation of the identifier value used for deduplication and matching across systems. Supports golden record management and cross-system reconciliation by providing a standardized matching key that accounts for formatting variations.' ;
    rdfs:domain ind:PartyIdentifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identifierStatus rdf:type rdf:Property ;
    rdfs:label 'Identifier Status' ;
    rdfs:comment 'Current lifecycle status of the identifier. Indicates whether the identifier is currently valid and usable for business operations, regulatory reporting, and cross-system reconciliation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identifierValue rdf:type rdf:Property ;
    rdfs:label 'Identifier Value' ;
    rdfs:comment 'The actual identifier value or number assigned to the party. This is the unique alphanumeric string that represents the party in the external or internal system (e.g., the 20-character LEI code, the 8 or 11-character SWIFT BIC, the 9-digit DUNS number, the CIF account number, the tax identification number, passport number, or national ID number).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:issuingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Issuing Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code representing the country or jurisdiction where the identifier was issued. Used for regulatory reporting and jurisdiction-based risk assessment.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastUpdatedBy rdf:type rdf:Property ;
    rdfs:label 'Last Updated By' ;
    rdfs:comment 'The user ID, employee ID, or system process name that last modified this identifier record. Supports audit trail requirements and accountability for data changes.' ;
    rdfs:domain ind:PartyIdentifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationSource rdf:type rdf:Property ;
    rdfs:label 'Verification Source' ;
    rdfs:comment 'The name of the system, service, or authority used to verify the identifier. Examples include GLEIF API for LEI verification, SWIFT directory for BIC verification, Dun & Bradstreet API for DUNS verification, government registry for national ID or passport verification, or internal compliance system name.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuanceCountryId rdf:type rdf:Property ;
    rdfs:label 'Issuance Country Id' ;
    rdfs:comment 'Foreign key linking to reference.country. Business justification: Country of issuance determines legal jurisdiction, tax treatment, and regulatory reporting requirements. Critical for sanctions screening, country risk limits, and Basel country exposure reporting. Ro' ;
    rdfs:domain ind:Instrument ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:underlyingInstrumentId rdf:type rdf:Property ;
    rdfs:label 'Underlying Instrument Id' ;
    rdfs:comment 'Reference to the underlying instrument for derivatives and structured products. Links to another instrument record.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Instrument .

ind:bloombergTicker rdf:type rdf:Property ;
    rdfs:label 'Bloomberg Ticker' ;
    rdfs:comment 'Bloomberg proprietary ticker symbol used to identify the instrument in Bloomberg Terminal systems.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callableFlag rdf:type rdf:Property ;
    rdfs:label 'Callable Flag' ;
    rdfs:comment 'Indicates whether the issuer has the right to redeem the instrument before maturity.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cfiCode rdf:type rdf:Property ;
    rdfs:label 'Cfi Code' ;
    rdfs:comment '6-character ISO standard code classifying the instrument by category, group, and attributes.' ;
    rdfs:domain ind:Instrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:convertibleFlag rdf:type rdf:Property ;
    rdfs:label 'Convertible Flag' ;
    rdfs:comment 'Indicates whether the instrument can be converted into another security (typically equity).' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:countryOfRisk rdf:type rdf:Property ;
    rdfs:label 'Country Of Risk' ;
    rdfs:comment '3-letter ISO country code representing the primary country exposure for risk management purposes.' ;
    rdfs:domain ind:Instrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:couponFrequency rdf:type rdf:Property ;
    rdfs:label 'Coupon Frequency' ;
    rdfs:comment 'Frequency at which coupon payments are made to holders of the instrument.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cusip rdf:type rdf:Property ;
    rdfs:label 'Cusip' ;
    rdfs:comment '9-character alphanumeric code identifying North American financial securities. Format: 6-character issuer code + 2-character issue code + 1 check digit.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeCode rdf:type rdf:Property ;
    rdfs:label 'Exchange Code' ;
    rdfs:comment '4-character ISO code identifying the primary exchange or trading venue where the instrument is listed.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exerciseStyle rdf:type rdf:Property ;
    rdfs:label 'Exercise Style' ;
    rdfs:comment 'Defines when the option can be exercised: American (any time), European (at expiry only), or Bermudan (specific dates).' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:faceValue rdf:type rdf:Property ;
    rdfs:label 'Face Value' ;
    rdfs:comment 'Nominal or par value of the instrument at issuance. Represents the principal amount for debt instruments.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:figi rdf:type rdf:Property ;
    rdfs:label 'Figi' ;
    rdfs:comment '12-character alphanumeric code assigned to financial instruments by the Object Management Group (OMG). Provides a universal identifier across asset classes.' ;
    rdfs:domain ind:Instrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstCouponDate rdf:type rdf:Property ;
    rdfs:label 'First Coupon Date' ;
    rdfs:comment 'Date of the first coupon payment for fixed income instruments. Applicable to bonds and structured products.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:instrumentName rdf:type rdf:Property ;
    rdfs:label 'Instrument Name' ;
    rdfs:comment 'Full legal name or description of the financial instrument as registered with the issuer or exchange.' ;
    rdfs:domain ind:Instrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isin rdf:type rdf:Property ;
    rdfs:label 'Isin' ;
    rdfs:comment '12-character alphanumeric code that uniquely identifies a security globally. Format: 2-letter country code + 9-character alphanumeric national security identifier + 1 check digit.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotSize rdf:type rdf:Property ;
    rdfs:label 'Lot Size' ;
    rdfs:comment 'Minimum trading unit or contract size for the instrument. Represents the number of units per lot.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optionType rdf:type rdf:Property ;
    rdfs:label 'Option Type' ;
    rdfs:comment 'Specifies whether the option is a call (right to buy) or put (right to sell).' ;
    rdfs:domain ind:Instrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:puttableFlag rdf:type rdf:Property ;
    rdfs:label 'Puttable Flag' ;
    rdfs:comment 'Indicates whether the holder has the right to sell the instrument back to the issuer before maturity.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reutersRic rdf:type rdf:Property ;
    rdfs:label 'Reuters Ric' ;
    rdfs:comment 'Reuters proprietary instrument code used to identify the security in Refinitiv systems.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sedol rdf:type rdf:Property ;
    rdfs:label 'Sedol' ;
    rdfs:comment '7-character alphanumeric code identifying securities traded on the London Stock Exchange and other UK exchanges. Format: 6-character identifier + 1 check digit.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seniority rdf:type rdf:Property ;
    rdfs:label 'Seniority' ;
    rdfs:comment 'Priority ranking of the instrument in the issuer\'s capital structure for claim settlement in case of default.' ;
    rdfs:domain ind:Instrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementConvention rdf:type rdf:Property ;
    rdfs:label 'Settlement Convention' ;
    rdfs:comment 'Standard number of business days between trade date and settlement date for this instrument.' ;
    rdfs:domain ind:Instrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortName rdf:type rdf:Property ;
    rdfs:label 'Short Name' ;
    rdfs:comment 'Abbreviated or display name of the instrument used for reporting and user interfaces.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Status Effective Date' ;
    rdfs:comment 'Date on which the current lifecycle status became effective.' ;
    rdfs:domain ind:Instrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:strikePrice rdf:type rdf:Property ;
    rdfs:label 'Strike Price' ;
    rdfs:comment 'Exercise price for options and warrants. The price at which the holder can buy or sell the underlying asset.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:subAssetClass rdf:type rdf:Property ;
    rdfs:label 'Sub Asset Class' ;
    rdfs:comment 'Granular sub-classification within the instrument type for detailed risk and reporting segmentation.' ;
    rdfs:domain ind:Instrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradingCurrency rdf:type rdf:Property ;
    rdfs:label 'Trading Currency' ;
    rdfs:comment '3-letter ISO currency code representing the currency in which the instrument is traded on the exchange.' ;
    rdfs:domain ind:Instrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equityId rdf:type rdf:Property ;
    rdfs:label 'Equity Id' ;
    rdfs:comment 'Unique identifier for the equity instrument record. Primary key.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Equity .

ind:listingCountryId rdf:type rdf:Property ;
    rdfs:label 'Listing Country Id' ;
    rdfs:comment 'Foreign key linking to reference.country. Business justification: Equity listing country drives withholding tax rates on dividends, FATCA/CRS reporting obligations, and short-selling restrictions. A tax operations or compliance team needs the primary listing country' ;
    rdfs:domain ind:Equity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:parValueCurrencyId rdf:type rdf:Property ;
    rdfs:label 'Par Value Currency Id' ;
    rdfs:comment 'Foreign key linking to reference.currency. Business justification: Par value currency determines corporate action entitlements (stock splits, dividends). Distinct from trading currency. Essential for accurate entitlement calculations in multi-currency equity portfoli' ;
    rdfs:domain ind:Equity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:adrRatio rdf:type rdf:Property ;
    rdfs:label 'Adr Ratio' ;
    rdfs:comment 'Ratio expressing how many underlying foreign shares one ADR represents (e.g., 1:5 means one ADR equals five foreign shares).' ;
    rdfs:domain ind:Equity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cumulativeDividendFlag rdf:type rdf:Property ;
    rdfs:label 'Cumulative Dividend Flag' ;
    rdfs:comment 'Indicates whether unpaid dividends on preferred stock accumulate and must be paid before common stock dividends.' ;
    rdfs:domain ind:Equity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:delistingDate rdf:type rdf:Property ;
    rdfs:label 'Delisting Date' ;
    rdfs:comment 'Date on which the equity was removed from exchange listing, if applicable.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:depositaryBank rdf:type rdf:Property ;
    rdfs:label 'Depositary Bank' ;
    rdfs:comment 'Name of the financial institution acting as depositary for ADRs or GDRs.' ;
    rdfs:domain ind:Equity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dividendEligibility rdf:type rdf:Property ;
    rdfs:label 'Dividend Eligibility' ;
    rdfs:comment 'Indicates whether this equity class is eligible to receive dividend distributions.' ;
    rdfs:domain ind:Equity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dividendFrequency rdf:type rdf:Property ;
    rdfs:label 'Dividend Frequency' ;
    rdfs:comment 'Frequency at which dividends are paid to shareholders.' ;
    rdfs:domain ind:Equity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dividendRate rdf:type rdf:Property ;
    rdfs:label 'Dividend Rate' ;
    rdfs:comment 'Annual dividend rate per share for preferred stock or fixed-dividend equities, expressed as a percentage of par value or absolute amount.' ;
    rdfs:domain ind:Equity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:equityName rdf:type rdf:Property ;
    rdfs:label 'Equity Name' ;
    rdfs:comment 'Full legal name of the equity security as registered with the issuer and exchange.' ;
    rdfs:domain ind:Equity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equityStatus rdf:type rdf:Property ;
    rdfs:label 'Equity Status' ;
    rdfs:comment 'Current lifecycle status of the equity instrument.' ;
    rdfs:domain ind:Equity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equityType rdf:type rdf:Property ;
    rdfs:label 'Equity Type' ;
    rdfs:comment 'Classification of the equity instrument: common stock, preferred stock, American Depositary Receipt (ADR), Global Depositary Receipt (GDR), Exchange-Traded Fund (ETF), or Real Estate Investment Trust (REIT).' ;
    rdfs:domain ind:Equity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:floatShares rdf:type rdf:Property ;
    rdfs:label 'Float Shares' ;
    rdfs:comment 'Number of shares available for public trading, excluding restricted shares held by insiders and large institutional holders.' ;
    rdfs:domain ind:Equity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gicsIndustryCode rdf:type rdf:Property ;
    rdfs:label 'Gics Industry Code' ;
    rdfs:comment 'Six-digit code representing the GICS industry classification of the issuer.' ;
    rdfs:domain ind:Equity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gicsIndustryGroupCode rdf:type rdf:Property ;
    rdfs:label 'Gics Industry Group Code' ;
    rdfs:comment 'Four-digit code representing the GICS industry group classification of the issuer.' ;
    rdfs:domain ind:Equity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gicsSectorCode rdf:type rdf:Property ;
    rdfs:label 'Gics Sector Code' ;
    rdfs:comment 'Two-digit code representing the GICS sector classification of the issuer (e.g., 10=Energy, 20=Materials, 45=Information Technology).' ;
    rdfs:domain ind:Equity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gicsSubIndustryCode rdf:type rdf:Property ;
    rdfs:label 'Gics Sub Industry Code' ;
    rdfs:comment 'Eight-digit code representing the most granular GICS sub-industry classification of the issuer.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indexMembership rdf:type rdf:Property ;
    rdfs:label 'Index Membership' ;
    rdfs:comment 'Comma-separated list of major indices in which this equity is a constituent (e.g., S&P 500, DJIA, NASDAQ-100, MSCI World, Russell 2000).' ;
    rdfs:domain ind:Equity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:listingDate rdf:type rdf:Property ;
    rdfs:label 'Listing Date' ;
    rdfs:comment 'Date on which the equity was first listed and began trading on the primary exchange.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:marketCapTier rdf:type rdf:Property ;
    rdfs:label 'Market Cap Tier' ;
    rdfs:comment 'Classification of the equity based on market capitalization size: mega-cap (>$200B), large-cap ($10B-$200B), mid-cap ($2B-$10B), small-cap ($300M-$2B), micro-cap ($50M-$300M), nano-cap (<$50M).' ;
    rdfs:domain ind:Equity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parValue rdf:type rdf:Property ;
    rdfs:label 'Par Value' ;
    rdfs:comment 'Nominal or face value of one share as stated in the corporate charter, used for accounting and legal purposes.' ;
    rdfs:domain ind:Equity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:participatingFlag rdf:type rdf:Property ;
    rdfs:label 'Participating Flag' ;
    rdfs:comment 'Indicates whether preferred stockholders can receive additional dividends beyond the stated rate if common stockholders receive dividends above a certain threshold.' ;
    rdfs:domain ind:Equity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryExchange rdf:type rdf:Property ;
    rdfs:label 'Primary Exchange' ;
    rdfs:comment 'Market Identifier Code (MIC) of the primary exchange where the equity is listed and traded.' ;
    rdfs:domain ind:Equity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shareClass rdf:type rdf:Property ;
    rdfs:label 'Share Class' ;
    rdfs:comment 'Designation of the share class (e.g., Class A, Class B, Class C) indicating different rights, voting power, or dividend structures.' ;
    rdfs:domain ind:Equity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sharesAuthorized rdf:type rdf:Property ;
    rdfs:label 'Shares Authorized' ;
    rdfs:comment 'Maximum number of shares the corporation is legally permitted to issue as defined in the corporate charter.' ;
    rdfs:domain ind:Equity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tickerSymbol rdf:type rdf:Property ;
    rdfs:label 'Ticker Symbol' ;
    rdfs:comment 'Exchange-specific trading symbol used to identify the equity on trading platforms.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradingStatus rdf:type rdf:Property ;
    rdfs:label 'Trading Status' ;
    rdfs:comment 'Current real-time trading status on the exchange.' ;
    rdfs:domain ind:Equity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:underlyingSecurityIsin rdf:type rdf:Property ;
    rdfs:label 'Underlying Security Isin' ;
    rdfs:comment 'ISIN of the underlying foreign security for ADRs and GDRs.' ;
    rdfs:domain ind:Equity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:votingRights rdf:type rdf:Property ;
    rdfs:label 'Voting Rights' ;
    rdfs:comment 'Indicates whether the equity carries voting rights and the type: voting (standard one share one vote), non-voting, limited voting, or super voting (multiple votes per share).' ;
    rdfs:domain ind:Equity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fixedIncomeId rdf:type rdf:Property ;
    rdfs:label 'Fixed Income Id' ;
    rdfs:comment 'Unique identifier for the fixed income instrument record. Primary key for the fixed income master data product.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FixedIncome .

ind:callDate rdf:type rdf:Property ;
    rdfs:label 'Call Date' ;
    rdfs:comment 'Earliest date on which the issuer may exercise the call option to redeem the bond. Null if the bond is not callable.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:callPrice rdf:type rdf:Property ;
    rdfs:label 'Call Price' ;
    rdfs:comment 'Price at which the issuer may redeem the bond if the call option is exercised. Often expressed as a percentage of face value plus accrued interest.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:convexity rdf:type rdf:Property ;
    rdfs:label 'Convexity' ;
    rdfs:comment 'Measure of the curvature in the relationship between bond prices and yields. Used to refine duration-based interest rate risk estimates for large rate movements.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:couponType rdf:type rdf:Property ;
    rdfs:label 'Coupon Type' ;
    rdfs:comment 'Classification of the coupon payment structure. Fixed coupons pay a constant rate, floating coupons reset periodically based on a reference rate, zero coupon bonds pay no periodic interest.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditRatingFitch rdf:type rdf:Property ;
    rdfs:label 'Credit Rating Fitch' ;
    rdfs:comment 'Credit quality assessment assigned by Fitch Ratings. Ranges from AAA (highest quality) to D (default). Used for portfolio risk management and regulatory reporting.' ;
    rdfs:domain ind:FixedIncome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:duration rdf:type rdf:Property ;
    rdfs:label 'Duration' ;
    rdfs:comment 'Measure of the bond\'s price sensitivity to changes in interest rates, expressed in years. Critical for interest rate risk management and ALM gap analysis.' ;
    rdfs:domain ind:FixedIncome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fixedIncomeStatus rdf:type rdf:Property ;
    rdfs:label 'Fixed Income Status' ;
    rdfs:comment 'Current state of the bond in its lifecycle. Active bonds are trading normally, matured bonds have reached their maturity date, called bonds have been redeemed early, defaulted bonds have missed payments.' ;
    rdfs:domain ind:FixedIncome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:floatingRateSpread rdf:type rdf:Property ;
    rdfs:label 'Floating Rate Spread' ;
    rdfs:comment 'Fixed spread in basis points added to the reference index rate to determine the coupon rate for floating-rate bonds. Reflects issuer credit risk and market conditions at issuance.' ;
    rdfs:domain ind:FixedIncome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastCouponDate rdf:type rdf:Property ;
    rdfs:label 'Last Coupon Date' ;
    rdfs:comment 'Date of the final scheduled coupon payment before maturity. Typically occurs on or shortly before the maturity date.' ;
    rdfs:domain ind:FixedIncome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priceDate rdf:type rdf:Property ;
    rdfs:label 'Price Date' ;
    rdfs:comment 'Date on which the current market price was observed or calculated. Critical for fair value accounting and regulatory reporting.' ;
    rdfs:domain ind:FixedIncome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:putDate rdf:type rdf:Property ;
    rdfs:label 'Put Date' ;
    rdfs:comment 'Earliest date on which the bondholder may exercise the put option to sell the bond back to the issuer. Null if the bond is not puttable.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:putPrice rdf:type rdf:Property ;
    rdfs:label 'Put Price' ;
    rdfs:comment 'Price at which the bondholder may sell the bond back to the issuer if the put option is exercised. Typically at or near par value.' ;
    rdfs:domain ind:FixedIncome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resetFrequency rdf:type rdf:Property ;
    rdfs:label 'Reset Frequency' ;
    rdfs:comment 'Frequency at which the coupon rate is recalculated based on the current reference index rate for floating-rate bonds. Determines interest rate risk exposure.' ;
    rdfs:domain ind:FixedIncome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sinkingFundFlag rdf:type rdf:Property ;
    rdfs:label 'Sinking Fund Flag' ;
    rdfs:comment 'Indicates whether the bond has a sinking fund provision requiring the issuer to retire a portion of the bond issue periodically before maturity. Reduces credit risk but may limit upside.' ;
    rdfs:domain ind:FixedIncome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:yieldToMaturity rdf:type rdf:Property ;
    rdfs:label 'Yield To Maturity' ;
    rdfs:comment 'Total return anticipated on the bond if held until maturity, expressed as an annual rate. Incorporates coupon payments, principal repayment, and current market price.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:derivativeId rdf:type rdf:Property ;
    rdfs:label 'Derivative Id' ;
    rdfs:comment 'Unique identifier for the derivative instrument. Primary key.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Derivative .

ind:referenceLoanFacilityId rdf:type rdf:Property ;
    rdfs:label 'Reference Loan Facility Id' ;
    rdfs:comment 'Foreign key linking to loan.facility. Business justification: Credit derivatives (CDS, total return swaps, credit-linked notes) referencing loan facilities as underlying exposure require facility identification for mark-to-market valuation, credit event determin' ;
    rdfs:domain ind:Derivative ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:reportingJurisdictionId rdf:type rdf:Property ;
    rdfs:label 'Reporting Jurisdiction Id' ;
    rdfs:comment 'Foreign key linking to reference.jurisdiction. Business justification: Derivatives carry a reporting_obligation field and are subject to jurisdiction-specific trade reporting rules (EMIR in EU, Dodd-Frank in US, MAS in Singapore). Compliance teams need the reporting juri' ;
    rdfs:domain ind:Derivative ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Jurisdiction .

ind:barrierLevel rdf:type rdf:Property ;
    rdfs:label 'Barrier Level' ;
    rdfs:comment 'Price threshold that activates (knock-in) or deactivates (knock-out) the derivative contract. Used in barrier options and structured products.' ;
    rdfs:domain ind:Derivative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:barrierType rdf:type rdf:Property ;
    rdfs:label 'Barrier Type' ;
    rdfs:comment 'Classification of barrier feature: knock-in (option activates when barrier is breached), knock-out (option terminates when barrier is breached), double-barrier (both upper and lower barriers), or none for non-barrier derivatives.' ;
    rdfs:domain ind:Derivative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cvaAmount rdf:type rdf:Property ;
    rdfs:label 'Cva Amount' ;
    rdfs:comment 'Adjustment to the mark-to-market value reflecting the counterparty credit risk. Calculated based on probability of default (PD), loss given default (LGD), and exposure at default (EAD).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:derivativeType rdf:type rdf:Property ;
    rdfs:label 'Derivative Type' ;
    rdfs:comment 'Classification of the derivative instrument by contract structure: swap, forward, future, option, swaption, credit default swap (CDS), total return swap, variance swap, or exotic derivative. [ENUM-REF-CANDIDATE: swap|forward|future|option|swaption|credit_default_swap|total_return_swap|variance_swap|exotic — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Derivative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initialMargin rdf:type rdf:Property ;
    rdfs:label 'Initial Margin' ;
    rdfs:comment 'Collateral posted at trade inception to cover potential future exposure. Required for non-cleared derivatives under EMIR and Dodd-Frank margin rules.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marginCurrency rdf:type rdf:Property ;
    rdfs:label 'Margin Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code in which initial and variation margin are posted.' ;
    rdfs:domain ind:Derivative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:markToMarketValue rdf:type rdf:Property ;
    rdfs:label 'Mark To Market Value' ;
    rdfs:comment 'Current fair value of the derivative contract based on prevailing market prices and valuation models. Updated daily for profit and loss (PnL) attribution and CVA calculation.' ;
    rdfs:domain ind:Derivative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mtmCurrency rdf:type rdf:Property ;
    rdfs:label 'Mtm Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code in which the mark-to-market value is denominated.' ;
    rdfs:domain ind:Derivative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strikeCurrency rdf:type rdf:Property ;
    rdfs:label 'Strike Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the strike price. Relevant for FX options and cross-currency derivatives.' ;
    rdfs:domain ind:Derivative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeRepositoryReference rdf:type rdf:Property ;
    rdfs:label 'Trade Repository Reference' ;
    rdfs:comment 'Identifier assigned by the trade repository where the derivative transaction is reported under EMIR or Dodd-Frank regulations.' ;
    rdfs:domain ind:Derivative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variationMargin rdf:type rdf:Property ;
    rdfs:label 'Variation Margin' ;
    rdfs:comment 'Daily collateral exchange based on mark-to-market movements. Ensures that counterparty exposure is fully collateralized on a daily basis.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentIssuerId rdf:type rdf:Property ;
    rdfs:label 'Parent Issuer Id' ;
    rdfs:comment 'Reference to the immediate parent entity in the corporate hierarchy. Used for consolidated risk reporting and group exposure aggregation under Basel III.' ;
    rdfs:domain ind:Issuer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Issuer .

ind:primaryUltimateParentIssuerId rdf:type rdf:Property ;
    rdfs:label 'Primary Ultimate Parent Issuer Id' ;
    rdfs:comment 'Reference to the top-level parent entity in the corporate hierarchy. Critical for ultimate risk aggregation, large exposure monitoring, and CCAR/DFAST stress testing.' ;
    rdfs:domain ind:Issuer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Issuer .

ind:bloombergIssuerCode rdf:type rdf:Property ;
    rdfs:label 'Bloomberg Issuer Code' ;
    rdfs:comment 'Bloomberg\'s proprietary issuer identifier used for market data integration, pricing feeds, and reference data synchronization with Bloomberg Terminal.' ;
    rdfs:domain ind:Issuer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fitchIssuerRating rdf:type rdf:Property ;
    rdfs:label 'Fitch Issuer Rating' ;
    rdfs:comment 'Current long-term issuer default rating assigned by Fitch Ratings. Provides third opinion for credit risk triangulation.' ;
    rdfs:domain ind:Issuer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fitchRatingDate rdf:type rdf:Property ;
    rdfs:label 'Fitch Rating Date' ;
    rdfs:comment 'Date when the current Fitch issuer rating was assigned or last affirmed.' ;
    rdfs:domain ind:Issuer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fitchRatingOutlook rdf:type rdf:Property ;
    rdfs:label 'Fitch Rating Outlook' ;
    rdfs:comment 'Fitch\'s assessment of the potential direction of the issuer rating over a one to two-year period.' ;
    rdfs:domain ind:Issuer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalLgd rdf:type rdf:Property ;
    rdfs:label 'Internal Lgd' ;
    rdfs:comment 'Bank\'s estimate of the economic loss as a percentage of Exposure at Default if the issuer defaults. Expressed as percentage (e.g., 45.00 = 45%). Used for IRB capital and expected loss calculations.' ;
    rdfs:domain ind:Issuer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:internalPd rdf:type rdf:Property ;
    rdfs:label 'Internal Pd' ;
    rdfs:comment 'Bank\'s estimate of the one-year probability of default for the issuer, expressed as a decimal (e.g., 0.015 = 1.5%). Core input for IRB capital calculations and CECL/IFRS 9 expected credit loss provisioning.' ;
    rdfs:domain ind:Issuer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isFinancialInstitution rdf:type rdf:Property ;
    rdfs:label 'Is Financial Institution' ;
    rdfs:comment 'Boolean indicator whether the issuer is classified as a financial institution under Basel III. Determines interbank exposure treatment and contagion risk assessment.' ;
    rdfs:domain ind:Issuer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isInvestmentGrade rdf:type rdf:Property ;
    rdfs:label 'Is Investment Grade' ;
    rdfs:comment 'Boolean indicator whether the issuer\'s credit rating meets investment grade threshold (BBB-/Baa3 or higher). Used for portfolio mandate compliance and risk appetite limits.' ;
    rdfs:domain ind:Issuer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPublicSectorEntity rdf:type rdf:Property ;
    rdfs:label 'Is Public Sector Entity' ;
    rdfs:comment 'Boolean indicator whether the issuer is a public sector entity eligible for preferential risk weighting under Basel III Standardized Approach.' ;
    rdfs:domain ind:Issuer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuerStatus rdf:type rdf:Property ;
    rdfs:label 'Issuer Status' ;
    rdfs:comment 'Current lifecycle status of the issuer entity. Inactive, merged, or bankrupt issuers require special handling for legacy securities and credit event processing.' ;
    rdfs:domain ind:Issuer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuerType rdf:type rdf:Property ;
    rdfs:label 'Issuer Type' ;
    rdfs:comment 'Classification of the issuer entity type. Determines applicable regulatory treatment, credit risk methodology, and capital requirements under Basel III.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moodysIssuerRating rdf:type rdf:Property ;
    rdfs:label 'Moodys Issuer Rating' ;
    rdfs:comment 'Current long-term issuer rating assigned by Moody\'s Investors Service. Used for credit risk assessment, portfolio limits, and regulatory capital calculations.' ;
    rdfs:domain ind:Issuer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moodysRatingDate rdf:type rdf:Property ;
    rdfs:label 'Moodys Rating Date' ;
    rdfs:comment 'Date when the current Moody\'s issuer rating was assigned or last affirmed.' ;
    rdfs:domain ind:Issuer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:moodysRatingOutlook rdf:type rdf:Property ;
    rdfs:label 'Moodys Rating Outlook' ;
    rdfs:comment 'Moody\'s opinion on the likely direction of the issuer rating over the medium term.' ;
    rdfs:domain ind:Issuer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryExchangeCode rdf:type rdf:Property ;
    rdfs:label 'Primary Exchange Code' ;
    rdfs:comment 'ISO 10383 Market Identifier Code (MIC) for the issuer\'s primary listing exchange. Used for market data sourcing and trading venue identification.' ;
    rdfs:domain ind:Issuer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spIssuerCreditRating rdf:type rdf:Property ;
    rdfs:label 'Sp Issuer Credit Rating' ;
    rdfs:comment 'Current long-term issuer credit rating assigned by Standard & Poor\'s. Used for credit risk assessment, RWA calculation under Standardized Approach, and investment policy compliance.' ;
    rdfs:domain ind:Issuer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spRatingDate rdf:type rdf:Property ;
    rdfs:label 'Sp Rating Date' ;
    rdfs:comment 'Date when the current S&P issuer credit rating was assigned or last affirmed. Critical for determining rating staleness in credit risk models.' ;
    rdfs:domain ind:Issuer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:spRatingOutlook rdf:type rdf:Property ;
    rdfs:label 'Sp Rating Outlook' ;
    rdfs:comment 'S&P\'s forward-looking opinion on the potential direction of the issuer credit rating over the intermediate term (typically 6-24 months).' ;
    rdfs:domain ind:Issuer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:websiteUrl rdf:type rdf:Property ;
    rdfs:label 'Website Url' ;
    rdfs:comment 'Official corporate website URL for the issuer. Used for investor relations access and ESG data sourcing.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByPriceId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Price Id' ;
    rdfs:comment 'Reference to the price_id of the corrected observation that supersedes this record. Null if this is the current valid observation.' ;
    rdfs:domain ind:Price ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Price .

ind:adjustedClosePrice rdf:type rdf:Property ;
    rdfs:label 'Adjusted Close Price' ;
    rdfs:comment 'The closing price adjusted for corporate actions (stock splits, dividends, rights issues) to maintain historical price continuity for performance analysis.' ;
    rdfs:domain ind:Price ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:askPrice rdf:type rdf:Property ;
    rdfs:label 'Ask Price' ;
    rdfs:comment 'The lowest price a seller is willing to accept for the security at the observation time. Used for liquidity analysis and bid-ask spread calculation.' ;
    rdfs:domain ind:Price ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bidPrice rdf:type rdf:Property ;
    rdfs:label 'Bid Price' ;
    rdfs:comment 'The highest price a buyer is willing to pay for the security at the observation time. Used for liquidity analysis and bid-ask spread calculation.' ;
    rdfs:domain ind:Price ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:changeAmount rdf:type rdf:Property ;
    rdfs:label 'Change Amount' ;
    rdfs:comment 'The absolute change in price from the previous observation, calculated as current price minus prior price. Used for volatility analysis and market movement tracking.' ;
    rdfs:domain ind:Price ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:changePercentage rdf:type rdf:Property ;
    rdfs:label 'Change Percentage' ;
    rdfs:comment 'The percentage change in price from the previous observation, calculated as ((current price - prior price) / prior price) * 100. Used for performance attribution and trend analysis.' ;
    rdfs:domain ind:Price ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confidenceScore rdf:type rdf:Property ;
    rdfs:label 'Confidence Score' ;
    rdfs:comment 'A quantitative measure (0.0000 to 1.0000) representing the confidence or reliability of the price observation, derived from source quality, market liquidity, and validation checks.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:correctionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Correction Reason Code' ;
    rdfs:comment 'Standardized code explaining why a price observation was corrected or superseded. Supports audit trail and data quality monitoring.' ;
    rdfs:domain ind:Price ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:highPrice rdf:type rdf:Property ;
    rdfs:label 'High Price' ;
    rdfs:comment 'The highest traded price of the security during the trading session or observation period.' ;
    rdfs:domain ind:Price ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isSuperseded rdf:type rdf:Property ;
    rdfs:label 'Is Superseded' ;
    rdfs:comment 'Boolean flag indicating whether this price observation has been superseded by a subsequent correction or restatement. Supports immutable append-only architecture.' ;
    rdfs:domain ind:Price ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastTradePrice rdf:type rdf:Property ;
    rdfs:label 'Last Trade Price' ;
    rdfs:comment 'The price at which the most recent trade was executed for this instrument. Represents actual market transaction price.' ;
    rdfs:domain ind:Price ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lowPrice rdf:type rdf:Property ;
    rdfs:label 'Low Price' ;
    rdfs:comment 'The lowest traded price of the security during the trading session or observation period.' ;
    rdfs:domain ind:Price ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:midPrice rdf:type rdf:Property ;
    rdfs:label 'Mid Price' ;
    rdfs:comment 'The midpoint between bid and ask prices, calculated as (bid + ask) / 2. Commonly used for fair value estimation and portfolio valuation.' ;
    rdfs:domain ind:Price ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:notation rdf:type rdf:Property ;
    rdfs:label 'Notation' ;
    rdfs:comment 'The format in which the price is expressed: decimal (e.g., 105.50), percentage (e.g., 98.75%), yield (e.g., 3.25%), basis points, or fractional (e.g., 32nds for US Treasuries).' ;
    rdfs:domain ind:Price ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:observationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Observation Timestamp' ;
    rdfs:comment 'The timestamp when this price record was captured and appended to the immutable time-series. Distinct from pricing_timestamp; supports data lineage and audit.' ;
    rdfs:domain ind:Price ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:officialClosePrice rdf:type rdf:Property ;
    rdfs:label 'Official Close Price' ;
    rdfs:comment 'The official closing price published by the exchange or pricing authority at end of trading day. Used for Net Asset Value (NAV) calculation and regulatory reporting.' ;
    rdfs:domain ind:Price ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:openPrice rdf:type rdf:Property ;
    rdfs:label 'Open Price' ;
    rdfs:comment 'The first traded price of the security at the start of the trading session.' ;
    rdfs:domain ind:Price ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceSource rdf:type rdf:Property ;
    rdfs:label 'Price Source' ;
    rdfs:comment 'The originating system or vendor that provided this price observation (e.g., Bloomberg, Reuters/Refinitiv, exchange feed, broker quote, internal valuation model). [ENUM-REF-CANDIDATE: bloomberg|reuters|refinitiv|exchange_feed|broker_quote|internal_model|vendor — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Price ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceStatus rdf:type rdf:Property ;
    rdfs:label 'Price Status' ;
    rdfs:comment 'The current status of pricing for this instrument: active (normal trading), suspended (temporarily halted), halted (trading stopped), delisted (removed from exchange), matured (instrument expired).' ;
    rdfs:domain ind:Price ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceType rdf:type rdf:Property ;
    rdfs:label 'Price Type' ;
    rdfs:comment 'Classification of the price observation: market (actual traded price), model (derived from valuation model), indicative (non-binding quote), official (exchange-published), closing (end-of-day), opening (start-of-day).' ;
    rdfs:domain ind:Price ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pricing Timestamp' ;
    rdfs:comment 'The precise date and time when this price observation was recorded or became effective. Critical for intraday Mark-to-Market (MTM) and trade execution analysis.' ;
    rdfs:domain ind:Price ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:qualityFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Flag' ;
    rdfs:comment 'Indicator of the reliability and timeliness of the price observation. Verified = confirmed by multiple sources; stale = outdated; estimated = model-derived; challenged = disputed or under review.' ;
    rdfs:domain ind:Price ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryPriceFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Price Flag' ;
    rdfs:comment 'Boolean flag indicating whether this price observation is used for regulatory reporting purposes (e.g., CCAR, DFAST, Basel III stress testing, IFRS 9 fair value measurement).' ;
    rdfs:domain ind:Price ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:spreadToBenchmarkBps rdf:type rdf:Property ;
    rdfs:label 'Spread To Benchmark Bps' ;
    rdfs:comment 'The yield spread over a benchmark rate (e.g., LIBOR, SOFR, Treasury) expressed in basis points (BPS). Used for credit risk assessment and relative value analysis.' ;
    rdfs:domain ind:Price ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tradingSession rdf:type rdf:Property ;
    rdfs:label 'Trading Session' ;
    rdfs:comment 'Identifies the trading session during which the price observation was recorded (pre-market, regular hours, after-hours, overnight).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volume rdf:type rdf:Property ;
    rdfs:label 'Volume' ;
    rdfs:comment 'The total number of units (shares, bonds, contracts) traded during the observation period. Used for liquidity assessment and market depth analysis.' ;
    rdfs:domain ind:Price ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vwap rdf:type rdf:Property ;
    rdfs:label 'Vwap' ;
    rdfs:comment 'The average price weighted by trading volume over the observation period. Used for execution quality assessment and algorithmic trading benchmarks.' ;
    rdfs:domain ind:Price ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cashCurrencyId rdf:type rdf:Property ;
    rdfs:label 'Cash Currency Id' ;
    rdfs:comment 'Foreign key linking to reference.currency. Business justification: Cash dividend and redemption currency determines entitlement calculations and FX conversion for cross-border corporate actions. Critical for accurate custody accounting and client entitlement processi' ;
    rdfs:domain ind:CorporateAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:primaryCorporateInstrumentId rdf:type rdf:Property ;
    rdfs:label 'Primary Corporate Instrument Id' ;
    rdfs:comment 'Reference to the security instrument affected by this corporate action.' ;
    rdfs:domain ind:CorporateAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Instrument .

ind:taxJurisdictionId rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction Id' ;
    rdfs:comment 'Foreign key linking to reference.jurisdiction. Business justification: Corporate actions (dividends, mergers) have withholding tax obligations determined by the tax jurisdiction. corporate_action.tax_jurisdiction is a plain text denormalization of the jurisdiction entity' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Jurisdiction .

ind:cashRate rdf:type rdf:Property ;
    rdfs:label 'Cash Rate' ;
    rdfs:comment 'Cash amount per share or unit to be distributed as part of the corporate action (e.g., dividend per share).' ;
    rdfs:domain ind:CorporateAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Certification Required Flag' ;
    rdfs:comment 'Indicates whether beneficial owners must provide certification (e.g., tax forms, eligibility declarations) to participate.' ;
    rdfs:domain ind:CorporateAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificationType rdf:type rdf:Property ;
    rdfs:label 'Certification Type' ;
    rdfs:comment 'Type of certification required (e.g., W-8BEN, W-9, beneficial ownership declaration).' ;
    rdfs:domain ind:CorporateAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultOptionCode rdf:type rdf:Property ;
    rdfs:label 'Default Option Code' ;
    rdfs:comment 'Code identifying the default option that will be applied if no election is received from the beneficial owner.' ;
    rdfs:domain ind:CorporateAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:electionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Election Required Flag' ;
    rdfs:comment 'Indicates whether beneficial owners must submit an election instruction to participate or receive entitlements.' ;
    rdfs:domain ind:CorporateAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:entitlementCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Entitlement Calculation Method' ;
    rdfs:comment 'Method used to calculate beneficial owner entitlements (e.g., based on record date position, average balance, or transaction history).' ;
    rdfs:domain ind:CorporateAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exDate rdf:type rdf:Property ;
    rdfs:label 'Ex Date' ;
    rdfs:comment 'Ex-dividend or ex-entitlement date. The first trading day on which the security trades without the entitlement to participate in the corporate action.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fractionalShareTreatment rdf:type rdf:Property ;
    rdfs:label 'Fractional Share Treatment' ;
    rdfs:comment 'Method for handling fractional shares resulting from the corporate action.' ;
    rdfs:domain ind:CorporateAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mandatoryVoluntaryIndicator rdf:type rdf:Property ;
    rdfs:label 'Mandatory Voluntary Indicator' ;
    rdfs:comment 'Indicates whether the corporate action is mandatory for all holders or requires voluntary election by beneficial owners.' ;
    rdfs:domain ind:CorporateAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketClaimFlag rdf:type rdf:Property ;
    rdfs:label 'Market Claim Flag' ;
    rdfs:comment 'Indicates whether market claims are applicable for trades settling after the record date but before the ex-date.' ;
    rdfs:domain ind:CorporateAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:offerPriceCurrency rdf:type rdf:Property ;
    rdfs:label 'Offer Price Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the offer price.' ;
    rdfs:domain ind:CorporateAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payingAgentBic rdf:type rdf:Property ;
    rdfs:label 'Paying Agent Bic' ;
    rdfs:comment 'SWIFT Bank Identifier Code of the paying agent.' ;
    rdfs:domain ind:CorporateAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payingAgentName rdf:type rdf:Property ;
    rdfs:label 'Paying Agent Name' ;
    rdfs:comment 'Name of the financial institution acting as paying agent for the distribution of cash or securities.' ;
    rdfs:domain ind:CorporateAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingStatus rdf:type rdf:Property ;
    rdfs:label 'Processing Status' ;
    rdfs:comment 'Internal processing status indicating the stage of corporate action processing within the banks systems.' ;
    rdfs:domain ind:CorporateAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protectDate rdf:type rdf:Property ;
    rdfs:label 'Protect Date' ;
    rdfs:comment 'Date by which custodians and intermediaries must submit protect instructions to ensure entitlements are preserved for beneficial owners.' ;
    rdfs:domain ind:CorporateAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recordDate rdf:type rdf:Property ;
    rdfs:label 'Record Date' ;
    rdfs:comment 'Date on which shareholders must be registered on the books to be entitled to participate in the corporate action.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceEventReference rdf:type rdf:Property ;
    rdfs:label 'Source Event Reference' ;
    rdfs:comment 'Unique identifier assigned to this corporate action event by the source system or data provider.' ;
    rdfs:domain ind:CorporateAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockRateDenominator rdf:type rdf:Property ;
    rdfs:label 'Stock Rate Denominator' ;
    rdfs:comment 'Denominator of the stock distribution ratio (e.g., in a 3-for-2 split, this would be 2).' ;
    rdfs:domain ind:CorporateAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stockRateNumerator rdf:type rdf:Property ;
    rdfs:label 'Stock Rate Numerator' ;
    rdfs:comment 'Numerator of the stock distribution ratio (e.g., in a 3-for-2 split, this would be 3).' ;
    rdfs:domain ind:CorporateAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:classificationId rdf:type rdf:Property ;
    rdfs:label 'Classification Id' ;
    rdfs:comment 'Primary key for classification' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Classification .

ind:chartOfAccountsId rdf:type rdf:Property ;
    rdfs:label 'Chart Of Accounts Id' ;
    rdfs:comment 'Foreign key linking to ledger.chart_of_accounts. Business justification: IFRS 9 instrument classification (FVTPL, FVOCI, amortized cost) directly determines which chart of accounts entry governs the instrument\'s accounting treatment. Banks maintain this mapping for automat' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ChartOfAccounts .

ind:classificationCode rdf:type rdf:Property ;
    rdfs:label 'Classification Code' ;
    rdfs:comment 'The specific classification code value within the chosen scheme. For CFI this is a 6-character code (e.g., ESVUFR for equity), for ISDA this is the product type code, for EMIR this is the asset class code, for SFDR this is the sustainability category (Article 6/8/9), for MiFID II this is the product complexity indicator, for FRTB this is the risk bucket identifier.' ;
    rdfs:domain ind:Classification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classificationDescription rdf:type rdf:Property ;
    rdfs:label 'Classification Description' ;
    rdfs:comment 'Human-readable description of the classification code. Provides business-friendly explanation of what the classification represents (e.g., \'Common Share\', \'Interest Rate Swap\', \'Equity Derivative\', \'Article 8 Fund - Promotes Environmental Characteristics\').' ;
    rdfs:domain ind:Classification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classificationLevel rdf:type rdf:Property ;
    rdfs:label 'Classification Level' ;
    rdfs:comment 'Hierarchical level within the classification taxonomy. Level 1 represents the highest level (e.g., asset class), with increasing numbers representing more granular categorization. Supports multi-level taxonomies where instruments are classified at multiple levels of detail.' ;
    rdfs:domain ind:Classification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:classificationSource rdf:type rdf:Property ;
    rdfs:label 'Classification Source' ;
    rdfs:comment 'The authoritative source of this classification. Identifies whether the classification was provided by a vendor (e.g., Bloomberg, Refinitiv), derived internally by the bank\'s reference data team, mandated by a regulatory authority, provided by the exchange, supplied by the issuer, or obtained from a third-party data provider.' ;
    rdfs:domain ind:Classification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classificationStatus rdf:type rdf:Property ;
    rdfs:label 'Classification Status' ;
    rdfs:comment 'Current lifecycle status of the classification record. Active classifications are in use; pending review indicates the classification is under validation; superseded indicates a newer classification has replaced this one; deprecated indicates the classification is no longer valid; under investigation indicates potential data quality issues are being reviewed.' ;
    rdfs:domain ind:Classification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complexityIndicator rdf:type rdf:Property ;
    rdfs:label 'Complexity Indicator' ;
    rdfs:comment 'MiFID II product complexity classification. Non-complex instruments can be sold without appropriateness assessment; complex instruments require suitability or appropriateness assessment. Critical for investment policy compliance screening and client advisory.' ;
    rdfs:domain ind:Classification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frtbRiskBucket rdf:type rdf:Property ;
    rdfs:label 'Frtb Risk Bucket' ;
    rdfs:comment 'FRTB sensitivities-based approach risk bucket assignment. Used for market risk capital calculation under Basel III FRTB framework. Buckets vary by asset class (e.g., interest rate buckets by currency and tenor, equity buckets by sector and market cap, credit buckets by rating and sector).' ;
    rdfs:domain ind:Classification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalAssetClass rdf:type rdf:Property ;
    rdfs:label 'Internal Asset Class' ;
    rdfs:comment 'Internal proprietary asset class hierarchy used for portfolio management, risk reporting, and investment policy compliance. May differ from regulatory classifications to align with the bank\'s internal risk management and business line structure.' ;
    rdfs:domain ind:Classification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalProductCategory rdf:type rdf:Property ;
    rdfs:label 'Internal Product Category' ;
    rdfs:comment 'Internal product categorization for business line reporting, profitability analysis, and operational management. Aligns with the bank\'s line of business (LOB) structure and product governance framework.' ;
    rdfs:domain ind:Classification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPrimaryClassification rdf:type rdf:Property ;
    rdfs:label 'Is Primary Classification' ;
    rdfs:comment 'Indicates whether this is the primary or default classification for the instrument within this classification scheme. True when this classification should be used as the authoritative categorization; false for alternative or supplementary classifications.' ;
    rdfs:domain ind:Classification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastModifiedBy rdf:type rdf:Property ;
    rdfs:label 'Last Modified By' ;
    rdfs:comment 'User ID or system identifier that last modified this classification record. Supports audit trail and change tracking.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Override Approval Date' ;
    rdfs:comment 'Date when the classification override was approved. Required when override_indicator is true. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:overrideApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Override Approved By' ;
    rdfs:comment 'User ID or name of the authorized person who approved the classification override. Required when override_indicator is true. Supports audit trail and accountability for manual classification decisions.' ;
    rdfs:domain ind:Classification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentClassificationCode rdf:type rdf:Property ;
    rdfs:label 'Parent Classification Code' ;
    rdfs:comment 'The classification code of the parent category in hierarchical taxonomies. Enables navigation of multi-level classification structures (e.g., \'Equity\' as parent of \'Common Share\'). Null for top-level classifications.' ;
    rdfs:domain ind:Classification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productType rdf:type rdf:Property ;
    rdfs:label 'Product Type' ;
    rdfs:comment 'Detailed product type within the asset class. Examples include \'Interest Rate Swap\', \'Credit Default Swap (CDS)\', \'Mortgage-Backed Securities (MBS)\', \'Asset-Backed Securities (ABS)\', \'Collateralized Loan Obligation (CLO)\', \'Collateralized Debt Obligation (CDO)\', \'Over-the-Counter (OTC) Option\'. Supports granular risk and regulatory reporting.' ;
    rdfs:domain ind:Classification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schemeCode rdf:type rdf:Property ;
    rdfs:label 'Scheme Code' ;
    rdfs:comment 'The classification framework or taxonomy being applied. Supports CFI (Classification of Financial Instruments ISO 10962), ISDA product taxonomy, ESMA EMIR classification, SFDR (Sustainable Finance Disclosure Regulation) sustainability classification, MiFID II product governance classification, FRTB (Fundamental Review of the Trading Book) sensitivities-based approach, and internal asset class hierarchy. [ENUM-REF-CANDIDATE: CFI|ISDA|EMIR|SFDR|MIFID2|FRTB|INTERNAL — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Classification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityClassification rdf:type rdf:Property ;
    rdfs:label 'Sustainability Classification' ;
    rdfs:comment 'SFDR sustainability classification for funds and financial products. Article 6 (no sustainability objective), Article 8 (promotes environmental or social characteristics), Article 9 (has sustainable investment as objective). Required for EU regulatory reporting and ESG investment screening.' ;
    rdfs:domain ind:Classification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:version rdf:type rdf:Property ;
    rdfs:label 'Version' ;
    rdfs:comment 'Version identifier for the classification scheme or taxonomy being applied. Tracks changes to classification standards over time (e.g., \'CFI 2021\', \'ISDA Taxonomy v2.0\', \'EMIR RTS 2023\'). Critical for regulatory reporting and historical analysis.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identifierId rdf:type rdf:Property ;
    rdfs:label 'Identifier Id' ;
    rdfs:comment 'Primary key for identifier' ;
    rdfs:domain ind:Identifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:issuingJurisdictionId rdf:type rdf:Property ;
    rdfs:label 'Issuing Jurisdiction Id' ;
    rdfs:comment 'Foreign key linking to reference.jurisdiction. Business justification: Security identifiers (ISIN, CUSIP, SEDOL) are issued by jurisdiction-specific numbering agencies (ANNA members). Operations and data management teams need the issuing jurisdiction FK to validate ident' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Jurisdiction .

ind:compositeIdentifierFlag rdf:type rdf:Property ;
    rdfs:label 'Composite Identifier Flag' ;
    rdfs:comment 'Boolean flag indicating whether this identifier is a composite or concatenated identifier formed from multiple components (e.g., ticker + exchange code). True indicates composite; False indicates atomic identifier.' ;
    rdfs:domain ind:Identifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:countryOfIssuance rdf:type rdf:Property ;
    rdfs:label 'Country Of Issuance' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the country where the identifier was issued or where the issuing authority is domiciled. Examples include USA, GBR, DEU, JPN. Used for regulatory reporting and geographic segmentation.' ;
    rdfs:domain ind:Identifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identifierDescription rdf:type rdf:Property ;
    rdfs:label 'Identifier Description' ;
    rdfs:comment 'Free-text description or additional context about this identifier. May include notes on usage, special handling instructions, or clarifications on identifier scope and applicability.' ;
    rdfs:domain ind:Identifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identifierType rdf:type rdf:Property ;
    rdfs:label 'Identifier Type' ;
    rdfs:comment 'Type of external identifier. Indicates the classification scheme or issuing authority for this identifier. Common types include ISIN (International Securities Identification Number), CUSIP (Committee on Uniform Securities Identification Procedures), SEDOL (Stock Exchange Daily Official List), FIGI (Financial Instrument Global Identifier), BBGID (Bloomberg ID), RIC (Reuters Instrument Code), Valoren, WKN (Wertpapierkennnummer), CINS (CUSIP International Numbering System), and exchange-specific ticker symbols. [ENUM-REF-CANDIDATE: ISIN|CUSIP|SEDOL|FIGI|BBGID|RIC|Valoren|WKN|CINS|Ticker|IBES|COMMON|RED_CODE — promote to reference product]' ;
    rdfs:domain ind:Identifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastVerifiedDate rdf:type rdf:Property ;
    rdfs:label 'Last Verified Date' ;
    rdfs:comment 'Date on which this identifier was last verified or validated against the issuing authority or external data vendor. Used to track data freshness and trigger re-verification workflows.' ;
    rdfs:domain ind:Identifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tradingCurrencyId rdf:type rdf:Property ;
    rdfs:label 'Trading Currency Id' ;
    rdfs:comment 'Foreign key linking to reference.currency. Business justification: Trading currency determines order entry and execution pricing. Distinct from settlement currency for dual-listed securities. Essential for FX risk management and multi-currency trading desk operations' ;
    rdfs:domain ind:Listing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:circuitBreakerThresholdPct rdf:type rdf:Property ;
    rdfs:label 'Circuit Breaker Threshold Pct' ;
    rdfs:comment 'Price movement threshold percentage that triggers automatic trading halt or circuit breaker for this listing.' ;
    rdfs:domain ind:Listing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentRecordFlag rdf:type rdf:Property ;
    rdfs:label 'Current Record Flag' ;
    rdfs:comment 'Indicates whether this is the current active version of the listing record in a slowly changing dimension (SCD) Type 2 history.' ;
    rdfs:domain ind:Listing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:effectiveFromTimestamp rdf:type rdf:Property ;
    rdfs:label 'Effective From Timestamp' ;
    rdfs:comment 'Timestamp from which this version of the listing record is effective, supporting slowly changing dimension (SCD) Type 2 historization.' ;
    rdfs:domain ind:Listing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:effectiveToTimestamp rdf:type rdf:Property ;
    rdfs:label 'Effective To Timestamp' ;
    rdfs:comment 'Timestamp until which this version of the listing record is effective. Null indicates current active record.' ;
    rdfs:domain ind:Listing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:exchangeTickerSymbol rdf:type rdf:Property ;
    rdfs:label 'Exchange Ticker Symbol' ;
    rdfs:comment 'Exchange-specific ticker or trading symbol used to identify the security on this particular exchange.' ;
    rdfs:domain ind:Listing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isinCode rdf:type rdf:Property ;
    rdfs:label 'Isin Code' ;
    rdfs:comment 'ISO 6166 twelve-character alphanumeric code uniquely identifying the security globally. Included here for denormalized reference and regulatory reporting convenience.' ;
    rdfs:domain ind:Listing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastTradingDate rdf:type rdf:Property ;
    rdfs:label 'Last Trading Date' ;
    rdfs:comment 'Final date on which the security can be traded on this exchange before expiry or delisting. Applicable primarily to derivatives and structured products.' ;
    rdfs:domain ind:Listing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:listingStatus rdf:type rdf:Property ;
    rdfs:label 'Listing Status' ;
    rdfs:comment 'Current trading status of the listing on the exchange. Active indicates normal trading; suspended indicates temporary halt due to regulatory or corporate action; halted indicates intraday trading pause; delisted indicates removed from exchange; pending indicates listing application in progress.' ;
    rdfs:domain ind:Listing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:listingType rdf:type rdf:Property ;
    rdfs:label 'Listing Type' ;
    rdfs:comment 'Classification of the listing relationship. Primary indicates home exchange; secondary indicates additional listing; dual indicates simultaneous primary listing on multiple exchanges; ADR indicates American Depositary Receipt; GDR indicates Global Depositary Receipt.' ;
    rdfs:domain ind:Listing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localInstrumentCode rdf:type rdf:Property ;
    rdfs:label 'Local Instrument Code' ;
    rdfs:comment 'Exchange-specific instrument identifier or code assigned by the listing exchange for internal reference and order routing.' ;
    rdfs:domain ind:Listing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketDataSubscriptionTier rdf:type rdf:Property ;
    rdfs:label 'Market Data Subscription Tier' ;
    rdfs:comment 'Exchange-defined tier or package level for market data distribution rights for this listing (e.g., Level 1, Level 2, Premium).' ;
    rdfs:domain ind:Listing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketMakerRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Market Maker Required Flag' ;
    rdfs:comment 'Indicates whether designated market makers or liquidity providers are required for this listing under exchange rules.' ;
    rdfs:domain ind:Listing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mifidLiquidFlag rdf:type rdf:Property ;
    rdfs:label 'Mifid Liquid Flag' ;
    rdfs:comment 'Indicates whether this listing is classified as a liquid instrument under MiFID II transparency and best execution requirements.' ;
    rdfs:domain ind:Listing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priceBandLowerPct rdf:type rdf:Property ;
    rdfs:label 'Price Band Lower Pct' ;
    rdfs:comment 'Lower limit percentage for intraday price movement relative to reference price, beyond which orders are rejected or trading is paused.' ;
    rdfs:domain ind:Listing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceBandUpperPct rdf:type rdf:Property ;
    rdfs:label 'Price Band Upper Pct' ;
    rdfs:comment 'Upper limit percentage for intraday price movement relative to reference price, beyond which orders are rejected or trading is paused.' ;
    rdfs:domain ind:Listing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceMultiplier rdf:type rdf:Property ;
    rdfs:label 'Price Multiplier' ;
    rdfs:comment 'Multiplier applied to quoted price to calculate actual contract or notional value. Commonly used for derivatives and structured products.' ;
    rdfs:domain ind:Listing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryListingFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Listing Flag' ;
    rdfs:comment 'Indicates whether this is the primary or home exchange listing for the security. True for primary listing; false for secondary or cross-listings.' ;
    rdfs:domain ind:Listing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:settlementCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Settlement Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which trades are settled for this listing. May differ from trading currency for certain cross-listed instruments.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementCycleDays rdf:type rdf:Property ;
    rdfs:label 'Settlement Cycle Days' ;
    rdfs:comment 'Number of business days after trade date (T+N) for standard settlement of trades in this listing. Common values are T+1 or T+2.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shortSellingAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Short Selling Allowed Flag' ;
    rdfs:comment 'Indicates whether short selling is permitted for this listing under current exchange and regulatory rules.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sponsor rdf:type rdf:Property ;
    rdfs:label 'Sponsor' ;
    rdfs:comment 'Name of the financial institution or broker-dealer sponsoring or facilitating the listing on this exchange.' ;
    rdfs:domain ind:Listing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tickSize rdf:type rdf:Property ;
    rdfs:label 'Tick Size' ;
    rdfs:comment 'Minimum price increment or tick size for this listing. Prices must move in multiples of this value.' ;
    rdfs:domain ind:Listing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tradingHoursEnd rdf:type rdf:Property ;
    rdfs:label 'Trading Hours End' ;
    rdfs:comment 'Local exchange time when regular trading session ends for this listing, in HH:MM format.' ;
    rdfs:domain ind:Listing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradingHoursStart rdf:type rdf:Property ;
    rdfs:label 'Trading Hours Start' ;
    rdfs:comment 'Local exchange time when regular trading session begins for this listing, in HH:MM format.' ;
    rdfs:domain ind:Listing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradingPhase rdf:type rdf:Property ;
    rdfs:label 'Trading Phase' ;
    rdfs:comment 'Current intraday trading phase or session state for this listing on the exchange.' ;
    rdfs:domain ind:Listing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradingTimezone rdf:type rdf:Property ;
    rdfs:label 'Trading Timezone' ;
    rdfs:comment 'IANA timezone identifier for the exchange trading hours (e.g., America/New_York, Europe/London, Asia/Tokyo).' ;
    rdfs:domain ind:Listing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradingVenueType rdf:type rdf:Property ;
    rdfs:label 'Trading Venue Type' ;
    rdfs:comment 'Classification of the trading venue under MiFID II. Regulated Market indicates traditional exchange; MTF indicates Multilateral Trading Facility; OTF indicates Organised Trading Facility; Systematic Internaliser indicates bank internal crossing.' ;
    rdfs:domain ind:Listing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:administratorLei rdf:type rdf:Property ;
    rdfs:label 'Administrator Lei' ;
    rdfs:comment 'ISO 17442 Legal Entity Identifier of the benchmark administrator.' ;
    rdfs:domain ind:Benchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:administratorName rdf:type rdf:Property ;
    rdfs:label 'Administrator Name' ;
    rdfs:comment 'Name of the organization responsible for administering and publishing the benchmark (e.g., Federal Reserve Bank of New York, ICE Benchmark Administration, S&P Dow Jones Indices).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benchmarkCode rdf:type rdf:Property ;
    rdfs:label 'Benchmark Code' ;
    rdfs:comment 'Short code or ticker symbol for the benchmark (e.g., SOFR, EURIBOR, SONIA, SPXT, MXWO).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benchmarkName rdf:type rdf:Property ;
    rdfs:label 'Benchmark Name' ;
    rdfs:comment 'Full official name of the benchmark or reference rate (e.g., Secured Overnight Financing Rate, Euro Interbank Offered Rate, S&P 500 Index).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benchmarkStatus rdf:type rdf:Property ;
    rdfs:label 'Benchmark Status' ;
    rdfs:comment 'Current lifecycle status of the benchmark (active, legacy, discontinued, suspended).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benchmarkType rdf:type rdf:Property ;
    rdfs:label 'Benchmark Type' ;
    rdfs:comment 'Classification of the benchmark by asset class or purpose (interest rate, equity index, credit spread index, commodity index, foreign exchange rate, yield curve, volatility index). [ENUM-REF-CANDIDATE: interest_rate|equity_index|credit_spread_index|commodity_index|fx_rate|yield_curve|volatility_index — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compoundingMethod rdf:type rdf:Property ;
    rdfs:label 'Compounding Method' ;
    rdfs:comment 'Method of compounding for rate calculations (simple, compound, continuous). Applicable to interest rate benchmarks.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constituentCount rdf:type rdf:Property ;
    rdfs:label 'Constituent Count' ;
    rdfs:comment 'Number of constituent instruments or securities included in the index. Applicable to equity and credit indices.' ;
    rdfs:domain ind:Benchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataSource rdf:type rdf:Property ;
    rdfs:label 'Data Source' ;
    rdfs:comment 'Primary source of underlying data used to calculate the benchmark (e.g., Federal Reserve, ICE, Bloomberg, Markit).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discontinuationDate rdf:type rdf:Property ;
    rdfs:label 'Discontinuation Date' ;
    rdfs:comment 'Date when the benchmark was or will be discontinued. Null if still active.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:geographicCoverage rdf:type rdf:Property ;
    rdfs:label 'Geographic Coverage' ;
    rdfs:comment 'Geographic scope of the benchmark or index (e.g., USA, Europe, Global, Emerging Markets). Pipe-separated list of ISO 3166-1 alpha-3 country codes or region names.' ;
    rdfs:domain ind:Benchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inceptionDate rdf:type rdf:Property ;
    rdfs:label 'Inception Date' ;
    rdfs:comment 'Date when the benchmark or index was first established and began publication.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:indexBaseDate rdf:type rdf:Property ;
    rdfs:label 'Index Base Date' ;
    rdfs:comment 'Date on which the index base value was established. Applicable to equity and credit indices.' ;
    rdfs:domain ind:Benchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:indexBaseValue rdf:type rdf:Property ;
    rdfs:label 'Index Base Value' ;
    rdfs:comment 'Base or starting value of the index at inception. Applicable to equity and credit indices.' ;
    rdfs:domain ind:Benchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ioscoCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Iosco Compliant Flag' ;
    rdfs:comment 'Indicates whether the benchmark complies with IOSCO Principles for Financial Benchmarks.' ;
    rdfs:domain ind:Benchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:methodologyDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Methodology Document Url' ;
    rdfs:comment 'URL to the official methodology document describing the benchmark calculation and governance.' ;
    rdfs:domain ind:Benchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicationFrequency rdf:type rdf:Property ;
    rdfs:label 'Publication Frequency' ;
    rdfs:comment 'Frequency at which the benchmark rate or index value is published (daily, weekly, monthly, quarterly, real-time, intraday).' ;
    rdfs:domain ind:Benchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicationTime rdf:type rdf:Property ;
    rdfs:label 'Publication Time' ;
    rdfs:comment 'Standard time of day when the benchmark is published (e.g., 08:00 EST, 11:00 GMT). Format: HH:MM timezone.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rebalancingFrequency rdf:type rdf:Property ;
    rdfs:label 'Rebalancing Frequency' ;
    rdfs:comment 'Frequency at which the index constituents or weights are rebalanced (daily, monthly, quarterly, semi-annual, annual, event-driven). Applicable to indices.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Status' ;
    rdfs:comment 'Current regulatory standing of the benchmark (authorized, registered, recognized, legacy, discontinued).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sectorCoverage rdf:type rdf:Property ;
    rdfs:label 'Sector Coverage' ;
    rdfs:comment 'Industry sectors covered by the benchmark or index (e.g., Technology, Financials, Healthcare, Broad Market). Applicable to equity and credit indices.' ;
    rdfs:domain ind:Benchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spreadAdjustmentBps rdf:type rdf:Property ;
    rdfs:label 'Spread Adjustment Bps' ;
    rdfs:comment 'Fixed spread adjustment in basis points to be added when transitioning to the fallback benchmark (e.g., LIBOR to SOFR transition spread).' ;
    rdfs:domain ind:Benchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usageRestriction rdf:type rdf:Property ;
    rdfs:label 'Usage Restriction' ;
    rdfs:comment 'Any restrictions or licensing requirements for using the benchmark in financial contracts or products.' ;
    rdfs:domain ind:Benchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightingScheme rdf:type rdf:Property ;
    rdfs:label 'Weighting Scheme' ;
    rdfs:comment 'Method used to weight constituents in the index (market capitalization, free-float adjusted, price, equal, fundamental, risk parity). Applicable to indices.' ;
    rdfs:domain ind:Benchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collateralizationType rdf:type rdf:Property ;
    rdfs:label 'Collateralization Type' ;
    rdfs:comment 'Collateral arrangement assumed for derivative discounting (e.g., OIS-collateralized for CSA trades, uncollateralized for legacy trades).' ;
    rdfs:domain ind:YieldCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constructionDate rdf:type rdf:Property ;
    rdfs:label 'Construction Date' ;
    rdfs:comment 'The business date on which the yield curve was constructed. Represents the valuation date for the curve snapshot.' ;
    rdfs:domain ind:YieldCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:constructionMethodology rdf:type rdf:Property ;
    rdfs:label 'Construction Methodology' ;
    rdfs:comment 'Mathematical method used to construct the yield curve from market instrument prices (e.g., bootstrapping, Nelson-Siegel, cubic spline interpolation).' ;
    rdfs:domain ind:YieldCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constructionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Construction Timestamp' ;
    rdfs:comment 'Precise date and time when the yield curve was constructed or last recalculated, supporting intraday curve updates and audit trails.' ;
    rdfs:domain ind:YieldCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:curveName rdf:type rdf:Property ;
    rdfs:label 'Curve Name' ;
    rdfs:comment 'Business name or label for the yield curve (e.g., USD SOFR Swap Curve, EUR Government Curve, USD Corporate AA Spread Curve).' ;
    rdfs:domain ind:YieldCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:curveNodesJson rdf:type rdf:Property ;
    rdfs:label 'Curve Nodes Json' ;
    rdfs:comment 'JSON-serialized array of tenor-rate nodes defining the complete curve shape. Each node includes tenor label, tenor in days, zero rate, par rate, forward rate, discount factor, and interpolation method. Supports full curve reconstruction for valuation and risk analytics.' ;
    rdfs:domain ind:YieldCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:curveShiftScenario rdf:type rdf:Property ;
    rdfs:label 'Curve Shift Scenario' ;
    rdfs:comment 'Name of the stress or shock scenario applied to the curve (e.g., +100 bps parallel shift, CCAR Severely Adverse). Null for base case curves.' ;
    rdfs:domain ind:YieldCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:curveStatus rdf:type rdf:Property ;
    rdfs:label 'Curve Status' ;
    rdfs:comment 'Current lifecycle status of the yield curve. Active curves are used for valuation; superseded curves are retained for historical analysis.' ;
    rdfs:domain ind:YieldCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:curveType rdf:type rdf:Property ;
    rdfs:label 'Curve Type' ;
    rdfs:comment 'Classification of the yield curve by underlying instrument or market segment. Determines the curve\'s application in valuation and risk measurement. [ENUM-REF-CANDIDATE: government|swap|credit_spread|ois|corporate|treasury|libor|sofr|euribor — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:curveVersion rdf:type rdf:Property ;
    rdfs:label 'Curve Version' ;
    rdfs:comment 'Version number for the curve construction on a given date. Supports intraday curve revisions and audit trails.' ;
    rdfs:domain ind:YieldCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:interpolationMethod rdf:type rdf:Property ;
    rdfs:label 'Interpolation Method' ;
    rdfs:comment 'Technique applied to interpolate rates between observed tenor nodes on the curve. Critical for pricing instruments with non-standard maturities.' ;
    rdfs:domain ind:YieldCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRiskFree rdf:type rdf:Property ;
    rdfs:label 'Is Risk Free' ;
    rdfs:comment 'Flag indicating whether the curve represents a risk-free rate (e.g., government or OIS curve). True for risk-free curves, false for credit or spread curves.' ;
    rdfs:domain ind:YieldCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:longestTenorDays rdf:type rdf:Property ;
    rdfs:label 'Longest Tenor Days' ;
    rdfs:comment 'Tenor in days of the longest maturity node on the curve (e.g., 10950 for 30 years). Defines the curve\'s maximum extrapolation horizon.' ;
    rdfs:domain ind:YieldCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shortestTenorDays rdf:type rdf:Property ;
    rdfs:label 'Shortest Tenor Days' ;
    rdfs:comment 'Tenor in days of the shortest maturity node on the curve (e.g., 1 for overnight, 30 for 1-month).' ;
    rdfs:domain ind:YieldCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tenorCount rdf:type rdf:Property ;
    rdfs:label 'Tenor Count' ;
    rdfs:comment 'Number of tenor nodes (pillars) defining the curve shape. Typical curves have 8-15 nodes spanning overnight to 30 years.' ;
    rdfs:domain ind:YieldCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:valuationPurpose rdf:type rdf:Property ;
    rdfs:label 'Valuation Purpose' ;
    rdfs:comment 'Primary business use case for the curve (e.g., trading book mark-to-market, IFRS 9 ECL discounting, FTP curve, regulatory stress testing).' ;
    rdfs:domain ind:YieldCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuerPartyId rdf:type rdf:Property ;
    rdfs:label 'Issuer Party Id' ;
    rdfs:comment 'Reference to the issuer entity whose creditworthiness is being assessed.' ;
    rdfs:domain ind:CreditRating ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:baselCreditQualityStep rdf:type rdf:Property ;
    rdfs:label 'Basel Credit Quality Step' ;
    rdfs:comment 'Credit quality step (1-6) under Basel III mapping framework for regulatory capital calculation.' ;
    rdfs:domain ind:CreditRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:baselRiskWeightPct rdf:type rdf:Property ;
    rdfs:label 'Basel Risk Weight Pct' ;
    rdfs:comment 'Risk weight percentage assigned under Basel III Standardized Approach for Risk-Weighted Assets (RWA) calculation.' ;
    rdfs:domain ind:CreditRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ceclRiskCategory rdf:type rdf:Property ;
    rdfs:label 'Cecl Risk Category' ;
    rdfs:comment 'Risk category under US GAAP CECL framework for expected credit loss estimation.' ;
    rdfs:domain ind:CreditRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalOverrideFlag rdf:type rdf:Property ;
    rdfs:label 'Internal Override Flag' ;
    rdfs:comment 'Indicates whether the bank has applied an internal override to the external rating for risk management purposes.' ;
    rdfs:domain ind:CreditRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:internalOverrideReason rdf:type rdf:Property ;
    rdfs:label 'Internal Override Reason' ;
    rdfs:comment 'Explanation for why an internal override was applied to the external rating.' ;
    rdfs:domain ind:CreditRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investmentGradeFlag rdf:type rdf:Property ;
    rdfs:label 'Investment Grade Flag' ;
    rdfs:comment 'Indicates whether the rating qualifies as investment grade (BBB-/Baa3 or higher) versus speculative/high-yield.' ;
    rdfs:domain ind:CreditRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:longTermRating rdf:type rdf:Property ;
    rdfs:label 'Long Term Rating' ;
    rdfs:comment 'Long-term credit rating assigned (e.g., AAA, Aaa, AA+, BBB-, Ba1, CCC). Format varies by agency.' ;
    rdfs:domain ind:CreditRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousRating rdf:type rdf:Property ;
    rdfs:label 'Previous Rating' ;
    rdfs:comment 'The rating that was in effect immediately prior to the current rating action. Used for tracking rating migration.' ;
    rdfs:domain ind:CreditRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:probabilityOfDefaultPct rdf:type rdf:Property ;
    rdfs:label 'Probability Of Default Pct' ;
    rdfs:comment 'Estimated probability of default associated with this rating, expressed as a percentage. Used for Expected Credit Loss (ECL) calculation under IFRS 9 and Current Expected Credit Losses (CECL).' ;
    rdfs:domain ind:CreditRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:publicRatingFlag rdf:type rdf:Property ;
    rdfs:label 'Public Rating Flag' ;
    rdfs:comment 'Indicates whether the rating is publicly disclosed or private/confidential.' ;
    rdfs:domain ind:CreditRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ratedEntityType rdf:type rdf:Property ;
    rdfs:label 'Rated Entity Type' ;
    rdfs:comment 'Type of entity being rated: instrument-level rating or issuer-level rating.' ;
    rdfs:domain ind:CreditRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingActionType rdf:type rdf:Property ;
    rdfs:label 'Rating Action Type' ;
    rdfs:comment 'Type of rating action: initial assignment, upgrade, downgrade, affirmation, withdrawal, or review status. [ENUM-REF-CANDIDATE: initial|upgrade|downgrade|affirmed|withdrawn|suspended|under_review — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CreditRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingAgencyCode rdf:type rdf:Property ;
    rdfs:label 'Rating Agency Code' ;
    rdfs:comment 'Code identifying the rating agency that assigned the rating (Moody\'s, S&P, Fitch, DBRS, Kroll, or internal model). [ENUM-REF-CANDIDATE: MOODYS|SP|FITCH|DBRS|KROLL|AM_BEST|JCR|INTERNAL — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CreditRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingAgencyName rdf:type rdf:Property ;
    rdfs:label 'Rating Agency Name' ;
    rdfs:comment 'Full legal name of the rating agency.' ;
    rdfs:domain ind:CreditRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingChangeReason rdf:type rdf:Property ;
    rdfs:label 'Rating Change Reason' ;
    rdfs:comment 'Brief description of the primary reason for rating change (e.g., deteriorating financial performance, improved liquidity, sector outlook change).' ;
    rdfs:domain ind:CreditRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingIdentifier rdf:type rdf:Property ;
    rdfs:label 'Rating Identifier' ;
    rdfs:comment 'External identifier or reference number assigned by the rating agency to this specific rating.' ;
    rdfs:domain ind:CreditRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingNotch rdf:type rdf:Property ;
    rdfs:label 'Rating Notch' ;
    rdfs:comment 'Numeric representation of the rating on a standardized scale for quantitative analysis and comparison across agencies.' ;
    rdfs:domain ind:CreditRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ratingRationale rdf:type rdf:Property ;
    rdfs:label 'Rating Rationale' ;
    rdfs:comment 'Summary of the key factors and rationale provided by the rating agency for the assigned rating.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingScaleType rdf:type rdf:Property ;
    rdfs:label 'Rating Scale Type' ;
    rdfs:comment 'Type of rating scale used (long-term, short-term, fund rating, insurance financial strength, etc.).' ;
    rdfs:domain ind:CreditRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Rating Source System' ;
    rdfs:comment 'Source system or data feed from which the rating was obtained (e.g., Bloomberg, Reuters, direct agency feed, internal model).' ;
    rdfs:domain ind:CreditRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryCapitalTreatment rdf:type rdf:Property ;
    rdfs:label 'Regulatory Capital Treatment' ;
    rdfs:comment 'Description of how this rating affects regulatory capital requirements under applicable frameworks (Basel III, Dodd-Frank, etc.).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortTermRating rdf:type rdf:Property ;
    rdfs:label 'Short Term Rating' ;
    rdfs:comment 'Short-term credit rating assigned (e.g., A-1+, P-1, F1, R-1H). Format varies by agency.' ;
    rdfs:domain ind:CreditRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:solicitedFlag rdf:type rdf:Property ;
    rdfs:label 'Solicited Flag' ;
    rdfs:comment 'Indicates whether the rating was solicited (requested by issuer) or unsolicited (assigned independently by agency).' ;
    rdfs:domain ind:CreditRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:benchmarkRateType rdf:type rdf:Property ;
    rdfs:label 'Benchmark Rate Type' ;
    rdfs:comment 'The primary interest rate benchmark associated with this currency (e.g., Secured Overnight Financing Rate (SOFR) for USD, Euro Short-Term Rate (ESTR) for EUR, Sterling Overnight Index Average (SONIA) for GBP). Used for pricing loans, derivatives, and other financial instruments. Reflects the transition from London Interbank Offered Rate (LIBOR) to alternative reference rates.' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:centralBankName rdf:type rdf:Property ;
    rdfs:label 'Central Bank Name' ;
    rdfs:comment 'Name of the central bank or monetary authority responsible for issuing and regulating this currency (e.g., Federal Reserve System for USD, European Central Bank for EUR, Bank of England for GBP). Used for regulatory reporting and monetary policy reference.' ;
    rdfs:domain ind:Currency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currencyName rdf:type rdf:Property ;
    rdfs:label 'Currency Name' ;
    rdfs:comment 'Full official name of the currency (e.g., United States Dollar, Euro, British Pound Sterling, Japanese Yen).' ;
    rdfs:domain ind:Currency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currencyStatus rdf:type rdf:Property ;
    rdfs:label 'Currency Status' ;
    rdfs:comment 'Current lifecycle status of the currency. Active currencies are currently in circulation and available for transactions. Inactive currencies are temporarily suspended. Deprecated currencies are being phased out (e.g., legacy currencies replaced by EUR). Historical currencies are no longer in use but retained for historical transaction reference. Pending currencies are approved but not yet in circulation.' ;
    rdfs:domain ind:Currency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currencyType rdf:type rdf:Property ;
    rdfs:label 'Currency Type' ;
    rdfs:comment 'Classification of the currency by its fundamental nature. Fiat currencies are government-issued legal tender. Commodity currencies are backed by physical commodities. Digital currencies include cryptocurrencies and central bank digital currencies. Fund represents investment fund units. Special Drawing Right (SDR) is the International Monetary Fund (IMF) reserve asset.' ;
    rdfs:domain ind:Currency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBaseCurrency rdf:type rdf:Property ;
    rdfs:label 'Is Base Currency' ;
    rdfs:comment 'Indicates whether this currency serves as a base currency for the enterprise\'s financial reporting and consolidation. Typically the functional currency of the parent company. Used for General Ledger (GL) consolidation and financial statement preparation.' ;
    rdfs:domain ind:Currency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isConvertible rdf:type rdf:Property ;
    rdfs:label 'Is Convertible' ;
    rdfs:comment 'Indicates whether this currency is freely convertible on international foreign exchange markets without significant restrictions. True for major reserve currencies and freely traded currencies. False for currencies with limited convertibility or capital controls.' ;
    rdfs:domain ind:Currency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCryptoCurrency rdf:type rdf:Property ;
    rdfs:label 'Is Crypto Currency' ;
    rdfs:comment 'Indicates whether this is a cryptocurrency or digital asset rather than a fiat currency issued by a central bank. Used to apply different regulatory treatment, risk controls, and processing rules for digital assets.' ;
    rdfs:domain ind:Currency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFundCurrency rdf:type rdf:Property ;
    rdfs:label 'Is Fund Currency' ;
    rdfs:comment 'Indicates whether this currency code represents a fund or investment vehicle unit rather than a traditional currency. Used for mutual funds, exchange-traded funds, and other investment products that have their own unit pricing.' ;
    rdfs:domain ind:Currency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLegalTender rdf:type rdf:Property ;
    rdfs:label 'Is Legal Tender' ;
    rdfs:comment 'Indicates whether this currency is currently recognized as legal tender in its issuing jurisdiction. True for currencies that must be accepted for payment of debts. False for commemorative, historical, or non-legal tender currencies.' ;
    rdfs:domain ind:Currency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPreciousMetal rdf:type rdf:Property ;
    rdfs:label 'Is Precious Metal' ;
    rdfs:comment 'Indicates whether this currency code represents a precious metal (e.g., XAU for gold, XAG for silver, XPT for platinum) used as a store of value or trading instrument. ISO 4217 includes codes for precious metals alongside traditional currencies.' ;
    rdfs:domain ind:Currency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRestricted rdf:type rdf:Property ;
    rdfs:label 'Is Restricted' ;
    rdfs:comment 'Indicates whether this currency is subject to capital controls, exchange restrictions, or regulatory limitations that restrict its convertibility or cross-border movement. True for currencies with government-imposed restrictions. Used for compliance and risk management.' ;
    rdfs:domain ind:Currency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isoCode rdf:type rdf:Property ;
    rdfs:label 'Iso Code' ;
    rdfs:comment 'Three-letter alphabetic currency code as defined by ISO 4217 standard (e.g., USD, EUR, GBP, JPY). This is the primary business identifier used across all financial systems for currency denomination.' ;
    rdfs:domain ind:Currency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minorUnit rdf:type rdf:Property ;
    rdfs:label 'Minor Unit' ;
    rdfs:comment 'Number of decimal places used for the currency\'s minor unit. Indicates the relationship between the major currency unit and its minor unit (e.g., 2 for USD cents, 0 for JPY which has no minor unit, 3 for certain Middle Eastern currencies). Critical for accurate financial calculations and rounding.' ;
    rdfs:domain ind:Currency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numericCode rdf:type rdf:Property ;
    rdfs:label 'Numeric Code' ;
    rdfs:comment 'Three-digit numeric currency code as defined by ISO 4217 standard (e.g., 840 for USD, 978 for EUR). Used in systems where alphabetic codes are not suitable.' ;
    rdfs:domain ind:Currency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roundingMethod rdf:type rdf:Property ;
    rdfs:label 'Rounding Method' ;
    rdfs:comment 'Standard rounding method to be applied for this currency in financial calculations. Standard uses mathematical rounding (0.5 rounds up). Bankers rounding rounds 0.5 to the nearest even number. Up always rounds up. Down always rounds down. Truncate drops decimal places without rounding. Critical for ensuring consistent calculation results across systems.' ;
    rdfs:domain ind:Currency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementLagDays rdf:type rdf:Property ;
    rdfs:label 'Settlement Lag Days' ;
    rdfs:comment 'Standard number of business days required for settlement of foreign exchange (FX) transactions involving this currency. Typically 2 days (T+2) for major currencies, but can vary. Used for calculating settlement dates in FX trading and payment processing.' ;
    rdfs:domain ind:Currency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:symbol rdf:type rdf:Property ;
    rdfs:label 'Symbol' ;
    rdfs:comment 'Graphical symbol used to represent the currency in financial displays and reports (e.g., $, €, £, ¥). Used for user interface presentation and customer-facing documents.' ;
    rdfs:domain ind:Currency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:achSystemName rdf:type rdf:Property ;
    rdfs:label 'Ach System Name' ;
    rdfs:comment 'Name of the country\'s automated clearing house system for retail payments (e.g., ACH for USA, Bacs for UK, SEPA for Eurozone). Used for batch payment processing, direct debit operations, and retail payment routing.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activeFlag rdf:type rdf:Property ;
    rdfs:label 'Active Flag' ;
    rdfs:comment 'Indicates whether this country record is currently active and should be used in operational systems. Inactive countries are retained for historical reference but excluded from customer onboarding and new transaction processing.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:baselCommitteeMemberFlag rdf:type rdf:Property ;
    rdfs:label 'Basel Committee Member Flag' ;
    rdfs:comment 'Indicates whether the country is represented on the Basel Committee on Banking Supervision. Signals adoption of Basel III capital and liquidity standards, relevant for counterparty risk assessment and regulatory capital calculations.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:businessDayConvention rdf:type rdf:Property ;
    rdfs:label 'Business Day Convention' ;
    rdfs:comment 'Standard business day convention code used for financial calculations in this country (e.g., Following, Modified Following, Preceding). Used in interest accrual, payment scheduling, and derivative valuation.' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callingCode rdf:type rdf:Property ;
    rdfs:label 'Calling Code' ;
    rdfs:comment 'International dialing prefix for the country (e.g., +1 for USA, +44 for UK). Used for phone number validation, customer contact data standardization, and communication routing.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capitalCity rdf:type rdf:Property ;
    rdfs:label 'Capital City' ;
    rdfs:comment 'Name of the country\'s capital city. Used for geographic reference, branch location planning, and regulatory correspondence addressing.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryName rdf:type rdf:Property ;
    rdfs:label 'Country Name' ;
    rdfs:comment 'Official short-form name of the country in English (e.g., United States of America, United Kingdom, Germany). Used for customer-facing displays, reports, and regulatory filings.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crsJurisdictionFlag rdf:type rdf:Property ;
    rdfs:label 'Crs Jurisdiction Flag' ;
    rdfs:comment 'Indicates whether the country is a CRS participating jurisdiction requiring automatic exchange of financial account information. Essential for global tax compliance and regulatory reporting.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crsReportableJurisdictionFlag rdf:type rdf:Property ;
    rdfs:label 'Crs Reportable Jurisdiction Flag' ;
    rdfs:comment 'Indicates whether accounts held by residents of this country must be reported under CRS. Used in customer classification and regulatory reporting workflows.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eeaMemberFlag rdf:type rdf:Property ;
    rdfs:label 'Eea Member Flag' ;
    rdfs:comment 'Indicates whether the country is a member of the European Economic Area (EU plus Iceland, Liechtenstein, Norway). Relevant for passporting rights, regulatory equivalence, and data protection frameworks.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:euMemberFlag rdf:type rdf:Property ;
    rdfs:label 'Eu Member Flag' ;
    rdfs:comment 'Indicates whether the country is a current member of the European Union. Used for regulatory compliance (GDPR, MiFID II), cross-border payment processing (SEPA), and risk classification.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fatcaGiinRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Fatca Giin Required Flag' ;
    rdfs:comment 'Indicates whether financial institutions in this country must obtain a GIIN for FATCA compliance. Used in onboarding and due diligence processes for institutional counterparties.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fatcaJurisdictionFlag rdf:type rdf:Property ;
    rdfs:label 'Fatca Jurisdiction Flag' ;
    rdfs:comment 'Indicates whether the country is a FATCA reporting jurisdiction requiring financial institutions to report US person accounts to the IRS. Critical for compliance with US tax regulations and customer onboarding workflows.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fatfHighRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Fatf High Risk Flag' ;
    rdfs:comment 'Indicates whether the country is identified by FATF as a high-risk jurisdiction with strategic AML/CFT deficiencies. Triggers enhanced due diligence requirements and elevated risk ratings in customer onboarding and transaction monitoring.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fatfMemberFlag rdf:type rdf:Property ;
    rdfs:label 'Fatf Member Flag' ;
    rdfs:comment 'Indicates whether the country is a member of the Financial Action Task Force. Used for assessing AML/CFT framework strength and country risk rating in financial crime compliance.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ibanLength rdf:type rdf:Property ;
    rdfs:label 'Iban Length' ;
    rdfs:comment 'Standard length of IBAN for this country (e.g., 22 for Germany, 27 for France). Used for IBAN validation and account number format checking.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ibanRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Iban Required Flag' ;
    rdfs:comment 'Indicates whether IBAN format is required for bank account numbers in this country. Used for payment validation, account number formatting, and cross-border payment processing.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:intermediateRegion rdf:type rdf:Property ;
    rdfs:label 'Intermediate Region' ;
    rdfs:comment 'Intermediate-level geographic classification between region and sub-region where applicable (e.g., Caribbean, Channel Islands). Used for specialized regional analytics and compliance grouping.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isoAlpha2Code rdf:type rdf:Property ;
    rdfs:label 'Iso Alpha 2 Code' ;
    rdfs:comment 'Two-letter country code as defined by ISO 3166-1 alpha-2 standard (e.g., US, GB, DE). Primary business identifier for country lookup in KYC, AML, and regulatory reporting systems.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isoAlpha3Code rdf:type rdf:Property ;
    rdfs:label 'Iso Alpha 3 Code' ;
    rdfs:comment 'Three-letter country code as defined by ISO 3166-1 alpha-3 standard (e.g., USA, GBR, DEU). Used in SWIFT messaging, trade finance, and cross-border payment processing.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isoNumericCode rdf:type rdf:Property ;
    rdfs:label 'Iso Numeric Code' ;
    rdfs:comment 'Three-digit numeric country code as defined by ISO 3166-1 numeric standard (e.g., 840 for USA, 826 for GBR). Used in systems requiring language-independent country representation.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oecdMemberFlag rdf:type rdf:Property ;
    rdfs:label 'Oecd Member Flag' ;
    rdfs:comment 'Indicates whether the country is a member of the OECD. Used for assessing regulatory standards, tax treaty eligibility, and country risk classification.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ofacSanctionsFlag rdf:type rdf:Property ;
    rdfs:label 'Ofac Sanctions Flag' ;
    rdfs:comment 'Indicates whether the country is subject to comprehensive OFAC sanctions programs. Critical for transaction screening, customer onboarding, and AML compliance.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ofacSanctionsProgram rdf:type rdf:Property ;
    rdfs:label 'Ofac Sanctions Program' ;
    rdfs:comment 'Name of the specific OFAC sanctions program applicable to this country (e.g., Iran Sanctions, North Korea Sanctions). Used for detailed compliance screening and risk assessment.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:officialName rdf:type rdf:Property ;
    rdfs:label 'Official Name' ;
    rdfs:comment 'Official long-form name of the country including full legal designation (e.g., United States of America, United Kingdom of Great Britain and Northern Ireland). Used in legal contracts, regulatory submissions, and formal documentation.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:region rdf:type rdf:Property ;
    rdfs:label 'Region' ;
    rdfs:comment 'High-level geographic region classification (e.g., Americas, Europe, Asia, Africa, Oceania). Used for regional risk aggregation, portfolio analysis, and management reporting.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rtgsSystemName rdf:type rdf:Property ;
    rdfs:label 'Rtgs System Name' ;
    rdfs:comment 'Name of the country\'s real-time gross settlement system for high-value payments (e.g., Fedwire for USA, CHAPS for UK, TARGET2 for Eurozone). Used for payment routing, liquidity management, and settlement risk assessment.' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sovereignCreditRating rdf:type rdf:Property ;
    rdfs:label 'Sovereign Credit Rating' ;
    rdfs:comment 'Long-term foreign currency sovereign credit rating from major rating agencies (e.g., AAA, AA+, BBB-, CCC). Used for risk-weighted asset (RWA) calculations, credit valuation adjustment (CVA), and investment grade classification.' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sovereignRatingAgency rdf:type rdf:Property ;
    rdfs:label 'Sovereign Rating Agency' ;
    rdfs:comment 'Name of the rating agency providing the sovereign credit rating (e.g., S&P, Moody\'s, Fitch). Used for rating source attribution and multi-agency rating reconciliation.' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sovereignRatingDate rdf:type rdf:Property ;
    rdfs:label 'Sovereign Rating Date' ;
    rdfs:comment 'Date of the most recent sovereign credit rating assessment. Used for rating staleness checks and triggering rating review workflows.' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sovereignStatus rdf:type rdf:Property ;
    rdfs:label 'Sovereign Status' ;
    rdfs:comment 'Indicates the political sovereignty status of the country or territory. Critical for determining applicable regulatory frameworks, tax treaties, and legal jurisdiction in cross-border transactions.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subRegion rdf:type rdf:Property ;
    rdfs:label 'Sub Region' ;
    rdfs:comment 'Detailed sub-region classification within the broader region (e.g., Northern America, Western Europe, South-Eastern Asia). Used for granular geographic segmentation and risk analysis.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxHavenFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Haven Flag' ;
    rdfs:comment 'Indicates whether the country is classified as a tax haven or low-tax jurisdiction. Used for enhanced due diligence, beneficial ownership verification, and tax evasion risk assessment.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:administratorJurisdictionId rdf:type rdf:Property ;
    rdfs:label 'Administrator Jurisdiction Id' ;
    rdfs:comment 'Foreign key linking to reference.jurisdiction. Business justification: rate_benchmark has administrator_jurisdiction as a STRING representing the legal/regulatory jurisdiction of the benchmark administrator (e.g., FCA for SONIA, CFTC/Fed for SOFR). This should be a FK to' ;
    rdfs:domain ind:RateBenchmark ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Jurisdiction .

ind:fallbackRateBenchmarkId rdf:type rdf:Property ;
    rdfs:label 'Fallback Rate Benchmark Id' ;
    rdfs:comment 'Reference to the alternative benchmark that serves as the fallback rate if this benchmark is discontinued (e.g., SOFR as fallback for USD LIBOR).' ;
    rdfs:domain ind:RateBenchmark ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RateBenchmark .

ind:alternativeBenchmarkNames rdf:type rdf:Property ;
    rdfs:label 'Alternative Benchmark Names' ;
    rdfs:comment 'Comma-separated list of alternative names or abbreviations for the benchmark (e.g., \'Fed Funds, Federal Funds Rate, Effective Federal Funds Rate\').' ;
    rdfs:domain ind:RateBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benchmarkFamily rdf:type rdf:Property ;
    rdfs:label 'Benchmark Family' ;
    rdfs:comment 'Grouping of related benchmarks under a common family name (e.g., LIBOR family includes USD LIBOR, GBP LIBOR, EUR LIBOR; SOFR family includes SOFR, Term SOFR).' ;
    rdfs:domain ind:RateBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compoundingConvention rdf:type rdf:Property ;
    rdfs:label 'Compounding Convention' ;
    rdfs:comment 'Method for aggregating overnight rates into term rates: simple (arithmetic average), compounded (geometric compounding), averaged (simple average), none (single rate, not compounded).' ;
    rdfs:domain ind:RateBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSourceDescription rdf:type rdf:Property ;
    rdfs:label 'Data Source Description' ;
    rdfs:comment 'Description of the underlying data sources used to calculate the benchmark (e.g., tri-party repo transactions cleared through FICC, panel bank submissions, central bank policy rate).' ;
    rdfs:domain ind:RateBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fallbackSpreadAdjustment rdf:type rdf:Property ;
    rdfs:label 'Fallback Spread Adjustment' ;
    rdfs:comment 'Fixed spread (in basis points) added to the fallback rate to account for historical differences between the original benchmark and the fallback benchmark.' ;
    rdfs:domain ind:RateBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:iborTransitionStatus rdf:type rdf:Property ;
    rdfs:label 'Ibor Transition Status' ;
    rdfs:comment 'Current status of the benchmark in the context of IBOR reform: active (current use), legacy (being phased out, e.g., LIBOR), discontinued (no longer published), transition_phase (migration underway), fallback_activated (fallback rate in use).' ;
    rdfs:domain ind:RateBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRiskFreeRate rdf:type rdf:Property ;
    rdfs:label 'Is Risk Free Rate' ;
    rdfs:comment 'Indicates whether the benchmark is classified as a risk-free rate (e.g., SOFR, SONIA, ESTR) as opposed to a credit-sensitive rate (e.g., LIBOR). True for RFRs, False otherwise.' ;
    rdfs:domain ind:RateBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSecuredRate rdf:type rdf:Property ;
    rdfs:label 'Is Secured Rate' ;
    rdfs:comment 'Indicates whether the benchmark is based on secured transactions (e.g., repo transactions for SOFR) as opposed to unsecured lending (e.g., LIBOR). True for secured rates, False for unsecured.' ;
    rdfs:domain ind:RateBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastPublicationDate rdf:type rdf:Property ;
    rdfs:label 'Last Publication Date' ;
    rdfs:comment 'Most recent date on which a rate was published for this benchmark. Used to track currency of data and identify stale benchmarks.' ;
    rdfs:domain ind:RateBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lookbackPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Lookback Period Days' ;
    rdfs:comment 'Number of business days prior to the payment date used to determine the applicable rate (common in SOFR-based loans to allow operational time for rate fixing).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:observationShiftDays rdf:type rdf:Property ;
    rdfs:label 'Observation Shift Days' ;
    rdfs:comment 'Number of days the observation period is shifted backward relative to the interest period (alternative to lookback for SOFR and other overnight rates).' ;
    rdfs:domain ind:RateBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:panelBankCount rdf:type rdf:Property ;
    rdfs:label 'Panel Bank Count' ;
    rdfs:comment 'Number of contributing banks or institutions in the benchmark panel (for panel-based benchmarks like legacy LIBOR). Null for transaction-based benchmarks.' ;
    rdfs:domain ind:RateBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paymentDelayDays rdf:type rdf:Property ;
    rdfs:label 'Payment Delay Days' ;
    rdfs:comment 'Standard number of business days between rate fixing and payment date (e.g., T+2 for some benchmarks).' ;
    rdfs:domain ind:RateBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:publicationSource rdf:type rdf:Property ;
    rdfs:label 'Publication Source' ;
    rdfs:comment 'Official source or platform where the benchmark rate is published (e.g., Federal Reserve website, Bloomberg, Reuters, ICE portal).' ;
    rdfs:domain ind:RateBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryRecognitionStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Recognition Status' ;
    rdfs:comment 'Regulatory approval status of the benchmark: authorized (approved by regulator), recognized (accepted for regulatory purposes), non_recognized (not approved), under_review (pending regulatory assessment).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryRegime rdf:type rdf:Property ;
    rdfs:label 'Regulatory Regime' ;
    rdfs:comment 'Primary regulatory framework governing the benchmark (e.g., EU Benchmark Regulation, UK Benchmark Regulation, IOSCO Principles).' ;
    rdfs:domain ind:RateBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportingCode rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Code' ;
    rdfs:comment 'Standardized code used for regulatory reporting purposes (e.g., CFTC reporting, EMIR reporting, MiFID II transaction reporting).' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tenorConvention rdf:type rdf:Property ;
    rdfs:label 'Tenor Convention' ;
    rdfs:comment 'Standard maturity or term structure for the benchmark (e.g., overnight, 1-month, 3-month, 6-month, 12-month). Overnight benchmarks use \'overnight\'; term benchmarks specify the period. [ENUM-REF-CANDIDATE: overnight|1_week|1_month|3_month|6_month|12_month|spot|custom — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RateBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionVolumeThreshold rdf:type rdf:Property ;
    rdfs:label 'Transaction Volume Threshold' ;
    rdfs:comment 'Minimum daily transaction volume (in currency units) required for the benchmark to be published. Used to assess benchmark robustness and representativeness.' ;
    rdfs:domain ind:RateBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usageScope rdf:type rdf:Property ;
    rdfs:label 'Usage Scope' ;
    rdfs:comment 'Description of typical use cases for the benchmark (e.g., loan pricing, derivatives valuation, asset-liability management, mortgage indexing, corporate debt).' ;
    rdfs:domain ind:RateBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fallbackMethodology rdf:type rdf:Property ;
    rdfs:label 'Fallback Methodology' ;
    rdfs:comment 'Description of the fallback calculation methodology applied if this is a fallback rate (e.g., compounded SOFR plus spread adjustment). Null if not a fallback.' ;
    rdfs:domain ind:BenchmarkRateFixing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fallbackRateIndicator rdf:type rdf:Property ;
    rdfs:label 'Fallback Rate Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this rate is a fallback or substitute rate used when the primary benchmark is unavailable (e.g., LIBOR transition fallbacks). True if this is a fallback rate.' ;
    rdfs:domain ind:BenchmarkRateFixing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fixingDate rdf:type rdf:Property ;
    rdfs:label 'Fixing Date' ;
    rdfs:comment 'The business date on which the benchmark rate was fixed and published by the rate authority. This is the effective date for the rate value.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isBusinessDay rdf:type rdf:Property ;
    rdfs:label 'Is Business Day' ;
    rdfs:comment 'Boolean flag indicating whether the fixing date is a business day in the relevant market. False if the fixing date falls on a weekend or holiday, which may affect rate applicability.' ;
    rdfs:domain ind:BenchmarkRateFixing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRevised rdf:type rdf:Property ;
    rdfs:label 'Is Revised' ;
    rdfs:comment 'Boolean flag indicating whether this fixing is a revision or correction of a previously published rate. True if this record supersedes an earlier fixing for the same date and tenor.' ;
    rdfs:domain ind:BenchmarkRateFixing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:numberOfTransactions rdf:type rdf:Property ;
    rdfs:label 'Number Of Transactions' ;
    rdfs:comment 'The count of individual transactions used to calculate the benchmark rate, if published by the rate authority. Indicates market breadth. Null if not disclosed.' ;
    rdfs:domain ind:BenchmarkRateFixing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:observationPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Observation Period End' ;
    rdfs:comment 'The end date of the observation period used to calculate the rate fixing. Null for spot rates.' ;
    rdfs:domain ind:BenchmarkRateFixing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:observationPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Observation Period Start' ;
    rdfs:comment 'The start date of the observation period used to calculate the rate fixing, applicable for compounded or averaged rates (e.g., SOFR averages). Null for spot rates.' ;
    rdfs:domain ind:BenchmarkRateFixing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:publicationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Publication Timestamp' ;
    rdfs:comment 'The exact date and time when the rate fixing was officially published by the rate authority. Used for audit trails and to determine which rate applies for time-sensitive calculations.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rateBasisPoints rdf:type rdf:Property ;
    rdfs:label 'Rate Basis Points' ;
    rdfs:comment 'The rate value expressed in basis points for convenience (e.g., 525.00 BPS for 5.25%). One basis point equals 0.01%. Commonly used in trading and risk reporting.' ;
    rdfs:domain ind:BenchmarkRateFixing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateValue rdf:type rdf:Property ;
    rdfs:label 'Rate Value' ;
    rdfs:comment 'The published benchmark interest rate value expressed as a decimal (e.g., 0.05250000 for 5.25%). This is the official fixing rate used for loan accrual, derivative settlement, and mark-to-market calculations.' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revisionReason rdf:type rdf:Property ;
    rdfs:label 'Revision Reason' ;
    rdfs:comment 'Explanation provided by the rate authority for why the rate was revised or corrected. Null if not a revision.' ;
    rdfs:domain ind:BenchmarkRateFixing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionSequence rdf:type rdf:Property ;
    rdfs:label 'Revision Sequence' ;
    rdfs:comment 'Sequential number indicating the revision iteration for this fixing date and tenor. Initial publication is 1, first revision is 2, etc. Null if never revised.' ;
    rdfs:domain ind:BenchmarkRateFixing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceAuthority rdf:type rdf:Property ;
    rdfs:label 'Source Authority' ;
    rdfs:comment 'The official organization or entity that published the benchmark rate fixing (e.g., Federal Reserve Bank of New York for SOFR, European Money Markets Institute for EURIBOR, Bank of England for SONIA).' ;
    rdfs:domain ind:BenchmarkRateFixing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spreadAdjustment rdf:type rdf:Property ;
    rdfs:label 'Spread Adjustment' ;
    rdfs:comment 'The spread adjustment (in decimal form) added to the fallback rate to align it with the discontinued benchmark. Used in LIBOR transition scenarios. Null if not applicable.' ;
    rdfs:domain ind:BenchmarkRateFixing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supersededRateValue rdf:type rdf:Property ;
    rdfs:label 'Superseded Rate Value' ;
    rdfs:comment 'The previous rate value that this fixing replaces, if this is a revision. Null for initial publications. Used for audit trails and impact analysis of rate corrections.' ;
    rdfs:domain ind:BenchmarkRateFixing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tenorCode rdf:type rdf:Property ;
    rdfs:label 'Tenor Code' ;
    rdfs:comment 'The maturity period for which the rate applies. Standard tenors include overnight (O/N), tomorrow-next (T/N), spot-next (S/N), and term periods (1W, 1M, 3M, 6M, 12M). Critical for matching rates to loan and derivative contract terms. [ENUM-REF-CANDIDATE: O/N|T/N|S/N|1W|2W|1M|2M|3M|6M|9M|12M — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BenchmarkRateFixing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeTraded rdf:type rdf:Property ;
    rdfs:label 'Volume Traded' ;
    rdfs:comment 'The total transaction volume (in currency units) underlying the rate calculation, if published by the rate authority. Provides transparency on market depth. Null if not disclosed.' ;
    rdfs:domain ind:BenchmarkRateFixing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:benchmarkRateFlag rdf:type rdf:Property ;
    rdfs:label 'Benchmark Rate Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether this rate is an official benchmark rate used for regulatory reporting, financial statement revaluation, or contractual reference (e.g., WM/Reuters 4pm London Fix). Benchmark rates have heightened governance and audit requirements.' ;
    rdfs:domain ind:ExchangeRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crossRateFlag rdf:type rdf:Property ;
    rdfs:label 'Cross Rate Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether this rate is a cross rate (derived from two other currency pairs) rather than a directly traded pair. For example, EUR/GBP may be derived from EUR/USD and GBP/USD. Cross rates may have wider spreads.' ;
    rdfs:domain ind:ExchangeRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ecbPublishedFlag rdf:type rdf:Property ;
    rdfs:label 'Ecb Published Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether this rate was published by the European Central Bank as an official ECB reference rate. ECB rates are used for regulatory reporting and accounting revaluations in the Eurozone.' ;
    rdfs:domain ind:ExchangeRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:expiryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Expiry Timestamp' ;
    rdfs:comment 'The date and time when this exchange rate expires and is no longer valid for use. For spot rates this may be end-of-day, for forward rates this is the forward settlement date. Null indicates an open-ended rate.' ;
    rdfs:domain ind:ExchangeRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fedPublishedFlag rdf:type rdf:Property ;
    rdfs:label 'Fed Published Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether this rate was published by the U.S. Federal Reserve as an official Fed reference rate. Fed rates are used for regulatory reporting and accounting revaluations in the United States.' ;
    rdfs:domain ind:ExchangeRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:glRevaluationEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Gl Revaluation Eligible Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether this rate is approved for use in general ledger foreign currency revaluation processes. GL revaluation rates must meet accounting policy standards and audit requirements.' ;
    rdfs:domain ind:ExchangeRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:holidayAdjustedFlag rdf:type rdf:Property ;
    rdfs:label 'Holiday Adjusted Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether this rate has been adjusted for banking holidays in either the base or quote currency jurisdiction. Holiday adjustments affect settlement dates and may impact rate calculations.' ;
    rdfs:domain ind:ExchangeRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inverseRateValue rdf:type rdf:Property ;
    rdfs:label 'Inverse Rate Value' ;
    rdfs:comment 'The inverse of the rate_value, representing the exchange rate when the base and quote currencies are swapped. Calculated as 1 / rate_value. Stored for performance optimization in bidirectional FX calculations.' ;
    rdfs:domain ind:ExchangeRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quoteCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Quote Currency Code' ;
    rdfs:comment 'The quote currency (counter currency) in the exchange rate pair, represented as a three-letter ISO 4217 currency code. This is the currency in which the base currency is priced.' ;
    rdfs:domain ind:ExchangeRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportingEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Eligible Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether this rate is approved for use in regulatory reporting submissions (e.g., Basel III, CCAR, DFAST, IFRS 9, CECL). Only rates from approved sources and meeting regulatory standards are eligible.' ;
    rdfs:domain ind:ExchangeRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceProvider rdf:type rdf:Property ;
    rdfs:label 'Source Provider' ;
    rdfs:comment 'The name or identifier of the market data provider or central bank that published this exchange rate (e.g., Bloomberg, Reuters, ECB, Federal Reserve, WM/Reuters Closing Spot Rates). Critical for audit trail and rate validation.' ;
    rdfs:domain ind:ExchangeRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triangulationMethod rdf:type rdf:Property ;
    rdfs:label 'Triangulation Method' ;
    rdfs:comment 'The method used to calculate this rate if it is a cross rate. Via_usd indicates the rate was triangulated through USD as the vehicle currency. Not_applicable indicates a directly traded pair. Triangulation method affects precision and spread.' ;
    rdfs:domain ind:ExchangeRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volatilityIndicator rdf:type rdf:Property ;
    rdfs:label 'Volatility Indicator' ;
    rdfs:comment 'Qualitative assessment of the market volatility level at the time this rate was published. High or extreme volatility may trigger additional risk management controls or require manual review before use in automated systems.' ;
    rdfs:domain ind:ExchangeRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appliesToDerivatives rdf:type rdf:Property ;
    rdfs:label 'Applies To Derivatives' ;
    rdfs:comment 'Indicates whether this calendar is used for derivatives contract settlement, coupon payment dates, and option expiry calculations (e.g., interest rate swaps, Credit Default Swaps (CDS), foreign exchange (FX) forwards). True for calendars referenced in International Swaps and Derivatives Association (ISDA) documentation.' ;
    rdfs:domain ind:HolidayCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appliesToLoans rdf:type rdf:Property ;
    rdfs:label 'Applies To Loans' ;
    rdfs:comment 'Indicates whether this calendar is used for loan payment scheduling, interest accrual period calculations, and covenant compliance date computations. True for banking calendars used in commercial lending and credit origination.' ;
    rdfs:domain ind:HolidayCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appliesToPayments rdf:type rdf:Property ;
    rdfs:label 'Applies To Payments' ;
    rdfs:comment 'Indicates whether this calendar is used for payment processing and funds transfer date calculations (e.g., Automated Clearing House (ACH), wire transfers, Real-Time Gross Settlement (RTGS), Society for Worldwide Interbank Financial Telecommunication (SWIFT) payments). True for payment system and banking calendars.' ;
    rdfs:domain ind:HolidayCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appliesToSecurities rdf:type rdf:Property ;
    rdfs:label 'Applies To Securities' ;
    rdfs:comment 'Indicates whether this calendar is used for securities settlement date calculations (e.g., equity trades, bond settlements, derivatives). True for exchange and clearing calendars; may be false for payment-only or banking-only calendars.' ;
    rdfs:domain ind:HolidayCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:calendarCode rdf:type rdf:Property ;
    rdfs:label 'Calendar Code' ;
    rdfs:comment 'Unique business identifier code for the holiday calendar (e.g., TARGET2, NYSE, SIFMA, LME, FED, ECB). Used as the externally-known reference key for settlement and payment systems.' ;
    rdfs:domain ind:HolidayCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calendarName rdf:type rdf:Property ;
    rdfs:label 'Calendar Name' ;
    rdfs:comment 'Full descriptive name of the holiday calendar (e.g., Trans-European Automated Real-time Gross Settlement Express Transfer System, New York Stock Exchange, Securities Industry and Financial Markets Association).' ;
    rdfs:domain ind:HolidayCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calendarSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Calendar Source System' ;
    rdfs:comment 'Name of the upstream system or data provider from which this calendar is sourced (e.g., Bloomberg, Reuters, SWIFT, internal treasury system, regulatory authority website). Used for data lineage and reconciliation.' ;
    rdfs:domain ind:HolidayCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calendarStatus rdf:type rdf:Property ;
    rdfs:label 'Calendar Status' ;
    rdfs:comment 'Current lifecycle status of the holiday calendar. Active calendars are in use for settlement and payment calculations. Inactive calendars are no longer used but retained for historical reference. Deprecated calendars are being phased out (e.g., LIBOR-based calendars transitioning to SOFR). Pending calendars are scheduled for future activation.' ;
    rdfs:domain ind:HolidayCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calendarType rdf:type rdf:Property ;
    rdfs:label 'Calendar Type' ;
    rdfs:comment 'Classification of the calendar by its primary business purpose: settlement (for trade settlement systems), exchange (for securities exchanges), banking (for commercial banking operations), clearing (for clearing houses), payment (for payment systems), public (for national public holidays), or custom (for institution-specific calendars). [ENUM-REF-CANDIDATE: settlement|exchange|banking|clearing|payment|public|custom — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:HolidayCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calendarUrl rdf:type rdf:Property ;
    rdfs:label 'Calendar Url' ;
    rdfs:comment 'Web address of the official source where the authoritative holiday calendar is published (e.g., central bank website, exchange website, SIFMA holiday schedule page). Used for reference and validation.' ;
    rdfs:domain ind:HolidayCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calendarVersion rdf:type rdf:Property ;
    rdfs:label 'Calendar Version' ;
    rdfs:comment 'Version identifier for this calendar publication (e.g., 2024, 1.0, 2.3). Calendars are versioned annually or when significant changes occur (e.g., addition of new public holidays, changes in weekend patterns). Used to track calendar updates and ensure correct historical calculations.' ;
    rdfs:domain ind:HolidayCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialCenterCode rdf:type rdf:Property ;
    rdfs:label 'Financial Center Code' ;
    rdfs:comment 'ISO 10383 Market Identifier Code (MIC) or ISO 3166-1 alpha-2 country code representing the financial center or market to which this calendar applies (e.g., XNYS for NYSE, XLON for London Stock Exchange, US for United States, GB for United Kingdom).' ;
    rdfs:domain ind:HolidayCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingAuthority rdf:type rdf:Property ;
    rdfs:label 'Governing Authority' ;
    rdfs:comment 'Name of the regulatory body, central bank, exchange, or industry association that publishes and maintains this calendar (e.g., European Central Bank, Federal Reserve System, New York Stock Exchange, Securities Industry and Financial Markets Association, Bank of England).' ;
    rdfs:domain ind:HolidayCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDefaultCalendar rdf:type rdf:Property ;
    rdfs:label 'Is Default Calendar' ;
    rdfs:comment 'Indicates whether this is the default holiday calendar for the institution or financial center when no specific calendar is designated. Typically true for the primary banking calendar of the institutions home country or the main exchange calendar for securities operations.' ;
    rdfs:domain ind:HolidayCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastUpdatedDate rdf:type rdf:Property ;
    rdfs:label 'Last Updated Date' ;
    rdfs:comment 'The date on which this calendar record was last modified in the system. Used for change tracking and data quality monitoring.' ;
    rdfs:domain ind:HolidayCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:publicationDate rdf:type rdf:Property ;
    rdfs:label 'Publication Date' ;
    rdfs:comment 'The date on which this calendar version was officially published or released by the governing authority. Used for audit trails and to determine when calendar updates became available to market participants.' ;
    rdfs:domain ind:HolidayCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:supportsPartialDays rdf:type rdf:Property ;
    rdfs:label 'Supports Partial Days' ;
    rdfs:comment 'Indicates whether this calendar supports partial business days (e.g., early close days for exchanges on days before major holidays, half-day trading sessions). True if the calendar includes partial day holiday entries; false if all non-business days are full-day closures.' ;
    rdfs:domain ind:HolidayCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:weekendPattern rdf:type rdf:Property ;
    rdfs:label 'Weekend Pattern' ;
    rdfs:comment 'Standard weekend days for this financial center or market. Most Western markets observe Saturday-Sunday; Middle Eastern markets may observe Friday-Saturday or Thursday-Friday. Used in conjunction with holiday dates to determine non-business days for settlement calculations.' ;
    rdfs:domain ind:HolidayCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holidayDateId rdf:type rdf:Property ;
    rdfs:label 'Holiday Date Id' ;
    rdfs:comment 'Unique identifier for the holiday date record. Primary key.' ;
    rdfs:domain ind:HolidayDate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualHolidayDate rdf:type rdf:Property ;
    rdfs:label 'Actual Holiday Date' ;
    rdfs:comment 'The actual calendar date of the holiday before any substitution or observance adjustment. Populated when observance_rule is \'substitute\' and the observed date differs from the actual date.' ;
    rdfs:domain ind:HolidayDate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:affectsAccrual rdf:type rdf:Property ;
    rdfs:label 'Affects Accrual' ;
    rdfs:comment 'Indicates whether this holiday affects interest accrual calculations for loans, deposits, and fixed income securities. True if accrual is suspended or adjusted, False otherwise.' ;
    rdfs:domain ind:HolidayDate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:affectsPayment rdf:type rdf:Property ;
    rdfs:label 'Affects Payment' ;
    rdfs:comment 'Indicates whether this holiday affects scheduled payment processing (loan payments, coupon payments, dividends). True if payments are deferred to the next business day, False otherwise.' ;
    rdfs:domain ind:HolidayDate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:affectsSettlement rdf:type rdf:Property ;
    rdfs:label 'Affects Settlement' ;
    rdfs:comment 'Indicates whether this holiday affects securities settlement and trade date plus one (T+1) or T+2 calculations. True if settlement is impacted, False otherwise.' ;
    rdfs:domain ind:HolidayDate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:holidayDate rdf:type rdf:Property ;
    rdfs:label 'Holiday Date' ;
    rdfs:comment 'The specific non-business date observed as a holiday. Used for settlement date calculations, accrual period adjustments, and payment scheduling across loan, securities, and treasury operations.' ;
    rdfs:domain ind:HolidayDate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:holidayName rdf:type rdf:Property ;
    rdfs:label 'Holiday Name' ;
    rdfs:comment 'The official name or description of the holiday (e.g., New Year\'s Day, Christmas, Good Friday, Independence Day, Market Closure).' ;
    rdfs:domain ind:HolidayDate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holidayType rdf:type rdf:Property ;
    rdfs:label 'Holiday Type' ;
    rdfs:comment 'Classification of the holiday type. Public: national/regional public holiday. Exchange: securities exchange closure. Settlement: payment system closure (ACH, RTGS, SWIFT). Bank: banking institution closure. Custom: client-specific or internal calendar event. Regulatory: regulatory reporting deadline adjustment.' ;
    rdfs:domain ind:HolidayDate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPartialDay rdf:type rdf:Property ;
    rdfs:label 'Is Partial Day' ;
    rdfs:comment 'Indicates whether the holiday is a partial day (e.g., early market close, half-day banking). True if partial, False if full-day closure.' ;
    rdfs:domain ind:HolidayDate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketIdentifierCode rdf:type rdf:Property ;
    rdfs:label 'Market Identifier Code' ;
    rdfs:comment 'ISO 10383 Market Identifier Code (MIC) for the exchange or trading venue to which this holiday applies (e.g., XNYS for NYSE, XLON for London Stock Exchange). Null if not exchange-specific.' ;
    rdfs:domain ind:HolidayDate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:observanceRule rdf:type rdf:Property ;
    rdfs:label 'Observance Rule' ;
    rdfs:comment 'Indicates how the holiday date is determined. Fixed: same calendar date each year. Floating: varies by rule (e.g., third Monday of January). Calculated: computed based on lunar calendar or other algorithm. Substitute: observed on a different date when the actual holiday falls on a weekend.' ;
    rdfs:domain ind:HolidayDate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partialDayCloseTime rdf:type rdf:Property ;
    rdfs:label 'Partial Day Close Time' ;
    rdfs:comment 'The closing time for partial day holidays in HH:mm format (24-hour). Null if not a partial day or if closed all day.' ;
    rdfs:domain ind:HolidayDate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:partialDayOpenTime rdf:type rdf:Property ;
    rdfs:label 'Partial Day Open Time' ;
    rdfs:comment 'The opening time for partial day holidays in HH:mm format (24-hour). Null if not a partial day or if closed all day.' ;
    rdfs:domain ind:HolidayDate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:paymentSystemCode rdf:type rdf:Property ;
    rdfs:label 'Payment System Code' ;
    rdfs:comment 'Code identifying the payment or settlement system affected by this holiday (e.g., FEDWIRE, CHIPS, TARGET2, CHAPS, ACH). Used for payment scheduling and liquidity management.' ;
    rdfs:domain ind:HolidayDate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recurringPattern rdf:type rdf:Property ;
    rdfs:label 'Recurring Pattern' ;
    rdfs:comment 'Description of the recurrence pattern for floating holidays (e.g., \'Third Monday in January\', \'Last Friday in March\', \'Easter Sunday + 1 day\'). Null for fixed-date holidays.' ;
    rdfs:domain ind:HolidayDate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reference' ;
    rdfs:comment 'Reference to the regulatory rule, statute, or official gazette that establishes this holiday (e.g., \'Federal Reserve Board Regulation D\', \'UK Banking Act 1971 Schedule 1\').' ;
    rdfs:domain ind:HolidayDate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:year rdf:type rdf:Property ;
    rdfs:label 'Year' ;
    rdfs:comment 'The calendar year in which this holiday occurs. Facilitates year-based filtering and multi-year calendar generation.' ;
    rdfs:domain ind:HolidayDate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bic11 rdf:type rdf:Property ;
    rdfs:label 'Bic11' ;
    rdfs:comment 'The 11-character BIC code including the 3-character branch code suffix. Used for branch-level identification in SWIFT messaging.' ;
    rdfs:domain ind:BicDirectory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bic8 rdf:type rdf:Property ;
    rdfs:label 'Bic8' ;
    rdfs:comment 'The 8-character BIC code identifying the institution, comprising institution code (4 chars), country code (2 chars), and location code (2 chars). Used for head office identification.' ;
    rdfs:domain ind:BicDirectory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:branchName rdf:type rdf:Property ;
    rdfs:label 'Branch Name' ;
    rdfs:comment 'The name of the specific branch or office identified by the BIC11 code. Null for head office BIC8 entries.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:connectivityStatus rdf:type rdf:Property ;
    rdfs:label 'Connectivity Status' ;
    rdfs:comment 'The current operational status of the BIC code in the SWIFT network. Live indicates active production use; test indicates sandbox environment; inactive indicates decommissioned; suspended indicates temporarily disabled.' ;
    rdfs:domain ind:BicDirectory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correspondentBankingRole rdf:type rdf:Property ;
    rdfs:label 'Correspondent Banking Role' ;
    rdfs:comment 'The role this institution plays in correspondent banking relationships. Nostro indicates the institution holds accounts at other banks; vostro indicates other banks hold accounts here; both indicates bidirectional relationships; none indicates no correspondent banking.' ;
    rdfs:domain ind:BicDirectory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cutOffTimeLocal rdf:type rdf:Property ;
    rdfs:label 'Cut Off Time Local' ;
    rdfs:comment 'The local time (HH:MM format) by which payment instructions must be received for same-day value. Used by payment processing hubs for scheduling.' ;
    rdfs:domain ind:BicDirectory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ibanSupported rdf:type rdf:Property ;
    rdfs:label 'Iban Supported' ;
    rdfs:comment 'Indicates whether the institution supports IBAN format for account identification. Mandatory in SEPA countries; optional elsewhere.' ;
    rdfs:domain ind:BicDirectory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:institutionName rdf:type rdf:Property ;
    rdfs:label 'Institution Name' ;
    rdfs:comment 'The legal name of the financial institution associated with this BIC code. Used for correspondent banking identification and payment processing.' ;
    rdfs:domain ind:BicDirectory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nationalIdentifierCode rdf:type rdf:Property ;
    rdfs:label 'National Identifier Code' ;
    rdfs:comment 'The national registration or license number assigned by the domestic banking regulator. Format varies by jurisdiction (e.g., FDIC Certificate Number in USA, Financial Conduct Authority (FCA) number in UK).' ;
    rdfs:domain ind:BicDirectory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentServicesEnabled rdf:type rdf:Property ;
    rdfs:label 'Payment Services Enabled' ;
    rdfs:comment 'Indicates whether this BIC is enabled for payment processing services including wire transfers, Automated Clearing House (ACH), and Real-Time Gross Settlement (RTGS).' ;
    rdfs:domain ind:BicDirectory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:routingNumber rdf:type rdf:Property ;
    rdfs:label 'Routing Number' ;
    rdfs:comment 'The domestic routing or sort code used for local payment clearing. Examples include American Bankers Association (ABA) routing number (USA), sort code (UK), Bankleitzahl (Germany). Null for institutions without domestic clearing participation.' ;
    rdfs:domain ind:BicDirectory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securitiesServicesEnabled rdf:type rdf:Property ;
    rdfs:label 'Securities Services Enabled' ;
    rdfs:comment 'Indicates whether this BIC is enabled for securities settlement, custody, and clearing services. Relevant for broker-dealers and custodian banks.' ;
    rdfs:domain ind:BicDirectory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sepaParticipant rdf:type rdf:Property ;
    rdfs:label 'Sepa Participant' ;
    rdfs:comment 'Indicates whether the institution is a participant in the Single Euro Payments Area for euro-denominated payments. Applicable to European Economic Area (EEA) institutions.' ;
    rdfs:domain ind:BicDirectory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:swiftServiceProfile rdf:type rdf:Property ;
    rdfs:label 'Swift Service Profile' ;
    rdfs:comment 'Comma-separated list of SWIFT service types supported by this BIC. Examples include FIN (financial messaging), FileAct (file transfer), InterAct (real-time messaging), and Browse (information retrieval).' ;
    rdfs:domain ind:BicDirectory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeFinanceServicesEnabled rdf:type rdf:Property ;
    rdfs:label 'Trade Finance Services Enabled' ;
    rdfs:comment 'Indicates whether this BIC is enabled for trade finance services including letters of credit, guarantees, and documentary collections.' ;
    rdfs:domain ind:BicDirectory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalAddressCountryId rdf:type rdf:Property ;
    rdfs:label 'Legal Address Country Id' ;
    rdfs:comment 'Foreign key linking to reference.country. Business justification: LEI entities have legal addresses in specific countries. The legal_address_country_code STRING column should be replaced with a proper FK to country.country_id. This is the first of two FKs from lei_r' ;
    rdfs:domain ind:LeiRegistry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:entityCategory rdf:type rdf:Property ;
    rdfs:label 'Entity Category' ;
    rdfs:comment 'The category classification of the entity as defined by GLEIF, indicating the type of legal entity (e.g., BRANCH for branch offices, FUND for investment funds, GENERAL for standard legal entities). [ENUM-REF-CANDIDATE: BRANCH|FUND|SOLE_PROPRIETOR|RESIDENT_GOVERNMENT_ENTITY|NON_RESIDENT_GOVERNMENT_ENTITY|INTERNATIONAL_ORGANIZATION|GENERAL — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LeiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entityExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Entity Expiration Date' ;
    rdfs:comment 'The date on which the legal entity is scheduled to expire, dissolve, or terminate, if applicable. This is relevant for entities with a defined lifespan such as special purpose vehicles, project companies, or entities in liquidation.' ;
    rdfs:domain ind:LeiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:entityExpirationReason rdf:type rdf:Property ;
    rdfs:label 'Entity Expiration Reason' ;
    rdfs:comment 'The reason for the entitys expiration or termination, if applicable. Indicates the business or legal event that led to the entitys cessation.' ;
    rdfs:domain ind:LeiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entityRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Entity Registration Number' ;
    rdfs:comment 'The unique registration number or identifier assigned to the entity by the registration authority in its jurisdiction of incorporation or registration.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entityStatus rdf:type rdf:Property ;
    rdfs:label 'Entity Status' ;
    rdfs:comment 'The operational status of the legal entity as reported by the registration authority. ACTIVE indicates the entity is currently operating; INACTIVE indicates the entity has ceased operations, been dissolved, or is otherwise non-operational.' ;
    rdfs:domain ind:LeiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersAddressCity rdf:type rdf:Property ;
    rdfs:label 'Headquarters Address City' ;
    rdfs:comment 'The city or municipality component of the headquarters address.' ;
    rdfs:domain ind:LeiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersAddressCountryCode rdf:type rdf:Property ;
    rdfs:label 'Headquarters Address Country Code' ;
    rdfs:comment 'The ISO 3166-1 alpha-2 two-letter country code representing the country of the headquarters address.' ;
    rdfs:domain ind:LeiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Headquarters Address Line 1' ;
    rdfs:comment 'The first line of the headquarters address where the entity conducts its primary business operations, which may differ from the legal address.' ;
    rdfs:domain ind:LeiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Headquarters Address Line 2' ;
    rdfs:comment 'The second line of the headquarters address, containing additional address details.' ;
    rdfs:domain ind:LeiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersAddressPostalCode rdf:type rdf:Property ;
    rdfs:label 'Headquarters Address Postal Code' ;
    rdfs:comment 'The postal code or ZIP code component of the headquarters address.' ;
    rdfs:domain ind:LeiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersAddressRegion rdf:type rdf:Property ;
    rdfs:label 'Headquarters Address Region' ;
    rdfs:comment 'The region, state, province, or administrative subdivision component of the headquarters address.' ;
    rdfs:domain ind:LeiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initialRegistrationDate rdf:type rdf:Property ;
    rdfs:label 'Initial Registration Date' ;
    rdfs:comment 'The date when the LEI was first issued to the entity by a Local Operating Unit (LOU). This represents the original registration date in the GLEIF system.' ;
    rdfs:domain ind:LeiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastUpdateDate rdf:type rdf:Property ;
    rdfs:label 'Last Update Date' ;
    rdfs:comment 'The date when the LEI record was last updated in the GLEIF system, reflecting changes to entity information, status, or other attributes.' ;
    rdfs:domain ind:LeiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalAddressCity rdf:type rdf:Property ;
    rdfs:label 'Legal Address City' ;
    rdfs:comment 'The city or municipality component of the legal address.' ;
    rdfs:domain ind:LeiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Legal Address Line 1' ;
    rdfs:comment 'The first line of the legal address of the entity as registered with the relevant registration authority. This is the official address for legal and regulatory purposes.' ;
    rdfs:domain ind:LeiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Legal Address Line 2' ;
    rdfs:comment 'The second line of the legal address, typically containing additional address details such as suite, floor, or building information.' ;
    rdfs:domain ind:LeiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalAddressPostalCode rdf:type rdf:Property ;
    rdfs:label 'Legal Address Postal Code' ;
    rdfs:comment 'The postal code or ZIP code component of the legal address.' ;
    rdfs:domain ind:LeiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalAddressRegion rdf:type rdf:Property ;
    rdfs:label 'Legal Address Region' ;
    rdfs:comment 'The region, state, province, or administrative subdivision component of the legal address.' ;
    rdfs:domain ind:LeiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalEntityName rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Name' ;
    rdfs:comment 'The official legal name of the entity as registered with the relevant registration authority. This is the primary legal name under which the entity operates and is recognized in legal and regulatory contexts.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalEntityNameLocal rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Name Local' ;
    rdfs:comment 'The legal name of the entity in the local language and script of the jurisdiction of registration, if different from the transliterated or English version.' ;
    rdfs:domain ind:LeiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalFormCode rdf:type rdf:Property ;
    rdfs:label 'Legal Form Code' ;
    rdfs:comment 'The code representing the legal form of the entity (e.g., corporation, partnership, trust) as defined by the Entity Legal Forms (ELF) code list maintained by GLEIF.' ;
    rdfs:domain ind:LeiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalFormName rdf:type rdf:Property ;
    rdfs:label 'Legal Form Name' ;
    rdfs:comment 'The descriptive name of the legal form corresponding to the legal form code (e.g., Public Limited Company, Limited Liability Company).' ;
    rdfs:domain ind:LeiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leiCode rdf:type rdf:Property ;
    rdfs:label 'Lei Code' ;
    rdfs:comment 'The 20-character alphanumeric ISO 17442 Legal Entity Identifier code assigned to the legal entity by a Local Operating Unit (LOU) under the Global Legal Entity Identifier Foundation (GLEIF) framework. Required for MiFID II, EMIR, and Dodd-Frank regulatory reporting.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leiStatus rdf:type rdf:Property ;
    rdfs:label 'Lei Status' ;
    rdfs:comment 'The current status of the LEI code itself within the GLEIF system. ISSUED indicates an active LEI; LAPSED indicates the LEI has not been renewed; MERGED, RETIRED, ANNULLED, CANCELLED indicate various termination states; TRANSFERRED and PENDING_TRANSFER indicate LEI management changes between LOUs. [ENUM-REF-CANDIDATE: ISSUED|LAPSED|MERGED|RETIRED|ANNULLED|CANCELLED|TRANSFERRED|PENDING_TRANSFER|PENDING_ARCHIVAL — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LeiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managingLouCode rdf:type rdf:Property ;
    rdfs:label 'Managing Lou Code' ;
    rdfs:comment 'The code identifying the Local Operating Unit (LOU) that currently manages and maintains the LEI record. LOUs are accredited organizations authorized by GLEIF to issue and manage LEIs.' ;
    rdfs:domain ind:LeiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managingLouName rdf:type rdf:Property ;
    rdfs:label 'Managing Lou Name' ;
    rdfs:comment 'The name of the Local Operating Unit (LOU) that currently manages the LEI record (e.g., London Stock Exchange, Bloomberg Finance L.P., DTCC).' ;
    rdfs:domain ind:LeiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextRenewalDate rdf:type rdf:Property ;
    rdfs:label 'Next Renewal Date' ;
    rdfs:comment 'The date by which the LEI must be renewed to maintain its ISSUED status. LEIs must be renewed annually; failure to renew results in a LAPSED status.' ;
    rdfs:domain ind:LeiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:registrationAuthorityCode rdf:type rdf:Property ;
    rdfs:label 'Registration Authority Code' ;
    rdfs:comment 'The identifier of the registration authority (business registry) where the entity is officially registered. This is typically a code from the Registration Authorities Code List (RAL) maintained by GLEIF.' ;
    rdfs:domain ind:LeiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Registration Authority Name' ;
    rdfs:comment 'The name of the registration authority or business registry where the entity is officially registered (e.g., Companies House UK, Delaware Division of Corporations).' ;
    rdfs:domain ind:LeiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipLastUpdateDate rdf:type rdf:Property ;
    rdfs:label 'Relationship Last Update Date' ;
    rdfs:comment 'The date when the parent-child relationship information (direct parent and ultimate parent LEIs) was last updated or validated in the GLEIF system.' ;
    rdfs:domain ind:LeiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:successorLei rdf:type rdf:Property ;
    rdfs:label 'Successor Lei' ;
    rdfs:comment 'The LEI code of the successor entity, if this entity has been merged, acquired, or otherwise succeeded by another legal entity. Used to maintain continuity in regulatory reporting and relationship tracking.' ;
    rdfs:domain ind:LeiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ultimateParentLei rdf:type rdf:Property ;
    rdfs:label 'Ultimate Parent Lei' ;
    rdfs:comment 'The LEI code of the ultimate parent entity at the top of the corporate ownership hierarchy. This represents the highest-level parent entity that is not itself owned or controlled by another entity, as reported under GLEIF Level 2 relationship data. Required for consolidated regulatory reporting and risk assessment.' ;
    rdfs:domain ind:LeiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationSource rdf:type rdf:Property ;
    rdfs:label 'Validation Source' ;
    rdfs:comment 'The level of validation and corroboration applied to the relationship data. FULLY_CORROBORATED indicates both parent and child have confirmed the relationship; PARTIALLY_CORROBORATED indicates one party has confirmed; ENTITY_SUPPLIED_ONLY indicates self-reported data without external validation; PENDING indicates validation is in progress.' ;
    rdfs:domain ind:LeiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amlMonitoringRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Aml Monitoring Required Flag' ;
    rdfs:comment 'Indicates whether transactions for this product type require anti-money laundering transaction monitoring, suspicious activity report (SAR) screening, and currency transaction report (CTR) filing.' ;
    rdfs:domain ind:ProductType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bookingModel rdf:type rdf:Property ;
    rdfs:label 'Booking Model' ;
    rdfs:comment 'Accounting treatment and valuation methodology applied to this product type (accrual, fair value, amortized cost, held for trading, available for sale). Determines how the product is measured and reported in the general ledger.' ;
    rdfs:domain ind:ProductType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ccarDfastCategory rdf:type rdf:Property ;
    rdfs:label 'Ccar Dfast Category' ;
    rdfs:comment 'Product classification used in CCAR and DFAST stress testing scenarios for capital planning and regulatory submissions to the Federal Reserve.' ;
    rdfs:domain ind:ProductType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ceclPortfolioSegment rdf:type rdf:Property ;
    rdfs:label 'Cecl Portfolio Segment' ;
    rdfs:comment 'Portfolio segment assignment for CECL expected credit loss calculation and allowance for credit losses (ACL) estimation under FASB ASC 326.' ;
    rdfs:domain ind:ProductType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collateralRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Collateral Required Flag' ;
    rdfs:comment 'Indicates whether this product type typically requires collateral or security (true for secured lending products, false for unsecured products).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Credit Risk Flag' ;
    rdfs:comment 'Indicates whether this product type carries credit risk exposure requiring probability of default (PD), loss given default (LGD), and exposure at default (EAD) calculations for capital adequacy purposes.' ;
    rdfs:domain ind:ProductType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:effectiveEndDate rdf:type rdf:Property ;
    rdfs:label 'Effective End Date' ;
    rdfs:comment 'The date on which this product type was discontinued or retired from the product catalog. Null for currently active products. Used for temporal validity and product lifecycle management.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Effective Start Date' ;
    rdfs:comment 'The date from which this product type became available for booking and customer origination. Used for temporal validity and historical product analysis.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fatcaReportableFlag rdf:type rdf:Property ;
    rdfs:label 'Fatca Reportable Flag' ;
    rdfs:comment 'Indicates whether accounts or transactions under this product type are subject to FATCA reporting requirements for U.S. tax compliance.' ;
    rdfs:domain ind:ProductType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:feeScheduleType rdf:type rdf:Property ;
    rdfs:label 'Fee Schedule Type' ;
    rdfs:comment 'Reference to the applicable fee schedule or pricing model for this product type (e.g., Standard Commercial Lending Fees, Wealth Management Advisory Fees, Transaction Banking Fees). Used to link product types to fee structures.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccountMapping rdf:type rdf:Property ;
    rdfs:label 'Gl Account Mapping' ;
    rdfs:comment 'Reference to the general ledger account code(s) or chart of accounts segment used for booking transactions of this product type. Enables financial reporting and reconciliation.' ;
    rdfs:domain ind:ProductType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interestBearingFlag rdf:type rdf:Property ;
    rdfs:label 'Interest Bearing Flag' ;
    rdfs:comment 'Indicates whether this product type accrues or pays interest (true for interest-bearing products like loans and deposits, false for non-interest products like guarantees and advisory services).' ;
    rdfs:domain ind:ProductType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kycRequirementLevel rdf:type rdf:Property ;
    rdfs:label 'Kyc Requirement Level' ;
    rdfs:comment 'The level of customer due diligence and KYC documentation required for this product type (standard, enhanced for high-risk products, simplified for low-risk, or not required for non-customer-facing products).' ;
    rdfs:domain ind:ProductType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liquidityRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Liquidity Risk Flag' ;
    rdfs:comment 'Indicates whether this product type contributes to liquidity risk metrics such as Liquidity Coverage Ratio (LCR) and Net Stable Funding Ratio (NSFR).' ;
    rdfs:domain ind:ProductType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lobOwnership rdf:type rdf:Property ;
    rdfs:label 'Lob Ownership' ;
    rdfs:comment 'The primary line of business or business unit responsible for managing, marketing, and servicing this product type (e.g., Commercial Banking, Investment Banking, Wealth Management, Treasury).' ;
    rdfs:domain ind:ProductType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Market Risk Flag' ;
    rdfs:comment 'Indicates whether this product type is subject to market risk (interest rate, foreign exchange, equity, commodity price movements) requiring Value at Risk (VaR) and stress testing.' ;
    rdfs:domain ind:ProductType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minimumAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Amount' ;
    rdfs:comment 'The minimum transaction or account balance amount required for this product type, expressed in the bank\'s base currency. Used for product eligibility and origination controls.' ;
    rdfs:domain ind:ProductType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:multiCurrencyFlag rdf:type rdf:Property ;
    rdfs:label 'Multi Currency Flag' ;
    rdfs:comment 'Indicates whether this product type supports multiple currencies (true for multi-currency accounts and foreign exchange products, false for single-currency products).' ;
    rdfs:domain ind:ProductType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operationalRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Operational Risk Flag' ;
    rdfs:comment 'Indicates whether this product type is subject to operational risk capital requirements under the Standardized Measurement Approach (SMA) or Advanced Measurement Approach (AMA).' ;
    rdfs:domain ind:ProductType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productFamily rdf:type rdf:Property ;
    rdfs:label 'Product Family' ;
    rdfs:comment 'High-level grouping of product types into major business lines (lending, deposit, investment, trading, advisory, payment, guarantee, custody, other). [ENUM-REF-CANDIDATE: lending|deposit|investment|trading|advisory|payment|guarantee|custody|other — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ProductType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productLifecycleStatus rdf:type rdf:Property ;
    rdfs:label 'Product Lifecycle Status' ;
    rdfs:comment 'Current lifecycle state of the product type in the bank\'s product catalog (active for current offerings, inactive for temporarily unavailable, discontinued for retired products, pending approval for new products under review, sunset for products being phased out).' ;
    rdfs:domain ind:ProductType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productTypeCode rdf:type rdf:Property ;
    rdfs:label 'Product Type Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the product type across all bank systems. Used as the business key for product classification in regulatory reporting and internal systems.' ;
    rdfs:domain ind:ProductType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productTypeDescription rdf:type rdf:Property ;
    rdfs:label 'Product Type Description' ;
    rdfs:comment 'Detailed business description of the product type, including key features, typical use cases, target customer segments, and distinguishing characteristics.' ;
    rdfs:domain ind:ProductType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productTypeName rdf:type rdf:Property ;
    rdfs:label 'Product Type Name' ;
    rdfs:comment 'Full business name of the product type as recognized by business users and customers (e.g., Term Loan, Revolving Credit Facility, Demand Deposit Account, Interest Rate Swap).' ;
    rdfs:domain ind:ProductType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryProductCategoryBasel rdf:type rdf:Property ;
    rdfs:label 'Regulatory Product Category Basel' ;
    rdfs:comment 'Product classification according to Basel III regulatory framework for capital adequacy and risk-weighted asset (RWA) calculation (e.g., Corporate Exposure, Retail Exposure, Sovereign Exposure).' ;
    rdfs:domain ind:ProductType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryProductCategoryIfrs9 rdf:type rdf:Property ;
    rdfs:label 'Regulatory Product Category Ifrs9' ;
    rdfs:comment 'Product classification according to IFRS 9 accounting standard for financial instruments, determining measurement basis (amortized cost, fair value through other comprehensive income, fair value through profit or loss) and expected credit loss (ECL) calculation approach.' ;
    rdfs:domain ind:ProductType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportingCategory rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Category' ;
    rdfs:comment 'Standardized category code used for regulatory reporting submissions to Federal Reserve, OCC, FDIC, SEC, or other governing bodies (e.g., Call Report schedule codes, FR Y-9C line items).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rwaApproach rdf:type rdf:Property ;
    rdfs:label 'Rwa Approach' ;
    rdfs:comment 'The Basel III approach used to calculate risk-weighted assets for this product type (standardized approach, foundation internal ratings-based, advanced internal ratings-based, or not applicable for non-credit products).' ;
    rdfs:domain ind:ProductType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaServiceLevel rdf:type rdf:Property ;
    rdfs:label 'Sla Service Level' ;
    rdfs:comment 'The service level commitment associated with this product type, defining response times, processing speeds, and support availability (standard, priority, premium, or not applicable for non-service products).' ;
    rdfs:domain ind:ProductType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subProductType rdf:type rdf:Property ;
    rdfs:label 'Sub Product Type' ;
    rdfs:comment 'Granular sub-classification within the product type (e.g., for Term Loan: Senior Secured, Subordinated; for Deposit: Savings, Checking, Money Market).' ;
    rdfs:domain ind:ProductType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxReportingCategory rdf:type rdf:Property ;
    rdfs:label 'Tax Reporting Category' ;
    rdfs:comment 'Tax classification for this product type used for IRS Form 1099 reporting, withholding tax calculations, and tax compliance (e.g., interest income, dividend income, capital gains).' ;
    rdfs:domain ind:ProductType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typicalTermMonths rdf:type rdf:Property ;
    rdfs:label 'Typical Term Months' ;
    rdfs:comment 'The standard or most common term length in months for this product type (e.g., 60 months for a 5-year term loan, 12 months for a 1-year certificate of deposit). Null for demand or perpetual products.' ;
    rdfs:domain ind:ProductType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentJurisdictionId rdf:type rdf:Property ;
    rdfs:label 'Parent Jurisdiction Id' ;
    rdfs:comment 'Reference to the parent jurisdiction for hierarchical relationships (e.g., New York State\'s parent is United States). Null for top-level jurisdictions.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Jurisdiction .

ind:accountingStandard rdf:type rdf:Property ;
    rdfs:label 'Accounting Standard' ;
    rdfs:comment 'Primary accounting standard required for financial reporting in this jurisdiction: International Financial Reporting Standards (IFRS), United States Generally Accepted Accounting Principles (US GAAP), local GAAP, or mixed.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amlAuthority rdf:type rdf:Property ;
    rdfs:label 'Aml Authority' ;
    rdfs:comment 'Name of the primary anti-money laundering and financial crime enforcement authority in this jurisdiction (e.g., Financial Crimes Enforcement Network, Financial Intelligence Unit).' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselImplementationStatus rdf:type rdf:Property ;
    rdfs:label 'Basel Implementation Status' ;
    rdfs:comment 'Status of Basel III/IV capital and liquidity framework implementation in this jurisdiction. Critical for Risk-Weighted Assets (RWA) and capital adequacy calculations.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bicCountryCode rdf:type rdf:Property ;
    rdfs:label 'Bic Country Code' ;
    rdfs:comment 'Two-letter ISO 3166-1 alpha-2 country code used in Bank Identifier Codes (BIC) and International Bank Account Numbers (IBAN) for this jurisdiction.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capitalAdequacyFramework rdf:type rdf:Property ;
    rdfs:label 'Capital Adequacy Framework' ;
    rdfs:comment 'The approach to capital adequacy calculation permitted or mandated in this jurisdiction: Standardized Approach (SA), Internal Ratings-Based (IRB) Approach, Advanced IRB, or other.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLossMethodology rdf:type rdf:Property ;
    rdfs:label 'Credit Loss Methodology' ;
    rdfs:comment 'Required methodology for credit loss provisioning: Current Expected Credit Losses (CECL), IFRS 9 Expected Credit Loss (ECL), incurred loss model, or other.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataPrivacyRegime rdf:type rdf:Property ;
    rdfs:label 'Data Privacy Regime' ;
    rdfs:comment 'Primary data protection and privacy regulatory framework applicable in this jurisdiction (e.g., General Data Protection Regulation (GDPR), California Consumer Privacy Act (CCPA), Personal Data Protection Act (PDPA)).' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:highRiskJurisdictionFlag rdf:type rdf:Property ;
    rdfs:label 'High Risk Jurisdiction Flag' ;
    rdfs:comment 'Indicates whether this jurisdiction is classified as high-risk for Anti-Money Laundering (AML) or Counter-Terrorist Financing (CTF) purposes by international bodies such as the Financial Action Task Force (FATF).' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ibanSupportedFlag rdf:type rdf:Property ;
    rdfs:label 'Iban Supported Flag' ;
    rdfs:comment 'Indicates whether this jurisdiction uses the International Bank Account Number (IBAN) standard for bank account identification.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insolvencyRegimeType rdf:type rdf:Property ;
    rdfs:label 'Insolvency Regime Type' ;
    rdfs:comment 'Classification of the insolvency and bankruptcy framework in this jurisdiction (e.g., debtor-friendly, creditor-friendly, administrative, judicial). Impacts Loss Given Default (LGD) and recovery rate assumptions.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Code' ;
    rdfs:comment 'Standardized code identifying the jurisdiction. Uses ISO 3166-1 alpha-2/alpha-3 for national jurisdictions, with optional subdivision codes (e.g., US-NY for New York State, EU for European Union).' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionLevel rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Level' ;
    rdfs:comment 'Hierarchical level of the jurisdiction: national (country-level), sub-national (state/province/region), supranational (multi-country bodies like EU or Basel Committee), or territorial (dependent territories).' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionName rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Name' ;
    rdfs:comment 'Full legal name of the jurisdiction (e.g., United States of America, State of New York, European Union).' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionStatus rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Status' ;
    rdfs:comment 'Current operational status of the jurisdiction record: active (currently in use), inactive (no longer used for new transactions), historical (archived), or pending (under review for activation).' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalSystemType rdf:type rdf:Property ;
    rdfs:label 'Legal System Type' ;
    rdfs:comment 'The foundational legal system governing the jurisdiction: common law (precedent-based), civil law (code-based), Sharia law (Islamic principles), mixed (combination), customary law, or other.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nettingEnforceabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Netting Enforceability Flag' ;
    rdfs:comment 'Indicates whether close-out netting provisions in derivative contracts are legally enforceable in this jurisdiction under insolvency or default scenarios. Critical for collateral and credit risk management.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nettingOpinionDate rdf:type rdf:Property ;
    rdfs:label 'Netting Opinion Date' ;
    rdfs:comment 'Date of the most recent legal opinion confirming netting enforceability in this jurisdiction. Used to track currency of legal assessments.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:primaryRegulator rdf:type rdf:Property ;
    rdfs:label 'Primary Regulator' ;
    rdfs:comment 'Name of the primary banking regulatory authority in this jurisdiction (e.g., Federal Reserve System, Office of the Comptroller of the Currency, European Central Bank, Prudential Regulation Authority).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sanctionsRegimeFlag rdf:type rdf:Property ;
    rdfs:label 'Sanctions Regime Flag' ;
    rdfs:comment 'Indicates whether this jurisdiction is subject to international economic sanctions or embargoes that restrict banking and financial transactions.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:securitiesRegulator rdf:type rdf:Property ;
    rdfs:label 'Securities Regulator' ;
    rdfs:comment 'Name of the primary securities and capital markets regulatory authority in this jurisdiction (e.g., Securities and Exchange Commission, Financial Conduct Authority, European Securities and Markets Authority).' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stressTestingRequirement rdf:type rdf:Property ;
    rdfs:label 'Stress Testing Requirement' ;
    rdfs:comment 'Mandatory stress testing framework applicable in this jurisdiction: Comprehensive Capital Analysis and Review (CCAR), Dodd-Frank Act Stress Testing (DFAST), European Banking Authority (EBA) stress test, local framework, or none.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxHavenClassification rdf:type rdf:Property ;
    rdfs:label 'Tax Haven Classification' ;
    rdfs:comment 'Classification of the jurisdiction\'s tax regime: tax haven (minimal or no taxation), low-tax (preferential tax rates), standard (typical tax rates), or not classified.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxTreatyNetworkFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Treaty Network Flag' ;
    rdfs:comment 'Indicates whether this jurisdiction participates in international tax treaty networks for withholding tax relief and double taxation avoidance.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:amlMonitoringEnabled rdf:type rdf:Property ;
    rdfs:label 'Aml Monitoring Enabled' ;
    rdfs:comment 'Indicates whether transactions through this channel are subject to real-time or near-real-time AML transaction monitoring.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:apiEndpointUrl rdf:type rdf:Property ;
    rdfs:label 'Api Endpoint Url' ;
    rdfs:comment 'Base URL for API-based channels (open banking API, BaaS API). Null for non-API channels.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authenticationMethod rdf:type rdf:Property ;
    rdfs:label 'Authentication Method' ;
    rdfs:comment 'Primary authentication method(s) used by the channel (e.g., username/password, biometric, two-factor authentication, certificate-based, in-person verification). [ENUM-REF-CANDIDATE: username_password|biometric|mfa|certificate|oauth|saml|in_person|pin|token — promote to reference product]' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelCode rdf:type rdf:Property ;
    rdfs:label 'Channel Code' ;
    rdfs:comment 'Unique business identifier code for the channel, used for external references and system integration. Follows bank-specific channel coding standards.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelDescription rdf:type rdf:Property ;
    rdfs:label 'Channel Description' ;
    rdfs:comment 'Detailed description of the channel\'s purpose, capabilities, and target customer segments.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelName rdf:type rdf:Property ;
    rdfs:label 'Channel Name' ;
    rdfs:comment 'Human-readable name of the channel (e.g., \'Mobile Banking App\', \'Downtown Branch\', \'Corporate API Gateway\').' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelStatus rdf:type rdf:Property ;
    rdfs:label 'Channel Status' ;
    rdfs:comment 'Current operational status of the channel in its lifecycle.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSegmentRestriction rdf:type rdf:Property ;
    rdfs:label 'Customer Segment Restriction' ;
    rdfs:comment 'Comma-separated list of customer segment codes that are permitted to use this channel. Null if no restriction applies (channel available to all segments).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:encryptionStandard rdf:type rdf:Property ;
    rdfs:label 'Encryption Standard' ;
    rdfs:comment 'Encryption standard applied to data transmitted through the channel (e.g., TLS 1.3, AES-256).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kycCapability rdf:type rdf:Property ;
    rdfs:label 'Kyc Capability' ;
    rdfs:comment 'Level of KYC and customer due diligence capability available through the channel (full identity verification, partial verification, or none).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:omnichannelOrchestrationEnabled rdf:type rdf:Property ;
    rdfs:label 'Omnichannel Orchestration Enabled' ;
    rdfs:comment 'Indicates whether the channel participates in omnichannel customer journey orchestration and cross-channel session continuity.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operatingHoursDescription rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Description' ;
    rdfs:comment 'Human-readable description of channel operating hours (e.g., \'24/7\', \'Mon-Fri 9AM-5PM EST\', \'Business days excluding bank holidays\').' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productOfferingScope rdf:type rdf:Property ;
    rdfs:label 'Product Offering Scope' ;
    rdfs:comment 'Scope of banking products and services available through this channel (all products, restricted subset, or custom configuration).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaResponseTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Sla Response Time Seconds' ;
    rdfs:comment 'Target response time in seconds for channel interactions as defined in the channel SLA (e.g., page load time for digital, call answer time for contact center).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaUptimePercentage rdf:type rdf:Property ;
    rdfs:label 'Sla Uptime Percentage' ;
    rdfs:comment 'Target uptime percentage for the channel as defined in the SLA (e.g., 99.9% for digital channels).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supportsAccountOpening rdf:type rdf:Property ;
    rdfs:label 'Supports Account Opening' ;
    rdfs:comment 'Indicates whether the channel supports new account origination and onboarding workflows.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsInvestmentServices rdf:type rdf:Property ;
    rdfs:label 'Supports Investment Services' ;
    rdfs:comment 'Indicates whether the channel provides investment banking, wealth management, or securities trading capabilities.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsLoanOrigination rdf:type rdf:Property ;
    rdfs:label 'Supports Loan Origination' ;
    rdfs:comment 'Indicates whether the channel supports loan application and origination processes.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsTransactions rdf:type rdf:Property ;
    rdfs:label 'Supports Transactions' ;
    rdfs:comment 'Indicates whether the channel supports financial transaction execution (payments, transfers, withdrawals) or is information/inquiry-only.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:thirdPartyProvider rdf:type rdf:Property ;
    rdfs:label 'Third Party Provider' ;
    rdfs:comment 'Name of third-party vendor or technology provider if the channel is operated or enabled by an external partner (e.g., fintech platform, BaaS provider, core banking vendor). Null if operated in-house.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionLimitDaily rdf:type rdf:Property ;
    rdfs:label 'Transaction Limit Daily' ;
    rdfs:comment 'Maximum aggregate transaction amount allowed per customer per day through this channel. Null if no limit applies.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionLimitPerTransaction rdf:type rdf:Property ;
    rdfs:label 'Transaction Limit Per Transaction' ;
    rdfs:comment 'Maximum single transaction amount allowed through this channel. Null if no limit applies.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:atmCount rdf:type rdf:Property ;
    rdfs:label 'Atm Count' ;
    rdfs:comment 'Number of ATM machines located at or immediately adjacent to the branch. Used for self-service capacity planning and customer convenience analysis.' ;
    rdfs:domain ind:Branch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:branchStatus rdf:type rdf:Property ;
    rdfs:label 'Branch Status' ;
    rdfs:comment 'Current operational status of the branch in its lifecycle. Active branches are fully operational; inactive branches are permanently closed; temporarily closed branches are expected to reopen; pending opening branches are approved but not yet operational; pending closure branches are scheduled for closure; under renovation branches are temporarily closed for facility upgrades.' ;
    rdfs:domain ind:Branch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:branchType rdf:type rdf:Property ;
    rdfs:label 'Branch Type' ;
    rdfs:comment 'Classification of the branch based on service capabilities and operational model. Full-service branches offer complete banking services; limited-service branches offer restricted services; drive-through branches focus on vehicle-accessible transactions; in-store branches are located within retail establishments; mobile branches are temporary or movable units; automated branches are primarily self-service; private banking branches serve high-net-worth clients. [ENUM-REF-CANDIDATE: full_service|limited_service|drive_through|in_store|mobile|automated|private_banking — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Branch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bsaAmlDesignation rdf:type rdf:Property ;
    rdfs:label 'Bsa Aml Designation' ;
    rdfs:comment 'Risk classification of the branch for BSA/AML compliance purposes. Standard designation applies default monitoring; high-risk designation requires enhanced due diligence; enhanced monitoring applies additional transaction surveillance; exempt designation applies to branches with limited transaction capabilities.' ;
    rdfs:domain ind:Branch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureDate rdf:type rdf:Property ;
    rdfs:label 'Closure Date' ;
    rdfs:comment 'Date when the branch permanently ceased operations. Null for active branches. Used for network rationalization analysis and regulatory reporting.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:driveThroughLanes rdf:type rdf:Property ;
    rdfs:label 'Drive Through Lanes' ;
    rdfs:comment 'Number of drive-through service lanes available at the branch for vehicle-accessible banking transactions.' ;
    rdfs:domain ind:Branch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:faxNumber rdf:type rdf:Property ;
    rdfs:label 'Fax Number' ;
    rdfs:comment 'Facsimile number for the branch used for document transmission and formal communications.' ;
    rdfs:domain ind:Branch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fdicCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Fdic Certificate Number' ;
    rdfs:comment 'FDIC certificate number associated with the institution operating this branch. Used for regulatory reporting and deposit insurance identification.' ;
    rdfs:domain ind:Branch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaseExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Lease Expiration Date' ;
    rdfs:comment 'Date when the current lease agreement for the branch facility expires. Null for owned properties. Used for lease renewal planning and real estate strategy.' ;
    rdfs:domain ind:Branch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leaseOrOwned rdf:type rdf:Property ;
    rdfs:label 'Lease Or Owned' ;
    rdfs:comment 'Indicates whether the branch facility is owned by the bank, leased from a third party, or operates under a ground lease arrangement. Used for real estate portfolio management and cost allocation.' ;
    rdfs:domain ind:Branch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketCode rdf:type rdf:Property ;
    rdfs:label 'Market Code' ;
    rdfs:comment 'Code identifying the market or metropolitan statistical area (MSA) in which the branch operates. Used for market share analysis and competitive positioning.' ;
    rdfs:domain ind:Branch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingHoursSaturday rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Saturday' ;
    rdfs:comment 'Operating hours for the branch on Saturdays. May differ from weekday hours or be closed. Format includes opening and closing times.' ;
    rdfs:domain ind:Branch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingHoursSunday rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Sunday' ;
    rdfs:comment 'Operating hours for the branch on Sundays. Many branches are closed on Sundays. Format includes opening and closing times or indication of closure.' ;
    rdfs:domain ind:Branch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingHoursWeekday rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Weekday' ;
    rdfs:comment 'Standard operating hours for the branch on weekdays (Monday through Friday). Format typically includes opening and closing times (e.g., 09:00-17:00).' ;
    rdfs:domain ind:Branch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parkingAvailable rdf:type rdf:Property ;
    rdfs:label 'Parking Available' ;
    rdfs:comment 'Indicates whether dedicated customer parking is available at or near the branch location.' ;
    rdfs:domain ind:Branch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:performanceTier rdf:type rdf:Property ;
    rdfs:label 'Performance Tier' ;
    rdfs:comment 'Internal classification of branch performance based on deposit volume, loan origination, customer acquisition, and profitability metrics. Flagship branches are premier locations; Tier 1 represents highest performance; Tier 4 represents lowest performance. Used for resource allocation and strategic planning.' ;
    rdfs:domain ind:Branch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safeDepositBoxCount rdf:type rdf:Property ;
    rdfs:label 'Safe Deposit Box Count' ;
    rdfs:comment 'Total number of safe deposit boxes available for customer rental at the branch. Used for vault capacity management and revenue forecasting.' ;
    rdfs:domain ind:Branch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:squareFootage rdf:type rdf:Property ;
    rdfs:label 'Square Footage' ;
    rdfs:comment 'Total interior floor space of the branch facility measured in square feet. Used for facilities management, lease cost analysis, and space utilization planning.' ;
    rdfs:domain ind:Branch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:staffCapacity rdf:type rdf:Property ;
    rdfs:label 'Staff Capacity' ;
    rdfs:comment 'Maximum number of full-time equivalent staff members the branch is designed to accommodate. Used for workforce planning and capacity management.' ;
    rdfs:domain ind:Branch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wheelchairAccessible rdf:type rdf:Property ;
    rdfs:label 'Wheelchair Accessible' ;
    rdfs:comment 'Indicates whether the branch facility is fully accessible to customers using wheelchairs, including ramps, elevators, and accessible service counters.' ;
    rdfs:domain ind:Branch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:adaCompliant rdf:type rdf:Property ;
    rdfs:label 'Ada Compliant' ;
    rdfs:comment 'Indicates whether the ATM meets ADA accessibility requirements (True) or not (False).' ;
    rdfs:domain ind:Atm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:averageDailyCashDispensed rdf:type rdf:Property ;
    rdfs:label 'Average Daily Cash Dispensed' ;
    rdfs:comment 'Average amount of cash dispensed by this ATM per day in the local currency, calculated over a rolling period.' ;
    rdfs:domain ind:Atm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageDailyTransactions rdf:type rdf:Property ;
    rdfs:label 'Average Daily Transactions' ;
    rdfs:comment 'Average number of transactions processed by this ATM per day, calculated over a rolling period (e.g., 30 days).' ;
    rdfs:domain ind:Atm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:biometricAuthenticationEnabled rdf:type rdf:Property ;
    rdfs:label 'Biometric Authentication Enabled' ;
    rdfs:comment 'Indicates whether the ATM supports biometric authentication methods such as fingerprint or iris scanning (True) or not (False).' ;
    rdfs:domain ind:Atm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cashCassetteConfiguration rdf:type rdf:Property ;
    rdfs:label 'Cash Cassette Configuration' ;
    rdfs:comment 'Denomination configuration of cash cassettes (e.g., Cassette 1: $20, Cassette 2: $50, Cassette 3: $100, Cassette 4: $20).' ;
    rdfs:domain ind:Atm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cashCassetteCount rdf:type rdf:Property ;
    rdfs:label 'Cash Cassette Count' ;
    rdfs:comment 'Number of cash cassettes installed in the ATM for dispensing currency.' ;
    rdfs:domain ind:Atm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cashReplenishmentSchedule rdf:type rdf:Property ;
    rdfs:label 'Cash Replenishment Schedule' ;
    rdfs:comment 'Frequency at which the ATM is scheduled for cash replenishment: daily, weekly, bi-weekly, monthly, or on-demand based on usage.' ;
    rdfs:domain ind:Atm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkImagingEnabled rdf:type rdf:Property ;
    rdfs:label 'Check Imaging Enabled' ;
    rdfs:comment 'Indicates whether the ATM has check imaging capability for remote deposit capture (True) or not (False).' ;
    rdfs:domain ind:Atm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contactlessEnabled rdf:type rdf:Property ;
    rdfs:label 'Contactless Enabled' ;
    rdfs:comment 'Indicates whether the ATM supports contactless card or mobile wallet transactions (True) or not (False).' ;
    rdfs:domain ind:Atm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:depositEnabled rdf:type rdf:Property ;
    rdfs:label 'Deposit Enabled' ;
    rdfs:comment 'Indicates whether the ATM supports cash and/or check deposit functionality (True) or is withdrawal-only (False).' ;
    rdfs:domain ind:Atm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:firmwareVersion rdf:type rdf:Property ;
    rdfs:label 'Firmware Version' ;
    rdfs:comment 'Version number of the firmware currently installed on the ATM.' ;
    rdfs:domain ind:Atm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:installationDate rdf:type rdf:Property ;
    rdfs:label 'Installation Date' ;
    rdfs:comment 'Date when the ATM was first installed and commissioned at its current location.' ;
    rdfs:domain ind:Atm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ipAddress rdf:type rdf:Property ;
    rdfs:label 'Ip Address' ;
    rdfs:comment 'Network IP address assigned to the ATM for communication with the bank\'s transaction processing systems.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastCashReplenishmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Cash Replenishment Date' ;
    rdfs:comment 'Date when the ATM was last replenished with cash.' ;
    rdfs:domain ind:Atm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Last Maintenance Date' ;
    rdfs:comment 'Date of the most recent scheduled or unscheduled maintenance service performed on the ATM.' ;
    rdfs:domain ind:Atm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:locationType rdf:type rdf:Property ;
    rdfs:label 'Location Type' ;
    rdfs:comment 'Classification of the ATM placement: branch-attached (within or adjacent to a branch), off-premise (remote location), in-lobby, drive-through, or standalone kiosk.' ;
    rdfs:domain ind:Atm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturer rdf:type rdf:Property ;
    rdfs:label 'Manufacturer' ;
    rdfs:comment 'Name of the company that manufactured the ATM unit.' ;
    rdfs:domain ind:Atm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxWithdrawalAmount rdf:type rdf:Property ;
    rdfs:label 'Max Withdrawal Amount' ;
    rdfs:comment 'Maximum single transaction withdrawal amount allowed at this ATM in the local currency.' ;
    rdfs:domain ind:Atm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:model rdf:type rdf:Property ;
    rdfs:label 'Model' ;
    rdfs:comment 'Model designation of the ATM unit as specified by the manufacturer (e.g., NCR SelfServ 80, Diebold Nixdorf DN Series).' ;
    rdfs:domain ind:Atm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkAffiliations rdf:type rdf:Property ;
    rdfs:label 'Network Affiliations' ;
    rdfs:comment 'Comma-separated list of interbank networks the ATM participates in (e.g., Visa, Mastercard, STAR, Allpoint, NYCE, Cirrus).' ;
    rdfs:domain ind:Atm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Next Maintenance Date' ;
    rdfs:comment 'Date when the next scheduled preventive maintenance is planned for the ATM.' ;
    rdfs:domain ind:Atm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operationalStatus rdf:type rdf:Property ;
    rdfs:label 'Operational Status' ;
    rdfs:comment 'Current operational state of the ATM: active (in service), inactive (temporarily offline), maintenance (scheduled service), out-of-service (unplanned downtime), or decommissioned (permanently removed).' ;
    rdfs:domain ind:Atm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serialNumber rdf:type rdf:Property ;
    rdfs:label 'Serial Number' ;
    rdfs:comment 'Manufacturer-assigned serial number uniquely identifying the physical ATM hardware unit.' ;
    rdfs:domain ind:Atm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceProvider rdf:type rdf:Property ;
    rdfs:label 'Service Provider' ;
    rdfs:comment 'Name of the third-party service provider responsible for ATM maintenance and cash management, if outsourced. Null if managed in-house.' ;
    rdfs:domain ind:Atm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportedTransactionTypes rdf:type rdf:Property ;
    rdfs:label 'Supported Transaction Types' ;
    rdfs:comment 'Comma-separated list of transaction types the ATM supports (e.g., withdrawal, deposit, balance inquiry, transfer, bill payment, check cashing).' ;
    rdfs:domain ind:Atm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surchargeAmount rdf:type rdf:Property ;
    rdfs:label 'Surcharge Amount' ;
    rdfs:comment 'Fee charged to non-customer cardholders for using this ATM, in the local currency. Zero if no surcharge applies.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:videoBankingEnabled rdf:type rdf:Property ;
    rdfs:label 'Video Banking Enabled' ;
    rdfs:comment 'Indicates whether the ATM supports live video teller assistance (True) or not (False).' ;
    rdfs:domain ind:Atm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:apiGatewayEndpoint rdf:type rdf:Property ;
    rdfs:label 'Api Gateway Endpoint' ;
    rdfs:comment 'Base URL or endpoint address for the API gateway serving this channel.' ;
    rdfs:domain ind:DigitalChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apiProductSubscriptions rdf:type rdf:Property ;
    rdfs:label 'Api Product Subscriptions' ;
    rdfs:comment 'Comma-separated list of subscribed API products (e.g., \'account_information\', \'payment_initiation\', \'funds_confirmation\', \'card_management\').' ;
    rdfs:domain ind:DigitalChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataAccessScope rdf:type rdf:Property ;
    rdfs:label 'Data Access Scope' ;
    rdfs:comment 'OAuth2 scope or permission set defining the data and operations this channel or TPP is authorized to access.' ;
    rdfs:domain ind:DigitalChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:developerContactEmail rdf:type rdf:Property ;
    rdfs:label 'Developer Contact Email' ;
    rdfs:comment 'Primary email address for technical contact or developer responsible for this channel or API consumer.' ;
    rdfs:domain ind:DigitalChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:developerOrganizationName rdf:type rdf:Property ;
    rdfs:label 'Developer Organization Name' ;
    rdfs:comment 'Legal name of the organization or developer entity that owns or operates this API consumer or channel.' ;
    rdfs:domain ind:DigitalChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalChannelStatus rdf:type rdf:Property ;
    rdfs:label 'Digital Channel Status' ;
    rdfs:comment 'Current lifecycle status of the digital channel instance or API consumer registration.' ;
    rdfs:domain ind:DigitalChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eidasCertificateReference rdf:type rdf:Property ;
    rdfs:label 'Eidas Certificate Reference' ;
    rdfs:comment 'Reference identifier for the eIDAS (electronic IDentification, Authentication and trust Services) qualified certificate used for TPP authentication.' ;
    rdfs:domain ind:DigitalChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environment rdf:type rdf:Property ;
    rdfs:label 'Environment' ;
    rdfs:comment 'Deployment environment classification for the channel instance.' ;
    rdfs:domain ind:DigitalChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:featureFlags rdf:type rdf:Property ;
    rdfs:label 'Feature Flags' ;
    rdfs:comment 'Comma-separated list of enabled feature flags or capabilities for this channel instance (e.g., \'payment_initiation\', \'account_aggregation\', \'funds_confirmation\').' ;
    rdfs:domain ind:DigitalChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipWhitelist rdf:type rdf:Property ;
    rdfs:label 'Ip Whitelist' ;
    rdfs:comment 'Comma-separated list of whitelisted IP addresses or CIDR ranges authorized to access this channel or API endpoint.' ;
    rdfs:domain ind:DigitalChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBaasEnabled rdf:type rdf:Property ;
    rdfs:label 'Is Baas Enabled' ;
    rdfs:comment 'Indicates whether this channel is configured for Banking-as-a-Service or embedded finance capabilities.' ;
    rdfs:domain ind:DigitalChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastActivityTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Activity Timestamp' ;
    rdfs:comment 'Timestamp of the most recent API call, login, or transaction activity through this channel.' ;
    rdfs:domain ind:DigitalChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:maxRequestsPerMinute rdf:type rdf:Property ;
    rdfs:label 'Max Requests Per Minute' ;
    rdfs:comment 'Maximum number of API requests allowed per minute for this channel instance.' ;
    rdfs:domain ind:DigitalChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:oauthClientIdentifier rdf:type rdf:Property ;
    rdfs:label 'Oauth Client Identifier' ;
    rdfs:comment 'OAuth2 or OIDC client identifier for API consumer authentication.' ;
    rdfs:domain ind:DigitalChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oauthClientSecretHash rdf:type rdf:Property ;
    rdfs:label 'Oauth Client Secret Hash' ;
    rdfs:comment 'Hashed OAuth2 client secret for secure credential storage.' ;
    rdfs:domain ind:DigitalChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onboardingApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Onboarding Approval Status' ;
    rdfs:comment 'Current approval status of the channel or API consumer onboarding workflow.' ;
    rdfs:domain ind:DigitalChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onboardingApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Onboarding Approved By' ;
    rdfs:comment 'Name or identifier of the approver who authorized this channel or API consumer registration.' ;
    rdfs:domain ind:DigitalChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onboardingApprovedDate rdf:type rdf:Property ;
    rdfs:label 'Onboarding Approved Date' ;
    rdfs:comment 'Date when the channel or API consumer registration was approved.' ;
    rdfs:domain ind:DigitalChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:platformVariant rdf:type rdf:Property ;
    rdfs:label 'Platform Variant' ;
    rdfs:comment 'Specific platform or protocol variant for the channel (e.g., iOS, Android, REST API).' ;
    rdfs:domain ind:DigitalChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateLimitTier rdf:type rdf:Property ;
    rdfs:label 'Rate Limit Tier' ;
    rdfs:comment 'API rate limiting tier assigned to this channel or consumer, governing request throughput.' ;
    rdfs:domain ind:DigitalChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionTimeoutMinutes rdf:type rdf:Property ;
    rdfs:label 'Session Timeout Minutes' ;
    rdfs:comment 'Idle session timeout duration in minutes before automatic logout or token expiration.' ;
    rdfs:domain ind:DigitalChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaResponseTimeMs rdf:type rdf:Property ;
    rdfs:label 'Sla Response Time Ms' ;
    rdfs:comment 'Target API response time in milliseconds as defined in the SLA for this channel.' ;
    rdfs:domain ind:DigitalChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:termsAcceptedDate rdf:type rdf:Property ;
    rdfs:label 'Terms Accepted Date' ;
    rdfs:comment 'Date when the current terms of service version was accepted by the developer or TPP.' ;
    rdfs:domain ind:DigitalChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:termsOfServiceVersion rdf:type rdf:Property ;
    rdfs:label 'Terms Of Service Version' ;
    rdfs:comment 'Version identifier of the terms of service or API usage agreement accepted by the channel or TPP.' ;
    rdfs:domain ind:DigitalChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tppRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Tpp Registration Number' ;
    rdfs:comment 'Regulatory registration or license number for third-party provider applications under PSD2 or open banking frameworks.' ;
    rdfs:domain ind:DigitalChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:webhookUrl rdf:type rdf:Property ;
    rdfs:label 'Webhook Url' ;
    rdfs:comment 'Callback URL endpoint for asynchronous event notifications or webhooks sent to the API consumer.' ;
    rdfs:domain ind:DigitalChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geolocationCountryId rdf:type rdf:Property ;
    rdfs:label 'Geolocation Country Id' ;
    rdfs:comment 'Foreign key linking to reference.country. Business justification: Session geolocation country is used for AML country-risk scoring and fraud detection — referencing country.aml_risk_rating and ofac_sanctions_flag directly. Banking domain experts expect geolocation c' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:applicationVersion rdf:type rdf:Property ;
    rdfs:label 'Application Version' ;
    rdfs:comment 'Version number of the mobile or desktop application used for the session. Null for web browser sessions.' ;
    rdfs:domain ind:Session ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authenticationLevel rdf:type rdf:Property ;
    rdfs:label 'Authentication Level' ;
    rdfs:comment 'Strength level of authentication applied, aligned with regulatory requirements for customer due diligence and transaction authorization.' ;
    rdfs:domain ind:Session ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:browserName rdf:type rdf:Property ;
    rdfs:label 'Browser Name' ;
    rdfs:comment 'Name of the web browser used for the session (e.g., Chrome, Safari, Firefox, Edge). Null for non-browser channels.' ;
    rdfs:domain ind:Session ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:browserVersion rdf:type rdf:Property ;
    rdfs:label 'Browser Version' ;
    rdfs:comment 'Version number of the web browser used for the session. Null for non-browser channels.' ;
    rdfs:domain ind:Session ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceFingerprint rdf:type rdf:Property ;
    rdfs:label 'Device Fingerprint' ;
    rdfs:comment 'Unique identifier or hash representing the device characteristics used to access the session. Used for fraud detection and device recognition.' ;
    rdfs:domain ind:Session ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceType rdf:type rdf:Property ;
    rdfs:label 'Device Type' ;
    rdfs:comment 'Classification of the device used to initiate the session (mobile phone, tablet, desktop computer, ATM, kiosk, point-of-sale terminal).' ;
    rdfs:domain ind:Session ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationSeconds rdf:type rdf:Property ;
    rdfs:label 'Duration Seconds' ;
    rdfs:comment 'Total duration of the session in seconds, calculated as the difference between session end and start timestamps.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:endTimestamp rdf:type rdf:Property ;
    rdfs:label 'End Timestamp' ;
    rdfs:comment 'Timestamp when the session was terminated, either by user action, timeout, or system event.' ;
    rdfs:domain ind:Session ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:exitPageUrl rdf:type rdf:Property ;
    rdfs:label 'Exit Page Url' ;
    rdfs:comment 'URL of the last page or screen accessed before the session was terminated.' ;
    rdfs:domain ind:Session ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudRiskScore rdf:type rdf:Property ;
    rdfs:label 'Fraud Risk Score' ;
    rdfs:comment 'Real-time fraud risk score assigned to the session based on behavioral analytics, device fingerprinting, and transaction patterns. Scale 0-100, higher indicates greater risk.' ;
    rdfs:domain ind:Session ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geolocationLatitude rdf:type rdf:Property ;
    rdfs:label 'Geolocation Latitude' ;
    rdfs:comment 'Latitude coordinate of the session origin, derived from IP address or device GPS. Used for location-based fraud detection and customer journey analysis.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geolocationLongitude rdf:type rdf:Property ;
    rdfs:label 'Geolocation Longitude' ;
    rdfs:comment 'Longitude coordinate of the session origin, derived from IP address or device GPS. Used for location-based fraud detection and customer journey analysis.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:landingPageUrl rdf:type rdf:Property ;
    rdfs:label 'Landing Page Url' ;
    rdfs:comment 'URL of the first page or screen accessed in the session.' ;
    rdfs:domain ind:Session ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languagePreference rdf:type rdf:Property ;
    rdfs:label 'Language Preference' ;
    rdfs:comment 'Two-letter ISO language code representing the customer\'s preferred language for the session interface.' ;
    rdfs:domain ind:Session ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingSystem rdf:type rdf:Property ;
    rdfs:label 'Operating System' ;
    rdfs:comment 'Operating system of the device used during the session (e.g., iOS, Android, Windows, macOS).' ;
    rdfs:domain ind:Session ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outcome rdf:type rdf:Property ;
    rdfs:label 'Outcome' ;
    rdfs:comment 'Final outcome classification of the session indicating whether the customer completed their intended action, abandoned the session, experienced a timeout, or encountered an error.' ;
    rdfs:domain ind:Session ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pageViewCount rdf:type rdf:Property ;
    rdfs:label 'Page View Count' ;
    rdfs:comment 'Total number of pages or screens viewed during the session. Used for engagement analysis and customer journey mapping.' ;
    rdfs:domain ind:Session ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:referrerUrl rdf:type rdf:Property ;
    rdfs:label 'Referrer Url' ;
    rdfs:comment 'URL of the page or source that referred the customer to initiate the session. Used for marketing attribution and customer journey analysis.' ;
    rdfs:domain ind:Session ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionStatus rdf:type rdf:Property ;
    rdfs:label 'Session Status' ;
    rdfs:comment 'Current lifecycle status of the session.' ;
    rdfs:domain ind:Session ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionType rdf:type rdf:Property ;
    rdfs:label 'Session Type' ;
    rdfs:comment 'Classification of the session based on authentication and interaction mode.' ;
    rdfs:domain ind:Session ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaActualResponseTimeMs rdf:type rdf:Property ;
    rdfs:label 'Sla Actual Response Time Ms' ;
    rdfs:comment 'Actual average response time in milliseconds measured during the session.' ;
    rdfs:domain ind:Session ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Compliance Flag' ;
    rdfs:comment 'Boolean indicator of whether the session met the defined SLA targets for response time and availability.' ;
    rdfs:domain ind:Session ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaTargetResponseTimeMs rdf:type rdf:Property ;
    rdfs:label 'Sla Target Response Time Ms' ;
    rdfs:comment 'Target response time in milliseconds defined by the SLA for this session type and channel.' ;
    rdfs:domain ind:Session ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:startTimestamp rdf:type rdf:Property ;
    rdfs:label 'Start Timestamp' ;
    rdfs:comment 'Timestamp when the session was initiated by the customer or system.' ;
    rdfs:domain ind:Session ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:token rdf:type rdf:Property ;
    rdfs:label 'Token' ;
    rdfs:comment 'Unique cryptographic token assigned to the session for authentication and authorization purposes. Used to maintain session state and security.' ;
    rdfs:domain ind:Session ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:userAgent rdf:type rdf:Property ;
    rdfs:label 'User Agent' ;
    rdfs:comment 'Browser or application user agent string identifying the client software, operating system, and device type used to access the session.' ;
    rdfs:domain ind:Session ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apiEndpoint rdf:type rdf:Property ;
    rdfs:label 'Api Endpoint' ;
    rdfs:comment 'The API endpoint URL or path invoked during the interaction. Populated only for API channel interactions.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apiPayloadSizeBytes rdf:type rdf:Property ;
    rdfs:label 'Api Payload Size Bytes' ;
    rdfs:comment 'The size of the API request or response payload in bytes. Populated only for API channel interactions.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:apiResponseCode rdf:type rdf:Property ;
    rdfs:label 'Api Response Code' ;
    rdfs:comment 'The HTTP response code returned by the API endpoint (e.g., 200, 400, 500). Populated only for API channel interactions.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:atmAuthorizationCode rdf:type rdf:Property ;
    rdfs:label 'Atm Authorization Code' ;
    rdfs:comment 'The authorization or approval code returned by the ATM network for the transaction. Populated only for ATM channel interactions.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:atmCashDispensedFlag rdf:type rdf:Property ;
    rdfs:label 'Atm Cash Dispensed Flag' ;
    rdfs:comment 'Indicates whether cash was successfully dispensed during the ATM transaction. Populated only for ATM channel interactions.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:atmResponseCode rdf:type rdf:Property ;
    rdfs:label 'Atm Response Code' ;
    rdfs:comment 'The response code returned by the ATM network indicating success, decline, or error condition. Populated only for ATM channel interactions.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:atmSurchargeAmount rdf:type rdf:Property ;
    rdfs:label 'Atm Surcharge Amount' ;
    rdfs:comment 'The surcharge fee applied to the ATM transaction, if applicable. Populated only for ATM channel interactions.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contactCenterCallDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Contact Center Call Duration Seconds' ;
    rdfs:comment 'The total duration of the contact center call in seconds. Populated only for contact center voice interactions.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contactCenterInteractionMode rdf:type rdf:Property ;
    rdfs:label 'Contact Center Interaction Mode' ;
    rdfs:comment 'The mode of contact center interaction (e.g., Interactive Voice Response (IVR), live voice call, chat, email, Short Message Service (SMS)). Populated only for contact center channel interactions.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactCenterIvrPath rdf:type rdf:Property ;
    rdfs:label 'Contact Center Ivr Path' ;
    rdfs:comment 'The sequence of IVR menu selections made by the customer during the interaction. Populated only for contact center IVR interactions.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctrThresholdFlag rdf:type rdf:Property ;
    rdfs:label 'Ctr Threshold Flag' ;
    rdfs:comment 'Indicates whether the transaction amount meets or exceeds the $10,000 threshold requiring a Currency Transaction Report (CTR) filing under Bank Secrecy Act (BSA) and Financial Crimes Enforcement Network (FinCEN) regulations. Populated for branch and other cash transactions.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:digitalDeviceType rdf:type rdf:Property ;
    rdfs:label 'Digital Device Type' ;
    rdfs:comment 'The type of device used for digital banking interactions. Populated only for digital banking channel interactions.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalSessionIpAddress rdf:type rdf:Property ;
    rdfs:label 'Digital Session Ip Address' ;
    rdfs:comment 'The IP address from which the digital banking session originated. Populated only for digital banking channel interactions.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalUserAgent rdf:type rdf:Property ;
    rdfs:label 'Digital User Agent' ;
    rdfs:comment 'The user agent string identifying the browser or application used for the digital banking interaction. Populated only for digital banking channel interactions.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:errorCode rdf:type rdf:Property ;
    rdfs:label 'Error Code' ;
    rdfs:comment 'The system error code if the interaction failed or encountered an error condition.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:errorMessage rdf:type rdf:Property ;
    rdfs:label 'Error Message' ;
    rdfs:comment 'The human-readable error message describing the failure or error condition.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionStatus rdf:type rdf:Property ;
    rdfs:label 'Interaction Status' ;
    rdfs:comment 'The outcome or current status of the interaction event.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Interaction Timestamp' ;
    rdfs:comment 'The precise date and time when the interaction event occurred in the channel system.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:interactionType rdf:type rdf:Property ;
    rdfs:label 'Interaction Type' ;
    rdfs:comment 'The specific type of interaction or transaction performed (e.g., withdrawal, deposit, balance inquiry, login, transfer, bill payment, wire initiation, account inquiry, IVR navigation, agent call, API call).' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productServiceCode rdf:type rdf:Property ;
    rdfs:label 'Product Service Code' ;
    rdfs:comment 'The code identifying the product or service associated with this interaction (e.g., checking account, savings account, loan product, investment product).' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionStatus rdf:type rdf:Property ;
    rdfs:label 'Resolution Status' ;
    rdfs:comment 'Indicates whether the customer inquiry or issue was resolved during this interaction.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaMetFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Met Flag' ;
    rdfs:comment 'Indicates whether the interaction met the defined SLA target time.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaTargetSeconds rdf:type rdf:Property ;
    rdfs:label 'Sla Target Seconds' ;
    rdfs:comment 'The target service level agreement time for this interaction type, measured in seconds.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:atmTransactionId rdf:type rdf:Property ;
    rdfs:label 'Atm Transaction Id' ;
    rdfs:comment 'Unique identifier for the ATM transaction event. Primary key for the atm_transaction product.' ;
    rdfs:domain ind:AtmTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:channelSessionId rdf:type rdf:Property ;
    rdfs:label 'Channel Session Id' ;
    rdfs:comment 'Unique identifier for the ATM session during which this transaction occurred, used to group multiple transactions within a single customer session.' ;
    rdfs:domain ind:AtmTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Session .

ind:chargebackId rdf:type rdf:Property ;
    rdfs:label 'Chargeback Id' ;
    rdfs:comment 'Foreign key linking to fraud.chargeback. Business justification: Visa/Mastercard dispute rules require the original ATM transaction reference when filing ATM chargebacks. ATM dispute processing workflows must directly link the disputed ATM transaction to its charge' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Chargeback .

ind:originalTransactionAtmTransactionId rdf:type rdf:Property ;
    rdfs:label 'Original Transaction Atm Transaction Id' ;
    rdfs:comment 'Reference to the original ATM transaction ID if this record represents a reversal or adjustment. Null for original transactions.' ;
    rdfs:domain ind:AtmTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AtmTransaction .

ind:primaryAtmIssuerInstitutionLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Primary Atm Issuer Institution Legal Entity Id' ;
    rdfs:comment 'Bank Identification Number (BIN) or institution code of the issuing bank that issued the card used in the transaction.' ;
    rdfs:domain ind:AtmTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:cardEntryMode rdf:type rdf:Property ;
    rdfs:label 'Card Entry Mode' ;
    rdfs:comment 'Method by which the card data was captured at the ATM: chip (EMV chip read), magnetic stripe, contactless (NFC/RFID), or manual entry.' ;
    rdfs:domain ind:AtmTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cashDispensedAmount rdf:type rdf:Property ;
    rdfs:label 'Cash Dispensed Amount' ;
    rdfs:comment 'Actual amount of cash dispensed by the ATM, which should match the transaction amount for withdrawal transactions. Null for non-cash transactions.' ;
    rdfs:domain ind:AtmTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cashDispensedFlag rdf:type rdf:Property ;
    rdfs:label 'Cash Dispensed Flag' ;
    rdfs:comment 'Boolean indicator of whether physical cash was successfully dispensed by the ATM for this transaction (True=cash dispensed, False=no cash dispensed).' ;
    rdfs:domain ind:AtmTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:networkCode rdf:type rdf:Property ;
    rdfs:label 'Network Code' ;
    rdfs:comment 'Card network or ATM network used to route and authorize the transaction (e.g., Visa, Mastercard, STAR, Cirrus, Plus). [ENUM-REF-CANDIDATE: visa|mastercard|star|pulse|cirrus|plus|interac|maestro — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AtmTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onUsTransactionFlag rdf:type rdf:Property ;
    rdfs:label 'On Us Transaction Flag' ;
    rdfs:comment 'Boolean indicator of whether this is an on-us transaction (customer using their own bank\'s ATM) or an off-us transaction (customer using another bank\'s ATM). True=on-us, False=off-us.' ;
    rdfs:domain ind:AtmTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pinVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Pin Verified Flag' ;
    rdfs:comment 'Boolean indicator of whether the customer\'s PIN was successfully verified during the transaction. True=PIN verified, False=PIN not verified or failed.' ;
    rdfs:domain ind:AtmTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receiptPrintedFlag rdf:type rdf:Property ;
    rdfs:label 'Receipt Printed Flag' ;
    rdfs:comment 'Boolean indicator of whether a paper receipt was printed for the customer (True=receipt printed, False=receipt declined or unavailable).' ;
    rdfs:domain ind:AtmTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responseCode rdf:type rdf:Property ;
    rdfs:label 'Response Code' ;
    rdfs:comment 'Numeric code returned by the issuer or network indicating the outcome of the authorization request (e.g., 00=approved, 51=insufficient funds, 54=expired card).' ;
    rdfs:domain ind:AtmTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseDescription rdf:type rdf:Property ;
    rdfs:label 'Response Description' ;
    rdfs:comment 'Human-readable description of the response code, explaining the reason for approval or decline (e.g., \'Approved\', \'Insufficient Funds\', \'Invalid PIN\').' ;
    rdfs:domain ind:AtmTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminalLocationCode rdf:type rdf:Property ;
    rdfs:label 'Terminal Location Code' ;
    rdfs:comment 'Geographic or branch location code where the ATM terminal is physically installed, used for location-based analytics and fraud detection.' ;
    rdfs:domain ind:AtmTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminalType rdf:type rdf:Property ;
    rdfs:label 'Terminal Type' ;
    rdfs:comment 'Classification of the ATM terminal type: branch (inside bank branch), offsite (standalone location), mobile (portable ATM), kiosk (self-service banking kiosk), or drive-through.' ;
    rdfs:domain ind:AtmTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benchmarkRateBenchmarkId rdf:type rdf:Property ;
    rdfs:label 'Benchmark Rate Benchmark Id' ;
    rdfs:comment 'Foreign key linking to reference.rate_benchmark. Business justification: Portfolio performance is measured against benchmarks for client reporting. Manager evaluation, performance attribution, and client review meetings require valid benchmark reference.' ;
    rdfs:domain ind:Wealth ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RateBenchmark .

ind:cashAccountDepositAccountId rdf:type rdf:Property ;
    rdfs:label 'Cash Account Deposit Account Id' ;
    rdfs:comment 'Foreign key linking to account.deposit_account. Business justification: Wealth portfolios maintain linked deposit accounts for cash sweep arrangements, dividend collection, trade settlement proceeds, and liquidity management. Essential for portfolio cash management operat' ;
    rdfs:domain ind:ManagedPortfolio ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DepositAccount .

ind:clientRiskRatingId rdf:type rdf:Property ;
    rdfs:label 'Client Risk Rating Id' ;
    rdfs:comment 'Foreign key linking to customer.risk_rating. Business justification: Portfolio construction and ongoing compliance require alignment between portfolio risk_profile and the client\'s formally approved risk_rating (MiFID II, COBS suitability). Portfolio managers and compl' ;
    rdfs:domain ind:ManagedPortfolio ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RiskRating .

ind:modelPortfolioId rdf:type rdf:Property ;
    rdfs:label 'Model Portfolio Id' ;
    rdfs:comment 'Reference to the model portfolio template used for asset allocation targets and rebalancing guidance.' ;
    rdfs:domain ind:Wealth ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ModelPortfolio .

ind:primaryChannelId rdf:type rdf:Property ;
    rdfs:label 'Primary Channel Id' ;
    rdfs:comment 'Foreign key linking to channel.channel. Business justification: Portfolios are serviced through primary channels (digital platform, branch, private banking). Required for channel preference tracking, service delivery routing, regulatory channel-of-record documenta' ;
    rdfs:domain ind:Wealth ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:revenueGlAccountId rdf:type rdf:Property ;
    rdfs:label 'Revenue Gl Account Id' ;
    rdfs:comment 'Foreign key linking to ledger.gl_account. Business justification: Portfolios generate management and performance fee revenue that must post to specific GL revenue accounts for P&L reporting and revenue recognition. Banking operations require mapping each portfolio\'s' ;
    rdfs:domain ind:Wealth ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:servicingBranchId rdf:type rdf:Property ;
    rdfs:label 'Servicing Branch Id' ;
    rdfs:comment 'Foreign key linking to channel.branch. Business justification: In private banking, each managed portfolio is serviced by a specific branch housing the relationship manager. Branch-level AUM reporting, P&L attribution, and regulatory branch supervision require lin' ;
    rdfs:domain ind:Wealth ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Branch .

ind:activationDate rdf:type rdf:Property ;
    rdfs:label 'Activation Date' ;
    rdfs:comment 'Date when the portfolio became active and available for trading and management.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:aumAmount rdf:type rdf:Property ;
    rdfs:label 'Aum Amount' ;
    rdfs:comment 'Total market value of assets under management in the portfolio, expressed in the base currency. Updated daily based on market valuations.' ;
    rdfs:domain ind:Wealth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:aumAsOfDate rdf:type rdf:Property ;
    rdfs:label 'Aum As Of Date' ;
    rdfs:comment 'Date as of which the AUM amount was calculated, typically the most recent business day.' ;
    rdfs:domain ind:Wealth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:derivativesAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Derivatives Allowed Flag' ;
    rdfs:comment 'Indicates whether the portfolio is permitted to invest in derivative instruments (options, futures, swaps).' ;
    rdfs:domain ind:ManagedPortfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:esgCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Esg Compliant Flag' ;
    rdfs:comment 'Indicates whether the portfolio follows ESG investment criteria and sustainability guidelines.' ;
    rdfs:domain ind:Wealth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:feeScheduleCode rdf:type rdf:Property ;
    rdfs:label 'Fee Schedule Code' ;
    rdfs:comment 'Code referencing the fee structure and pricing schedule applicable to this portfolio (e.g., management fees, performance fees, custody fees).' ;
    rdfs:domain ind:Wealth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:highWaterMark rdf:type rdf:Property ;
    rdfs:label 'High Water Mark' ;
    rdfs:comment 'Highest Net Asset Value (NAV) level reached by the portfolio, used to calculate performance fees. Ensures performance fees are only charged on new gains.' ;
    rdfs:domain ind:Wealth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:investmentHorizon rdf:type rdf:Property ;
    rdfs:label 'Investment Horizon' ;
    rdfs:comment 'Expected time horizon for the investment: short-term (< 3 years), medium-term (3-10 years), long-term (> 10 years), or perpetual.' ;
    rdfs:domain ind:ManagedPortfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastRebalanceDate rdf:type rdf:Property ;
    rdfs:label 'Last Rebalance Date' ;
    rdfs:comment 'Date when the portfolio was last rebalanced to target allocations.' ;
    rdfs:domain ind:ManagedPortfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leverageAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Leverage Allowed Flag' ;
    rdfs:comment 'Indicates whether the portfolio is permitted to use leverage or borrowed funds to amplify investment positions.' ;
    rdfs:domain ind:ManagedPortfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:managedPortfolioStatus rdf:type rdf:Property ;
    rdfs:label 'Managed Portfolio Status' ;
    rdfs:comment 'Current lifecycle status of the managed portfolio.' ;
    rdfs:domain ind:ManagedPortfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managementFeeRate rdf:type rdf:Property ;
    rdfs:label 'Management Fee Rate' ;
    rdfs:comment 'Annual management fee rate expressed as a decimal (e.g., 0.0150 for 1.50% per annum), charged on AUM.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextRebalanceDate rdf:type rdf:Property ;
    rdfs:label 'Next Rebalance Date' ;
    rdfs:comment 'Scheduled date for the next portfolio rebalancing review.' ;
    rdfs:domain ind:ManagedPortfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:performanceFeeRate rdf:type rdf:Property ;
    rdfs:label 'Performance Fee Rate' ;
    rdfs:comment 'Performance fee rate expressed as a decimal, typically charged on returns exceeding the benchmark or hurdle rate. Null if no performance fee applies.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:portfolioName rdf:type rdf:Property ;
    rdfs:label 'Portfolio Name' ;
    rdfs:comment 'Human-readable name or title of the managed portfolio, typically reflecting the client name or investment strategy.' ;
    rdfs:domain ind:ManagedPortfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portfolioNumber rdf:type rdf:Property ;
    rdfs:label 'Portfolio Number' ;
    rdfs:comment 'Externally-known unique business identifier for the portfolio, used in client communications and regulatory reporting.' ;
    rdfs:domain ind:ManagedPortfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portfolioStrategy rdf:type rdf:Property ;
    rdfs:label 'Portfolio Strategy' ;
    rdfs:comment 'High-level investment strategy or approach for the portfolio (e.g., growth, income, balanced, capital preservation, ESG-focused).' ;
    rdfs:domain ind:ManagedPortfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskProfile rdf:type rdf:Property ;
    rdfs:label 'Risk Profile' ;
    rdfs:comment 'Client risk tolerance classification based on suitability assessment, ranging from conservative to aggressive.' ;
    rdfs:domain ind:Wealth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shariahCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Shariah Compliant Flag' ;
    rdfs:comment 'Indicates whether the portfolio adheres to Islamic finance principles and Shariah law.' ;
    rdfs:domain ind:Wealth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxStatus rdf:type rdf:Property ;
    rdfs:label 'Tax Status' ;
    rdfs:comment 'Tax treatment classification of the portfolio, affecting investment decisions and reporting requirements.' ;
    rdfs:domain ind:Wealth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalBranchId rdf:type rdf:Property ;
    rdfs:label 'Approval Branch Id' ;
    rdfs:comment 'Foreign key linking to channel.branch. Business justification: IPS documents are executed and approved at a specific branch in private banking. Branch-level compliance reporting (MiFID II, FCA COBS) requires tracking which branch approved each IPS — distinct from' ;
    rdfs:domain ind:InvestmentPolicyStatement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Branch .

ind:annualWithdrawalAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Withdrawal Amount' ;
    rdfs:comment 'Expected annual withdrawal amount from the portfolio to meet client spending needs.' ;
    rdfs:domain ind:InvestmentPolicyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:esgExclusions rdf:type rdf:Property ;
    rdfs:label 'Esg Exclusions' ;
    rdfs:comment 'List of industries, sectors, or activities excluded from the portfolio based on ESG criteria (e.g., tobacco, firearms, fossil fuels).' ;
    rdfs:domain ind:InvestmentPolicyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esgPreference rdf:type rdf:Property ;
    rdfs:label 'Esg Preference' ;
    rdfs:comment 'Client\'s preference for ESG integration: none (no ESG consideration), basic (ESG screening), advanced (ESG integration), or impact_focused (mission-driven investing).' ;
    rdfs:domain ind:InvestmentPolicyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeStructure rdf:type rdf:Property ;
    rdfs:label 'Fee Structure' ;
    rdfs:comment 'Type of fee arrangement: AUM-based (percentage of assets under management), flat fee, performance-based, or hybrid.' ;
    rdfs:domain ind:InvestmentPolicyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicRestrictions rdf:type rdf:Property ;
    rdfs:label 'Geographic Restrictions' ;
    rdfs:comment 'Geographic regions or countries excluded from or required in the portfolio (e.g., no emerging markets, US-only, exclude sanctioned countries).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investmentObjective rdf:type rdf:Property ;
    rdfs:label 'Investment Objective' ;
    rdfs:comment 'Primary investment goal articulated by the client: capital preservation, income generation, balanced growth, capital appreciation, or aggressive growth.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipsNumber rdf:type rdf:Property ;
    rdfs:label 'Ips Number' ;
    rdfs:comment 'Business identifier for the IPS document, used for external reference and client communication.' ;
    rdfs:domain ind:InvestmentPolicyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipsStatus rdf:type rdf:Property ;
    rdfs:label 'Ips Status' ;
    rdfs:comment 'Current lifecycle status of the IPS document. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|active|suspended|terminated|superseded — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InvestmentPolicyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipsType rdf:type rdf:Property ;
    rdfs:label 'Ips Type' ;
    rdfs:comment 'Classification of the IPS lifecycle stage: proposal (pre-acceptance), approved_ips (client-accepted mandate), or amended_ips (revised mandate).' ;
    rdfs:domain ind:InvestmentPolicyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipsVersion rdf:type rdf:Property ;
    rdfs:label 'Ips Version' ;
    rdfs:comment 'Version number of the IPS document, incremented with each amendment or restatement.' ;
    rdfs:domain ind:InvestmentPolicyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:liquidityRequirementDescription rdf:type rdf:Property ;
    rdfs:label 'Liquidity Requirement Description' ;
    rdfs:comment 'Narrative description of the client\'s liquidity needs, including anticipated withdrawals, emergency reserves, and cash flow requirements.' ;
    rdfs:domain ind:InvestmentPolicyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managementFeePct rdf:type rdf:Property ;
    rdfs:label 'Management Fee Pct' ;
    rdfs:comment 'Annual management fee as a percentage of AUM, expressed as a decimal (e.g., 1.00 for 1%).' ;
    rdfs:domain ind:InvestmentPolicyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceFeePct rdf:type rdf:Property ;
    rdfs:label 'Performance Fee Pct' ;
    rdfs:comment 'Performance-based fee as a percentage of returns above a hurdle rate, expressed as a decimal (e.g., 20.00 for 20%).' ;
    rdfs:domain ind:InvestmentPolicyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prohibitedSecurities rdf:type rdf:Property ;
    rdfs:label 'Prohibited Securities' ;
    rdfs:comment 'Specific securities, issuers, or asset types explicitly prohibited by the client (e.g., employer stock, specific countries, derivatives).' ;
    rdfs:domain ind:InvestmentPolicyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposalDate rdf:type rdf:Property ;
    rdfs:label 'Proposal Date' ;
    rdfs:comment 'Date the initial investment proposal was presented to the client.' ;
    rdfs:domain ind:InvestmentPolicyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rebalancingTriggerPct rdf:type rdf:Property ;
    rdfs:label 'Rebalancing Trigger Pct' ;
    rdfs:comment 'Percentage deviation from target asset allocation that triggers a portfolio rebalancing action, expressed as a decimal (e.g., 5.00 for 5%).' ;
    rdfs:domain ind:InvestmentPolicyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryRestrictions rdf:type rdf:Property ;
    rdfs:label 'Regulatory Restrictions' ;
    rdfs:comment 'Regulatory or legal constraints applicable to the portfolio, including ERISA fiduciary rules, UCITS limits, or jurisdiction-specific investment restrictions.' ;
    rdfs:domain ind:InvestmentPolicyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnObjectiveDescription rdf:type rdf:Property ;
    rdfs:label 'Return Objective Description' ;
    rdfs:comment 'Narrative description of the client\'s return expectations, including target return rates, benchmarks, and time horizon considerations.' ;
    rdfs:domain ind:InvestmentPolicyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskCapacity rdf:type rdf:Property ;
    rdfs:label 'Risk Capacity' ;
    rdfs:comment 'Client\'s financial ability to absorb investment losses without materially impacting their financial goals.' ;
    rdfs:domain ind:InvestmentPolicyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskTolerance rdf:type rdf:Property ;
    rdfs:label 'Risk Tolerance' ;
    rdfs:comment 'Client\'s stated risk tolerance level, ranging from conservative to aggressive.' ;
    rdfs:domain ind:InvestmentPolicyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sectorExclusions rdf:type rdf:Property ;
    rdfs:label 'Sector Exclusions' ;
    rdfs:comment 'List of economic sectors excluded from the portfolio per client mandate (e.g., financials, energy, healthcare).' ;
    rdfs:domain ind:InvestmentPolicyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetAnnualReturnPct rdf:type rdf:Property ;
    rdfs:label 'Target Annual Return Pct' ;
    rdfs:comment 'Target annualized return percentage specified in the IPS, expressed as a decimal (e.g., 7.50 for 7.5%).' ;
    rdfs:domain ind:InvestmentPolicyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxConsiderations rdf:type rdf:Property ;
    rdfs:label 'Tax Considerations' ;
    rdfs:comment 'Narrative description of tax-related constraints and preferences, including capital gains management, tax-loss harvesting, and jurisdiction-specific tax rules.' ;
    rdfs:domain ind:InvestmentPolicyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeHorizonYears rdf:type rdf:Property ;
    rdfs:label 'Time Horizon Years' ;
    rdfs:comment 'Investment time horizon in years, representing the period until the client expects to draw down the portfolio.' ;
    rdfs:domain ind:InvestmentPolicyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assetAllocationId rdf:type rdf:Property ;
    rdfs:label 'Asset Allocation Id' ;
    rdfs:comment 'Unique identifier for the asset allocation record.' ;
    rdfs:domain ind:Wealth ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssetAllocation .

ind:allocationCurrencyId rdf:type rdf:Property ;
    rdfs:label 'Allocation Currency Id' ;
    rdfs:comment 'Foreign key linking to reference.currency. Business justification: Asset allocations by currency (FX exposure management) require reference to valid currency codes. Portfolio construction, rebalancing, and risk reporting depend on currency allocation tracking against' ;
    rdfs:domain ind:AssetAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:eligibilityRuleId rdf:type rdf:Property ;
    rdfs:label 'Eligibility Rule Id' ;
    rdfs:comment 'Foreign key linking to collateral.eligibility_rule. Business justification: Asset allocation decisions for portfolios with margin/derivatives exposure must respect collateral eligibility rules (HQLA classification, minimum credit rating, eligible asset classes). Linking enabl' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EligibilityRule .

ind:fundMandateId rdf:type rdf:Property ;
    rdfs:label 'Fund Mandate Id' ;
    rdfs:comment 'Foreign key linking to asset.fund_mandate. Business justification: Asset allocation compliance monitoring checks each allocation line against the applicable fund mandate constraints (sector limits, geographic restrictions, leverage limits, prohibited asset classes). ' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FundMandate .

ind:parentAllocationAssetAllocationId rdf:type rdf:Property ;
    rdfs:label 'Parent Allocation Asset Allocation Id' ;
    rdfs:comment 'Reference to the parent asset allocation record in a hierarchical allocation structure (nullable for top-level allocations).' ;
    rdfs:domain ind:AssetAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssetAllocation .

ind:actualWeightPercent rdf:type rdf:Property ;
    rdfs:label 'Actual Weight Percent' ;
    rdfs:comment 'Current actual allocation weight as a percentage of total portfolio value, calculated from current holdings and market values.' ;
    rdfs:domain ind:AssetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationHierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Allocation Hierarchy Level' ;
    rdfs:comment 'Hierarchical level of this allocation within the asset class taxonomy (1=top-level asset class, 2=subclass, 3=granular segment).' ;
    rdfs:domain ind:AssetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocationName rdf:type rdf:Property ;
    rdfs:label 'Allocation Name' ;
    rdfs:comment 'Business-friendly name or label for this asset allocation strategy (e.g., Conservative Growth, Aggressive Equity).' ;
    rdfs:domain ind:AssetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationNotes rdf:type rdf:Property ;
    rdfs:label 'Allocation Notes' ;
    rdfs:comment 'Free-text notes or commentary regarding the rationale, constraints, or special considerations for this allocation.' ;
    rdfs:domain ind:AssetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationType rdf:type rdf:Property ;
    rdfs:label 'Allocation Type' ;
    rdfs:comment 'Classification of the allocation approach: strategic (long-term target), tactical (short-term adjustment), dynamic (rules-based rebalancing), or model (template allocation).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetSubclass rdf:type rdf:Property ;
    rdfs:label 'Asset Subclass' ;
    rdfs:comment 'Granular sub-classification within the asset class (e.g., large-cap equities, investment-grade bonds, private equity, REITs).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correlationCoefficient rdf:type rdf:Property ;
    rdfs:label 'Correlation Coefficient' ;
    rdfs:comment 'Statistical correlation of this asset class with the overall portfolio or a reference asset class, ranging from -1.000 to +1.000.' ;
    rdfs:domain ind:AssetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:driftPercent rdf:type rdf:Property ;
    rdfs:label 'Drift Percent' ;
    rdfs:comment 'Calculated deviation of actual weight from target weight, expressed as percentage points (actual_weight_percent - target_weight_percent).' ;
    rdfs:domain ind:AssetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:driftThresholdPercent rdf:type rdf:Property ;
    rdfs:label 'Drift Threshold Percent' ;
    rdfs:comment 'Maximum allowable drift from target weight before rebalancing is triggered, expressed as percentage points.' ;
    rdfs:domain ind:AssetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:esgAlignmentFlag rdf:type rdf:Property ;
    rdfs:label 'Esg Alignment Flag' ;
    rdfs:comment 'Indicator whether this allocation aligns with Environmental, Social, and Governance (ESG) investment criteria (True/False).' ;
    rdfs:domain ind:AssetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:expectedReturnPercent rdf:type rdf:Property ;
    rdfs:label 'Expected Return Percent' ;
    rdfs:comment 'Projected annualized return for this asset class allocation, used in portfolio optimization and client reporting.' ;
    rdfs:domain ind:Wealth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedVolatilityPercent rdf:type rdf:Property ;
    rdfs:label 'Expected Volatility Percent' ;
    rdfs:comment 'Projected annualized standard deviation (volatility) for this asset class allocation, used in risk assessment.' ;
    rdfs:domain ind:Wealth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geographicAllocation rdf:type rdf:Property ;
    rdfs:label 'Geographic Allocation' ;
    rdfs:comment 'Geographic or regional focus of the allocation (e.g., USA, EUR, GBR, emerging markets, global).' ;
    rdfs:domain ind:AssetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastRebalancedDate rdf:type rdf:Property ;
    rdfs:label 'Last Rebalanced Date' ;
    rdfs:comment 'Date when this allocation was last rebalanced to bring actual weights back in line with target weights.' ;
    rdfs:domain ind:AssetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:liquidityClassification rdf:type rdf:Property ;
    rdfs:label 'Liquidity Classification' ;
    rdfs:comment 'Liquidity profile of the asset class allocation (highly liquid, liquid, moderately liquid, illiquid) for liquidity risk management.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumWeightPercent rdf:type rdf:Property ;
    rdfs:label 'Maximum Weight Percent' ;
    rdfs:comment 'Maximum allowable allocation weight as a percentage, defining the upper bound of the rebalancing band.' ;
    rdfs:domain ind:AssetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumWeightPercent rdf:type rdf:Property ;
    rdfs:label 'Minimum Weight Percent' ;
    rdfs:comment 'Minimum allowable allocation weight as a percentage, defining the lower bound of the rebalancing band.' ;
    rdfs:domain ind:AssetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rebalancingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Rebalancing Required Flag' ;
    rdfs:comment 'Indicator whether this allocation line has breached drift thresholds and requires rebalancing action (True/False).' ;
    rdfs:domain ind:AssetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recordVersion rdf:type rdf:Property ;
    rdfs:label 'Record Version' ;
    rdfs:comment 'Version number of this allocation record, incremented with each update to support change tracking and audit history.' ;
    rdfs:domain ind:AssetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:riskToleranceAlignment rdf:type rdf:Property ;
    rdfs:label 'Risk Tolerance Alignment' ;
    rdfs:comment 'Risk profile category that this allocation is designed to support (conservative, moderate, balanced, growth, aggressive).' ;
    rdfs:domain ind:AssetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetWeightPercent rdf:type rdf:Property ;
    rdfs:label 'Target Weight Percent' ;
    rdfs:comment 'Strategic or tactical target allocation weight as a percentage of total portfolio value (e.g., 60.00 for 60%).' ;
    rdfs:domain ind:AssetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxEfficiencyRating rdf:type rdf:Property ;
    rdfs:label 'Tax Efficiency Rating' ;
    rdfs:comment 'Qualitative assessment of the tax efficiency of this asset class allocation (high, medium, low) for tax-aware portfolio management.' ;
    rdfs:domain ind:AssetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portfolioHoldingId rdf:type rdf:Property ;
    rdfs:label 'Portfolio Holding Id' ;
    rdfs:comment 'Unique identifier for each portfolio holding record. Primary key for the portfolio holding entity.' ;
    rdfs:domain ind:PortfolioHolding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:issuerCountryId rdf:type rdf:Property ;
    rdfs:label 'Issuer Country Id' ;
    rdfs:comment 'Foreign key linking to reference.country. Business justification: Holdings have issuer domicile for country risk reporting. Geographic concentration limits, IPS compliance, and country risk exposure analysis require issuer country reference for every security positi' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:taxLotId rdf:type rdf:Property ;
    rdfs:label 'Tax Lot Id' ;
    rdfs:comment 'Unique identifier for the specific tax lot within the holding. Enables lot-level tracking for tax optimization strategies.' ;
    rdfs:domain ind:Wealth ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TaxLot .

ind:acquisitionDate rdf:type rdf:Property ;
    rdfs:label 'Acquisition Date' ;
    rdfs:comment 'Date when the security position was originally acquired or established in the portfolio. Used for holding period determination and tax lot tracking.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:costBasisMethod rdf:type rdf:Property ;
    rdfs:label 'Cost Basis Method' ;
    rdfs:comment 'Accounting method used to determine which tax lots are sold first for capital gains calculation. Critical for tax-loss harvesting and capital gains optimization strategies.' ;
    rdfs:domain ind:Wealth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdingPeriodClassification rdf:type rdf:Property ;
    rdfs:label 'Holding Period Classification' ;
    rdfs:comment 'Tax classification based on holding period. Short-term applies to positions held one year or less; long-term applies to positions held more than one year. Determines capital gains tax rate.' ;
    rdfs:domain ind:Wealth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incomeType rdf:type rdf:Property ;
    rdfs:label 'Income Type' ;
    rdfs:comment 'Tax classification of income generated by the holding. Determines tax treatment and reporting requirements for client tax documents.' ;
    rdfs:domain ind:Wealth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotAcquisitionDate rdf:type rdf:Property ;
    rdfs:label 'Lot Acquisition Date' ;
    rdfs:comment 'Date when this specific tax lot was acquired. Used to determine short-term versus long-term capital gains treatment.' ;
    rdfs:domain ind:PortfolioHolding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lotAcquisitionPrice rdf:type rdf:Property ;
    rdfs:label 'Lot Acquisition Price' ;
    rdfs:comment 'Per-unit purchase price for this specific tax lot including transaction costs allocated to the lot.' ;
    rdfs:domain ind:PortfolioHolding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lotQuantity rdf:type rdf:Property ;
    rdfs:label 'Lot Quantity' ;
    rdfs:comment 'Number of units in this specific tax lot. Sum of all lot quantities equals the total holding quantity.' ;
    rdfs:domain ind:PortfolioHolding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lotStatus rdf:type rdf:Property ;
    rdfs:label 'Lot Status' ;
    rdfs:comment 'Current lifecycle status of the tax lot indicating whether it is still held, has been sold, or affected by corporate actions.' ;
    rdfs:domain ind:Wealth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pledgedFlag rdf:type rdf:Property ;
    rdfs:label 'Pledged Flag' ;
    rdfs:comment 'Indicates whether the holding is pledged as collateral for margin loans, derivatives positions, or other obligations. Critical for available liquidity calculations.' ;
    rdfs:domain ind:PortfolioHolding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:portfolioWeight rdf:type rdf:Property ;
    rdfs:label 'Portfolio Weight' ;
    rdfs:comment 'Percentage of total portfolio market value represented by this holding. Used for asset allocation analysis and rebalancing decisions.' ;
    rdfs:domain ind:PortfolioHolding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:restrictedFlag rdf:type rdf:Property ;
    rdfs:label 'Restricted Flag' ;
    rdfs:comment 'Indicates whether the holding is subject to trading restrictions such as lock-up periods, regulatory holds, or contractual limitations. Affects liquidity analysis and rebalancing decisions.' ;
    rdfs:domain ind:PortfolioHolding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalCostBasis rdf:type rdf:Property ;
    rdfs:label 'Total Cost Basis' ;
    rdfs:comment 'Total acquisition cost of the holding including commissions and fees. Used for capital gains calculation and performance attribution.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitCostBasis rdf:type rdf:Property ;
    rdfs:label 'Unit Cost Basis' ;
    rdfs:comment 'Average cost per unit of the security for tax and performance calculation purposes. Calculated based on the cost basis method applied to all lots.' ;
    rdfs:domain ind:PortfolioHolding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unrealizedGainLoss rdf:type rdf:Property ;
    rdfs:label 'Unrealized Gain Loss' ;
    rdfs:comment 'Difference between market value and total cost basis. Represents paper profit or loss on the holding that has not been realized through sale.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unrealizedGainLossPercent rdf:type rdf:Property ;
    rdfs:label 'Unrealized Gain Loss Percent' ;
    rdfs:comment 'Unrealized gain or loss expressed as a percentage of total cost basis. Used for performance reporting and client communication.' ;
    rdfs:domain ind:Wealth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:washSaleFlag rdf:type rdf:Property ;
    rdfs:label 'Wash Sale Flag' ;
    rdfs:comment 'Indicates whether this holding is subject to wash sale rules, which disallow loss deductions when substantially identical securities are purchased within 30 days before or after a sale at a loss.' ;
    rdfs:domain ind:Wealth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:portfolioTransactionId rdf:type rdf:Property ;
    rdfs:label 'Portfolio Transaction Id' ;
    rdfs:comment 'Unique identifier for the portfolio transaction record.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PortfolioTransaction .

ind:distributionEventId rdf:type rdf:Property ;
    rdfs:label 'Distribution Event Id' ;
    rdfs:comment 'Foreign key linking to asset.distribution_event. Business justification: Fund income distributions (dividends, capital gains) generate portfolio_transactions recording the receipt. Linking to distribution_event enables income attribution for performance reporting, tax repo' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionEvent .

ind:executionChannelId rdf:type rdf:Property ;
    rdfs:label 'Execution Channel Id' ;
    rdfs:comment 'Foreign key linking to channel.channel. Business justification: Transactions execute through specific channels (online platform, mobile app, RM phone order, branch). Required for channel attribution reporting, differential fee calculation by channel, regulatory tr' ;
    rdfs:domain ind:PortfolioTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:executionDigitalChannelId rdf:type rdf:Property ;
    rdfs:label 'Execution Digital Channel Id' ;
    rdfs:comment 'Foreign key linking to channel.digital_channel. Business justification: MiFID II best execution reporting requires identifying the specific digital platform (API, robo-advisory, online portal) through which a portfolio transaction was executed. The existing execution_chan' ;
    rdfs:domain ind:PortfolioTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DigitalChannel .

ind:executionPriceId rdf:type rdf:Property ;
    rdfs:label 'Execution Price Id' ;
    rdfs:comment 'Foreign key linking to security.price. Business justification: MiFID II best execution reporting and trade reconstruction require linking each portfolio transaction to the authoritative price record at execution time. Role-prefix \'execution_\' distinguishes this f' ;
    rdfs:domain ind:PortfolioTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Price .

ind:initiatingSessionId rdf:type rdf:Property ;
    rdfs:label 'Initiating Session Id' ;
    rdfs:comment 'Foreign key linking to channel.session. Business justification: Digital wealth transactions require session linkage for fraud detection, impersonation investigation, and regulatory audit trails. Linking a portfolio transaction to the authenticated session that ini' ;
    rdfs:domain ind:Wealth ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Session .

ind:rebalancingOrderId rdf:type rdf:Property ;
    rdfs:label 'Rebalancing Order Id' ;
    rdfs:comment 'Identifier of the portfolio rebalancing event that triggered this transaction, if applicable.' ;
    rdfs:domain ind:Wealth ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RebalancingOrder .

ind:settlementDepositAccountId rdf:type rdf:Property ;
    rdfs:label 'Settlement Deposit Account Id' ;
    rdfs:comment 'Foreign key linking to account.deposit_account. Business justification: Portfolio transactions settle cash legs via deposit accounts for trade execution, dividend payments, interest receipts, and fee debits. Required for trade settlement reconciliation and cash movement t' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DepositAccount .

ind:settlementNostroAccountId rdf:type rdf:Property ;
    rdfs:label 'Settlement Nostro Account Id' ;
    rdfs:comment 'Foreign key linking to treasury.nostro_account. Business justification: Securities portfolio transactions settle the cash leg through specific nostro accounts at correspondent banks. Linking portfolio_transaction to nostro_account enables settlement tracking, nostro recon' ;
    rdfs:domain ind:PortfolioTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NostroAccount .

ind:actionRatio rdf:type rdf:Property ;
    rdfs:label 'Action Ratio' ;
    rdfs:comment 'Ratio describing the terms of a corporate action (e.g., \'2:1\' for a stock split, \'1:0.5\' for a rights issue). Format varies by action type.' ;
    rdfs:domain ind:PortfolioTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commission rdf:type rdf:Property ;
    rdfs:label 'Commission' ;
    rdfs:comment 'Brokerage commission charged for executing the transaction.' ;
    rdfs:domain ind:PortfolioTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:corporateActionType rdf:type rdf:Property ;
    rdfs:label 'Corporate Action Type' ;
    rdfs:comment 'Type of corporate action that generated this transaction, if applicable. [ENUM-REF-CANDIDATE: dividend|stock_split|reverse_split|merger|acquisition|spin_off|rights_issue|tender_offer|redemption|call|conversion|name_change — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PortfolioTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costBasis rdf:type rdf:Property ;
    rdfs:label 'Cost Basis' ;
    rdfs:comment 'Original acquisition cost of the securities involved in this transaction, used for capital gains calculation. Applicable for sell transactions.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:electionType rdf:type rdf:Property ;
    rdfs:label 'Election Type' ;
    rdfs:comment 'Shareholder election for corporate actions offering multiple options (e.g., cash dividend vs. stock dividend, cash vs. stock in a merger).' ;
    rdfs:domain ind:PortfolioTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Amount' ;
    rdfs:comment 'Total transaction value before fees, commissions, and taxes. Calculated as quantity multiplied by price.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:realizedGainLoss rdf:type rdf:Property ;
    rdfs:label 'Realized Gain Loss' ;
    rdfs:comment 'Capital gain or loss realized from this transaction, calculated as the difference between net proceeds and cost basis. Applicable for sell transactions.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementInstruction rdf:type rdf:Property ;
    rdfs:label 'Settlement Instruction' ;
    rdfs:comment 'Method of settlement: Delivery Versus Payment (DVP), Receive Versus Payment (RVP), Free of Payment (FOP), or Against Payment.' ;
    rdfs:domain ind:PortfolioTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxLotMethod rdf:type rdf:Property ;
    rdfs:label 'Tax Lot Method' ;
    rdfs:comment 'Method used to identify which tax lots are affected by this transaction for cost basis tracking and capital gains calculation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:navCalculationId rdf:type rdf:Property ;
    rdfs:label 'Nav Calculation Id' ;
    rdfs:comment 'Unique identifier for the NAV calculation record. Primary key for this entity.' ;
    rdfs:domain ind:NavCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accruedExpenses rdf:type rdf:Property ;
    rdfs:label 'Accrued Expenses' ;
    rdfs:comment 'Expenses incurred but not yet paid as of the valuation date, including management fees, performance fees, custody fees, and other operating expenses.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calculationMethod rdf:type rdf:Property ;
    rdfs:label 'Calculation Method' ;
    rdfs:comment 'The NAV calculation method applied. Forward pricing uses end-of-day prices; swing pricing adjusts NAV for dilution; dual pricing separates bid/offer NAVs.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dividendIncome rdf:type rdf:Property ;
    rdfs:label 'Dividend Income' ;
    rdfs:comment 'Total dividend income received or accrued during the period ending on the valuation date.' ;
    rdfs:domain ind:NavCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expenseRatio rdf:type rdf:Property ;
    rdfs:label 'Expense Ratio' ;
    rdfs:comment 'Total expenses expressed as a percentage of average net assets, typically annualized. A key metric for fund cost transparency.' ;
    rdfs:domain ind:NavCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossAssetValue rdf:type rdf:Property ;
    rdfs:label 'Gross Asset Value' ;
    rdfs:comment 'Total market value of all assets held in the portfolio or fund at the valuation date, before deducting any liabilities.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interestIncome rdf:type rdf:Property ;
    rdfs:label 'Interest Income' ;
    rdfs:comment 'Total interest income received or accrued from fixed-income securities and cash holdings during the period ending on the valuation date.' ;
    rdfs:domain ind:NavCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:managementFeeAccrual rdf:type rdf:Property ;
    rdfs:label 'Management Fee Accrual' ;
    rdfs:comment 'Accrued management fees owed to the investment manager as of the valuation date, typically calculated as a percentage of Assets Under Management (AUM).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:navChangeAmount rdf:type rdf:Property ;
    rdfs:label 'Nav Change Amount' ;
    rdfs:comment 'Absolute change in NAV from the prior valuation date to the current valuation date.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:navChangePercent rdf:type rdf:Property ;
    rdfs:label 'Nav Change Percent' ;
    rdfs:comment 'Percentage change in NAV from the prior valuation date, expressed as a decimal (e.g., 0.0250 for 2.5%).' ;
    rdfs:domain ind:NavCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:navPerUnit rdf:type rdf:Property ;
    rdfs:label 'Nav Per Unit' ;
    rdfs:comment 'The NAV divided by the number of outstanding units or shares. This is the price at which investors can subscribe or redeem units.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netAssetValue rdf:type rdf:Property ;
    rdfs:label 'Net Asset Value' ;
    rdfs:comment 'The net value of the portfolio or fund, calculated as gross asset value minus total liabilities. This is the headline NAV figure used for client reporting and unit pricing.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netCashFlow rdf:type rdf:Property ;
    rdfs:label 'Net Cash Flow' ;
    rdfs:comment 'Net cash flow into or out of the fund, calculated as subscriptions minus redemptions.' ;
    rdfs:domain ind:Wealth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceFeeAccrual rdf:type rdf:Property ;
    rdfs:label 'Performance Fee Accrual' ;
    rdfs:comment 'Accrued performance or incentive fees owed to the investment manager, typically calculated based on returns exceeding a hurdle rate or high-water mark.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorNav rdf:type rdf:Property ;
    rdfs:label 'Prior Nav' ;
    rdfs:comment 'The NAV from the previous valuation date, used for period-over-period performance calculation and reconciliation.' ;
    rdfs:domain ind:NavCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:redemptionsAmount rdf:type rdf:Property ;
    rdfs:label 'Redemptions Amount' ;
    rdfs:comment 'Total value of investor redemptions (capital outflows) processed on or before the valuation date.' ;
    rdfs:domain ind:NavCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:subscriptionsAmount rdf:type rdf:Property ;
    rdfs:label 'Subscriptions Amount' ;
    rdfs:comment 'Total value of new investor subscriptions (capital inflows) processed on or before the valuation date.' ;
    rdfs:domain ind:NavCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:swingFactorApplied rdf:type rdf:Property ;
    rdfs:label 'Swing Factor Applied' ;
    rdfs:comment 'The swing pricing adjustment factor applied to the NAV to protect existing investors from dilution caused by large subscriptions or redemptions.' ;
    rdfs:domain ind:NavCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalExpenses rdf:type rdf:Property ;
    rdfs:label 'Total Expenses' ;
    rdfs:comment 'Sum of all operating expenses, management fees, performance fees, custody fees, and other costs incurred during the period ending on the valuation date.' ;
    rdfs:domain ind:NavCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitsOutstanding rdf:type rdf:Property ;
    rdfs:label 'Units Outstanding' ;
    rdfs:comment 'Total number of fund units or shares outstanding at the valuation date. Used to calculate NAV per unit.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceAmount rdf:type rdf:Property ;
    rdfs:label 'Variance Amount' ;
    rdfs:comment 'Absolute value of any variance identified during reconciliation between internal NAV calculation and external custodian or administrator NAV.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceReason rdf:type rdf:Property ;
    rdfs:label 'Variance Reason' ;
    rdfs:comment 'Explanation of any material variance identified during NAV reconciliation, including root cause and resolution plan.' ;
    rdfs:domain ind:NavCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalChannelId rdf:type rdf:Property ;
    rdfs:label 'Approval Channel Id' ;
    rdfs:comment 'Foreign key linking to channel.channel. Business justification: Rebalancing orders require client approval through specific channels (email consent, phone authorization, digital approval). Essential for compliance audit trail, client consent documentation, dispute' ;
    rdfs:domain ind:RebalancingOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:approvalDigitalChannelId rdf:type rdf:Property ;
    rdfs:label 'Approval Digital Channel Id' ;
    rdfs:comment 'Foreign key linking to channel.digital_channel. Business justification: Robo-advisory and digital wealth platforms generate rebalancing orders via specific API/digital channels. Linking to the digital_channel instance supports platform performance reporting, API-level aud' ;
    rdfs:domain ind:RebalancingOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DigitalChannel .

ind:fundingDepositAccountId rdf:type rdf:Property ;
    rdfs:label 'Funding Deposit Account Id' ;
    rdfs:comment 'Foreign key linking to account.deposit_account. Business justification: Rebalancing orders require deposit accounts for funding security purchases and receiving sale proceeds. Essential for portfolio rebalancing execution, cash availability verification, and transaction c' ;
    rdfs:domain ind:RebalancingOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DepositAccount .

ind:actualExecutionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Execution Date' ;
    rdfs:comment 'The actual date on which the rebalancing trades were executed and completed. Null if not yet executed.' ;
    rdfs:domain ind:RebalancingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualTransactionCost rdf:type rdf:Property ;
    rdfs:label 'Actual Transaction Cost' ;
    rdfs:comment 'The actual total transaction costs incurred during rebalancing execution. Null if not yet executed.' ;
    rdfs:domain ind:RebalancingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvalWorkflowStage rdf:type rdf:Property ;
    rdfs:label 'Approval Workflow Stage' ;
    rdfs:comment 'Current stage in the multi-level approval workflow for the rebalancing order, indicating which stakeholder group must review and approve next.' ;
    rdfs:domain ind:RebalancingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:driftTolerancePercentage rdf:type rdf:Property ;
    rdfs:label 'Drift Tolerance Percentage' ;
    rdfs:comment 'The maximum allowable percentage deviation from target asset allocation that triggers a rebalancing order, as defined in the clients Investment Policy Statement (IPS).' ;
    rdfs:domain ind:RebalancingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedTaxBenefit rdf:type rdf:Property ;
    rdfs:label 'Estimated Tax Benefit' ;
    rdfs:comment 'The estimated tax benefit from realized capital losses through tax-loss harvesting in this rebalancing order. Null if tax-loss harvesting is not applicable.' ;
    rdfs:domain ind:RebalancingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedTransactionCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Transaction Cost' ;
    rdfs:comment 'The estimated total transaction costs including brokerage commissions, bid-ask spreads, market impact, and other execution costs for the proposed rebalancing trades.' ;
    rdfs:domain ind:RebalancingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:executionVenue rdf:type rdf:Property ;
    rdfs:label 'Execution Venue' ;
    rdfs:comment 'The trading venue, broker, or execution platform used to execute the rebalancing trades (e.g., internal trading desk, external broker, algorithmic execution platform).' ;
    rdfs:domain ind:RebalancingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipsComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Ips Compliance Flag' ;
    rdfs:comment 'Indicates whether the proposed rebalancing order is compliant with the clients Investment Policy Statement (IPS) constraints including asset allocation ranges, security restrictions, and risk limits.' ;
    rdfs:domain ind:RebalancingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:portfolioNavAtExecution rdf:type rdf:Property ;
    rdfs:label 'Portfolio Nav At Execution' ;
    rdfs:comment 'The total Net Asset Value (NAV) of the portfolio at the time of rebalancing execution. Null if not yet executed.' ;
    rdfs:domain ind:RebalancingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:portfolioNavAtTrigger rdf:type rdf:Property ;
    rdfs:label 'Portfolio Nav At Trigger' ;
    rdfs:comment 'The total Net Asset Value (NAV) of the portfolio at the time the rebalancing trigger was identified, expressed in the portfolio base currency.' ;
    rdfs:domain ind:RebalancingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postRebalanceDriftPercentage rdf:type rdf:Property ;
    rdfs:label 'Post Rebalance Drift Percentage' ;
    rdfs:comment 'The maximum percentage deviation from target asset allocation across all asset classes after rebalancing execution. Null if not yet executed.' ;
    rdfs:domain ind:RebalancingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preRebalanceDriftPercentage rdf:type rdf:Property ;
    rdfs:label 'Pre Rebalance Drift Percentage' ;
    rdfs:comment 'The maximum percentage deviation from target asset allocation across all asset classes before rebalancing, measured as the absolute difference between actual and target weights.' ;
    rdfs:domain ind:RebalancingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proposedExecutionDate rdf:type rdf:Property ;
    rdfs:label 'Proposed Execution Date' ;
    rdfs:comment 'The target date for executing the rebalancing trades, subject to approval and market conditions.' ;
    rdfs:domain ind:RebalancingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rebalancingMethod rdf:type rdf:Property ;
    rdfs:label 'Rebalancing Method' ;
    rdfs:comment 'The methodology used to determine rebalancing trades: cash-flow rebalancing (using new contributions/withdrawals), threshold-based (triggered by drift), calendar-based (periodic), or optimization-based (minimizing costs and taxes).' ;
    rdfs:domain ind:RebalancingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemOrderReference rdf:type rdf:Property ;
    rdfs:label 'Source System Order Reference' ;
    rdfs:comment 'The unique identifier for this rebalancing order in the originating source system, used for reconciliation and traceability.' ;
    rdfs:domain ind:RebalancingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxLossHarvestingFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Loss Harvesting Flag' ;
    rdfs:comment 'Indicates whether this rebalancing order includes tax-loss harvesting opportunities to realize capital losses for tax optimization purposes.' ;
    rdfs:domain ind:RebalancingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalEstimatedTradeValue rdf:type rdf:Property ;
    rdfs:label 'Total Estimated Trade Value' ;
    rdfs:comment 'The total estimated market value of all proposed trades (buys and sells) in the rebalancing order, expressed in the portfolio base currency.' ;
    rdfs:domain ind:RebalancingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tradeInstructionCount rdf:type rdf:Property ;
    rdfs:label 'Trade Instruction Count' ;
    rdfs:comment 'The total number of individual trade instructions (buy and sell orders) included in this rebalancing order.' ;
    rdfs:domain ind:RebalancingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:triggerDate rdf:type rdf:Property ;
    rdfs:label 'Trigger Date' ;
    rdfs:comment 'The date on which the rebalancing trigger condition was identified or the rebalancing instruction was initiated.' ;
    rdfs:domain ind:RebalancingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:triggerType rdf:type rdf:Property ;
    rdfs:label 'Trigger Type' ;
    rdfs:comment 'The business event or condition that initiated the rebalancing order, such as asset allocation drift exceeding threshold, Investment Policy Statement (IPS) mandate change, model portfolio update, explicit client instruction, scheduled periodic review, or tax-loss harvesting opportunity.' ;
    rdfs:domain ind:RebalancingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:washSaleCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Wash Sale Check Status' ;
    rdfs:comment 'Status of the wash sale rule compliance check to ensure that substantially identical securities are not repurchased within 30 days before or after a loss sale, which would disallow the tax loss.' ;
    rdfs:domain ind:RebalancingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceReturnId rdf:type rdf:Property ;
    rdfs:label 'Performance Return Id' ;
    rdfs:comment 'Unique identifier for the performance return calculation record.' ;
    rdfs:domain ind:PerformanceReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:activeReturn rdf:type rdf:Property ;
    rdfs:label 'Active Return' ;
    rdfs:comment 'The difference between the portfolio gross return and the benchmark return, representing the value added by active management (alpha).' ;
    rdfs:domain ind:PerformanceReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annualizedReturn rdf:type rdf:Property ;
    rdfs:label 'Annualized Return' ;
    rdfs:comment 'The geometric average return expressed as an annual rate, standardizing returns across different time periods.' ;
    rdfs:domain ind:PerformanceReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annualizedVolatility rdf:type rdf:Property ;
    rdfs:label 'Annualized Volatility' ;
    rdfs:comment 'The annualized standard deviation of portfolio returns, measuring total risk.' ;
    rdfs:domain ind:PerformanceReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:attributionAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Attribution Available Flag' ;
    rdfs:comment 'Indicates whether detailed performance attribution analysis is available for this return calculation.' ;
    rdfs:domain ind:PerformanceReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:beginningMarketValue rdf:type rdf:Property ;
    rdfs:label 'Beginning Market Value' ;
    rdfs:comment 'The total market value of the portfolio at the start of the measurement period.' ;
    rdfs:domain ind:PerformanceReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:benchmarkReturn rdf:type rdf:Property ;
    rdfs:label 'Benchmark Return' ;
    rdfs:comment 'The return of the designated benchmark index over the same measurement period.' ;
    rdfs:domain ind:PerformanceReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calculatedBy rdf:type rdf:Property ;
    rdfs:label 'Calculated By' ;
    rdfs:comment 'The system user or automated process that performed the performance calculation.' ;
    rdfs:domain ind:PerformanceReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculationDate rdf:type rdf:Property ;
    rdfs:label 'Calculation Date' ;
    rdfs:comment 'The business date on which the performance return was calculated.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:compositeMemberFlag rdf:type rdf:Property ;
    rdfs:label 'Composite Member Flag' ;
    rdfs:comment 'Indicates whether this portfolio is included as a member of a GIPS composite during this measurement period.' ;
    rdfs:domain ind:PerformanceReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:downsideDeviation rdf:type rdf:Property ;
    rdfs:label 'Downside Deviation' ;
    rdfs:comment 'The standard deviation of negative returns only, used in Sortino ratio calculation.' ;
    rdfs:domain ind:PerformanceReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:endingMarketValue rdf:type rdf:Property ;
    rdfs:label 'Ending Market Value' ;
    rdfs:comment 'The total market value of the portfolio at the end of the measurement period.' ;
    rdfs:domain ind:PerformanceReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gipsCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Gips Compliant Flag' ;
    rdfs:comment 'Indicates whether this performance calculation is compliant with GIPS standards for composite membership and reporting.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incomeEarned rdf:type rdf:Property ;
    rdfs:label 'Income Earned' ;
    rdfs:comment 'The total income (dividends, interest, coupons) earned by the portfolio during the measurement period.' ;
    rdfs:domain ind:PerformanceReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:informationRatio rdf:type rdf:Property ;
    rdfs:label 'Information Ratio' ;
    rdfs:comment 'Risk-adjusted active return metric calculated as active return divided by tracking error, measuring manager skill.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:managementFees rdf:type rdf:Property ;
    rdfs:label 'Management Fees' ;
    rdfs:comment 'The investment management fees charged during the measurement period, used to calculate net-of-fee returns.' ;
    rdfs:domain ind:PerformanceReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumDrawdown rdf:type rdf:Property ;
    rdfs:label 'Maximum Drawdown' ;
    rdfs:comment 'The largest peak-to-trough decline in portfolio value during the measurement period, expressed as a percentage.' ;
    rdfs:domain ind:PerformanceReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mwrReturn rdf:type rdf:Property ;
    rdfs:label 'Mwr Return' ;
    rdfs:comment 'Money-weighted rate of return (also known as Internal Rate of Return or IRR) that accounts for the timing and magnitude of external cash flows.' ;
    rdfs:domain ind:PerformanceReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:periodType rdf:type rdf:Property ;
    rdfs:label 'Period Type' ;
    rdfs:comment 'The type of measurement period for the performance calculation (daily, MTD, QTD, YTD, since inception, or custom).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskFreeRate rdf:type rdf:Property ;
    rdfs:label 'Risk Free Rate' ;
    rdfs:comment 'The risk-free rate of return used in risk-adjusted performance calculations (typically based on government securities).' ;
    rdfs:domain ind:PerformanceReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sharpeRatio rdf:type rdf:Property ;
    rdfs:label 'Sharpe Ratio' ;
    rdfs:comment 'Risk-adjusted return metric calculated as (portfolio return - risk-free rate) / standard deviation of portfolio returns.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sortinoRatio rdf:type rdf:Property ;
    rdfs:label 'Sortino Ratio' ;
    rdfs:comment 'Risk-adjusted return metric that uses downside deviation instead of total standard deviation, penalizing only negative volatility.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalContributions rdf:type rdf:Property ;
    rdfs:label 'Total Contributions' ;
    rdfs:comment 'The total amount of external contributions (deposits) made to the portfolio during the measurement period.' ;
    rdfs:domain ind:PerformanceReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalWithdrawals rdf:type rdf:Property ;
    rdfs:label 'Total Withdrawals' ;
    rdfs:comment 'The total amount of external withdrawals (distributions) made from the portfolio during the measurement period.' ;
    rdfs:domain ind:PerformanceReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trackingError rdf:type rdf:Property ;
    rdfs:label 'Tracking Error' ;
    rdfs:comment 'The standard deviation of the difference between portfolio returns and benchmark returns, measuring the consistency of active return.' ;
    rdfs:domain ind:PerformanceReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:twrGrossReturn rdf:type rdf:Property ;
    rdfs:label 'Twr Gross Return' ;
    rdfs:comment 'Time-weighted rate of return before deduction of investment management fees, calculated to eliminate the effect of external cash flows.' ;
    rdfs:domain ind:PerformanceReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:twrNetReturn rdf:type rdf:Property ;
    rdfs:label 'Twr Net Return' ;
    rdfs:comment 'Time-weighted rate of return after deduction of investment management fees and expenses.' ;
    rdfs:domain ind:PerformanceReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onboardingBranchId rdf:type rdf:Property ;
    rdfs:label 'Onboarding Branch Id' ;
    rdfs:comment 'Foreign key linking to channel.branch. Business justification: Mandates typically opened at specific branch for KYC, document notarization, and relationship establishment. Required for branch attribution, geographic regulatory compliance (state/country licensing)' ;
    rdfs:domain ind:ClientMandate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Branch .

ind:regulatoryClassificationProductTypeId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Classification Product Type Id' ;
    rdfs:comment 'Foreign key linking to reference.product_type. Business justification: Mandates are classified by product type for regulatory reporting. UCITS/AIF classification, Form ADV reporting, and product governance require product type reference.' ;
    rdfs:domain ind:ClientMandate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductType .

ind:taxReportingJurisdictionCountryId rdf:type rdf:Property ;
    rdfs:label 'Tax Reporting Jurisdiction Country Id' ;
    rdfs:comment 'Foreign key linking to reference.country. Business justification: Mandates specify tax reporting jurisdiction for FATCA/CRS compliance. Regulatory reporting, withholding tax calculation, and cross-border tax treaty application require country reference.' ;
    rdfs:domain ind:ClientMandate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:aumAtInception rdf:type rdf:Property ;
    rdfs:label 'Aum At Inception' ;
    rdfs:comment 'Total asset value under management at the time the mandate was established, used for performance tracking and fee calculation baseline.' ;
    rdfs:domain ind:ClientMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:authorizedSignatoryName rdf:type rdf:Property ;
    rdfs:label 'Authorized Signatory Name' ;
    rdfs:comment 'Name of the individual authorized to sign documents and approve transactions on behalf of the client for this mandate.' ;
    rdfs:domain ind:ClientMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedSignatoryTitle rdf:type rdf:Property ;
    rdfs:label 'Authorized Signatory Title' ;
    rdfs:comment 'Title or role of the authorized signatory (e.g., Trustee, Power of Attorney, Director).' ;
    rdfs:domain ind:ClientMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discretionaryLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Discretionary Limit Amount' ;
    rdfs:comment 'Maximum amount the wealth manager may invest or trade without explicit client approval, applicable to discretionary mandates.' ;
    rdfs:domain ind:ClientMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mandateName rdf:type rdf:Property ;
    rdfs:label 'Mandate Name' ;
    rdfs:comment 'Descriptive name or title of the mandate, often reflecting the investment objective or client preference (e.g., \'Growth Portfolio\', \'Conservative Income Strategy\').' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mandateNumber rdf:type rdf:Property ;
    rdfs:label 'Mandate Number' ;
    rdfs:comment 'Externally visible unique business identifier for the mandate, used in client communications and regulatory reporting.' ;
    rdfs:domain ind:ClientMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Balance Amount' ;
    rdfs:comment 'Minimum asset value required to maintain the mandate. Falling below this threshold may trigger review or termination.' ;
    rdfs:domain ind:ClientMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxReportingJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Tax Reporting Jurisdiction' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code representing the primary tax jurisdiction for reporting purposes (e.g., USA, GBR, CHE).' ;
    rdfs:domain ind:ClientMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationConditions rdf:type rdf:Property ;
    rdfs:label 'Termination Conditions' ;
    rdfs:comment 'Textual description of the conditions under which the mandate may be terminated by the client or the wealth manager, including breach of terms, regulatory changes, or client request.' ;
    rdfs:domain ind:ClientMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationNoticePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Termination Notice Period Days' ;
    rdfs:comment 'Number of days advance notice required by either party to terminate the mandate.' ;
    rdfs:domain ind:ClientMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assessmentBranchId rdf:type rdf:Property ;
    rdfs:label 'Assessment Branch Id' ;
    rdfs:comment 'Foreign key linking to channel.branch. Business justification: MiFID II and FCA COBS require branch-level reporting on suitability assessments conducted. Branch compliance officers need visibility into all assessments performed at their branch. The existing asses' ;
    rdfs:domain ind:SuitabilityAssessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Branch .

ind:assessmentChannelId rdf:type rdf:Property ;
    rdfs:label 'Assessment Channel Id' ;
    rdfs:comment 'Foreign key linking to channel.channel. Business justification: Suitability assessments conducted through specific channels (branch interview, video call, digital questionnaire). Critical for MiFID II/Regulation Best Interest compliance, proving appropriate advice' ;
    rdfs:domain ind:SuitabilityAssessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:assessmentSessionId rdf:type rdf:Property ;
    rdfs:label 'Assessment Session Id' ;
    rdfs:comment 'Foreign key linking to channel.session. Business justification: MiFID II appropriateness and suitability testing conducted digitally requires session linkage for regulatory audit trails. Linking the assessment to the authenticated digital session proves the client' ;
    rdfs:domain ind:SuitabilityAssessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Session .

ind:supersededByAssessmentSuitabilityAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Assessment Suitability Assessment Id' ;
    rdfs:comment 'Reference to the subsequent suitability assessment that supersedes this record, enabling historical tracking of assessment evolution.' ;
    rdfs:domain ind:SuitabilityAssessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SuitabilityAssessment .

ind:taxJurisdictionCountryId rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction Country Id' ;
    rdfs:comment 'Foreign key linking to reference.country. Business justification: Client tax status varies by jurisdiction for suitability. Tax-efficient investment strategy, municipal bond suitability, and withholding tax planning require country reference for client tax domicile.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:alternativeInvestmentsSuitability rdf:type rdf:Property ;
    rdfs:label 'Alternative Investments Suitability' ;
    rdfs:comment 'Assessment of the client\'s suitability for alternative investments (hedge funds, private equity, real estate, commodities) based on knowledge, experience, and financial capacity.' ;
    rdfs:domain ind:SuitabilityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentOutcome rdf:type rdf:Property ;
    rdfs:label 'Assessment Outcome' ;
    rdfs:comment 'The overall outcome of the suitability assessment: suitable (client profile matches investment strategy), not suitable (mismatch identified), suitable with conditions (restrictions apply), or requires further review.' ;
    rdfs:domain ind:SuitabilityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessorNotes rdf:type rdf:Property ;
    rdfs:label 'Assessor Notes' ;
    rdfs:comment 'Free-text notes and observations recorded by the relationship manager or assessor during the suitability assessment process.' ;
    rdfs:domain ind:SuitabilityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complexProductsSuitability rdf:type rdf:Property ;
    rdfs:label 'Complex Products Suitability' ;
    rdfs:comment 'Assessment of the client\'s suitability for complex financial products (structured products, derivatives, leveraged instruments) based on knowledge and experience.' ;
    rdfs:domain ind:SuitabilityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:concentrationRiskTolerance rdf:type rdf:Property ;
    rdfs:label 'Concentration Risk Tolerance' ;
    rdfs:comment 'Client\'s tolerance for concentration risk, indicating willingness to hold large positions in individual securities or sectors.' ;
    rdfs:domain ind:SuitabilityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esgPreferenceCategory rdf:type rdf:Property ;
    rdfs:label 'Esg Preference Category' ;
    rdfs:comment 'The type of ESG preference expressed by the client: none, exclusionary screening (avoiding certain sectors), positive screening (favoring ESG leaders), impact investing, or thematic ESG investing.' ;
    rdfs:domain ind:SuitabilityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esgPreferenceFlag rdf:type rdf:Property ;
    rdfs:label 'Esg Preference Flag' ;
    rdfs:comment 'Indicates whether the client has expressed a preference for Environmental, Social, and Governance (ESG) or sustainable investment criteria.' ;
    rdfs:domain ind:SuitabilityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:investableAssetsAmount rdf:type rdf:Property ;
    rdfs:label 'Investable Assets Amount' ;
    rdfs:comment 'Total value of assets the client intends to allocate for investment management, forming the basis for Assets Under Management (AUM) calculation.' ;
    rdfs:domain ind:SuitabilityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:investmentExperienceYears rdf:type rdf:Property ;
    rdfs:label 'Investment Experience Years' ;
    rdfs:comment 'Number of years the client has been actively investing in financial markets.' ;
    rdfs:domain ind:SuitabilityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:investmentKnowledgeLevel rdf:type rdf:Property ;
    rdfs:label 'Investment Knowledge Level' ;
    rdfs:comment 'Client\'s level of investment knowledge and understanding of financial instruments, ranging from basic to expert.' ;
    rdfs:domain ind:SuitabilityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investmentObjectivePrimary rdf:type rdf:Property ;
    rdfs:label 'Investment Objective Primary' ;
    rdfs:comment 'The client\'s primary investment objective, which drives portfolio construction and asset allocation strategy.' ;
    rdfs:domain ind:SuitabilityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investmentObjectiveSecondary rdf:type rdf:Property ;
    rdfs:label 'Investment Objective Secondary' ;
    rdfs:comment 'The client\'s secondary investment objective, providing additional context for portfolio construction.' ;
    rdfs:domain ind:SuitabilityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investmentTimeHorizonYears rdf:type rdf:Property ;
    rdfs:label 'Investment Time Horizon Years' ;
    rdfs:comment 'The number of years the client expects to maintain the investment before needing to liquidate, influencing asset allocation and risk capacity.' ;
    rdfs:domain ind:SuitabilityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:leverageTolerance rdf:type rdf:Property ;
    rdfs:label 'Leverage Tolerance' ;
    rdfs:comment 'Client\'s tolerance for the use of leverage or margin in the investment portfolio.' ;
    rdfs:domain ind:SuitabilityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liquidAssetsAmount rdf:type rdf:Property ;
    rdfs:label 'Liquid Assets Amount' ;
    rdfs:comment 'Value of client\'s liquid assets (cash, marketable securities, money market funds) available for investment, excluding illiquid assets such as real estate or private equity.' ;
    rdfs:domain ind:SuitabilityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:liquidityNeedsDescription rdf:type rdf:Property ;
    rdfs:label 'Liquidity Needs Description' ;
    rdfs:comment 'Textual description of the client\'s anticipated liquidity needs, including planned withdrawals, major expenses, or cash flow requirements.' ;
    rdfs:domain ind:SuitabilityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lossCapacityPercentage rdf:type rdf:Property ;
    rdfs:label 'Loss Capacity Percentage' ;
    rdfs:comment 'The maximum percentage loss the client can financially absorb without materially impacting their lifestyle or financial goals, expressed as a percentage of investable assets.' ;
    rdfs:domain ind:SuitabilityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netWorthAmount rdf:type rdf:Property ;
    rdfs:label 'Net Worth Amount' ;
    rdfs:comment 'Client\'s total net worth (assets minus liabilities), used to determine high-net-worth (HNW) or ultra-high-net-worth (UHNW) status and investment suitability.' ;
    rdfs:domain ind:SuitabilityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:restrictionsNotes rdf:type rdf:Property ;
    rdfs:label 'Restrictions Notes' ;
    rdfs:comment 'Textual notes documenting any investment restrictions, limitations, or special conditions identified during the suitability assessment (e.g., sector exclusions, leverage limits, concentration caps).' ;
    rdfs:domain ind:SuitabilityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskToleranceCategory rdf:type rdf:Property ;
    rdfs:label 'Risk Tolerance Category' ;
    rdfs:comment 'Categorical classification of the client\'s risk tolerance based on the risk tolerance score and qualitative assessment.' ;
    rdfs:domain ind:SuitabilityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskToleranceScore rdf:type rdf:Property ;
    rdfs:label 'Risk Tolerance Score' ;
    rdfs:comment 'Quantitative risk tolerance score derived from client questionnaire, typically on a scale of 0-100, indicating the client\'s willingness and capacity to accept investment risk.' ;
    rdfs:domain ind:SuitabilityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:suitabilityScore rdf:type rdf:Property ;
    rdfs:label 'Suitability Score' ;
    rdfs:comment 'Quantitative suitability score (0-100) indicating the degree of alignment between the client\'s profile and the proposed investment strategy or portfolio.' ;
    rdfs:domain ind:SuitabilityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:timeHorizonCategory rdf:type rdf:Property ;
    rdfs:label 'Time Horizon Category' ;
    rdfs:comment 'Categorical classification of the investment time horizon: short-term (0-3 years), medium-term (3-10 years), long-term (10+ years), or multi-generational (estate planning).' ;
    rdfs:domain ind:SuitabilityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activeClientCount rdf:type rdf:Property ;
    rdfs:label 'Active Client Count' ;
    rdfs:comment 'Current number of client accounts assigned to this model portfolio, used for capacity monitoring and performance reporting.' ;
    rdfs:domain ind:ModelPortfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:investmentPolicyStatementUrl rdf:type rdf:Property ;
    rdfs:label 'Investment Policy Statement Url' ;
    rdfs:comment 'URL reference to the formal Investment Policy Statement document governing this model portfolio construction and management.' ;
    rdfs:domain ind:ModelPortfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumInvestmentAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Investment Amount' ;
    rdfs:comment 'Minimum account value required for a client to be assigned to this model portfolio, ensuring adequate diversification and cost efficiency.' ;
    rdfs:domain ind:ModelPortfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modelCode rdf:type rdf:Property ;
    rdfs:label 'Model Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the model portfolio in operational systems and client reporting.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelPortfolioDescription rdf:type rdf:Property ;
    rdfs:label 'Model Portfolio Description' ;
    rdfs:comment 'Comprehensive business description of the model portfolio including investment philosophy, target outcomes, and key differentiators for client communication.' ;
    rdfs:domain ind:ModelPortfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rebalancingThresholdPercent rdf:type rdf:Property ;
    rdfs:label 'Rebalancing Threshold Percent' ;
    rdfs:comment 'Percentage drift threshold from target allocation that triggers a rebalancing event for any asset class within the model portfolio.' ;
    rdfs:domain ind:ModelPortfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retirementDate rdf:type rdf:Property ;
    rdfs:label 'Retirement Date' ;
    rdfs:comment 'Date on which this model portfolio version is retired and no longer available for new client assignments. Null if currently active.' ;
    rdfs:domain ind:ModelPortfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:strategicAllocationFlag rdf:type rdf:Property ;
    rdfs:label 'Strategic Allocation Flag' ;
    rdfs:comment 'Indicates whether this model portfolio uses strategic (long-term) asset allocation. True if strategic, False if tactical or dynamic allocation is primary.' ;
    rdfs:domain ind:ModelPortfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:suitabilityCriteria rdf:type rdf:Property ;
    rdfs:label 'Suitability Criteria' ;
    rdfs:comment 'Detailed description of client suitability requirements including risk tolerance, investment horizon, liquidity needs, and regulatory constraints.' ;
    rdfs:domain ind:ModelPortfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tacticalAllocationFlag rdf:type rdf:Property ;
    rdfs:label 'Tactical Allocation Flag' ;
    rdfs:comment 'Indicates whether this model portfolio incorporates tactical (short-term) asset allocation overlays to capitalize on market opportunities.' ;
    rdfs:domain ind:ModelPortfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetAum rdf:type rdf:Property ;
    rdfs:label 'Target Aum' ;
    rdfs:comment 'Target total assets under management for this model portfolio across all client accounts, used for capacity planning and investment committee oversight.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetClientSegment rdf:type rdf:Property ;
    rdfs:label 'Target Client Segment' ;
    rdfs:comment 'Primary client segment or wealth tier for which this model portfolio is designed, such as high-net-worth, ultra-high-net-worth, mass affluent, or institutional.' ;
    rdfs:domain ind:ModelPortfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxOptimizationStrategy rdf:type rdf:Property ;
    rdfs:label 'Tax Optimization Strategy' ;
    rdfs:comment 'Primary tax optimization approach employed in the model portfolio construction and rebalancing to minimize client tax liability.' ;
    rdfs:domain ind:ModelPortfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalAum rdf:type rdf:Property ;
    rdfs:label 'Total Aum' ;
    rdfs:comment 'Current total assets under management across all client accounts using this model portfolio, reported in base currency.' ;
    rdfs:domain ind:ModelPortfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingDepositAccountId rdf:type rdf:Property ;
    rdfs:label 'Billing Deposit Account Id' ;
    rdfs:comment 'Foreign key linking to account.deposit_account. Business justification: Wealth management fees are debited from client deposit accounts per fee schedule terms. Required for automated fee billing, payment processing, and revenue recognition in wealth advisory operations.' ;
    rdfs:domain ind:FeeSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DepositAccount .

ind:feeCurrencyId rdf:type rdf:Property ;
    rdfs:label 'Fee Currency Id' ;
    rdfs:comment 'Foreign key linking to reference.currency. Business justification: Regulatory fee disclosure (MiFID II cost and charges), FX conversion of fees, and billing system integration require fee currency as a proper reference entity. Role-prefixed \'fee_currency_id\' is appro' ;
    rdfs:domain ind:Wealth ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:aumBasisAmount rdf:type rdf:Property ;
    rdfs:label 'Aum Basis Amount' ;
    rdfs:comment 'The total Assets Under Management value used as the basis for fee calculation in this billing period. May be average daily balance, beginning balance, or ending balance depending on agreement terms.' ;
    rdfs:domain ind:Wealth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:aumCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Aum Calculation Method' ;
    rdfs:comment 'The method used to determine the AUM basis for fee calculation. Average daily is most precise; beginning or ending balance is simpler but less accurate during volatile periods.' ;
    rdfs:domain ind:FeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingFrequency rdf:type rdf:Property ;
    rdfs:label 'Billing Frequency' ;
    rdfs:comment 'The cadence at which fees are calculated and billed to the client. Monthly and quarterly are most common for management fees; performance fees are typically annual or semi-annual.' ;
    rdfs:domain ind:FeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingInAdvanceFlag rdf:type rdf:Property ;
    rdfs:label 'Billing In Advance Flag' ;
    rdfs:comment 'Indicates whether fees are billed at the beginning (true) or end (false) of the billing period. Management fees are commonly billed in advance; performance fees are billed in arrears.' ;
    rdfs:domain ind:FeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Billing Period End Date' ;
    rdfs:comment 'The end date of the billing period for which fees are being calculated. Used in billing execution records.' ;
    rdfs:domain ind:Wealth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Billing Period Start Date' ;
    rdfs:comment 'The start date of the billing period for which fees are being calculated. Used in billing execution records.' ;
    rdfs:domain ind:Wealth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingStatus rdf:type rdf:Property ;
    rdfs:label 'Billing Status' ;
    rdfs:comment 'Current lifecycle status of the fee billing record. Tracks progression from calculation through payment or resolution. [ENUM-REF-CANDIDATE: draft|calculated|invoiced|paid|overdue|waived|disputed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Wealth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeRate rdf:type rdf:Property ;
    rdfs:label 'Fee Rate' ;
    rdfs:comment 'The percentage rate or basis points (BPS) applied to the fee basis. For AUM-based fees, this is typically expressed as an annual percentage (e.g., 1.00% = 0.010000). For tiered schedules, this represents the rate for the current tier.' ;
    rdfs:domain ind:FeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feeWaiverAmount rdf:type rdf:Property ;
    rdfs:label 'Fee Waiver Amount' ;
    rdfs:comment 'The amount of fee waived or discounted for this billing period. May result from promotional arrangements, relationship pricing, or service level adjustments.' ;
    rdfs:domain ind:FeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:flatFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Flat Fee Amount' ;
    rdfs:comment 'Fixed fee amount charged when fee_basis is flat. Null for percentage-based or tiered fee structures.' ;
    rdfs:domain ind:FeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:glPostingReference rdf:type rdf:Property ;
    rdfs:label 'Gl Posting Reference' ;
    rdfs:comment 'Reference to the general ledger journal entry or posting batch that recorded this fee revenue. Supports financial reconciliation and audit trail.' ;
    rdfs:domain ind:FeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Fee Amount' ;
    rdfs:comment 'The total fee amount calculated before any waivers, discounts, or tax withholding. Represents the contractual fee per the schedule.' ;
    rdfs:domain ind:Wealth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Invoice Reference Number' ;
    rdfs:comment 'The unique invoice number generated for this fee billing. Used for client communication, payment tracking, and reconciliation.' ;
    rdfs:domain ind:FeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:negotiatedDiscountPercentage rdf:type rdf:Property ;
    rdfs:label 'Negotiated Discount Percentage' ;
    rdfs:comment 'Permanent discount percentage negotiated with the client, applied to the standard fee rate. Common for UHNW clients or large institutional mandates.' ;
    rdfs:domain ind:FeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceHurdleRate rdf:type rdf:Property ;
    rdfs:label 'Performance Hurdle Rate' ;
    rdfs:comment 'The minimum return threshold that must be exceeded before performance fees are charged. Expressed as an annual percentage. Null for non-performance-based fees.' ;
    rdfs:domain ind:FeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryDisclosureFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Disclosure Flag' ;
    rdfs:comment 'Indicates whether this fee must be disclosed in regulatory filings such as Form ADV Part 2 (SEC) or MIFID II cost disclosures (EU). True for material fees subject to disclosure requirements.' ;
    rdfs:domain ind:FeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxWithholdingAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Withholding Amount' ;
    rdfs:comment 'The amount of tax withheld from the fee payment, if applicable. Relevant for cross-border mandates subject to withholding tax treaties.' ;
    rdfs:domain ind:Wealth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tierLowerBound rdf:type rdf:Property ;
    rdfs:label 'Tier Lower Bound' ;
    rdfs:comment 'The minimum AUM threshold for this fee tier. Used in tiered fee structures where different rates apply to different asset levels. Null for non-tiered fee schedules.' ;
    rdfs:domain ind:FeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tierUpperBound rdf:type rdf:Property ;
    rdfs:label 'Tier Upper Bound' ;
    rdfs:comment 'The maximum AUM threshold for this fee tier. Null indicates no upper limit (top tier). Used in tiered fee structures.' ;
    rdfs:domain ind:FeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feeBillingId rdf:type rdf:Property ;
    rdfs:label 'Fee Billing Id' ;
    rdfs:comment 'Unique identifier for the fee billing record. Primary key for the fee billing entity.' ;
    rdfs:domain ind:FeeBilling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billingChannelId rdf:type rdf:Property ;
    rdfs:label 'Billing Channel Id' ;
    rdfs:comment 'Foreign key linking to channel.channel. Business justification: Fee invoices delivered through client-preferred channels (email, postal mail, digital portal). Required for client preference fulfillment, delivery confirmation tracking, dispute resolution (proof of ' ;
    rdfs:domain ind:FeeBilling ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:paymentDepositAccountId rdf:type rdf:Property ;
    rdfs:label 'Payment Deposit Account Id' ;
    rdfs:comment 'Foreign key linking to account.deposit_account. Business justification: Fee billing invoices are settled via deposit account debits. Essential for fee collection automation, payment reconciliation, and accounts receivable management in wealth management operations.' ;
    rdfs:domain ind:FeeBilling ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DepositAccount .

ind:aumCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Aum Currency Code' ;
    rdfs:comment 'The three-letter ISO 4217 currency code for the AUM basis amount. Typically USD, EUR, GBP, or CHF for wealth management clients.' ;
    rdfs:domain ind:FeeBilling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeReason rdf:type rdf:Property ;
    rdfs:label 'Dispute Reason' ;
    rdfs:comment 'Free-text explanation of why the client disputed the fee billing. Examples include \'AUM calculation discrepancy\', \'Fee rate incorrect\', \'Performance calculation error\', or \'Unauthorized charge\'. Populated when billing status is disputed.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeDiscountAmount rdf:type rdf:Property ;
    rdfs:label 'Fee Discount Amount' ;
    rdfs:comment 'Any discount or reduction applied to the gross fee amount. May result from promotional offers, relationship pricing, fee waivers for underperformance, or negotiated concessions for high-net-worth clients.' ;
    rdfs:domain ind:FeeBilling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:omnibusParentAccountId rdf:type rdf:Property ;
    rdfs:label 'Omnibus Parent Account Id' ;
    rdfs:comment 'Reference to the parent omnibus custodian account if this account is a sub-account within a pooled structure. Null for standalone or top-level accounts.' ;
    rdfs:domain ind:CustodianAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustodianAccount .

ind:primarySubCustodianInstitutionPartyId rdf:type rdf:Property ;
    rdfs:label 'Primary Sub Custodian Institution Party Id' ;
    rdfs:comment 'Reference to a sub-custodian institution in the custody chain, used when the primary custodian delegates safekeeping to a local custodian in specific markets (common for emerging markets and cross-border holdings).' ;
    rdfs:domain ind:CustodianAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:settlementPaymentChannelId rdf:type rdf:Property ;
    rdfs:label 'Settlement Payment Channel Id' ;
    rdfs:comment 'Foreign key linking to payment.payment_channel. Business justification: Custodian accounts use designated payment channels (SWIFT, CHAPS, Fedwire) for settlement instructions. Linking custodian_account to payment_channel enables settlement routing configuration, SLA manag' ;
    rdfs:domain ind:CustodianAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentChannel .

ind:accountOpeningDocumentationComplete rdf:type rdf:Property ;
    rdfs:label 'Account Opening Documentation Complete' ;
    rdfs:comment 'Boolean flag indicating whether all required account opening documentation (KYC, service agreements, authorized signatory forms) has been completed and verified.' ;
    rdfs:domain ind:CustodianAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:authorizedSignatoryList rdf:type rdf:Property ;
    rdfs:label 'Authorized Signatory List' ;
    rdfs:comment 'Comma-separated list or reference to individuals authorized to issue instructions on this custodian account. Critical for operational control and audit trail.' ;
    rdfs:domain ind:CustodianAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cassClassification rdf:type rdf:Property ;
    rdfs:label 'Cass Classification' ;
    rdfs:comment 'FCA CASS classification for UK-regulated accounts: CASS 5 (designated investment business), CASS 6 (custody assets), CASS 7 (client money), or not_applicable for non-UK accounts.' ;
    rdfs:domain ind:CustodianAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collateralManagementEnabled rdf:type rdf:Property ;
    rdfs:label 'Collateral Management Enabled' ;
    rdfs:comment 'Boolean flag indicating whether this custodian account is used for collateral management purposes, including posting and receiving collateral for derivatives and securities financing transactions.' ;
    rdfs:domain ind:CustodianAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:corporateActionElectionMethod rdf:type rdf:Property ;
    rdfs:label 'Corporate Action Election Method' ;
    rdfs:comment 'Defines how corporate action elections (dividends, rights issues, tender offers) are handled for securities held in this account: automatic (pre-defined rules), manual (case-by-case instruction), or custodian_discretion (custodian decides per standing instructions).' ;
    rdfs:domain ind:CustodianAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:custodianAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Custodian Account Number' ;
    rdfs:comment 'The external account number assigned by the custodian institution for this custody relationship. Used for trade settlement instructions and reconciliation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:custodianContactEmail rdf:type rdf:Property ;
    rdfs:label 'Custodian Contact Email' ;
    rdfs:comment 'Email address of the primary custodian contact for operational inquiries and settlement instructions.' ;
    rdfs:domain ind:CustodianAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:custodianContactName rdf:type rdf:Property ;
    rdfs:label 'Custodian Contact Name' ;
    rdfs:comment 'Name of the primary relationship manager or operations contact at the custodian institution for this account.' ;
    rdfs:domain ind:CustodianAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:custodianContactPhone rdf:type rdf:Property ;
    rdfs:label 'Custodian Contact Phone' ;
    rdfs:comment 'Phone number of the primary custodian contact for urgent operational matters and settlement issues.' ;
    rdfs:domain ind:CustodianAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReconciliationDate rdf:type rdf:Property ;
    rdfs:label 'Last Reconciliation Date' ;
    rdfs:comment 'The most recent date on which holdings and cash balances in this custodian account were reconciled against internal portfolio records. Critical for operational risk management and audit.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:marginLendingEnabled rdf:type rdf:Property ;
    rdfs:label 'Margin Lending Enabled' ;
    rdfs:comment 'Boolean flag indicating whether this custodian account supports margin lending and leveraged positions.' ;
    rdfs:domain ind:CustodianAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryReportingJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Jurisdiction' ;
    rdfs:comment 'Three-letter ISO country code indicating the primary regulatory jurisdiction for reporting requirements applicable to this custodian account (e.g., USA for SEC, GBR for FCA).' ;
    rdfs:domain ind:CustodianAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securitiesLendingEnabled rdf:type rdf:Property ;
    rdfs:label 'Securities Lending Enabled' ;
    rdfs:comment 'Boolean flag indicating whether securities held in this custodian account are eligible for securities lending programs to generate additional revenue.' ;
    rdfs:domain ind:CustodianAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:segregationRequirement rdf:type rdf:Property ;
    rdfs:label 'Segregation Requirement' ;
    rdfs:comment 'Regulatory or contractual requirement for asset segregation: client_segregated (individual client assets held separately per CASS/SEC 15c3-3), pooled (omnibus account), or partially_segregated (hybrid model).' ;
    rdfs:domain ind:CustodianAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementInstructionMethod rdf:type rdf:Property ;
    rdfs:label 'Settlement Instruction Method' ;
    rdfs:comment 'The primary method used to transmit settlement instructions to the custodian: SWIFT messaging, fax, electronic portal, API integration, or manual delivery.' ;
    rdfs:domain ind:CustodianAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subCustodianAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Sub Custodian Account Number' ;
    rdfs:comment 'The account number at the sub-custodian institution, if applicable. Used for tracking the full custody chain and reconciliation across multiple custodian layers.' ;
    rdfs:domain ind:CustodianAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acquisitionPriceId rdf:type rdf:Property ;
    rdfs:label 'Acquisition Price Id' ;
    rdfs:comment 'Foreign key linking to security.price. Business justification: IRS cost basis reporting (Form 1099-B), FATCA/CRS tax reporting, and wash sale calculations require linking each tax lot to the authoritative price record at acquisition. Role-prefix \'acquisition_\' id' ;
    rdfs:domain ind:TaxLot ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Price .

ind:washSaleReferenceLotId rdf:type rdf:Property ;
    rdfs:label 'Wash Sale Reference Lot Id' ;
    rdfs:comment 'Reference to the replacement tax lot that triggered the wash sale rule.' ;
    rdfs:domain ind:TaxLot ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TaxLot .

ind:accruedIncomeAmount rdf:type rdf:Property ;
    rdfs:label 'Accrued Income Amount' ;
    rdfs:comment 'Accrued interest or dividend income included in the acquisition cost for fixed income or dividend-bearing securities.' ;
    rdfs:domain ind:TaxLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acquisitionPrice rdf:type rdf:Property ;
    rdfs:label 'Acquisition Price' ;
    rdfs:comment 'Price per unit at which the security was acquired.' ;
    rdfs:domain ind:TaxLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adjustedCostBasisAmount rdf:type rdf:Property ;
    rdfs:label 'Adjusted Cost Basis Amount' ;
    rdfs:comment 'Cost basis after adjustments for corporate actions, return of capital, or other events.' ;
    rdfs:domain ind:TaxLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commissionFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Commission Fee Amount' ;
    rdfs:comment 'Commission and transaction fees included in the cost basis of the tax lot.' ;
    rdfs:domain ind:TaxLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:corporateActionAdjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Corporate Action Adjustment Amount' ;
    rdfs:comment 'Total adjustments to cost basis resulting from corporate actions such as stock splits, mergers, spin-offs, or return of capital.' ;
    rdfs:domain ind:TaxLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costBasisAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Basis Amount' ;
    rdfs:comment 'Total cost basis for the tax lot, including acquisition cost and any adjustments.' ;
    rdfs:domain ind:TaxLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentMarketValue rdf:type rdf:Property ;
    rdfs:label 'Current Market Value' ;
    rdfs:comment 'Current market value of the tax lot based on latest available pricing.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disposalDate rdf:type rdf:Property ;
    rdfs:label 'Disposal Date' ;
    rdfs:comment 'Date when the tax lot was fully or partially disposed of through a sale or other transaction.' ;
    rdfs:domain ind:TaxLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disposalPrice rdf:type rdf:Property ;
    rdfs:label 'Disposal Price' ;
    rdfs:comment 'Price per unit at which the security was disposed of or sold.' ;
    rdfs:domain ind:TaxLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:donorCostBasisAmount rdf:type rdf:Property ;
    rdfs:label 'Donor Cost Basis Amount' ;
    rdfs:comment 'Original cost basis from the donor for gifted securities, used to determine gain or loss upon disposal.' ;
    rdfs:domain ind:TaxLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fairMarketValueAtGiftDate rdf:type rdf:Property ;
    rdfs:label 'Fair Market Value At Gift Date' ;
    rdfs:comment 'Fair market value of the security on the date of gift, used for determining loss basis if lower than donor cost basis.' ;
    rdfs:domain ind:TaxLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:giftInheritanceFlag rdf:type rdf:Property ;
    rdfs:label 'Gift Inheritance Flag' ;
    rdfs:comment 'Indicates whether this lot was acquired through gift or inheritance, which has special cost basis rules.' ;
    rdfs:domain ind:TaxLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lotNumber rdf:type rdf:Property ;
    rdfs:label 'Lot Number' ;
    rdfs:comment 'Business identifier for the tax lot, typically assigned by the portfolio management system.' ;
    rdfs:domain ind:TaxLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotType rdf:type rdf:Property ;
    rdfs:label 'Lot Type' ;
    rdfs:comment 'Type or origin of the tax lot acquisition. [ENUM-REF-CANDIDATE: purchase|dividend_reinvestment|stock_split|merger|spin_off|return_of_capital|gift|inheritance|transfer_in — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TaxLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noncoveredSecurityFlag rdf:type rdf:Property ;
    rdfs:label 'Noncovered Security Flag' ;
    rdfs:comment 'Indicates whether the security is noncovered for IRS Form 1099-B reporting purposes, meaning cost basis reporting is not required by the custodian.' ;
    rdfs:domain ind:TaxLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originalQuantity rdf:type rdf:Property ;
    rdfs:label 'Original Quantity' ;
    rdfs:comment 'Original number of units or shares when the lot was first acquired, before any partial sales or adjustments.' ;
    rdfs:domain ind:TaxLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:realizedGainLossAmount rdf:type rdf:Property ;
    rdfs:label 'Realized Gain Loss Amount' ;
    rdfs:comment 'Realized gain or loss from disposal of the tax lot, calculated as proceeds minus adjusted cost basis.' ;
    rdfs:domain ind:TaxLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportingCategory rdf:type rdf:Property ;
    rdfs:label 'Reporting Category' ;
    rdfs:comment 'IRS tax form category for reporting this tax lot.' ;
    rdfs:domain ind:TaxLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificIdentificationFlag rdf:type rdf:Property ;
    rdfs:label 'Specific Identification Flag' ;
    rdfs:comment 'Indicates whether this lot was specifically identified by the client or advisor for disposal, overriding the default cost basis method.' ;
    rdfs:domain ind:TaxLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxLossHarvestingCandidateFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Loss Harvesting Candidate Flag' ;
    rdfs:comment 'Indicates whether this lot is a candidate for tax-loss harvesting strategy based on unrealized losses and holding period.' ;
    rdfs:domain ind:TaxLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxTreatmentCode rdf:type rdf:Property ;
    rdfs:label 'Tax Treatment Code' ;
    rdfs:comment 'Tax treatment classification for this lot based on account type and security characteristics.' ;
    rdfs:domain ind:Wealth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unrealizedGainLossAmount rdf:type rdf:Property ;
    rdfs:label 'Unrealized Gain Loss Amount' ;
    rdfs:comment 'Unrealized gain or loss calculated as current market value minus adjusted cost basis. Positive values indicate gains, negative values indicate losses.' ;
    rdfs:domain ind:TaxLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:washSaleDisallowedLossAmount rdf:type rdf:Property ;
    rdfs:label 'Wash Sale Disallowed Loss Amount' ;
    rdfs:comment 'Amount of loss disallowed due to wash sale rules, which must be added to the cost basis of the replacement security.' ;
    rdfs:domain ind:TaxLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accountCurrencyId rdf:type rdf:Property ;
    rdfs:label 'Account Currency Id' ;
    rdfs:comment 'Foreign key linking to reference.currency. Business justification: Chart of accounts must specify native currency for each account to support multi-currency GL operations, currency-specific reporting, and FX revaluation processes required in global banking operations' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:accountCode rdf:type rdf:Property ;
    rdfs:label 'Account Code' ;
    rdfs:comment 'The unique alphanumeric code identifying the general ledger account. This is the externally-known business identifier used in all journal entries and financial reports. Typically follows a hierarchical numbering scheme (e.g., 1000-1999 for assets, 2000-2999 for liabilities).' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountDescription rdf:type rdf:Property ;
    rdfs:label 'Account Description' ;
    rdfs:comment 'A detailed description of the purpose, usage guidelines, and business rules for this account. Provides additional context beyond the account name for users posting journal entries and for auditors reviewing account activity.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountLevel rdf:type rdf:Property ;
    rdfs:label 'Account Level' ;
    rdfs:comment 'The level of this account in the chart of accounts hierarchy (e.g., 1 for top-level summary accounts, 2 for sub-categories, 3 for detail accounts). Used for drill-down reporting and financial statement presentation at different levels of detail.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountName rdf:type rdf:Property ;
    rdfs:label 'Account Name' ;
    rdfs:comment 'The full descriptive name of the general ledger account (e.g., \'Cash and Cash Equivalents\', \'Accounts Receivable - Trade\', \'Interest Income on Loans\'). This is the human-readable label used in financial statements and reports.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountSubtype rdf:type rdf:Property ;
    rdfs:label 'Account Subtype' ;
    rdfs:comment 'A more granular classification within the account type (e.g., \'current asset\', \'fixed asset\', \'current liability\', \'long-term liability\', \'operating revenue\', \'non-operating revenue\', \'operating expense\', \'non-operating expense\'). Used for detailed financial statement presentation and analysis.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alternateAccountCode rdf:type rdf:Property ;
    rdfs:label 'Alternate Account Code' ;
    rdfs:comment 'An alternate or legacy account code used for cross-reference purposes during system migrations, mergers and acquisitions (M&A), or for mapping to external reporting frameworks. Allows historical data to be linked to the current chart of accounts structure.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationGroup rdf:type rdf:Property ;
    rdfs:label 'Consolidation Group' ;
    rdfs:comment 'The consolidation grouping code used for multi-entity financial consolidation and elimination of intercompany transactions. Identifies which legal entities or business units this account applies to and how it should be treated in consolidated financial statements.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialStatementCategory rdf:type rdf:Property ;
    rdfs:label 'Financial Statement Category' ;
    rdfs:comment 'Identifies the primary financial statement where this account is reported (balance sheet for assets/liabilities/equity, income statement for revenue/expenses, cash flow statement for cash movements, statement of changes in equity for equity movements).' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialStatementLineItem rdf:type rdf:Property ;
    rdfs:label 'Financial Statement Line Item' ;
    rdfs:comment 'The specific line item or caption on the financial statement where this account balance is aggregated and presented (e.g., \'Cash and Cash Equivalents\', \'Property Plant and Equipment\', \'Interest Income\', \'Salaries and Benefits\'). Maps the detailed GL account to the published financial statement presentation.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalArea rdf:type rdf:Property ;
    rdfs:label 'Functional Area' ;
    rdfs:comment 'The functional area or business process this account supports (e.g., \'Commercial Lending\', \'Investment Banking\', \'Treasury\', \'Risk Management\', \'Operations\', \'Technology\'). Used for functional cost allocation and activity-based costing.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ifrsClassification rdf:type rdf:Property ;
    rdfs:label 'Ifrs Classification' ;
    rdfs:comment 'The classification of this account under IFRS accounting standards, including specific IAS/IFRS standard references where applicable (e.g., \'IAS 16 - Property Plant and Equipment\', \'IFRS 9 - Financial Instruments\', \'IFRS 15 - Revenue from Contracts with Customers\'). Used for international statutory reporting and consolidation.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intercompanyFlag rdf:type rdf:Property ;
    rdfs:label 'Intercompany Flag' ;
    rdfs:comment 'Indicates whether this account is used for intercompany transactions between legal entities within the consolidated group. Intercompany accounts are subject to elimination entries during financial consolidation to remove intra-group transactions.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:normalBalance rdf:type rdf:Property ;
    rdfs:label 'Normal Balance' ;
    rdfs:comment 'Indicates whether the account normally carries a debit or credit balance. Asset and expense accounts have debit normal balances; liability, equity, and revenue accounts have credit normal balances. Used for validation of journal entries and trial balance preparation.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentAccountCode rdf:type rdf:Property ;
    rdfs:label 'Parent Account Code' ;
    rdfs:comment 'The account code of the parent account in a hierarchical chart of accounts structure. Used for roll-up reporting and financial statement aggregation. Null for top-level accounts.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Posting Allowed Flag' ;
    rdfs:comment 'Indicates whether direct manual journal entries are allowed to this account, or whether it is a control/summary account that only receives automated postings from subledgers. Control accounts typically have this flag set to false to prevent manual posting errors.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reconciliationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Required Flag' ;
    rdfs:comment 'Indicates whether this account requires periodic reconciliation to external statements or subledger systems (e.g., bank statements, loan subledger, securities positions). Accounts flagged for reconciliation are subject to monthly close procedures and variance investigation.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riskWeightedAssetCategory rdf:type rdf:Property ;
    rdfs:label 'Risk Weighted Asset Category' ;
    rdfs:comment 'The Basel III risk-weighted asset category for this account, used in capital adequacy calculations (e.g., \'credit risk - corporate exposures\', \'credit risk - retail exposures\', \'market risk\', \'operational risk\'). Determines the risk weighting applied for Common Equity Tier 1 (CET1) ratio calculations.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxControlFlag rdf:type rdf:Property ;
    rdfs:label 'Sox Control Flag' ;
    rdfs:comment 'Indicates whether this account is subject to Sarbanes-Oxley Act (SOX) internal control testing and documentation requirements. Accounts flagged as SOX-controlled require additional review, approval workflows, and audit trail documentation for all journal entries.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:statisticalAccountFlag rdf:type rdf:Property ;
    rdfs:label 'Statistical Account Flag' ;
    rdfs:comment 'Indicates whether this is a statistical (non-monetary) account used to track quantities, headcount, or other non-financial metrics for management reporting and ratio analysis (e.g., number of employees, number of accounts, transaction volumes). Statistical accounts do not appear in financial statements but support KPI calculations.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxLineMapping rdf:type rdf:Property ;
    rdfs:label 'Tax Line Mapping' ;
    rdfs:comment 'The mapping of this account to specific lines on corporate tax returns (e.g., IRS Form 1120 line references, state tax return schedules). Used for tax provision calculation, deferred tax accounting, and tax compliance reporting.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentAccountGlAccountId rdf:type rdf:Property ;
    rdfs:label 'Parent Account Gl Account Id' ;
    rdfs:comment 'Reference to the parent account in the account hierarchy. Enables roll-up reporting and hierarchical financial analysis.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:accountCategory rdf:type rdf:Property ;
    rdfs:label 'Account Category' ;
    rdfs:comment 'Sub-classification within the account type (e.g., current asset, fixed asset, operating expense, cost of goods sold). Used for financial statement line item grouping and regulatory reporting.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountHierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Account Hierarchy Level' ;
    rdfs:comment 'The level of this account in the chart of accounts hierarchy (1=top level, increasing for detail accounts). Used for reporting aggregation and drill-down.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountSubcategory rdf:type rdf:Property ;
    rdfs:label 'Account Subcategory' ;
    rdfs:comment 'Granular classification within the account category for detailed financial analysis and management reporting (e.g., trade receivables, employee receivables, intercompany receivables).' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetControlFlag rdf:type rdf:Property ;
    rdfs:label 'Budget Control Flag' ;
    rdfs:comment 'Indicates whether postings to this account are subject to budget availability checking. Prevents overspending and enforces fiscal discipline.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:materialityThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Materiality Threshold Amount' ;
    rdfs:comment 'The monetary threshold above which variances or adjustments to this account require additional review or approval. Used for risk-based controls and audit scoping.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:naturalBalance rdf:type rdf:Property ;
    rdfs:label 'Natural Balance' ;
    rdfs:comment 'The normal balance side for this account: debit for assets and expenses, credit for liabilities, equity, and revenue. Used for balance validation and error detection.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationFrequency rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Frequency' ;
    rdfs:comment 'The required frequency for account reconciliation: daily for high-volume transaction accounts, monthly for standard accounts, quarterly for low-activity accounts.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revaluationFlag rdf:type rdf:Property ;
    rdfs:label 'Revaluation Flag' ;
    rdfs:comment 'Indicates whether this account is subject to foreign exchange revaluation or fair value remeasurement at period end. Applies to foreign currency accounts and financial instruments.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxAccountFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Account Flag' ;
    rdfs:comment 'Indicates whether this account is used for tax-related transactions (VAT, sales tax, withholding tax). Subject to specific tax reporting and compliance requirements.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:thirdPartyControlFlag rdf:type rdf:Property ;
    rdfs:label 'Third Party Control Flag' ;
    rdfs:comment 'Indicates whether this account is a control account for a subledger (AP, AR, fixed assets). Balance must reconcile to subledger detail.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryJournalLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Primary Journal Legal Entity Id' ;
    rdfs:comment 'Reference to the legal entity (subsidiary, branch, operating company) to which this journal entry belongs for consolidation and statutory reporting.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:reversedJournalEntryId rdf:type rdf:Property ;
    rdfs:label 'Reversed Journal Entry Id' ;
    rdfs:comment 'Reference to the original journal entry that this entry reverses, establishing the reversal relationship for audit trail. Null if not a reversal.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntry .

ind:adjustmentIndicator rdf:type rdf:Property ;
    rdfs:label 'Adjustment Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this journal entry is a period-end or year-end adjustment (true) or a regular operational entry (false), supporting financial close process tracking.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approverName rdf:type rdf:Property ;
    rdfs:label 'Approver Name' ;
    rdfs:comment 'Full name of the user who approved the journal entry, for audit trail and accountability.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchName rdf:type rdf:Property ;
    rdfs:label 'Batch Name' ;
    rdfs:comment 'Descriptive name of the batch or import run that created this journal entry, for operational tracking and troubleshooting.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Functional Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter code for the functional currency of the legal entity, used for currency translation and consolidation.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalTotalCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Functional Total Credit Amount' ;
    rdfs:comment 'Total credit amount translated into the functional currency of the legal entity using the applicable exchange rate at accounting date.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:functionalTotalDebitAmount rdf:type rdf:Property ;
    rdfs:label 'Functional Total Debit Amount' ;
    rdfs:comment 'Total debit amount translated into the functional currency of the legal entity using the applicable exchange rate at accounting date.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:intercompanyIndicator rdf:type rdf:Property ;
    rdfs:label 'Intercompany Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this journal entry represents an intercompany transaction requiring elimination during consolidation (true) or is a single-entity transaction (false).' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:journalCategory rdf:type rdf:Property ;
    rdfs:label 'Journal Category' ;
    rdfs:comment 'User-defined or system-assigned category for grouping and reporting journal entries (e.g., payroll, depreciation, revenue recognition, tax provision, consolidation).' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:journalEntryDescription rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Description' ;
    rdfs:comment 'Free-text narrative description of the business purpose and nature of the journal entry, supporting audit trail and user understanding.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:journalNumber rdf:type rdf:Property ;
    rdfs:label 'Journal Number' ;
    rdfs:comment 'Business-facing unique journal entry number assigned by the GL system or user, used for external reference and audit trail.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:journalSource rdf:type rdf:Property ;
    rdfs:label 'Journal Source' ;
    rdfs:comment 'Origin or type of journal entry indicating how it was created: manual entry by user, automated posting from subledger (AP/AR/FA), intercompany elimination, period-end accrual, foreign exchange or fair value revaluation, reversal of prior entry, recurring template-based entry, account reclassification, top-side consolidation adjustment, or statistical (non-monetary) entry. [ENUM-REF-CANDIDATE: manual|subledger|intercompany|accrual|revaluation|reversal|recurring|reclassification|top_side_adjustment|statistical — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingStatus rdf:type rdf:Property ;
    rdfs:label 'Posting Status' ;
    rdfs:comment 'Current posting status of the journal entry in the general ledger: unposted (not yet affecting GL balances), posted (committed to GL), reversed (original entry reversed by a subsequent entry), or voided (cancelled before posting).' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preparerName rdf:type rdf:Property ;
    rdfs:label 'Preparer Name' ;
    rdfs:comment 'Full name of the user who prepared the journal entry, for audit trail and accountability.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalIndicator rdf:type rdf:Property ;
    rdfs:label 'Reversal Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this journal entry is a reversal of a prior entry (true) or an original entry (false).' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:soxControlReference rdf:type rdf:Property ;
    rdfs:label 'Sox Control Reference' ;
    rdfs:comment 'Reference code or identifier linking this journal entry to the applicable SOX internal control (e.g., control ID for manual journal entry review, approval workflow, or segregation of duties), supporting Section 302 and 404 compliance.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statisticalIndicator rdf:type rdf:Property ;
    rdfs:label 'Statistical Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this journal entry is statistical (non-monetary, used for ratio calculations and management reporting) rather than a financial accounting entry.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:subledgerSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Subledger Source System' ;
    rdfs:comment 'Name or code of the upstream subledger system (AP, AR, FA, Payroll, etc.) that originated this journal entry, supporting data lineage and reconciliation.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subledgerTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Subledger Transaction Reference' ;
    rdfs:comment 'Unique transaction identifier from the source subledger system, enabling drill-back and reconciliation between GL and subledger.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Total Credit Amount' ;
    rdfs:comment 'Sum of all credit line amounts in the journal entry, expressed in the entry currency. Must equal total_debit_amount for a balanced entry.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDebitAmount rdf:type rdf:Property ;
    rdfs:label 'Total Debit Amount' ;
    rdfs:comment 'Sum of all debit line amounts in the journal entry, expressed in the entry currency. Must equal total_credit_amount for a balanced entry.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:journalEntryLineId rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Line Id' ;
    rdfs:comment 'Unique identifier for the journal entry line. Primary key for atomic GL postings.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bankingChannelId rdf:type rdf:Property ;
    rdfs:label 'Banking Channel Id' ;
    rdfs:comment 'Foreign key linking to channel.channel. Business justification: GL entries must track originating channel for regulatory reporting (CTR/SAR filings require channel identification), channel profitability analysis, and transaction source attribution. Standard in ret' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:enteredCurrencyId rdf:type rdf:Property ;
    rdfs:label 'Entered Currency Id' ;
    rdfs:comment 'Foreign key linking to reference.currency. Business justification: Individual journal lines may be entered in currencies different from header; this link supports multi-currency transaction processing, line-level FX calculation, and detailed currency reporting in ban' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:reversedLineJournalEntryLineId rdf:type rdf:Property ;
    rdfs:label 'Reversed Line Journal Entry Line Id' ;
    rdfs:comment 'Reference to the original journal entry line being reversed. Maintains audit trail for reversing entries.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntryLine .

ind:adjustmentType rdf:type rdf:Property ;
    rdfs:label 'Adjustment Type' ;
    rdfs:comment 'Type of accounting adjustment represented by this line. Supports financial close analytics and SOX control testing. [ENUM-REF-CANDIDATE: standard|accrual|reclassification|elimination|revaluation|provision|none — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessSegmentCode rdf:type rdf:Property ;
    rdfs:label 'Business Segment Code' ;
    rdfs:comment 'Business segment or division code for segment reporting. Supports IFRS 8 and regulatory segment disclosures.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Amount' ;
    rdfs:comment 'Credit amount in functional currency. Represents increases to liability, equity, and revenue accounts or decreases to asset and expense accounts.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:debitAmount rdf:type rdf:Property ;
    rdfs:label 'Debit Amount' ;
    rdfs:comment 'Debit amount in functional currency. Represents increases to asset and expense accounts or decreases to liability, equity, and revenue accounts.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enteredAmount rdf:type rdf:Property ;
    rdfs:label 'Entered Amount' ;
    rdfs:comment 'Transaction amount in the original entered currency before conversion to functional currency. Supports multi-currency operations and FX analysis.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exchangeRateType rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate Type' ;
    rdfs:comment 'Type of exchange rate used for currency conversion. Supports different rate types for various accounting treatments.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYear rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year' ;
    rdfs:comment 'Fiscal year to which this posting belongs. Supports annual financial reporting and multi-year analysis.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:intercompanyEntityCode rdf:type rdf:Property ;
    rdfs:label 'Intercompany Entity Code' ;
    rdfs:comment 'Legal entity or intercompany counterparty code for consolidation and intercompany eliminations. Critical for group-level IFRS/GAAP consolidation.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineDescription rdf:type rdf:Property ;
    rdfs:label 'Line Description' ;
    rdfs:comment 'Detailed description of the journal entry line. Provides business context and audit trail for the posting.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineNumber rdf:type rdf:Property ;
    rdfs:label 'Line Number' ;
    rdfs:comment 'Sequential line number within the journal entry. Establishes ordering for audit trail and display purposes.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:projectCode rdf:type rdf:Property ;
    rdfs:label 'Project Code' ;
    rdfs:comment 'Project or initiative code for capital expenditure tracking and project accounting. Supports investment banking deal tracking and infrastructure projects.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statisticalAmount rdf:type rdf:Property ;
    rdfs:label 'Statistical Amount' ;
    rdfs:comment 'Non-monetary statistical amount for allocation or reporting purposes. Supports headcount, square footage, or other allocation bases.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:statisticalUnit rdf:type rdf:Property ;
    rdfs:label 'Statistical Unit' ;
    rdfs:comment 'Unit of measure for the statistical amount. Examples include headcount, square meters, or transaction count.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subledgerType rdf:type rdf:Property ;
    rdfs:label 'Subledger Type' ;
    rdfs:comment 'Type of subledger that originated this posting. Links GL to operational systems such as AP, AR, loan origination, or trading platforms. [ENUM-REF-CANDIDATE: accounts_payable|accounts_receivable|fixed_assets|cash_management|loan|deposit|securities|none — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCode rdf:type rdf:Property ;
    rdfs:label 'Tax Code' ;
    rdfs:comment 'Tax code for VAT, GST, or other tax treatment. Supports tax reporting and compliance with FATCA and CRS requirements.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountingPeriodDescription rdf:type rdf:Property ;
    rdfs:label 'Accounting Period Description' ;
    rdfs:comment 'Free-text description or notes about the accounting period. May include special instructions, closing notes, or period-specific context.' ;
    rdfs:domain ind:AccountingPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentPeriodFlag rdf:type rdf:Property ;
    rdfs:label 'Adjustment Period Flag' ;
    rdfs:comment 'Indicates whether this is an adjustment period (True) or a standard operating period (False). Adjustment periods (e.g., Period 13, Period 14) are used for year-end closing entries and do not correspond to calendar months.' ;
    rdfs:domain ind:AccountingPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:budgetPeriodFlag rdf:type rdf:Property ;
    rdfs:label 'Budget Period Flag' ;
    rdfs:comment 'Indicates whether this period is used for budgeting and planning (True) or is actuals-only (False). Supports budget vs. actual variance analysis.' ;
    rdfs:domain ind:AccountingPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:closeSequence rdf:type rdf:Property ;
    rdfs:label 'Close Sequence' ;
    rdfs:comment 'Defines the order in which periods should be closed in a multi-period close process. Lower numbers close first. Supports controlled, sequential period-end closing workflows.' ;
    rdfs:domain ind:AccountingPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:closedDate rdf:type rdf:Property ;
    rdfs:label 'Closed Date' ;
    rdfs:comment 'The date on which the accounting period was closed. Null if the period is still open or has never been closed. Supports audit trail and period lifecycle tracking.' ;
    rdfs:domain ind:AccountingPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consolidationFlag rdf:type rdf:Property ;
    rdfs:label 'Consolidation Flag' ;
    rdfs:comment 'Indicates whether this period is used for consolidation reporting (True) or is a subsidiary-only period (False). Supports multi-entity consolidation workflows.' ;
    rdfs:domain ind:AccountingPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:intercompanyEliminationFlag rdf:type rdf:Property ;
    rdfs:label 'Intercompany Elimination Flag' ;
    rdfs:comment 'Indicates whether intercompany eliminations have been processed for this period (True) or not (False). Supports consolidated financial statement preparation.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:openedDate rdf:type rdf:Property ;
    rdfs:label 'Opened Date' ;
    rdfs:comment 'The date on which the accounting period was opened for posting. Supports audit trail and period lifecycle tracking.' ;
    rdfs:domain ind:AccountingPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodName rdf:type rdf:Property ;
    rdfs:label 'Period Name' ;
    rdfs:comment 'Human-readable name of the accounting period, typically in the format \'MMM-YY\' (e.g., \'JAN-24\', \'FEB-24\') or \'Period 1\', \'Period 2\'. Used for display and reporting purposes.' ;
    rdfs:domain ind:AccountingPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodNumber rdf:type rdf:Property ;
    rdfs:label 'Period Number' ;
    rdfs:comment 'Sequential numeric identifier of the period within the fiscal year (e.g., 1 for January, 2 for February, 13 for year-end adjustment period). Supports ordering and period arithmetic.' ;
    rdfs:domain ind:AccountingPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:periodStatus rdf:type rdf:Property ;
    rdfs:label 'Period Status' ;
    rdfs:comment 'Current lifecycle status of the accounting period. Controls whether journal entries can be posted. \'future_enterable\' allows posting to future periods; \'open\' allows normal posting; \'closed\' prevents posting but can be reopened; \'permanently_closed\' locks the period for SOX compliance; \'never_opened\' indicates the period has not yet been activated.' ;
    rdfs:domain ind:AccountingPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permanentlyClosedDate rdf:type rdf:Property ;
    rdfs:label 'Permanently Closed Date' ;
    rdfs:comment 'The date on which the accounting period was permanently closed and locked for SOX compliance. Once permanently closed, the period cannot be reopened. Null if not permanently closed.' ;
    rdfs:domain ind:AccountingPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quarterNumber rdf:type rdf:Property ;
    rdfs:label 'Quarter Number' ;
    rdfs:comment 'The fiscal quarter to which this period belongs (1, 2, 3, or 4). Supports quarterly reporting and SEC 10-Q filing requirements.' ;
    rdfs:domain ind:AccountingPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reportingFlag rdf:type rdf:Property ;
    rdfs:label 'Reporting Flag' ;
    rdfs:comment 'Indicates whether this period is included in external financial reporting (True) or is for internal management purposes only (False). Supports GAAP and IFRS reporting requirements.' ;
    rdfs:domain ind:AccountingPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:soxCertificationDate rdf:type rdf:Property ;
    rdfs:label 'Sox Certification Date' ;
    rdfs:comment 'The date on which the period was certified for SOX compliance. Null if not yet certified. Supports audit trail and compliance reporting.' ;
    rdfs:domain ind:AccountingPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:soxCertificationFlag rdf:type rdf:Property ;
    rdfs:label 'Sox Certification Flag' ;
    rdfs:comment 'Indicates whether the period has been certified for SOX compliance (True) or not (False). Supports internal control attestation and audit requirements.' ;
    rdfs:domain ind:AccountingPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:yearEndFlag rdf:type rdf:Property ;
    rdfs:label 'Year End Flag' ;
    rdfs:comment 'Indicates whether this period is the final period of the fiscal year (True) or not (False). Used to trigger year-end closing processes, retained earnings rollover, and annual financial statement preparation.' ;
    rdfs:domain ind:AccountingPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:budgetCurrencyId rdf:type rdf:Property ;
    rdfs:label 'Budget Currency Id' ;
    rdfs:comment 'Foreign key linking to reference.currency. Business justification: Cost center budgets are set in specific currencies; this link enables budget vs. actual reporting in correct currency, budget translation for consolidation, and multi-currency budget management.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:parentCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Parent Cost Center Id' ;
    rdfs:comment 'Identifier of the parent cost center in the organizational hierarchy. Null for top-level units. Enables hierarchical roll-up of costs and revenues.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:baselBusinessLine rdf:type rdf:Property ;
    rdfs:label 'Basel Business Line' ;
    rdfs:comment 'Basel III standardized business line classification for operational risk capital calculation. Maps cost center to one of eight Basel business lines. [ENUM-REF-CANDIDATE: corporate_finance|trading_sales|retail_banking|commercial_banking|payment_settlement|agency_services|asset_management|retail_brokerage — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Amount' ;
    rdfs:comment 'Annual budgeted amount for this cost center in the reporting currency. Used for variance analysis and performance measurement.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costAllocationMethod rdf:type rdf:Property ;
    rdfs:label 'Cost Allocation Method' ;
    rdfs:comment 'Method used to allocate shared or indirect costs to this cost center. Direct assigns costs directly incurred; step-down cascades from service units; reciprocal accounts for mutual services; activity-based uses cost drivers. [ENUM-REF-CANDIDATE: direct|step_down|reciprocal|activity_based|headcount|square_footage|custom — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterCode rdf:type rdf:Property ;
    rdfs:label 'Cost Center Code' ;
    rdfs:comment 'Externally-known unique alphanumeric code identifying the cost center in financial systems and reports. Used in General Ledger (GL) posting and management accounting.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterDescription rdf:type rdf:Property ;
    rdfs:label 'Cost Center Description' ;
    rdfs:comment 'Detailed business description of the cost center\'s purpose, scope, and responsibilities.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterName rdf:type rdf:Property ;
    rdfs:label 'Cost Center Name' ;
    rdfs:comment 'Full business name of the cost center organizational unit.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterStatus rdf:type rdf:Property ;
    rdfs:label 'Cost Center Status' ;
    rdfs:comment 'Current lifecycle status of the cost center. Active units participate in financial transactions; inactive/closed units are historical.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterType rdf:type rdf:Property ;
    rdfs:label 'Cost Center Type' ;
    rdfs:comment 'Classification of the organizational unit by financial responsibility: cost center (expense only), revenue center (revenue only), profit center (P&L responsibility), investment center (ROI responsibility), shared service (allocated costs), or support unit (overhead).' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ftpRateAssignmentMethod rdf:type rdf:Property ;
    rdfs:label 'Ftp Rate Assignment Method' ;
    rdfs:comment 'Method used to assign FTP rates to this cost center for internal profitability measurement. Matched maturity assigns rates based on asset/liability duration; pooled uses average rates; market-based uses external benchmarks.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ftpRatePercent rdf:type rdf:Property ;
    rdfs:label 'Ftp Rate Percent' ;
    rdfs:comment 'Current FTP rate assigned to this cost center, expressed as an annual percentage. Used to calculate Net Interest Income (NII) and Net Interest Margin (NIM) at the cost center level.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:glAccountRangeEnd rdf:type rdf:Property ;
    rdfs:label 'Gl Account Range End' ;
    rdfs:comment 'Ending GL account number in the range assigned to this cost center. Used to filter GL transactions by cost center.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccountRangeStart rdf:type rdf:Property ;
    rdfs:label 'Gl Account Range Start' ;
    rdfs:comment 'Starting GL account number in the range assigned to this cost center. Used to filter GL transactions by cost center.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ifrs8ReportableSegmentFlag rdf:type rdf:Property ;
    rdfs:label 'Ifrs8 Reportable Segment Flag' ;
    rdfs:comment 'Indicates whether this cost center is part of an IFRS 8 reportable operating segment that must be disclosed in external financial statements.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lob rdf:type rdf:Property ;
    rdfs:label 'Lob' ;
    rdfs:comment 'Primary line of business classification for this cost center. Used for Basel III business line mapping, RAROC reporting, and segment profitability analysis. [ENUM-REF-CANDIDATE: retail_banking|investment_banking|wealth_management|asset_management|treasury|corporate_banking|trade_finance|capital_markets|operations|technology|risk|compliance|finance|human_resources|legal — 15 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueAllocationMethod rdf:type rdf:Property ;
    rdfs:label 'Revenue Allocation Method' ;
    rdfs:comment 'Method used to allocate revenues to this cost center. Direct allocation assigns revenues directly generated; activity-based uses cost drivers; headcount uses employee count; revenue driver uses business-specific metrics.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxControlScopeFlag rdf:type rdf:Property ;
    rdfs:label 'Sox Control Scope Flag' ;
    rdfs:comment 'Indicates whether this cost center is in scope for SOX Section 404 internal control testing and documentation.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transferPricingMethod rdf:type rdf:Property ;
    rdfs:label 'Transfer Pricing Method' ;
    rdfs:comment 'Method used for intercompany or inter-unit transfer pricing when this cost center transacts with other units. Cost-plus adds markup to cost; market price uses external benchmarks; negotiated uses agreed rates.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalCurrencyId rdf:type rdf:Property ;
    rdfs:label 'Functional Currency Id' ;
    rdfs:comment 'Foreign key linking to reference.currency. Business justification: Every legal entity has a functional currency per IAS 21; this is mandatory for IFRS consolidation, currency translation, and financial statement preparation in multi-entity banking groups.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:parentLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Parent Legal Entity Id' ;
    rdfs:comment 'Foreign key reference to the immediate parent legal entity within the banking group hierarchy. Null for the ultimate parent entity. Used for consolidation, intercompany eliminations, and organizational reporting.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:primaryUltimateParentLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Primary Ultimate Parent Legal Entity Id' ;
    rdfs:comment 'Foreign key reference to the top-level parent legal entity (holding company) of the entire banking group. Used for ultimate consolidation and group-level regulatory reporting.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:ccarDfastEntityFlag rdf:type rdf:Property ;
    rdfs:label 'Ccar Dfast Entity Flag' ;
    rdfs:comment 'Boolean flag indicating whether this legal entity is included in the scope of Federal Reserve CCAR or DFAST stress testing submissions. True = included in stress testing; False = excluded.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consolidationMethod rdf:type rdf:Property ;
    rdfs:label 'Consolidation Method' ;
    rdfs:comment 'Method used to consolidate this legal entity into the group financial statements. FULL = full consolidation (subsidiary), EQUITY = equity method (associate/joint venture), PROPORTIONAL = proportional consolidation (joint operation), NONE = not consolidated (investment held for sale, discontinued operation).' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfDomicile rdf:type rdf:Property ;
    rdfs:label 'Country Of Domicile' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the country where the legal entity has its principal place of business or tax residence. May differ from country of incorporation for tax planning structures.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crsReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Crs Reporting Flag' ;
    rdfs:comment 'Boolean flag indicating whether this legal entity is required to report financial account information under the OECD Common Reporting Standard (CRS) for automatic exchange of information. True = CRS reporting required; False = not a reporting financial institution.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dissolutionDate rdf:type rdf:Property ;
    rdfs:label 'Dissolution Date' ;
    rdfs:comment 'Date on which the legal entity was officially dissolved, liquidated, or deregistered. Null for active entities. Used for historical record-keeping and final reporting.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:entityType rdf:type rdf:Property ;
    rdfs:label 'Entity Type' ;
    rdfs:comment 'Classification of the legal entity by its primary business function within the banking group. Values include: BANK (deposit-taking institution), BROKER_DEALER (securities trading), INSURANCE (insurance underwriting), ASSET_MANAGER (investment management), SPV (special purpose vehicle), HOLDING_COMPANY (non-operating parent), BRANCH (non-legal entity branch office). [ENUM-REF-CANDIDATE: BANK|BROKER_DEALER|INSURANCE|ASSET_MANAGER|SPV|HOLDING_COMPANY|BRANCH|TRUST_COMPANY|FINANCE_COMPANY|SERVICER|CUSTODIAN — promote to reference product]' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalAuditorName rdf:type rdf:Property ;
    rdfs:label 'External Auditor Name' ;
    rdfs:comment 'Name of the external audit firm responsible for auditing the legal entity statutory financial statements. Used for audit coordination and SOX compliance tracking.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fatcaGiin rdf:type rdf:Property ;
    rdfs:label 'Fatca Giin' ;
    rdfs:comment 'Global Intermediary Identification Number (GIIN) assigned by the IRS for FATCA reporting. Format: XXXXXX.XXXXX.XX.XXX. Required for financial institutions reporting under FATCA to identify the legal entity in Form 8966 submissions.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYearEndMonth rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year End Month' ;
    rdfs:comment 'Month (1-12) in which the legal entity closes its fiscal year for statutory financial reporting. Used to align consolidation schedules and regulatory reporting deadlines. Example: 12 = December year-end.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastAuditOpinionDate rdf:type rdf:Property ;
    rdfs:label 'Last Audit Opinion Date' ;
    rdfs:comment 'Date of the most recent external audit opinion issued for the legal entity statutory financial statements. Used to track audit currency and compliance status.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastAuditOpinionType rdf:type rdf:Property ;
    rdfs:label 'Last Audit Opinion Type' ;
    rdfs:comment 'Type of audit opinion issued in the most recent external audit. UNQUALIFIED = clean opinion; QUALIFIED = opinion with exceptions; ADVERSE = financial statements materially misstated; DISCLAIMER = auditor unable to form opinion.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalEntityCode rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Code' ;
    rdfs:comment 'Short alphanumeric code used to identify the legal entity in operational systems and reporting. Typically aligned with General Ledger (GL) company code or regulatory reporting entity code.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalEntityStatus rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Status' ;
    rdfs:comment 'Current operational status of the legal entity. ACTIVE = operating and transacting; INACTIVE = temporarily not operating but still registered; DORMANT = no activity for extended period; LIQUIDATION = in process of winding down; DISSOLVED = legally terminated.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Registered Address Line1' ;
    rdfs:comment 'First line of the legal entity registered office address as filed with the corporate registry. Used for legal correspondence and regulatory filings.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Registered Address Line2' ;
    rdfs:comment 'Second line of the legal entity registered office address (suite, floor, building name). Optional field for additional address detail.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportingEntityFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Entity Flag' ;
    rdfs:comment 'Boolean flag indicating whether this legal entity is required to file standalone regulatory reports (e.g., Call Reports, FR Y-9C, COREP, FINREP). True = files reports; False = consolidated into parent reporting.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:soxScopeFlag rdf:type rdf:Property ;
    rdfs:label 'Sox Scope Flag' ;
    rdfs:comment 'Boolean flag indicating whether this legal entity is within the scope of Sarbanes-Oxley Act Section 404 internal controls testing and certification. True = SOX controls apply; False = out of scope.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:controlGlAccountId rdf:type rdf:Property ;
    rdfs:label 'Control Gl Account Id' ;
    rdfs:comment 'FK to ledger.gl_account' ;
    rdfs:domain ind:Subledger ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:autoReconciliationFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Reconciliation Flag' ;
    rdfs:comment 'Indicates whether the reconciliation was performed automatically by the system (True) or required manual intervention (False).' ;
    rdfs:domain ind:Subledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:balanceAmount rdf:type rdf:Property ;
    rdfs:label 'Balance Amount' ;
    rdfs:comment 'Aggregate balance amount from the subledger module for the reconciliation period, in the reporting currency.' ;
    rdfs:domain ind:Subledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:businessUnitCode rdf:type rdf:Property ;
    rdfs:label 'Business Unit Code' ;
    rdfs:comment 'Code identifying the business unit or line of business (LOB) responsible for this subledger.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glPostedBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Gl Posted Balance Amount' ;
    rdfs:comment 'Posted balance amount in the General Ledger (GL) for the corresponding control account and period, in the reporting currency.' ;
    rdfs:domain ind:Subledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:glTransferMethod rdf:type rdf:Property ;
    rdfs:label 'Gl Transfer Method' ;
    rdfs:comment 'Method by which subledger balances are transferred to the General Ledger (batch, real-time, scheduled, manual).' ;
    rdfs:domain ind:Subledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingFrequency rdf:type rdf:Property ;
    rdfs:label 'Posting Frequency' ;
    rdfs:comment 'Frequency at which subledger transactions are posted to the General Ledger (daily, weekly, monthly, quarterly, on-demand).' ;
    rdfs:domain ind:Subledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationDate rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Date' ;
    rdfs:comment 'Date on which the subledger-to-General Ledger (GL) reconciliation was executed.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:resolutionActions rdf:type rdf:Property ;
    rdfs:label 'Resolution Actions' ;
    rdfs:comment 'Documented actions taken to resolve any reconciliation exceptions or variances (e.g., journal entry posted, transaction reclassified, timing difference noted).' ;
    rdfs:domain ind:Subledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewerName rdf:type rdf:Property ;
    rdfs:label 'Reviewer Name' ;
    rdfs:comment 'Full name of the individual who reviewed the subledger reconciliation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemName rdf:type rdf:Property ;
    rdfs:label 'Source System Name' ;
    rdfs:comment 'Name of the operational system of record that generates subledger transactions (e.g., Temenos T24, Murex, ACI Worldwide).' ;
    rdfs:domain ind:Subledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subledgerCode rdf:type rdf:Property ;
    rdfs:label 'Subledger Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the subledger module within the General Ledger (GL) system.' ;
    rdfs:domain ind:Subledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subledgerName rdf:type rdf:Property ;
    rdfs:label 'Subledger Name' ;
    rdfs:comment 'Business name of the subledger module (e.g., Accounts Payable, Fixed Assets, Loan Subledger).' ;
    rdfs:domain ind:Subledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variancePercentage rdf:type rdf:Property ;
    rdfs:label 'Variance Percentage' ;
    rdfs:comment 'Variance expressed as a percentage of the General Ledger (GL) posted balance, used for materiality assessment.' ;
    rdfs:domain ind:Subledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceRootCause rdf:type rdf:Property ;
    rdfs:label 'Variance Root Cause' ;
    rdfs:comment 'Documented root cause explanation for any variance between subledger and General Ledger (GL) balances (e.g., timing difference, posting error, unrecorded transaction).' ;
    rdfs:domain ind:Subledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trialBalanceId rdf:type rdf:Property ;
    rdfs:label 'Trial Balance Id' ;
    rdfs:comment 'Unique identifier for the trial balance record. Primary key for this entity.' ;
    rdfs:domain ind:TrialBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adjustmentFlag rdf:type rdf:Property ;
    rdfs:label 'Adjustment Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether this trial balance line includes post-close adjustments, reclassifications, or audit adjustments. Supports SOX audit trail requirements.' ;
    rdfs:domain ind:TrialBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:balanceType rdf:type rdf:Property ;
    rdfs:label 'Balance Type' ;
    rdfs:comment 'Classification of the trial balance record indicating whether it represents actual posted transactions, budgeted amounts, forecasted amounts, adjusted balances, restated balances for prior period corrections, or pro forma balances for scenario analysis.' ;
    rdfs:domain ind:TrialBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closingBalanceCredit rdf:type rdf:Property ;
    rdfs:label 'Closing Balance Credit' ;
    rdfs:comment 'Ending credit balance for this GL account at the end of the accounting period. Calculated as opening balance plus period activity. Forms the basis for financial statement preparation.' ;
    rdfs:domain ind:TrialBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:closingBalanceDebit rdf:type rdf:Property ;
    rdfs:label 'Closing Balance Debit' ;
    rdfs:comment 'Ending debit balance for this GL account at the end of the accounting period. Calculated as opening balance plus period activity. Forms the basis for financial statement preparation.' ;
    rdfs:domain ind:TrialBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eliminationFlag rdf:type rdf:Property ;
    rdfs:label 'Elimination Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether this trial balance line has been marked for elimination in the consolidation process. Used to remove intercompany balances and transactions.' ;
    rdfs:domain ind:TrialBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:extractionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Extraction Timestamp' ;
    rdfs:comment 'Timestamp when this trial balance record was extracted from the source system and loaded into the data lakehouse. Supports data lineage and freshness tracking.' ;
    rdfs:domain ind:TrialBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:functionalClosingBalanceCredit rdf:type rdf:Property ;
    rdfs:label 'Functional Closing Balance Credit' ;
    rdfs:comment 'Closing credit balance converted to the functional currency of the legal entity. Used for consolidated financial statements and regulatory reporting.' ;
    rdfs:domain ind:TrialBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:functionalClosingBalanceDebit rdf:type rdf:Property ;
    rdfs:label 'Functional Closing Balance Debit' ;
    rdfs:comment 'Closing debit balance converted to the functional currency of the legal entity. Used for consolidated financial statements and regulatory reporting.' ;
    rdfs:domain ind:TrialBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:functionalOpeningBalanceCredit rdf:type rdf:Property ;
    rdfs:label 'Functional Opening Balance Credit' ;
    rdfs:comment 'Opening credit balance converted to the functional currency of the legal entity using the appropriate exchange rate. Used for consolidation and group reporting.' ;
    rdfs:domain ind:TrialBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:functionalOpeningBalanceDebit rdf:type rdf:Property ;
    rdfs:label 'Functional Opening Balance Debit' ;
    rdfs:comment 'Opening debit balance converted to the functional currency of the legal entity using the appropriate exchange rate. Used for consolidation and group reporting.' ;
    rdfs:domain ind:TrialBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:functionalPeriodCreditActivity rdf:type rdf:Property ;
    rdfs:label 'Functional Period Credit Activity' ;
    rdfs:comment 'Period credit activity converted to the functional currency of the legal entity. Supports multi-currency consolidation and reporting under IFRS/GAAP.' ;
    rdfs:domain ind:TrialBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:functionalPeriodDebitActivity rdf:type rdf:Property ;
    rdfs:label 'Functional Period Debit Activity' ;
    rdfs:comment 'Period debit activity converted to the functional currency of the legal entity. Supports multi-currency consolidation and reporting under IFRS/GAAP.' ;
    rdfs:domain ind:TrialBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:openingBalanceCredit rdf:type rdf:Property ;
    rdfs:label 'Opening Balance Credit' ;
    rdfs:comment 'Credit balance brought forward from the prior accounting period for this GL account. Represents the beginning balance for the current period.' ;
    rdfs:domain ind:TrialBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:openingBalanceDebit rdf:type rdf:Property ;
    rdfs:label 'Opening Balance Debit' ;
    rdfs:comment 'Debit balance brought forward from the prior accounting period for this GL account. Represents the beginning balance for the current period.' ;
    rdfs:domain ind:TrialBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:periodCreditActivity rdf:type rdf:Property ;
    rdfs:label 'Period Credit Activity' ;
    rdfs:comment 'Total credit transactions posted to this GL account during the current accounting period. Includes journal entries from all subledgers and manual adjustments.' ;
    rdfs:domain ind:TrialBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:periodDebitActivity rdf:type rdf:Property ;
    rdfs:label 'Period Debit Activity' ;
    rdfs:comment 'Total debit transactions posted to this GL account during the current accounting period. Includes journal entries from all subledgers and manual adjustments.' ;
    rdfs:domain ind:TrialBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reconciledBy rdf:type rdf:Property ;
    rdfs:label 'Reconciled By' ;
    rdfs:comment 'User ID or name of the individual who performed the account reconciliation. Supports segregation of duties and audit trail requirements under SOX.' ;
    rdfs:domain ind:TrialBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intercompanyTransactionId rdf:type rdf:Property ;
    rdfs:label 'Intercompany Transaction Id' ;
    rdfs:comment 'Unique identifier for the intercompany transaction record. Primary key.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eliminationJournalEntryId rdf:type rdf:Property ;
    rdfs:label 'Elimination Journal Entry Id' ;
    rdfs:comment 'Identifier of the consolidation journal entry that eliminated this intercompany transaction during the financial close process.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntry .

ind:matchedTransactionId rdf:type rdf:Property ;
    rdfs:label 'Matched Transaction Id' ;
    rdfs:comment 'Identifier of the corresponding intercompany transaction record in the counterparty legal entity that matches this transaction for reconciliation purposes.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IntercompanyTransaction .

ind:originatingGlAccountId rdf:type rdf:Property ;
    rdfs:label 'Originating Gl Account Id' ;
    rdfs:comment 'Foreign key linking to ledger.gl_account. Business justification: intercompany_transaction has originating_gl_account_code (STRING) referencing the GL account on the originating entity side of the intercompany transaction. Normalizing to originating_gl_account_id → ' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:originatingLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Originating Legal Entity Id' ;
    rdfs:comment 'Identifier of the legal entity that initiated or originated the intercompany transaction.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:primaryIntercompanyCounterpartyLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Primary Intercompany Counterparty Legal Entity Id' ;
    rdfs:comment 'Identifier of the legal entity that is the counterparty or receiving entity in the intercompany transaction.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:reversedTransactionIntercompanyTransactionId rdf:type rdf:Property ;
    rdfs:label 'Reversed Transaction Intercompany Transaction Id' ;
    rdfs:comment 'Identifier of the original intercompany transaction that this record reverses, if applicable.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IntercompanyTransaction .

ind:counterpartyGlAccountCode rdf:type rdf:Property ;
    rdfs:label 'Counterparty Gl Account Code' ;
    rdfs:comment 'The general ledger account code in the counterparty legal entity where the intercompany transaction is recorded.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eliminationPeriod rdf:type rdf:Property ;
    rdfs:label 'Elimination Period' ;
    rdfs:comment 'The fiscal period in which the intercompany transaction was or will be eliminated during the consolidation process.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eliminationStatus rdf:type rdf:Property ;
    rdfs:label 'Elimination Status' ;
    rdfs:comment 'Current status of the intercompany transaction in the consolidation elimination process.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Functional Currency Amount' ;
    rdfs:comment 'The monetary value of the intercompany transaction converted to the functional currency of the originating legal entity.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:intercompanyTransactionDescription rdf:type rdf:Property ;
    rdfs:label 'Intercompany Transaction Description' ;
    rdfs:comment 'Detailed textual description of the intercompany transaction, including business purpose and context.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nettingAgreementReference rdf:type rdf:Property ;
    rdfs:label 'Netting Agreement Reference' ;
    rdfs:comment 'Reference to the intercompany netting or settlement agreement that governs the offsetting of this transaction with other intercompany balances.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productLineCode rdf:type rdf:Property ;
    rdfs:label 'Product Line Code' ;
    rdfs:comment 'Code identifying the product line or service category associated with the intercompany transaction for profitability analysis.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Source System Transaction Reference' ;
    rdfs:comment 'The unique transaction identifier from the originating source system, used for traceability and reconciliation.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferPricingDocumentationReference rdf:type rdf:Property ;
    rdfs:label 'Transfer Pricing Documentation Reference' ;
    rdfs:comment 'Reference to the transfer pricing documentation or study that supports the pricing of this intercompany transaction for tax compliance.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentProfitCenterId rdf:type rdf:Property ;
    rdfs:label 'Parent Profit Center Id' ;
    rdfs:comment 'FK to ledger.profit_center' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProfitCenter .

ind:alternateProfitCenterCode rdf:type rdf:Property ;
    rdfs:label 'Alternate Profit Center Code' ;
    rdfs:comment 'Secondary or legacy profit center code used for cross-system mapping, migration tracking, or external reporting. Supports integration with legacy systems and external partners.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ftpRateAssignment rdf:type rdf:Property ;
    rdfs:label 'Ftp Rate Assignment' ;
    rdfs:comment 'The FTP methodology assigned to this profit center for internal pricing of funds. Matched maturity assigns rates based on asset/liability duration. Pooled and blended methods use average rates. Critical for accurate profitability measurement in banking.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ifrsSegmentFlag rdf:type rdf:Property ;
    rdfs:label 'Ifrs Segment Flag' ;
    rdfs:comment 'Indicates whether this profit center represents a reportable operating segment under IFRS 8. True for segments that meet the quantitative thresholds or are otherwise disclosed separately in financial statements.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lobClassification rdf:type rdf:Property ;
    rdfs:label 'Lob Classification' ;
    rdfs:comment 'The primary line of business classification for this profit center, aligning with the bank\'s strategic business segments and regulatory reporting requirements. [ENUM-REF-CANDIDATE: retail_banking|commercial_banking|investment_banking|wealth_management|treasury|capital_markets|asset_management|corporate_trust|payment_services|other — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterCode rdf:type rdf:Property ;
    rdfs:label 'Profit Center Code' ;
    rdfs:comment 'The externally-known unique business identifier for the profit center, used in financial reporting and management accounting. Typically alphanumeric code assigned by the finance organization.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterDescription rdf:type rdf:Property ;
    rdfs:label 'Profit Center Description' ;
    rdfs:comment 'Detailed textual description of the profit center\'s business purpose, scope of operations, and strategic objectives. Provides context for financial analysis and reporting.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterName rdf:type rdf:Property ;
    rdfs:label 'Profit Center Name' ;
    rdfs:comment 'The full business name or title of the profit center, used for display and reporting purposes.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterStatus rdf:type rdf:Property ;
    rdfs:label 'Profit Center Status' ;
    rdfs:comment 'Current lifecycle status of the profit center. Active profit centers are operational and accumulate PnL. Inactive or closed profit centers are no longer operational but retained for historical reporting.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterType rdf:type rdf:Property ;
    rdfs:label 'Profit Center Type' ;
    rdfs:comment 'Classification of the profit center by organizational dimension. Indicates whether the profit center represents a banking segment (retail, commercial, investment banking), product line (loans, deposits, trading), geographic region, business unit, legal entity, or functional area.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rarocTargetRate rdf:type rdf:Property ;
    rdfs:label 'Raroc Target Rate' ;
    rdfs:comment 'The target RAROC rate (expressed as a decimal, e.g., 0.1500 for 15%) set for this profit center. Used to evaluate whether the profit center is generating adequate returns relative to the economic capital allocated to it.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportingCurrency rdf:type rdf:Property ;
    rdfs:label 'Reporting Currency' ;
    rdfs:comment 'The currency in which this profit center\'s results are reported for consolidation and group reporting purposes, using ISO 4217 three-letter currency code. May differ from functional currency for foreign operations.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleExecutive rdf:type rdf:Property ;
    rdfs:label 'Responsible Executive' ;
    rdfs:comment 'Name or identifier of the executive or senior manager accountable for the profit center\'s financial performance and strategic objectives.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rwaCategory rdf:type rdf:Property ;
    rdfs:label 'Rwa Category' ;
    rdfs:comment 'The primary risk category for RWA calculation and capital allocation. Determines how this profit center\'s activities contribute to the bank\'s total risk-weighted assets under Basel III.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lcId rdf:type rdf:Property ;
    rdfs:label 'Lc Id' ;
    rdfs:comment 'Unique identifier for the Letter of Credit record. Primary key.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lc .

ind:beneficiaryCounterpartyRatingId rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Counterparty Rating Id' ;
    rdfs:comment 'Foreign key linking to risk.counterparty_rating. Business justification: Letter of credit issuance requires credit assessment of beneficiary (especially for standby LCs). Beneficiary default risk affects LC utilization probability and regulatory capital requirements under ' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CounterpartyRating .

ind:expiryCountryId rdf:type rdf:Property ;
    rdfs:label 'Expiry Country Id' ;
    rdfs:comment 'Foreign key linking to reference.country. Business justification: LCs specify expiry place (country) requiring country business day conventions, holiday calendars, and regulatory rules (UCP 600 Article 3) for expiry date calculation and presentation deadline determi' ;
    rdfs:domain ind:Lc ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:issuanceChannelId rdf:type rdf:Property ;
    rdfs:label 'Issuance Channel Id' ;
    rdfs:comment 'Foreign key linking to channel.channel. Business justification: Letters of credit issued through channels (branch trade desk, digital platform, RM). Required for trade finance channel analytics, documentary credit origination tracking, and trade services performan' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:advisingBankBic rdf:type rdf:Property ;
    rdfs:label 'Advising Bank Bic' ;
    rdfs:comment 'SWIFT BIC code of the bank that advises the Letter of Credit to the beneficiary without adding its own undertaking.' ;
    rdfs:domain ind:Lc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableRules rdf:type rdf:Property ;
    rdfs:label 'Applicable Rules' ;
    rdfs:comment 'ICC rules governing this Letter of Credit. UCP 600: Uniform Customs and Practice for Documentary Credits. eUCP: electronic presentation supplement. ISP98: International Standby Practices. URDG 758: Uniform Rules for Demand Guarantees.' ;
    rdfs:domain ind:Lc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availableAmount rdf:type rdf:Property ;
    rdfs:label 'Available Amount' ;
    rdfs:comment 'Current remaining credit amount available for drawing under the Letter of Credit after accounting for any utilizations, amendments, or expirations.' ;
    rdfs:domain ind:Lc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confirmingBankBic rdf:type rdf:Property ;
    rdfs:label 'Confirming Bank Bic' ;
    rdfs:comment 'SWIFT BIC code of the bank that adds its confirmation to the Letter of Credit, thereby undertaking to honor complying presentations in addition to the issuing bank.' ;
    rdfs:domain ind:Lc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expiryPlace rdf:type rdf:Property ;
    rdfs:label 'Expiry Place' ;
    rdfs:comment 'Geographic location (city and country) where the Letter of Credit expires and documents must be presented. Typically the counters of the nominated bank or issuing bank.' ;
    rdfs:domain ind:Lc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsDescription rdf:type rdf:Property ;
    rdfs:label 'Goods Description' ;
    rdfs:comment 'Detailed description of the merchandise or services covered by the Letter of Credit. Must match the description in commercial invoices and other documents.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hsCode rdf:type rdf:Property ;
    rdfs:label 'Hs Code' ;
    rdfs:comment 'International standardized system of names and numbers for classifying traded products, used for customs and tariff purposes.' ;
    rdfs:domain ind:Lc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incoterm rdf:type rdf:Property ;
    rdfs:label 'Incoterm' ;
    rdfs:comment 'ICC Incoterms rule defining the division of costs, risks, and responsibilities between buyer and seller in the international sale of goods. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Lc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingBankBic rdf:type rdf:Property ;
    rdfs:label 'Issuing Bank Bic' ;
    rdfs:comment 'SWIFT BIC code of the bank that issued the Letter of Credit. 8 or 11 character ISO 9362 identifier.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:latestShipmentDate rdf:type rdf:Property ;
    rdfs:label 'Latest Shipment Date' ;
    rdfs:comment 'Last date by which shipment of goods must occur as stipulated in the Letter of Credit terms. Critical for compliance with transport document requirements.' ;
    rdfs:domain ind:Lc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lcNumber rdf:type rdf:Property ;
    rdfs:label 'Lc Number' ;
    rdfs:comment 'Externally-known unique reference number assigned to the Letter of Credit by the issuing bank. This is the business identifier used in SWIFT messages and trade documentation.' ;
    rdfs:domain ind:Lc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lcStatus rdf:type rdf:Property ;
    rdfs:label 'Lc Status' ;
    rdfs:comment 'Current lifecycle status of the Letter of Credit. Draft: being prepared. Issued: sent to advising bank. Advised: communicated to beneficiary. Confirmed: confirmed by another bank. Amended: modified after issuance. Utilized: drawings made. Expired: validity period ended. Cancelled: terminated before expiry. [ENUM-REF-CANDIDATE: draft|issued|advised|confirmed|amended|utilized|expired|cancelled — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Lc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lcType rdf:type rdf:Property ;
    rdfs:label 'Lc Type' ;
    rdfs:comment 'Classification of the Letter of Credit based on payment terms and transferability. Sight: payable on presentation. Usance: payable at a future date. Deferred Payment: payment deferred without draft. Acceptance: draft accepted for future payment. Standby: guarantee instrument. Transferable: can be transferred to secondary beneficiary.' ;
    rdfs:domain ind:Lc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partialShipmentAllowed rdf:type rdf:Property ;
    rdfs:label 'Partial Shipment Allowed' ;
    rdfs:comment 'Indicates whether the beneficiary is permitted to ship goods in multiple installments. True if partial shipments are allowed, False if prohibited.' ;
    rdfs:domain ind:Lc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:portOfDischarge rdf:type rdf:Property ;
    rdfs:label 'Port Of Discharge' ;
    rdfs:comment 'Name and country of the port or place where goods are unloaded from the vessel or transport mode at the destination.' ;
    rdfs:domain ind:Lc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portOfLoading rdf:type rdf:Property ;
    rdfs:label 'Port Of Loading' ;
    rdfs:comment 'Name and country of the port or place where goods are loaded onto the vessel or transport mode for shipment to the destination.' ;
    rdfs:domain ind:Lc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:presentationPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Presentation Period Days' ;
    rdfs:comment 'Number of days after shipment date within which documents must be presented to the nominated bank. Defaults to 21 days per UCP 600 Article 14(c) if not specified.' ;
    rdfs:domain ind:Lc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reimbursementBankBic rdf:type rdf:Property ;
    rdfs:label 'Reimbursement Bank Bic' ;
    rdfs:comment 'SWIFT BIC code of the bank authorized to reimburse the nominated or confirming bank upon receipt of complying documents.' ;
    rdfs:domain ind:Lc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reimbursementInstructions rdf:type rdf:Property ;
    rdfs:label 'Reimbursement Instructions' ;
    rdfs:comment 'Detailed instructions specifying how the nominated or confirming bank should claim reimbursement from the issuing or reimbursing bank, including account details and SWIFT message requirements.' ;
    rdfs:domain ind:Lc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revolvingFlag rdf:type rdf:Property ;
    rdfs:label 'Revolving Flag' ;
    rdfs:comment 'Indicates whether this is a revolving Letter of Credit that automatically reinstates its value after each drawing, allowing multiple shipments under a single LC.' ;
    rdfs:domain ind:Lc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revolvingFrequency rdf:type rdf:Property ;
    rdfs:label 'Revolving Frequency' ;
    rdfs:comment 'For revolving LCs, the period at which the credit amount reinstates. Applicable only when revolving_flag is True.' ;
    rdfs:domain ind:Lc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialConditions rdf:type rdf:Property ;
    rdfs:label 'Special Conditions' ;
    rdfs:comment 'Additional terms, conditions, or documentary requirements specific to this Letter of Credit beyond standard UCP 600 provisions. May include inspection certificates, insurance requirements, or specific document clauses.' ;
    rdfs:domain ind:Lc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tolerancePercentage rdf:type rdf:Property ;
    rdfs:label 'Tolerance Percentage' ;
    rdfs:comment 'Permitted variance (plus or minus) in the LC amount and quantity, typically 10% unless otherwise specified. Allows for minor discrepancies in commercial invoices.' ;
    rdfs:domain ind:Lc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transferableFlag rdf:type rdf:Property ;
    rdfs:label 'Transferable Flag' ;
    rdfs:comment 'Indicates whether the beneficiary has the right to transfer all or part of the Letter of Credit to one or more second beneficiaries. Must be explicitly stated as transferable.' ;
    rdfs:domain ind:Lc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transhipmentAllowed rdf:type rdf:Property ;
    rdfs:label 'Transhipment Allowed' ;
    rdfs:comment 'Indicates whether goods may be transferred from one vessel to another during transit. True if transhipment is permitted, False if prohibited.' ;
    rdfs:domain ind:Lc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:utilizedAmount rdf:type rdf:Property ;
    rdfs:label 'Utilized Amount' ;
    rdfs:comment 'Cumulative amount that has been drawn or claimed against the Letter of Credit through complying presentations and payments.' ;
    rdfs:domain ind:Lc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lcDrawingId rdf:type rdf:Property ;
    rdfs:label 'Lc Drawing Id' ;
    rdfs:comment 'Unique identifier for the LC drawing or amendment transaction record.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LcDrawing .

ind:amendedFieldName rdf:type rdf:Property ;
    rdfs:label 'Amended Field Name' ;
    rdfs:comment 'Name of the LC field being amended (e.g., lc_amount, expiry_date, document_requirements). Applicable when transaction_type is amendment.' ;
    rdfs:domain ind:LcDrawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Amendment Compliance Flag' ;
    rdfs:comment 'Indicator of whether the amendment complies with UCP 600 and internal bank policies. Applicable when transaction_type is amendment.' ;
    rdfs:domain ind:LcDrawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:amendmentRequestDate rdf:type rdf:Property ;
    rdfs:label 'Amendment Request Date' ;
    rdfs:comment 'Date on which the amendment was formally requested by the applicant or issuing bank. Applicable when transaction_type is amendment.' ;
    rdfs:domain ind:LcDrawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:availableBalanceAfterTransaction rdf:type rdf:Property ;
    rdfs:label 'Available Balance After Transaction' ;
    rdfs:comment 'Remaining available balance on the LC after this drawing or amendment is processed.' ;
    rdfs:domain ind:LcDrawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:beneficiaryAcceptanceDate rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Acceptance Date' ;
    rdfs:comment 'Date on which the beneficiary formally accepted or rejected the amendment. Applicable when transaction_type is amendment.' ;
    rdfs:domain ind:LcDrawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:beneficiaryAcceptanceStatus rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Acceptance Status' ;
    rdfs:comment 'Status indicating whether the beneficiary has accepted, rejected, or not yet responded to the amendment per UCP 600 Article 10. Applicable when transaction_type is amendment.' ;
    rdfs:domain ind:LcDrawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discrepancyCode rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Code' ;
    rdfs:comment 'Standardized code classifying the type of discrepancy (e.g., late presentation, missing document, inconsistent data). Applicable when transaction_type is drawing.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentSetReference rdf:type rdf:Property ;
    rdfs:label 'Document Set Reference' ;
    rdfs:comment 'Reference identifier for the set of documents presented with the drawing (e.g., bill of lading, commercial invoice, certificate of origin). Applicable when transaction_type is drawing.' ;
    rdfs:domain ind:LcDrawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drawingAmount rdf:type rdf:Property ;
    rdfs:label 'Drawing Amount' ;
    rdfs:comment 'Monetary value of the drawing being claimed by the beneficiary. Applicable when transaction_type is drawing.' ;
    rdfs:domain ind:LcDrawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:honourDecision rdf:type rdf:Property ;
    rdfs:label 'Honour Decision' ;
    rdfs:comment 'Decision by the issuing or nominated bank to honour or dishonour the drawing based on document examination. Applicable when transaction_type is drawing.' ;
    rdfs:domain ind:LcDrawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:honourDecisionDate rdf:type rdf:Property ;
    rdfs:label 'Honour Decision Date' ;
    rdfs:comment 'Date on which the honour or dishonour decision was made by the bank. Applicable when transaction_type is drawing.' ;
    rdfs:domain ind:LcDrawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:issuingBankApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Issuing Bank Approval Date' ;
    rdfs:comment 'Date on which the issuing bank approved and issued the amendment. Applicable when transaction_type is amendment.' ;
    rdfs:domain ind:LcDrawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:negotiationFlag rdf:type rdf:Property ;
    rdfs:label 'Negotiation Flag' ;
    rdfs:comment 'Indicator of whether the drawing was negotiated by a nominated bank before presentation to the issuing bank. Applicable when transaction_type is drawing.' ;
    rdfs:domain ind:LcDrawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:newValue rdf:type rdf:Property ;
    rdfs:label 'New Value' ;
    rdfs:comment 'Updated value of the amended field after the amendment. Stored as string to accommodate various data types. Applicable when transaction_type is amendment.' ;
    rdfs:domain ind:LcDrawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partialDrawingFlag rdf:type rdf:Property ;
    rdfs:label 'Partial Drawing Flag' ;
    rdfs:comment 'Indicator of whether this drawing represents a partial utilization of the LC available balance. Applicable when transaction_type is drawing.' ;
    rdfs:domain ind:LcDrawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:presentationDate rdf:type rdf:Property ;
    rdfs:label 'Presentation Date' ;
    rdfs:comment 'Date on which the beneficiary presented documents to the nominated or issuing bank for drawing under the LC. Applicable when transaction_type is drawing.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priorValue rdf:type rdf:Property ;
    rdfs:label 'Prior Value' ;
    rdfs:comment 'Original value of the amended field before the amendment. Stored as string to accommodate various data types. Applicable when transaction_type is amendment.' ;
    rdfs:domain ind:LcDrawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Sequence Number' ;
    rdfs:comment 'Sequential numbering of amendments or drawings against the parent LC, enabling chronological tracking of all transactional activity.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:waiverRequestDate rdf:type rdf:Property ;
    rdfs:label 'Waiver Request Date' ;
    rdfs:comment 'Date on which the issuing bank requested the applicant to waive identified discrepancies. Applicable when transaction_type is drawing.' ;
    rdfs:domain ind:LcDrawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:waiverResponseDate rdf:type rdf:Property ;
    rdfs:label 'Waiver Response Date' ;
    rdfs:comment 'Date on which the applicant responded to the waiver request. Applicable when transaction_type is drawing.' ;
    rdfs:domain ind:LcDrawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:waiverStatus rdf:type rdf:Property ;
    rdfs:label 'Waiver Status' ;
    rdfs:comment 'Status indicating whether the applicant has been asked to waive discrepancies and their response. Applicable when transaction_type is drawing and discrepancy_flag is true.' ;
    rdfs:domain ind:LcDrawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentaryCollectionId rdf:type rdf:Property ;
    rdfs:label 'Documentary Collection Id' ;
    rdfs:comment 'Unique identifier for the documentary collection transaction. Primary key.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DocumentaryCollection .

ind:primaryDocumentaryDrawerPartyId rdf:type rdf:Property ;
    rdfs:label 'Primary Documentary Drawer Party Id' ;
    rdfs:comment 'Identifier of the drawer (exporter/seller) who is the principal in the collection and who instructs the remitting bank to collect payment from the drawee.' ;
    rdfs:domain ind:DocumentaryCollection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:tertiaryDocumentaryCaseOfNeedPartyId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Documentary Case Of Need Party Id' ;
    rdfs:comment 'Identifier of the case-of-need party (referee in case of need) who may be contacted for instructions if the drawee refuses payment or acceptance. Optional field per URC 522.' ;
    rdfs:domain ind:DocumentaryCollection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:caseOfNeedInstructions rdf:type rdf:Property ;
    rdfs:label 'Case Of Need Instructions' ;
    rdfs:comment 'Specific instructions to be followed if the drawee dishonours the collection, including contact details and authority of the case-of-need party.' ;
    rdfs:domain ind:DocumentaryCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargesAllocation rdf:type rdf:Property ;
    rdfs:label 'Charges Allocation' ;
    rdfs:comment 'Party responsible for paying collection charges: drawer (exporter), drawee (importer), or shared between both parties.' ;
    rdfs:domain ind:DocumentaryCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargesAmount rdf:type rdf:Property ;
    rdfs:label 'Charges Amount' ;
    rdfs:comment 'Total bank charges and fees associated with the collection. May be for account of drawer, drawee, or split per collection instructions.' ;
    rdfs:domain ind:DocumentaryCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chargesCurrency rdf:type rdf:Property ;
    rdfs:label 'Charges Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the charges amount.' ;
    rdfs:domain ind:DocumentaryCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectingBankBic rdf:type rdf:Property ;
    rdfs:label 'Collecting Bank Bic' ;
    rdfs:comment 'SWIFT Bank Identifier Code (BIC) of the collecting bank (presenting bank) that presents documents to the drawee. 8 or 11 character ISO 9362 format.' ;
    rdfs:domain ind:DocumentaryCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionAmount rdf:type rdf:Property ;
    rdfs:label 'Collection Amount' ;
    rdfs:comment 'Principal amount to be collected from the drawee. Represents the invoice value or bill amount.' ;
    rdfs:domain ind:DocumentaryCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collectionCurrency rdf:type rdf:Property ;
    rdfs:label 'Collection Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the collection amount.' ;
    rdfs:domain ind:DocumentaryCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Collection Reference Number' ;
    rdfs:comment 'Externally-known unique reference number assigned to this documentary collection by the remitting bank. Used for tracking and correspondence under URC 522.' ;
    rdfs:domain ind:DocumentaryCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionStatus rdf:type rdf:Property ;
    rdfs:label 'Collection Status' ;
    rdfs:comment 'Current lifecycle status of the documentary collection: lodged (received by remitting bank), presented (documents presented to drawee), accepted (drawee accepted documents), paid (payment received), dishonoured (drawee refused), returned (documents returned to drawer), cancelled (collection cancelled). [ENUM-REF-CANDIDATE: lodged|presented|accepted|paid|dishonoured|returned|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DocumentaryCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionType rdf:type rdf:Property ;
    rdfs:label 'Collection Type' ;
    rdfs:comment 'Type of documentary collection: Documents Against Payment (D/P), Documents Against Acceptance (D/A), or Clean Collection (financial documents only without commercial documents).' ;
    rdfs:domain ind:DocumentaryCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryInstructions rdf:type rdf:Property ;
    rdfs:label 'Delivery Instructions' ;
    rdfs:comment 'Instructions for when the collecting bank should release documents to the drawee: against payment (D/P), against acceptance (D/A), or without payment (exceptional cases).' ;
    rdfs:domain ind:DocumentaryCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dishonourReason rdf:type rdf:Property ;
    rdfs:label 'Dishonour Reason' ;
    rdfs:comment 'Reason provided by the drawee or collecting bank for non-payment or non-acceptance of the collection (e.g., discrepancies in documents, insufficient funds, goods not as described). Populated only if collection status is dishonoured.' ;
    rdfs:domain ind:DocumentaryCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentSetDescription rdf:type rdf:Property ;
    rdfs:label 'Document Set Description' ;
    rdfs:comment 'Detailed description of the commercial and financial documents included in the collection (e.g., bill of exchange, commercial invoice, bill of lading, insurance certificate, certificate of origin, packing list).' ;
    rdfs:domain ind:DocumentaryCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:draweeName rdf:type rdf:Property ;
    rdfs:label 'Drawee Name' ;
    rdfs:comment 'Full legal name of the drawee (importer/buyer) to whom the documents are to be presented.' ;
    rdfs:domain ind:DocumentaryCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drawerName rdf:type rdf:Property ;
    rdfs:label 'Drawer Name' ;
    rdfs:comment 'Full legal name of the drawer (exporter/seller) as it appears on the collection documents.' ;
    rdfs:domain ind:DocumentaryCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberOfDocuments rdf:type rdf:Property ;
    rdfs:label 'Number Of Documents' ;
    rdfs:comment 'Total count of individual documents included in the collection package.' ;
    rdfs:domain ind:DocumentaryCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:partialPaymentAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Partial Payment Allowed Flag' ;
    rdfs:comment 'Indicates whether the drawer permits the collecting bank to accept partial payment from the drawee. True if partial payment is allowed, false otherwise.' ;
    rdfs:domain ind:DocumentaryCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:protestInstructions rdf:type rdf:Property ;
    rdfs:label 'Protest Instructions' ;
    rdfs:comment 'Instructions from the drawer regarding whether to protest non-payment or non-acceptance. Protest is a formal notarial act evidencing dishonour.' ;
    rdfs:domain ind:DocumentaryCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remittingBankBic rdf:type rdf:Property ;
    rdfs:label 'Remitting Bank Bic' ;
    rdfs:comment 'SWIFT Bank Identifier Code (BIC) of the remitting bank that received the collection instruction from the drawer. 8 or 11 character ISO 9362 format.' ;
    rdfs:domain ind:DocumentaryCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentDate rdf:type rdf:Property ;
    rdfs:label 'Shipment Date' ;
    rdfs:comment 'Date of shipment of goods as evidenced by the transport document (bill of lading, airway bill, etc.). Relevant for calculating tenor in shipment-date-based collections.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tenorBasis rdf:type rdf:Property ;
    rdfs:label 'Tenor Basis' ;
    rdfs:comment 'Basis from which the tenor period is calculated: sight (immediate payment), date of acceptance, date of bill, or date of shipment.' ;
    rdfs:domain ind:DocumentaryCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:underlyingTradeReference rdf:type rdf:Property ;
    rdfs:label 'Underlying Trade Reference' ;
    rdfs:comment 'Reference number of the underlying trade transaction, purchase order, or sales contract that this documentary collection supports.' ;
    rdfs:domain ind:DocumentaryCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankGuaranteeId rdf:type rdf:Property ;
    rdfs:label 'Bank Guarantee Id' ;
    rdfs:comment 'Unique identifier for the bank guarantee record. Primary key for the bank guarantee entity.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BankGuarantee .

ind:autoExtensionFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Extension Flag' ;
    rdfs:comment 'Indicates whether the guarantee contains an automatic extension clause. True if the guarantee automatically extends unless the issuing bank provides notice of non-renewal.' ;
    rdfs:domain ind:BankGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:claimDocumentsReceived rdf:type rdf:Property ;
    rdfs:label 'Claim Documents Received' ;
    rdfs:comment 'Description of documents submitted with the claim (e.g., \'Demand letter, Beneficiary certificate, Invoice copies\'). Null if no claim has been made.' ;
    rdfs:domain ind:BankGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Claim Period Days' ;
    rdfs:comment 'Number of days after expiry date during which claims may still be presented, if specified in the guarantee terms. Null if no extended claim period applies.' ;
    rdfs:domain ind:BankGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:claimReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Claim Receipt Date' ;
    rdfs:comment 'Date on which a claim demand was received from the beneficiary. Null if no claim has been made.' ;
    rdfs:domain ind:BankGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:claimSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Claim Sequence Number' ;
    rdfs:comment 'Sequential number of the claim against this guarantee. Null if no claim has been made. Increments with each new claim (supports multiple claims against a single guarantee).' ;
    rdfs:domain ind:BankGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:claimantIdentity rdf:type rdf:Property ;
    rdfs:label 'Claimant Identity' ;
    rdfs:comment 'Name and identification details of the party presenting the claim. Typically the beneficiary or an authorized representative. Null if no claim has been made.' ;
    rdfs:domain ind:BankGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimedAmount rdf:type rdf:Property ;
    rdfs:label 'Claimed Amount' ;
    rdfs:comment 'Amount claimed by the beneficiary in the current or most recent claim. Null if no claim has been made.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commissionRateBps rdf:type rdf:Property ;
    rdfs:label 'Commission Rate Bps' ;
    rdfs:comment 'Annual commission rate charged on the outstanding guarantee amount, expressed in basis points (1 bps = 0.01%).' ;
    rdfs:domain ind:BankGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:counterGuaranteeingBankBic rdf:type rdf:Property ;
    rdfs:label 'Counter Guaranteeing Bank Bic' ;
    rdfs:comment 'SWIFT BIC of the bank providing a counter-guarantee (guarantee backing another guarantee). Applicable only for counter-guarantee arrangements. Null if not a counter-guarantee.' ;
    rdfs:domain ind:BankGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demandIndicator rdf:type rdf:Property ;
    rdfs:label 'Demand Indicator' ;
    rdfs:comment 'Indicates whether the guarantee is payable on first demand (on-demand) or requires proof of default or other conditions (conditional).' ;
    rdfs:domain ind:BankGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guaranteeAmount rdf:type rdf:Property ;
    rdfs:label 'Guarantee Amount' ;
    rdfs:comment 'Face value amount of the bank guarantee. The maximum amount that can be claimed by the beneficiary under the guarantee terms.' ;
    rdfs:domain ind:BankGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:guaranteeCurrency rdf:type rdf:Property ;
    rdfs:label 'Guarantee Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code in which the guarantee amount is denominated.' ;
    rdfs:domain ind:BankGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guaranteeReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Guarantee Reference Number' ;
    rdfs:comment 'Externally-known unique reference number assigned to the bank guarantee or standby letter of credit. Used for identification in correspondence and SWIFT messaging.' ;
    rdfs:domain ind:BankGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guaranteeStatus rdf:type rdf:Property ;
    rdfs:label 'Guarantee Status' ;
    rdfs:comment 'Current lifecycle status of the bank guarantee: draft (being prepared), issued (sent to beneficiary), active (in force), extended (maturity extended), reduced (amount reduced), claimed (demand received), expired (past expiry date), cancelled (terminated before expiry), or released (obligations fulfilled). [ENUM-REF-CANDIDATE: draft|issued|active|extended|reduced|claimed|expired|cancelled|released — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guaranteeType rdf:type rdf:Property ;
    rdfs:label 'Guarantee Type' ;
    rdfs:comment 'Classification of the guarantee instrument: bid bond (tender guarantee), performance bond, advance payment guarantee, retention money guarantee, financial guarantee, standby letter of credit (LC), or counter-guarantee. [ENUM-REF-CANDIDATE: bid_bond|performance_bond|advance_payment_guarantee|retention_money_guarantee|financial_guarantee|standby_lc|counter_guarantee — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuanceDate rdf:type rdf:Property ;
    rdfs:label 'Issuance Date' ;
    rdfs:comment 'Date on which the bank guarantee was formally issued by the issuing bank.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:issuanceFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Issuance Fee Amount' ;
    rdfs:comment 'Fee charged by the issuing bank for issuing the guarantee. Typically a percentage of the guarantee amount.' ;
    rdfs:domain ind:BankGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:issuanceFeeCurrency rdf:type rdf:Property ;
    rdfs:label 'Issuance Fee Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code in which the issuance fee is denominated.' ;
    rdfs:domain ind:BankGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentDecision rdf:type rdf:Property ;
    rdfs:label 'Payment Decision' ;
    rdfs:comment 'Bank\'s decision on the claim: honour (pay the claim), reject (refuse payment with reasons), or extend_or_pay (offer extension in lieu of payment). Null if decision not yet made.' ;
    rdfs:domain ind:BankGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reductionSchedule rdf:type rdf:Property ;
    rdfs:label 'Reduction Schedule' ;
    rdfs:comment 'Description of the schedule by which the guarantee amount reduces over time (e.g., \'Reduce by 10% quarterly\', \'Reduce to 50% after 6 months\'). Null if no reduction schedule applies.' ;
    rdfs:domain ind:BankGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Rejection Notification Date' ;
    rdfs:comment 'Date on which the beneficiary was notified of the claim rejection. Must be within the timeline specified in URDG 758. Null if claim was honoured or not yet decided.' ;
    rdfs:domain ind:BankGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:residualGuaranteeBalance rdf:type rdf:Property ;
    rdfs:label 'Residual Guarantee Balance' ;
    rdfs:comment 'Remaining guarantee amount available after claim payment or reduction. Equals original guarantee amount minus cumulative payments and reductions.' ;
    rdfs:domain ind:BankGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:underlyingContractReference rdf:type rdf:Property ;
    rdfs:label 'Underlying Contract Reference' ;
    rdfs:comment 'Reference number or description of the underlying commercial contract or transaction that the guarantee secures (e.g., construction contract, supply agreement).' ;
    rdfs:domain ind:BankGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:urdgComplianceAssessment rdf:type rdf:Property ;
    rdfs:label 'Urdg Compliance Assessment' ;
    rdfs:comment 'Assessment result of whether the claim complies with URDG 758 Article 20 requirements (complying presentation). Null if no claim has been made.' ;
    rdfs:domain ind:BankGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeDocumentId rdf:type rdf:Property ;
    rdfs:label 'Trade Document Id' ;
    rdfs:comment 'Unique identifier for the trade finance document record. Primary key.' ;
    rdfs:domain ind:TradeDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:guaranteeId rdf:type rdf:Property ;
    rdfs:label 'Guarantee Id' ;
    rdfs:comment 'Reference to the bank guarantee associated with this document. Links to guarantee transactions requiring documentary support.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Guarantee .

ind:compliantFlag rdf:type rdf:Property ;
    rdfs:label 'Compliant Flag' ;
    rdfs:comment 'Indicates whether the document is compliant with the terms and conditions of the LC or guarantee. True if no discrepancies exist, false if discrepancies are present.' ;
    rdfs:domain ind:TradeDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:documentAmount rdf:type rdf:Property ;
    rdfs:label 'Document Amount' ;
    rdfs:comment 'Monetary amount stated on the document. Applicable to commercial invoices, drafts, bills of exchange, and insurance certificates. Must not exceed LC amount.' ;
    rdfs:domain ind:TradeDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:documentHash rdf:type rdf:Property ;
    rdfs:label 'Document Hash' ;
    rdfs:comment 'Cryptographic hash of the document content for integrity verification. Used to detect tampering or alteration of electronic documents.' ;
    rdfs:domain ind:TradeDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Document Reference Number' ;
    rdfs:comment 'Unique external reference number assigned to the trade document by the issuer or presenting party. Used for tracking and reconciliation across parties.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentStatus rdf:type rdf:Property ;
    rdfs:label 'Document Status' ;
    rdfs:comment 'Current lifecycle status of the document in the examination and acceptance workflow. Tracks progression from receipt through compliance review to final disposition. [ENUM-REF-CANDIDATE: received|under_examination|compliant|discrepant|waived|rejected|accepted|returned — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TradeDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:electronicDocumentFlag rdf:type rdf:Property ;
    rdfs:label 'Electronic Document Flag' ;
    rdfs:comment 'Indicates whether the document is presented in electronic form under eUCP rules. True for electronic presentation, false for paper documents.' ;
    rdfs:domain ind:TradeDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:examinationDate rdf:type rdf:Property ;
    rdfs:label 'Examination Date' ;
    rdfs:comment 'Date on which the document examination was completed by the bank. Must occur within five banking days of presentation per UCP 600 Article 14(b).' ;
    rdfs:domain ind:TradeDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:issuerIdentifier rdf:type rdf:Property ;
    rdfs:label 'Issuer Identifier' ;
    rdfs:comment 'Unique identifier or registration number of the issuing party. May include business registration number, carrier code, or agency license number.' ;
    rdfs:domain ind:TradeDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuerName rdf:type rdf:Property ;
    rdfs:label 'Issuer Name' ;
    rdfs:comment 'Name of the party or institution that issued the trade document. May be a carrier, inspection agency, chamber of commerce, insurance company, or beneficiary.' ;
    rdfs:domain ind:TradeDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberOfOriginals rdf:type rdf:Property ;
    rdfs:label 'Number Of Originals' ;
    rdfs:comment 'Count of original documents presented when multiple originals are issued. Common for bills of lading issued in sets of three originals.' ;
    rdfs:domain ind:TradeDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalFlag rdf:type rdf:Property ;
    rdfs:label 'Original Flag' ;
    rdfs:comment 'Indicates whether the document is an original as required by LC terms. True if original, false if copy. Critical for documents like bills of lading where originals are required.' ;
    rdfs:domain ind:TradeDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pageCount rdf:type rdf:Property ;
    rdfs:label 'Page Count' ;
    rdfs:comment 'Total number of pages in the document. Used for completeness verification and audit trail purposes.' ;
    rdfs:domain ind:TradeDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:receivedDate rdf:type rdf:Property ;
    rdfs:label 'Received Date' ;
    rdfs:comment 'Date on which the document was received by the examining bank or presenting party. Marks the start of the examination period under UCP 600 Article 14.' ;
    rdfs:domain ind:TradeDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:storageLocation rdf:type rdf:Property ;
    rdfs:label 'Storage Location' ;
    rdfs:comment 'Physical or electronic storage location reference for the document. May be vault location, document management system path, or cloud storage URI.' ;
    rdfs:domain ind:TradeDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Storage Reference Code' ;
    rdfs:comment 'Unique identifier or key used to retrieve the document from the storage system. Links to document management or imaging system.' ;
    rdfs:domain ind:TradeDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverDate rdf:type rdf:Property ;
    rdfs:label 'Waiver Date' ;
    rdfs:comment 'Date on which the applicant granted waiver of discrepancies and authorized the bank to proceed with payment or acceptance.' ;
    rdfs:domain ind:TradeDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:counterpartyCountryId rdf:type rdf:Property ;
    rdfs:label 'Counterparty Country Id' ;
    rdfs:comment 'Foreign key linking to reference.country. Business justification: AML alert risk scoring depends on counterparty country FATF high-risk and OFAC sanctions flags. The existing `counterparty_country_code` is a denormalized plain-text field; normalizing to a FK enables' ;
    rdfs:domain ind:AmlAlert ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:detectionBranchId rdf:type rdf:Property ;
    rdfs:label 'Detection Branch Id' ;
    rdfs:comment 'Foreign key linking to channel.branch. Business justification: Branch-originated AML alerts require branch attribution for investigation context, regulatory exam support, and branch-level BSA/AML program effectiveness assessment. Critical for targeted examiner re' ;
    rdfs:domain ind:AmlAlert ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Branch .

ind:detectionChannelId rdf:type rdf:Property ;
    rdfs:label 'Detection Channel Id' ;
    rdfs:comment 'Foreign key linking to channel.channel. Business justification: AML alerts must track detection channel (branch, ATM, digital, wire) for BSA/AML regulatory reporting, pattern analysis, and FinCEN SAR filing requirements. Channel attribution is mandatory for regula' ;
    rdfs:domain ind:AmlAlert ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:adverseMediaFlag rdf:type rdf:Property ;
    rdfs:label 'Adverse Media Flag' ;
    rdfs:comment 'Indicator whether adverse media or negative news has been identified for the customer or counterparty during the alert review process.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:alertNarrative rdf:type rdf:Property ;
    rdfs:label 'Alert Narrative' ;
    rdfs:comment 'Detailed narrative generated by the detection system describing the suspicious pattern, transactions, and risk indicators that triggered the alert.' ;
    rdfs:domain ind:AmlAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertNumber rdf:type rdf:Property ;
    rdfs:label 'Alert Number' ;
    rdfs:comment 'Business-facing unique reference number for the alert, typically displayed to analysts and used in case management workflows.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertStatus rdf:type rdf:Property ;
    rdfs:label 'Alert Status' ;
    rdfs:comment 'Current workflow status of the alert in the Level 1 review process (new, assigned to analyst, under review, escalated to case, closed, reopened).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertType rdf:type rdf:Property ;
    rdfs:label 'Alert Type' ;
    rdfs:comment 'Classification of the alert based on the suspicious pattern detected (e.g., structuring, rapid movement of funds, high-risk geography exposure, unusual activity relative to profile). [ENUM-REF-CANDIDATE: structuring|rapid_movement|high_risk_geography|unusual_activity|layering|smurfing|round_tripping|trade_based_laundering|cash_intensive|funnel_account|dormant_reactivation|sanctions_proximity|other — 13 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AmlAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureReason rdf:type rdf:Property ;
    rdfs:label 'Closure Reason' ;
    rdfs:comment 'Explanation provided by the analyst for closing the alert as a false positive or true positive without escalation, documenting the rationale for the disposition.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterpartyName rdf:type rdf:Property ;
    rdfs:label 'Counterparty Name' ;
    rdfs:comment 'Name of the external party or beneficiary involved in the suspicious transactions that triggered the alert, if applicable.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionDate rdf:type rdf:Property ;
    rdfs:label 'Detection Date' ;
    rdfs:comment 'Date when the alert was generated by the AML transaction monitoring system.' ;
    rdfs:domain ind:AmlAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:detectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Detection Timestamp' ;
    rdfs:comment 'Precise timestamp when the alert was generated by the detection engine, capturing the exact moment the threshold or rule was breached.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:disposition rdf:type rdf:Property ;
    rdfs:label 'Disposition' ;
    rdfs:comment 'Final determination of the alert outcome after analyst review: true positive (suspicious activity confirmed), false positive (benign activity), escalated to case for further investigation, or pending review.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:highRiskGeographyFlag rdf:type rdf:Property ;
    rdfs:label 'High Risk Geography Flag' ;
    rdfs:comment 'Indicator whether the alert involves transactions with countries or jurisdictions identified as high-risk for money laundering or terrorist financing per FATF or internal risk ratings.' ;
    rdfs:domain ind:AmlAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riskScore rdf:type rdf:Property ;
    rdfs:label 'Risk Score' ;
    rdfs:comment 'Quantitative risk score assigned by the detection engine indicating the severity or likelihood of money laundering activity, typically on a 0-100 or 0-1000 scale.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaDeadline rdf:type rdf:Property ;
    rdfs:label 'Sla Deadline' ;
    rdfs:comment 'Target date and time by which the alert must be reviewed and dispositioned per internal SLA policies and regulatory requirements.' ;
    rdfs:domain ind:AmlAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalAmount rdf:type rdf:Property ;
    rdfs:label 'Total Amount' ;
    rdfs:comment 'Aggregate monetary value of all transactions associated with the alert, expressed in the account\'s base currency.' ;
    rdfs:domain ind:AmlAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:alertCount rdf:type rdf:Property ;
    rdfs:label 'Alert Count' ;
    rdfs:comment 'Number of AML alerts that were escalated and aggregated into this case.' ;
    rdfs:domain ind:AmlCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedInvestigatorName rdf:type rdf:Property ;
    rdfs:label 'Assigned Investigator Name' ;
    rdfs:comment 'Full name of the compliance officer or investigator assigned to this case.' ;
    rdfs:domain ind:AmlCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseClosedDate rdf:type rdf:Property ;
    rdfs:label 'Case Closed Date' ;
    rdfs:comment 'Date when the AML case investigation was completed and the case was closed.' ;
    rdfs:domain ind:AmlCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:caseClosedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Case Closed Timestamp' ;
    rdfs:comment 'Precise timestamp when the AML case investigation was completed and the case was closed.' ;
    rdfs:domain ind:AmlCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:caseOpenedDate rdf:type rdf:Property ;
    rdfs:label 'Case Opened Date' ;
    rdfs:comment 'Date when the AML case was officially opened for investigation.' ;
    rdfs:domain ind:AmlCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:caseOpenedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Case Opened Timestamp' ;
    rdfs:comment 'Precise timestamp when the AML case was officially opened for investigation.' ;
    rdfs:domain ind:AmlCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:caseType rdf:type rdf:Property ;
    rdfs:label 'Case Type' ;
    rdfs:comment 'Classification of the financial crime case type being investigated.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctrFilingDate rdf:type rdf:Property ;
    rdfs:label 'Ctr Filing Date' ;
    rdfs:comment 'Date when the CTR was filed with FinCEN.' ;
    rdfs:domain ind:AmlCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ctrFilingRequired rdf:type rdf:Property ;
    rdfs:label 'Ctr Filing Required' ;
    rdfs:comment 'Indicates whether a Currency Transaction Report must be filed for this case.' ;
    rdfs:domain ind:AmlCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dispositionOutcome rdf:type rdf:Property ;
    rdfs:label 'Disposition Outcome' ;
    rdfs:comment 'Final outcome or resolution of the case investigation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationNarrative rdf:type rdf:Property ;
    rdfs:label 'Investigation Narrative' ;
    rdfs:comment 'Detailed narrative documenting the investigation findings, analysis, and rationale for case disposition.' ;
    rdfs:domain ind:AmlCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lawEnforcementAgency rdf:type rdf:Property ;
    rdfs:label 'Law Enforcement Agency' ;
    rdfs:comment 'Name of the law enforcement agency to which the case was referred.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lawEnforcementReferral rdf:type rdf:Property ;
    rdfs:label 'Law Enforcement Referral' ;
    rdfs:comment 'Indicates whether the case has been referred to law enforcement agencies for further investigation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ofacScreeningResult rdf:type rdf:Property ;
    rdfs:label 'Ofac Screening Result' ;
    rdfs:comment 'Result of OFAC sanctions screening performed on the parties involved in this case.' ;
    rdfs:domain ind:AmlCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Primary Account Number' ;
    rdfs:comment 'Account number of the primary account involved in the suspicious activity.' ;
    rdfs:domain ind:AmlCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryExaminationFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Examination Flag' ;
    rdfs:comment 'Indicates whether this case has been flagged for regulatory examination or audit review.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewedBy rdf:type rdf:Property ;
    rdfs:label 'Reviewed By' ;
    rdfs:comment 'User ID or name of the senior compliance officer or manager who reviewed and approved the case disposition.' ;
    rdfs:domain ind:AmlCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reviewed Timestamp' ;
    rdfs:comment 'Timestamp when the case was reviewed and approved by senior compliance management.' ;
    rdfs:domain ind:AmlCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sanctionsListMatch rdf:type rdf:Property ;
    rdfs:label 'Sanctions List Match' ;
    rdfs:comment 'Name of the sanctions list (e.g., SDN, EU Sanctions) if a match was identified during screening.' ;
    rdfs:domain ind:AmlCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sarFilingRequired rdf:type rdf:Property ;
    rdfs:label 'Sar Filing Required' ;
    rdfs:comment 'Indicates whether a Suspicious Activity Report must be filed with FinCEN for this case.' ;
    rdfs:domain ind:AmlCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalTransactionAmount rdf:type rdf:Property ;
    rdfs:label 'Total Transaction Amount' ;
    rdfs:comment 'Aggregate monetary value of all transactions under investigation in this case.' ;
    rdfs:domain ind:AmlCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:documentIssuingCountryId rdf:type rdf:Property ;
    rdfs:label 'Document Issuing Country Id' ;
    rdfs:comment 'Foreign key linking to reference.country. Business justification: KYC reviews validate identity documents issued by specific countries; country AML risk rating, FATF status, sanctions flags, and document verification standards inform due diligence level and approval' ;
    rdfs:domain ind:KycReview ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:kycJurisdictionId rdf:type rdf:Property ;
    rdfs:label 'Kyc Jurisdiction Id' ;
    rdfs:comment 'Foreign key linking to reference.jurisdiction. Business justification: KYC due diligence levels (standard, enhanced, simplified) are mandated by jurisdiction-specific AML regulations (EU AMLD5/6, FinCEN CDD Rule). Linking kyc_review to jurisdiction enables jurisdiction-d' ;
    rdfs:domain ind:KycReview ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Jurisdiction .

ind:reviewBranchId rdf:type rdf:Property ;
    rdfs:label 'Review Branch Id' ;
    rdfs:comment 'Foreign key linking to channel.branch. Business justification: KYC/CIP reviews initiated at a branch (new account opening, enhanced due diligence) require branch-level attribution for CIP compliance reporting, branch exam findings, and BSA officer oversight. Exis' ;
    rdfs:domain ind:KycReview ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Branch .

ind:reviewChannelId rdf:type rdf:Property ;
    rdfs:label 'Review Channel Id' ;
    rdfs:comment 'Foreign key linking to channel.channel. Business justification: KYC reviews track review channel (branch meeting, digital document upload, mail) for audit trail completeness, regulatory examination support, and CDD program effectiveness assessment. Required for de' ;
    rdfs:domain ind:KycReview ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:assignedAnalystName rdf:type rdf:Property ;
    rdfs:label 'Assigned Analyst Name' ;
    rdfs:comment 'Full name of the compliance analyst assigned to this review for audit trail and accountability.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficialOwnerIdentified rdf:type rdf:Property ;
    rdfs:label 'Beneficial Owner Identified' ;
    rdfs:comment 'Indicates whether ultimate beneficial owners (UBOs) have been identified and documented for corporate customers, as required by CDD regulations.' ;
    rdfs:domain ind:KycReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:documentExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Document Expiry Date' ;
    rdfs:comment 'Expiration date of the document, if applicable. Null for documents without expiry (e.g., birth certificates).' ;
    rdfs:domain ind:KycReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentIssueDate rdf:type rdf:Property ;
    rdfs:label 'Document Issue Date' ;
    rdfs:comment 'Date when the document was originally issued by the authority.' ;
    rdfs:domain ind:KycReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentationCompletenessFlag rdf:type rdf:Property ;
    rdfs:label 'Documentation Completeness Flag' ;
    rdfs:comment 'Indicates whether all required documentation for the due diligence level has been collected and verified. True if complete, False if incomplete.' ;
    rdfs:domain ind:KycReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dueDiligenceLevel rdf:type rdf:Property ;
    rdfs:label 'Due Diligence Level' ;
    rdfs:comment 'Level of due diligence applied: SDD (Simplified Due Diligence), CDD (Customer Due Diligence), or EDD (Enhanced Due Diligence). Determines the depth and frequency of review.' ;
    rdfs:domain ind:KycReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outstandingDocumentList rdf:type rdf:Property ;
    rdfs:label 'Outstanding Document List' ;
    rdfs:comment 'Comma-separated list of document types still required to complete the KYC review. Null if documentation is complete.' ;
    rdfs:domain ind:KycReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewApprovedDate rdf:type rdf:Property ;
    rdfs:label 'Review Approved Date' ;
    rdfs:comment 'Date when the completed KYC review was formally approved by the authorized approver.' ;
    rdfs:domain ind:KycReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Review Completed Date' ;
    rdfs:comment 'Actual date when the KYC review was completed and all required documentation was verified.' ;
    rdfs:domain ind:KycReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewCycleNumber rdf:type rdf:Property ;
    rdfs:label 'Review Cycle Number' ;
    rdfs:comment 'Sequential number indicating which periodic review cycle this represents for the party (e.g., 1st annual review, 2nd annual review).' ;
    rdfs:domain ind:KycReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewInitiatedDate rdf:type rdf:Property ;
    rdfs:label 'Review Initiated Date' ;
    rdfs:comment 'Date when the KYC review was formally initiated or triggered.' ;
    rdfs:domain ind:KycReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:riskRatingChangeReason rdf:type rdf:Property ;
    rdfs:label 'Risk Rating Change Reason' ;
    rdfs:comment 'Explanation for any change in risk rating from previous to current, documenting the rationale for the adjustment.' ;
    rdfs:domain ind:KycReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:systemOfRecord rdf:type rdf:Property ;
    rdfs:label 'System Of Record' ;
    rdfs:comment 'The source system where this KYC review record was originally created (e.g., NICE Actimize, Oracle Financial Crime, internal KYC platform).' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primarySanctionsPartyId rdf:type rdf:Property ;
    rdfs:label 'Primary Sanctions Party Id' ;
    rdfs:comment 'Identifier of the entity being screened (customer, counterparty, payment beneficiary, correspondent bank).' ;
    rdfs:domain ind:SanctionsScreeningEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:sanctionsListEntryId rdf:type rdf:Property ;
    rdfs:label 'Sanctions List Entry Id' ;
    rdfs:comment 'Unique identifier of the specific watchlist entry that matched.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SanctionsListEntry .

ind:screenedAccountDepositAccountId rdf:type rdf:Property ;
    rdfs:label 'Screened Account Deposit Account Id' ;
    rdfs:comment 'Foreign key linking to account.deposit_account. Business justification: Account opening and transaction screening require account-level linkage. Screened_entity_id(unlinked) represents various entity types; explicit account FK enables account screening event queries for O' ;
    rdfs:domain ind:SanctionsScreeningEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DepositAccount .

ind:screenedEntityCountryId rdf:type rdf:Property ;
    rdfs:label 'Screened Entity Country Id' ;
    rdfs:comment 'Foreign key linking to reference.country. Business justification: Sanctions screening requires knowing the screened entity\'s country to apply the correct sanctions program (OFAC, EU, UN). Country-level FATF high-risk and OFAC sanctions flags directly determine scree' ;
    rdfs:domain ind:SanctionsScreeningEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:screeningBranchId rdf:type rdf:Property ;
    rdfs:label 'Screening Branch Id' ;
    rdfs:comment 'Foreign key linking to channel.branch. Business justification: Sanctions screening events triggered at a branch (e.g., teller-initiated wire transfer) require branch-level attribution for BSA officer review, branch exam scoping, and FinCEN reporting. Existing FK ' ;
    rdfs:domain ind:SanctionsScreeningEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Branch .

ind:screeningChannelId rdf:type rdf:Property ;
    rdfs:label 'Screening Channel Id' ;
    rdfs:comment 'Foreign key linking to channel.channel. Business justification: Sanctions screening events track channel context (payment channel, account opening channel, wire transfer) for OFAC reporting, blocking action implementation, and channel-specific screening rule confi' ;
    rdfs:domain ind:SanctionsScreeningEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:screeningJurisdictionId rdf:type rdf:Property ;
    rdfs:label 'Screening Jurisdiction Id' ;
    rdfs:comment 'Foreign key linking to reference.jurisdiction. Business justification: Sanctions screening is conducted under specific jurisdictional sanctions regimes (OFAC for US, EU Consolidated List, UN Security Council). The screening_jurisdiction_id determines which sanctions prog' ;
    rdfs:domain ind:SanctionsScreeningEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Jurisdiction .

ind:analystReviewNotes rdf:type rdf:Property ;
    rdfs:label 'Analyst Review Notes' ;
    rdfs:comment 'Detailed notes and rationale documented by the compliance analyst during review of the sanctions match.' ;
    rdfs:domain ind:SanctionsScreeningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analystReviewRequired rdf:type rdf:Property ;
    rdfs:label 'Analyst Review Required' ;
    rdfs:comment 'Indicates whether the screening result requires manual analyst review.' ;
    rdfs:domain ind:SanctionsScreeningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:blockingActionTaken rdf:type rdf:Property ;
    rdfs:label 'Blocking Action Taken' ;
    rdfs:comment 'Indicates whether a blocking action was taken on the transaction or relationship due to the sanctions match.' ;
    rdfs:domain ind:SanctionsScreeningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:blockingActionType rdf:type rdf:Property ;
    rdfs:label 'Blocking Action Type' ;
    rdfs:comment 'Specific type of blocking action taken in response to the sanctions match.' ;
    rdfs:domain ind:SanctionsScreeningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Escalation Timestamp' ;
    rdfs:comment 'Date and time when the screening event was escalated to a higher authority.' ;
    rdfs:domain ind:SanctionsScreeningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:falsePositiveIndicator rdf:type rdf:Property ;
    rdfs:label 'False Positive Indicator' ;
    rdfs:comment 'Indicates whether the sanctions match was determined to be a false positive after investigation.' ;
    rdfs:domain ind:SanctionsScreeningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:matchedListType rdf:type rdf:Property ;
    rdfs:label 'Matched List Type' ;
    rdfs:comment 'Category of the watchlist where the match was identified.' ;
    rdfs:domain ind:SanctionsScreeningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ofacReportFiled rdf:type rdf:Property ;
    rdfs:label 'Ofac Report Filed' ;
    rdfs:comment 'Indicates whether a blocking report was filed with OFAC for this sanctions match.' ;
    rdfs:domain ind:SanctionsScreeningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ofacReportFilingDate rdf:type rdf:Property ;
    rdfs:label 'Ofac Report Filing Date' ;
    rdfs:comment 'Date when the OFAC blocking report was filed.' ;
    rdfs:domain ind:SanctionsScreeningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryHoldApplied rdf:type rdf:Property ;
    rdfs:label 'Regulatory Hold Applied' ;
    rdfs:comment 'Indicates whether a regulatory hold was placed on the entity or transaction due to the sanctions match.' ;
    rdfs:domain ind:SanctionsScreeningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryHoldDetails rdf:type rdf:Property ;
    rdfs:label 'Regulatory Hold Details' ;
    rdfs:comment 'Detailed information about the regulatory hold including scope, duration, and legal basis.' ;
    rdfs:domain ind:SanctionsScreeningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sarFiled rdf:type rdf:Property ;
    rdfs:label 'Sar Filed' ;
    rdfs:comment 'Indicates whether a Suspicious Activity Report was filed with FinCEN as a result of this screening event.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:screenedEntityName rdf:type rdf:Property ;
    rdfs:label 'Screened Entity Name' ;
    rdfs:comment 'Name of the entity submitted for sanctions screening.' ;
    rdfs:domain ind:SanctionsScreeningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screenedEntityType rdf:type rdf:Property ;
    rdfs:label 'Screened Entity Type' ;
    rdfs:comment 'Type of entity being screened for sanctions compliance.' ;
    rdfs:domain ind:SanctionsScreeningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningSystemCode rdf:type rdf:Property ;
    rdfs:label 'Screening System Code' ;
    rdfs:comment 'Identifier of the sanctions screening system that performed the screening (e.g., NICE Actimize, Oracle Financial Crime).' ;
    rdfs:domain ind:SanctionsScreeningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningTrigger rdf:type rdf:Property ;
    rdfs:label 'Screening Trigger' ;
    rdfs:comment 'Business event that triggered the sanctions screening.' ;
    rdfs:domain ind:SanctionsScreeningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningType rdf:type rdf:Property ;
    rdfs:label 'Screening Type' ;
    rdfs:comment 'Type of screening workflow executed (real-time payment screening, batch customer screening, event-driven screening).' ;
    rdfs:domain ind:SanctionsScreeningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:watchlistConsulted rdf:type rdf:Property ;
    rdfs:label 'Watchlist Consulted' ;
    rdfs:comment 'Comma-separated list of sanctions watchlists consulted during screening (OFAC SDN, EU Consolidated, UN Security Council, HMT, internal high-risk).' ;
    rdfs:domain ind:SanctionsScreeningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:watchlistLastRefreshDate rdf:type rdf:Property ;
    rdfs:label 'Watchlist Last Refresh Date' ;
    rdfs:comment 'Date when the sanctions watchlist was last updated or refreshed.' ;
    rdfs:domain ind:SanctionsScreeningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:examinedChannelId rdf:type rdf:Property ;
    rdfs:label 'Examined Channel Id' ;
    rdfs:comment 'Foreign key linking to channel.channel. Business justification: Regulatory exams often scope specific channels (branch network BSA exam, digital banking security exam, ATM ADA compliance). Exam findings and MRAs cite channel scope for targeted remediation and foll' ;
    rdfs:domain ind:RegulatoryExam ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:assetQualityRating rdf:type rdf:Property ;
    rdfs:label 'Asset Quality Rating' ;
    rdfs:comment 'The CAMELS component rating for asset quality. Evaluates credit risk, loan portfolio quality, and adequacy of loan loss reserves. Scale of 1 (strongest) to 5 (weakest).' ;
    rdfs:domain ind:RegulatoryExam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capitalAdequacyRating rdf:type rdf:Property ;
    rdfs:label 'Capital Adequacy Rating' ;
    rdfs:comment 'The CAMELS component rating for capital adequacy. Assesses the quantity and quality of capital relative to risk profile. Scale of 1 (strongest) to 5 (weakest).' ;
    rdfs:domain ind:RegulatoryExam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compositeRating rdf:type rdf:Property ;
    rdfs:label 'Composite Rating' ;
    rdfs:comment 'The overall composite rating assigned to the institution based on the CAMELS rating system (Capital adequacy, Asset quality, Management, Earnings, Liquidity, Sensitivity to market risk). Scale of 1 (strongest) to 5 (weakest).' ;
    rdfs:domain ind:RegulatoryExam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialFlag rdf:type rdf:Property ;
    rdfs:label 'Confidential Flag' ;
    rdfs:comment 'Indicates whether the examination report and findings are subject to confidential supervisory information restrictions and cannot be publicly disclosed.' ;
    rdfs:domain ind:RegulatoryExam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:earningsRating rdf:type rdf:Property ;
    rdfs:label 'Earnings Rating' ;
    rdfs:comment 'The CAMELS component rating for earnings performance. Evaluates profitability, earnings quality, and sustainability of earnings. Scale of 1 (strongest) to 5 (weakest).' ;
    rdfs:domain ind:RegulatoryExam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enforcementActionFlag rdf:type rdf:Property ;
    rdfs:label 'Enforcement Action Flag' ;
    rdfs:comment 'Indicates whether the examination resulted in or is associated with a formal enforcement action such as a consent order, cease and desist order, or civil money penalty.' ;
    rdfs:domain ind:RegulatoryExam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:examMethodology rdf:type rdf:Property ;
    rdfs:label 'Exam Methodology' ;
    rdfs:comment 'The approach or format used to conduct the examination. Specifies whether examiners conducted the review on-site at the institution, remotely off-site, or using a hybrid approach.' ;
    rdfs:domain ind:RegulatoryExam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:examNotes rdf:type rdf:Property ;
    rdfs:label 'Exam Notes' ;
    rdfs:comment 'Free-form text field for capturing additional notes, observations, or context related to the examination engagement that do not fit into structured fields.' ;
    rdfs:domain ind:RegulatoryExam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:examNumber rdf:type rdf:Property ;
    rdfs:label 'Exam Number' ;
    rdfs:comment 'The official examination number or reference code assigned by the regulatory agency. This is the externally-known identifier used in all regulatory correspondence and documentation.' ;
    rdfs:domain ind:RegulatoryExam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:examPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Exam Period End Date' ;
    rdfs:comment 'The ending date of the period under examination. Defines the end of the lookback window for transactions, controls, and activities being reviewed.' ;
    rdfs:domain ind:RegulatoryExam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:examPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Exam Period Start Date' ;
    rdfs:comment 'The beginning date of the period under examination. Defines the start of the lookback window for transactions, controls, and activities being reviewed.' ;
    rdfs:domain ind:RegulatoryExam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:examPriority rdf:type rdf:Property ;
    rdfs:label 'Exam Priority' ;
    rdfs:comment 'The priority classification of the examination. Indicates whether this is a routine supervisory cycle exam, a targeted review of specific risks, a for-cause examination due to concerns, or a follow-up to prior findings.' ;
    rdfs:domain ind:RegulatoryExam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:examScope rdf:type rdf:Property ;
    rdfs:label 'Exam Scope' ;
    rdfs:comment 'Detailed description of the examination scope, including specific business lines, processes, systems, or risk areas to be reviewed. Defines the boundaries and focus areas for the examination engagement.' ;
    rdfs:domain ind:RegulatoryExam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:examStatus rdf:type rdf:Property ;
    rdfs:label 'Exam Status' ;
    rdfs:comment 'Current lifecycle state of the regulatory examination. Tracks the examination from initial scheduling through final closure and response completion.' ;
    rdfs:domain ind:RegulatoryExam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:examTeamSize rdf:type rdf:Property ;
    rdfs:label 'Exam Team Size' ;
    rdfs:comment 'The total number of examiners assigned to the examination engagement. Indicates the scale and resource commitment of the regulatory review.' ;
    rdfs:domain ind:RegulatoryExam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:examType rdf:type rdf:Property ;
    rdfs:label 'Exam Type' ;
    rdfs:comment 'The category or focus area of the regulatory examination. Defines the primary scope and regulatory framework under which the examination is conducted.' ;
    rdfs:domain ind:RegulatoryExam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exitMeetingDate rdf:type rdf:Property ;
    rdfs:label 'Exit Meeting Date' ;
    rdfs:comment 'The date of the formal exit meeting or closing conference between examiners and institution management. Represents the date when preliminary findings were discussed.' ;
    rdfs:domain ind:RegulatoryExam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fieldworkEndDate rdf:type rdf:Property ;
    rdfs:label 'Fieldwork End Date' ;
    rdfs:comment 'The date when on-site or remote examination fieldwork activities concluded. Marks the completion of active data gathering and testing by examiners.' ;
    rdfs:domain ind:RegulatoryExam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fieldworkStartDate rdf:type rdf:Property ;
    rdfs:label 'Fieldwork Start Date' ;
    rdfs:comment 'The date when on-site or remote examination fieldwork activities commenced. Marks the beginning of active examiner engagement with the institution.' ;
    rdfs:domain ind:RegulatoryExam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:findingsCount rdf:type rdf:Property ;
    rdfs:label 'Findings Count' ;
    rdfs:comment 'The total number of examination findings, matters requiring attention, or deficiencies identified during the examination. Quantifies the volume of issues discovered.' ;
    rdfs:domain ind:RegulatoryExam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:internalCoordinatorEmail rdf:type rdf:Property ;
    rdfs:label 'Internal Coordinator Email' ;
    rdfs:comment 'The email address of the internal bank coordinator responsible for managing examination logistics and information requests.' ;
    rdfs:domain ind:RegulatoryExam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalCoordinatorName rdf:type rdf:Property ;
    rdfs:label 'Internal Coordinator Name' ;
    rdfs:comment 'The name of the internal bank employee or officer designated as the primary coordinator and liaison for the examination engagement.' ;
    rdfs:domain ind:RegulatoryExam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadExaminerEmail rdf:type rdf:Property ;
    rdfs:label 'Lead Examiner Email' ;
    rdfs:comment 'The official email address of the lead examiner for examination-related correspondence and communication.' ;
    rdfs:domain ind:RegulatoryExam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadExaminerName rdf:type rdf:Property ;
    rdfs:label 'Lead Examiner Name' ;
    rdfs:comment 'The full name of the lead examiner or examiner-in-charge responsible for overseeing the examination engagement. Primary point of contact from the regulatory agency.' ;
    rdfs:domain ind:RegulatoryExam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadExaminerPhone rdf:type rdf:Property ;
    rdfs:label 'Lead Examiner Phone' ;
    rdfs:comment 'The direct phone number of the lead examiner for examination-related inquiries and coordination.' ;
    rdfs:domain ind:RegulatoryExam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liquidityRating rdf:type rdf:Property ;
    rdfs:label 'Liquidity Rating' ;
    rdfs:comment 'The CAMELS component rating for liquidity position. Assesses funding stability, liquidity risk management, and ability to meet obligations. Scale of 1 (strongest) to 5 (weakest).' ;
    rdfs:domain ind:RegulatoryExam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managementRating rdf:type rdf:Property ;
    rdfs:label 'Management Rating' ;
    rdfs:comment 'The CAMELS component rating for management capability. Assesses board and management oversight, risk management practices, and compliance culture. Scale of 1 (strongest) to 5 (weakest).' ;
    rdfs:domain ind:RegulatoryExam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mattersRequiringAttentionCount rdf:type rdf:Property ;
    rdfs:label 'Matters Requiring Attention Count' ;
    rdfs:comment 'The number of Matters Requiring Attention (MRA) or Matters Requiring Board Attention (MRBA) formally cited in the examination report. Represents significant supervisory concerns requiring corrective action.' ;
    rdfs:domain ind:RegulatoryExam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reportIssueDate rdf:type rdf:Property ;
    rdfs:label 'Report Issue Date' ;
    rdfs:comment 'The date the final examination report was officially issued by the regulatory agency. Marks the formal delivery of findings and recommendations to the institution.' ;
    rdfs:domain ind:RegulatoryExam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responseDueDate rdf:type rdf:Property ;
    rdfs:label 'Response Due Date' ;
    rdfs:comment 'The deadline by which the institution must submit its formal written response to examination findings and proposed corrective action plans.' ;
    rdfs:domain ind:RegulatoryExam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responseSubmittedDate rdf:type rdf:Property ;
    rdfs:label 'Response Submitted Date' ;
    rdfs:comment 'The date the institution submitted its formal written response to the examination findings and corrective action plans to the regulatory agency.' ;
    rdfs:domain ind:RegulatoryExam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sensitivityRating rdf:type rdf:Property ;
    rdfs:label 'Sensitivity Rating' ;
    rdfs:comment 'The CAMELS component rating for sensitivity to market risk. Evaluates exposure to interest rate risk, foreign exchange risk, and other market risks. Scale of 1 (strongest) to 5 (weakest).' ;
    rdfs:domain ind:RegulatoryExam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingBranchId rdf:type rdf:Property ;
    rdfs:label 'Filing Branch Id' ;
    rdfs:comment 'Foreign key linking to channel.branch. Business justification: CTR and SAR filings require conducting location (branch) as mandatory FinCEN BSA E-Filing field. Branch attribution enables filing accuracy validation, branch-level BSA program assessment, and regulat' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Branch .

ind:filingJurisdictionId rdf:type rdf:Property ;
    rdfs:label 'Filing Jurisdiction Id' ;
    rdfs:comment 'Foreign key linking to reference.jurisdiction. Business justification: Regulatory filings (SARs, CTRs, FATCA, CRS) are submitted to specific jurisdictional regulators (FinCEN, FCA, BaFin). The filing_jurisdiction_id links each filing to its governing jurisdiction, enabli' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Jurisdiction .

ind:filingLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Filing Legal Entity Id' ;
    rdfs:comment 'Foreign key linking to ledger.legal_entity. Business justification: Regulatory filings (FATCA, CRS, FR Y-9C, call reports) are submitted by specific legal entities. The filing legal entity is a required regulatory field. Role-prefixed to distinguish from subject_party' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:subjectPartyId rdf:type rdf:Property ;
    rdfs:label 'Subject Party Id' ;
    rdfs:comment 'Foreign key linking to customer.party. Business justification: SARs, CTRs, and FATCA filings must identify the specific customer party involved. Regulatory reporting requires structured party linkage for FinCEN submissions and audit validation. Removes denormaliz' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:accountBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Account Balance Amount' ;
    rdfs:comment 'Account balance or value as of the end of the FATCA or CRS reporting year. This is the total value of financial assets held in the account, including deposits, securities, and other investments.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accountHolderTin rdf:type rdf:Property ;
    rdfs:label 'Account Holder Tin' ;
    rdfs:comment 'Tax identification number of the account holder for FATCA or CRS reporting. For U.S. persons, this is the Social Security Number (SSN) or Employer Identification Number (EIN). For foreign persons, this is the foreign tax identification number.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acknowledgmentDate rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Date' ;
    rdfs:comment 'Date on which the regulatory agency acknowledged receipt of the filing. For FinCEN filings, this is the date the BSA E-Filing System confirms successful submission.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Submission Date' ;
    rdfs:comment 'Date on which the filing was actually submitted to the regulatory agency. Used to track timeliness and compliance with submission deadlines.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conductingPartyIdentifier rdf:type rdf:Property ;
    rdfs:label 'Conducting Party Identifier' ;
    rdfs:comment 'Unique identifier for the conducting party, such as driver\'s license number, passport number, or other government-issued identification. Required for CTR filings to verify the identity of the person conducting the transaction.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conductingPartyName rdf:type rdf:Property ;
    rdfs:label 'Conducting Party Name' ;
    rdfs:comment 'Name of the individual or entity that conducted the transaction reported in a CTR filing. This is the person who physically presented the currency or initiated the transaction.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityFlag rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Flag' ;
    rdfs:comment 'Boolean flag indicating whether this filing contains confidential or sensitive information that requires special handling and access controls. True = confidential, False = standard handling. SAR filings are always confidential by law.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exemptionStatus rdf:type rdf:Property ;
    rdfs:label 'Exemption Status' ;
    rdfs:comment 'Indicates whether the transaction or customer is exempt from CTR reporting requirements under FinCEN exemption rules. Phase I exemptions apply to banks and government entities. Phase II exemptions apply to certain non-listed businesses and payroll customers.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fatcaJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Fatca Jurisdiction' ;
    rdfs:comment 'Three-letter ISO country code representing the jurisdiction to which FATCA or CRS reporting is submitted. For FATCA, this is typically the jurisdiction of the foreign financial institution. For CRS, this is the jurisdiction of the account holder\'s tax residency.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fatcaReportingYear rdf:type rdf:Property ;
    rdfs:label 'Fatca Reporting Year' ;
    rdfs:comment 'Calendar year for which FATCA or CRS reporting is being submitted. FATCA requires annual reporting of financial accounts held by U.S. persons at foreign financial institutions, and CRS requires reporting of accounts held by foreign tax residents.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:filingStatus rdf:type rdf:Property ;
    rdfs:label 'Filing Status' ;
    rdfs:comment 'Current lifecycle status of the regulatory filing. Draft = initial preparation, Pending Review = awaiting internal approval, Approved = cleared for submission, Submitted = sent to regulatory agency, Acknowledged = receipt confirmed by agency, Rejected = returned by agency for correction, Amended = corrected version submitted, Withdrawn = filing cancelled. [ENUM-REF-CANDIDATE: Draft|Pending Review|Approved|Submitted|Acknowledged|Rejected|Amended|Withdrawn — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fincenTrackingNumber rdf:type rdf:Property ;
    rdfs:label 'Fincen Tracking Number' ;
    rdfs:comment 'Unique tracking number assigned by FinCEN upon successful submission of a BSA filing (SAR, CTR, FBAR, Form 8300). This number is used for all subsequent correspondence and inquiries regarding the filing.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incomeAmount rdf:type rdf:Property ;
    rdfs:label 'Income Amount' ;
    rdfs:comment 'Total income paid or credited to the account during the FATCA or CRS reporting year. Includes interest, dividends, gross proceeds from sales, and other income types as defined by FATCA and CRS regulations.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preparerContactPhone rdf:type rdf:Property ;
    rdfs:label 'Preparer Contact Phone' ;
    rdfs:comment 'Phone number of the preparer for follow-up inquiries by the regulatory agency. Required on many regulatory filings to facilitate communication.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorFilingReference rdf:type rdf:Property ;
    rdfs:label 'Prior Filing Reference' ;
    rdfs:comment 'Reference number or tracking identifier of the original filing that this amendment or correction is replacing. Required when amendment_indicator is True.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAgency rdf:type rdf:Property ;
    rdfs:label 'Regulatory Agency' ;
    rdfs:comment 'Governing body or regulatory authority to which the filing is submitted. FinCEN = Financial Crimes Enforcement Network, Fed = Federal Reserve System, OCC = Office of the Comptroller of the Currency, FDIC = Federal Deposit Insurance Corporation, SEC = Securities and Exchange Commission, FINRA = Financial Industry Regulatory Authority, CFTC = Commodity Futures Trading Commission, CFPB = Consumer Financial Protection Bureau, IRS = Internal Revenue Service, EBA = European Banking Authority, PRA = Prudential Regulation Authority. [ENUM-REF-CANDIDATE: FinCEN|Fed|OCC|FDIC|SEC|FINRA|CFTC|CFPB|IRS|EBA|PRA — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Reporting Period End Date' ;
    rdfs:comment 'End date of the period covered by this regulatory filing. For periodic filings, this is the last day of the reporting quarter or year. For event-driven filings, this may represent the end of the activity window or the date of the reportable event.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Start Date' ;
    rdfs:comment 'Start date of the period covered by this regulatory filing. For periodic filings (Call Report, FR Y-9C), this is the beginning of the reporting quarter or year. For event-driven filings (SAR, CTR), this may represent the start of the activity window.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:retentionExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Retention Expiration Date' ;
    rdfs:comment 'Date on which the regulatory filing record is eligible for archival or deletion based on regulatory retention requirements. BSA records must be retained for 5 years from the date of filing. Other filings may have different retention periods.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:submissionDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Submission Deadline Date' ;
    rdfs:comment 'Regulatory deadline by which the filing must be submitted to the governing body. Failure to meet this deadline may result in penalties, fines, or enforcement actions.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:submissionMethod rdf:type rdf:Property ;
    rdfs:label 'Submission Method' ;
    rdfs:comment 'Technical method or channel used to submit the filing to the regulatory agency. BSA E-Filing = FinCEN\'s electronic filing system, FRB E-Filing = Federal Reserve electronic submission, SEC EDGAR = SEC\'s Electronic Data Gathering Analysis and Retrieval system, FINRA Gateway = FINRA\'s submission portal, Manual Upload = web-based manual submission, API = application programming interface, SFTP = secure file transfer protocol. [ENUM-REF-CANDIDATE: BSA E-Filing|FRB E-Filing|SEC EDGAR|FINRA Gateway|Manual Upload|API|SFTP — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suspiciousActivityAmount rdf:type rdf:Property ;
    rdfs:label 'Suspicious Activity Amount' ;
    rdfs:comment 'Total dollar amount involved in the suspicious activity reported in a SAR filing. Represents the cumulative value of transactions or account activity that triggered the filing.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:suspiciousActivityDescription rdf:type rdf:Property ;
    rdfs:label 'Suspicious Activity Description' ;
    rdfs:comment 'Detailed narrative description of the suspicious activity, including facts, circumstances, and reasons for suspicion. This is the free-text explanation provided in Part V of the SAR form and is critical for law enforcement review.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suspiciousActivityType rdf:type rdf:Property ;
    rdfs:label 'Suspicious Activity Type' ;
    rdfs:comment 'Classification of the type of suspicious activity reported in a SAR filing. Examples include structuring, money laundering, terrorist financing, fraud, identity theft, elder financial exploitation, cyber event, or other financial crimes. [ENUM-REF-CANDIDATE: Structuring|Money Laundering|Terrorist Financing|Fraud|Identity Theft|Elder Financial Exploitation|Cyber Event|Bribery/Corruption|Embezzlement|Check Fraud|Wire Fraud|ACH Fraud|Credit Card Fraud|Mortgage Loan Fraud|Consumer Loan Fraud|Trade-Based Money Laundering|Bulk Cash Smuggling|Funnel Account|Unlicensed Money Services Business|Other — promote to reference product]' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByObligationId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Obligation Id' ;
    rdfs:comment 'Reference to the obligation ID that supersedes or replaces this obligation, if applicable. Used to track regulatory changes and obligation evolution. Null if not superseded.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Obligation .

ind:applicabilityScope rdf:type rdf:Property ;
    rdfs:label 'Applicability Scope' ;
    rdfs:comment 'Textual description of the scope of applicability within the bank: which lines of business (LOB), product types, geographies, or legal entities this obligation applies to (e.g., \'All retail banking operations in USA\', \'Investment banking M&A advisory\', \'All deposit accounts\').' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:automationLevel rdf:type rdf:Property ;
    rdfs:label 'Automation Level' ;
    rdfs:comment 'The degree to which compliance monitoring and reporting for this obligation is automated: fully automated (no manual intervention), partially automated (some manual steps), manual (entirely manual process), or hybrid (combination of automated and manual).' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceFrequency rdf:type rdf:Property ;
    rdfs:label 'Compliance Frequency' ;
    rdfs:comment 'The frequency at which compliance with this obligation must be demonstrated or reported: continuous monitoring, daily, weekly, monthly, quarterly, semi-annual, annual, ad-hoc, or event-driven. [ENUM-REF-CANDIDATE: continuous|daily|weekly|monthly|quarterly|semi_annual|annual|ad_hoc|event_driven — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Status' ;
    rdfs:comment 'Current assessment of the bank\'s compliance with this obligation: compliant (fully meeting requirements), non-compliant (failing to meet requirements), partially compliant (meeting some but not all requirements), not assessed (no recent assessment), in remediation (actively addressing gaps), or exempt (granted exemption or waiver).' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlObjective rdf:type rdf:Property ;
    rdfs:label 'Control Objective' ;
    rdfs:comment 'The high-level control objective or purpose this obligation is designed to achieve (e.g., \'Prevent money laundering and terrorist financing\', \'Ensure capital adequacy\', \'Protect customer data privacy\', \'Maintain accurate financial reporting\').' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationProcedure rdf:type rdf:Property ;
    rdfs:label 'Escalation Procedure' ;
    rdfs:comment 'Description of the escalation path and procedures to follow when non-compliance is identified or when issues arise (e.g., \'Escalate to Chief Compliance Officer within 24 hours\', \'Notify Board Risk Committee for critical violations\').' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceRequirement rdf:type rdf:Property ;
    rdfs:label 'Evidence Requirement' ;
    rdfs:comment 'Description of the documentation, records, or evidence that must be maintained to demonstrate compliance with this obligation (e.g., \'Transaction monitoring reports\', \'SAR filing confirmations\', \'Board meeting minutes\', \'Audit trails\').' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:examFindings rdf:type rdf:Property ;
    rdfs:label 'Exam Findings' ;
    rdfs:comment 'Summary of findings, observations, or matters requiring attention (MRA) from the most recent regulatory examination related to this obligation.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalAuditFlag rdf:type rdf:Property ;
    rdfs:label 'External Audit Flag' ;
    rdfs:comment 'Boolean indicator of whether this obligation is subject to external audit or regulatory examination (True) or is only internally monitored (False).' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:implementationGuidance rdf:type rdf:Property ;
    rdfs:label 'Implementation Guidance' ;
    rdfs:comment 'Summary of implementation guidance, best practices, or internal procedures for meeting this obligation. May reference internal policy documents or control procedures.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Assessment Date' ;
    rdfs:comment 'The date of the most recent compliance assessment or audit for this obligation.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastRegulatoryExamDate rdf:type rdf:Property ;
    rdfs:label 'Last Regulatory Exam Date' ;
    rdfs:comment 'The date of the most recent regulatory examination or supervisory review that covered this obligation.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Next Assessment Date' ;
    rdfs:comment 'The scheduled date for the next compliance assessment or review of this obligation.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:obligationCode rdf:type rdf:Property ;
    rdfs:label 'Obligation Code' ;
    rdfs:comment 'Business-assigned unique code or reference number for the obligation, used for external identification and regulatory mapping (e.g., BSA-AML-001, FATCA-2023-05).' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationDescription rdf:type rdf:Property ;
    rdfs:label 'Obligation Description' ;
    rdfs:comment 'Detailed narrative description of the obligation, including the specific requirement, scope, and what the bank must do to comply.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationStatus rdf:type rdf:Property ;
    rdfs:label 'Obligation Status' ;
    rdfs:comment 'Current lifecycle status of the obligation: active (in force), inactive (not currently applicable), pending (awaiting effective date), superseded (replaced by newer obligation), under review (being assessed), or retired (no longer applicable).' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationType rdf:type rdf:Property ;
    rdfs:label 'Obligation Type' ;
    rdfs:comment 'Classification of the obligation by its nature: regulatory reporting (e.g., CCAR, DFAST), operational control (e.g., SOX control), policy requirement, supervisory guidance, legal mandate, or contractual obligation.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:owner rdf:type rdf:Property ;
    rdfs:label 'Owner' ;
    rdfs:comment 'Name or identifier of the business unit, department, or individual responsible for ensuring compliance with this obligation (e.g., \'Chief Compliance Officer\', \'AML Compliance Team\', \'Risk Management Division\').' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerEmail rdf:type rdf:Property ;
    rdfs:label 'Owner Email' ;
    rdfs:comment 'Primary email contact for the obligation owner or responsible party.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyDescription rdf:type rdf:Property ;
    rdfs:label 'Penalty Description' ;
    rdfs:comment 'Description of potential penalties, fines, sanctions, or consequences for non-compliance with this obligation (e.g., \'Civil monetary penalties up to $1M per violation\', \'Regulatory enforcement action\', \'License suspension\').' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productTypeApplicability rdf:type rdf:Property ;
    rdfs:label 'Product Type Applicability' ;
    rdfs:comment 'Comma-separated list of product types to which this obligation applies (e.g., \'Demand Deposit Accounts\', \'Mortgage Loans\', \'Derivatives\', \'Securities Trading\'). Null if applicable to all products.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationPlan rdf:type rdf:Property ;
    rdfs:label 'Remediation Plan' ;
    rdfs:comment 'Summary of the current remediation plan or corrective actions being taken to address any compliance gaps. Null if fully compliant.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingRequirement rdf:type rdf:Property ;
    rdfs:label 'Reporting Requirement' ;
    rdfs:comment 'Description of any regulatory reporting obligations associated with this requirement (e.g., \'Quarterly CCAR submission\', \'Annual FATCA reporting\', \'SAR filing within 30 days of detection\').' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:title rdf:type rdf:Property ;
    rdfs:label 'Title' ;
    rdfs:comment 'Short, human-readable title or name of the regulatory obligation (e.g., \'Customer Due Diligence Requirements\', \'Suspicious Activity Reporting\').' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updatedBy rdf:type rdf:Property ;
    rdfs:label 'Updated By' ;
    rdfs:comment 'Identifier of the user or system that last updated this obligation record.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskRatingId rdf:type rdf:Property ;
    rdfs:label 'Risk Rating Id' ;
    rdfs:comment 'Unique identifier for the customer risk rating record. Primary key for this entity.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RiskRating .

ind:adverseInformationRiskScore rdf:type rdf:Property ;
    rdfs:label 'Adverse Information Risk Score' ;
    rdfs:comment 'Risk score component based on adverse media findings, sanctions screening hits, Politically Exposed Person (PEP) status, and negative news. Scale 0-100.' ;
    rdfs:domain ind:RiskRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adverseMediaSummary rdf:type rdf:Property ;
    rdfs:label 'Adverse Media Summary' ;
    rdfs:comment 'Summary of adverse media findings identified during screening, including source, date, and nature of the negative news.' ;
    rdfs:domain ind:RiskRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cddTierRequired rdf:type rdf:Property ;
    rdfs:label 'Cdd Tier Required' ;
    rdfs:comment 'Level of Customer Due Diligence (CDD) required based on the assigned risk tier: simplified for low-risk, standard for medium-risk, enhanced for high-risk and very-high-risk customers.' ;
    rdfs:domain ind:RiskRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerTypeRiskScore rdf:type rdf:Property ;
    rdfs:label 'Customer Type Risk Score' ;
    rdfs:comment 'Risk score component based on customer type classification (individual, corporate, Politically Exposed Person (PEP), non-profit, money services business). Scale 0-100.' ;
    rdfs:domain ind:RiskRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:kycReviewFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Kyc Review Frequency Months' ;
    rdfs:comment 'Frequency in months for mandatory Know Your Customer (KYC) refresh reviews. Typically 12 months for low-risk, 6 months for medium-risk, 3 months for high-risk customers.' ;
    rdfs:domain ind:RiskRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overrideJustification rdf:type rdf:Property ;
    rdfs:label 'Override Justification' ;
    rdfs:comment 'Detailed justification narrative for any manual override of the model-recommended risk tier. Required when override_indicator is true.' ;
    rdfs:domain ind:RiskRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorRiskTier rdf:type rdf:Property ;
    rdfs:label 'Prior Risk Tier' ;
    rdfs:comment 'Previous risk tier assigned to this customer before the current rating. Used to track risk rating migration and escalation trends.' ;
    rdfs:domain ind:RiskRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Rating Reference Number' ;
    rdfs:comment 'Business-facing unique reference number for this risk rating assessment, used for audit trails and regulatory reporting.' ;
    rdfs:domain ind:RiskRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipExitConsiderationFlag rdf:type rdf:Property ;
    rdfs:label 'Relationship Exit Consideration Flag' ;
    rdfs:comment 'Flag indicating whether the risk profile is severe enough to warrant consideration of customer relationship termination or exit.' ;
    rdfs:domain ind:RiskRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riskTierChangeDate rdf:type rdf:Property ;
    rdfs:label 'Risk Tier Change Date' ;
    rdfs:comment 'Date on which the risk tier changed from the prior tier to the current tier. Null if this is the initial rating.' ;
    rdfs:domain ind:RiskRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:riskTierChangeReason rdf:type rdf:Property ;
    rdfs:label 'Risk Tier Change Reason' ;
    rdfs:comment 'Explanation of the reason for the risk tier change, such as change in transaction behavior, new adverse information, or geographic risk escalation.' ;
    rdfs:domain ind:RiskRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sarFilingConsiderationFlag rdf:type rdf:Property ;
    rdfs:label 'Sar Filing Consideration Flag' ;
    rdfs:comment 'Flag indicating whether the risk rating assessment identified activity warranting consideration for Suspicious Activity Report (SAR) filing.' ;
    rdfs:domain ind:RiskRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transactionBehaviorRiskScore rdf:type rdf:Property ;
    rdfs:label 'Transaction Behavior Risk Score' ;
    rdfs:comment 'Risk score component based on transaction volume, velocity, complexity, and deviation from expected activity profile. Scale 0-100.' ;
    rdfs:domain ind:RiskRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:caseId rdf:type rdf:Property ;
    rdfs:label 'Case Id' ;
    rdfs:comment 'Primary key for case' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:detectionRuleId rdf:type rdf:Property ;
    rdfs:label 'Detection Rule Id' ;
    rdfs:comment 'Foreign key linking to fraud.detection_rule. Business justification: A fraud case is opened based on a detection rule trigger. case.fraud_detection_method (STRING) captures the detection method name, but a FK to detection_rule provides structured access to rule configu' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DetectionRule .

ind:investigationBranchId rdf:type rdf:Property ;
    rdfs:label 'Investigation Branch Id' ;
    rdfs:comment 'Foreign key linking to channel.branch. Business justification: Complex fraud cases may require branch-based investigation (safe deposit box fraud, teller collusion, check fraud, cash vault discrepancies). Links case to physical location for evidence collection, s' ;
    rdfs:domain ind:Case ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Branch .

ind:assignedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assigned Timestamp' ;
    rdfs:comment 'Date and time when the case was assigned to an investigator. Used for SLA tracking and workload analytics.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:chargebackInitiatedFlag rdf:type rdf:Property ;
    rdfs:label 'Chargeback Initiated Flag' ;
    rdfs:comment 'Indicates whether a chargeback was initiated with the card network or payment processor for loss recovery.' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:closedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Closed Timestamp' ;
    rdfs:comment 'Date and time when the case was closed. Nullable for open cases. Used for cycle time and resolution metrics.' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:confirmedLossAmount rdf:type rdf:Property ;
    rdfs:label 'Confirmed Loss Amount' ;
    rdfs:comment 'Final confirmed financial loss amount after investigation completion. Used for regulatory reporting and loss provisioning. Expressed in base currency.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerReimbursedFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Reimbursed Flag' ;
    rdfs:comment 'Indicates whether the affected customer was reimbursed for their loss. Used for customer satisfaction and regulatory compliance tracking.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dispositionReason rdf:type rdf:Property ;
    rdfs:label 'Disposition Reason' ;
    rdfs:comment 'Detailed narrative explanation of the disposition outcome. Captures investigator findings and supporting rationale.' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedLossAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Loss Amount' ;
    rdfs:comment 'Initial estimated financial loss amount at case opening. May be revised during investigation. Expressed in base currency.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fraudDetectionMethod rdf:type rdf:Property ;
    rdfs:label 'Fraud Detection Method' ;
    rdfs:comment 'The method or system that initially detected the fraud. Used to measure detection effectiveness and optimize fraud controls.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudRingIndicator rdf:type rdf:Property ;
    rdfs:label 'Fraud Ring Indicator' ;
    rdfs:comment 'Indicates whether this case is part of an identified organized fraud ring or syndicate. Used for pattern analysis and network investigation.' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insuranceClaimFiledFlag rdf:type rdf:Property ;
    rdfs:label 'Insurance Claim Filed Flag' ;
    rdfs:comment 'Indicates whether an insurance claim was filed for fraud loss recovery under the banks fraud insurance policy.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:investigationNotes rdf:type rdf:Property ;
    rdfs:label 'Investigation Notes' ;
    rdfs:comment 'Free-text field capturing investigator observations, findings, and case narrative. Confidential investigative work product.' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lawEnforcementReferralFlag rdf:type rdf:Property ;
    rdfs:label 'Law Enforcement Referral Flag' ;
    rdfs:comment 'Indicates whether the case was referred to law enforcement agencies for criminal investigation or prosecution.' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:openedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Opened Timestamp' ;
    rdfs:comment 'Date and time when the fraud case was initially opened in the case management system. Marks the start of the investigation lifecycle.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recoveredAmount rdf:type rdf:Property ;
    rdfs:label 'Recovered Amount' ;
    rdfs:comment 'Total amount recovered through chargeback, insurance claim, or legal action. Used to calculate net loss. Expressed in base currency.' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reimbursementAmount rdf:type rdf:Property ;
    rdfs:label 'Reimbursement Amount' ;
    rdfs:comment 'Total amount reimbursed to the customer. Nullable if no reimbursement was made. Expressed in base currency.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reimbursementDate rdf:type rdf:Property ;
    rdfs:label 'Reimbursement Date' ;
    rdfs:comment 'Date when the customer reimbursement was processed. Nullable if no reimbursement was made. Used for SLA compliance tracking.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:severity rdf:type rdf:Property ;
    rdfs:label 'Severity' ;
    rdfs:comment 'Risk-based severity classification reflecting potential financial and reputational impact. Level 1 is highest severity.' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTargetCloseDate rdf:type rdf:Property ;
    rdfs:label 'Sla Target Close Date' ;
    rdfs:comment 'Target date by which the case should be closed based on SLA policy and case priority. Used for workload planning and escalation.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fundTransactionId rdf:type rdf:Property ;
    rdfs:label 'Fund Transaction Id' ;
    rdfs:comment 'Foreign key linking to asset.fund_transaction. Business justification: Fraud alerts are triggered by suspicious fund transactions (unusual redemption patterns, rapid switching, structuring). AML and fraud monitoring systems generate alerts on specific fund transactions r' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FundTransaction .

ind:merchantIndustryCodeId rdf:type rdf:Property ;
    rdfs:label 'Merchant Industry Code Id' ;
    rdfs:comment 'Foreign key linking to reference.industry_code. Business justification: Alerts link merchant categories to industry risk profiles for fraud typology detection, high-risk MCC flagging, and rule tuning. Essential for card fraud detection. New FK replaces denormalized MCC co' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IndustryCode .

ind:transactionChannelId rdf:type rdf:Property ;
    rdfs:label 'Transaction Channel Id' ;
    rdfs:comment 'Foreign key linking to channel.channel. Business justification: Fraud alerts capture the channel where suspicious transactions occurred for pattern analysis and channel-specific fraud detection tuning. Essential for fraud operations teams analyzing fraud by channe' ;
    rdfs:domain ind:Alert ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:triggeringInteractionId rdf:type rdf:Property ;
    rdfs:label 'Triggering Interaction Id' ;
    rdfs:comment 'Foreign key linking to channel.interaction. Business justification: Fraud alerts are triggered by specific interactions (ATM withdrawal, wire transfer, mobile deposit). Linking enables interaction replay for investigations, employee review (insider fraud detection), f' ;
    rdfs:domain ind:Alert ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Interaction .

ind:triggeringPriceId rdf:type rdf:Property ;
    rdfs:label 'Triggering Price Id' ;
    rdfs:comment 'Foreign key linking to security.price. Business justification: Price surveillance systems generate fraud alerts when instrument prices deviate anomalously (price manipulation, spoofing, layering detection). The specific price observation that triggered the alert ' ;
    rdfs:domain ind:Alert ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Price .

ind:cardNumberLastFour rdf:type rdf:Property ;
    rdfs:label 'Card Number Last Four' ;
    rdfs:comment 'Last four digits of the payment card number involved in the alert, used for identification without exposing full PCI data.' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerContactTimestamp rdf:type rdf:Property ;
    rdfs:label 'Customer Contact Timestamp' ;
    rdfs:comment 'Date and time when the customer was contacted regarding the fraud alert.' ;
    rdfs:domain ind:Alert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:customerContactedFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Contacted Flag' ;
    rdfs:comment 'Boolean indicator of whether the customer was contacted during the alert investigation for verification or additional information.' ;
    rdfs:domain ind:Alert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerResponse rdf:type rdf:Property ;
    rdfs:label 'Customer Response' ;
    rdfs:comment 'Classification of the customers response when contacted about the alert, indicating whether they confirmed the transaction as legitimate or fraudulent.' ;
    rdfs:domain ind:Alert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionMethod rdf:type rdf:Property ;
    rdfs:label 'Detection Method' ;
    rdfs:comment 'The detection mechanism or source that generated the fraud alert, indicating whether it was triggered by automated rules, ML models, behavioral analytics, or external sources.' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionCode rdf:type rdf:Property ;
    rdfs:label 'Disposition Code' ;
    rdfs:comment 'Final outcome classification assigned by the analyst after investigation, indicating whether the alert represents genuine fraud, a false positive, or requires further action.' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geolocationCity rdf:type rdf:Property ;
    rdfs:label 'Geolocation City' ;
    rdfs:comment 'City name derived from IP geolocation or transaction metadata, used for anomaly detection and travel pattern analysis.' ;
    rdfs:domain ind:Alert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lossAmount rdf:type rdf:Property ;
    rdfs:label 'Loss Amount' ;
    rdfs:comment 'Confirmed monetary loss amount resulting from the fraud event, if the alert was dispositioned as confirmed fraud. Used for loss reporting and recovery tracking.' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:merchantName rdf:type rdf:Property ;
    rdfs:label 'Merchant Name' ;
    rdfs:comment 'Name of the merchant or counterparty involved in the transaction that triggered the fraud alert, if applicable.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Review Completed Timestamp' ;
    rdfs:comment 'Date and time when the fraud analyst completed the investigation and assigned a final disposition to the alert.' ;
    rdfs:domain ind:Alert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reviewStartedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Review Started Timestamp' ;
    rdfs:comment 'Date and time when the fraud analyst began reviewing the alert, marking the transition from new to under review status.' ;
    rdfs:domain ind:Alert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:score rdf:type rdf:Property ;
    rdfs:label 'Score' ;
    rdfs:comment 'Numeric risk score assigned by the detection engine indicating the likelihood of fraud, typically ranging from 0 to 100 or 0 to 999 depending on model configuration.' ;
    rdfs:domain ind:Alert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionChannel rdf:type rdf:Property ;
    rdfs:label 'Transaction Channel' ;
    rdfs:comment 'The channel or interface through which the triggering transaction was initiated (e.g., online banking, mobile app, ATM, branch, point-of-sale). [ENUM-REF-CANDIDATE: online|mobile|atm|branch|phone|mail|pos — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Alert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationId rdf:type rdf:Property ;
    rdfs:label 'Investigation Id' ;
    rdfs:comment 'Primary key for investigation' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Investigation .

ind:evidenceInteractionId rdf:type rdf:Property ;
    rdfs:label 'Evidence Interaction Id' ;
    rdfs:comment 'Foreign key linking to channel.interaction. Business justification: Fraud investigations collect interaction records as evidence. Linking enables audit trail reconstruction, regulatory exam support (demonstrating transaction monitoring controls), litigation evidence p' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Interaction .

ind:evidenceSessionId rdf:type rdf:Property ;
    rdfs:label 'Evidence Session Id' ;
    rdfs:comment 'Foreign key linking to channel.session. Business justification: Fraud investigations collect session data as evidence. Linking enables chain-of-custody tracking, legal hold management, courtroom evidence presentation, regulatory exam support, and forensic timeline' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Session .

ind:incidentId rdf:type rdf:Property ;
    rdfs:label 'Incident Id' ;
    rdfs:comment 'Foreign key linking to fraud.fraud_incident. Business justification: An investigation can focus on a specific fraud incident within the broader case. N:1 relationship. No bidirectional conflict (fraud_incident does not have investigation_id FK back). Investigation trac' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Incident .

ind:previousInvestigationId rdf:type rdf:Property ;
    rdfs:label 'Previous Investigation Id' ;
    rdfs:comment 'Reference to the preceding investigation phase in a multi-phase investigation workflow. Null for initial investigation phase.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Investigation .

ind:sarFilingId rdf:type rdf:Property ;
    rdfs:label 'Sar Filing Id' ;
    rdfs:comment 'Foreign key linking to fraud.sar_filing. Business justification: An investigation that escalates to a SAR filing should reference the resulting sar_filing record directly. investigation.sar_escalation_flag and sar_filing_date are denormalized; the FK to sar_filing ' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SarFiling .

ind:customerNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Date' ;
    rdfs:comment 'Date when the customer was notified of the investigation outcome. Null if customer notification has not occurred.' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dispositionRationale rdf:type rdf:Property ;
    rdfs:label 'Disposition Rationale' ;
    rdfs:comment 'Detailed explanation of the reasoning behind the recommended disposition. Supports audit trail and regulatory review.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceItemsCount rdf:type rdf:Property ;
    rdfs:label 'Evidence Items Count' ;
    rdfs:comment 'Total number of evidence items collected and catalogued during this investigation (e.g., transaction records, device logs, interview transcripts, surveillance footage).' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:evidenceSummary rdf:type rdf:Property ;
    rdfs:label 'Evidence Summary' ;
    rdfs:comment 'High-level summary of key evidence gathered during the investigation. Used for case review and escalation briefings.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingsNarrative rdf:type rdf:Property ;
    rdfs:label 'Findings Narrative' ;
    rdfs:comment 'Detailed narrative of investigation findings, analysis, and conclusions. Forms the basis for disposition recommendations and SAR (Suspicious Activity Report) narratives.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudLossAmount rdf:type rdf:Property ;
    rdfs:label 'Fraud Loss Amount' ;
    rdfs:comment 'Total monetary loss attributed to the fraud as determined by the investigation. Expressed in the banks base currency.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interviewConductedFlag rdf:type rdf:Property ;
    rdfs:label 'Interview Conducted Flag' ;
    rdfs:comment 'Indicates whether a formal customer or witness interview was conducted as part of this investigation.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interviewDate rdf:type rdf:Property ;
    rdfs:label 'Interview Date' ;
    rdfs:comment 'Date when the customer or witness interview was conducted. Null if no interview was performed.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:interviewNotes rdf:type rdf:Property ;
    rdfs:label 'Interview Notes' ;
    rdfs:comment 'Summary notes from customer or witness interviews conducted during the investigation. May include key statements, admissions, or denials.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationNumber rdf:type rdf:Property ;
    rdfs:label 'Investigation Number' ;
    rdfs:comment 'Business-facing unique investigation identifier used for tracking and reporting. Typically system-generated with prefix INV- followed by numeric sequence.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationStatus rdf:type rdf:Property ;
    rdfs:label 'Investigation Status' ;
    rdfs:comment 'Current operational status of the investigation within its phase. Indicates whether the investigation is actively being worked, pending review, escalated, or completed.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lawEnforcementCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Law Enforcement Case Number' ;
    rdfs:comment 'Case or incident number assigned by the law enforcement agency for tracking the criminal investigation.' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:multiPhaseInvestigationFlag rdf:type rdf:Property ;
    rdfs:label 'Multi Phase Investigation Flag' ;
    rdfs:comment 'Indicates whether this investigation is part of a multi-phase investigation requiring sequential stages with different investigators or specialized skill sets.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:phase rdf:type rdf:Property ;
    rdfs:label 'Phase' ;
    rdfs:comment 'Current phase of the investigation workflow. Tracks progression from initial review through deep investigation, potential legal referral, SAR (Suspicious Activity Report) escalation, or closure.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendedDisposition rdf:type rdf:Property ;
    rdfs:label 'Recommended Disposition' ;
    rdfs:comment 'Investigators recommended outcome or disposition for the case based on investigation findings. Determines next steps including SAR filing, legal action, or case closure.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sarEscalationFlag rdf:type rdf:Property ;
    rdfs:label 'Sar Escalation Flag' ;
    rdfs:comment 'Indicates whether this investigation has been escalated for SAR (Suspicious Activity Report) filing to FinCEN due to suspicious activity meeting regulatory thresholds.' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:team rdf:type rdf:Property ;
    rdfs:label 'Team' ;
    rdfs:comment 'Name or code of the specialized fraud investigation team handling this case (e.g., Card Fraud Unit, Wire Fraud Unit, AML Investigation Team).' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:debtIssuanceId rdf:type rdf:Property ;
    rdfs:label 'Debt Issuance Id' ;
    rdfs:comment 'Foreign key linking to treasury.debt_issuance. Business justification: Securities issuance fraud investigation: prospectus fraud, fictitious bond issuances, and unauthorized debt issuances are recognized securities fraud typologies. Linking fraud_incident to the specific' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DebtIssuance .

ind:subjectId rdf:type rdf:Property ;
    rdfs:label 'Subject Id' ;
    rdfs:comment 'Foreign key linking to fraud.subject. Business justification: A fraud incident involves a specific fraud subject (the perpetrator or suspected fraudster). fraud_incident already has party_id → customer.party (cross-domain), but subject is the fraud-domain entity' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Subject .

ind:transactionCountryId rdf:type rdf:Property ;
    rdfs:label 'Transaction Country Id' ;
    rdfs:comment 'Foreign key linking to reference.country. Business justification: Incidents track transaction location for cross-border fraud pattern analysis, jurisdiction determination, and country-level risk reporting. Core fraud investigation and reporting requirement. New FK r' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:chargebackDate rdf:type rdf:Property ;
    rdfs:label 'Chargeback Date' ;
    rdfs:comment 'Date when the chargeback was filed for this fraud incident, if applicable.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:chargebackFlag rdf:type rdf:Property ;
    rdfs:label 'Chargeback Flag' ;
    rdfs:comment 'Indicates whether a chargeback was initiated for this fraud incident (True) or not (False).' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerReportedFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Reported Flag' ;
    rdfs:comment 'Indicates whether the fraud incident was reported by the customer (True) or detected by internal systems (False).' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incidentDescription rdf:type rdf:Property ;
    rdfs:label 'Incident Description' ;
    rdfs:comment 'Detailed narrative description of the fraudulent event, including circumstances, methods used, and any relevant context for investigation.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentStatus rdf:type rdf:Property ;
    rdfs:label 'Incident Status' ;
    rdfs:comment 'Current lifecycle status of the fraud incident within the investigation workflow.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Incident Timestamp' ;
    rdfs:comment 'Date and time when the fraudulent event occurred or was first detected. Represents the real-world event time of the fraudulent act.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:investigationCloseDate rdf:type rdf:Property ;
    rdfs:label 'Investigation Close Date' ;
    rdfs:comment 'Date when the investigation of this fraud incident was completed and closed.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:investigationStartDate rdf:type rdf:Property ;
    rdfs:label 'Investigation Start Date' ;
    rdfs:comment 'Date when the formal investigation of this fraud incident began.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lawEnforcementNotifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Law Enforcement Notified Flag' ;
    rdfs:comment 'Indicates whether law enforcement authorities were notified about this fraud incident (True) or not (False).' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resolutionNotes rdf:type rdf:Property ;
    rdfs:label 'Resolution Notes' ;
    rdfs:comment 'Detailed notes documenting the investigation findings, resolution actions taken, and final disposition rationale.' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionLocation rdf:type rdf:Property ;
    rdfs:label 'Transaction Location' ;
    rdfs:comment 'Geographic location where the fraudulent transaction occurred (city, state, country) or IP address for online transactions.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeChannelId rdf:type rdf:Property ;
    rdfs:label 'Dispute Channel Id' ;
    rdfs:comment 'Foreign key linking to channel.channel. Business justification: Chargebacks document the channel where the disputed transaction occurred. Required for chargeback representment (channel-specific evidence requirements), network dispute resolution, channel-specific f' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:originalInteractionId rdf:type rdf:Property ;
    rdfs:label 'Original Interaction Id' ;
    rdfs:comment 'Foreign key linking to channel.interaction. Business justification: Chargebacks reference the original transaction interaction for representment evidence (signed receipts, authorization codes, delivery confirmation, EMV chip data). Critical for chargeback defense, net' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Interaction .

ind:acquirerBin rdf:type rdf:Property ;
    rdfs:label 'Acquirer Bin' ;
    rdfs:comment 'Bank Identification Number of the acquiring bank that processed the original transaction. Identifies the financial institution responsible for the merchant relationship.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arbitrationFiledDate rdf:type rdf:Property ;
    rdfs:label 'Arbitration Filed Date' ;
    rdfs:comment 'The date when either party escalated the dispute to formal arbitration with the card network.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cardNetwork rdf:type rdf:Property ;
    rdfs:label 'Card Network' ;
    rdfs:comment 'The payment card network that governs the chargeback dispute process (e.g., Visa, Mastercard, American Express). Each network has distinct rules and timelines.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargebackStatus rdf:type rdf:Property ;
    rdfs:label 'Chargeback Status' ;
    rdfs:comment 'Current processing status of the chargeback within the current stage. Indicates whether the chargeback is awaiting action, under investigation, or has reached a decision point.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeAmount rdf:type rdf:Property ;
    rdfs:label 'Dispute Amount' ;
    rdfs:comment 'The monetary amount being disputed in the chargeback, typically matching the original transaction amount or a portion thereof.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fee rdf:type rdf:Property ;
    rdfs:label 'Fee' ;
    rdfs:comment 'Administrative fee charged by the card network or acquiring bank for processing the chargeback. Typically ranges from $15 to $100 depending on the network and merchant agreement.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fraudIndicator rdf:type rdf:Property ;
    rdfs:label 'Fraud Indicator' ;
    rdfs:comment 'Boolean flag indicating whether the chargeback is related to confirmed or suspected fraudulent activity. True if the chargeback reason code indicates fraud.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:initiatedDate rdf:type rdf:Property ;
    rdfs:label 'Initiated Date' ;
    rdfs:comment 'The date when the chargeback was first initiated by the cardholder or issuing bank.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:issuerBin rdf:type rdf:Property ;
    rdfs:label 'Issuer Bin' ;
    rdfs:comment 'Bank Identification Number of the card-issuing bank. Identifies the financial institution that issued the payment card to the cardholder.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maskedCardNumber rdf:type rdf:Property ;
    rdfs:label 'Masked Card Number' ;
    rdfs:comment 'Partially masked payment card number (e.g., ****1234) used to identify the card while maintaining PCI DSS compliance. Only the last four digits are visible.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Network Case Number' ;
    rdfs:comment 'Unique case identifier assigned by the payment card network (Visa, Mastercard, Amex) for tracking the chargeback through the network dispute resolution process.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalTransactionAmount rdf:type rdf:Property ;
    rdfs:label 'Original Transaction Amount' ;
    rdfs:comment 'The full amount of the original transaction that is subject to the chargeback dispute.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalTransactionCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Original Transaction Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the original transaction amount.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalTransactionDate rdf:type rdf:Property ;
    rdfs:label 'Original Transaction Date' ;
    rdfs:comment 'The date when the original disputed transaction was processed.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:representmentFiledDate rdf:type rdf:Property ;
    rdfs:label 'Representment Filed Date' ;
    rdfs:comment 'The date when the merchant or acquiring bank filed a representment (rebuttal) to challenge the chargeback.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:resolutionDate rdf:type rdf:Property ;
    rdfs:label 'Resolution Date' ;
    rdfs:comment 'The date when the chargeback dispute reached final resolution, either through acceptance, reversal, or arbitration decision.' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:resolutionOutcome rdf:type rdf:Property ;
    rdfs:label 'Resolution Outcome' ;
    rdfs:comment 'Final outcome of the chargeback dispute. Cardholder favor means the chargeback stands; merchant favor means the chargeback was reversed; partial reversal indicates a compromise; withdrawn means the cardholder retracted the dispute; expired means no response was filed within the deadline.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Response Deadline Date' ;
    rdfs:comment 'The date by which the bank or merchant must respond to the chargeback to avoid automatic acceptance. Deadlines are typically set by card network rules (e.g., 30-45 days).' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sarFiledIndicator rdf:type rdf:Property ;
    rdfs:label 'Sar Filed Indicator' ;
    rdfs:comment 'Boolean flag indicating whether a Suspicious Activity Report was filed with FinCEN in connection with this chargeback due to suspected fraud or money laundering.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stage rdf:type rdf:Property ;
    rdfs:label 'Stage' ;
    rdfs:comment 'Current stage in the chargeback dispute lifecycle. First chargeback is the initial dispute; representment is the merchant\'s response; pre-arbitration and arbitration are escalation stages; closed indicates final resolution.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activityCountryId rdf:type rdf:Property ;
    rdfs:label 'Activity Country Id' ;
    rdfs:comment 'Foreign key linking to reference.country. Business justification: SAR filings must identify the country where suspicious activity occurred for cross-border AML reporting to FinCEN/FATF. Role-prefixed activity_country_id distinguishes the activity location from the f' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:amendedSarSarFilingId rdf:type rdf:Property ;
    rdfs:label 'Amended Sar Sar Filing Id' ;
    rdfs:comment 'Reference to the original SAR filing that this record amends, if amendment_flag is true.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SarFiling .

ind:primarySarAmlCaseId rdf:type rdf:Property ;
    rdfs:label 'Primary Sar Aml Case Id' ;
    rdfs:comment 'Foreign key linking to compliance.aml_case. Business justification: SARs filed by fraud teams reference the originating AML case for regulatory coordination. Banks track which AML case triggered the SAR for audit trail, regulatory exams, and FinCEN reporting consisten' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Case .

ind:activityDescription rdf:type rdf:Property ;
    rdfs:label 'Activity Description' ;
    rdfs:comment 'Detailed narrative description of the suspicious activity, including facts, patterns, and rationale for filing the SAR. This is the core investigative summary.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentFlag rdf:type rdf:Property ;
    rdfs:label 'Amendment Flag' ;
    rdfs:comment 'Indicates whether this SAR filing is an amendment to a previously filed SAR.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:filingDate rdf:type rdf:Property ;
    rdfs:label 'Filing Date' ;
    rdfs:comment 'Date when the SAR was officially filed with FinCEN. This is the principal business event timestamp for the SAR filing.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:filingDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Filing Deadline Date' ;
    rdfs:comment 'Regulatory deadline by which the SAR must be filed with FinCEN, typically 30 days from initial detection of suspicious activity.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:filingInstitutionContactName rdf:type rdf:Property ;
    rdfs:label 'Filing Institution Contact Name' ;
    rdfs:comment 'Name of the individual at the filing institution who can be contacted regarding this SAR.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingInstitutionContactPhone rdf:type rdf:Property ;
    rdfs:label 'Filing Institution Contact Phone' ;
    rdfs:comment 'Phone number of the filing institution contact person for follow-up inquiries.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Filing Timestamp' ;
    rdfs:comment 'Precise timestamp when the SAR was submitted to FinCEN\'s BSA E-Filing system.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fincenAcknowledgmentDate rdf:type rdf:Property ;
    rdfs:label 'Fincen Acknowledgment Date' ;
    rdfs:comment 'Date when FinCEN acknowledged receipt and acceptance of the SAR filing.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fincenBsaReference rdf:type rdf:Property ;
    rdfs:label 'Fincen Bsa Reference' ;
    rdfs:comment 'Unique identifier assigned by FinCEN upon successful submission and acknowledgment of the SAR filing.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lawEnforcementAgencyName rdf:type rdf:Property ;
    rdfs:label 'Law Enforcement Agency Name' ;
    rdfs:comment 'Name of the law enforcement agency contacted or involved in the investigation of this suspicious activity.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lawEnforcementContactDate rdf:type rdf:Property ;
    rdfs:label 'Law Enforcement Contact Date' ;
    rdfs:comment 'Date when law enforcement was contacted regarding this suspicious activity, if applicable.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priorSarReference rdf:type rdf:Property ;
    rdfs:label 'Prior Sar Reference' ;
    rdfs:comment 'Reference to any prior SAR filings related to the same subject or activity, enabling continuity tracking.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sarNumber rdf:type rdf:Property ;
    rdfs:label 'Sar Number' ;
    rdfs:comment 'Business identifier for the SAR filing, typically assigned by the financial institution\'s SAR management system.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sarType rdf:type rdf:Property ;
    rdfs:label 'Sar Type' ;
    rdfs:comment 'Classification of the SAR based on the primary suspicious activity driver. This entity focuses on fraud-originated SARs distinct from compliance AML SARs.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suspiciousActivityEndDate rdf:type rdf:Property ;
    rdfs:label 'Suspicious Activity End Date' ;
    rdfs:comment 'Date when the suspicious activity being reported ended or was last observed. Nullable for ongoing activity.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:suspiciousActivityStartDate rdf:type rdf:Property ;
    rdfs:label 'Suspicious Activity Start Date' ;
    rdfs:comment 'Date when the suspicious activity being reported first began or was first detected.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:suspiciousActivityTypeCode rdf:type rdf:Property ;
    rdfs:label 'Suspicious Activity Type Code' ;
    rdfs:comment 'FinCEN-defined code(s) categorizing the type of suspicious activity. Multiple codes may be concatenated or stored as delimited list. [ENUM-REF-CANDIDATE: fraud_card|fraud_ach|fraud_wire|fraud_check|fraud_identity_theft|fraud_account_takeover|fraud_elder_financial_exploitation|fraud_mortgage|fraud_consumer_loan|fraud_commercial_loan|fraud_securities|fraud_insurance|fraud_other — promote to reference product]' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalSuspiciousAmount rdf:type rdf:Property ;
    rdfs:label 'Total Suspicious Amount' ;
    rdfs:comment 'Aggregate monetary value of all transactions or activity deemed suspicious and reported in this SAR.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lossRecoveryId rdf:type rdf:Property ;
    rdfs:label 'Loss Recovery Id' ;
    rdfs:comment 'Unique identifier for the loss recovery record. Primary key for the loss recovery entity.' ;
    rdfs:domain ind:LossRecovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:claimId rdf:type rdf:Property ;
    rdfs:label 'Claim Id' ;
    rdfs:comment 'Foreign key linking to fraud.claim. Business justification: Loss recovery tracks the financial recovery lifecycle for fraud losses, which are often initiated by customer claims. Linking loss_recovery.claim_id → claim establishes the direct operational relation' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Claim .

ind:lossJournalEntryId rdf:type rdf:Property ;
    rdfs:label 'Loss Journal Entry Id' ;
    rdfs:comment 'Foreign key linking to ledger.journal_entry. Business justification: Fraud loss recognition requires a journal entry to book the gross loss to the GL (distinct from the chargeback\'s GL entry). Basel operational risk ILDC and CCAR loss data collection require tracing ea' ;
    rdfs:domain ind:LossRecovery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntry .

ind:baselEventTypeCode rdf:type rdf:Property ;
    rdfs:label 'Basel Event Type Code' ;
    rdfs:comment 'Basel III operational risk event type classification code. Fraud losses typically fall under Level 1 Event Type 1 (Internal Fraud) or 3 (Clients, Products & Business Practices).' ;
    rdfs:domain ind:LossRecovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessLine rdf:type rdf:Property ;
    rdfs:label 'Business Line' ;
    rdfs:comment 'The line of business (LOB) where the fraud loss occurred. Aligns with Basel III business line segmentation for operational risk capital allocation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ccarLossEventFlag rdf:type rdf:Property ;
    rdfs:label 'Ccar Loss Event Flag' ;
    rdfs:comment 'Indicates whether this loss event is included in the historical loss data set used for CCAR stress testing scenarios.' ;
    rdfs:domain ind:LossRecovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insuranceClaimNumber rdf:type rdf:Property ;
    rdfs:label 'Insurance Claim Number' ;
    rdfs:comment 'Reference number for the insurance claim filed for this loss, if applicable. Links to external insurance carrier systems.' ;
    rdfs:domain ind:LossRecovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Legal Case Number' ;
    rdfs:comment 'Reference number for legal proceedings initiated to recover the loss, if applicable. Links to legal case management systems.' ;
    rdfs:domain ind:LossRecovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lossCategory rdf:type rdf:Property ;
    rdfs:label 'Loss Category' ;
    rdfs:comment 'Classification of the fraud loss by fraud typology. Aligns with internal fraud taxonomy for retail, card, wire, and deposit fraud.' ;
    rdfs:domain ind:LossRecovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lossDate rdf:type rdf:Property ;
    rdfs:label 'Loss Date' ;
    rdfs:comment 'The date when the fraud loss was recognized and recorded in the financial system.' ;
    rdfs:domain ind:LossRecovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lossDescription rdf:type rdf:Property ;
    rdfs:label 'Loss Description' ;
    rdfs:comment 'Detailed narrative description of the fraud loss event, including circumstances, methods used, and impact. Confidential business information.' ;
    rdfs:domain ind:LossRecovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lossDiscoveryDate rdf:type rdf:Property ;
    rdfs:label 'Loss Discovery Date' ;
    rdfs:comment 'The date when the fraud loss was first discovered or detected by the institution.' ;
    rdfs:domain ind:LossRecovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lossEventNumber rdf:type rdf:Property ;
    rdfs:label 'Loss Event Number' ;
    rdfs:comment 'Business-readable unique identifier for the loss event, typically formatted as business-line prefix, year, and sequence number.' ;
    rdfs:domain ind:LossRecovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lossStatus rdf:type rdf:Property ;
    rdfs:label 'Loss Status' ;
    rdfs:comment 'Current lifecycle status of the loss recovery record. Tracks the overall case from initial recognition through final disposition.' ;
    rdfs:domain ind:LossRecovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recoveryDate rdf:type rdf:Property ;
    rdfs:label 'Recovery Date' ;
    rdfs:comment 'The date when the recovery amount was received or recognized. Null if no recovery has occurred.' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recoveryMethod rdf:type rdf:Property ;
    rdfs:label 'Recovery Method' ;
    rdfs:comment 'The method or channel through which loss recovery was pursued or achieved. Includes insurance claims, chargeback processes, legal action, and write-offs. [ENUM-REF-CANDIDATE: insurance|merchant_chargeback|network_recovery|legal_judgment|customer_restitution|write_off|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LossRecovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recoveryNotes rdf:type rdf:Property ;
    rdfs:label 'Recovery Notes' ;
    rdfs:comment 'Free-text notes documenting recovery activities, communications with recovery parties, and status updates. Confidential business information.' ;
    rdfs:domain ind:LossRecovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recoveryStatus rdf:type rdf:Property ;
    rdfs:label 'Recovery Status' ;
    rdfs:comment 'Current status of recovery efforts for this loss event. Tracks the lifecycle from initial pursuit through final disposition.' ;
    rdfs:domain ind:LossRecovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:writeOffApprovalAuthority rdf:type rdf:Property ;
    rdfs:label 'Write Off Approval Authority' ;
    rdfs:comment 'The name or role of the authority who approved the write-off decision, per internal delegation of authority policies.' ;
    rdfs:domain ind:LossRecovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSegmentId rdf:type rdf:Property ;
    rdfs:label 'Customer Segment Id' ;
    rdfs:comment 'Foreign key linking to customer.segment. Business justification: Fraud detection rules are configured and tuned per customer segment (e.g., Premier Banking, SME, Retail) with different thresholds and logic. Rule governance and model performance reporting require st' ;
    rdfs:domain ind:DetectionRule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:alertPriorityScore rdf:type rdf:Property ;
    rdfs:label 'Alert Priority Score' ;
    rdfs:comment 'Numeric priority score (1-100) assigned to alerts generated by this rule, used for case queue prioritization and resource allocation. Higher scores indicate higher priority.' ;
    rdfs:domain ind:DetectionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:alertVolume rdf:type rdf:Property ;
    rdfs:label 'Alert Volume' ;
    rdfs:comment 'Total number of alerts generated by this rule during the measurement period. Used for capacity planning and rule efficiency assessment.' ;
    rdfs:domain ind:DetectionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:caseConversionRate rdf:type rdf:Property ;
    rdfs:label 'Case Conversion Rate' ;
    rdfs:comment 'Proportion of alerts that resulted in formal fraud investigation cases, calculated as cases opened divided by total alerts. Indicates rule precision and investigative value.' ;
    rdfs:domain ind:DetectionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:channelApplicability rdf:type rdf:Property ;
    rdfs:label 'Channel Applicability' ;
    rdfs:comment 'Comma-separated list of banking channels to which this rule applies: online banking, mobile app, ATM (Automated Teller Machine), branch, call center, wire transfer, ACH (Automated Clearing House), card payment. Empty indicates all channels.' ;
    rdfs:domain ind:DetectionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionEffectivenessScore rdf:type rdf:Property ;
    rdfs:label 'Detection Effectiveness Score' ;
    rdfs:comment 'Composite metric (0-100) evaluating overall rule performance, incorporating true positive rate, false positive rate, and case conversion rate. Used for rule ranking and optimization prioritization.' ;
    rdfs:domain ind:DetectionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:falsePositiveRate rdf:type rdf:Property ;
    rdfs:label 'False Positive Rate' ;
    rdfs:comment 'Proportion of legitimate transactions incorrectly flagged as fraud, calculated as false positives divided by total legitimate transactions. Critical for operational efficiency and customer experience.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastTuningDate rdf:type rdf:Property ;
    rdfs:label 'Last Tuning Date' ;
    rdfs:comment 'Date when the rule parameters were last adjusted or optimized based on performance analysis. Critical for tracking rule maintenance and effectiveness improvement efforts.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Measurement Period End Date' ;
    rdfs:comment 'End date of the performance measurement period for the recorded metrics. Defines the temporal scope of performance statistics.' ;
    rdfs:domain ind:DetectionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Measurement Period Start Date' ;
    rdfs:comment 'Start date of the performance measurement period for the recorded metrics. Enables time-series analysis of rule effectiveness.' ;
    rdfs:domain ind:DetectionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mlModelName rdf:type rdf:Property ;
    rdfs:label 'Ml Model Name' ;
    rdfs:comment 'Name or identifier of the machine learning model used for detection, if applicable. References trained model artifacts in the fraud analytics platform.' ;
    rdfs:domain ind:DetectionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mlModelVersion rdf:type rdf:Property ;
    rdfs:label 'Ml Model Version' ;
    rdfs:comment 'Version identifier of the machine learning model, enabling model lineage tracking and performance comparison across model iterations.' ;
    rdfs:domain ind:DetectionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelType rdf:type rdf:Property ;
    rdfs:label 'Model Type' ;
    rdfs:comment 'Detection methodology employed: rule-based (deterministic logic), machine learning (ML/AI model), hybrid (combination of rules and ML), statistical (statistical anomaly detection).' ;
    rdfs:domain ind:DetectionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportingRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Required' ;
    rdfs:comment 'Indicates whether confirmed fraud cases from this rule must be included in regulatory reports such as CTR (Currency Transaction Report) or SAR (Suspicious Activity Report) filings.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ruleCategory rdf:type rdf:Property ;
    rdfs:label 'Rule Category' ;
    rdfs:comment 'Classification of the detection rule by fraud detection methodology: velocity check (transaction frequency), amount threshold (monetary limits), geographic anomaly (location-based), device fingerprint (device identification), behavioral pattern (customer behavior analysis), or account takeover (credential compromise detection).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleDescription rdf:type rdf:Property ;
    rdfs:label 'Rule Description' ;
    rdfs:comment 'Comprehensive business description of the rule\'s purpose, detection methodology, and intended use cases. Provides context for analysts and auditors.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleDocumentationUrl rdf:type rdf:Property ;
    rdfs:label 'Rule Documentation Url' ;
    rdfs:comment 'URL or file path to detailed technical documentation, configuration guides, and tuning history for the rule. Supports knowledge management and operational continuity.' ;
    rdfs:domain ind:DetectionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleLogic rdf:type rdf:Property ;
    rdfs:label 'Rule Logic' ;
    rdfs:comment 'Detailed description of the rule\'s detection logic, including conditions, thresholds, and decision criteria. May reference SQL-like expressions, business rules, or machine learning model invocation logic.' ;
    rdfs:domain ind:DetectionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleOwner rdf:type rdf:Property ;
    rdfs:label 'Rule Owner' ;
    rdfs:comment 'Name or identifier of the business unit, team, or individual responsible for rule governance, performance monitoring, and tuning decisions.' ;
    rdfs:domain ind:DetectionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleSeverity rdf:type rdf:Property ;
    rdfs:label 'Rule Severity' ;
    rdfs:comment 'Severity classification of alerts generated by this rule, indicating priority for investigation: critical (immediate action required), high (urgent review), medium (standard review), low (informational).' ;
    rdfs:domain ind:DetectionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeWindowUnit rdf:type rdf:Property ;
    rdfs:label 'Time Window Unit' ;
    rdfs:comment 'Unit of time for the evaluation window: minute, hour, day, week, or month. Defines the temporal scope for transaction aggregation and pattern detection.' ;
    rdfs:domain ind:DetectionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeWindowValue rdf:type rdf:Property ;
    rdfs:label 'Time Window Value' ;
    rdfs:comment 'Numeric value defining the lookback or evaluation period for the rule (e.g., 24 for 24 hours, 7 for 7 days). Used in velocity checks and pattern analysis.' ;
    rdfs:domain ind:DetectionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:truePositiveRate rdf:type rdf:Property ;
    rdfs:label 'True Positive Rate' ;
    rdfs:comment 'Proportion of actual fraud cases correctly identified by the rule, calculated as true positives divided by total actual fraud cases. Key performance metric for detection effectiveness.' ;
    rdfs:domain ind:DetectionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tuningFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Tuning Frequency Days' ;
    rdfs:comment 'Recommended number of days between rule performance reviews and parameter adjustments. Supports proactive rule maintenance scheduling.' ;
    rdfs:domain ind:DetectionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:evidenceId rdf:type rdf:Property ;
    rdfs:label 'Evidence Id' ;
    rdfs:comment 'Unique identifier for the fraud evidence item. Primary key for the fraud evidence entity.' ;
    rdfs:domain ind:Evidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:admissibilityClassification rdf:type rdf:Property ;
    rdfs:label 'Admissibility Classification' ;
    rdfs:comment 'Legal admissibility classification of the evidence item for use in legal proceedings, regulatory examinations, or law enforcement referrals. Indicates whether the evidence meets evidentiary standards and chain of custody requirements.' ;
    rdfs:domain ind:Evidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:archivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Archived Timestamp' ;
    rdfs:comment 'The date and time when the evidence item was moved to long-term archival storage.' ;
    rdfs:domain ind:Evidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:chainOfCustodyStatus rdf:type rdf:Property ;
    rdfs:label 'Chain Of Custody Status' ;
    rdfs:comment 'Current lifecycle status of the evidence item within the chain of custody process. Tracks whether the evidence has been collected, secured in storage, transferred to another party, archived for long-term retention, or destroyed per retention policy.' ;
    rdfs:domain ind:Evidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Collection Timestamp' ;
    rdfs:comment 'The date and time when the evidence item was collected or extracted from the source system. Represents the principal business event timestamp for evidence capture.' ;
    rdfs:domain ind:Evidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:containsPiiFlag rdf:type rdf:Property ;
    rdfs:label 'Contains Pii Flag' ;
    rdfs:comment 'Indicates whether the evidence item contains personally identifiable information (PII) subject to privacy regulations such as GDPR, CCPA, or GLBA.' ;
    rdfs:domain ind:Evidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:destroyedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Destroyed Timestamp' ;
    rdfs:comment 'The date and time when the evidence item was destroyed per retention policy and legal requirements.' ;
    rdfs:domain ind:Evidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:destructionAuthorizedBy rdf:type rdf:Property ;
    rdfs:label 'Destruction Authorized By' ;
    rdfs:comment 'Reference to the employee or manager who authorized the destruction of the evidence item after confirming retention period expiration and absence of legal holds.' ;
    rdfs:domain ind:Evidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:destructionMethod rdf:type rdf:Property ;
    rdfs:label 'Destruction Method' ;
    rdfs:comment 'The method used to destroy the evidence item. Includes secure deletion (for digital files), shredding (for paper documents), degaussing (for magnetic media), or incineration.' ;
    rdfs:domain ind:Evidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceDescription rdf:type rdf:Property ;
    rdfs:label 'Evidence Description' ;
    rdfs:comment 'Detailed textual description of the evidence item, including its content, relevance to the fraud case, and any notable characteristics or findings.' ;
    rdfs:domain ind:Evidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceType rdf:type rdf:Property ;
    rdfs:label 'Evidence Type' ;
    rdfs:comment 'Classification of the evidence item by its nature and format. Includes transaction log extract, device fingerprint record, IP geolocation data, call recording, surveillance footage, document image, network traffic log, customer correspondence, witness statement, and third-party verification response.' ;
    rdfs:domain ind:Evidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileFormat rdf:type rdf:Property ;
    rdfs:label 'File Format' ;
    rdfs:comment 'The file format or media type of the evidence artifact. Common formats include PDF, image files (JPG, PNG), audio recordings (MP3), video files (MP4), structured data (CSV, XML, JSON), and document formats (DOC, DOCX, TXT). [ENUM-REF-CANDIDATE: pdf|jpg|png|mp3|mp4|csv|xml|json|txt|doc|docx — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Evidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileName rdf:type rdf:Property ;
    rdfs:label 'File Name' ;
    rdfs:comment 'The original or assigned file name of the evidence artifact, including file extension if applicable.' ;
    rdfs:domain ind:Evidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileSizeBytes rdf:type rdf:Property ;
    rdfs:label 'File Size Bytes' ;
    rdfs:comment 'The size of the evidence file or artifact in bytes. Used for storage capacity planning and transfer validation.' ;
    rdfs:domain ind:Evidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hashAlgorithm rdf:type rdf:Property ;
    rdfs:label 'Hash Algorithm' ;
    rdfs:comment 'The cryptographic hash algorithm used to generate the hash value for evidence integrity verification.' ;
    rdfs:domain ind:Evidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hashValue rdf:type rdf:Property ;
    rdfs:label 'Hash Value' ;
    rdfs:comment 'Cryptographic hash (e.g., SHA-256) of the evidence file to ensure integrity and detect tampering. Used to verify that the evidence has not been altered since collection.' ;
    rdfs:domain ind:Evidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:internalAuditReference rdf:type rdf:Property ;
    rdfs:label 'Internal Audit Reference' ;
    rdfs:comment 'Reference identifier for the internal audit review or control testing for which this evidence item was produced or is relevant.' ;
    rdfs:domain ind:Evidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lawEnforcementSharedFlag rdf:type rdf:Property ;
    rdfs:label 'Law Enforcement Shared Flag' ;
    rdfs:comment 'Indicates whether this evidence item has been shared with law enforcement agencies as part of a criminal investigation or Suspicious Activity Report (SAR) filing.' ;
    rdfs:domain ind:Evidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Legal Hold Flag' ;
    rdfs:comment 'Indicates whether the evidence item is subject to a legal hold order, preventing its destruction or alteration pending litigation, regulatory examination, or law enforcement investigation.' ;
    rdfs:domain ind:Evidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalHoldReference rdf:type rdf:Property ;
    rdfs:label 'Legal Hold Reference' ;
    rdfs:comment 'Reference identifier for the legal hold order or case that requires preservation of this evidence item.' ;
    rdfs:domain ind:Evidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryExamReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Exam Reference' ;
    rdfs:comment 'Reference identifier for the regulatory examination or audit request for which this evidence item was produced or is relevant.' ;
    rdfs:domain ind:Evidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relevanceScore rdf:type rdf:Property ;
    rdfs:label 'Relevance Score' ;
    rdfs:comment 'A numerical score (0.00 to 100.00) indicating the relevance or importance of this evidence item to the fraud case investigation. Higher scores indicate more critical evidence.' ;
    rdfs:domain ind:Evidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retentionPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Retention Period Days' ;
    rdfs:comment 'The number of days the evidence item must be retained per the banks evidence retention policy, regulatory requirements, and legal hold obligations. Drives evidence archival and destruction schedules.' ;
    rdfs:domain ind:Evidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:secureStorageReference rdf:type rdf:Property ;
    rdfs:label 'Secure Storage Reference' ;
    rdfs:comment 'Reference identifier or URI pointing to the secure storage location where the evidence file or artifact is stored. May reference document management system, secure file share, or evidence vault.' ;
    rdfs:domain ind:Evidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferMethod rdf:type rdf:Property ;
    rdfs:label 'Transfer Method' ;
    rdfs:comment 'The method used to transfer the evidence item to another party. Includes secure email, encrypted file transfer, physical media (USB, CD), secure portal, or in-person handoff.' ;
    rdfs:domain ind:Evidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferRecipient rdf:type rdf:Property ;
    rdfs:label 'Transfer Recipient' ;
    rdfs:comment 'The name or identifier of the party to whom the evidence item was transferred.' ;
    rdfs:domain ind:Evidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transfer Timestamp' ;
    rdfs:comment 'The date and time when the evidence item was transferred to another party, such as law enforcement, legal counsel, or regulatory authority.' ;
    rdfs:domain ind:Evidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:claimDepositAccountId rdf:type rdf:Property ;
    rdfs:label 'Claim Deposit Account Id' ;
    rdfs:comment 'Identifier of the account associated with the fraud claim.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DepositAccount .

ind:claimProvisionalCreditAccountDepositAccountId rdf:type rdf:Property ;
    rdfs:label 'Claim Provisional Credit Account Deposit Account Id' ;
    rdfs:comment 'Identifier of the account to which provisional credit was posted.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DepositAccount .

ind:claimedInteractionId rdf:type rdf:Property ;
    rdfs:label 'Claimed Interaction Id' ;
    rdfs:comment 'Foreign key linking to channel.interaction. Business justification: Customer fraud claims reference specific interactions. Linking enables claim validation (did transaction occur as claimed?), provisional credit calculation (Reg E 10-day rule), dispute resolution, and' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Interaction .

ind:fraudChargebackId rdf:type rdf:Property ;
    rdfs:label 'Fraud Chargeback Id' ;
    rdfs:comment 'External case identifier for the chargeback filed with the card network or payment processor.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Chargeback .

ind:attestationDate rdf:type rdf:Property ;
    rdfs:label 'Attestation Date' ;
    rdfs:comment 'Date the customer attestation or affidavit was received by the bank.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:chargebackInitiated rdf:type rdf:Property ;
    rdfs:label 'Chargeback Initiated' ;
    rdfs:comment 'Indicates whether a chargeback was initiated with the card network or merchant acquirer as part of the claim resolution process.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:claimNumber rdf:type rdf:Property ;
    rdfs:label 'Claim Number' ;
    rdfs:comment 'Externally visible unique claim reference number assigned at intake for customer and regulatory tracking.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimStatus rdf:type rdf:Property ;
    rdfs:label 'Claim Status' ;
    rdfs:comment 'Current lifecycle status of the fraud claim in the investigation and resolution workflow. [ENUM-REF-CANDIDATE: received|under_investigation|pending_documentation|approved|denied|closed|withdrawn — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimType rdf:type rdf:Property ;
    rdfs:label 'Claim Type' ;
    rdfs:comment 'Classification of the fraud claim based on the nature of the fraudulent activity reported by the customer.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerAttestationReceived rdf:type rdf:Property ;
    rdfs:label 'Customer Attestation Received' ;
    rdfs:comment 'Indicates whether the customer has provided a signed attestation or affidavit affirming the fraudulent nature of the transactions.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:finalCreditConfirmationDate rdf:type rdf:Property ;
    rdfs:label 'Final Credit Confirmation Date' ;
    rdfs:comment 'Date the provisional credit was confirmed as permanent following successful claim resolution.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:finalCreditConfirmed rdf:type rdf:Property ;
    rdfs:label 'Final Credit Confirmed' ;
    rdfs:comment 'Indicates whether provisional credit has been converted to permanent credit following claim approval.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:provisionalCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Provisional Credit Amount' ;
    rdfs:comment 'Amount of provisional credit issued to the customer pending investigation outcome, as required by consumer protection regulations.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:provisionalCreditIssuedDate rdf:type rdf:Property ;
    rdfs:label 'Provisional Credit Issued Date' ;
    rdfs:comment 'Date provisional credit was posted to the customer account, must comply with Regulation E 10-business-day rule or Regulation Z 5-business-day rule.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:provisionalCreditReversalDate rdf:type rdf:Property ;
    rdfs:label 'Provisional Credit Reversal Date' ;
    rdfs:comment 'Date provisional credit was reversed from the customer account, typically when the claim is denied or investigation concludes the transaction was authorized.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:provisionalCreditReversalReason rdf:type rdf:Property ;
    rdfs:label 'Provisional Credit Reversal Reason' ;
    rdfs:comment 'Business reason for reversing provisional credit, such as claim denial, customer withdrawal, or determination that transaction was authorized.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptDate rdf:type rdf:Property ;
    rdfs:label 'Receipt Date' ;
    rdfs:comment 'Date the fraud claim was received from the customer, marking the start of regulatory timelines for provisional credit and investigation.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:receiptTimestamp rdf:type rdf:Property ;
    rdfs:label 'Receipt Timestamp' ;
    rdfs:comment 'Precise timestamp when the fraud claim was logged into the system, used for SLA tracking and audit trails.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:resolutionCode rdf:type rdf:Property ;
    rdfs:label 'Resolution Code' ;
    rdfs:comment 'Final disposition code indicating the outcome of the fraud claim investigation.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkLinkId rdf:type rdf:Property ;
    rdfs:label 'Network Link Id' ;
    rdfs:comment 'Primary key for network_link' ;
    rdfs:domain ind:NetworkLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceFraudCaseId rdf:type rdf:Property ;
    rdfs:label 'Source Fraud Case Id' ;
    rdfs:comment 'Identifier of the primary fraud case that led to the discovery of this network link. Links the relationship to the originating investigation.' ;
    rdfs:domain ind:NetworkLink ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Case .

ind:sourceSubjectId rdf:type rdf:Property ;
    rdfs:label 'Source Subject Id' ;
    rdfs:comment 'Identifier of the originating fraud subject, account, device, or entity in the network relationship. References the source node in the fraud network graph.' ;
    rdfs:domain ind:NetworkLink ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Subject .

ind:targetSubjectId rdf:type rdf:Property ;
    rdfs:label 'Target Subject Id' ;
    rdfs:comment 'Identifier of the destination fraud subject, account, device, or entity in the network relationship. References the target node in the fraud network graph.' ;
    rdfs:domain ind:NetworkLink ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Subject .

ind:bidirectionalFlag rdf:type rdf:Property ;
    rdfs:label 'Bidirectional Flag' ;
    rdfs:comment 'Indicates whether the network link represents a bidirectional relationship (true) or a unidirectional relationship (false). Bidirectional links suggest mutual coordination.' ;
    rdfs:domain ind:NetworkLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:confirmationDate rdf:type rdf:Property ;
    rdfs:label 'Confirmation Date' ;
    rdfs:comment 'Date when the network link was validated and confirmed by an analyst as a legitimate fraud relationship.' ;
    rdfs:domain ind:NetworkLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:discoveryMethod rdf:type rdf:Property ;
    rdfs:label 'Discovery Method' ;
    rdfs:comment 'Method by which the network link was identified and established. Indicates whether the relationship was discovered through automated systems, manual investigation, or external sources.' ;
    rdfs:domain ind:NetworkLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discoveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Discovery Timestamp' ;
    rdfs:comment 'Precise timestamp when the network link was first identified, including time-of-day for audit trail and temporal analysis purposes.' ;
    rdfs:domain ind:NetworkLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:firstObservedDate rdf:type rdf:Property ;
    rdfs:label 'First Observed Date' ;
    rdfs:comment 'Earliest date when the relationship between the linked subjects was first observed in transaction or behavioral data, prior to formal discovery.' ;
    rdfs:domain ind:NetworkLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:graphVisualizationMetadata rdf:type rdf:Property ;
    rdfs:label 'Graph Visualization Metadata' ;
    rdfs:comment 'JSON or XML metadata used by graph analytics platforms for network topology visualization, including node positioning, edge styling, and clustering information.' ;
    rdfs:domain ind:NetworkLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationPriority rdf:type rdf:Property ;
    rdfs:label 'Investigation Priority' ;
    rdfs:comment 'Priority level assigned to the investigation of this network link based on risk score, potential loss exposure, and regulatory urgency.' ;
    rdfs:domain ind:NetworkLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastObservedDate rdf:type rdf:Property ;
    rdfs:label 'Last Observed Date' ;
    rdfs:comment 'Most recent date when the relationship between the linked subjects was observed in transaction or behavioral data, used to assess ongoing activity.' ;
    rdfs:domain ind:NetworkLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:linkEvidenceDescription rdf:type rdf:Property ;
    rdfs:label 'Link Evidence Description' ;
    rdfs:comment 'Detailed narrative describing the specific evidence supporting the network link, including data points, patterns, and investigative findings used for SAR narratives and law enforcement referrals.' ;
    rdfs:domain ind:NetworkLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Link Expiration Date' ;
    rdfs:comment 'Date when the network link is scheduled to expire or be archived if no further activity is observed. Used for data retention and case closure workflows.' ;
    rdfs:domain ind:NetworkLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:linkStrengthScore rdf:type rdf:Property ;
    rdfs:label 'Link Strength Score' ;
    rdfs:comment 'Quantitative measure of the confidence and strength of the network relationship, typically ranging from 0.00 to 100.00. Higher scores indicate stronger evidence of coordinated fraud activity.' ;
    rdfs:domain ind:NetworkLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:linkType rdf:type rdf:Property ;
    rdfs:label 'Link Type' ;
    rdfs:comment 'Classification of the relationship type between fraud subjects indicating the nature of the connection. [ENUM-REF-CANDIDATE: shared_device_fingerprint|shared_ip_address|shared_physical_address|shared_phone_number|common_beneficiary_account|mule_account_network|shared_employer|velocity_pattern_match|shared_email_domain|common_transaction_pattern — promote to reference product]' ;
    rdfs:domain ind:NetworkLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkDepthLevel rdf:type rdf:Property ;
    rdfs:label 'Network Depth Level' ;
    rdfs:comment 'Degree of separation from the primary fraud subject in the network graph. Level 1 indicates direct connection, higher levels indicate indirect relationships through intermediaries.' ;
    rdfs:domain ind:NetworkLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:observationFrequency rdf:type rdf:Property ;
    rdfs:label 'Observation Frequency' ;
    rdfs:comment 'Number of times the relationship pattern has been observed across transactions, interactions, or events. Higher frequency indicates stronger coordination.' ;
    rdfs:domain ind:NetworkLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:referralDate rdf:type rdf:Property ;
    rdfs:label 'Referral Date' ;
    rdfs:comment 'Date when the network link evidence was formally referred to law enforcement. Used for tracking investigation timelines.' ;
    rdfs:domain ind:NetworkLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sarIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Sar Included Flag' ;
    rdfs:comment 'Indicates whether this network link was included in a Suspicious Activity Report (SAR) filing to FinCEN. Used for regulatory compliance tracking.' ;
    rdfs:domain ind:NetworkLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sharedAttributeValue rdf:type rdf:Property ;
    rdfs:label 'Shared Attribute Value' ;
    rdfs:comment 'The specific shared data element that establishes the link (e.g., IP address, device fingerprint hash, physical address, phone number). Stored in hashed or masked format for privacy.' ;
    rdfs:domain ind:NetworkLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:driversLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Drivers License Number' ;
    rdfs:comment 'Drivers license number of the fraud subject used for identity verification.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstIdentifiedDate rdf:type rdf:Property ;
    rdfs:label 'First Identified Date' ;
    rdfs:comment 'Date when the fraud subject was first identified in the fraud management system.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:firstName rdf:type rdf:Property ;
    rdfs:label 'First Name' ;
    rdfs:comment 'First name or given name of the fraud subject.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fullName rdf:type rdf:Property ;
    rdfs:label 'Full Name' ;
    rdfs:comment 'Complete legal or known name of the fraud subject as identified during investigation.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:knownAliases rdf:type rdf:Property ;
    rdfs:label 'Known Aliases' ;
    rdfs:comment 'Comma-separated list of known aliases, alternate names, or pseudonyms used by the fraud subject.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastName rdf:type rdf:Property ;
    rdfs:label 'Last Name' ;
    rdfs:comment 'Last name or surname of the fraud subject.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lawEnforcementReferralDate rdf:type rdf:Property ;
    rdfs:label 'Law Enforcement Referral Date' ;
    rdfs:comment 'Date when the fraud subject was referred to law enforcement.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:middleName rdf:type rdf:Property ;
    rdfs:label 'Middle Name' ;
    rdfs:comment 'Middle name or initial of the fraud subject if available.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorFraudCaseCount rdf:type rdf:Property ;
    rdfs:label 'Prior Fraud Case Count' ;
    rdfs:comment 'Number of prior fraud cases in which this subject has been identified or implicated.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:riskTier rdf:type rdf:Property ;
    rdfs:label 'Risk Tier' ;
    rdfs:comment 'Risk tier classification of the fraud subject based on risk score and threat assessment.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectStatus rdf:type rdf:Property ;
    rdfs:label 'Subject Status' ;
    rdfs:comment 'Current status of the fraud subject in the fraud management system indicating their investigation or monitoring state.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectType rdf:type rdf:Property ;
    rdfs:label 'Subject Type' ;
    rdfs:comment 'Classification of the fraud subject indicating their relationship to the bank: internal employee, external third party, customer, organized fraud ring member, mule account holder, or unknown.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalConfirmedLossAmount rdf:type rdf:Property ;
    rdfs:label 'Total Confirmed Loss Amount' ;
    rdfs:comment 'Cumulative confirmed financial loss across all fraud cases involving this subject.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalEstimatedLossAmount rdf:type rdf:Property ;
    rdfs:label 'Total Estimated Loss Amount' ;
    rdfs:comment 'Cumulative estimated financial loss across all fraud cases involving this subject.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:watchlistStatus rdf:type rdf:Property ;
    rdfs:label 'Watchlist Status' ;
    rdfs:comment 'Indicates whether the fraud subject is on any internal or external watchlist including law enforcement, industry fraud databases, or sanctions lists.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:haircutScheduleId rdf:type rdf:Property ;
    rdfs:label 'Haircut Schedule Id' ;
    rdfs:comment 'Foreign key linking to collateral.haircut_schedule. Business justification: A collateral asset is subject to a specific haircut schedule based on its asset class, credit quality, and residual maturity. Linking collateral_asset to haircut_schedule identifies the governing sche' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HaircutSchedule .

ind:issuerCounterpartyRatingId rdf:type rdf:Property ;
    rdfs:label 'Issuer Counterparty Rating Id' ;
    rdfs:comment 'Foreign key linking to risk.counterparty_rating. Business justification: Collateral eligibility assessment and haircut determination require the issuer\'s current credit rating. collateral_asset.credit_rating and internal_rating are denormalized copies of counterparty_ratin' ;
    rdfs:domain ind:CollateralAsset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CounterpartyRating .

ind:issuerIndustryCodeId rdf:type rdf:Property ;
    rdfs:label 'Issuer Industry Code Id' ;
    rdfs:comment 'Foreign key linking to reference.industry_code. Business justification: For equity collateral, issuer industry classification is critical for concentration limit monitoring and sector risk management. Creating new issuer_industry_code_id FK.' ;
    rdfs:domain ind:CollateralAsset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IndustryCode .

ind:ownerPartyId rdf:type rdf:Property ;
    rdfs:label 'Owner Party Id' ;
    rdfs:comment 'Foreign key linking to customer.party. Business justification: Asset ownership tracking is fundamental for collateral perfection, lien priority determination, regulatory capital treatment (Basel III), and legal enforceability. Banking operations require definitiv' ;
    rdfs:domain ind:CollateralAsset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:ownerSanctionsScreeningEventId rdf:type rdf:Property ;
    rdfs:label 'Owner Sanctions Screening Event Id' ;
    rdfs:comment 'Foreign key linking to compliance.sanctions_screening_event. Business justification: Collateral onboarding mandates sanctions screening of the asset owner before acceptance. OFAC/EU sanctions compliance requires screening the pledging party. This is a distinct step from KYC review. Ro' ;
    rdfs:domain ind:CollateralAsset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SanctionsScreeningEvent .

ind:sourceDepositAccountId rdf:type rdf:Property ;
    rdfs:label 'Source Deposit Account Id' ;
    rdfs:comment 'Foreign key linking to account.deposit_account. Business justification: Cash collateral management: when a deposit account is the collateral asset (e.g., cash margin posted), the collateral_asset record must reference the specific deposit account for daily reconciliation,' ;
    rdfs:domain ind:CollateralAsset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DepositAccount .

ind:assetStatus rdf:type rdf:Property ;
    rdfs:label 'Asset Status' ;
    rdfs:comment 'Current lifecycle status of the collateral asset indicating its availability and encumbrance state. [ENUM-REF-CANDIDATE: eligible|pledged|released|ineligible|under_review|restricted|substituted — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CollateralAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Basel Eligible Flag' ;
    rdfs:comment 'Indicates whether the collateral asset qualifies as eligible collateral under Basel III capital and liquidity frameworks.' ;
    rdfs:domain ind:CollateralAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:concentrationLimitFlag rdf:type rdf:Property ;
    rdfs:label 'Concentration Limit Flag' ;
    rdfs:comment 'Indicates whether the collateral asset is subject to concentration limits under Basel III or internal risk policy.' ;
    rdfs:domain ind:CollateralAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:condition rdf:type rdf:Property ;
    rdfs:label 'Condition' ;
    rdfs:comment 'Assessment of the physical or credit condition of the collateral asset. Impacts valuation and haircut application.' ;
    rdfs:domain ind:CollateralAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:custodyLocation rdf:type rdf:Property ;
    rdfs:label 'Custody Location' ;
    rdfs:comment 'Physical or electronic location where the collateral asset is held (custodian name, vault location, depository, or registry).' ;
    rdfs:domain ind:CollateralAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Eligibility Flag' ;
    rdfs:comment 'Boolean indicator of whether the collateral asset meets the banks eligibility criteria for acceptance under Basel III, EMIR, and internal credit policy.' ;
    rdfs:domain ind:CollateralAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:emirEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Emir Eligible Flag' ;
    rdfs:comment 'Indicates whether the collateral asset meets EMIR eligibility requirements for central clearing and bilateral margin.' ;
    rdfs:domain ind:CollateralAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:encumbranceStatus rdf:type rdf:Property ;
    rdfs:label 'Encumbrance Status' ;
    rdfs:comment 'Indicates whether the collateral asset is free of liens or has existing encumbrances that affect its availability for pledging.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hqlaClassification rdf:type rdf:Property ;
    rdfs:label 'Hqla Classification' ;
    rdfs:comment 'Classification of the collateral asset under Basel III Liquidity Coverage Ratio (LCR) framework as Level 1, Level 2A, Level 2B, or non-HQLA.' ;
    rdfs:domain ind:Collateral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalDescription rdf:type rdf:Property ;
    rdfs:label 'Legal Description' ;
    rdfs:comment 'Formal legal description of the collateral asset as documented in legal agreements, deeds, or certificates. Includes property descriptions, security identifiers (ISIN, CUSIP), or instrument details.' ;
    rdfs:domain ind:CollateralAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pledgedDate rdf:type rdf:Property ;
    rdfs:label 'Pledged Date' ;
    rdfs:comment 'Date on which the collateral asset was pledged to the bank or counterparty under a collateral agreement.' ;
    rdfs:domain ind:CollateralAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rehypothecationAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Rehypothecation Allowed Flag' ;
    rdfs:comment 'Indicates whether the bank is permitted to rehypothecate (re-pledge) the collateral asset to third parties under the collateral agreement terms.' ;
    rdfs:domain ind:Collateral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:releaseDate rdf:type rdf:Property ;
    rdfs:label 'Release Date' ;
    rdfs:comment 'Date on which the collateral asset was released from pledge and returned to the owner. Null if currently pledged.' ;
    rdfs:domain ind:Collateral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:riskWeightPercentage rdf:type rdf:Property ;
    rdfs:label 'Risk Weight Percentage' ;
    rdfs:comment 'Risk weight percentage applied to the collateral asset for Risk-Weighted Assets (RWA) calculation under Basel III.' ;
    rdfs:domain ind:CollateralAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:obligorKycRecordId rdf:type rdf:Property ;
    rdfs:label 'Obligor Kyc Record Id' ;
    rdfs:comment 'Foreign key linking to customer.kyc_record. Business justification: AML/KYC compliance requires verifying the pledgor\'s KYC status before accepting a collateral pledge. Regulators (EMIR, Basel III) mandate KYC clearance at pledge creation and periodic review. Role-pre' ;
    rdfs:domain ind:Pledge ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:KycRecord .

ind:obligorRiskRatingId rdf:type rdf:Property ;
    rdfs:label 'Obligor Risk Rating Id' ;
    rdfs:comment 'Foreign key linking to customer.risk_rating. Business justification: Credit risk management requires the pledgor\'s risk rating to determine haircut percentages, LTV ratios, and pledge eligibility at origination and review. Basel III credit risk mitigation rules tie col' ;
    rdfs:domain ind:Pledge ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RiskRating .

ind:originatingOnboardingCaseId rdf:type rdf:Property ;
    rdfs:label 'Originating Onboarding Case Id' ;
    rdfs:comment 'Foreign key linking to customer.onboarding_case. Business justification: Secured product onboarding creates both an onboarding_case and a collateral_pledge simultaneously. Operations and compliance teams trace pledges back to originating onboarding cases for audit, SLA tra' ;
    rdfs:domain ind:Pledge ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OnboardingCase .

ind:perfectionJurisdictionCountryId rdf:type rdf:Property ;
    rdfs:label 'Perfection Jurisdiction Country Id' ;
    rdfs:comment 'Foreign key linking to reference.country. Business justification: Perfection jurisdiction determines legal enforceability and priority. Required for netting opinions, insolvency regime assessment, and regulatory capital relief eligibility. Creating perfection_jurisd' ;
    rdfs:domain ind:Collateral ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:perfectionJurisdictionId rdf:type rdf:Property ;
    rdfs:label 'Perfection Jurisdiction Id' ;
    rdfs:comment 'Foreign key linking to reference.jurisdiction. Business justification: Pledge perfection legal enforceability and Basel III capital relief recognition require jurisdiction-level netting enforceability status and legal opinion validity. reference.jurisdiction.netting_enfo' ;
    rdfs:domain ind:Collateral ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Jurisdiction .

ind:pledgedDepositAccountId rdf:type rdf:Property ;
    rdfs:label 'Pledged Deposit Account Id' ;
    rdfs:comment 'Foreign key linking to account.deposit_account. Business justification: CD-secured and savings-secured lending: a deposit account is frequently pledged as collateral. The pledge record must reference the specific deposit account to enforce holds, calculate eligible collat' ;
    rdfs:domain ind:Collateral ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DepositAccount .

ind:pledgorSanctionsScreeningEventId rdf:type rdf:Property ;
    rdfs:label 'Pledgor Sanctions Screening Event Id' ;
    rdfs:comment 'Foreign key linking to compliance.sanctions_screening_event. Business justification: Before accepting a pledge, the pledging counterparty must be sanctions-screened (OFAC, EU, UN lists). This is a distinct compliance step from KYC (already linked). Role-prefix \'pledgor_\' identifies th' ;
    rdfs:domain ind:Pledge ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SanctionsScreeningEvent .

ind:primaryCollateralPledgeCustodianPartyId rdf:type rdf:Property ;
    rdfs:label 'Primary Collateral Pledge Custodian Party Id' ;
    rdfs:comment 'Reference to the third-party custodian or depository holding the pledged collateral on behalf of the secured party.' ;
    rdfs:domain ind:Pledge ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:tertiaryCollateralPledgeSecuredPartyId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Collateral Pledge Secured Party Id' ;
    rdfs:comment 'Reference to the party receiving the collateral (the secured party or beneficiary).' ;
    rdfs:domain ind:Pledge ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:eligibleCollateralValue rdf:type rdf:Property ;
    rdfs:label 'Eligible Collateral Value' ;
    rdfs:comment 'The collateral value after applying the haircut, representing the amount eligible for regulatory capital relief under Basel III CRM framework.' ;
    rdfs:domain ind:Pledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enforcementDate rdf:type rdf:Property ;
    rdfs:label 'Enforcement Date' ;
    rdfs:comment 'The date on which the secured party exercised its right to seize and liquidate the pledged collateral due to obligor default.' ;
    rdfs:domain ind:Pledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:initialMarginAmount rdf:type rdf:Property ;
    rdfs:label 'Initial Margin Amount' ;
    rdfs:comment 'The initial margin amount posted as collateral at the inception of the derivative or repo transaction, as required under the CSA or margin agreement.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:legalPerfectionStatus rdf:type rdf:Property ;
    rdfs:label 'Legal Perfection Status' ;
    rdfs:comment 'Indicates whether the security interest has been legally perfected (enforceable against third parties): perfected (fully enforceable), pending (perfection in progress), unperfected (not yet enforceable), disputed (under legal challenge).' ;
    rdfs:domain ind:Pledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lienRank rdf:type rdf:Property ;
    rdfs:label 'Lien Rank' ;
    rdfs:comment 'The priority ranking of this pledge relative to other liens on the same collateral: first (highest priority), second, subordinate, pari passu (equal ranking), junior, senior.' ;
    rdfs:domain ind:Pledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pledgeDate rdf:type rdf:Property ;
    rdfs:label 'Pledge Date' ;
    rdfs:comment 'The date on which the collateral was formally pledged to secure the obligation.' ;
    rdfs:domain ind:Pledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pledgeStatus rdf:type rdf:Property ;
    rdfs:label 'Pledge Status' ;
    rdfs:comment 'Current lifecycle status of the pledge: active (in force), released (returned to obligor), substituted (replaced with alternative collateral), enforced (collateral seized), defaulted (obligor in default), pending (awaiting perfection).' ;
    rdfs:domain ind:Pledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pledgeType rdf:type rdf:Property ;
    rdfs:label 'Pledge Type' ;
    rdfs:comment 'The type of obligation being secured by this pledge: loan collateral (secured lending), derivative margin (ISDA CSA), repo collateral (repo/reverse repo), guarantee backing, letter of credit collateral.' ;
    rdfs:domain ind:Pledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryCapitalReliefAmount rdf:type rdf:Property ;
    rdfs:label 'Regulatory Capital Relief Amount' ;
    rdfs:comment 'The amount of regulatory capital relief recognized under Basel III CRM framework as a result of this collateral pledge, reducing Risk-Weighted Assets (RWA).' ;
    rdfs:domain ind:Pledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rwaReductionAmount rdf:type rdf:Property ;
    rdfs:label 'Rwa Reduction Amount' ;
    rdfs:comment 'The reduction in Risk-Weighted Assets attributable to this collateral pledge under Basel III capital adequacy calculations.' ;
    rdfs:domain ind:Pledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:substitutionDate rdf:type rdf:Property ;
    rdfs:label 'Substitution Date' ;
    rdfs:comment 'The date on which this collateral was substituted with alternative collateral, if applicable.' ;
    rdfs:domain ind:Pledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:variationMarginAmount rdf:type rdf:Property ;
    rdfs:label 'Variation Margin Amount' ;
    rdfs:comment 'The variation margin amount posted or received to reflect daily mark-to-market changes in the value of the underlying derivative or repo transaction.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collateralPositionId rdf:type rdf:Property ;
    rdfs:label 'Collateral Position Id' ;
    rdfs:comment 'Foreign key linking to collateral.collateral_position. Business justification: A margin call results in changes to collateral positions — when a margin call is issued, it affects the collateral_posted_amount and collateral_received_amount in the position. Linking collateral_marg' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CollateralPosition .

ind:callDirection rdf:type rdf:Property ;
    rdfs:label 'Call Direction' ;
    rdfs:comment 'Indicates whether the margin call was issued by the institution to a counterparty or received from a counterparty.' ;
    rdfs:domain ind:MarginCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callTimestamp rdf:type rdf:Property ;
    rdfs:label 'Call Timestamp' ;
    rdfs:comment 'Precise date and time when the margin call was generated and communicated to the counterparty.' ;
    rdfs:domain ind:MarginCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:collateralPostedAmount rdf:type rdf:Property ;
    rdfs:label 'Collateral Posted Amount' ;
    rdfs:comment 'The total amount of collateral posted by the institution to the counterparty as of the call date.' ;
    rdfs:domain ind:Collateral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collateralReceivedAmount rdf:type rdf:Property ;
    rdfs:label 'Collateral Received Amount' ;
    rdfs:comment 'The total amount of collateral received by the institution from the counterparty as of the call date.' ;
    rdfs:domain ind:Collateral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dailyVmRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Daily Vm Requirement Flag' ;
    rdfs:comment 'Indicates whether this margin call is subject to daily Variation Margin exchange requirements per regulatory rules.' ;
    rdfs:domain ind:MarginCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Delivery Deadline Date' ;
    rdfs:comment 'The date by which the margin must be delivered to satisfy the call, per CSA or CCP rules.' ;
    rdfs:domain ind:MarginCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deliveryDeadlineTimestamp rdf:type rdf:Property ;
    rdfs:label 'Delivery Deadline Timestamp' ;
    rdfs:comment 'Precise date and time by which the margin must be delivered, including intraday deadlines for VM settlements.' ;
    rdfs:domain ind:MarginCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:disputeRaisedDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Raised Date' ;
    rdfs:comment 'The date on which the dispute was formally raised by either party.' ;
    rdfs:domain ind:MarginCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disputeResolutionStatus rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Status' ;
    rdfs:comment 'Current status of the dispute resolution process from initial dispute through final resolution or withdrawal.' ;
    rdfs:domain ind:MarginCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doddFrankComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Dodd Frank Compliance Flag' ;
    rdfs:comment 'Indicates whether this margin call is subject to and compliant with Dodd-Frank Act margin requirements for uncleared swaps.' ;
    rdfs:domain ind:Collateral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:emirComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Emir Compliance Flag' ;
    rdfs:comment 'Indicates whether this margin call is subject to and compliant with EMIR margin requirements for OTC derivatives.' ;
    rdfs:domain ind:Collateral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:imCalculationMethodology rdf:type rdf:Property ;
    rdfs:label 'Im Calculation Methodology' ;
    rdfs:comment 'The methodology used to calculate Initial Margin: ISDA SIMM (Standard Initial Margin Model), schedule-based approach, internal model, or CCP-prescribed method.' ;
    rdfs:domain ind:MarginCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imCustodianIdentifier rdf:type rdf:Property ;
    rdfs:label 'Im Custodian Identifier' ;
    rdfs:comment 'Legal Entity Identifier (LEI) or other unique identifier for the IM custodian.' ;
    rdfs:domain ind:MarginCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imCustodianName rdf:type rdf:Property ;
    rdfs:label 'Im Custodian Name' ;
    rdfs:comment 'Name of the third-party custodian holding the segregated Initial Margin collateral.' ;
    rdfs:domain ind:MarginCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imSegregationStatus rdf:type rdf:Property ;
    rdfs:label 'Im Segregation Status' ;
    rdfs:comment 'Indicates whether the Initial Margin is held in a segregated account per regulatory requirements (UMR, Dodd-Frank, EMIR).' ;
    rdfs:domain ind:MarginCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:independentAmount rdf:type rdf:Property ;
    rdfs:label 'Independent Amount' ;
    rdfs:comment 'Additional margin amount required beyond mark-to-market exposure, often used as a buffer for potential future exposure or credit risk mitigation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marginCallType rdf:type rdf:Property ;
    rdfs:label 'Margin Call Type' ;
    rdfs:comment 'Classification of the margin arrangement: bilateral (under CSA), central counterparty (CCP), or tri-party collateral management.' ;
    rdfs:domain ind:MarginCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marginType rdf:type rdf:Property ;
    rdfs:label 'Margin Type' ;
    rdfs:comment 'Classification of margin activity: Initial Margin (IM) requirement, IM posted, IM received, Variation Margin (VM) call, or VM settlement.' ;
    rdfs:domain ind:Collateral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netExposureAmount rdf:type rdf:Property ;
    rdfs:label 'Net Exposure Amount' ;
    rdfs:comment 'The net mark-to-market exposure of the netting set after netting all trades, used as the basis for margin calculation.' ;
    rdfs:domain ind:MarginCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:thresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Threshold Amount' ;
    rdfs:comment 'The CSA threshold amount below which no margin call is required, representing the unsecured credit exposure limit.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:umrComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Umr Compliance Flag' ;
    rdfs:comment 'Indicates whether this margin call is subject to and compliant with Uncleared Margin Rules (UMR) requirements.' ;
    rdfs:domain ind:Collateral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:umrPhase rdf:type rdf:Property ;
    rdfs:label 'Umr Phase' ;
    rdfs:comment 'The regulatory phase under which this margin call falls per the phased implementation of Uncleared Margin Rules (UMR) based on counterparty aggregate average notional amount (AANA). [ENUM-REF-CANDIDATE: phase_1|phase_2|phase_3|phase_4|phase_5|phase_6|not_applicable — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Collateral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vmSettlementStatus rdf:type rdf:Property ;
    rdfs:label 'Vm Settlement Status' ;
    rdfs:comment 'Current status of the Variation Margin settlement process from call issuance through final settlement confirmation.' ;
    rdfs:domain ind:MarginCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cashCollateralDepositAccountId rdf:type rdf:Property ;
    rdfs:label 'Cash Collateral Deposit Account Id' ;
    rdfs:comment 'Foreign key linking to account.deposit_account. Business justification: Cash collateral valuation: valuations of cash collateral must reference the deposit account to pull the authoritative balance for net collateral value calculation. Valuation agents and risk systems re' ;
    rdfs:domain ind:Collateral ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DepositAccount .

ind:collateralAssetClass rdf:type rdf:Property ;
    rdfs:label 'Collateral Asset Class' ;
    rdfs:comment 'The broad asset class category of the collateral being valued, determining applicable haircut schedules and eligibility rules under Basel III. [ENUM-REF-CANDIDATE: cash|government_securities|corporate_bonds|equities|real_estate|commodities|derivatives|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CollateralValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:concentrationLimitBreach rdf:type rdf:Property ;
    rdfs:label 'Concentration Limit Breach' ;
    rdfs:comment 'Flag indicating whether accepting this collateral valuation would breach concentration limits defined in the CSA agreement or internal risk policies.' ;
    rdfs:domain ind:Collateral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:confidenceIntervalLower rdf:type rdf:Property ;
    rdfs:label 'Confidence Interval Lower' ;
    rdfs:comment 'The lower bound of the confidence interval for the valuation, representing the minimum expected value within the statistical confidence range (typically 95% or 99%).' ;
    rdfs:domain ind:CollateralValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confidenceIntervalUpper rdf:type rdf:Property ;
    rdfs:label 'Confidence Interval Upper' ;
    rdfs:comment 'The upper bound of the confidence interval for the valuation, representing the maximum expected value within the statistical confidence range.' ;
    rdfs:domain ind:CollateralValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confidenceLevelPercentage rdf:type rdf:Property ;
    rdfs:label 'Confidence Level Percentage' ;
    rdfs:comment 'The statistical confidence level used for the valuation interval, typically 0.95 (95%) or 0.99 (99%), indicating the probability that the true value falls within the stated range.' ;
    rdfs:domain ind:CollateralValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eligibleForCentralBank rdf:type rdf:Property ;
    rdfs:label 'Eligible For Central Bank' ;
    rdfs:comment 'Indicates whether this collateral asset is eligible for use in central bank operations (e.g., Fed discount window, ECB refinancing operations).' ;
    rdfs:domain ind:CollateralValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:frequency rdf:type rdf:Property ;
    rdfs:label 'Frequency' ;
    rdfs:comment 'The scheduled frequency at which this collateral asset is revalued. Daily MTM for liquid securities and derivatives, periodic for real estate and illiquid assets, event-driven for trigger-based revaluations, or continuous for real-time pricing. [ENUM-REF-CANDIDATE: daily|weekly|monthly|quarterly|annual|event_driven|continuous — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CollateralValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossMarketValue rdf:type rdf:Property ;
    rdfs:label 'Gross Market Value' ;
    rdfs:comment 'The unadjusted market value of the collateral asset before applying any haircuts or adjustments.' ;
    rdfs:domain ind:CollateralValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:haircutAmount rdf:type rdf:Property ;
    rdfs:label 'Haircut Amount' ;
    rdfs:comment 'The absolute monetary value of the haircut applied, calculated as gross market value multiplied by haircut percentage.' ;
    rdfs:domain ind:CollateralValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netCollateralValue rdf:type rdf:Property ;
    rdfs:label 'Net Collateral Value' ;
    rdfs:comment 'The adjusted collateral value after applying haircuts, representing the effective value available for margin coverage and LTV (Loan-to-Value) calculations.' ;
    rdfs:domain ind:Collateral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:previousNetValue rdf:type rdf:Property ;
    rdfs:label 'Previous Net Value' ;
    rdfs:comment 'The net collateral value from the previous valuation, used to calculate value changes and trigger margin calls when thresholds are breached.' ;
    rdfs:domain ind:CollateralValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:previousValuationDate rdf:type rdf:Property ;
    rdfs:label 'Previous Valuation Date' ;
    rdfs:comment 'The date of the immediately preceding valuation for this collateral asset, enabling time-series analysis and value change tracking.' ;
    rdfs:domain ind:CollateralValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:valueChangeAmount rdf:type rdf:Property ;
    rdfs:label 'Value Change Amount' ;
    rdfs:comment 'The absolute change in net collateral value since the previous valuation, calculated as current net value minus previous net value.' ;
    rdfs:domain ind:CollateralValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valueChangePercentage rdf:type rdf:Property ;
    rdfs:label 'Value Change Percentage' ;
    rdfs:comment 'The percentage change in net collateral value since the previous valuation, expressed as a decimal (e.g., 0.0523 for 5.23% increase).' ;
    rdfs:domain ind:CollateralValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bilateralCsaHaircutPct rdf:type rdf:Property ;
    rdfs:label 'Bilateral Csa Haircut Pct' ;
    rdfs:comment 'Negotiated haircut percentage specified in a bilateral Credit Support Annex under an ISDA Master Agreement. May differ from supervisory haircuts based on counterparty agreement.' ;
    rdfs:domain ind:HaircutSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ccpHaircutPct rdf:type rdf:Property ;
    rdfs:label 'Ccp Haircut Pct' ;
    rdfs:comment 'Haircut percentage applied by a qualifying central counterparty (QCCP) for cleared derivatives and securities financing transactions. Reflects CCP-specific margin methodology.' ;
    rdfs:domain ind:HaircutSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collateralEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Collateral Eligibility Flag' ;
    rdfs:comment 'Indicates whether this asset class is eligible as collateral under the applicable regulatory framework and internal policy. True if eligible, False if ineligible.' ;
    rdfs:domain ind:HaircutSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:confidenceLevelPct rdf:type rdf:Property ;
    rdfs:label 'Confidence Level Pct' ;
    rdfs:comment 'Statistical confidence level used in VaR-based haircut calculations. Basel III requires 99% confidence level for own-estimate haircuts.' ;
    rdfs:domain ind:HaircutSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditQualityStep rdf:type rdf:Property ;
    rdfs:label 'Credit Quality Step' ;
    rdfs:comment 'The credit quality step assigned to the collateral asset under the standardized approach, mapping external credit ratings to regulatory risk buckets. CQS 1 represents highest credit quality (e.g., AAA to AA-), CQS 6 represents lowest investment grade. [ENUM-REF-CANDIDATE: CQS_1|CQS_2|CQS_3|CQS_4|CQS_5|CQS_6|unrated — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:HaircutSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currencyMismatchAddonPct rdf:type rdf:Property ;
    rdfs:label 'Currency Mismatch Addon Pct' ;
    rdfs:comment 'Additional haircut percentage applied when collateral and exposure currencies differ. Typically 8% under Basel III standardized approach for major currency pairs.' ;
    rdfs:domain ind:HaircutSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currencyMismatchIndicator rdf:type rdf:Property ;
    rdfs:label 'Currency Mismatch Indicator' ;
    rdfs:comment 'Flag indicating whether the collateral currency differs from the exposure currency. True if mismatch exists, requiring an additional haircut add-on per Basel III.' ;
    rdfs:domain ind:HaircutSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:initialMarginHaircutPct rdf:type rdf:Property ;
    rdfs:label 'Initial Margin Haircut Pct' ;
    rdfs:comment 'Haircut applied to collateral posted as initial margin for non-cleared derivatives under the BCBS-IOSCO margin framework. Protects against potential future exposure.' ;
    rdfs:domain ind:HaircutSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:internalModelHaircutPct rdf:type rdf:Property ;
    rdfs:label 'Internal Model Haircut Pct' ;
    rdfs:comment 'Haircut percentage derived from the bank\'s own internal Value-at-Risk (VaR) model under the own-estimate approach, subject to regulatory approval and minimum floors.' ;
    rdfs:domain ind:HaircutSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:liquidityCategory rdf:type rdf:Property ;
    rdfs:label 'Liquidity Category' ;
    rdfs:comment 'Classification of the collateral asset based on market depth, trading volume, and ease of liquidation. Highly liquid assets (e.g., G7 sovereign bonds) receive lower haircuts.' ;
    rdfs:domain ind:HaircutSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumHaircutFloorPct rdf:type rdf:Property ;
    rdfs:label 'Minimum Haircut Floor Pct' ;
    rdfs:comment 'Regulatory minimum haircut percentage that must be applied regardless of internal model estimates. Ensures prudent collateral valuation under all circumstances.' ;
    rdfs:domain ind:HaircutSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:residualMaturityBucket rdf:type rdf:Property ;
    rdfs:label 'Residual Maturity Bucket' ;
    rdfs:comment 'The time-to-maturity band of the collateral instrument. Longer maturities typically attract higher haircuts due to increased interest rate and market risk.' ;
    rdfs:domain ind:HaircutSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supervisoryHaircutPct rdf:type rdf:Property ;
    rdfs:label 'Supervisory Haircut Pct' ;
    rdfs:comment 'The standardized haircut percentage prescribed by the Basel III supervisory framework for this asset class, credit quality, and maturity combination. Used under the standardized approach for credit risk mitigation.' ;
    rdfs:domain ind:HaircutSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:variationMarginHaircutPct rdf:type rdf:Property ;
    rdfs:label 'Variation Margin Haircut Pct' ;
    rdfs:comment 'Haircut applied to collateral posted as variation margin for non-cleared derivatives. Typically lower than initial margin haircuts as VM covers current exposure.' ;
    rdfs:domain ind:HaircutSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volatilityAdjustmentMethod rdf:type rdf:Property ;
    rdfs:label 'Volatility Adjustment Method' ;
    rdfs:comment 'The statistical or econometric method used to calculate volatility-based haircut adjustments. Relevant for internal model approaches and dynamic haircut schedules.' ;
    rdfs:domain ind:HaircutSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceObligationId rdf:type rdf:Property ;
    rdfs:label 'Compliance Obligation Id' ;
    rdfs:comment 'Foreign key linking to compliance.obligation. Business justification: Eligibility rules operationalize regulatory obligations (central bank eligibility criteria, CCP requirements, Basel HQLA definitions). Each rule maps to specific regulatory citations and compliance ob' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Obligation .

ind:assetType rdf:type rdf:Property ;
    rdfs:label 'Asset Type' ;
    rdfs:comment 'More granular asset type specification within the asset class, such as specific instrument types, security subtypes, or product categories. Provides additional detail beyond the broad asset class.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachAction rdf:type rdf:Property ;
    rdfs:label 'Breach Action' ;
    rdfs:comment 'Action to be taken when the eligibility rule or concentration limit is breached: hard_stop (prevent transaction), soft_warning (alert but allow), escalation (notify risk management), or auto_rebalance (trigger automatic portfolio rebalancing).' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:concentrationLimitAbsoluteAmount rdf:type rdf:Property ;
    rdfs:label 'Concentration Limit Absolute Amount' ;
    rdfs:comment 'Maximum absolute monetary amount that can be allocated to the specified concentration dimension, expressed in the base currency of the collateral arrangement. Used when limits are defined in absolute terms rather than percentages.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:concentrationLimitPercentage rdf:type rdf:Property ;
    rdfs:label 'Concentration Limit Percentage' ;
    rdfs:comment 'Maximum percentage of total collateral portfolio value that can be allocated to the specified concentration dimension (e.g., no more than 25% from a single issuer). Expressed as a percentage with two decimal places.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:concentrationLimitType rdf:type rdf:Property ;
    rdfs:label 'Concentration Limit Type' ;
    rdfs:comment 'Dimension along which the concentration limit is applied: issuer (single issuer exposure), asset_class (exposure to one asset class), currency (single currency exposure), counterparty (exposure to one counterparty), jurisdiction (geographic concentration), or sector (industry sector concentration).' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibleForCcp rdf:type rdf:Property ;
    rdfs:label 'Eligible For Ccp' ;
    rdfs:comment 'Boolean flag indicating whether collateral meeting this rule is eligible for posting to a central counterparty (CCP) for cleared derivatives transactions. True if eligible, false otherwise.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eligibleForInitialMargin rdf:type rdf:Property ;
    rdfs:label 'Eligible For Initial Margin' ;
    rdfs:comment 'Boolean flag indicating whether collateral meeting this rule is eligible to satisfy initial margin (IM) requirements under uncleared derivatives margin rules (UMR). True if eligible, false otherwise.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eligibleForRepo rdf:type rdf:Property ;
    rdfs:label 'Eligible For Repo' ;
    rdfs:comment 'Boolean flag indicating whether collateral meeting this rule is eligible for use in repurchase (repo) or reverse repurchase (reverse repo) transactions. True if eligible, false otherwise.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eligibleForSecuredLending rdf:type rdf:Property ;
    rdfs:label 'Eligible For Secured Lending' ;
    rdfs:comment 'Boolean flag indicating whether collateral meeting this rule is eligible for secured lending transactions, including securities lending and collateralized loans. True if eligible, false otherwise.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eligibleForVariationMargin rdf:type rdf:Property ;
    rdfs:label 'Eligible For Variation Margin' ;
    rdfs:comment 'Boolean flag indicating whether collateral meeting this rule is eligible to satisfy variation margin (VM) requirements under derivatives margining frameworks. True if eligible, false otherwise.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:limitScope rdf:type rdf:Property ;
    rdfs:label 'Limit Scope' ;
    rdfs:comment 'Scope of application for the eligibility or concentration rule: portfolio-wide (applies across all collateral arrangements), agreement-specific (applies to a single CSA or collateral agreement), counterparty-specific (applies to all arrangements with one counterparty), or product-specific (applies to a specific product type).' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumMaturityDays rdf:type rdf:Property ;
    rdfs:label 'Maximum Maturity Days' ;
    rdfs:comment 'Maximum remaining time to maturity in days for collateral assets to be eligible under this rule. Assets with longer maturity are excluded.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumCreditRating rdf:type rdf:Property ;
    rdfs:label 'Minimum Credit Rating' ;
    rdfs:comment 'Minimum acceptable credit rating for collateral assets under this rule, expressed in standard rating agency notation (e.g., AAA, AA+, A-, BBB). Assets below this rating are ineligible. NR indicates no rating requirement.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumMaturityDays rdf:type rdf:Property ;
    rdfs:label 'Minimum Maturity Days' ;
    rdfs:comment 'Minimum remaining time to maturity in days for collateral assets to be eligible under this rule. Assets with shorter maturity are excluded.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ruleType rdf:type rdf:Property ;
    rdfs:label 'Rule Type' ;
    rdfs:comment 'Classification of the rule defining its functional purpose: eligibility criterion (what assets qualify), concentration limit (diversification requirements), jurisdiction restriction (geographic constraints), haircut rule (valuation discount), rating threshold (minimum credit quality), or maturity constraint (time-to-maturity limits).' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substitutionAllowed rdf:type rdf:Property ;
    rdfs:label 'Substitution Allowed' ;
    rdfs:comment 'Boolean flag indicating whether collateral assets meeting this rule can be substituted with other eligible collateral during the life of the collateral arrangement. True if substitution rights are granted, false otherwise.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cashCollateralRateBenchmarkId rdf:type rdf:Property ;
    rdfs:label 'Cash Collateral Rate Benchmark Id' ;
    rdfs:comment 'Foreign key linking to reference.rate_benchmark. Business justification: Interest on cash collateral typically references benchmark rate for accrual calculations and settlement. Creating cash_collateral_rate_benchmark_id FK for benchmark-linked interest.' ;
    rdfs:domain ind:MarginAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RateBenchmark .

ind:primaryMarginPartyId rdf:type rdf:Property ;
    rdfs:label 'Primary Margin Party Id' ;
    rdfs:comment 'Reference to the custodian or third-party agent holding segregated collateral under this agreement, if applicable.' ;
    rdfs:domain ind:MarginAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:accelerationClause rdf:type rdf:Property ;
    rdfs:label 'Acceleration Clause' ;
    rdfs:comment 'Indicates whether the agreement contains an acceleration clause allowing immediate termination and full collateral call upon default. True = acceleration allowed, False = no acceleration.' ;
    rdfs:domain ind:MarginAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:agreementNumber rdf:type rdf:Property ;
    rdfs:label 'Agreement Number' ;
    rdfs:comment 'Externally-known unique business identifier for the margin agreement, used in legal documentation and counterparty communications.' ;
    rdfs:domain ind:MarginAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementStatus rdf:type rdf:Property ;
    rdfs:label 'Agreement Status' ;
    rdfs:comment 'Current lifecycle status of the margin agreement. DRAFT = under negotiation, PENDING_APPROVAL = awaiting internal or counterparty approval, ACTIVE = in force, SUSPENDED = temporarily inactive, TERMINATED = ended by mutual agreement or default, EXPIRED = reached natural end date.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementType rdf:type rdf:Property ;
    rdfs:label 'Agreement Type' ;
    rdfs:comment 'Classification of the collateral agreement type. CSA_BILATERAL = ISDA Credit Support Annex bilateral, CSA_UNILATERAL = ISDA CSA unilateral, CCP_CLEARING = Central Counterparty clearing agreement, GMRA = Global Master Repurchase Agreement, GMSLA = Global Master Securities Lending Agreement, PLEDGE = pledge agreement, SECURITY_AGREEMENT = security agreement, HYPOTHECATION = hypothecation agreement, CHARGE = charge agreement for secured commercial lending. [ENUM-REF-CANDIDATE: CSA_BILATERAL|CSA_UNILATERAL|CCP_CLEARING|GMRA|GMSLA|PLEDGE|SECURITY_AGREEMENT|HYPOTHECATION|CHARGE — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collateralAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Collateral Account Number' ;
    rdfs:comment 'Account number or identifier for the segregated collateral account associated with this margin agreement.' ;
    rdfs:domain ind:MarginAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossDefaultProvision rdf:type rdf:Property ;
    rdfs:label 'Cross Default Provision' ;
    rdfs:comment 'Indicates whether a default under this agreement triggers default under other agreements with the same counterparty. True = cross-default applies, False = standalone agreement.' ;
    rdfs:domain ind:MarginAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disputeResolutionTerms rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Terms' ;
    rdfs:comment 'Free-text description of the dispute resolution process and escalation procedures defined in the agreement, including timeframes and arbitration clauses.' ;
    rdfs:domain ind:MarginAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingLaw rdf:type rdf:Property ;
    rdfs:label 'Governing Law' ;
    rdfs:comment 'Legal jurisdiction whose laws govern the interpretation and enforcement of the margin agreement. [ENUM-REF-CANDIDATE: ENGLISH_LAW|NEW_YORK_LAW|JAPANESE_LAW|GERMAN_LAW|FRENCH_LAW|SWISS_LAW|SINGAPORE_LAW|HONG_KONG_LAW|OTHER — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:independentAmountCurrency rdf:type rdf:Property ;
    rdfs:label 'Independent Amount Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the independent amount.' ;
    rdfs:domain ind:Collateral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initialMarginMethodology rdf:type rdf:Property ;
    rdfs:label 'Initial Margin Methodology' ;
    rdfs:comment 'Methodology used to calculate initial margin requirements. ISDA_SIMM = ISDA Standard Initial Margin Model, SCHEDULE_BASED = fixed schedule approach, CCP_GRID = central counterparty grid-based calculation, INTERNAL_MODEL = proprietary internal model, STANDARDIZED = regulatory standardized approach.' ;
    rdfs:domain ind:MarginAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interestRateOnCashCollateral rdf:type rdf:Property ;
    rdfs:label 'Interest Rate On Cash Collateral' ;
    rdfs:comment 'Annual interest rate paid on cash collateral posted under this agreement, typically based on a benchmark rate such as SOFR or EONIA.' ;
    rdfs:domain ind:MarginAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lienPriority rdf:type rdf:Property ;
    rdfs:label 'Lien Priority' ;
    rdfs:comment 'Priority ranking of the security interest relative to other creditors. FIRST = first lien, SECOND = second lien, THIRD = third lien, SUBORDINATED = subordinated to other creditors, PARI_PASSU = equal ranking with other creditors.' ;
    rdfs:domain ind:Collateral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mtaCurrency rdf:type rdf:Property ;
    rdfs:label 'Mta Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the minimum transfer amount.' ;
    rdfs:domain ind:Collateral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryMarginRegime rdf:type rdf:Property ;
    rdfs:label 'Regulatory Margin Regime' ;
    rdfs:comment 'Applicable regulatory margin framework governing this agreement. UMR = Uncleared Margin Rules phases 1-6, EMIR = European Market Infrastructure Regulation, DODD_FRANK = Dodd-Frank Act margin rules, NONE = no specific regulatory regime applies. [ENUM-REF-CANDIDATE: UMR_PHASE_1|UMR_PHASE_2|UMR_PHASE_3|UMR_PHASE_4|UMR_PHASE_5|UMR_PHASE_6|EMIR|DODD_FRANK|NONE — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MarginAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rehypothecationRights rdf:type rdf:Property ;
    rdfs:label 'Rehypothecation Rights' ;
    rdfs:comment 'Indicates whether the collateral taker has the right to rehypothecate (reuse) posted collateral for its own purposes. True = rehypothecation allowed, False = collateral must be segregated.' ;
    rdfs:domain ind:MarginAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Date' ;
    rdfs:comment 'Date on which the margin agreement is scheduled for renewal or renegotiation. Nullable for agreements without automatic renewal.' ;
    rdfs:domain ind:Collateral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:roundingConvention rdf:type rdf:Property ;
    rdfs:label 'Rounding Convention' ;
    rdfs:comment 'Method used to round collateral transfer amounts. NEAREST = round to nearest unit, UP = always round up, DOWN = always round down, NONE = no rounding applied.' ;
    rdfs:domain ind:MarginAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roundingPrecision rdf:type rdf:Property ;
    rdfs:label 'Rounding Precision' ;
    rdfs:comment 'Precision unit for rounding collateral transfer amounts, typically expressed in the settlement currency (e.g., 1000 for rounding to nearest thousand).' ;
    rdfs:domain ind:MarginAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:substitutionRights rdf:type rdf:Property ;
    rdfs:label 'Substitution Rights' ;
    rdfs:comment 'Indicates whether the collateral provider has the right to substitute posted collateral with other eligible collateral. True = substitution allowed, False = no substitution permitted.' ;
    rdfs:domain ind:MarginAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:valuationAgent rdf:type rdf:Property ;
    rdfs:label 'Valuation Agent' ;
    rdfs:comment 'Entity responsible for determining the value of collateral and exposure. PARTY_A = bank, PARTY_B = counterparty, THIRD_PARTY = independent valuation service, MUTUAL = both parties agree on valuation.' ;
    rdfs:domain ind:Collateral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationFrequency rdf:type rdf:Property ;
    rdfs:label 'Valuation Frequency' ;
    rdfs:comment 'Frequency at which collateral and exposure are revalued for margin call purposes.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variationMarginSettlementCurrency rdf:type rdf:Property ;
    rdfs:label 'Variation Margin Settlement Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which variation margin is settled daily to reflect mark-to-market exposure changes.' ;
    rdfs:domain ind:MarginAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marginExposureId rdf:type rdf:Property ;
    rdfs:label 'Margin Exposure Id' ;
    rdfs:comment 'Foreign key linking to collateral.margin_exposure. Business justification: collateral_position is the inventory/position snapshot while margin_exposure is the calculated net mark-to-market exposure record. Linking the position to its corresponding exposure calculation allows' ;
    rdfs:domain ind:Collateral ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MarginExposure .

ind:primaryCollateralPartyId rdf:type rdf:Property ;
    rdfs:label 'Primary Collateral Party Id' ;
    rdfs:comment 'Reference to the custodian bank or depository institution holding the physical or book-entry collateral asset.' ;
    rdfs:domain ind:CollateralPosition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:collateralPostedValue rdf:type rdf:Property ;
    rdfs:label 'Collateral Posted Value' ;
    rdfs:comment 'The total haircut-adjusted value of collateral already posted to the counterparty as of the position date. Applicable to exposure-type positions.' ;
    rdfs:domain ind:CollateralPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collateralReceivedValue rdf:type rdf:Property ;
    rdfs:label 'Collateral Received Value' ;
    rdfs:comment 'The total haircut-adjusted value of collateral received from the counterparty as of the position date. Applicable to exposure-type positions.' ;
    rdfs:domain ind:CollateralPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditValuationAdjustment rdf:type rdf:Property ;
    rdfs:label 'Credit Valuation Adjustment' ;
    rdfs:comment 'The adjustment to the fair value of derivative positions to account for counterparty credit risk. Represents the market value of counterparty default risk. Applicable to exposure-type positions.' ;
    rdfs:domain ind:CollateralPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eligibilityStatus rdf:type rdf:Property ;
    rdfs:label 'Eligibility Status' ;
    rdfs:comment 'Indicates whether the collateral asset meets the eligibility criteria defined in the collateral agreement or regulatory framework: eligible (accepted), ineligible (rejected), restricted (conditionally accepted), pending_review (under evaluation).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exposureDate rdf:type rdf:Property ;
    rdfs:label 'Exposure Date' ;
    rdfs:comment 'For exposure-type positions, the date on which the counterparty credit exposure was calculated. Typically aligns with position_date but may differ for forward-looking exposure calculations.' ;
    rdfs:domain ind:Collateral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:grossNegativeExposure rdf:type rdf:Property ;
    rdfs:label 'Gross Negative Exposure' ;
    rdfs:comment 'The total mark-to-market value of all derivative and repo positions with the counterparty where the bank owes money, before netting or collateral offsets. Applicable to exposure-type positions.' ;
    rdfs:domain ind:CollateralPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossPositiveExposure rdf:type rdf:Property ;
    rdfs:label 'Gross Positive Exposure' ;
    rdfs:comment 'The total mark-to-market value of all derivative and repo positions with the counterparty where the bank is owed money, before netting or collateral offsets. Applicable to exposure-type positions.' ;
    rdfs:domain ind:CollateralPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:haircutValue rdf:type rdf:Property ;
    rdfs:label 'Haircut Value' ;
    rdfs:comment 'The collateral value after applying the haircut percentage. Calculated as market_value * (1 - haircut_percentage). This is the risk-adjusted collateral value recognized for margin and capital purposes.' ;
    rdfs:domain ind:CollateralPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netCurrentExposure rdf:type rdf:Property ;
    rdfs:label 'Net Current Exposure' ;
    rdfs:comment 'The net mark-to-market exposure after bilateral netting under a qualifying master netting agreement (e.g., ISDA Master Agreement). Calculated as max(GPE - GNE, 0). Applicable to exposure-type positions.' ;
    rdfs:domain ind:CollateralPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netMarginRequirement rdf:type rdf:Property ;
    rdfs:label 'Net Margin Requirement' ;
    rdfs:comment 'The net amount of additional collateral required (positive) or excess collateral available for return (negative) after considering threshold, MTA, independent amount, and collateral already posted/received. Applicable to exposure-type positions.' ;
    rdfs:domain ind:Collateral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rehypothecationAllowed rdf:type rdf:Property ;
    rdfs:label 'Rehypothecation Allowed' ;
    rdfs:comment 'Boolean flag indicating whether the collateral receiver is permitted to rehypothecate (reuse) the received collateral under the terms of the collateral agreement.' ;
    rdfs:domain ind:CollateralPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riskWeightedAssets rdf:type rdf:Property ;
    rdfs:label 'Risk Weighted Assets' ;
    rdfs:comment 'The regulatory capital requirement for this collateral position, calculated by applying risk weights to the exposure amount under Basel III standardized or internal ratings-based approaches. Applicable to exposure-type positions.' ;
    rdfs:domain ind:CollateralPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:substitutionRightExercised rdf:type rdf:Property ;
    rdfs:label 'Substitution Right Exercised' ;
    rdfs:comment 'Boolean flag indicating whether the collateral provider has exercised their right to substitute this collateral asset with another eligible asset under the terms of the CSA.' ;
    rdfs:domain ind:CollateralPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:thresholdBreachAmount rdf:type rdf:Property ;
    rdfs:label 'Threshold Breach Amount' ;
    rdfs:comment 'The amount by which the net current exposure exceeds the threshold amount, triggering a margin call requirement. Calculated as max(NCE - threshold_amount, 0). Applicable to exposure-type positions.' ;
    rdfs:domain ind:Collateral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exposureCurrencyId rdf:type rdf:Property ;
    rdfs:label 'Exposure Currency Id' ;
    rdfs:comment 'Foreign key linking to reference.currency. Business justification: margin_exposure.exposure_currency_code is a denormalized currency code. A proper FK to reference.currency is required for multi-currency exposure aggregation, CVA/DVA calculation currency conversion, ' ;
    rdfs:domain ind:MarginExposure ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:calculationRunCode rdf:type rdf:Property ;
    rdfs:label 'Calculation Run Code' ;
    rdfs:comment 'Identifier for the batch calculation run that produced this exposure record. Used for audit trail and reconciliation purposes.' ;
    rdfs:domain ind:MarginExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collateralCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Collateral Currency Code' ;
    rdfs:comment 'The three-letter ISO 4217 currency code for the eligible collateral currency specified in the CSA. Determines the currency in which collateral must be posted.' ;
    rdfs:domain ind:MarginExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collateralSegregationRequired rdf:type rdf:Property ;
    rdfs:label 'Collateral Segregation Required' ;
    rdfs:comment 'Indicates whether initial margin collateral must be held in a segregated account at a third-party custodian, as required by regulatory mandates for certain counterparties and jurisdictions.' ;
    rdfs:domain ind:MarginExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disputeThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Dispute Threshold Amount' ;
    rdfs:comment 'The minimum exposure difference amount that can trigger a formal dispute resolution process under the CSA. Valuation differences below this amount are typically resolved informally.' ;
    rdfs:domain ind:MarginExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dvaAmount rdf:type rdf:Property ;
    rdfs:label 'Dva Amount' ;
    rdfs:comment 'The adjustment to the fair value of derivative positions to account for the bank\'s own credit risk. Represents the benefit the bank receives from its own default risk.' ;
    rdfs:domain ind:MarginExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exposureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Exposure Timestamp' ;
    rdfs:comment 'The precise timestamp when the margin exposure calculation was performed, including time zone information.' ;
    rdfs:domain ind:MarginExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:gneAmount rdf:type rdf:Property ;
    rdfs:label 'Gne Amount' ;
    rdfs:comment 'The total mark-to-market value of all positions where the bank has a negative exposure to the counterparty (bank owes the counterparty). Represents the gross liability before netting and collateral.' ;
    rdfs:domain ind:MarginExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gpeAmount rdf:type rdf:Property ;
    rdfs:label 'Gpe Amount' ;
    rdfs:comment 'The total mark-to-market value of all positions where the bank has a positive exposure to the counterparty (counterparty owes the bank). Represents the gross amount at risk before netting and collateral.' ;
    rdfs:domain ind:MarginExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastMarginCallDate rdf:type rdf:Property ;
    rdfs:label 'Last Margin Call Date' ;
    rdfs:comment 'The date on which the most recent margin call was issued for this margin agreement and counterparty.' ;
    rdfs:domain ind:MarginExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:marginCallDirection rdf:type rdf:Property ;
    rdfs:label 'Margin Call Direction' ;
    rdfs:comment 'Indicates the direction of the margin call: whether the bank is calling for collateral from the counterparty, the counterparty is calling from the bank, or no call is required.' ;
    rdfs:domain ind:MarginExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marginPeriodOfRiskDays rdf:type rdf:Property ;
    rdfs:label 'Margin Period Of Risk Days' ;
    rdfs:comment 'The number of days between the last margin call and the closeout of positions following a counterparty default. Used in calculating initial margin requirements. Typically 10 days for standard CSAs.' ;
    rdfs:domain ind:MarginExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nceAmount rdf:type rdf:Property ;
    rdfs:label 'Nce Amount' ;
    rdfs:comment 'The net mark-to-market exposure after bilateral netting of all positions under the margin agreement. Calculated as GPE minus GNE. Positive values indicate the bank is owed; negative values indicate the bank owes.' ;
    rdfs:domain ind:MarginExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netCollateralPosition rdf:type rdf:Property ;
    rdfs:label 'Net Collateral Position' ;
    rdfs:comment 'The net collateral position calculated as collateral received minus collateral posted. Positive values indicate the bank holds net collateral; negative values indicate the bank has posted net collateral.' ;
    rdfs:domain ind:MarginExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextMarginCallDate rdf:type rdf:Property ;
    rdfs:label 'Next Margin Call Date' ;
    rdfs:comment 'The next scheduled date on which a margin call may be issued based on the CSA terms. Typically daily for most CSAs but may be less frequent for certain counterparties.' ;
    rdfs:domain ind:MarginExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pfeAmount rdf:type rdf:Property ;
    rdfs:label 'Pfe Amount' ;
    rdfs:comment 'The estimated maximum exposure that could arise in the future due to market movements, calculated using regulatory or internal models. Used for regulatory capital calculations and risk management.' ;
    rdfs:domain ind:MarginExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryImModel rdf:type rdf:Property ;
    rdfs:label 'Regulatory Im Model' ;
    rdfs:comment 'The regulatory model used to calculate initial margin requirements. SIMM (Standard Initial Margin Model) is the industry standard; grid and schedule are simplified approaches; internal models require regulatory approval.' ;
    rdfs:domain ind:MarginExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPledgeObligorPartyId rdf:type rdf:Property ;
    rdfs:label 'Primary Pledge Obligor Party Id' ;
    rdfs:comment 'Identifier of the party pledging collateral (borrower or debtor) under this agreement.' ;
    rdfs:domain ind:PledgeAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:tertiaryPledgeCustodianPartyId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Pledge Custodian Party Id' ;
    rdfs:comment 'Identifier of the third-party custodian or trustee holding the collateral assets on behalf of the secured party.' ;
    rdfs:domain ind:PledgeAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:accelerationClauseFlag rdf:type rdf:Property ;
    rdfs:label 'Acceleration Clause Flag' ;
    rdfs:comment 'Indicates whether the agreement contains acceleration provisions allowing the secured party to demand immediate payment of all obligations upon default.' ;
    rdfs:domain ind:PledgeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:agreementNotes rdf:type rdf:Property ;
    rdfs:label 'Agreement Notes' ;
    rdfs:comment 'Free-form text field for additional comments, special terms, exceptions, or operational notes related to this pledge agreement.' ;
    rdfs:domain ind:PledgeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Agreement Reference Number' ;
    rdfs:comment 'External business reference number or contract identifier for the pledge agreement, used in legal documentation and correspondence.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collateralDescription rdf:type rdf:Property ;
    rdfs:label 'Collateral Description' ;
    rdfs:comment 'Detailed textual description of the collateral assets covered by this pledge agreement, including asset types, identifiers, and any specific inclusions or exclusions.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossDefaultProvisionFlag rdf:type rdf:Property ;
    rdfs:label 'Cross Default Provision Flag' ;
    rdfs:comment 'Indicates whether the agreement includes cross-default clauses that trigger default if the obligor defaults on other obligations.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:filingReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Filing Reference Number' ;
    rdfs:comment 'Official registration or filing number assigned by the relevant authority (e.g., UCC filing number, land registry number).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdiction rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction' ;
    rdfs:comment 'Geographic or legal jurisdiction where disputes will be resolved and where the agreement is enforceable.' ;
    rdfs:domain ind:PledgeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marginCallThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Margin Call Threshold Amount' ;
    rdfs:comment 'Minimum collateral value shortfall that triggers a margin call requiring additional collateral to be posted.' ;
    rdfs:domain ind:PledgeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumCollateralCoverageRatio rdf:type rdf:Property ;
    rdfs:label 'Minimum Collateral Coverage Ratio' ;
    rdfs:comment 'Required minimum ratio of collateral value to secured obligation amount, expressed as a percentage (e.g., 125.00 means 125% coverage required).' ;
    rdfs:domain ind:PledgeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nettingAgreementFlag rdf:type rdf:Property ;
    rdfs:label 'Netting Agreement Flag' ;
    rdfs:comment 'Indicates whether this pledge agreement is part of a master netting arrangement allowing offset of obligations across multiple transactions.' ;
    rdfs:domain ind:PledgeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rwaReductionPercentage rdf:type rdf:Property ;
    rdfs:label 'Rwa Reduction Percentage' ;
    rdfs:comment 'Percentage reduction in Risk-Weighted Assets (RWA) achieved through this collateral arrangement for regulatory capital purposes.' ;
    rdfs:domain ind:PledgeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:securedObligationAmount rdf:type rdf:Property ;
    rdfs:label 'Secured Obligation Amount' ;
    rdfs:comment 'Total monetary amount of the debt or obligation secured by this pledge agreement.' ;
    rdfs:domain ind:PledgeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:substitutionRightsFlag rdf:type rdf:Property ;
    rdfs:label 'Substitution Rights Flag' ;
    rdfs:comment 'Indicates whether the obligor has the right to substitute collateral assets with equivalent eligible assets during the agreement term.' ;
    rdfs:domain ind:Collateral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:governingLawJurisdictionCountryId rdf:type rdf:Property ;
    rdfs:label 'Governing Law Jurisdiction Country Id' ;
    rdfs:comment 'Foreign key linking to reference.country. Business justification: Governing law jurisdiction determines netting enforceability and regulatory capital recognition. Creating governing_law_jurisdiction_country_id FK to replace jurisdiction code.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:primaryNettingCustodianPartyId rdf:type rdf:Property ;
    rdfs:label 'Primary Netting Custodian Party Id' ;
    rdfs:comment 'Reference to the third-party custodian holding segregated initial margin collateral for this netting set, if segregation is required.' ;
    rdfs:domain ind:NettingSet ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:capitalTreatmentApproach rdf:type rdf:Property ;
    rdfs:label 'Capital Treatment Approach' ;
    rdfs:comment 'Regulatory approach used for calculating counterparty credit risk capital requirements for this netting set: SA-CCR (Standardized Approach for Counterparty Credit Risk), IMM (Internal Models Method), CEM (Current Exposure Method), or Standardized Approach.' ;
    rdfs:domain ind:NettingSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initialMarginRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Initial Margin Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether initial margin is required for this netting set under the applicable margin agreement or regulatory requirements (e.g., UMR).' ;
    rdfs:domain ind:NettingSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastValuationDate rdf:type rdf:Property ;
    rdfs:label 'Last Valuation Date' ;
    rdfs:comment 'Most recent date on which derivative positions within the netting set were valued for exposure and margin call calculation purposes.' ;
    rdfs:domain ind:NettingSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalOpinionDate rdf:type rdf:Property ;
    rdfs:label 'Legal Opinion Date' ;
    rdfs:comment 'Date on which the legal opinion confirming netting enforceability was issued or last reviewed by legal counsel.' ;
    rdfs:domain ind:NettingSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:marginAgreementType rdf:type rdf:Property ;
    rdfs:label 'Margin Agreement Type' ;
    rdfs:comment 'Type of margin agreement governing collateral exchange: bilateral (both parties post collateral), unilateral (only one party posts), or no margin agreement in place.' ;
    rdfs:domain ind:NettingSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nettingEnforceabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Netting Enforceability Status' ;
    rdfs:comment 'Legal opinion status indicating whether close-out netting under the ISDA Master Agreement is legally enforceable in the relevant jurisdiction. Critical for regulatory capital treatment.' ;
    rdfs:domain ind:NettingSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nettingSetStatus rdf:type rdf:Property ;
    rdfs:label 'Netting Set Status' ;
    rdfs:comment 'Current lifecycle status of the netting set indicating whether it is actively used for netting derivative exposures or has been suspended or terminated.' ;
    rdfs:domain ind:NettingSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextValuationDate rdf:type rdf:Property ;
    rdfs:label 'Next Valuation Date' ;
    rdfs:comment 'Next scheduled date on which derivative positions within the netting set will be valued for exposure and margin call calculation purposes.' ;
    rdfs:domain ind:NettingSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notificationTime rdf:type rdf:Property ;
    rdfs:label 'Notification Time' ;
    rdfs:comment 'Deadline by which margin call notifications must be sent to the counterparty, typically expressed as a time of day in a specific time zone.' ;
    rdfs:domain ind:NettingSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:productScope rdf:type rdf:Property ;
    rdfs:label 'Product Scope' ;
    rdfs:comment 'Comma-separated list of derivative product types included in this netting set (e.g., rates, FX, credit, equity, commodities). Defines the breadth of transactions subject to netting.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rehypothecationRightsFlag rdf:type rdf:Property ;
    rdfs:label 'Rehypothecation Rights Flag' ;
    rdfs:comment 'Boolean flag indicating whether the secured party has the right to rehypothecate (reuse) collateral posted by the counterparty for its own purposes.' ;
    rdfs:domain ind:NettingSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:roundingAmount rdf:type rdf:Property ;
    rdfs:label 'Rounding Amount' ;
    rdfs:comment 'Amount to which margin call calculations are rounded to simplify collateral transfers and reduce operational complexity.' ;
    rdfs:domain ind:NettingSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:roundingCurrency rdf:type rdf:Property ;
    rdfs:label 'Rounding Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the rounding amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:NettingSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segregationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Segregation Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether initial margin must be segregated with a third-party custodian to protect against counterparty default, as required under UMR.' ;
    rdfs:domain ind:NettingSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:thresholdCurrency rdf:type rdf:Property ;
    rdfs:label 'Threshold Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the threshold amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationTime rdf:type rdf:Property ;
    rdfs:label 'Valuation Time' ;
    rdfs:comment 'Specified time of day (e.g., close of business, 4:00 PM New York time) at which derivative positions are valued for margin call calculations.' ;
    rdfs:domain ind:NettingSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:variationMarginRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Variation Margin Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether variation margin is required for this netting set to cover mark-to-market exposure fluctuations.' ;
    rdfs:domain ind:NettingSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:alcoReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Alco Reporting Flag' ;
    rdfs:comment 'Indicates whether this liquidity position record is included in ALCO reporting packages for senior management and board oversight.' ;
    rdfs:domain ind:Treasury ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:availableLiquidityAmount rdf:type rdf:Property ;
    rdfs:label 'Available Liquidity Amount' ;
    rdfs:comment 'Total available liquidity calculated as liquid assets plus cash balances plus undrawn facilities plus net cash inflows for the tenor bucket.' ;
    rdfs:domain ind:LiquidityPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:behavioralInflowAmount rdf:type rdf:Property ;
    rdfs:label 'Behavioral Inflow Amount' ;
    rdfs:comment 'Projected cash inflows from behavioral assumptions within the tenor bucket, including expected deposit inflows and credit line repayments based on historical patterns.' ;
    rdfs:domain ind:Treasury ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:behavioralOutflowAmount rdf:type rdf:Property ;
    rdfs:label 'Behavioral Outflow Amount' ;
    rdfs:comment 'Projected cash outflows from behavioral assumptions within the tenor bucket, including deposit runoff rates and credit line drawdown expectations based on historical patterns.' ;
    rdfs:domain ind:Treasury ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cashBalance rdf:type rdf:Property ;
    rdfs:label 'Cash Balance' ;
    rdfs:comment 'Total cash balances held across all nostro accounts, correspondent banking accounts, and internal cash accounts in the specified currency.' ;
    rdfs:domain ind:LiquidityPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:centralBankReserveBalance rdf:type rdf:Property ;
    rdfs:label 'Central Bank Reserve Balance' ;
    rdfs:comment 'Balance held in reserve accounts at central banks (e.g., Federal Reserve, ECB), representing the highest quality liquid asset.' ;
    rdfs:domain ind:LiquidityPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contingencyFundingTriggerStatus rdf:type rdf:Property ;
    rdfs:label 'Contingency Funding Trigger Status' ;
    rdfs:comment 'Current status of contingency funding plan triggers based on liquidity position and market conditions: normal operations, early warning, stress, or crisis.' ;
    rdfs:domain ind:Treasury ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractualInflowAmount rdf:type rdf:Property ;
    rdfs:label 'Contractual Inflow Amount' ;
    rdfs:comment 'Projected cash inflows from contractual obligations within the tenor bucket, including loan repayments, bond maturities, coupon payments, and maturing investments.' ;
    rdfs:domain ind:Treasury ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractualOutflowAmount rdf:type rdf:Property ;
    rdfs:label 'Contractual Outflow Amount' ;
    rdfs:comment 'Projected cash outflows from contractual obligations within the tenor bucket, including debt maturities, interest payments, and committed funding obligations.' ;
    rdfs:domain ind:Treasury ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cumulativeNetCashFlowAmount rdf:type rdf:Property ;
    rdfs:label 'Cumulative Net Cash Flow Amount' ;
    rdfs:comment 'Cumulative net cash flow from position date through the end of the tenor bucket, used for forward liquidity gap analysis.' ;
    rdfs:domain ind:Treasury ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interbankFundingAmount rdf:type rdf:Property ;
    rdfs:label 'Interbank Funding Amount' ;
    rdfs:comment 'Total unsecured interbank borrowing outstanding at the position date, including federal funds purchased and interbank deposits.' ;
    rdfs:domain ind:LiquidityPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:liquidAssetBalance rdf:type rdf:Property ;
    rdfs:label 'Liquid Asset Balance' ;
    rdfs:comment 'Total value of high-quality liquid assets (HQLA) available for immediate liquidation, including Level 1 and Level 2 assets per Basel III LCR framework.' ;
    rdfs:domain ind:LiquidityPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netCashFlowAmount rdf:type rdf:Property ;
    rdfs:label 'Net Cash Flow Amount' ;
    rdfs:comment 'Net projected cash flow for the tenor bucket, calculated as total inflows minus total outflows (contractual plus behavioral).' ;
    rdfs:domain ind:Treasury ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nsfrBufferAmount rdf:type rdf:Property ;
    rdfs:label 'Nsfr Buffer Amount' ;
    rdfs:comment 'Excess stable funding buffer above the regulatory minimum NSFR requirement, calculated as (NSFR ratio - 100%) multiplied by required stable funding.' ;
    rdfs:domain ind:LiquidityPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:repoFundingAmount rdf:type rdf:Property ;
    rdfs:label 'Repo Funding Amount' ;
    rdfs:comment 'Total funding obtained through repurchase agreements (repos) outstanding at the position date, representing secured short-term borrowing.' ;
    rdfs:domain ind:LiquidityPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reverseRepoFundingAmount rdf:type rdf:Property ;
    rdfs:label 'Reverse Repo Funding Amount' ;
    rdfs:comment 'Total funding provided through reverse repurchase agreements (reverse repos) outstanding at the position date, representing secured short-term lending.' ;
    rdfs:domain ind:LiquidityPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tenorBucket rdf:type rdf:Property ;
    rdfs:label 'Tenor Bucket' ;
    rdfs:comment 'Time horizon bucket for cash flow forecasting: intraday, overnight, 1 week, 2 weeks, 1 month, 3 months, 6 months, or 1 year. [ENUM-REF-CANDIDATE: intraday|overnight|1W|2W|1M|3M|6M|1Y — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Treasury ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:undrawnCommittedFacilityAmount rdf:type rdf:Property ;
    rdfs:label 'Undrawn Committed Facility Amount' ;
    rdfs:comment 'Total amount of undrawn committed credit facilities available to the bank for liquidity purposes, including interbank lines and central bank standing facilities.' ;
    rdfs:domain ind:LiquidityPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportingCurrencyId rdf:type rdf:Property ;
    rdfs:label 'Reporting Currency Id' ;
    rdfs:comment 'Foreign key linking to reference.currency. Business justification: LCR/NSFR ratios reported in specific currency for regulatory submission. Link enables multi-currency consolidation, FX revaluation for base currency reporting, and validation of regulatory currency re' ;
    rdfs:domain ind:Treasury ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:alcoApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Alco Approval Status' ;
    rdfs:comment 'The approval status of the liquidity ratio by the ALCO, indicating whether the ratio and any remediation plans have been formally accepted.' ;
    rdfs:domain ind:LiquidityRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alcoReviewDate rdf:type rdf:Property ;
    rdfs:label 'Alco Review Date' ;
    rdfs:comment 'The date on which the liquidity ratio was reviewed and approved by the Asset-Liability Committee for internal governance and risk management.' ;
    rdfs:domain ind:Treasury ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:breachFlag rdf:type rdf:Property ;
    rdfs:label 'Breach Flag' ;
    rdfs:comment 'Boolean indicator of whether the liquidity ratio is below the regulatory minimum threshold. True indicates a breach requiring immediate remediation and regulatory notification.' ;
    rdfs:domain ind:LiquidityRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bufferPercentage rdf:type rdf:Property ;
    rdfs:label 'Buffer Percentage' ;
    rdfs:comment 'The buffer above the regulatory minimum threshold, calculated as (Actual Ratio - Regulatory Threshold). Positive values indicate compliance buffer; negative values indicate breach.' ;
    rdfs:domain ind:LiquidityRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consolidationLevel rdf:type rdf:Property ;
    rdfs:label 'Consolidation Level' ;
    rdfs:comment 'The level of consolidation for the liquidity ratio calculation: solo entity, fully consolidated group, or sub-consolidated group.' ;
    rdfs:domain ind:Treasury ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:derivativeOutflowAmount rdf:type rdf:Property ;
    rdfs:label 'Derivative Outflow Amount' ;
    rdfs:comment 'Expected cash outflows from derivative contracts and collateral calls over the 30-day stress horizon.' ;
    rdfs:domain ind:LiquidityRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hqlaLevel1Amount rdf:type rdf:Property ;
    rdfs:label 'Hqla Level 1 Amount' ;
    rdfs:comment 'Total value of Level 1 HQLA (cash, central bank reserves, sovereign debt) eligible for LCR numerator with 0% haircut.' ;
    rdfs:domain ind:LiquidityRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hqlaLevel2aAmount rdf:type rdf:Property ;
    rdfs:label 'Hqla Level 2a Amount' ;
    rdfs:comment 'Total value of Level 2A HQLA (high-quality corporate bonds, covered bonds) eligible for LCR numerator with 15% haircut.' ;
    rdfs:domain ind:LiquidityRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hqlaLevel2bAmount rdf:type rdf:Property ;
    rdfs:label 'Hqla Level 2b Amount' ;
    rdfs:comment 'Total value of Level 2B HQLA (lower-rated corporate bonds, residential mortgage-backed securities, equities) eligible for LCR numerator with haircuts ranging from 25% to 50%.' ;
    rdfs:domain ind:LiquidityRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lcrPercentage rdf:type rdf:Property ;
    rdfs:label 'Lcr Percentage' ;
    rdfs:comment 'The calculated LCR expressed as a percentage. Calculated as (Total HQLA / Total Net Cash Outflows) * 100. Regulatory minimum is 100%.' ;
    rdfs:domain ind:LiquidityRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nsfrPercentage rdf:type rdf:Property ;
    rdfs:label 'Nsfr Percentage' ;
    rdfs:comment 'The calculated NSFR expressed as a percentage. Calculated as (Available Stable Funding / Required Stable Funding) * 100. Regulatory minimum is 100%.' ;
    rdfs:domain ind:LiquidityRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:periodOverPeriodChangePercentage rdf:type rdf:Property ;
    rdfs:label 'Period Over Period Change Percentage' ;
    rdfs:comment 'The percentage point change in the liquidity ratio compared to the prior reporting period. Calculated as (Current Ratio - Prior Period Ratio).' ;
    rdfs:domain ind:LiquidityRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorPeriodRatioPercentage rdf:type rdf:Property ;
    rdfs:label 'Prior Period Ratio Percentage' ;
    rdfs:comment 'The liquidity ratio percentage from the previous reporting period, used for trend analysis and variance reporting.' ;
    rdfs:domain ind:LiquidityRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ratioType rdf:type rdf:Property ;
    rdfs:label 'Ratio Type' ;
    rdfs:comment 'Discriminator indicating the type of liquidity ratio: LCR (Liquidity Coverage Ratio) for 30-day stress horizon or NSFR (Net Stable Funding Ratio) for one-year structural funding stability.' ;
    rdfs:domain ind:LiquidityRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorySubmissionFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Flag' ;
    rdfs:comment 'Indicates whether this liquidity ratio record was submitted to regulatory authorities (Federal Reserve, OCC) as part of formal Basel III reporting.' ;
    rdfs:domain ind:Treasury ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryThresholdPercentage rdf:type rdf:Property ;
    rdfs:label 'Regulatory Threshold Percentage' ;
    rdfs:comment 'The regulatory minimum threshold for the ratio (typically 100% for both LCR and NSFR under Basel III).' ;
    rdfs:domain ind:LiquidityRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportingPeriod rdf:type rdf:Property ;
    rdfs:label 'Reporting Period' ;
    rdfs:comment 'The reporting period identifier (e.g., Q1 2024, 2024-01-31) for regulatory submission and internal ALCO reporting.' ;
    rdfs:domain ind:Treasury ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securedFundingOutflowAmount rdf:type rdf:Property ;
    rdfs:label 'Secured Funding Outflow Amount' ;
    rdfs:comment 'Expected cash outflows from maturing secured funding transactions (repos, covered bonds) over the 30-day stress horizon.' ;
    rdfs:domain ind:LiquidityRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalHqlaAmount rdf:type rdf:Property ;
    rdfs:label 'Total Hqla Amount' ;
    rdfs:comment 'Total stock of HQLA after applying haircuts and caps. Numerator of the LCR calculation.' ;
    rdfs:domain ind:LiquidityRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalNetCashOutflowAmount rdf:type rdf:Property ;
    rdfs:label 'Total Net Cash Outflow Amount' ;
    rdfs:comment 'Total expected net cash outflows over the 30-day stress scenario. Denominator of the LCR calculation.' ;
    rdfs:domain ind:LiquidityRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hqlaInventoryId rdf:type rdf:Property ;
    rdfs:label 'Hqla Inventory Id' ;
    rdfs:comment 'Unique identifier for each HQLA inventory record. Primary key for the HQLA inventory master.' ;
    rdfs:domain ind:HqlaInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:issuerJurisdictionId rdf:type rdf:Property ;
    rdfs:label 'Issuer Jurisdiction Id' ;
    rdfs:comment 'Foreign key linking to reference.jurisdiction. Business justification: Basel III LCR rules define HQLA eligibility and haircuts by jurisdiction (ECB, Fed, PRA differ). HQLA classification (hqla_level, eligibility_status, haircut_percentage) is governed by the issuer\'s re' ;
    rdfs:domain ind:HqlaInventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Jurisdiction .

ind:issuerLeiRegistryId rdf:type rdf:Property ;
    rdfs:label 'Issuer Lei Registry Id' ;
    rdfs:comment 'Foreign key linking to reference.lei_registry. Business justification: HQLA inventory tracks issuer by LEI for counterparty identification. Link enables concentration risk monitoring, ultimate parent lookup, regulatory reporting (e.g., FR 2052a), and sanctions screening.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LeiRegistry .

ind:businessUnit rdf:type rdf:Property ;
    rdfs:label 'Business Unit' ;
    rdfs:comment 'Internal organizational unit or treasury desk responsible for managing this HQLA position.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:encumberedAmount rdf:type rdf:Property ;
    rdfs:label 'Encumbered Amount' ;
    rdfs:comment 'Market value of the asset that is pledged, restricted, or otherwise encumbered and not available for LCR purposes.' ;
    rdfs:domain ind:HqlaInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hqlaLevel rdf:type rdf:Property ;
    rdfs:label 'Hqla Level' ;
    rdfs:comment 'Classification of the asset under Basel III liquidity framework: Level 1 (central bank reserves, sovereign bonds with 0% haircut), Level 2A (agency MBS, covered bonds with 15% haircut), or Level 2B (corporate bonds, equities with 50% haircut).' ;
    rdfs:domain ind:HqlaInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hqlaValueAmount rdf:type rdf:Property ;
    rdfs:label 'Hqla Value Amount' ;
    rdfs:comment 'Post-haircut value of the asset eligible for LCR calculation, computed as market value multiplied by (1 minus haircut percentage).' ;
    rdfs:domain ind:HqlaInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ineligibilityReason rdf:type rdf:Property ;
    rdfs:label 'Ineligibility Reason' ;
    rdfs:comment 'Explanation of why the asset does not qualify for HQLA treatment, if eligibility status is Ineligible or Conditionally Eligible.' ;
    rdfs:domain ind:HqlaInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lcrInclusionFlag rdf:type rdf:Property ;
    rdfs:label 'Lcr Inclusion Flag' ;
    rdfs:comment 'Boolean indicator of whether this asset is currently included in the LCR numerator calculation.' ;
    rdfs:domain ind:Treasury ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:movementDate rdf:type rdf:Property ;
    rdfs:label 'Movement Date' ;
    rdfs:comment 'Date on which the most recent inventory movement or change occurred.' ;
    rdfs:domain ind:HqlaInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:movementType rdf:type rdf:Property ;
    rdfs:label 'Movement Type' ;
    rdfs:comment 'Classification of the most recent change to the HQLA inventory record, tracking asset lifecycle events. [ENUM-REF-CANDIDATE: Addition|Disposal|Substitution|Encumbrance Change|Valuation Adjustment|Maturity|Transfer In|Transfer Out — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:HqlaInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nominalAmount rdf:type rdf:Property ;
    rdfs:label 'Nominal Amount' ;
    rdfs:comment 'Face value or par value of the security holdings in the security\'s denomination currency.' ;
    rdfs:domain ind:HqlaInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nsfrInclusionFlag rdf:type rdf:Property ;
    rdfs:label 'Nsfr Inclusion Flag' ;
    rdfs:comment 'Boolean indicator of whether this asset is included in the NSFR available stable funding calculation.' ;
    rdfs:domain ind:Treasury ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unencumberedHqlaValueAmount rdf:type rdf:Property ;
    rdfs:label 'Unencumbered Hqla Value Amount' ;
    rdfs:comment 'Post-haircut value of the unencumbered portion of the asset that qualifies for LCR numerator calculation.' ;
    rdfs:domain ind:HqlaInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:alcoReportingCategory rdf:type rdf:Property ;
    rdfs:label 'Alco Reporting Category' ;
    rdfs:comment 'Classification category for ALCO reporting purposes, grouping placements by strategic funding or investment bucket for balance sheet management.' ;
    rdfs:domain ind:Treasury ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benchmarkRateValue rdf:type rdf:Property ;
    rdfs:label 'Benchmark Rate Value' ;
    rdfs:comment 'The actual benchmark rate value at trade execution, expressed as a percentage (e.g., 5.25 for 5.25%). Null if placement is fixed rate with no benchmark.' ;
    rdfs:domain ind:InterbankPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bookingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Booking Timestamp' ;
    rdfs:comment 'Timestamp when the placement transaction was recorded in the treasury management system.' ;
    rdfs:domain ind:InterbankPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:counterpartyConcentrationFlag rdf:type rdf:Property ;
    rdfs:label 'Counterparty Concentration Flag' ;
    rdfs:comment 'Indicates whether this placement contributes to a counterparty concentration risk threshold breach (True) or not (False), used for large exposure monitoring.' ;
    rdfs:domain ind:InterbankPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:expectedCreditLoss rdf:type rdf:Property ;
    rdfs:label 'Expected Credit Loss' ;
    rdfs:comment 'Calculated expected credit loss provision for this placement under IFRS 9 or CECL methodology, based on PD, LGD, and EAD.' ;
    rdfs:domain ind:InterbankPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exposureAtDefault rdf:type rdf:Property ;
    rdfs:label 'Exposure At Default' ;
    rdfs:comment 'Total exposure amount at risk if the counterparty defaults, including notional principal and accrued interest, used for credit risk capital calculation.' ;
    rdfs:domain ind:InterbankPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:liquidityGapBucket rdf:type rdf:Property ;
    rdfs:label 'Liquidity Gap Bucket' ;
    rdfs:comment 'Time bucket for liquidity gap analysis based on remaining maturity: overnight, 1-7 days, 8-30 days, 31-90 days, 91-180 days, 181-365 days, or over 1 year. [ENUM-REF-CANDIDATE: overnight|1_7_days|8_30_days|31_90_days|91_180_days|181_365_days|over_1_year — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InterbankPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lossGivenDefault rdf:type rdf:Property ;
    rdfs:label 'Loss Given Default' ;
    rdfs:comment 'Estimated percentage of exposure that will be lost if the counterparty defaults, expressed as a decimal (e.g., 0.45 for 45%), used for ECL calculation.' ;
    rdfs:domain ind:InterbankPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nsfrAsfFactor rdf:type rdf:Property ;
    rdfs:label 'Nsfr Asf Factor' ;
    rdfs:comment 'Available Stable Funding factor applied to this placement for NSFR calculation, expressed as a decimal (e.g., 0.85 for 85%).' ;
    rdfs:domain ind:InterbankPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nsfrRsfFactor rdf:type rdf:Property ;
    rdfs:label 'Nsfr Rsf Factor' ;
    rdfs:comment 'Required Stable Funding factor applied to this placement for NSFR calculation, expressed as a decimal (e.g., 0.50 for 50%).' ;
    rdfs:domain ind:InterbankPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:placementReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Placement Reference Number' ;
    rdfs:comment 'External business identifier for the interbank placement transaction, used for operational reference and reconciliation with counterparties.' ;
    rdfs:domain ind:InterbankPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:placementType rdf:type rdf:Property ;
    rdfs:label 'Placement Type' ;
    rdfs:comment 'Classification of the interbank placement by tenor structure: overnight (1 day), term (fixed maturity), call money (callable on demand), notice (requires advance notice), or fixed deposit.' ;
    rdfs:domain ind:InterbankPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:probabilityOfDefault rdf:type rdf:Property ;
    rdfs:label 'Probability Of Default' ;
    rdfs:comment 'Estimated probability that the counterparty will default within one year, expressed as a decimal (e.g., 0.0025 for 0.25%), used for Expected Credit Loss (ECL) calculation.' ;
    rdfs:domain ind:InterbankPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rolloverInstruction rdf:type rdf:Property ;
    rdfs:label 'Rollover Instruction' ;
    rdfs:comment 'Type of rollover instruction: automatic (system-driven rollover), manual (requires explicit approval), or none (no rollover planned).' ;
    rdfs:domain ind:InterbankPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rolloverStatus rdf:type rdf:Property ;
    rdfs:label 'Rollover Status' ;
    rdfs:comment 'Indicates whether the placement is subject to rollover at maturity: none (no rollover), pending (rollover requested), executed (rolled over), or declined (rollover not agreed).' ;
    rdfs:domain ind:InterbankPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionDirection rdf:type rdf:Property ;
    rdfs:label 'Transaction Direction' ;
    rdfs:comment 'Indicates whether the bank is placing funds with a counterparty (asset) or borrowing funds from a counterparty (liability).' ;
    rdfs:domain ind:InterbankPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collateralFundId rdf:type rdf:Property ;
    rdfs:label 'Collateral Fund Id' ;
    rdfs:comment 'Foreign key linking to asset.fund. Business justification: Repo transactions use fund units as collateral in tri-party arrangements. Treasury must track which funds are pledged, their market value, haircuts, and substitution rights for collateral management a' ;
    rdfs:domain ind:Treasury ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fund .

ind:settlementHolidayCalendarId rdf:type rdf:Property ;
    rdfs:label 'Settlement Holiday Calendar Id' ;
    rdfs:comment 'Foreign key linking to reference.holiday_calendar. Business justification: Repo settlement_date and maturity_date calculations require the applicable market holiday calendar for business day convention adjustments. Banking repo operations teams must reference the correct set' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HolidayCalendar .

ind:cumulativePnl rdf:type rdf:Property ;
    rdfs:label 'Cumulative Pnl' ;
    rdfs:comment 'The cumulative profit or loss on the repo position from inception to the current valuation date.' ;
    rdfs:domain ind:RepoPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dailyPnl rdf:type rdf:Property ;
    rdfs:label 'Daily Pnl' ;
    rdfs:comment 'The daily profit or loss attributed to this repo position, calculated from mark-to-market changes and accrued interest.' ;
    rdfs:domain ind:RepoPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lcrClassification rdf:type rdf:Property ;
    rdfs:label 'Lcr Classification' ;
    rdfs:comment 'Classification of the collateral for LCR purposes: HQLA Level 1, HQLA Level 2A, HQLA Level 2B, or non-HQLA.' ;
    rdfs:domain ind:RepoPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mtmDate rdf:type rdf:Property ;
    rdfs:label 'Mtm Date' ;
    rdfs:comment 'The date as of which the mark-to-market valuation was calculated.' ;
    rdfs:domain ind:RepoPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mtmValuation rdf:type rdf:Property ;
    rdfs:label 'Mtm Valuation' ;
    rdfs:comment 'The current mark-to-market valuation of the repo position, reflecting changes in collateral value and accrued interest.' ;
    rdfs:domain ind:RepoPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nsfrClassification rdf:type rdf:Property ;
    rdfs:label 'Nsfr Classification' ;
    rdfs:comment 'Required Stable Funding (RSF) factor classification for NSFR calculation: 0%, 5%, 10%, 15%, 50%, 65%, 85%, or 100%. [ENUM-REF-CANDIDATE: rsf_0|rsf_5|rsf_10|rsf_15|rsf_50|rsf_65|rsf_85|rsf_100 — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RepoPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryTreatment rdf:type rdf:Property ;
    rdfs:label 'Regulatory Treatment' ;
    rdfs:comment 'The regulatory accounting treatment applied to the repo position: true sale, secured financing, on-balance-sheet, or off-balance-sheet.' ;
    rdfs:domain ind:Treasury ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repoRate rdf:type rdf:Property ;
    rdfs:label 'Repo Rate' ;
    rdfs:comment 'The annualized interest rate applied to the repo transaction, expressed as a decimal (e.g., 0.0525 for 5.25%).' ;
    rdfs:domain ind:Treasury ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:repoType rdf:type rdf:Property ;
    rdfs:label 'Repo Type' ;
    rdfs:comment 'Classification of the repurchase agreement structure: classic repo, sell/buy-back, tri-party, hold-in-custody, or bilateral.' ;
    rdfs:domain ind:RepoPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termType rdf:type rdf:Property ;
    rdfs:label 'Term Type' ;
    rdfs:comment 'Classification of the repo duration: open (no fixed maturity), term (fixed maturity), or overnight.' ;
    rdfs:domain ind:RepoPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triPartyAgent rdf:type rdf:Property ;
    rdfs:label 'Tri Party Agent' ;
    rdfs:comment 'The name of the tri-party agent managing collateral for tri-party repo transactions.' ;
    rdfs:domain ind:Treasury ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookingSystem rdf:type rdf:Property ;
    rdfs:label 'Booking System' ;
    rdfs:comment 'The name of the source trading or treasury management system where this repo transaction was originally booked (e.g., Murex, Calypso).' ;
    rdfs:domain ind:Treasury ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingHouse rdf:type rdf:Property ;
    rdfs:label 'Clearing House' ;
    rdfs:comment 'The name of the central counterparty (CCP) or clearing house used for this repo transaction, if centrally cleared.' ;
    rdfs:domain ind:RepoTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collateralMarketValue rdf:type rdf:Property ;
    rdfs:label 'Collateral Market Value' ;
    rdfs:comment 'The current market value of the collateral asset as of the valuation date, used for margin call calculations.' ;
    rdfs:domain ind:RepoTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fundingCostAmount rdf:type rdf:Property ;
    rdfs:label 'Funding Cost Amount' ;
    rdfs:comment 'The calculated funding cost for this repo transaction, feeding into the treasury funding cost ledger.' ;
    rdfs:domain ind:RepoTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fundingCostRate rdf:type rdf:Property ;
    rdfs:label 'Funding Cost Rate' ;
    rdfs:comment 'The internal funds transfer pricing (FTP) rate applied to this repo transaction for treasury funding cost allocation.' ;
    rdfs:domain ind:RepoTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lcrTreatment rdf:type rdf:Property ;
    rdfs:label 'Lcr Treatment' ;
    rdfs:comment 'Classification of the collateral for Basel III LCR purposes, determining its eligibility as High-Quality Liquid Assets (HQLA).' ;
    rdfs:domain ind:Treasury ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legType rdf:type rdf:Property ;
    rdfs:label 'Leg Type' ;
    rdfs:comment 'Indicates whether this is the opening leg (initial cash/collateral exchange) or closing leg (repurchase/return) of the repo transaction.' ;
    rdfs:domain ind:RepoTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marginCallAmount rdf:type rdf:Property ;
    rdfs:label 'Margin Call Amount' ;
    rdfs:comment 'The additional collateral or cash amount required to be posted due to adverse market movements or collateral value decline.' ;
    rdfs:domain ind:RepoTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marginCallDate rdf:type rdf:Property ;
    rdfs:label 'Margin Call Date' ;
    rdfs:comment 'The date on which a margin call was issued for this repo transaction.' ;
    rdfs:domain ind:RepoTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mtmValuationAmount rdf:type rdf:Property ;
    rdfs:label 'Mtm Valuation Amount' ;
    rdfs:comment 'The mark-to-market valuation of the repo transaction, reflecting current market conditions and collateral value changes.' ;
    rdfs:domain ind:RepoTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mtmValuationDate rdf:type rdf:Property ;
    rdfs:label 'Mtm Valuation Date' ;
    rdfs:comment 'The date on which the mark-to-market valuation was performed for this repo transaction.' ;
    rdfs:domain ind:RepoTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nsfrTreatment rdf:type rdf:Property ;
    rdfs:label 'Nsfr Treatment' ;
    rdfs:comment 'Required Stable Funding (RSF) factor applied to this repo transaction for Basel III NSFR calculation. [ENUM-REF-CANDIDATE: rsf_0|rsf_5|rsf_10|rsf_15|rsf_50|rsf_65|rsf_85|rsf_100 — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Treasury ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pnlAmount rdf:type rdf:Property ;
    rdfs:label 'Pnl Amount' ;
    rdfs:comment 'The daily profit or loss attributed to this repo transaction, calculated from interest income, MTM changes, and funding costs.' ;
    rdfs:domain ind:RepoTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pnlAttributionDate rdf:type rdf:Property ;
    rdfs:label 'Pnl Attribution Date' ;
    rdfs:comment 'The business date for which the PnL amount was calculated and attributed to the repo book.' ;
    rdfs:domain ind:RepoTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:repurchaseAmount rdf:type rdf:Property ;
    rdfs:label 'Repurchase Amount' ;
    rdfs:comment 'The total amount due at maturity, including principal and accrued interest (closing leg).' ;
    rdfs:domain ind:RepoTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseRateBenchmarkId rdf:type rdf:Property ;
    rdfs:label 'Base Rate Benchmark Id' ;
    rdfs:comment 'Foreign key linking to reference.rate_benchmark. Business justification: FTP rates built on benchmark rates (SOFR, SONIA, etc.) for curve construction. Link enables daily rate fixing, benchmark transition management, and spread calculation over risk-free rate.' ;
    rdfs:domain ind:FtpRate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RateBenchmark .

ind:referenceProductTypeId rdf:type rdf:Property ;
    rdfs:label 'Reference Product Type Id' ;
    rdfs:comment 'Foreign key linking to reference.product_type. Business justification: FTP rates vary by product type (deposits, loans, mortgages) for NIM allocation. Link enables product-specific FTP curves, profitability analysis by product, and RAROC calculation.' ;
    rdfs:domain ind:Treasury ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductType .

ind:supersededByRateFtpRateId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Rate Ftp Rate Id' ;
    rdfs:comment 'Reference to the FTP rate that supersedes this rate; null if this is the current active rate.' ;
    rdfs:domain ind:FtpRate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FtpRate .

ind:alcoApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Alco Approval Date' ;
    rdfs:comment 'Date on which the ALCO formally approved this FTP rate for use.' ;
    rdfs:domain ind:FtpRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:alcoApprovalReference rdf:type rdf:Property ;
    rdfs:label 'Alco Approval Reference' ;
    rdfs:comment 'Reference number or identifier of the ALCO meeting or decision that approved this rate.' ;
    rdfs:domain ind:FtpRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetLiabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Asset Liability Flag' ;
    rdfs:comment 'Indicates whether this FTP rate applies to asset products (loans, investments) or liability products (deposits, borrowings).' ;
    rdfs:domain ind:FtpRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseRateValue rdf:type rdf:Property ;
    rdfs:label 'Base Rate Value' ;
    rdfs:comment 'Numeric value of the base rate component expressed in basis points (BPS) or percentage.' ;
    rdfs:domain ind:FtpRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:basisAdjustmentBps rdf:type rdf:Property ;
    rdfs:label 'Basis Adjustment Bps' ;
    rdfs:comment 'Additional basis point adjustment for market basis risk, cross-currency basis, or other technical adjustments.' ;
    rdfs:domain ind:FtpRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compositeRateBps rdf:type rdf:Property ;
    rdfs:label 'Composite Rate Bps' ;
    rdfs:comment 'Fully loaded FTP rate in basis points, representing the sum of base rate and all spread components.' ;
    rdfs:domain ind:FtpRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditSpreadBps rdf:type rdf:Property ;
    rdfs:label 'Credit Spread Bps' ;
    rdfs:comment 'Credit risk adjustment component in basis points, capturing expected credit loss or risk premium.' ;
    rdfs:domain ind:FtpRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:liquidityPremiumBps rdf:type rdf:Property ;
    rdfs:label 'Liquidity Premium Bps' ;
    rdfs:comment 'Liquidity spread component in basis points, reflecting the bank-specific cost of funding or liquidity premium.' ;
    rdfs:domain ind:Treasury ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nimAllocationFlag rdf:type rdf:Property ;
    rdfs:label 'Nim Allocation Flag' ;
    rdfs:comment 'Indicates whether this FTP rate is used for NIM decomposition and profitability analysis.' ;
    rdfs:domain ind:FtpRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optionalityChargeBps rdf:type rdf:Property ;
    rdfs:label 'Optionality Charge Bps' ;
    rdfs:comment 'Adjustment in basis points for embedded optionality (e.g., prepayment risk, early withdrawal penalties).' ;
    rdfs:domain ind:FtpRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rarocCalculationFlag rdf:type rdf:Property ;
    rdfs:label 'Raroc Calculation Flag' ;
    rdfs:comment 'Indicates whether this FTP rate is used in RAROC calculations for risk-adjusted performance measurement.' ;
    rdfs:domain ind:FtpRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rateCode rdf:type rdf:Property ;
    rdfs:label 'Rate Code' ;
    rdfs:comment 'Business identifier for the FTP rate, used for external reference and reporting.' ;
    rdfs:domain ind:FtpRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateDescription rdf:type rdf:Property ;
    rdfs:label 'Rate Description' ;
    rdfs:comment 'Detailed textual description of the FTP rate, including methodology notes, assumptions, and business context.' ;
    rdfs:domain ind:FtpRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateName rdf:type rdf:Property ;
    rdfs:label 'Rate Name' ;
    rdfs:comment 'Descriptive name of the FTP rate for business user identification.' ;
    rdfs:domain ind:FtpRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateSource rdf:type rdf:Property ;
    rdfs:label 'Rate Source' ;
    rdfs:comment 'Source system or data provider from which the base rate or spread components were obtained (e.g., Bloomberg, Reuters, internal treasury system).' ;
    rdfs:domain ind:FtpRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ftpAllocationId rdf:type rdf:Property ;
    rdfs:label 'Ftp Allocation Id' ;
    rdfs:comment 'Unique identifier for the FTP allocation record. Primary key for the FTP allocation transaction.' ;
    rdfs:domain ind:FtpAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalAllocationFtpAllocationId rdf:type rdf:Property ;
    rdfs:label 'Original Allocation Ftp Allocation Id' ;
    rdfs:comment 'Reference to the original FTP allocation ID if this record is a reversal or adjustment. Null for original allocations.' ;
    rdfs:domain ind:FtpAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FtpAllocation .

ind:businessLineCode rdf:type rdf:Property ;
    rdfs:label 'Business Line Code' ;
    rdfs:comment 'The business line or line of business code to which this FTP allocation is attributed. Used for profitability analysis and Net Interest Margin (NIM) decomposition.' ;
    rdfs:domain ind:FtpAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditAdjustmentBps rdf:type rdf:Property ;
    rdfs:label 'Credit Adjustment Bps' ;
    rdfs:comment 'The credit risk adjustment component in basis points included in the FTP rate. Reflects the Expected Credit Loss (ECL) or credit risk premium.' ;
    rdfs:domain ind:FtpAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:economicCapitalAmount rdf:type rdf:Property ;
    rdfs:label 'Economic Capital Amount' ;
    rdfs:comment 'The economic capital allocated to this account balance. Used for Risk-Adjusted Return on Capital (RAROC) calculation and capital planning.' ;
    rdfs:domain ind:FtpAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ftpAmount rdf:type rdf:Property ;
    rdfs:label 'Ftp Amount' ;
    rdfs:comment 'The calculated FTP charge or credit amount in the account currency. Computed as notional_balance × ftp_rate × day_count_fraction.' ;
    rdfs:domain ind:FtpAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nimContribution rdf:type rdf:Property ;
    rdfs:label 'Nim Contribution' ;
    rdfs:comment 'The contribution of this FTP allocation to the overall Net Interest Margin (NIM) for the business line or product. Calculated as FTP amount adjusted for actual interest income or expense.' ;
    rdfs:domain ind:FtpAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:notionalBalance rdf:type rdf:Property ;
    rdfs:label 'Notional Balance' ;
    rdfs:comment 'The principal or notional balance amount of the account on which the FTP rate is applied. Represents the base amount for FTP calculation.' ;
    rdfs:domain ind:FtpAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:basisRiskAmount rdf:type rdf:Property ;
    rdfs:label 'Basis Risk Amount' ;
    rdfs:comment 'The exposure arising from imperfect correlation between interest rates earned on assets and paid on liabilities with similar repricing characteristics.' ;
    rdfs:domain ind:InterestRateRiskPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:behavioralAssumptionSet rdf:type rdf:Property ;
    rdfs:label 'Behavioral Assumption Set' ;
    rdfs:comment 'The set of behavioral assumptions applied for non-maturity deposits, prepayment rates, and other customer behavior modeling.' ;
    rdfs:domain ind:InterestRateRiskPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationOfEquity rdf:type rdf:Property ;
    rdfs:label 'Duration Of Equity' ;
    rdfs:comment 'The weighted average time to repricing of the bank\'s equity, measuring the sensitivity of economic value to interest rate changes.' ;
    rdfs:domain ind:InterestRateRiskPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eveSensitivityAmount rdf:type rdf:Property ;
    rdfs:label 'Eve Sensitivity Amount' ;
    rdfs:comment 'The change in the present value of the bank\'s assets minus liabilities (economic value of equity) resulting from interest rate shocks.' ;
    rdfs:domain ind:InterestRateRiskPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eveSensitivityPercentage rdf:type rdf:Property ;
    rdfs:label 'Eve Sensitivity Percentage' ;
    rdfs:comment 'The percentage change in economic value of equity relative to total equity capital under interest rate shock scenarios.' ;
    rdfs:domain ind:InterestRateRiskPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modifiedDuration rdf:type rdf:Property ;
    rdfs:label 'Modified Duration' ;
    rdfs:comment 'The measure of the price sensitivity of the banking book portfolio to a 1% change in interest rates.' ;
    rdfs:domain ind:InterestRateRiskPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:niiSensitivityAmount rdf:type rdf:Property ;
    rdfs:label 'Nii Sensitivity Amount' ;
    rdfs:comment 'The projected change in net interest income over a specified time horizon (typically 12 months) resulting from interest rate shocks.' ;
    rdfs:domain ind:InterestRateRiskPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:niiSensitivityPercentage rdf:type rdf:Property ;
    rdfs:label 'Nii Sensitivity Percentage' ;
    rdfs:comment 'The percentage change in net interest income relative to baseline NII under interest rate shock scenarios.' ;
    rdfs:domain ind:InterestRateRiskPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:optionalityRiskAmount rdf:type rdf:Property ;
    rdfs:label 'Optionality Risk Amount' ;
    rdfs:comment 'The exposure arising from embedded options in banking book positions, such as prepayment risk on mortgages or early withdrawal risk on deposits.' ;
    rdfs:domain ind:InterestRateRiskPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:portfolioCode rdf:type rdf:Property ;
    rdfs:label 'Portfolio Code' ;
    rdfs:comment 'The code identifying the specific portfolio or book for which this interest rate risk position is calculated.' ;
    rdfs:domain ind:InterestRateRiskPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateSensitiveAssetsAmount rdf:type rdf:Property ;
    rdfs:label 'Rate Sensitive Assets Amount' ;
    rdfs:comment 'The total value of assets that will reprice or mature within the specified time bucket.' ;
    rdfs:domain ind:InterestRateRiskPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateSensitiveLiabilitiesAmount rdf:type rdf:Property ;
    rdfs:label 'Rate Sensitive Liabilities Amount' ;
    rdfs:comment 'The total value of liabilities that will reprice or mature within the specified time bucket.' ;
    rdfs:domain ind:InterestRateRiskPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:repricingGapAmount rdf:type rdf:Property ;
    rdfs:label 'Repricing Gap Amount' ;
    rdfs:comment 'The net difference between rate-sensitive assets and rate-sensitive liabilities within a specific time bucket, representing the exposure to interest rate changes.' ;
    rdfs:domain ind:InterestRateRiskPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shockScenarioType rdf:type rdf:Property ;
    rdfs:label 'Shock Scenario Type' ;
    rdfs:comment 'The interest rate shock scenario applied to calculate sensitivity metrics, expressed in basis points (bps) parallel shift.' ;
    rdfs:domain ind:InterestRateRiskPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeBucket rdf:type rdf:Property ;
    rdfs:label 'Time Bucket' ;
    rdfs:comment 'The repricing or maturity time band used to classify rate-sensitive positions for gap analysis. [ENUM-REF-CANDIDATE: overnight|1_7_days|8_30_days|31_90_days|91_180_days|181_365_days|1_2_years|2_3_years|3_5_years|5_10_years|over_10_years — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InterestRateRiskPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yieldCurveRiskAmount rdf:type rdf:Property ;
    rdfs:label 'Yield Curve Risk Amount' ;
    rdfs:comment 'The exposure arising from changes in the slope and shape of the yield curve, affecting assets and liabilities with different maturity profiles.' ;
    rdfs:domain ind:InterestRateRiskPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:alcoTargetCet1Ratio rdf:type rdf:Property ;
    rdfs:label 'Alco Target Cet1 Ratio' ;
    rdfs:comment 'The internal ALCO-approved target CET1 ratio, typically set above regulatory minimums to provide a management buffer for business volatility and growth.' ;
    rdfs:domain ind:CapitalRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:at1TriggerBreachFlag rdf:type rdf:Property ;
    rdfs:label 'At1 Trigger Breach Flag' ;
    rdfs:comment 'Indicates whether the CET1 ratio has breached the contractual trigger level for AT1 instrument write-down or conversion (typically 5.125% or 7.0% depending on instrument terms).' ;
    rdfs:domain ind:CapitalRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capitalConservationBuffer rdf:type rdf:Property ;
    rdfs:label 'Capital Conservation Buffer' ;
    rdfs:comment 'The capital conservation buffer requirement, expressed as a percentage of RWA. Standard requirement is 2.5% of RWA in CET1 capital above the minimum.' ;
    rdfs:domain ind:CapitalRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capitalIssuanceAmount rdf:type rdf:Property ;
    rdfs:label 'Capital Issuance Amount' ;
    rdfs:comment 'The amount of new capital issuance (common equity, AT1, or Tier 2 instruments) planned or executed during the reporting period.' ;
    rdfs:domain ind:CapitalRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capitalRedemptionAmount rdf:type rdf:Property ;
    rdfs:label 'Capital Redemption Amount' ;
    rdfs:comment 'The amount of capital instrument redemptions (AT1 or Tier 2 instruments) planned or executed during the reporting period.' ;
    rdfs:domain ind:CapitalRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cet1BufferAmount rdf:type rdf:Property ;
    rdfs:label 'Cet1 Buffer Amount' ;
    rdfs:comment 'The absolute amount of CET1 capital held above the minimum regulatory requirement plus buffers, representing the management buffer or excess capital.' ;
    rdfs:domain ind:CapitalRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cet1CapitalAmount rdf:type rdf:Property ;
    rdfs:label 'Cet1 Capital Amount' ;
    rdfs:comment 'The total Common Equity Tier 1 capital amount, representing the highest quality capital consisting of common shares, retained earnings, and other comprehensive income, net of regulatory adjustments.' ;
    rdfs:domain ind:CapitalRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cet1Ratio rdf:type rdf:Property ;
    rdfs:label 'Cet1 Ratio' ;
    rdfs:comment 'The CET1 capital ratio, calculated as CET1 capital divided by total RWA, expressed as a percentage. Regulatory minimum is 4.5% under Basel III.' ;
    rdfs:domain ind:CapitalRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:countercyclicalBuffer rdf:type rdf:Property ;
    rdfs:label 'Countercyclical Buffer' ;
    rdfs:comment 'The countercyclical capital buffer requirement, expressed as a percentage of RWA. Ranges from 0% to 2.5% and varies by jurisdiction based on credit cycle conditions.' ;
    rdfs:domain ind:CapitalRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditRwaAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Rwa Amount' ;
    rdfs:comment 'Risk-weighted assets arising from credit risk exposures, calculated using either the Standardized Approach (SA) or Internal Ratings-Based (IRB) approach.' ;
    rdfs:domain ind:CapitalRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gsibSurcharge rdf:type rdf:Property ;
    rdfs:label 'Gsib Surcharge' ;
    rdfs:comment 'The additional capital surcharge for Global Systemically Important Banks, ranging from 1.0% to 3.5% of RWA based on systemic importance score.' ;
    rdfs:domain ind:CapitalRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketRwaAmount rdf:type rdf:Property ;
    rdfs:label 'Market Rwa Amount' ;
    rdfs:comment 'Risk-weighted assets arising from market risk exposures in the trading book, calculated under the Fundamental Review of the Trading Book (FRTB) or legacy market risk framework.' ;
    rdfs:domain ind:CapitalRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operationalRwaAmount rdf:type rdf:Property ;
    rdfs:label 'Operational Rwa Amount' ;
    rdfs:comment 'Risk-weighted assets arising from operational risk, calculated using the Standardized Measurement Approach (SMA) or legacy approaches.' ;
    rdfs:domain ind:CapitalRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedBuybackAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Buyback Amount' ;
    rdfs:comment 'The planned share repurchase amount for the reporting period under the capital plan.' ;
    rdfs:domain ind:CapitalRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedDividendAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Dividend Amount' ;
    rdfs:comment 'The planned common stock dividend distribution amount for the reporting period under the capital plan.' ;
    rdfs:domain ind:CapitalRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectedCet1RatioYear1 rdf:type rdf:Property ;
    rdfs:label 'Projected Cet1 Ratio Year1' ;
    rdfs:comment 'The projected CET1 ratio for the first year of the capital planning horizon under the specified scenario.' ;
    rdfs:domain ind:CapitalRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectedCet1RatioYear2 rdf:type rdf:Property ;
    rdfs:label 'Projected Cet1 Ratio Year2' ;
    rdfs:comment 'The projected CET1 ratio for the second year of the capital planning horizon under the specified scenario.' ;
    rdfs:domain ind:CapitalRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectedCet1RatioYear3 rdf:type rdf:Property ;
    rdfs:label 'Projected Cet1 Ratio Year3' ;
    rdfs:comment 'The projected CET1 ratio for the third year of the capital planning horizon under the specified scenario.' ;
    rdfs:domain ind:CapitalRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectedRwaGrowthRate rdf:type rdf:Property ;
    rdfs:label 'Projected Rwa Growth Rate' ;
    rdfs:comment 'The assumed annual growth rate for RWA in the capital planning scenario, expressed as a percentage.' ;
    rdfs:domain ind:CapitalRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryMinimumCet1Ratio rdf:type rdf:Property ;
    rdfs:label 'Regulatory Minimum Cet1 Ratio' ;
    rdfs:comment 'The applicable regulatory minimum CET1 ratio including all buffers, representing the threshold below which capital distribution restrictions apply.' ;
    rdfs:domain ind:Treasury ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tier1CapitalAmount rdf:type rdf:Property ;
    rdfs:label 'Tier1 Capital Amount' ;
    rdfs:comment 'The total Tier 1 capital amount, comprising CET1 capital plus Additional Tier 1 (AT1) instruments such as perpetual non-cumulative preferred stock.' ;
    rdfs:domain ind:CapitalRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tier1Ratio rdf:type rdf:Property ;
    rdfs:label 'Tier1 Ratio' ;
    rdfs:comment 'The Tier 1 capital ratio, calculated as Tier 1 capital divided by total RWA, expressed as a percentage. Regulatory minimum is 6.0% under Basel III.' ;
    rdfs:domain ind:CapitalRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tier2CapitalAmount rdf:type rdf:Property ;
    rdfs:label 'Tier2 Capital Amount' ;
    rdfs:comment 'The total Tier 2 capital amount, comprising subordinated debt, hybrid instruments, and loan loss reserves up to regulatory limits.' ;
    rdfs:domain ind:CapitalRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalBufferRequirement rdf:type rdf:Property ;
    rdfs:label 'Total Buffer Requirement' ;
    rdfs:comment 'The sum of all capital buffer requirements (conservation, countercyclical, G-SIB surcharge), expressed as a percentage of RWA.' ;
    rdfs:domain ind:CapitalRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCapitalAmount rdf:type rdf:Property ;
    rdfs:label 'Total Capital Amount' ;
    rdfs:comment 'The sum of Tier 1 and Tier 2 capital, representing the total regulatory capital available to absorb losses.' ;
    rdfs:domain ind:CapitalRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCapitalRatio rdf:type rdf:Property ;
    rdfs:label 'Total Capital Ratio' ;
    rdfs:comment 'The total capital ratio, calculated as total capital divided by total RWA, expressed as a percentage. Regulatory minimum is 8.0% under Basel III.' ;
    rdfs:domain ind:CapitalRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalExposureMeasure rdf:type rdf:Property ;
    rdfs:label 'Total Exposure Measure' ;
    rdfs:comment 'The total exposure measure used in the leverage ratio calculation, comprising on-balance sheet exposures, derivative exposures, securities financing transaction exposures, and off-balance sheet items.' ;
    rdfs:domain ind:CapitalRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalRwaAmount rdf:type rdf:Property ;
    rdfs:label 'Total Rwa Amount' ;
    rdfs:comment 'The sum of credit, market, and operational risk-weighted assets, representing the total risk exposure for capital adequacy calculation.' ;
    rdfs:domain ind:CapitalRatio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:alcoApprovedTargetCet1Ratio rdf:type rdf:Property ;
    rdfs:label 'Alco Approved Target Cet1 Ratio' ;
    rdfs:comment 'Internal target CET1 ratio approved by the Asset-Liability Committee, typically above regulatory minimums to provide a management buffer.' ;
    rdfs:domain ind:CapitalPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:at1TriggerThreshold rdf:type rdf:Property ;
    rdfs:label 'At1 Trigger Threshold' ;
    rdfs:comment 'CET1 ratio threshold at which Additional Tier 1 capital instruments would be written down or converted, expressed as a percentage.' ;
    rdfs:domain ind:CapitalPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baselineCet1Ratio rdf:type rdf:Property ;
    rdfs:label 'Baseline Cet1 Ratio' ;
    rdfs:comment 'Starting Common Equity Tier 1 capital ratio at the beginning of the planning horizon, expressed as a percentage.' ;
    rdfs:domain ind:CapitalPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baselineRwaAmount rdf:type rdf:Property ;
    rdfs:label 'Baseline Rwa Amount' ;
    rdfs:comment 'Starting Risk-Weighted Assets amount at the beginning of the planning horizon, in millions of base currency.' ;
    rdfs:domain ind:CapitalPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capitalActionDescription rdf:type rdf:Property ;
    rdfs:label 'Capital Action Description' ;
    rdfs:comment 'Narrative description of planned capital actions including issuances, redemptions, dividends, and buybacks over the planning horizon.' ;
    rdfs:domain ind:CapitalPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managementBufferAboveMinimum rdf:type rdf:Property ;
    rdfs:label 'Management Buffer Above Minimum' ;
    rdfs:comment 'Management buffer maintained above the regulatory minimum CET1 ratio, expressed as percentage points.' ;
    rdfs:domain ind:CapitalPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:methodologyDescription rdf:type rdf:Property ;
    rdfs:label 'Methodology Description' ;
    rdfs:comment 'Description of the methodologies, models, and assumptions used to develop the capital plan projections.' ;
    rdfs:domain ind:CapitalPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumCet1RatioStressed rdf:type rdf:Property ;
    rdfs:label 'Minimum Cet1 Ratio Stressed' ;
    rdfs:comment 'Lowest projected CET1 ratio during the planning horizon under the stress scenario, representing the trough capital level.' ;
    rdfs:domain ind:CapitalPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netIncomeProjection rdf:type rdf:Property ;
    rdfs:label 'Net Income Projection' ;
    rdfs:comment 'Projected net income over the planning horizon under the specified scenario, in millions of base currency.' ;
    rdfs:domain ind:CapitalPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planName rdf:type rdf:Property ;
    rdfs:label 'Plan Name' ;
    rdfs:comment 'Descriptive name of the capital plan (e.g., \'2024 CCAR Base Scenario\', \'2025 Annual Capital Plan\').' ;
    rdfs:domain ind:Treasury ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planStatus rdf:type rdf:Property ;
    rdfs:label 'Plan Status' ;
    rdfs:comment 'Current lifecycle status of the capital plan in the regulatory submission and approval process.' ;
    rdfs:domain ind:Treasury ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planVersion rdf:type rdf:Property ;
    rdfs:label 'Plan Version' ;
    rdfs:comment 'Version identifier for the capital plan to track revisions and resubmissions (e.g., \'v1.0\', \'v2.1 Revised\').' ;
    rdfs:domain ind:CapitalPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedCapitalIssuanceAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Capital Issuance Amount' ;
    rdfs:comment 'Total planned capital issuance (common equity, preferred stock, subordinated debt) over the planning horizon, in millions of base currency.' ;
    rdfs:domain ind:CapitalPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedCapitalRedemptionAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Capital Redemption Amount' ;
    rdfs:comment 'Total planned capital redemptions (preferred stock, subordinated debt) over the planning horizon, in millions of base currency.' ;
    rdfs:domain ind:CapitalPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedCommonStockDividendAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Common Stock Dividend Amount' ;
    rdfs:comment 'Total planned common stock dividend distributions over the planning horizon, in millions of base currency.' ;
    rdfs:domain ind:CapitalPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedDividendPayoutRatio rdf:type rdf:Property ;
    rdfs:label 'Planned Dividend Payout Ratio' ;
    rdfs:comment 'Planned dividend payout ratio as a percentage of net income over the planning horizon.' ;
    rdfs:domain ind:CapitalPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedShareBuybackAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Share Buyback Amount' ;
    rdfs:comment 'Total planned share repurchase amount over the planning horizon, in millions of base currency.' ;
    rdfs:domain ind:CapitalPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planningHorizonEndDate rdf:type rdf:Property ;
    rdfs:label 'Planning Horizon End Date' ;
    rdfs:comment 'End date of the multi-year capital planning horizon covered by this plan.' ;
    rdfs:domain ind:CapitalPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planningHorizonStartDate rdf:type rdf:Property ;
    rdfs:label 'Planning Horizon Start Date' ;
    rdfs:comment 'Start date of the multi-year capital planning horizon covered by this plan.' ;
    rdfs:domain ind:CapitalPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preProvisionNetRevenueProjection rdf:type rdf:Property ;
    rdfs:label 'Pre Provision Net Revenue Projection' ;
    rdfs:comment 'Projected pre-provision net revenue over the planning horizon under the specified scenario, in millions of base currency.' ;
    rdfs:domain ind:CapitalPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectedCet1RatioYear1 rdf:type rdf:Property ;
    rdfs:label 'Projected Cet1 Ratio Year 1' ;
    rdfs:comment 'Projected CET1 capital ratio at the end of year 1 under the specified scenario, expressed as a percentage.' ;
    rdfs:domain ind:CapitalPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectedCet1RatioYear2 rdf:type rdf:Property ;
    rdfs:label 'Projected Cet1 Ratio Year 2' ;
    rdfs:comment 'Projected CET1 capital ratio at the end of year 2 under the specified scenario, expressed as a percentage.' ;
    rdfs:domain ind:CapitalPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectedCet1RatioYear3 rdf:type rdf:Property ;
    rdfs:label 'Projected Cet1 Ratio Year 3' ;
    rdfs:comment 'Projected CET1 capital ratio at the end of year 3 under the specified scenario, expressed as a percentage.' ;
    rdfs:domain ind:CapitalPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectedRwaGrowthRateYear1 rdf:type rdf:Property ;
    rdfs:label 'Projected Rwa Growth Rate Year 1' ;
    rdfs:comment 'Projected annual growth rate of RWA in year 1, expressed as a percentage.' ;
    rdfs:domain ind:CapitalPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectedRwaGrowthRateYear2 rdf:type rdf:Property ;
    rdfs:label 'Projected Rwa Growth Rate Year 2' ;
    rdfs:comment 'Projected annual growth rate of RWA in year 2, expressed as a percentage.' ;
    rdfs:domain ind:CapitalPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectedRwaGrowthRateYear3 rdf:type rdf:Property ;
    rdfs:label 'Projected Rwa Growth Rate Year 3' ;
    rdfs:comment 'Projected annual growth rate of RWA in year 3, expressed as a percentage.' ;
    rdfs:domain ind:CapitalPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:provisionForCreditLossesProjection rdf:type rdf:Property ;
    rdfs:label 'Provision For Credit Losses Projection' ;
    rdfs:comment 'Projected provision for credit losses over the planning horizon under the specified scenario, in millions of base currency.' ;
    rdfs:domain ind:CapitalPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportingEntityName rdf:type rdf:Property ;
    rdfs:label 'Reporting Entity Name' ;
    rdfs:comment 'Legal name of the bank holding company or financial institution submitting the capital plan.' ;
    rdfs:domain ind:CapitalPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stressLossProjectionAmount rdf:type rdf:Property ;
    rdfs:label 'Stress Loss Projection Amount' ;
    rdfs:comment 'Total projected losses under the stress scenario over the planning horizon, in millions of base currency.' ;
    rdfs:domain ind:CapitalPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualCostOfFundsRate rdf:type rdf:Property ;
    rdfs:label 'Actual Cost Of Funds Rate' ;
    rdfs:comment 'Actual realized all-in cost of funds rate for this instrument type during the plan period, expressed as a decimal. Tracks execution vs. target pricing.' ;
    rdfs:domain ind:FundingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualIssuanceAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Issuance Amount' ;
    rdfs:comment 'Actual notional amount raised through this funding instrument during the plan period, in the plan\'s base currency. Tracks execution vs. plan.' ;
    rdfs:domain ind:FundingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:callFeatureFlag rdf:type rdf:Property ;
    rdfs:label 'Call Feature Flag' ;
    rdfs:comment 'Indicates whether the debt instrument includes a call feature allowing the issuer to redeem the instrument before maturity. True if callable, False otherwise.' ;
    rdfs:domain ind:FundingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:counterpartyConcentrationLimit rdf:type rdf:Property ;
    rdfs:label 'Counterparty Concentration Limit' ;
    rdfs:comment 'Maximum notional amount that can be sourced from a single counterparty or investor group for this instrument type, in the plan\'s base currency. Enforces counterparty concentration risk limits.' ;
    rdfs:domain ind:FundingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:listingExchange rdf:type rdf:Property ;
    rdfs:label 'Listing Exchange' ;
    rdfs:comment 'Name of the stock exchange or trading venue where the debt instrument is listed (e.g., New York Stock Exchange (NYSE), London Stock Exchange (LSE), Luxembourg Stock Exchange). Null if unlisted.' ;
    rdfs:domain ind:Treasury ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notionalOutstanding rdf:type rdf:Property ;
    rdfs:label 'Notional Outstanding' ;
    rdfs:comment 'Current outstanding notional principal amount of the debt instrument, in the instrument\'s currency. Tracks amortization and prepayments.' ;
    rdfs:domain ind:FundingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Plan Period End Date' ;
    rdfs:comment 'The effective end date of the funding plan period (e.g., end of fiscal quarter or year).' ;
    rdfs:domain ind:FundingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Plan Period Start Date' ;
    rdfs:comment 'The effective start date of the funding plan period (e.g., beginning of fiscal quarter or year).' ;
    rdfs:domain ind:FundingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planType rdf:type rdf:Property ;
    rdfs:label 'Plan Type' ;
    rdfs:comment 'Classification of the funding plan by strategic purpose: wholesale (institutional funding), retail (deposit-based), hybrid (mixed sources), contingency (stress scenario), or strategic (long-term capital structure).' ;
    rdfs:domain ind:FundingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:putFeatureFlag rdf:type rdf:Property ;
    rdfs:label 'Put Feature Flag' ;
    rdfs:comment 'Indicates whether the debt instrument includes a put feature allowing the investor to demand early redemption. True if puttable, False otherwise.' ;
    rdfs:domain ind:FundingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetCostOfFundsRate rdf:type rdf:Property ;
    rdfs:label 'Target Cost Of Funds Rate' ;
    rdfs:comment 'Planned or target all-in cost of funds rate for this instrument type, expressed as a decimal (e.g., 0.0325 for 3.25% or 325 basis points). Includes coupon, fees, and issuance costs.' ;
    rdfs:domain ind:FundingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetIssuanceAmount rdf:type rdf:Property ;
    rdfs:label 'Target Issuance Amount' ;
    rdfs:comment 'Planned or target notional amount to be raised through this funding instrument during the plan period, in the plan\'s base currency.' ;
    rdfs:domain ind:FundingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetMaturityProfile rdf:type rdf:Property ;
    rdfs:label 'Target Maturity Profile' ;
    rdfs:comment 'Planned maturity profile for the funding instrument: short-term (< 1 year), medium-term (1-5 years), long-term (> 5 years), perpetual (no maturity), or mixed (diversified maturities).' ;
    rdfs:domain ind:FundingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetWeightedAverageMaturityYears rdf:type rdf:Property ;
    rdfs:label 'Target Weighted Average Maturity Years' ;
    rdfs:comment 'Planned weighted average maturity of the funding instrument issuances, expressed in years. Used for maturity ladder and duration management.' ;
    rdfs:domain ind:FundingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:underwriterName rdf:type rdf:Property ;
    rdfs:label 'Underwriter Name' ;
    rdfs:comment 'Name of the lead underwriter or bookrunner for the debt issuance (e.g., investment bank managing the offering).' ;
    rdfs:domain ind:Treasury ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditRatingAgency rdf:type rdf:Property ;
    rdfs:label 'Credit Rating Agency' ;
    rdfs:comment 'Name of the credit rating agency that assigned the rating to this debt issuance (e.g., Moodys, S&P, Fitch). Multiple agencies may rate the same instrument.' ;
    rdfs:domain ind:DebtIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:greenBondFlag rdf:type rdf:Property ;
    rdfs:label 'Green Bond Flag' ;
    rdfs:comment 'Indicates whether the debt issuance qualifies as a green bond with proceeds dedicated to environmentally beneficial projects. True if certified green bond; false otherwise.' ;
    rdfs:domain ind:DebtIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuanceStatus rdf:type rdf:Property ;
    rdfs:label 'Issuance Status' ;
    rdfs:comment 'Current lifecycle status of the debt issuance from planning through maturity or early termination. [ENUM-REF-CANDIDATE: planned|priced|issued|outstanding|matured|called|defaulted — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DebtIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuePrice rdf:type rdf:Property ;
    rdfs:label 'Issue Price' ;
    rdfs:comment 'Price at which the debt instrument was issued, expressed as a percentage of par value. Values below 100 indicate discount; above 100 indicate premium.' ;
    rdfs:domain ind:DebtIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalMaturityTenor rdf:type rdf:Property ;
    rdfs:label 'Original Maturity Tenor' ;
    rdfs:comment 'Time period from issuance date to maturity date expressed in standard market convention (e.g., 5Y, 10Y, 30Y). Used for funding maturity profile analysis.' ;
    rdfs:domain ind:DebtIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outstandingAmount rdf:type rdf:Property ;
    rdfs:label 'Outstanding Amount' ;
    rdfs:comment 'Current principal amount outstanding after accounting for any partial redemptions, amortization, or calls. Used for balance sheet and capital ratio calculations.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prospectusUrl rdf:type rdf:Property ;
    rdfs:label 'Prospectus Url' ;
    rdfs:comment 'URL link to the official prospectus or offering document filed with regulatory authorities. Provides full legal terms and conditions.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:syndicateMembers rdf:type rdf:Property ;
    rdfs:label 'Syndicate Members' ;
    rdfs:comment 'Comma-separated list of all underwriting syndicate members participating in the debt issuance. Includes co-managers and selling group members.' ;
    rdfs:domain ind:DebtIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountCloseDate rdf:type rdf:Property ;
    rdfs:label 'Account Close Date' ;
    rdfs:comment 'Date when the nostro account was closed, if applicable.' ;
    rdfs:domain ind:NostroAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accountOpenDate rdf:type rdf:Property ;
    rdfs:label 'Account Open Date' ;
    rdfs:comment 'Date when the nostro account was opened with the correspondent bank.' ;
    rdfs:domain ind:NostroAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accountPurpose rdf:type rdf:Property ;
    rdfs:label 'Account Purpose' ;
    rdfs:comment 'Primary business purpose of the nostro account (e.g., settlement, foreign exchange, securities, general operations, liquidity management).' ;
    rdfs:domain ind:NostroAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedSignatories rdf:type rdf:Property ;
    rdfs:label 'Authorized Signatories' ;
    rdfs:comment 'List or reference to individuals authorized to operate and sign on behalf of this nostro account.' ;
    rdfs:domain ind:NostroAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breakAgingCategory rdf:type rdf:Property ;
    rdfs:label 'Break Aging Category' ;
    rdfs:comment 'Aging category of unmatched items (breaks) based on the number of days outstanding.' ;
    rdfs:domain ind:NostroAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Current Balance Amount' ;
    rdfs:comment 'Current balance of the nostro account as per the latest reconciliation or statement.' ;
    rdfs:domain ind:NostroAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:escalationTriggerFlag rdf:type rdf:Property ;
    rdfs:label 'Escalation Trigger Flag' ;
    rdfs:comment 'Boolean flag indicating whether reconciliation breaks have triggered an escalation process.' ;
    rdfs:domain ind:NostroAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fxPositionManagementFlag rdf:type rdf:Property ;
    rdfs:label 'Fx Position Management Flag' ;
    rdfs:comment 'Boolean flag indicating whether this nostro account is used for foreign exchange position management.' ;
    rdfs:domain ind:NostroAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:intradayLiquidityMonitoringFlag rdf:type rdf:Property ;
    rdfs:label 'Intraday Liquidity Monitoring Flag' ;
    rdfs:comment 'Boolean flag indicating whether this nostro account is subject to intraday liquidity monitoring under BCBS 248.' ;
    rdfs:domain ind:NostroAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overdraftLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Overdraft Limit Amount' ;
    rdfs:comment 'Maximum overdraft limit authorized by the correspondent bank for this nostro account.' ;
    rdfs:domain ind:NostroAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rtgsSettlementFlag rdf:type rdf:Property ;
    rdfs:label 'Rtgs Settlement Flag' ;
    rdfs:comment 'Boolean flag indicating whether this nostro account is used for RTGS payment settlement.' ;
    rdfs:domain ind:NostroAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:statementFrequency rdf:type rdf:Property ;
    rdfs:label 'Statement Frequency' ;
    rdfs:comment 'Frequency at which the correspondent bank provides account statements (e.g., daily MT940/MT950 messages).' ;
    rdfs:domain ind:NostroAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unmatchedAmount rdf:type rdf:Property ;
    rdfs:label 'Unmatched Amount' ;
    rdfs:comment 'Total monetary value of unmatched items (breaks) from the last reconciliation.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unmatchedItemsCount rdf:type rdf:Property ;
    rdfs:label 'Unmatched Items Count' ;
    rdfs:comment 'Number of unmatched items (breaks) identified during the last reconciliation.' ;
    rdfs:domain ind:NostroAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bondMaturityInflowAmount rdf:type rdf:Property ;
    rdfs:label 'Bond Maturity Inflow Amount' ;
    rdfs:comment 'Projected cash inflows from bond maturities and coupon payments on held-to-maturity securities.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cashFlowCategory rdf:type rdf:Property ;
    rdfs:label 'Cash Flow Category' ;
    rdfs:comment 'Classification of the cash flow as contractual (legally binding), behavioral (modeled based on historical patterns), or contingent (conditional on events).' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contingentInflowAmount rdf:type rdf:Property ;
    rdfs:label 'Contingent Inflow Amount' ;
    rdfs:comment 'Projected contingent cash inflows dependent on specific events such as asset sales, securitization proceeds, or central bank facilities.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contingentOutflowAmount rdf:type rdf:Property ;
    rdfs:label 'Contingent Outflow Amount' ;
    rdfs:comment 'Projected contingent cash outflows including margin calls, collateral top-ups, guarantees called, and off-balance-sheet commitments.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditLineDrawdownOutflowAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Line Drawdown Outflow Amount' ;
    rdfs:comment 'Projected cash outflows from expected drawdowns on committed credit facilities and revolving lines of credit.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depositRunoffOutflowAmount rdf:type rdf:Property ;
    rdfs:label 'Deposit Runoff Outflow Amount' ;
    rdfs:comment 'Projected cash outflows from deposit withdrawals modeled using behavioral runoff rates by deposit type and stability.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:derivativeSettlementNetAmount rdf:type rdf:Property ;
    rdfs:label 'Derivative Settlement Net Amount' ;
    rdfs:comment 'Net projected cash flows from derivative settlements including foreign exchange forwards, interest rate swaps, and options.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:flowDirection rdf:type rdf:Property ;
    rdfs:label 'Flow Direction' ;
    rdfs:comment 'Indicates whether the forecast represents a cash inflow or outflow.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastDate rdf:type rdf:Property ;
    rdfs:label 'Forecast Date' ;
    rdfs:comment 'The date for which the cash flow forecast is projected.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:forecastReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Forecast Reference Number' ;
    rdfs:comment 'Business identifier for the cash flow forecast used for tracking and audit purposes.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastRunTimestamp rdf:type rdf:Property ;
    rdfs:label 'Forecast Run Timestamp' ;
    rdfs:comment 'The timestamp when the forecast calculation was executed.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:forecastType rdf:type rdf:Property ;
    rdfs:label 'Forecast Type' ;
    rdfs:comment 'Classification of the forecast by time horizon: intraday, overnight, short-term, medium-term, or long-term.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loanRepaymentInflowAmount rdf:type rdf:Property ;
    rdfs:label 'Loan Repayment Inflow Amount' ;
    rdfs:comment 'Projected cash inflows from scheduled loan principal and interest repayments.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operationalExpenseOutflowAmount rdf:type rdf:Property ;
    rdfs:label 'Operational Expense Outflow Amount' ;
    rdfs:comment 'Projected cash outflows for operational expenses including payroll, rent, technology costs, and other recurring expenses.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:repoFundingNetAmount rdf:type rdf:Property ;
    rdfs:label 'Repo Funding Net Amount' ;
    rdfs:comment 'Net projected cash flows from repurchase and reverse repurchase agreements maturing in the tenor bucket.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fxNostroAccountId rdf:type rdf:Property ;
    rdfs:label 'Fx Nostro Account Id' ;
    rdfs:comment 'Reference to the nostro account (our account held at another bank) used for settlement of this FX transaction.' ;
    rdfs:domain ind:FxTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NostroAccount .

ind:hedgedSecurityInstrumentId rdf:type rdf:Property ;
    rdfs:label 'Hedged Security Instrument Id' ;
    rdfs:comment 'Foreign key linking to security.instrument. Business justification: FX transactions hedging currency risk on foreign securities positions need instrument linkage for hedge accounting, effectiveness testing, and portfolio risk reporting. Role-prefixed because FX transa' ;
    rdfs:domain ind:FxTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Instrument .

ind:primaryFxBaseCurrencyId rdf:type rdf:Property ;
    rdfs:label 'Primary Fx Base Currency Id' ;
    rdfs:comment 'Foreign key linking to reference.currency. Business justification: FX deal base currency leg requires currency master for minor unit precision, settlement lag (T+0/T+1/T+2), and regulatory reporting (Dodd-Frank Part 45, EMIR). Base_currency_code replaced by FK.' ;
    rdfs:domain ind:FxTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:reversalFxTransactionId rdf:type rdf:Property ;
    rdfs:label 'Reversal Fx Transaction Id' ;
    rdfs:comment 'Self-referencing FK on fx_transaction (reversal_fx_transaction_id)' ;
    rdfs:domain ind:FxTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FxTransaction .

ind:baseCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Base Currency Amount' ;
    rdfs:comment 'The notional amount in the base currency being exchanged in this FX transaction.' ;
    rdfs:domain ind:FxTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseCurrencySettlementAccount rdf:type rdf:Property ;
    rdfs:label 'Base Currency Settlement Account' ;
    rdfs:comment 'Account number or identifier for the nostro/vostro account used to settle the base currency leg of the FX transaction.' ;
    rdfs:domain ind:FxTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buySellIndicator rdf:type rdf:Property ;
    rdfs:label 'Buy Sell Indicator' ;
    rdfs:comment 'Indicates whether the institution is buying or selling the base currency in this FX transaction.' ;
    rdfs:domain ind:FxTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterpartyBic rdf:type rdf:Property ;
    rdfs:label 'Counterparty Bic' ;
    rdfs:comment 'SWIFT BIC code of the counterparty bank or financial institution.' ;
    rdfs:domain ind:FxTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currencyPair rdf:type rdf:Property ;
    rdfs:label 'Currency Pair' ;
    rdfs:comment 'Standard representation of the currency pair being traded (e.g., USD/EUR, GBP/JPY).' ;
    rdfs:domain ind:FxTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealRate rdf:type rdf:Property ;
    rdfs:label 'Deal Rate' ;
    rdfs:comment 'The agreed exchange rate at which the base currency is converted to the quote currency for this transaction.' ;
    rdfs:domain ind:FxTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dealReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Deal Reference Number' ;
    rdfs:comment 'Externally-known unique reference number assigned to this FX deal by the trading system or counterparty.' ;
    rdfs:domain ind:FxTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealTimestamp rdf:type rdf:Property ;
    rdfs:label 'Deal Timestamp' ;
    rdfs:comment 'Date and time when the FX deal was executed or agreed upon between parties.' ;
    rdfs:domain ind:FxTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fixingRate rdf:type rdf:Property ;
    rdfs:label 'Fixing Rate' ;
    rdfs:comment 'The official exchange rate determined on the fixing date, used to calculate settlement amounts for NDF transactions.' ;
    rdfs:domain ind:FxTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forwardPoints rdf:type rdf:Property ;
    rdfs:label 'Forward Points' ;
    rdfs:comment 'The adjustment in basis points applied to the spot rate to calculate the forward rate for forward or swap transactions.' ;
    rdfs:domain ind:FxTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quoteCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Quote Currency Amount' ;
    rdfs:comment 'The equivalent amount in the quote currency calculated using the deal rate.' ;
    rdfs:domain ind:FxTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quoteCurrencySettlementAccount rdf:type rdf:Property ;
    rdfs:label 'Quote Currency Settlement Account' ;
    rdfs:comment 'Account number or identifier for the nostro/vostro account used to settle the quote currency leg of the FX transaction.' ;
    rdfs:domain ind:FxTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spotRateReference rdf:type rdf:Property ;
    rdfs:label 'Spot Rate Reference' ;
    rdfs:comment 'The prevailing spot exchange rate at the time of deal execution, used as reference for forward pricing.' ;
    rdfs:domain ind:FxTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:correspondentCountryId rdf:type rdf:Property ;
    rdfs:label 'Correspondent Country Id' ;
    rdfs:comment 'Foreign key linking to reference.country. Business justification: Correspondent bank country determines sanctions screening requirements (OFAC, EU), regulatory approval needs (Fed Reserve approval for US correspondents), and settlement risk limits. Country master pr' ;
    rdfs:domain ind:CorrespondentBank ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:parentCorrespondentBankId rdf:type rdf:Property ;
    rdfs:label 'Parent Correspondent Bank Id' ;
    rdfs:comment 'Self-referencing FK on correspondent_bank (parent_correspondent_bank_id)' ;
    rdfs:domain ind:CorrespondentBank ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CorrespondentBank .

ind:contactEmail rdf:type rdf:Property ;
    rdfs:label 'Contact Email' ;
    rdfs:comment 'Email address of the primary contact at the correspondent bank for operational communications and issue resolution.' ;
    rdfs:domain ind:CorrespondentBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactName rdf:type rdf:Property ;
    rdfs:label 'Contact Name' ;
    rdfs:comment 'Name of the primary relationship manager or contact person at the correspondent bank for operational matters.' ;
    rdfs:domain ind:CorrespondentBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPhone rdf:type rdf:Property ;
    rdfs:label 'Contact Phone' ;
    rdfs:comment 'Phone number of the primary contact at the correspondent bank for urgent operational matters.' ;
    rdfs:domain ind:CorrespondentBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correspondentCity rdf:type rdf:Property ;
    rdfs:label 'Correspondent City' ;
    rdfs:comment 'City where the correspondent bank\'s primary office or headquarters is located.' ;
    rdfs:domain ind:CorrespondentBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correspondentName rdf:type rdf:Property ;
    rdfs:label 'Correspondent Name' ;
    rdfs:comment 'Full legal name of the correspondent banking institution as registered with regulatory authorities.' ;
    rdfs:domain ind:CorrespondentBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Amount' ;
    rdfs:comment 'Maximum credit exposure limit approved for transactions with this correspondent bank, denominated in primary currency.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cutoffTimeUtc rdf:type rdf:Property ;
    rdfs:label 'Cutoff Time Utc' ;
    rdfs:comment 'Daily cutoff time in UTC (HH:MM format) for submitting payment instructions to meet same-day settlement through this correspondent.' ;
    rdfs:domain ind:CorrespondentBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dailyTransactionLimit rdf:type rdf:Property ;
    rdfs:label 'Daily Transaction Limit' ;
    rdfs:comment 'Maximum aggregate transaction amount permitted per business day through this correspondent relationship, denominated in primary currency.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feeStructureCode rdf:type rdf:Property ;
    rdfs:label 'Fee Structure Code' ;
    rdfs:comment 'Code identifying the fee structure and pricing schedule applicable to transactions processed through this correspondent relationship.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gpiEnabled rdf:type rdf:Property ;
    rdfs:label 'Gpi Enabled' ;
    rdfs:comment 'Indicates whether this correspondent bank supports SWIFT Global Payments Innovation (gpi) for enhanced payment tracking and transparency.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nostroAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Nostro Account Number' ;
    rdfs:comment 'Account number of our institution\'s nostro account held at the correspondent bank for settlement purposes.' ;
    rdfs:domain ind:CorrespondentBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentRailTypes rdf:type rdf:Property ;
    rdfs:label 'Payment Rail Types' ;
    rdfs:comment 'Comma-separated list of payment rail types supported through this correspondent (e.g., SWIFT, RTGS, ACH, SEPA, TARGET2, CHAPS).' ;
    rdfs:domain ind:CorrespondentBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredIntermediaryBic rdf:type rdf:Property ;
    rdfs:label 'Preferred Intermediary Bic' ;
    rdfs:comment 'SWIFT BIC of the preferred intermediary bank to use when routing payments through this correspondent, if applicable.' ;
    rdfs:domain ind:CorrespondentBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryCurrency rdf:type rdf:Property ;
    rdfs:label 'Primary Currency' ;
    rdfs:comment 'Primary ISO 4217 three-letter currency code used for settlement with this correspondent bank.' ;
    rdfs:domain ind:CorrespondentBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryApprovalReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Reference' ;
    rdfs:comment 'Reference number or identifier for regulatory approval documentation related to this correspondent relationship.' ;
    rdfs:domain ind:CorrespondentBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipType rdf:type rdf:Property ;
    rdfs:label 'Relationship Type' ;
    rdfs:comment 'Type of correspondent banking relationship: nostro (our account with them), vostro (their account with us), bilateral (reciprocal), or unilateral (one-way).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceLevelAgreementReference rdf:type rdf:Property ;
    rdfs:label 'Service Level Agreement Reference' ;
    rdfs:comment 'Reference identifier for the Service Level Agreement (SLA) governing operational performance and service standards with this correspondent.' ;
    rdfs:domain ind:CorrespondentBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportedCurrencies rdf:type rdf:Property ;
    rdfs:label 'Supported Currencies' ;
    rdfs:comment 'Comma-separated list of ISO 4217 three-letter currency codes that can be processed through this correspondent relationship (e.g., USD,EUR,GBP,JPY).' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:swiftMessageTypes rdf:type rdf:Property ;
    rdfs:label 'Swift Message Types' ;
    rdfs:comment 'Comma-separated list of SWIFT message types (MT codes) supported for this correspondent relationship (e.g., MT103, MT202, MT910).' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageCurrencyId rdf:type rdf:Property ;
    rdfs:label 'Coverage Currency Id' ;
    rdfs:comment 'Foreign key linking to reference.currency. Business justification: Guarantees with coverage in currencies require currency metadata (rounding, minor unit) for enforceability assessment, call processing, capital relief calculation (RWA reduction), and regulatory repor' ;
    rdfs:domain ind:Guarantee ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:guaranteeGuarantorPartyId rdf:type rdf:Property ;
    rdfs:label 'Guarantee Guarantor Party Id' ;
    rdfs:comment 'FK to customer.party' ;
    rdfs:domain ind:Guarantee ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:guaranteePartyId rdf:type rdf:Property ;
    rdfs:label 'Guarantee Party Id' ;
    rdfs:comment 'Reference to the party providing the guarantee. May be an individual, corporation, or government entity.' ;
    rdfs:domain ind:Guarantee ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:guarantorCounterpartyRatingId rdf:type rdf:Property ;
    rdfs:label 'Guarantor Counterparty Rating Id' ;
    rdfs:comment 'Foreign key linking to risk.counterparty_rating. Business justification: Guarantee credit risk mitigation depends on guarantor creditworthiness. Regulatory capital relief calculations require guarantor ratings. Guarantor_credit_rating/internal_rating/pd/lgd are denormalize' ;
    rdfs:domain ind:Guarantee ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CounterpartyRating .

ind:guarantorKycReviewId rdf:type rdf:Property ;
    rdfs:label 'Guarantor Kyc Review Id' ;
    rdfs:comment 'Foreign key linking to compliance.kyc_review. Business justification: Guarantors must have current KYC reviews before a guarantee is accepted as credit risk mitigation. Role-prefixed \'guarantor_\' because guarantee has two party roles (guarantee_party_id and guarantee_gu' ;
    rdfs:domain ind:Guarantee ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:KycReview .

ind:guarantorSanctionsScreeningEventId rdf:type rdf:Property ;
    rdfs:label 'Guarantor Sanctions Screening Event Id' ;
    rdfs:comment 'Foreign key linking to compliance.sanctions_screening_event. Business justification: Guarantors must be screened against OFAC/sanctions lists before a guarantee is accepted. Role-prefixed \'guarantor_\' to distinguish from the primary obligor screening. This is a mandatory BSA complianc' ;
    rdfs:domain ind:Guarantee ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SanctionsScreeningEvent .

ind:parentGuaranteeId rdf:type rdf:Property ;
    rdfs:label 'Parent Guarantee Id' ;
    rdfs:comment 'Self-referencing FK on guarantee (parent_guarantee_id)' ;
    rdfs:domain ind:Guarantee ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Guarantee .

ind:callAmount rdf:type rdf:Property ;
    rdfs:label 'Call Amount' ;
    rdfs:comment 'Monetary amount demanded from the guarantor upon calling the guarantee. May be less than the full coverage amount depending on the outstanding loan balance and guarantee terms.' ;
    rdfs:domain ind:Guarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capitalReliefAmount rdf:type rdf:Property ;
    rdfs:label 'Capital Relief Amount' ;
    rdfs:comment 'Reduction in Risk-Weighted Assets (RWA) achieved through the guarantee. Calculated based on the difference between the borrower\'s and guarantor\'s risk weights.' ;
    rdfs:domain ind:Guarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coverageAmount rdf:type rdf:Property ;
    rdfs:label 'Coverage Amount' ;
    rdfs:comment 'Maximum monetary amount that the guarantor is obligated to pay under the guarantee. Used to calculate Loss Given Default (LGD) and regulatory capital relief.' ;
    rdfs:domain ind:Guarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coveragePercentage rdf:type rdf:Property ;
    rdfs:label 'Coverage Percentage' ;
    rdfs:comment 'Percentage of the loan exposure covered by the guarantee. Used to calculate partial credit risk mitigation for regulatory capital and Expected Credit Loss (ECL) purposes.' ;
    rdfs:domain ind:Guarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:crossDefaultClauseFlag rdf:type rdf:Property ;
    rdfs:label 'Cross Default Clause Flag' ;
    rdfs:comment 'Indicates whether the guarantee includes a cross-default provision that triggers the guarantee if the borrower defaults on other obligations. Strengthens credit risk mitigation.' ;
    rdfs:domain ind:Guarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:documentationType rdf:type rdf:Property ;
    rdfs:label 'Documentation Type' ;
    rdfs:comment 'Legal form of the guarantee documentation. Determines the legal framework, enforceability standards, and regulatory capital treatment.' ;
    rdfs:domain ind:Guarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eclAdjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Ecl Adjustment Amount' ;
    rdfs:comment 'Reduction in Expected Credit Loss provision due to the guarantee. Calculated based on the guarantor\'s creditworthiness and coverage amount under IFRS 9 or CECL.' ;
    rdfs:domain ind:Guarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enforceabilityOpinionDate rdf:type rdf:Property ;
    rdfs:label 'Enforceability Opinion Date' ;
    rdfs:comment 'Date of the most recent legal opinion confirming the enforceability of the guarantee. Basel III requires periodic legal review of credit risk mitigation instruments.' ;
    rdfs:domain ind:Guarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enforceabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Enforceability Status' ;
    rdfs:comment 'Legal assessment of whether the guarantee can be enforced in the relevant jurisdiction. Only enforceable guarantees qualify for regulatory capital relief under Basel III.' ;
    rdfs:domain ind:Guarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guarantorType rdf:type rdf:Property ;
    rdfs:label 'Guarantor Type' ;
    rdfs:comment 'Classification of the guarantor entity. Determines credit risk treatment, regulatory capital calculation, and enforceability considerations. [ENUM-REF-CANDIDATE: personal|corporate|government|bank|insurance_company|parent_company|third_party — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Guarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentReceivedAmount rdf:type rdf:Property ;
    rdfs:label 'Payment Received Amount' ;
    rdfs:comment 'Actual monetary amount received from the guarantor. Used to calculate recovery rates and reduce net credit losses.' ;
    rdfs:domain ind:Guarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryCapitalReliefFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Capital Relief Flag' ;
    rdfs:comment 'Indicates whether the guarantee meets Basel III criteria for regulatory capital relief. Requires enforceability, guarantor creditworthiness, and proper documentation.' ;
    rdfs:domain ind:Guarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rwaAfterGuarantee rdf:type rdf:Property ;
    rdfs:label 'Rwa After Guarantee' ;
    rdfs:comment 'Risk-Weighted Assets of the loan exposure after applying the guarantee credit risk mitigation. Reflects the substitution of the guarantor\'s risk weight.' ;
    rdfs:domain ind:Guarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rwaBeforeGuarantee rdf:type rdf:Property ;
    rdfs:label 'Rwa Before Guarantee' ;
    rdfs:comment 'Risk-Weighted Assets of the loan exposure before applying the guarantee credit risk mitigation. Used to calculate the capital relief benefit.' ;
    rdfs:domain ind:Guarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:destinationAccountDepositAccountId rdf:type rdf:Property ;
    rdfs:label 'Destination Account Deposit Account Id' ;
    rdfs:comment 'Foreign key linking to account.deposit_account. Business justification: Loan proceeds disbursement process: funds are credited to borrower\'s deposit account. Existing destination_account_number is denormalized; FK enables automated disbursement processing, regulatory repo' ;
    rdfs:domain ind:Disbursement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DepositAccount .

ind:reversalDisbursementId rdf:type rdf:Property ;
    rdfs:label 'Reversal Disbursement Id' ;
    rdfs:comment 'Self-referencing FK on disbursement (reversal_disbursement_id)' ;
    rdfs:domain ind:Disbursement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Disbursement .

ind:approvalAuthorityLevel rdf:type rdf:Property ;
    rdfs:label 'Approval Authority Level' ;
    rdfs:comment 'Level of authority required for disbursement approval (e.g., branch manager, credit committee, senior management).' ;
    rdfs:domain ind:Disbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionsPrecedentChecklist rdf:type rdf:Property ;
    rdfs:label 'Conditions Precedent Checklist' ;
    rdfs:comment 'Comma-separated list or description of specific conditions precedent that were verified before disbursement.' ;
    rdfs:domain ind:Disbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionsPrecedentSatisfiedFlag rdf:type rdf:Property ;
    rdfs:label 'Conditions Precedent Satisfied Flag' ;
    rdfs:comment 'Indicates whether all conditions precedent required for disbursement have been satisfied (e.g., documentation, collateral perfection, insurance).' ;
    rdfs:domain ind:Disbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:destinationAccountName rdf:type rdf:Property ;
    rdfs:label 'Destination Account Name' ;
    rdfs:comment 'Name of the account holder for the destination account receiving funds.' ;
    rdfs:domain ind:Disbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationBankBic rdf:type rdf:Property ;
    rdfs:label 'Destination Bank Bic' ;
    rdfs:comment 'SWIFT BIC code of the destination bank receiving the disbursement. Applicable for wire transfers and international payments.' ;
    rdfs:domain ind:Disbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationBankName rdf:type rdf:Property ;
    rdfs:label 'Destination Bank Name' ;
    rdfs:comment 'Name of the financial institution where the destination account is held.' ;
    rdfs:domain ind:Disbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationRoutingNumber rdf:type rdf:Property ;
    rdfs:label 'Destination Routing Number' ;
    rdfs:comment 'Routing or sort code for the destination bank. Used for domestic transfers (e.g., ABA routing number in US, sort code in UK).' ;
    rdfs:domain ind:Disbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disbursementDate rdf:type rdf:Property ;
    rdfs:label 'Disbursement Date' ;
    rdfs:comment 'Business date on which the disbursement was initiated or authorized.' ;
    rdfs:domain ind:Disbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disbursementMethod rdf:type rdf:Property ;
    rdfs:label 'Disbursement Method' ;
    rdfs:comment 'Payment mechanism used to transfer funds to the borrower (e.g., wire transfer, ACH, RTGS, check).' ;
    rdfs:domain ind:Disbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disbursementStatus rdf:type rdf:Property ;
    rdfs:label 'Disbursement Status' ;
    rdfs:comment 'Current lifecycle status of the disbursement transaction indicating processing state. [ENUM-REF-CANDIDATE: pending|approved|in_progress|completed|failed|cancelled|reversed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Disbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeRateDate rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate Date' ;
    rdfs:comment 'Date on which the exchange rate was determined for currency conversion.' ;
    rdfs:domain ind:Disbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:netDisbursementAmount rdf:type rdf:Property ;
    rdfs:label 'Net Disbursement Amount' ;
    rdfs:comment 'Net amount received by the borrower after deducting fees and charges from the gross disbursement amount.' ;
    rdfs:domain ind:Disbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partialDisbursementFlag rdf:type rdf:Property ;
    rdfs:label 'Partial Disbursement Flag' ;
    rdfs:comment 'Indicates whether this disbursement represents a partial release of the total approved loan amount.' ;
    rdfs:domain ind:Disbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pricingId rdf:type rdf:Property ;
    rdfs:label 'Pricing Id' ;
    rdfs:comment 'Unique identifier for the loan pricing record. Primary key for the pricing entity.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:previousLoanPricingId rdf:type rdf:Property ;
    rdfs:label 'Previous Loan Pricing Id' ;
    rdfs:comment 'Self-referencing FK on pricing (previous_loan_pricing_id)' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Pricing .

ind:securityBenchmarkId rdf:type rdf:Property ;
    rdfs:label 'Security Benchmark Id' ;
    rdfs:comment 'Foreign key linking to security.benchmark. Business justification: Floating-rate loan pricing desks reference security benchmarks (SOFR, EURIBOR indices) for base rate determination and MiFID/FRTB reporting. pricing already has rate_benchmark_id→reference.rate_benchm' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Benchmark .

ind:benchmarkRateCode rdf:type rdf:Property ;
    rdfs:label 'Benchmark Rate Code' ;
    rdfs:comment 'Code identifying the reference benchmark rate for floating-rate loans (e.g., SOFR, LIBOR, Prime, EURIBOR, Fed Funds). Null for fixed-rate loans.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capRate rdf:type rdf:Property ;
    rdfs:label 'Cap Rate' ;
    rdfs:comment 'The maximum interest rate that can be charged on the loan, providing borrower protection against rate increases. Expressed as a decimal. Null if no cap applies.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:defaultRate rdf:type rdf:Property ;
    rdfs:label 'Default Rate' ;
    rdfs:comment 'The penalty interest rate applied when the borrower is in default or breach of loan covenants. Expressed as a decimal. Null if no default rate provision exists.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:defaultSpreadBps rdf:type rdf:Property ;
    rdfs:label 'Default Spread Bps' ;
    rdfs:comment 'Additional spread in basis points added to the standard rate upon default or covenant breach. Null if no default spread applies.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exceptionFlag rdf:type rdf:Property ;
    rdfs:label 'Exception Flag' ;
    rdfs:comment 'Indicates whether this pricing represents an exception to standard pricing policy (true) or follows standard guidelines (false).' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exceptionReason rdf:type rdf:Property ;
    rdfs:label 'Exception Reason' ;
    rdfs:comment 'Business justification for pricing exception if the pricing_exception_flag is true. Null if no exception applies.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:floorRate rdf:type rdf:Property ;
    rdfs:label 'Floor Rate' ;
    rdfs:comment 'The minimum interest rate that can be charged on the loan, regardless of how low the benchmark rate falls. Expressed as a decimal. Null if no floor applies.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lgdAtPricing rdf:type rdf:Property ;
    rdfs:label 'Lgd At Pricing' ;
    rdfs:comment 'The estimated loss given default (LGD) at the time of pricing, expressed as a decimal (e.g., 0.4500 for 45%). Used for expected loss calculation in pricing models.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marginRate rdf:type rdf:Property ;
    rdfs:label 'Margin Rate' ;
    rdfs:comment 'Additional margin or adjustment rate applied on top of the base rate and spread, often used for risk-based pricing adjustments. Expressed as a decimal.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextRepricingDate rdf:type rdf:Property ;
    rdfs:label 'Next Repricing Date' ;
    rdfs:comment 'The next scheduled date on which the interest rate will be recalculated or reset based on the repricing frequency.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pdAtPricing rdf:type rdf:Property ;
    rdfs:label 'Pd At Pricing' ;
    rdfs:comment 'The estimated probability of default (PD) for the borrower at the time of pricing, expressed as a decimal (e.g., 0.0250 for 2.50%). Used for risk-based pricing validation.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prepaymentPenaltyRate rdf:type rdf:Property ;
    rdfs:label 'Prepayment Penalty Rate' ;
    rdfs:comment 'The penalty rate or fee percentage charged when the borrower prepays the loan before maturity. Expressed as a decimal. Null if no prepayment penalty applies.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricingStatus rdf:type rdf:Property ;
    rdfs:label 'Pricing Status' ;
    rdfs:comment 'Current lifecycle status of the pricing record: active (currently in effect), inactive (not in use), pending (approved but not yet effective), superseded (replaced by newer pricing), or expired (past expiration date).' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingTier rdf:type rdf:Property ;
    rdfs:label 'Pricing Tier' ;
    rdfs:comment 'Classification tier for relationship-based or volume-based pricing (e.g., Tier 1, Tier 2, Premium, Standard). Used when pricing varies by customer segment or utilization level.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rarocAtPricing rdf:type rdf:Property ;
    rdfs:label 'Raroc At Pricing' ;
    rdfs:comment 'The calculated risk-adjusted return on capital (RAROC) at the time of pricing, expressed as a decimal. Used to validate that pricing meets minimum return hurdles.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateLockExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Rate Lock Expiration Date' ;
    rdfs:comment 'The date on which a rate lock expires if the loan has not closed. Null if no rate lock is in effect.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rateLockFlag rdf:type rdf:Property ;
    rdfs:label 'Rate Lock Flag' ;
    rdfs:comment 'Indicates whether the interest rate is locked (true) or subject to change before loan closing (false). Commonly used during loan origination period.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:relationshipDiscountBps rdf:type rdf:Property ;
    rdfs:label 'Relationship Discount Bps' ;
    rdfs:comment 'Discount in basis points granted based on the overall banking relationship value. Null if no relationship discount applies.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:repricingFrequency rdf:type rdf:Property ;
    rdfs:label 'Repricing Frequency' ;
    rdfs:comment 'The frequency at which the interest rate is recalculated or reset for floating-rate loans. For fixed-rate loans, this is typically \'at_maturity\'. [ENUM-REF-CANDIDATE: daily|weekly|monthly|quarterly|semi_annually|annually|at_maturity|on_demand — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskRatingAtPricing rdf:type rdf:Property ;
    rdfs:label 'Risk Rating At Pricing' ;
    rdfs:comment 'The internal credit risk rating of the borrower or facility at the time this pricing was established. Used for risk-adjusted pricing analysis.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentCtrFilingId rdf:type rdf:Property ;
    rdfs:label 'Amendment Ctr Filing Id' ;
    rdfs:comment 'Self-referencing FK on ctr_filing (amendment_ctr_filing_id)' ;
    rdfs:domain ind:CtrFiling ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CtrFiling .

ind:aggregatedTransactionsFlag rdf:type rdf:Property ;
    rdfs:label 'Aggregated Transactions Flag' ;
    rdfs:comment 'Indicates whether this CTR represents multiple transactions aggregated to exceed the $10,000 threshold.' ;
    rdfs:domain ind:CtrFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:armoredCarServiceFlag rdf:type rdf:Property ;
    rdfs:label 'Armored Car Service Flag' ;
    rdfs:comment 'Indicates whether the cash transaction involved an armored car service.' ;
    rdfs:domain ind:CtrFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:atmTransactionFlag rdf:type rdf:Property ;
    rdfs:label 'Atm Transaction Flag' ;
    rdfs:comment 'Indicates whether the cash transaction occurred at an ATM.' ;
    rdfs:domain ind:CtrFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bsaIdentifier rdf:type rdf:Property ;
    rdfs:label 'Bsa Identifier' ;
    rdfs:comment 'FinCEN-assigned BSA identifier for this CTR filing, used for regulatory tracking and acknowledgment.' ;
    rdfs:domain ind:CtrFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingNotes rdf:type rdf:Property ;
    rdfs:label 'Filing Notes' ;
    rdfs:comment 'Additional notes or comments related to the CTR filing, including context or special circumstances.' ;
    rdfs:domain ind:CtrFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:multiplePersonsFlag rdf:type rdf:Property ;
    rdfs:label 'Multiple Persons Flag' ;
    rdfs:comment 'Indicates whether multiple persons were involved in conducting the reportable transaction(s).' ;
    rdfs:domain ind:CtrFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preparerPhoneNumber rdf:type rdf:Property ;
    rdfs:label 'Preparer Phone Number' ;
    rdfs:comment 'Contact phone number for the bank employee who prepared the CTR.' ;
    rdfs:domain ind:CtrFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorFilingReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Prior Filing Reference Number' ;
    rdfs:comment 'Reference number of the original CTR filing if this is an amendment.' ;
    rdfs:domain ind:CtrFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewTimestamp rdf:type rdf:Property ;
    rdfs:label 'Review Timestamp' ;
    rdfs:comment 'Timestamp when the CTR filing was reviewed and approved by compliance.' ;
    rdfs:domain ind:CtrFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:suspiciousActivityIndicator rdf:type rdf:Property ;
    rdfs:label 'Suspicious Activity Indicator' ;
    rdfs:comment 'Indicates whether the transaction also warrants a Suspicious Activity Report (SAR) filing due to suspicious characteristics.' ;
    rdfs:domain ind:CtrFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalCashInAmount rdf:type rdf:Property ;
    rdfs:label 'Total Cash In Amount' ;
    rdfs:comment 'Total amount of cash received (deposited) in the reportable transaction(s).' ;
    rdfs:domain ind:CtrFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCashOutAmount rdf:type rdf:Property ;
    rdfs:label 'Total Cash Out Amount' ;
    rdfs:comment 'Total amount of cash disbursed (withdrawn) in the reportable transaction(s).' ;
    rdfs:domain ind:CtrFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primarySupersededByPolicyId rdf:type rdf:Property ;
    rdfs:label 'Primary Superseded By Policy Id' ;
    rdfs:comment 'Identifier of the policy that replaces this one, if applicable. Null if the policy is current.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Policy .

ind:attestationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Attestation Required Flag' ;
    rdfs:comment 'Indicates whether employees must formally attest to their understanding and compliance with this policy.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:documentUrl rdf:type rdf:Property ;
    rdfs:label 'Document Url' ;
    rdfs:comment 'Link to the full policy document stored in the document management system or intranet.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enforcementLevel rdf:type rdf:Property ;
    rdfs:label 'Enforcement Level' ;
    rdfs:comment 'Degree of enforceability and consequences for non-adherence to the policy.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governanceCommittee rdf:type rdf:Property ;
    rdfs:label 'Governance Committee' ;
    rdfs:comment 'Name of the board committee or governance body responsible for oversight of this policy (e.g., Asset-Liability Committee (ALCO), Risk Committee, Audit Committee).' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lobApplicability rdf:type rdf:Property ;
    rdfs:label 'Lob Applicability' ;
    rdfs:comment 'Specific lines of business covered by this policy (e.g., Retail Banking, Investment Banking, Wealth Management, Treasury).' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyCategory rdf:type rdf:Property ;
    rdfs:label 'Policy Category' ;
    rdfs:comment 'Regulatory domain or compliance area that this policy addresses, aligned with industry-standard frameworks and regulatory requirements. [ENUM-REF-CANDIDATE: aml|kyc|sanctions|sox|fatca|crs|bsa|ccar|dfast|ifrs9|cecl|frtb — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyDescription rdf:type rdf:Property ;
    rdfs:label 'Policy Description' ;
    rdfs:comment 'Comprehensive description of the policy objectives, scope, and key requirements it implements.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyName rdf:type rdf:Property ;
    rdfs:label 'Policy Name' ;
    rdfs:comment 'Full name of the compliance policy as it appears in official documentation and regulatory filings.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyNumber rdf:type rdf:Property ;
    rdfs:label 'Policy Number' ;
    rdfs:comment 'Business identifier for the compliance policy, externally referenced in regulatory documentation and internal governance materials.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyStatus rdf:type rdf:Property ;
    rdfs:label 'Policy Status' ;
    rdfs:comment 'Current lifecycle status of the policy indicating its operational state and enforceability. [ENUM-REF-CANDIDATE: draft|pending_review|approved|active|suspended|retired|superseded — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyType rdf:type rdf:Property ;
    rdfs:label 'Policy Type' ;
    rdfs:comment 'Classification of the policy based on its primary purpose and scope within the compliance framework.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicDisclosureFlag rdf:type rdf:Property ;
    rdfs:label 'Public Disclosure Flag' ;
    rdfs:comment 'Indicates whether this policy or its summary must be publicly disclosed per regulatory requirements.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryBody rdf:type rdf:Property ;
    rdfs:label 'Regulatory Body' ;
    rdfs:comment 'The governing authority or regulatory agency that issued the underlying requirement (e.g., Federal Reserve, SEC, OCC, FINRA).' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewCycleMonths rdf:type rdf:Property ;
    rdfs:label 'Review Cycle Months' ;
    rdfs:comment 'Frequency in months at which the policy must be reviewed and reaffirmed to ensure continued relevance and compliance.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trainingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Training Required Flag' ;
    rdfs:comment 'Indicates whether employees subject to this policy must complete mandatory training.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:applicableChannelId rdf:type rdf:Property ;
    rdfs:label 'Applicable Channel Id' ;
    rdfs:comment 'Foreign key linking to channel.channel. Business justification: AML monitoring rules scope applicable channels (wire transfer rules don\'t apply to ATM, structuring rules target branch/teller) for scenario configuration, alert generation logic, and false positive r' ;
    rdfs:domain ind:MonitoringRule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:primarySupersededByRuleMonitoringRuleId rdf:type rdf:Property ;
    rdfs:label 'Primary Superseded By Rule Monitoring Rule Id' ;
    rdfs:comment 'Identifier of the monitoring rule that replaces this rule, if applicable.' ;
    rdfs:domain ind:MonitoringRule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MonitoringRule .

ind:aggregationMethod rdf:type rdf:Property ;
    rdfs:label 'Aggregation Method' ;
    rdfs:comment 'Statistical method used to aggregate transaction data for threshold comparison (sum, count, average, maximum, peer comparison).' ;
    rdfs:domain ind:MonitoringRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertVolumeMonthlyAverage rdf:type rdf:Property ;
    rdfs:label 'Alert Volume Monthly Average' ;
    rdfs:comment 'Average number of alerts generated by this rule per month, used for capacity planning and effectiveness assessment.' ;
    rdfs:domain ind:MonitoringRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicableCustomerSegments rdf:type rdf:Property ;
    rdfs:label 'Applicable Customer Segments' ;
    rdfs:comment 'Customer segments or types to which this rule applies (e.g., retail, commercial, private banking, correspondent banking).' ;
    rdfs:domain ind:MonitoringRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableProductTypes rdf:type rdf:Property ;
    rdfs:label 'Applicable Product Types' ;
    rdfs:comment 'Banking product types monitored by this rule (e.g., checking accounts, wire transfers, trade finance, securities trading).' ;
    rdfs:domain ind:MonitoringRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionLogic rdf:type rdf:Property ;
    rdfs:label 'Detection Logic' ;
    rdfs:comment 'Technical description of the rule logic, including conditions, thresholds, and aggregation methods used for alert generation.' ;
    rdfs:domain ind:MonitoringRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastExaminationDate rdf:type rdf:Property ;
    rdfs:label 'Last Examination Date' ;
    rdfs:comment 'Date of the most recent regulatory examination that reviewed this rule.' ;
    rdfs:domain ind:MonitoringRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:modelValidationStatus rdf:type rdf:Property ;
    rdfs:label 'Model Validation Status' ;
    rdfs:comment 'Current validation status of the rule model under the Model Risk Management framework.' ;
    rdfs:domain ind:MonitoringRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextValidationDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Validation Due Date' ;
    rdfs:comment 'Scheduled date for the next required model validation review.' ;
    rdfs:domain ind:MonitoringRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:peerGroupDefinition rdf:type rdf:Property ;
    rdfs:label 'Peer Group Definition' ;
    rdfs:comment 'Criteria used to define peer groups for peer-based anomaly detection rules (e.g., industry, geography, account type).' ;
    rdfs:domain ind:MonitoringRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retirementReason rdf:type rdf:Property ;
    rdfs:label 'Retirement Reason' ;
    rdfs:comment 'Explanation for why the rule was retired or deactivated, if applicable.' ;
    rdfs:domain ind:MonitoringRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sarConversionRate rdf:type rdf:Property ;
    rdfs:label 'Sar Conversion Rate' ;
    rdfs:comment 'Percentage of alerts from this rule that result in SAR filings, indicating rule effectiveness.' ;
    rdfs:domain ind:MonitoringRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaReviewHours rdf:type rdf:Property ;
    rdfs:label 'Sla Review Hours' ;
    rdfs:comment 'Number of hours within which alerts generated by this rule must be reviewed, per internal SLA policy.' ;
    rdfs:domain ind:MonitoringRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:thresholdCount rdf:type rdf:Property ;
    rdfs:label 'Threshold Count' ;
    rdfs:comment 'Transaction count threshold that triggers an alert when exceeded. Used in frequency-based detection scenarios.' ;
    rdfs:domain ind:MonitoringRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tuningHistoryCount rdf:type rdf:Property ;
    rdfs:label 'Tuning History Count' ;
    rdfs:comment 'Number of times this rule has been tuned or recalibrated since initial deployment.' ;
    rdfs:domain ind:MonitoringRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tuningRationale rdf:type rdf:Property ;
    rdfs:label 'Tuning Rationale' ;
    rdfs:comment 'Business justification and explanation for the most recent rule tuning or threshold adjustment.' ;
    rdfs:domain ind:MonitoringRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousCounterpartyAgreementId rdf:type rdf:Property ;
    rdfs:label 'Previous Counterparty Agreement Id' ;
    rdfs:comment 'Self-referencing FK on counterparty_agreement (previous_counterparty_agreement_id)' ;
    rdfs:domain ind:CounterpartyAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CounterpartyAgreement .

ind:bookingEntityLei rdf:type rdf:Property ;
    rdfs:label 'Booking Entity Lei' ;
    rdfs:comment '20-character ISO 17442 Legal Entity Identifier of the bank legal entity that is party to this agreement.' ;
    rdfs:domain ind:CounterpartyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Clearing Requirement Flag' ;
    rdfs:comment 'Indicates whether trades under this agreement are subject to mandatory central clearing requirements.' ;
    rdfs:domain ind:CounterpartyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:collateralArrangementFlag rdf:type rdf:Property ;
    rdfs:label 'Collateral Arrangement Flag' ;
    rdfs:comment 'Indicates whether the agreement includes collateral or margin posting requirements.' ;
    rdfs:domain ind:CounterpartyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditRatingTriggerFlag rdf:type rdf:Property ;
    rdfs:label 'Credit Rating Trigger Flag' ;
    rdfs:comment 'Indicates whether the agreement contains provisions triggered by credit rating downgrades.' ;
    rdfs:domain ind:CounterpartyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disputeResolutionMethod rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Method' ;
    rdfs:comment 'Primary method specified in the agreement for resolving disputes between parties.' ;
    rdfs:domain ind:CounterpartyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentRepositoryReference rdf:type rdf:Property ;
    rdfs:label 'Document Repository Reference' ;
    rdfs:comment 'Reference identifier or URI to the physical or electronic storage location of the signed agreement document.' ;
    rdfs:domain ind:CounterpartyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibleCollateralTypes rdf:type rdf:Property ;
    rdfs:label 'Eligible Collateral Types' ;
    rdfs:comment 'Comma-separated list of asset types acceptable as collateral under the agreement (e.g., Cash, Government Bonds, Corporate Bonds, Equities).' ;
    rdfs:domain ind:CounterpartyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marginCallFrequency rdf:type rdf:Property ;
    rdfs:label 'Margin Call Frequency' ;
    rdfs:comment 'Frequency at which margin calls may be issued under the agreement.' ;
    rdfs:domain ind:CounterpartyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:masterConfirmationFlag rdf:type rdf:Property ;
    rdfs:label 'Master Confirmation Flag' ;
    rdfs:comment 'Indicates whether a master confirmation agreement exists that pre-defines economic terms for specific product types.' ;
    rdfs:domain ind:CounterpartyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mtmLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Mtm Limit Amount' ;
    rdfs:comment 'Maximum mark-to-market exposure permitted under the agreement. Null if no limit applies.' ;
    rdfs:domain ind:CounterpartyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nettingProvisionFlag rdf:type rdf:Property ;
    rdfs:label 'Netting Provision Flag' ;
    rdfs:comment 'Indicates whether the agreement includes close-out netting provisions for offsetting obligations upon default or termination.' ;
    rdfs:domain ind:CounterpartyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:settlementTime rdf:type rdf:Property ;
    rdfs:label 'Settlement Time' ;
    rdfs:comment 'Standard settlement timeframe for collateral transfers under the agreement, expressed as trade date plus number of business days.' ;
    rdfs:domain ind:CounterpartyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:commissionCurrencyId rdf:type rdf:Property ;
    rdfs:label 'Commission Currency Id' ;
    rdfs:comment 'Foreign key linking to reference.currency. Business justification: Broker commission currency validation required for cost accrual, payment processing, and commission schedule management. Reference data provides currency attributes for broker payment instructions.' ;
    rdfs:domain ind:Broker ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:parentBrokerId rdf:type rdf:Property ;
    rdfs:label 'Parent Broker Id' ;
    rdfs:comment 'Self-referencing FK on broker (parent_broker_id)' ;
    rdfs:domain ind:Broker ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Broker .

ind:brokerCode rdf:type rdf:Property ;
    rdfs:label 'Broker Code' ;
    rdfs:comment 'Internal business identifier or mnemonic code assigned to the broker for operational reference and reporting purposes.' ;
    rdfs:domain ind:Broker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brokerStatus rdf:type rdf:Property ;
    rdfs:label 'Broker Status' ;
    rdfs:comment 'Current operational status of the broker relationship: active (approved for trading), inactive (not currently used), suspended (temporarily restricted), pending approval (under review), or terminated (relationship ended).' ;
    rdfs:domain ind:Broker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brokerType rdf:type rdf:Property ;
    rdfs:label 'Broker Type' ;
    rdfs:comment 'Classification of the broker based on the primary service provided: executing broker (trade execution), prime broker (financing and custody), clearing broker (post-trade clearing), introducing broker (client referral), custodian broker (asset custody), or agency broker (agent capacity).' ;
    rdfs:domain ind:Broker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimitCurrency rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the credit limit is denominated.' ;
    rdfs:domain ind:Broker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultCommissionRate rdf:type rdf:Property ;
    rdfs:label 'Default Commission Rate' ;
    rdfs:comment 'Standard commission rate (in basis points or percentage) charged by the broker for trade execution when no specific schedule applies.' ;
    rdfs:domain ind:Broker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eligibleAssetClasses rdf:type rdf:Property ;
    rdfs:label 'Eligible Asset Classes' ;
    rdfs:comment 'Comma-separated list of asset classes for which this broker is approved to execute trades (e.g., equities, fixed_income, derivatives, fx, commodities).' ;
    rdfs:domain ind:Broker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibleMarkets rdf:type rdf:Property ;
    rdfs:label 'Eligible Markets' ;
    rdfs:comment 'Comma-separated list of trading venues or market identifiers (MIC codes) where this broker is authorized to execute trades.' ;
    rdfs:domain ind:Broker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onboardingDate rdf:type rdf:Property ;
    rdfs:label 'Onboarding Date' ;
    rdfs:comment 'Date on which the broker was onboarded and approved for trading activity following due diligence and compliance review.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:parentIndustryCodeId rdf:type rdf:Property ;
    rdfs:label 'Parent Industry Code Id' ;
    rdfs:comment 'Self-referencing FK on industry_code (parent_industry_code_id)' ;
    rdfs:domain ind:IndustryCode ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IndustryCode .

ind:classificationSystem rdf:type rdf:Property ;
    rdfs:label 'Classification System' ;
    rdfs:comment 'The industry classification system or taxonomy used (Standard Industrial Classification, North American Industry Classification System, Global Industry Classification Standard, Industry Classification Benchmark).' ;
    rdfs:domain ind:IndustryCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:climateRiskExposure rdf:type rdf:Property ;
    rdfs:label 'Climate Risk Exposure' ;
    rdfs:comment 'The level of physical and transition climate risk exposure associated with this industry, used for climate stress testing and scenario analysis.' ;
    rdfs:domain ind:IndustryCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codeDescription rdf:type rdf:Property ;
    rdfs:label 'Code Description' ;
    rdfs:comment 'Full textual description of the industry classification code, providing detailed explanation of the industry segment or activity covered.' ;
    rdfs:domain ind:IndustryCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codePath rdf:type rdf:Property ;
    rdfs:label 'Code Path' ;
    rdfs:comment 'Full hierarchical path from root to current code, typically pipe or slash delimited (e.g., Financials|Banks|Diversified Banks), enabling efficient hierarchy queries.' ;
    rdfs:domain ind:IndustryCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codeShortName rdf:type rdf:Property ;
    rdfs:label 'Code Short Name' ;
    rdfs:comment 'Abbreviated or short name for the industry classification code, used for display and reporting purposes.' ;
    rdfs:domain ind:IndustryCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codeValue rdf:type rdf:Property ;
    rdfs:label 'Code Value' ;
    rdfs:comment 'The actual industry classification code value within the specified system (e.g., 522110 for Commercial Banking in NAICS, 4020 for Banks in GICS).' ;
    rdfs:domain ind:IndustryCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:concentrationRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Concentration Risk Flag' ;
    rdfs:comment 'Indicates whether exposures to this industry are subject to concentration risk monitoring and limits under the banks risk appetite framework and regulatory guidance.' ;
    rdfs:domain ind:IndustryCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cyclicalSensitivity rdf:type rdf:Property ;
    rdfs:label 'Cyclical Sensitivity' ;
    rdfs:comment 'The sensitivity of this industry to economic cycles, informing credit risk modeling, stress testing, and portfolio diversification strategies.' ;
    rdfs:domain ind:IndustryCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esgRiskCategory rdf:type rdf:Property ;
    rdfs:label 'Esg Risk Category' ;
    rdfs:comment 'The Environmental, Social, and Governance risk category assigned to this industry, supporting sustainable finance and climate risk assessment.' ;
    rdfs:domain ind:IndustryCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gicsEquivalentCode rdf:type rdf:Property ;
    rdfs:label 'Gics Equivalent Code' ;
    rdfs:comment 'Cross-mapping to the equivalent GICS code, enabling global equity market analysis and portfolio classification.' ;
    rdfs:domain ind:IndustryCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:highRiskIndustryFlag rdf:type rdf:Property ;
    rdfs:label 'High Risk Industry Flag' ;
    rdfs:comment 'Indicates whether this industry is classified as high-risk for Anti-Money Laundering (AML), sanctions, fraud, or credit risk purposes, triggering enhanced due diligence requirements.' ;
    rdfs:domain ind:IndustryCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:icbEquivalentCode rdf:type rdf:Property ;
    rdfs:label 'Icb Equivalent Code' ;
    rdfs:comment 'Cross-mapping to the equivalent ICB code, enabling FTSE Russell index alignment and international market analysis.' ;
    rdfs:domain ind:IndustryCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industryCodeStatus rdf:type rdf:Property ;
    rdfs:label 'Industry Code Status' ;
    rdfs:comment 'The current lifecycle status of this industry code, indicating whether it is actively used, deprecated, superseded by another code, or proposed for future adoption.' ;
    rdfs:domain ind:IndustryCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industryGroupName rdf:type rdf:Property ;
    rdfs:label 'Industry Group Name' ;
    rdfs:comment 'The mid-level industry group name within the sector hierarchy, providing intermediate classification granularity.' ;
    rdfs:domain ind:IndustryCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:naicsEquivalentCode rdf:type rdf:Property ;
    rdfs:label 'Naics Equivalent Code' ;
    rdfs:comment 'Cross-mapping to the equivalent NAICS code, enabling regulatory reporting alignment and North American market analysis.' ;
    rdfs:domain ind:IndustryCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentCodeValue rdf:type rdf:Property ;
    rdfs:label 'Parent Code Value' ;
    rdfs:comment 'The code value of the parent industry classification in the hierarchy, enabling drill-up aggregation and hierarchical navigation.' ;
    rdfs:domain ind:IndustryCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:riskWeightCategory rdf:type rdf:Property ;
    rdfs:label 'Risk Weight Category' ;
    rdfs:comment 'The risk weight category assigned to exposures in this industry for regulatory capital calculation under Basel III standardized or internal ratings-based approaches.' ;
    rdfs:domain ind:IndustryCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sanctionsExposureFlag rdf:type rdf:Property ;
    rdfs:label 'Sanctions Exposure Flag' ;
    rdfs:comment 'Indicates whether this industry has heightened exposure to OFAC or international sanctions regimes, requiring enhanced screening and monitoring.' ;
    rdfs:domain ind:IndustryCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sicEquivalentCode rdf:type rdf:Property ;
    rdfs:label 'Sic Equivalent Code' ;
    rdfs:comment 'Cross-mapping to the equivalent Standard Industrial Classification code, enabling legacy system integration and historical analysis.' ;
    rdfs:domain ind:IndustryCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subIndustryName rdf:type rdf:Property ;
    rdfs:label 'Sub Industry Name' ;
    rdfs:comment 'The most granular sub-industry name, providing detailed industry segment classification for specialized analysis.' ;
    rdfs:domain ind:IndustryCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByCodeValue rdf:type rdf:Property ;
    rdfs:label 'Superseded By Code Value' ;
    rdfs:comment 'The code value that supersedes this industry code when it is deprecated or replaced, enabling automated code migration and historical mapping.' ;
    rdfs:domain ind:IndustryCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usageNotes rdf:type rdf:Property ;
    rdfs:label 'Usage Notes' ;
    rdfs:comment 'Free-text notes providing guidance on proper usage, interpretation, or special considerations for this industry code classification.' ;
    rdfs:domain ind:IndustryCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentTrustAccountId rdf:type rdf:Property ;
    rdfs:label 'Parent Trust Account Id' ;
    rdfs:comment 'Self-referencing FK on trust_account (parent_trust_account_id)' ;
    rdfs:domain ind:TrustAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TrustAccount .

ind:beneficiaryCount rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Count' ;
    rdfs:comment 'Total number of beneficiaries designated to receive distributions or benefits from the trust.' ;
    rdfs:domain ind:TrustAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:distributionFrequency rdf:type rdf:Property ;
    rdfs:label 'Distribution Frequency' ;
    rdfs:comment 'Scheduled frequency at which distributions are made to beneficiaries according to trust terms.' ;
    rdfs:domain ind:Banking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionProvisionType rdf:type rdf:Property ;
    rdfs:label 'Distribution Provision Type' ;
    rdfs:comment 'Classification of the distribution rules governing how and when trust assets are distributed to beneficiaries.' ;
    rdfs:domain ind:TrustAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiduciaryDutyClassification rdf:type rdf:Property ;
    rdfs:label 'Fiduciary Duty Classification' ;
    rdfs:comment 'Classification of the fiduciary responsibility and duty of care owed to the trust beneficiaries.' ;
    rdfs:domain ind:TrustAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantorName rdf:type rdf:Property ;
    rdfs:label 'Grantor Name' ;
    rdfs:comment 'Full legal name of the individual or entity who established the trust and transferred assets into it.' ;
    rdfs:domain ind:TrustAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantorTaxIdentifier rdf:type rdf:Property ;
    rdfs:label 'Grantor Tax Identifier' ;
    rdfs:comment 'Tax identification number of the grantor for IRS reporting and tax compliance purposes.' ;
    rdfs:domain ind:TrustAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryBeneficiaryName rdf:type rdf:Property ;
    rdfs:label 'Primary Beneficiary Name' ;
    rdfs:comment 'Full legal name of the primary beneficiary entitled to receive distributions from the trust.' ;
    rdfs:domain ind:TrustAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revocableFlag rdf:type rdf:Property ;
    rdfs:label 'Revocable Flag' ;
    rdfs:comment 'Indicates whether the grantor retains the right to revoke, amend, or terminate the trust during their lifetime.' ;
    rdfs:domain ind:TrustAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:spendthriftProvisionFlag rdf:type rdf:Property ;
    rdfs:label 'Spendthrift Provision Flag' ;
    rdfs:comment 'Indicates whether the trust includes a spendthrift clause restricting beneficiary ability to transfer or pledge trust interests and protecting assets from creditors.' ;
    rdfs:domain ind:TrustAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:successorTrusteeName rdf:type rdf:Property ;
    rdfs:label 'Successor Trustee Name' ;
    rdfs:comment 'Name of the designated successor trustee who will assume fiduciary duties upon the current trustee\'s resignation, incapacity, or death.' ;
    rdfs:domain ind:TrustAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationEvent rdf:type rdf:Property ;
    rdfs:label 'Termination Event' ;
    rdfs:comment 'Description of the event or condition that triggered the termination of the trust, such as beneficiary reaching specified age or grantor death.' ;
    rdfs:domain ind:TrustAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trustAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Trust Account Number' ;
    rdfs:comment 'Externally visible unique account number assigned to the trust account for client communication and regulatory reporting.' ;
    rdfs:domain ind:TrustAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trustInstrumentDate rdf:type rdf:Property ;
    rdfs:label 'Trust Instrument Date' ;
    rdfs:comment 'Date on which the trust instrument or declaration was executed and legally established.' ;
    rdfs:domain ind:TrustAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trustName rdf:type rdf:Property ;
    rdfs:label 'Trust Name' ;
    rdfs:comment 'Legal name of the trust as registered in the trust instrument or declaration.' ;
    rdfs:domain ind:TrustAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trustPurpose rdf:type rdf:Property ;
    rdfs:label 'Trust Purpose' ;
    rdfs:comment 'Stated purpose and intent of the trust as documented in the trust instrument, describing the grantor\'s objectives.' ;
    rdfs:domain ind:TrustAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trustStatus rdf:type rdf:Property ;
    rdfs:label 'Trust Status' ;
    rdfs:comment 'Current operational status of the trust account in its lifecycle.' ;
    rdfs:domain ind:TrustAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trustTaxIdentifier rdf:type rdf:Property ;
    rdfs:label 'Trust Tax Identifier' ;
    rdfs:comment 'Employer Identification Number (EIN) or Tax Identification Number assigned to the trust for tax reporting purposes.' ;
    rdfs:domain ind:TrustAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trustType rdf:type rdf:Property ;
    rdfs:label 'Trust Type' ;
    rdfs:comment 'Classification of the trust structure indicating the legal and tax treatment of the trust arrangement. [ENUM-REF-CANDIDATE: revocable|irrevocable|testamentary|living|charitable|special_needs|grantor_retained|qualified_personal_residence — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TrustAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trusteeName rdf:type rdf:Property ;
    rdfs:label 'Trustee Name' ;
    rdfs:comment 'Full legal name of the individual or institution serving as trustee with fiduciary responsibility for managing trust assets.' ;
    rdfs:domain ind:TrustAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trusteeType rdf:type rdf:Property ;
    rdfs:label 'Trustee Type' ;
    rdfs:comment 'Classification of the trustee role indicating whether the trustee is an individual or institutional fiduciary.' ;
    rdfs:domain ind:TrustAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditorPartyId rdf:type rdf:Property ;
    rdfs:label 'Auditor Party Id' ;
    rdfs:comment 'Unique identifier for the external auditor responsible for auditing the fund\'s financial statements.' ;
    rdfs:domain ind:Fund ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:domicileJurisdictionId rdf:type rdf:Property ;
    rdfs:label 'Domicile Jurisdiction Id' ;
    rdfs:comment 'Foreign key linking to reference.jurisdiction. Business justification: Fund domicile determines regulatory framework (Luxembourg UCITS, Irish QIF, Cayman SPC), tax treatment, and supervisory authority. Critical for compliance, licensing, and legal structure.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Jurisdiction .

ind:fundPartyId rdf:type rdf:Property ;
    rdfs:label 'Fund Party Id' ;
    rdfs:comment 'Unique identifier for the custodian bank responsible for safekeeping the fund\'s assets.' ;
    rdfs:domain ind:Fund ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:fundTransferAgentPartyId rdf:type rdf:Property ;
    rdfs:label 'Fund Transfer Agent Party Id' ;
    rdfs:comment 'Unique identifier for the transfer agent responsible for maintaining shareholder records and processing subscriptions and redemptions.' ;
    rdfs:domain ind:Fund ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:masterFundId rdf:type rdf:Property ;
    rdfs:label 'Master Fund Id' ;
    rdfs:comment 'Self-referencing FK on fund (master_fund_id)' ;
    rdfs:domain ind:Fund ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fund .

ind:primaryUmbrellaFundId rdf:type rdf:Property ;
    rdfs:label 'Primary Umbrella Fund Id' ;
    rdfs:comment 'Unique identifier for the parent umbrella fund structure if this fund is a sub-fund within a larger umbrella arrangement. Null if the fund is standalone.' ;
    rdfs:domain ind:Fund ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fund .

ind:dealingFrequency rdf:type rdf:Property ;
    rdfs:label 'Dealing Frequency' ;
    rdfs:comment 'The frequency at which investors can subscribe to or redeem shares from the fund: daily, weekly, monthly, or quarterly.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionPolicy rdf:type rdf:Property ;
    rdfs:label 'Distribution Policy' ;
    rdfs:comment 'The fund\'s policy regarding income and capital gains: accumulating (reinvested), distributing (paid out to investors), or mixed.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYearEnd rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year End' ;
    rdfs:comment 'The month and day (MM-DD format) marking the end of the fund\'s fiscal year for accounting and regulatory reporting purposes.' ;
    rdfs:domain ind:Fund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundName rdf:type rdf:Property ;
    rdfs:label 'Fund Name' ;
    rdfs:comment 'The full legal name of the investment fund as registered with regulatory authorities.' ;
    rdfs:domain ind:Fund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundStatus rdf:type rdf:Property ;
    rdfs:label 'Fund Status' ;
    rdfs:comment 'The current operational status of the fund: active (accepting subscriptions), soft-closed (limited new subscriptions), hard-closed (no new subscriptions), liquidating (winding down), terminated (closed), or suspended (temporarily halted).' ;
    rdfs:domain ind:Fund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundType rdf:type rdf:Property ;
    rdfs:label 'Fund Type' ;
    rdfs:comment 'The primary classification of the fund structure: mutual fund, exchange-traded fund (ETF), hedge fund, pension fund, UCITS (Undertakings for Collective Investment in Transferable Securities), or SICAV (Société d\'Investissement à Capital Variable).' ;
    rdfs:domain ind:Fund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investmentStrategy rdf:type rdf:Property ;
    rdfs:label 'Investment Strategy' ;
    rdfs:comment 'The primary investment strategy employed by the fund: growth, value, income, balanced, index-tracking, quantitative, or alternative strategies. [ENUM-REF-CANDIDATE: growth|value|income|balanced|index|quantitative|alternative — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalStructure rdf:type rdf:Property ;
    rdfs:label 'Legal Structure' ;
    rdfs:comment 'The legal structure of the fund: open-ended (continuous issuance/redemption), closed-ended (fixed shares), unit trust, investment trust, or limited partnership.' ;
    rdfs:domain ind:Fund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumInvestment rdf:type rdf:Property ;
    rdfs:label 'Minimum Investment' ;
    rdfs:comment 'The minimum amount required for an initial investment in the fund, expressed in the base currency.' ;
    rdfs:domain ind:Fund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumSubsequentInvestment rdf:type rdf:Property ;
    rdfs:label 'Minimum Subsequent Investment' ;
    rdfs:comment 'The minimum amount required for subsequent investments after the initial subscription, expressed in the base currency.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:navFrequency rdf:type rdf:Property ;
    rdfs:label 'Nav Frequency' ;
    rdfs:comment 'The frequency at which the fund\'s Net Asset Value (NAV) is calculated and published: daily, weekly, monthly, quarterly, or annually.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prospectusDate rdf:type rdf:Property ;
    rdfs:label 'Prospectus Date' ;
    rdfs:comment 'The effective date of the current fund prospectus or offering document.' ;
    rdfs:domain ind:Fund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:redemptionNoticePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Redemption Notice Period Days' ;
    rdfs:comment 'The number of days advance notice required by investors to redeem shares from the fund.' ;
    rdfs:domain ind:Fund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:settlementPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Settlement Period Days' ;
    rdfs:comment 'The number of days after a subscription or redemption transaction date (T) by which settlement must occur (e.g., T+3).' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalExpenseRatio rdf:type rdf:Property ;
    rdfs:label 'Total Expense Ratio' ;
    rdfs:comment 'The total annual operating expenses of the fund expressed as a percentage of average net assets, including management fees, administrative costs, and other operational expenses.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseFundClassId rdf:type rdf:Property ;
    rdfs:label 'Base Fund Class Id' ;
    rdfs:comment 'Self-referencing FK on fund_class (base_fund_class_id)' ;
    rdfs:domain ind:FundClass ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FundClass .

ind:dealingHolidayCalendarId rdf:type rdf:Property ;
    rdfs:label 'Dealing Holiday Calendar Id' ;
    rdfs:comment 'Foreign key linking to reference.holiday_calendar. Business justification: Each fund share class has a specific dealing calendar that determines valid subscription and redemption dates. The dealing_cutoff_time and dealing_frequency on fund_class are only meaningful relative ' ;
    rdfs:domain ind:FundClass ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HolidayCalendar .

ind:classCode rdf:type rdf:Property ;
    rdfs:label 'Class Code' ;
    rdfs:comment 'Short alphanumeric code identifying the share class within the fund (e.g., A, B, I, R, Institutional). Used for internal classification and operational processing.' ;
    rdfs:domain ind:FundClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:className rdf:type rdf:Property ;
    rdfs:label 'Class Name' ;
    rdfs:comment 'Full descriptive name of the share class (e.g., Institutional Class, Retail Class A, Hedged EUR Class). Human-readable identifier used in client reporting and marketing materials.' ;
    rdfs:domain ind:FundClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealingCutoffTime rdf:type rdf:Property ;
    rdfs:label 'Dealing Cutoff Time' ;
    rdfs:comment 'Time of day (HH:MM format) by which subscription and redemption orders must be received to be processed at the next available NAV. Orders received after this time are processed at the subsequent NAV.' ;
    rdfs:domain ind:FundClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:entryLoadRate rdf:type rdf:Property ;
    rdfs:label 'Entry Load Rate' ;
    rdfs:comment 'Front-end sales charge or entry fee applied when an investor subscribes to the fund class, expressed as a decimal percentage of the subscription amount. May be waived for institutional investors.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exitLoadRate rdf:type rdf:Property ;
    rdfs:label 'Exit Load Rate' ;
    rdfs:comment 'Back-end sales charge or exit fee applied when an investor redeems shares from the fund class, expressed as a decimal percentage of the redemption amount. Often used to discourage short-term trading.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fundClassStatus rdf:type rdf:Property ;
    rdfs:label 'Fund Class Status' ;
    rdfs:comment 'Current operational status of the fund class. Active classes accept subscriptions and redemptions; suspended classes are temporarily closed; closed classes no longer accept new investors; liquidated classes have been wound down.' ;
    rdfs:domain ind:FundClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hedgedFlag rdf:type rdf:Property ;
    rdfs:label 'Hedged Flag' ;
    rdfs:comment 'Indicates whether the fund class employs currency hedging to mitigate foreign exchange risk for investors. True if hedged, False if unhedged.' ;
    rdfs:domain ind:FundClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:investorEligibility rdf:type rdf:Property ;
    rdfs:label 'Investor Eligibility' ;
    rdfs:comment 'Classification of investor types eligible to invest in this share class. Determines minimum investment thresholds, fee structures, and regulatory treatment.' ;
    rdfs:domain ind:FundClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kiidUrl rdf:type rdf:Property ;
    rdfs:label 'Kiid Url' ;
    rdfs:comment 'Web address (URL) where the Key Investor Information Document (KIID) or Key Information Document (KID) can be accessed. Mandatory pre-contractual disclosure document for UCITS and PRIIPs.' ;
    rdfs:domain ind:FundClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumInitialInvestment rdf:type rdf:Property ;
    rdfs:label 'Minimum Initial Investment' ;
    rdfs:comment 'Minimum amount required for an investor to make an initial subscription into the fund class, expressed in the class currency. Used to enforce eligibility and operational thresholds.' ;
    rdfs:domain ind:FundClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ongoingChargesFigure rdf:type rdf:Property ;
    rdfs:label 'Ongoing Charges Figure' ;
    rdfs:comment 'Annual charges taken from the fund class excluding transaction costs and performance fees, expressed as a decimal percentage of AUM. Required disclosure metric under UCITS regulations.' ;
    rdfs:domain ind:FundClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sfdrClassification rdf:type rdf:Property ;
    rdfs:label 'Sfdr Classification' ;
    rdfs:comment 'Classification under EU SFDR indicating the fund class sustainability profile. Article 8 funds promote environmental or social characteristics; Article 9 funds have sustainable investment as their objective; Article 6 funds do not integrate sustainability.' ;
    rdfs:domain ind:FundClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousNavRecordId rdf:type rdf:Property ;
    rdfs:label 'Previous Nav Record Id' ;
    rdfs:comment 'Reference to the prior NAV record for this fund class, enabling time-series analysis and change tracking. Null for the first NAV record.' ;
    rdfs:domain ind:NavRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NavRecord .

ind:distributionPerUnit rdf:type rdf:Property ;
    rdfs:label 'Distribution Per Unit' ;
    rdfs:comment 'The amount of income or capital distribution declared per unit/share on this valuation date, if any. Zero if no distribution declared.' ;
    rdfs:domain ind:NavRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exDistributionDate rdf:type rdf:Property ;
    rdfs:label 'Ex Distribution Date' ;
    rdfs:comment 'The date on which the fund begins trading without the value of its next distribution payment. Investors purchasing on or after this date are not entitled to the declared distribution.' ;
    rdfs:domain ind:NavRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isAudited rdf:type rdf:Property ;
    rdfs:label 'Is Audited' ;
    rdfs:comment 'Indicates whether this NAV calculation has been subject to external audit verification. True if audited, false otherwise.' ;
    rdfs:domain ind:NavRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:navCalculationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Nav Calculation Timestamp' ;
    rdfs:comment 'The precise date and time when the NAV calculation was completed and finalized.' ;
    rdfs:domain ind:NavRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:navChangePercentage rdf:type rdf:Property ;
    rdfs:label 'Nav Change Percentage' ;
    rdfs:comment 'The percentage change in NAV per unit compared to the previous valuation date. Expressed as a percentage (e.g., 2.5000 represents 2.50%).' ;
    rdfs:domain ind:NavRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:navPublicationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Nav Publication Timestamp' ;
    rdfs:comment 'The date and time when the NAV was officially published and made available to investors and distribution channels.' ;
    rdfs:domain ind:NavRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:navStatus rdf:type rdf:Property ;
    rdfs:label 'Nav Status' ;
    rdfs:comment 'Current lifecycle status of this NAV calculation. Preliminary indicates initial calculation pending review; final indicates approved and published; restated indicates correction of previously published NAV; suspended indicates NAV calculation halted.' ;
    rdfs:domain ind:NavRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingBasis rdf:type rdf:Property ;
    rdfs:label 'Pricing Basis' ;
    rdfs:comment 'The pricing methodology used for investor transactions. Forward pricing uses the next calculated NAV after order receipt; historic pricing uses the most recent NAV; swing pricing adjusts NAV for dilution.' ;
    rdfs:domain ind:NavRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restatementReason rdf:type rdf:Property ;
    rdfs:label 'Restatement Reason' ;
    rdfs:comment 'Explanation for why this NAV was restated, if applicable. Null for original NAV calculations. Populated when nav_status is restated.' ;
    rdfs:domain ind:NavRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalRedemptions rdf:type rdf:Property ;
    rdfs:label 'Total Redemptions' ;
    rdfs:comment 'Total monetary value of investor redemptions (sales) processed and settled on this valuation date.' ;
    rdfs:domain ind:NavRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalSubscriptions rdf:type rdf:Property ;
    rdfs:label 'Total Subscriptions' ;
    rdfs:comment 'Total monetary value of new investor subscriptions (purchases) processed and settled on this valuation date.' ;
    rdfs:domain ind:NavRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketPriceCurrencyId rdf:type rdf:Property ;
    rdfs:label 'Market Price Currency Id' ;
    rdfs:comment 'Foreign key linking to reference.currency. Business justification: Holdings priced in local currencies (JPY equity, EUR bond) require FX conversion to fund base currency. Fundamental to portfolio valuation and NAV calculation.' ;
    rdfs:domain ind:FundHolding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:previousFundHoldingId rdf:type rdf:Property ;
    rdfs:label 'Previous Fund Holding Id' ;
    rdfs:comment 'Self-referencing FK on fund_holding (previous_fund_holding_id)' ;
    rdfs:domain ind:FundHolding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FundHolding .

ind:sectorIndustryCodeId rdf:type rdf:Property ;
    rdfs:label 'Sector Industry Code Id' ;
    rdfs:comment 'Foreign key linking to reference.industry_code. Business justification: Sector exposure reporting (GICS, ICB) for risk analytics, concentration monitoring, and investment mandate compliance. Essential for sector allocation analysis and style drift detection.' ;
    rdfs:domain ind:FundHolding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IndustryCode .

ind:baseCurrency rdf:type rdf:Property ;
    rdfs:label 'Base Currency' ;
    rdfs:comment 'The three-letter ISO 4217 currency code representing the fund base currency in which NAV is calculated (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterpartyLei rdf:type rdf:Property ;
    rdfs:label 'Counterparty Lei' ;
    rdfs:comment 'The 20-character ISO 17442 Legal Entity Identifier of the counterparty for derivative or collateralized transactions. Required for regulatory reporting under EMIR and Dodd-Frank.' ;
    rdfs:domain ind:FundHolding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationYears rdf:type rdf:Property ;
    rdfs:label 'Duration Years' ;
    rdfs:comment 'The modified duration or effective duration of the fixed income instrument, expressed in years. Measures the sensitivity of the instrument price to changes in interest rates. Applicable to bonds and other fixed income securities.' ;
    rdfs:domain ind:FundHolding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fairValueLevel rdf:type rdf:Property ;
    rdfs:label 'Fair Value Level' ;
    rdfs:comment 'The IFRS 13 fair value hierarchy level used to determine the market price: Level 1 (quoted prices in active markets), Level 2 (observable inputs other than quoted prices), or Level 3 (unobservable inputs).' ;
    rdfs:domain ind:FundHolding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdingStatus rdf:type rdf:Property ;
    rdfs:label 'Holding Status' ;
    rdfs:comment 'The current lifecycle status of the holding. Indicates whether the position is active, pending settlement, restricted from trading, pledged as collateral, or liquidated.' ;
    rdfs:domain ind:FundHolding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketValueBase rdf:type rdf:Property ;
    rdfs:label 'Market Value Base' ;
    rdfs:comment 'The total market value of the holding converted to the fund base currency using the FX rate at the valuation date. This is the value used in NAV calculation.' ;
    rdfs:domain ind:FundHolding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketValueLocal rdf:type rdf:Property ;
    rdfs:label 'Market Value Local' ;
    rdfs:comment 'The total market value of the holding in the local currency of the instrument, calculated as quantity held multiplied by market price.' ;
    rdfs:domain ind:FundHolding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:percentageOfNav rdf:type rdf:Property ;
    rdfs:label 'Percentage Of Nav' ;
    rdfs:comment 'The market value of this holding expressed as a percentage of the total fund NAV at the valuation date. Used for concentration risk analysis and regulatory reporting.' ;
    rdfs:domain ind:FundHolding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityHeld rdf:type rdf:Property ;
    rdfs:label 'Quantity Held' ;
    rdfs:comment 'The number of units, shares, or nominal amount of the instrument held in the fund at the valuation date. For bonds, this may represent face value; for equities, share count.' ;
    rdfs:domain ind:FundHolding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brokerBicDirectoryId rdf:type rdf:Property ;
    rdfs:label 'Broker Bic Directory Id' ;
    rdfs:comment 'Foreign key linking to reference.bic_directory. Business justification: Broker BIC for settlement instructions, SWIFT messaging, and trade confirmation matching. Critical for straight-through processing and payment routing.' ;
    rdfs:domain ind:FundTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BicDirectory .

ind:reversalFundTransactionId rdf:type rdf:Property ;
    rdfs:label 'Reversal Fund Transaction Id' ;
    rdfs:comment 'Self-referencing FK on fund_transaction (reversal_fund_transaction_id)' ;
    rdfs:domain ind:FundTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FundTransaction .

ind:settlementAccountTransactionId rdf:type rdf:Property ;
    rdfs:label 'Settlement Account Transaction Id' ;
    rdfs:comment 'Foreign key linking to account.account_transaction. Business justification: Fund subscription/redemption settlements generate deposit account debits/credits. Operations and finance teams reconcile fund_transactions to account_transactions for settlement confirmation, break re' ;
    rdfs:domain ind:FundTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccountTransaction .

ind:accountingTreatment rdf:type rdf:Property ;
    rdfs:label 'Accounting Treatment' ;
    rdfs:comment 'Classification of how the transaction is treated in fund accounting books for financial reporting purposes.' ;
    rdfs:domain ind:FundTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseCurrencyGrossAmount rdf:type rdf:Property ;
    rdfs:label 'Base Currency Gross Amount' ;
    rdfs:comment 'Gross transaction amount converted to the funds base currency using the FX rate.' ;
    rdfs:domain ind:FundTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseCurrencyNetAmount rdf:type rdf:Property ;
    rdfs:label 'Base Currency Net Amount' ;
    rdfs:comment 'Net transaction amount converted to the funds base currency using the FX rate. Used for NAV calculation.' ;
    rdfs:domain ind:FundTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:instrumentCusip rdf:type rdf:Property ;
    rdfs:label 'Instrument Cusip' ;
    rdfs:comment 'CUSIP identifier for North American securities involved in the transaction.' ;
    rdfs:domain ind:FundTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instrumentIsin rdf:type rdf:Property ;
    rdfs:label 'Instrument Isin' ;
    rdfs:comment 'International Securities Identification Number uniquely identifying the financial instrument traded in this transaction.' ;
    rdfs:domain ind:FundTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instrumentSedol rdf:type rdf:Property ;
    rdfs:label 'Instrument Sedol' ;
    rdfs:comment 'SEDOL identifier for securities traded on UK and Irish exchanges.' ;
    rdfs:domain ind:FundTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:navDate rdf:type rdf:Property ;
    rdfs:label 'Nav Date' ;
    rdfs:comment 'NAV calculation date to which this transaction contributes. Critical for daily NAV computation and investor pricing.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tradeConfirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Trade Confirmation Number' ;
    rdfs:comment 'Confirmation number received from the broker or exchange confirming the trade execution.' ;
    rdfs:domain ind:FundTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionNotes rdf:type rdf:Property ;
    rdfs:label 'Transaction Notes' ;
    rdfs:comment 'Free-text notes or comments providing additional context or explanation for the transaction.' ;
    rdfs:domain ind:FundTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openingSessionId rdf:type rdf:Property ;
    rdfs:label 'Opening Session Id' ;
    rdfs:comment 'Foreign key linking to channel.session. Business justification: Digital onboarding compliance and fraud prevention require capturing the exact session during which an investor account was opened online. Role-prefix \'opening_\' distinguishes this from any future ses' ;
    rdfs:domain ind:InvestorAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Session .

ind:taxResidencyJurisdictionId rdf:type rdf:Property ;
    rdfs:label 'Tax Residency Jurisdiction Id' ;
    rdfs:comment 'Foreign key linking to reference.jurisdiction. Business justification: CRS and FATCA regulatory reporting obligations are determined at jurisdiction level, not just country level. investor_account.crs_reportable_flag and fatca_status require the authoritative jurisdictio' ;
    rdfs:domain ind:InvestorAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Jurisdiction .

ind:accountClosureDate rdf:type rdf:Property ;
    rdfs:label 'Account Closure Date' ;
    rdfs:comment 'Date when the account was formally closed. Null for active accounts. Closed accounts retain historical data for regulatory retention periods.' ;
    rdfs:domain ind:InvestorAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accountOpeningDate rdf:type rdf:Property ;
    rdfs:label 'Account Opening Date' ;
    rdfs:comment 'Date when the investor account was first opened and activated in the transfer agency system. Marks the start of the account lifecycle.' ;
    rdfs:domain ind:InvestorAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:beneficialOwnerCount rdf:type rdf:Property ;
    rdfs:label 'Beneficial Owner Count' ;
    rdfs:comment 'Number of underlying beneficial owners represented by this account. Applicable for omnibus and nominee accounts. Null for direct retail accounts.' ;
    rdfs:domain ind:InvestorAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:distributionPreference rdf:type rdf:Property ;
    rdfs:label 'Distribution Preference' ;
    rdfs:comment 'Investor election for handling fund distributions (dividends, capital gains). Reinvest purchases additional shares; cash pays to bank account.' ;
    rdfs:domain ind:InvestorAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dormancyFlag rdf:type rdf:Property ;
    rdfs:label 'Dormancy Flag' ;
    rdfs:comment 'Indicates whether the account has been classified as dormant due to prolonged inactivity. Triggers escheatment and outreach processes.' ;
    rdfs:domain ind:InvestorAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mailingAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Mailing Address Line1' ;
    rdfs:comment 'First line of the postal mailing address for account correspondence and statements.' ;
    rdfs:domain ind:InvestorAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Mailing Address Line2' ;
    rdfs:comment 'Second line of the postal mailing address (apartment, suite, building number). Optional field.' ;
    rdfs:domain ind:InvestorAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingCity rdf:type rdf:Property ;
    rdfs:label 'Mailing City' ;
    rdfs:comment 'City or municipality component of the mailing address.' ;
    rdfs:domain ind:InvestorAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingCountry rdf:type rdf:Property ;
    rdfs:label 'Mailing Country' ;
    rdfs:comment 'Three-letter ISO country code for the mailing address. Determines postal routing and regulatory jurisdiction.' ;
    rdfs:domain ind:InvestorAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingPostalCode rdf:type rdf:Property ;
    rdfs:label 'Mailing Postal Code' ;
    rdfs:comment 'Postal or ZIP code component of the mailing address. Format varies by country.' ;
    rdfs:domain ind:InvestorAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingStateProvince rdf:type rdf:Property ;
    rdfs:label 'Mailing State Province' ;
    rdfs:comment 'State, province, or region component of the mailing address. Format varies by country.' ;
    rdfs:domain ind:InvestorAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:omnibusAccountFlag rdf:type rdf:Property ;
    rdfs:label 'Omnibus Account Flag' ;
    rdfs:comment 'Indicates whether this is an omnibus account holding positions on behalf of multiple underlying beneficial owners. True for intermediary and nominee accounts.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferredCurrency rdf:type rdf:Property ;
    rdfs:label 'Preferred Currency' ;
    rdfs:comment 'Three-letter ISO currency code for account statements, distributions, and client communications. May differ from fund base currency.' ;
    rdfs:domain ind:InvestorAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationType rdf:type rdf:Property ;
    rdfs:label 'Registration Type' ;
    rdfs:comment 'Legal structure of the account registration. Determines ownership rights, tax treatment, and beneficiary rules. [ENUM-REF-CANDIDATE: individual|joint_tenants|tenants_in_common|trust|corporate|partnership|ira|401k|ugma|utma — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictedTradingFlag rdf:type rdf:Property ;
    rdfs:label 'Restricted Trading Flag' ;
    rdfs:comment 'Indicates whether trading restrictions are in place on this account. True if the account is subject to market timing controls, redemption fees, or regulatory holds.' ;
    rdfs:domain ind:InvestorAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:restrictedTradingReason rdf:type rdf:Property ;
    rdfs:label 'Restricted Trading Reason' ;
    rdfs:comment 'Explanation for trading restrictions. Examples include excessive trading pattern detection, regulatory hold, or pending investigation.' ;
    rdfs:domain ind:InvestorAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statementDeliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Statement Delivery Method' ;
    rdfs:comment 'Investor preference for receiving account statements and confirmations. Electronic delivery reduces costs and environmental impact.' ;
    rdfs:domain ind:InvestorAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealingPriceId rdf:type rdf:Property ;
    rdfs:label 'Dealing Price Id' ;
    rdfs:comment 'Foreign key linking to security.price. Business justification: The specific price record used to calculate dealing NAV for unit allotment is a mandatory audit trail item for trade confirmation, investor statements, and regulatory reporting (UCITS/AIFMD). Role-pre' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Price .

ind:reversalSubscriptionId rdf:type rdf:Property ;
    rdfs:label 'Reversal Subscription Id' ;
    rdfs:comment 'Self-referencing FK on subscription (reversal_subscription_id)' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Subscription .

ind:amlClearanceDate rdf:type rdf:Property ;
    rdfs:label 'Aml Clearance Date' ;
    rdfs:comment 'Date when the subscription transaction received Anti-Money Laundering (AML) clearance and was approved to proceed.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:amlClearanceStatus rdf:type rdf:Property ;
    rdfs:label 'Aml Clearance Status' ;
    rdfs:comment 'Status of Anti-Money Laundering (AML) screening and clearance for this subscription transaction. Pending = screening in progress, Cleared = passed AML checks, Flagged = requires manual review, Rejected = failed AML checks and transaction blocked.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionRate rdf:type rdf:Property ;
    rdfs:label 'Commission Rate' ;
    rdfs:comment 'Percentage rate of commission payable to the intermediary or advisor on this subscription. Expressed as a decimal. May be zero for direct orders or fee-based accounts.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confirmationSentDate rdf:type rdf:Property ;
    rdfs:label 'Confirmation Sent Date' ;
    rdfs:comment 'Date when the trade confirmation was sent to the investor. Required by SEC regulations to be sent promptly after settlement.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:costBasisPerUnit rdf:type rdf:Property ;
    rdfs:label 'Cost Basis Per Unit' ;
    rdfs:comment 'Tax cost basis per unit for this subscription lot. Calculated as net_investment_amount / units_allotted. Used for future capital gains/loss calculations upon redemption.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dealingNav rdf:type rdf:Property ;
    rdfs:label 'Dealing Nav' ;
    rdfs:comment 'The Net Asset Value per unit/share applied to this subscription transaction. Determined based on the trade date and fund valuation rules (forward pricing).' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:entryLoadAmount rdf:type rdf:Property ;
    rdfs:label 'Entry Load Amount' ;
    rdfs:comment 'Dollar amount of the front-end sales load or entry fee deducted from the gross subscription amount. Calculated as gross_subscription_amount * entry_load_rate.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossSubscriptionAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Subscription Amount' ;
    rdfs:comment 'Total dollar amount of the subscription before deducting entry loads or fees. Calculated as requested_amount or (requested_units * dealing_nav).' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumInvestmentWaived rdf:type rdf:Property ;
    rdfs:label 'Minimum Investment Waived' ;
    rdfs:comment 'Indicates whether the fund minimum investment requirement was waived for this subscription (e.g., for systematic investment plans, employer-sponsored plans, or discretionary waivers).' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netInvestmentAmount rdf:type rdf:Property ;
    rdfs:label 'Net Investment Amount' ;
    rdfs:comment 'Net dollar amount actually invested in the fund after deducting entry loads and fees. Calculated as gross_subscription_amount - entry_load_amount. This is the amount used to calculate units allotted.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderMethod rdf:type rdf:Property ;
    rdfs:label 'Order Method' ;
    rdfs:comment 'Indicates whether the investor specified a dollar amount to invest or a specific number of units/shares to purchase.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedUnits rdf:type rdf:Property ;
    rdfs:label 'Requested Units' ;
    rdfs:comment 'Number of fund units or shares the investor requests to purchase. Populated when order_method is units.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceOfFunds rdf:type rdf:Property ;
    rdfs:label 'Source Of Funds' ;
    rdfs:comment 'Investor declaration or classification of the source of funds for this subscription (e.g., salary, savings, inheritance, business income, investment proceeds). Required for Anti-Money Laundering (AML) compliance and Know Your Customer (KYC) due diligence.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriptionNumber rdf:type rdf:Property ;
    rdfs:label 'Subscription Number' ;
    rdfs:comment 'Business-facing unique order number for the subscription transaction. Used for investor communication and operational tracking.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriptionStatus rdf:type rdf:Property ;
    rdfs:label 'Subscription Status' ;
    rdfs:comment 'Current lifecycle status of the subscription order. Pending = order received awaiting validation, Accepted = order validated and accepted, Processing = order being processed for settlement, Settled = units allotted and transaction complete, Cancelled = order cancelled by investor or system, Rejected = order rejected due to validation failure or compliance issue.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriptionType rdf:type rdf:Property ;
    rdfs:label 'Subscription Type' ;
    rdfs:comment 'Classification of the subscription order type. Initial = first investment in fund, Additional = subsequent investment, Systematic = recurring automatic investment, Reinvestment = dividend/capital gain reinvestment, Exchange_in = transfer from another fund.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitsAllotted rdf:type rdf:Property ;
    rdfs:label 'Units Allotted' ;
    rdfs:comment 'Number of fund units or shares allotted to the investor account as a result of this subscription. Calculated as net_investment_amount / dealing_nav.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reversalRedemptionId rdf:type rdf:Property ;
    rdfs:label 'Reversal Redemption Id' ;
    rdfs:comment 'Self-referencing FK on redemption (reversal_redemption_id)' ;
    rdfs:domain ind:Redemption ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Redemption .

ind:amlCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Aml Check Status' ;
    rdfs:comment 'Status of Anti-Money Laundering screening performed on the redemption transaction to detect suspicious activity.' ;
    rdfs:domain ind:Redemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amountRequested rdf:type rdf:Property ;
    rdfs:label 'Amount Requested' ;
    rdfs:comment 'Monetary amount requested for redemption when the investor specifies a dollar amount rather than units.' ;
    rdfs:domain ind:Redemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confirmationSentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Confirmation Sent Timestamp' ;
    rdfs:comment 'Date and time when the redemption confirmation was sent to the investor.' ;
    rdfs:domain ind:Redemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:exitLoadAmount rdf:type rdf:Property ;
    rdfs:label 'Exit Load Amount' ;
    rdfs:comment 'Monetary value of the exit load or redemption fee deducted from gross proceeds.' ;
    rdfs:domain ind:Redemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gatePercentageApplied rdf:type rdf:Property ;
    rdfs:label 'Gate Percentage Applied' ;
    rdfs:comment 'Percentage of the requested redemption that is fulfilled when a gate restriction is in effect, with the remainder deferred.' ;
    rdfs:domain ind:Redemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gateRestrictionFlag rdf:type rdf:Property ;
    rdfs:label 'Gate Restriction Flag' ;
    rdfs:comment 'Indicates whether the redemption is subject to fund-level gate restrictions limiting total redemptions in a period (True = gate applied, False = no gate).' ;
    rdfs:domain ind:Redemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:grossRedemptionProceeds rdf:type rdf:Property ;
    rdfs:label 'Gross Redemption Proceeds' ;
    rdfs:comment 'Total proceeds calculated before deducting exit loads, redemption fees, or other charges (redemption_units × dealing_nav).' ;
    rdfs:domain ind:Redemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lockInComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Lock In Compliance Flag' ;
    rdfs:comment 'Indicates whether the redemption complies with any lock-in period requirements (True = compliant, False = early redemption).' ;
    rdfs:domain ind:Redemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lockInPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Lock In Period End Date' ;
    rdfs:comment 'Date on which any mandatory lock-in or holding period for the redeemed units expires, used to validate early redemption restrictions.' ;
    rdfs:domain ind:Redemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:netRedemptionProceeds rdf:type rdf:Property ;
    rdfs:label 'Net Redemption Proceeds' ;
    rdfs:comment 'Final amount payable to the investor after deducting exit load, fees, and taxes from gross proceeds.' ;
    rdfs:domain ind:Redemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Account Number' ;
    rdfs:comment 'Bank account number or International Bank Account Number (IBAN) to which redemption proceeds are transferred.' ;
    rdfs:domain ind:Redemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentRoutingNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Routing Number' ;
    rdfs:comment 'Bank routing number, SWIFT Bank Identifier Code (BIC), or other routing identifier for the payment destination.' ;
    rdfs:domain ind:Redemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentSentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Payment Sent Timestamp' ;
    rdfs:comment 'Date and time when the redemption proceeds payment was initiated to the investor account.' ;
    rdfs:domain ind:Redemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:redemptionStatus rdf:type rdf:Property ;
    rdfs:label 'Redemption Status' ;
    rdfs:comment 'Current lifecycle status of the redemption order (pending, confirmed, settled, cancelled, rejected, suspended).' ;
    rdfs:domain ind:Redemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionType rdf:type rdf:Property ;
    rdfs:label 'Redemption Type' ;
    rdfs:comment 'Indicates whether the redemption is a full liquidation of the investor position or a partial withdrawal.' ;
    rdfs:domain ind:Redemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxWithheldAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Withheld Amount' ;
    rdfs:comment 'Amount of tax withheld at source on redemption proceeds, if applicable under jurisdiction tax rules (e.g., capital gains tax, withholding tax).' ;
    rdfs:domain ind:Redemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:units rdf:type rdf:Property ;
    rdfs:label 'Units' ;
    rdfs:comment 'Number of fund units or shares requested for redemption by the investor.' ;
    rdfs:domain ind:Redemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentAccountTransactionId rdf:type rdf:Property ;
    rdfs:label 'Payment Account Transaction Id' ;
    rdfs:comment 'Foreign key linking to account.account_transaction. Business justification: Fund distributions (dividends, income) credited to investor deposit accounts generate account_transactions. Operations reconcile distribution_events to account_transactions for payment confirmation, t' ;
    rdfs:domain ind:DistributionEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccountTransaction .

ind:paymentHolidayCalendarId rdf:type rdf:Property ;
    rdfs:label 'Payment Holiday Calendar Id' ;
    rdfs:comment 'Foreign key linking to reference.holiday_calendar. Business justification: Distribution payments made on valid business days per fund calendar. Required for payment scheduling, cash management, and investor servicing.' ;
    rdfs:domain ind:DistributionEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HolidayCalendar .

ind:reinvestmentPriceId rdf:type rdf:Property ;
    rdfs:label 'Reinvestment Price Id' ;
    rdfs:comment 'Foreign key linking to security.price. Business justification: The specific price record used for dividend reinvestment unit allotment is required for tax lot tracking, Form 1099-DIV reporting, and investor cost basis calculations. distribution_event.reinvestment' ;
    rdfs:domain ind:DistributionEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Price .

ind:reversalDistributionEventId rdf:type rdf:Property ;
    rdfs:label 'Reversal Distribution Event Id' ;
    rdfs:comment 'Self-referencing FK on distribution_event (reversal_distribution_event_id)' ;
    rdfs:domain ind:DistributionEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionEvent .

ind:declarationDate rdf:type rdf:Property ;
    rdfs:label 'Declaration Date' ;
    rdfs:comment 'Date on which the fund\'s board of directors or trustees formally declares the distribution.' ;
    rdfs:domain ind:DistributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:distributionApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Distribution Approval Date' ;
    rdfs:comment 'Date on which the distribution was formally approved by the fund\'s board of directors or trustees, or by authorized fund management under delegated authority.' ;
    rdfs:domain ind:DistributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:distributionCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Distribution Calculation Method' ;
    rdfs:comment 'Description of the methodology used to calculate the distribution amount, such as percentage of Net Asset Value (NAV), fixed rate, or based on net investment income and realized gains.' ;
    rdfs:domain ind:DistributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionNoticeDate rdf:type rdf:Property ;
    rdfs:label 'Distribution Notice Date' ;
    rdfs:comment 'Date on which the distribution notice was sent to shareholders, intermediaries, and regulatory authorities. Used to track compliance with notice requirements.' ;
    rdfs:domain ind:DistributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:distributionNumber rdf:type rdf:Property ;
    rdfs:label 'Distribution Number' ;
    rdfs:comment 'Business identifier for the distribution event, typically assigned by the fund administrator or transfer agent.' ;
    rdfs:domain ind:DistributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionRatePerUnit rdf:type rdf:Property ;
    rdfs:label 'Distribution Rate Per Unit' ;
    rdfs:comment 'Gross distribution amount per fund share or unit before any withholding taxes or adjustments.' ;
    rdfs:domain ind:DistributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:distributionSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Distribution Sequence Number' ;
    rdfs:comment 'Sequential number of the distribution within the tax year or fund fiscal year, used to track and order multiple distributions for the same fund class.' ;
    rdfs:domain ind:DistributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:distributionSourceDescription rdf:type rdf:Property ;
    rdfs:label 'Distribution Source Description' ;
    rdfs:comment 'Narrative description of the source of the distribution, such as net investment income, realized capital gains, or return of capital. Provides additional context for investor communications and regulatory disclosures.' ;
    rdfs:domain ind:DistributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionStatus rdf:type rdf:Property ;
    rdfs:label 'Distribution Status' ;
    rdfs:comment 'Current lifecycle status of the distribution event. Declared indicates the distribution has been announced. Pending approval indicates awaiting regulatory or board approval. Approved indicates ready for payment processing. Paid indicates distribution has been processed and paid to shareholders. Cancelled indicates the distribution was revoked before payment.' ;
    rdfs:domain ind:DistributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionType rdf:type rdf:Property ;
    rdfs:label 'Distribution Type' ;
    rdfs:comment 'Classification of the distribution for tax and accounting purposes. Income dividend represents ordinary income distributions from interest and dividends earned by the fund. Short-term capital gain represents gains from securities held one year or less. Long-term capital gain represents gains from securities held more than one year. Return of capital represents distributions that exceed the fund\'s earnings and profits. Qualified dividend represents dividends eligible for preferential tax treatment. Non-qualified dividend represents ordinary income dividends taxed at regular rates.' ;
    rdfs:domain ind:DistributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exDividendDate rdf:type rdf:Property ;
    rdfs:label 'Ex Dividend Date' ;
    rdfs:comment 'Date on which the fund begins trading without the distribution value. Investors purchasing shares on or after this date are not entitled to the declared distribution.' ;
    rdfs:domain ind:DistributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:foreignTaxCreditPercentage rdf:type rdf:Property ;
    rdfs:label 'Foreign Tax Credit Percentage' ;
    rdfs:comment 'Percentage of the distribution eligible for foreign tax credit pass-through to U.S. shareholders, representing foreign taxes paid by the fund on foreign-source income. Expressed as a decimal.' ;
    rdfs:domain ind:DistributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:form1099DivReportable rdf:type rdf:Property ;
    rdfs:label 'Form 1099 Div Reportable' ;
    rdfs:comment 'Indicates whether the distribution must be reported to the Internal Revenue Service (IRS) on Form 1099-DIV for U.S. tax purposes. True for most distributions to U.S. taxable investors.' ;
    rdfs:domain ind:DistributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netDistributionPerUnit rdf:type rdf:Property ;
    rdfs:label 'Net Distribution Per Unit' ;
    rdfs:comment 'Net distribution amount per share after applying default withholding tax rate. Represents the cash amount paid to investors subject to standard withholding.' ;
    rdfs:domain ind:DistributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualifiedDividendPercentage rdf:type rdf:Property ;
    rdfs:label 'Qualified Dividend Percentage' ;
    rdfs:comment 'Percentage of the distribution that qualifies for preferential tax treatment as qualified dividends under Internal Revenue Code Section 1(h)(11). Expressed as a decimal (e.g., 0.85 for 85%).' ;
    rdfs:domain ind:DistributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryFilingReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Reference' ;
    rdfs:comment 'Reference number or identifier for the regulatory filing associated with the distribution, such as Securities and Exchange Commission (SEC) Form N-CSR or Form N-PORT filing number.' ;
    rdfs:domain ind:DistributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reinvestmentNav rdf:type rdf:Property ;
    rdfs:label 'Reinvestment Nav' ;
    rdfs:comment 'Net Asset Value per share used to calculate the number of additional shares issued to investors who elect to reinvest their distribution. Typically the NAV as of the ex-dividend date or payment date per fund prospectus.' ;
    rdfs:domain ind:DistributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:section199aDividendPercentage rdf:type rdf:Property ;
    rdfs:label 'Section 199a Dividend Percentage' ;
    rdfs:comment 'Percentage of the distribution that qualifies as Section 199A dividends eligible for the qualified business income deduction. Expressed as a decimal. Applicable to Real Estate Investment Trust (REIT) and certain other fund distributions.' ;
    rdfs:domain ind:DistributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sharesOutstandingAtRecord rdf:type rdf:Property ;
    rdfs:label 'Shares Outstanding At Record' ;
    rdfs:comment 'Total number of fund shares outstanding as of the record date, used to calculate the total distribution amount and determine eligible shareholders.' ;
    rdfs:domain ind:DistributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxYear rdf:type rdf:Property ;
    rdfs:label 'Tax Year' ;
    rdfs:comment 'Calendar or fiscal tax year to which the distribution is attributed for tax reporting purposes. Typically the year in which the distribution is paid, but may differ for distributions declared in December and paid in January.' ;
    rdfs:domain ind:DistributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalDistributionAmount rdf:type rdf:Property ;
    rdfs:label 'Total Distribution Amount' ;
    rdfs:comment 'Total gross distribution amount declared for all eligible shares of the fund class, calculated as distribution rate per unit multiplied by total shares outstanding as of record date.' ;
    rdfs:domain ind:DistributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitRegisterId rdf:type rdf:Property ;
    rdfs:label 'Unit Register Id' ;
    rdfs:comment 'Unique identifier for the unit register record. Primary key for the authoritative unit/share register.' ;
    rdfs:domain ind:UnitRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:previousAssetUnitRegisterId rdf:type rdf:Property ;
    rdfs:label 'Previous Asset Unit Register Id' ;
    rdfs:comment 'Self-referencing FK on asset_unit_register (previous_asset_unit_register_id)' ;
    rdfs:domain ind:UnitRegister ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UnitRegister .

ind:averageCostPerUnit rdf:type rdf:Property ;
    rdfs:label 'Average Cost Per Unit' ;
    rdfs:comment 'Weighted average cost basis per unit calculated across all purchase transactions. Used for tax reporting and capital gains calculations.' ;
    rdfs:domain ind:UnitRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:beneficialOwnerFlag rdf:type rdf:Property ;
    rdfs:label 'Beneficial Owner Flag' ;
    rdfs:comment 'Indicates whether the registered account holder is the beneficial owner of the units. False indicates the account is held by a nominee or intermediary on behalf of underlying beneficial owners.' ;
    rdfs:domain ind:UnitRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currentNavPerUnit rdf:type rdf:Property ;
    rdfs:label 'Current Nav Per Unit' ;
    rdfs:comment 'Most recent Net Asset Value per unit for the fund class. Used to calculate current market value of the investor\'s holdings.' ;
    rdfs:domain ind:UnitRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:distributionOption rdf:type rdf:Property ;
    rdfs:label 'Distribution Option' ;
    rdfs:comment 'Investor\'s election for handling fund distributions and dividends. Reinvest automatically purchases additional units, cash pays distributions to the investor\'s bank account, partial reinvest applies a percentage to each option.' ;
    rdfs:domain ind:UnitRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escheatmentDueDate rdf:type rdf:Property ;
    rdfs:label 'Escheatment Due Date' ;
    rdfs:comment 'Date by which the position must be escheated to the appropriate state authority if the investor cannot be located. Calculated based on dormancy period and state-specific regulations.' ;
    rdfs:domain ind:UnitRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:firstInvestmentDate rdf:type rdf:Property ;
    rdfs:label 'First Investment Date' ;
    rdfs:comment 'Date of the investor\'s first purchase transaction in this fund class. Used for holding period calculations and investor tenure analysis.' ;
    rdfs:domain ind:UnitRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastTransactionType rdf:type rdf:Property ;
    rdfs:label 'Last Transaction Type' ;
    rdfs:comment 'Type of the most recent transaction that affected this position. Used for operational tracking and investor behavior analysis.' ;
    rdfs:domain ind:UnitRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordClosedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Closed Timestamp' ;
    rdfs:comment 'Timestamp when this unit register position was closed due to full redemption or account closure. Null for active positions.' ;
    rdfs:domain ind:UnitRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:registerStatus rdf:type rdf:Property ;
    rdfs:label 'Register Status' ;
    rdfs:comment 'Current status of the unit register position. Active indicates normal holdings, closed indicates fully redeemed, suspended indicates temporary restrictions, pending closure indicates redemption in progress, restricted indicates regulatory or compliance holds.' ;
    rdfs:domain ind:UnitRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictionCode rdf:type rdf:Property ;
    rdfs:label 'Restriction Code' ;
    rdfs:comment 'Code indicating any restrictions on the investor\'s ability to transact in this position. Examples include regulatory holds, legal restrictions, compliance blocks, or voluntary locks. Empty if no restrictions apply.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictionExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Restriction Expiry Date' ;
    rdfs:comment 'Date when the current restriction will automatically expire and normal transaction processing will resume. Null if restriction is indefinite or no restriction applies.' ;
    rdfs:domain ind:UnitRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:restrictionReason rdf:type rdf:Property ;
    rdfs:label 'Restriction Reason' ;
    rdfs:comment 'Detailed explanation of why the position is restricted, if applicable. Provides context for operational staff and compliance teams.' ;
    rdfs:domain ind:UnitRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalDistributionsReceived rdf:type rdf:Property ;
    rdfs:label 'Total Distributions Received' ;
    rdfs:comment 'Cumulative amount of all distributions (dividends, capital gains, return of capital) received by the investor since first investment. Used for tax reporting and investor statements.' ;
    rdfs:domain ind:UnitRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDistributionsReinvested rdf:type rdf:Property ;
    rdfs:label 'Total Distributions Reinvested' ;
    rdfs:comment 'Cumulative amount of distributions that were reinvested to purchase additional units. Subset of total distributions received.' ;
    rdfs:domain ind:UnitRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitsHeld rdf:type rdf:Property ;
    rdfs:label 'Units Held' ;
    rdfs:comment 'Current number of fund units or shares held by the investor in this fund class. Represents the investor\'s ownership stake and is used to calculate distributions and redemption proceeds.' ;
    rdfs:domain ind:UnitRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unrealizedGainLossPercentage rdf:type rdf:Property ;
    rdfs:label 'Unrealized Gain Loss Percentage' ;
    rdfs:comment 'Unrealized gain or loss expressed as a percentage of the total cost basis. Calculated as (unrealized gain/loss / total cost basis) * 100.' ;
    rdfs:domain ind:UnitRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:previousFundMandateId rdf:type rdf:Property ;
    rdfs:label 'Previous Fund Mandate Id' ;
    rdfs:comment 'Self-referencing FK on fund_mandate (previous_fund_mandate_id)' ;
    rdfs:domain ind:FundMandate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FundMandate .

ind:primaryFundPartyId rdf:type rdf:Property ;
    rdfs:label 'Primary Fund Party Id' ;
    rdfs:comment 'Reference to the investment manager or portfolio manager responsible for executing the mandate.' ;
    rdfs:domain ind:FundMandate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:breachTolerancePolicy rdf:type rdf:Property ;
    rdfs:label 'Breach Tolerance Policy' ;
    rdfs:comment 'Policy describing acceptable tolerance levels for temporary breaches of mandate restrictions and required remediation actions.' ;
    rdfs:domain ind:FundMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceMonitoringFrequency rdf:type rdf:Property ;
    rdfs:label 'Compliance Monitoring Frequency' ;
    rdfs:comment 'Frequency at which portfolio holdings are monitored for compliance with mandate restrictions.' ;
    rdfs:domain ind:FundMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditQualityMinimum rdf:type rdf:Property ;
    rdfs:label 'Credit Quality Minimum' ;
    rdfs:comment 'Minimum credit rating required for fixed income investments (e.g., investment grade, BBB- or higher). [ENUM-REF-CANDIDATE: AAA|AA|A|BBB|BB|B|CCC|investment_grade|non_investment_grade — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FundMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currencyHedgingPolicy rdf:type rdf:Property ;
    rdfs:label 'Currency Hedging Policy' ;
    rdfs:comment 'Policy regarding foreign exchange risk management (e.g., fully hedged, partially hedged, unhedged, discretionary).' ;
    rdfs:domain ind:FundMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:derivativeUsagePolicy rdf:type rdf:Property ;
    rdfs:label 'Derivative Usage Policy' ;
    rdfs:comment 'Policy governing the use of derivative instruments (e.g., prohibited, hedging only, efficient portfolio management, speculative trading allowed).' ;
    rdfs:domain ind:FundMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentReference rdf:type rdf:Property ;
    rdfs:label 'Document Reference' ;
    rdfs:comment 'Reference identifier or file path to the formal mandate document or Investment Policy Statement (IPS).' ;
    rdfs:domain ind:FundMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationRangeMaxYears rdf:type rdf:Property ;
    rdfs:label 'Duration Range Max Years' ;
    rdfs:comment 'Maximum portfolio duration in years for fixed income holdings to manage interest rate risk.' ;
    rdfs:domain ind:FundMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:durationRangeMinYears rdf:type rdf:Property ;
    rdfs:label 'Duration Range Min Years' ;
    rdfs:comment 'Minimum portfolio duration in years for fixed income holdings to manage interest rate risk.' ;
    rdfs:domain ind:FundMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:esgConstraints rdf:type rdf:Property ;
    rdfs:label 'Esg Constraints' ;
    rdfs:comment 'Environmental, Social, and Governance criteria or exclusions applied to the investment universe (e.g., exclude tobacco, weapons, fossil fuels; require minimum ESG rating).' ;
    rdfs:domain ind:FundMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:highWaterMarkApplicable rdf:type rdf:Property ;
    rdfs:label 'High Water Mark Applicable' ;
    rdfs:comment 'Indicates whether a high water mark mechanism is used for performance fee calculation to ensure fees are only charged on net new profits.' ;
    rdfs:domain ind:FundMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuerConcentrationLimitPct rdf:type rdf:Property ;
    rdfs:label 'Issuer Concentration Limit Pct' ;
    rdfs:comment 'Maximum percentage of fund assets that can be invested in securities of a single issuer to mitigate concentration risk.' ;
    rdfs:domain ind:FundMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leverageLimitPct rdf:type rdf:Property ;
    rdfs:label 'Leverage Limit Pct' ;
    rdfs:comment 'Maximum leverage ratio expressed as a percentage of Net Asset Value (NAV) that the fund is permitted to employ.' ;
    rdfs:domain ind:FundMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:liquidityRequirementPct rdf:type rdf:Property ;
    rdfs:label 'Liquidity Requirement Pct' ;
    rdfs:comment 'Minimum percentage of fund assets that must be held in liquid instruments to meet redemption requests and operational needs.' ;
    rdfs:domain ind:FundMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mandateCode rdf:type rdf:Property ;
    rdfs:label 'Mandate Code' ;
    rdfs:comment 'Unique business identifier or code for the mandate used in operational systems and regulatory reporting.' ;
    rdfs:domain ind:FundMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceFeeApplicable rdf:type rdf:Property ;
    rdfs:label 'Performance Fee Applicable' ;
    rdfs:comment 'Indicates whether a performance-based fee structure is applicable to this mandate.' ;
    rdfs:domain ind:FundMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:permittedAssetClasses rdf:type rdf:Property ;
    rdfs:label 'Permitted Asset Classes' ;
    rdfs:comment 'Comma-separated list of asset classes the fund is authorized to invest in (e.g., equities, fixed income, commodities, real estate, derivatives, cash equivalents).' ;
    rdfs:domain ind:FundMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prohibitedAssetClasses rdf:type rdf:Property ;
    rdfs:label 'Prohibited Asset Classes' ;
    rdfs:comment 'Comma-separated list of asset classes explicitly excluded from the investment universe.' ;
    rdfs:domain ind:FundMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sectorLimits rdf:type rdf:Property ;
    rdfs:label 'Sector Limits' ;
    rdfs:comment 'Maximum exposure limits by industry sector (e.g., technology max 25%, financials max 20%) to ensure diversification.' ;
    rdfs:domain ind:FundMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sriConstraints rdf:type rdf:Property ;
    rdfs:label 'Sri Constraints' ;
    rdfs:comment 'Socially responsible investment criteria or ethical screening rules applied to portfolio construction.' ;
    rdfs:domain ind:FundMandate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investmentRestrictionId rdf:type rdf:Property ;
    rdfs:label 'Investment Restriction Id' ;
    rdfs:comment 'Unique identifier for the investment restriction rule record.' ;
    rdfs:domain ind:InvestmentRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primarySupersededByRestrictionInvestmentRestrictionId rdf:type rdf:Property ;
    rdfs:label 'Primary Superseded By Restriction Investment Restriction Id' ;
    rdfs:comment 'Identifier of the restriction rule that supersedes this one. Null if this is the current version.' ;
    rdfs:domain ind:InvestmentRestriction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InvestmentRestriction .

ind:breachDate rdf:type rdf:Property ;
    rdfs:label 'Breach Date' ;
    rdfs:comment 'Date on which the restriction was breached. Null if no breach has occurred.' ;
    rdfs:domain ind:InvestmentRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:breachMagnitude rdf:type rdf:Property ;
    rdfs:label 'Breach Magnitude' ;
    rdfs:comment 'Magnitude of the breach expressed in the same unit as the threshold (e.g., 2.50 for 2.5% over limit). Null if compliant.' ;
    rdfs:domain ind:InvestmentRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:breachTimestamp rdf:type rdf:Property ;
    rdfs:label 'Breach Timestamp' ;
    rdfs:comment 'Precise timestamp when the breach was detected, supporting intraday and real-time monitoring.' ;
    rdfs:domain ind:InvestmentRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:breachTolerance rdf:type rdf:Property ;
    rdfs:label 'Breach Tolerance' ;
    rdfs:comment 'Allowable tolerance or buffer before a breach is triggered (e.g., 0.50 for 0.5% tolerance above threshold).' ;
    rdfs:domain ind:InvestmentRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:checkTiming rdf:type rdf:Property ;
    rdfs:label 'Check Timing' ;
    rdfs:comment 'Indicates whether the restriction is enforced pre-trade (before execution), post-trade (after settlement), or both.' ;
    rdfs:domain ind:InvestmentRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enforcementAction rdf:type rdf:Property ;
    rdfs:label 'Enforcement Action' ;
    rdfs:comment 'Action taken when a breach is detected: block (prevent trade), alert (notify), escalate (senior approval), override required, or auto-remediate.' ;
    rdfs:domain ind:InvestmentRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastCheckTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Check Timestamp' ;
    rdfs:comment 'Timestamp of the most recent compliance check performed for this restriction.' ;
    rdfs:domain ind:InvestmentRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:nextCheckTimestamp rdf:type rdf:Property ;
    rdfs:label 'Next Check Timestamp' ;
    rdfs:comment 'Scheduled timestamp for the next compliance check based on monitoring frequency.' ;
    rdfs:domain ind:InvestmentRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:overrideAllowed rdf:type rdf:Property ;
    rdfs:label 'Override Allowed' ;
    rdfs:comment 'Indicates whether manual override of the restriction is permitted under defined circumstances (true/false).' ;
    rdfs:domain ind:InvestmentRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overrideAuthorityLevel rdf:type rdf:Property ;
    rdfs:label 'Override Authority Level' ;
    rdfs:comment 'Minimum authority level required to approve an override: none, portfolio manager, head of risk, CIO (Chief Investment Officer), board, or regulator.' ;
    rdfs:domain ind:InvestmentRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationDeadline rdf:type rdf:Property ;
    rdfs:label 'Remediation Deadline' ;
    rdfs:comment 'Date by which a breach must be remediated to restore compliance. Null if no breach or no deadline applies.' ;
    rdfs:domain ind:InvestmentRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:restrictionCategory rdf:type rdf:Property ;
    rdfs:label 'Restriction Category' ;
    rdfs:comment 'Business category of the restriction: concentration, liquidity, leverage, counterparty exposure, asset class, geography, sector, issuer, credit rating, or maturity. [ENUM-REF-CANDIDATE: concentration|liquidity|leverage|counterparty|asset_class|geography|sector|issuer|rating|maturity — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InvestmentRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictionName rdf:type rdf:Property ;
    rdfs:label 'Restriction Name' ;
    rdfs:comment 'Human-readable name of the investment restriction rule.' ;
    rdfs:domain ind:InvestmentRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictionStatus rdf:type rdf:Property ;
    rdfs:label 'Restriction Status' ;
    rdfs:comment 'Lifecycle status of the restriction rule: active (in force), suspended (temporarily inactive), expired, superseded (replaced by newer rule), or draft (not yet effective).' ;
    rdfs:domain ind:InvestmentRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictionType rdf:type rdf:Property ;
    rdfs:label 'Restriction Type' ;
    rdfs:comment 'Classification of the restriction source: regulatory (UCITS, AIFMD), mandate (prospectus), internal (risk policy), contractual (IMA), statutory (local law), or risk limit (VaR, concentration).' ;
    rdfs:domain ind:InvestmentRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beginningNavRecordId rdf:type rdf:Property ;
    rdfs:label 'Beginning Nav Record Id' ;
    rdfs:comment 'Foreign key linking to asset.nav_record. Business justification: Fund performance is calculated between two NAV points. beginning_nav_record_id links to the nav_record representing the start-of-period NAV used in TWR/MWR calculations. This creates a direct audit tr' ;
    rdfs:domain ind:FundPerformance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NavRecord .

ind:navCurrencyId rdf:type rdf:Property ;
    rdfs:label 'Nav Currency Id' ;
    rdfs:comment 'Foreign key linking to reference.currency. Business justification: Performance metrics currency denomination for return calculation and peer comparison. Essential for GIPS compliance and performance attribution.' ;
    rdfs:domain ind:FundPerformance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:previousFundPerformanceId rdf:type rdf:Property ;
    rdfs:label 'Previous Fund Performance Id' ;
    rdfs:comment 'Self-referencing FK on fund_performance (previous_fund_performance_id)' ;
    rdfs:domain ind:FundPerformance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FundPerformance .

ind:riskFreeRateBenchmarkId rdf:type rdf:Property ;
    rdfs:label 'Risk Free Rate Benchmark Id' ;
    rdfs:comment 'Foreign key linking to reference.rate_benchmark. Business justification: Sharpe ratio, Sortino ratio, and GIPS-compliant performance reporting require identifying the specific risk-free rate benchmark used (e.g., SOFR, Fed Funds). risk_free_rate_pct is a denormalized value' ;
    rdfs:domain ind:FundPerformance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RateBenchmark .

ind:activeReturnPct rdf:type rdf:Property ;
    rdfs:label 'Active Return Pct' ;
    rdfs:comment 'Excess return of the fund relative to the benchmark (fund return minus benchmark return), also known as alpha. Measures the value added by active management.' ;
    rdfs:domain ind:FundPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageAum rdf:type rdf:Property ;
    rdfs:label 'Average Aum' ;
    rdfs:comment 'Average total net assets of the fund during the performance period, used for expense ratio and turnover calculations.' ;
    rdfs:domain ind:FundPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:beginningNav rdf:type rdf:Property ;
    rdfs:label 'Beginning Nav' ;
    rdfs:comment 'Net Asset Value per share at the start of the performance period.' ;
    rdfs:domain ind:FundPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:benchmarkReturnPct rdf:type rdf:Property ;
    rdfs:label 'Benchmark Return Pct' ;
    rdfs:comment 'Return of the benchmark index over the same performance period, expressed as a percentage.' ;
    rdfs:domain ind:FundPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:beta rdf:type rdf:Property ;
    rdfs:label 'Beta' ;
    rdfs:comment 'Measure of the fund\'s sensitivity to benchmark movements. Beta of 1.0 indicates the fund moves in line with the benchmark; >1.0 indicates higher volatility; <1.0 indicates lower volatility.' ;
    rdfs:domain ind:FundPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capitalAppreciationPct rdf:type rdf:Property ;
    rdfs:label 'Capital Appreciation Pct' ;
    rdfs:comment 'Portion of total return attributable to capital gains (price appreciation), expressed as a percentage.' ;
    rdfs:domain ind:FundPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:endingNav rdf:type rdf:Property ;
    rdfs:label 'Ending Nav' ;
    rdfs:comment 'Net Asset Value per share at the end of the performance period.' ;
    rdfs:domain ind:FundPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expenseRatioPct rdf:type rdf:Property ;
    rdfs:label 'Expense Ratio Pct' ;
    rdfs:comment 'Total annual operating expenses as a percentage of average net assets during the performance period. Includes management fees, administrative costs, and other fund expenses.' ;
    rdfs:domain ind:FundPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incomeReturnPct rdf:type rdf:Property ;
    rdfs:label 'Income Return Pct' ;
    rdfs:comment 'Portion of total return attributable to income (dividends, interest, distributions), expressed as a percentage.' ;
    rdfs:domain ind:FundPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumDrawdownPct rdf:type rdf:Property ;
    rdfs:label 'Maximum Drawdown Pct' ;
    rdfs:comment 'Largest peak-to-trough decline in fund value during the performance period, expressed as a percentage. Measures downside risk and worst-case loss scenario.' ;
    rdfs:domain ind:FundPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mwrReturnPct rdf:type rdf:Property ;
    rdfs:label 'Mwr Return Pct' ;
    rdfs:comment 'Money-weighted return (also known as Internal Rate of Return or IRR) that accounts for the timing and magnitude of cash flows. Reflects the actual investor experience including contribution and withdrawal timing effects.' ;
    rdfs:domain ind:FundPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:numberOfHoldings rdf:type rdf:Property ;
    rdfs:label 'Number Of Holdings' ;
    rdfs:comment 'Total count of distinct securities held in the fund portfolio at the end of the performance period.' ;
    rdfs:domain ind:FundPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:performanceAttributionAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Performance Attribution Available Flag' ;
    rdfs:comment 'Indicates whether detailed performance attribution analysis (sector allocation, security selection effects) is available for this performance record.' ;
    rdfs:domain ind:FundPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:performanceEndDate rdf:type rdf:Property ;
    rdfs:label 'Performance End Date' ;
    rdfs:comment 'End date of the performance measurement period.' ;
    rdfs:domain ind:FundPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:performancePeriodType rdf:type rdf:Property ;
    rdfs:label 'Performance Period Type' ;
    rdfs:comment 'Standard reporting period for the performance calculation. ITD = Inception-to-Date (since inception). [ENUM-REF-CANDIDATE: 1M|3M|6M|YTD|1Y|3Y|5Y|ITD — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FundPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceStartDate rdf:type rdf:Property ;
    rdfs:label 'Performance Start Date' ;
    rdfs:comment 'Start date of the performance measurement period.' ;
    rdfs:domain ind:FundPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:performanceStatus rdf:type rdf:Property ;
    rdfs:label 'Performance Status' ;
    rdfs:comment 'Current status of the performance record in its lifecycle: preliminary (initial calculation), final (confirmed), restated (corrected after finalization), audited (verified by external auditor).' ;
    rdfs:domain ind:FundPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rSquared rdf:type rdf:Property ;
    rdfs:label 'R Squared' ;
    rdfs:comment 'Statistical measure (0 to 1) indicating how much of the fund\'s movements can be explained by benchmark movements. Higher values indicate greater correlation with the benchmark.' ;
    rdfs:domain ind:FundPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalReturnAmount rdf:type rdf:Property ;
    rdfs:label 'Total Return Amount' ;
    rdfs:comment 'Absolute dollar amount of return generated during the performance period, calculated as ending NAV minus beginning NAV plus distributions.' ;
    rdfs:domain ind:FundPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trackingErrorPct rdf:type rdf:Property ;
    rdfs:label 'Tracking Error Pct' ;
    rdfs:comment 'Standard deviation of the difference between fund returns and benchmark returns, expressed as a percentage. Measures the consistency of active return.' ;
    rdfs:domain ind:FundPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:turnoverRatioPct rdf:type rdf:Property ;
    rdfs:label 'Turnover Ratio Pct' ;
    rdfs:comment 'Measure of how frequently assets within the fund are bought and sold, expressed as a percentage of average net assets. Higher turnover may indicate more active trading.' ;
    rdfs:domain ind:FundPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:twrGrossReturnPct rdf:type rdf:Property ;
    rdfs:label 'Twr Gross Return Pct' ;
    rdfs:comment 'Time-weighted return before deduction of fees, expressed as a percentage. TWR eliminates the effect of cash flows and measures the compound growth rate of the portfolio.' ;
    rdfs:domain ind:FundPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:twrNetReturnPct rdf:type rdf:Property ;
    rdfs:label 'Twr Net Return Pct' ;
    rdfs:comment 'Time-weighted return after deduction of all fees and expenses, expressed as a percentage. This is the return actually realized by investors.' ;
    rdfs:domain ind:FundPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volatilityPct rdf:type rdf:Property ;
    rdfs:label 'Volatility Pct' ;
    rdfs:comment 'Annualized standard deviation of fund returns over the performance period, expressed as a percentage. Measures total risk and return variability.' ;
    rdfs:domain ind:FundPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentPaymentChannelId rdf:type rdf:Property ;
    rdfs:label 'Parent Payment Channel Id' ;
    rdfs:comment 'Self-referencing FK on payment_channel (parent_payment_channel_id)' ;
    rdfs:domain ind:PaymentChannel ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentChannel .

ind:primaryCurrencyId rdf:type rdf:Property ;
    rdfs:label 'Primary Currency Id' ;
    rdfs:comment 'Foreign key linking to reference.currency. Business justification: Payment channels optimized for specific currency (e.g., SEPA for EUR, CHAPS for GBP). Currency master provides settlement cycle, cutoff times, and liquidity requirements for channel capacity planning ' ;
    rdfs:domain ind:PaymentChannel ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:amlScreeningRequired rdf:type rdf:Property ;
    rdfs:label 'Aml Screening Required' ;
    rdfs:comment 'Indicates whether payments through this channel must undergo mandatory Anti-Money Laundering screening before processing.' ;
    rdfs:domain ind:PaymentChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:batchProcessingSupported rdf:type rdf:Property ;
    rdfs:label 'Batch Processing Supported' ;
    rdfs:comment 'Indicates whether the payment channel supports batch file submission for multiple payment instructions in a single transmission.' ;
    rdfs:domain ind:PaymentChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:chargeBearerDefault rdf:type rdf:Property ;
    rdfs:label 'Charge Bearer Default' ;
    rdfs:comment 'Default charge bearer code for the channel indicating who pays transaction fees: OUR (originator pays all), BEN (beneficiary pays all), SHA (shared between parties).' ;
    rdfs:domain ind:PaymentChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingHouseIdentifier rdf:type rdf:Property ;
    rdfs:label 'Clearing House Identifier' ;
    rdfs:comment 'Unique identifier for the clearing house or settlement system associated with this payment channel (e.g., FedACH, CHIPS, CLS).' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossBorderEnabled rdf:type rdf:Property ;
    rdfs:label 'Cross Border Enabled' ;
    rdfs:comment 'Indicates whether the payment channel supports cross-border international payments (True) or is limited to domestic transactions (False).' ;
    rdfs:domain ind:PaymentChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cutoffTime rdf:type rdf:Property ;
    rdfs:label 'Cutoff Time' ;
    rdfs:comment 'Daily deadline for submitting payments to be included in the current settlement cycle, expressed in HH:MM format in the operating timezone.' ;
    rdfs:domain ind:PaymentChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:intermediaryBankAllowed rdf:type rdf:Property ;
    rdfs:label 'Intermediary Bank Allowed' ;
    rdfs:comment 'Indicates whether the payment channel supports routing through intermediary correspondent banks for indirect settlement.' ;
    rdfs:domain ind:PaymentChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maximumTransactionAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Transaction Amount' ;
    rdfs:comment 'The maximum payment amount that can be processed through this channel in a single transaction, expressed in the primary currency.' ;
    rdfs:domain ind:PaymentChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumTransactionAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Transaction Amount' ;
    rdfs:comment 'The minimum payment amount that can be processed through this channel, expressed in the primary currency.' ;
    rdfs:domain ind:PaymentChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:networkOperator rdf:type rdf:Property ;
    rdfs:label 'Network Operator' ;
    rdfs:comment 'The organization or entity that operates and governs the payment network or rail (e.g., Federal Reserve, SWIFT, The Clearing House, NACHA, Visa, Mastercard).' ;
    rdfs:domain ind:PaymentChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nostroAccountRequired rdf:type rdf:Property ;
    rdfs:label 'Nostro Account Required' ;
    rdfs:comment 'Indicates whether payments through this channel require the use of nostro accounts (our account held at correspondent banks) for settlement.' ;
    rdfs:domain ind:PaymentChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operatingHoursEnd rdf:type rdf:Property ;
    rdfs:label 'Operating Hours End' ;
    rdfs:comment 'Daily end time when the payment channel closes for transaction submission, expressed in HH:MM format in the channels operating timezone.' ;
    rdfs:domain ind:PaymentChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingHoursStart rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Start' ;
    rdfs:comment 'Daily start time when the payment channel opens for transaction submission, expressed in HH:MM format in the channels operating timezone.' ;
    rdfs:domain ind:PaymentChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingTimezone rdf:type rdf:Property ;
    rdfs:label 'Operating Timezone' ;
    rdfs:comment 'Timezone in which the payment channel operates and cutoff times are defined (e.g., EST, UTC, CET).' ;
    rdfs:domain ind:PaymentChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityLevelsSupported rdf:type rdf:Property ;
    rdfs:label 'Priority Levels Supported' ;
    rdfs:comment 'Comma-separated list of payment priority levels supported by this channel (e.g., normal, urgent, high, express) for expedited processing.' ;
    rdfs:domain ind:PaymentChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnWindowDays rdf:type rdf:Property ;
    rdfs:label 'Return Window Days' ;
    rdfs:comment 'The number of business days within which a payment processed through this channel can be returned or reversed by the receiving institution.' ;
    rdfs:domain ind:PaymentChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sanctionsScreeningRequired rdf:type rdf:Property ;
    rdfs:label 'Sanctions Screening Required' ;
    rdfs:comment 'Indicates whether payments through this channel must undergo mandatory sanctions screening against OFAC and other watchlists before processing.' ;
    rdfs:domain ind:PaymentChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:settlementModel rdf:type rdf:Property ;
    rdfs:label 'Settlement Model' ;
    rdfs:comment 'Settlement methodology used by the channel: gross settlement (transaction-by-transaction) or net settlement (aggregated positions).' ;
    rdfs:domain ind:PaymentChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Standard Fee Amount' ;
    rdfs:comment 'The standard per-transaction fee charged for processing payments through this channel, expressed in the primary currency.' ;
    rdfs:domain ind:PaymentChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vostroAccountRequired rdf:type rdf:Property ;
    rdfs:label 'Vostro Account Required' ;
    rdfs:comment 'Indicates whether payments through this channel require the use of vostro accounts (their account held at our bank) for settlement.' ;
    rdfs:domain ind:PaymentChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reconciliationId rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Id' ;
    rdfs:comment 'Unique identifier for the payment reconciliation record. Primary key for the payment reconciliation entity.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Reconciliation .

ind:previousReconciliationId rdf:type rdf:Property ;
    rdfs:label 'Previous Reconciliation Id' ;
    rdfs:comment 'Self-referencing FK on reconciliation (previous_reconciliation_id)' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Reconciliation .

ind:reconciliationNostroAccountId rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Nostro Account Id' ;
    rdfs:comment 'Identifier for the nostro account (our account held at a correspondent bank) involved in the reconciliation, if applicable.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NostroAccount .

ind:reconciliationVostroAccountNostroAccountId rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Vostro Account Nostro Account Id' ;
    rdfs:comment 'Identifier for the vostro account (their account held at our bank) involved in the reconciliation, if applicable.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NostroAccount .

ind:breakItemCount rdf:type rdf:Property ;
    rdfs:label 'Break Item Count' ;
    rdfs:comment 'The total number of reconciliation break items identified, including discrepancies in amounts, dates, or missing transactions.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cardNetworkName rdf:type rdf:Property ;
    rdfs:label 'Card Network Name' ;
    rdfs:comment 'The name of the card network providing settlement files for card transaction reconciliation.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionCount rdf:type rdf:Property ;
    rdfs:label 'Exception Count' ;
    rdfs:comment 'The number of exceptions or anomalies identified during the reconciliation process that require investigation or resolution.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:externalStatementReference rdf:type rdf:Property ;
    rdfs:label 'External Statement Reference' ;
    rdfs:comment 'The reference number or identifier of the external statement, confirmation file, or settlement report being reconciled.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchedAmount rdf:type rdf:Property ;
    rdfs:label 'Matched Amount' ;
    rdfs:comment 'The aggregate monetary value of payments that were successfully matched between internal and external records.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:matchedPaymentCount rdf:type rdf:Property ;
    rdfs:label 'Matched Payment Count' ;
    rdfs:comment 'The number of payment transactions that were successfully matched between internal records and external confirmations.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:matchingRuleSet rdf:type rdf:Property ;
    rdfs:label 'Matching Rule Set' ;
    rdfs:comment 'The identifier or name of the rule set or algorithm used to match internal payment records with external confirmations.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationMethod rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Method' ;
    rdfs:comment 'The method used to perform the reconciliation, indicating the level of automation versus manual intervention.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Timestamp' ;
    rdfs:comment 'The precise date and time when the reconciliation process was executed.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reconciliationType rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Type' ;
    rdfs:comment 'The category of reconciliation being performed, indicating the source of external records being matched against internal payment records.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaActualHours rdf:type rdf:Property ;
    rdfs:label 'Sla Actual Hours' ;
    rdfs:comment 'The actual number of hours taken to complete the reconciliation process from initiation to resolution.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaTargetHours rdf:type rdf:Property ;
    rdfs:label 'Sla Target Hours' ;
    rdfs:comment 'The target number of hours within which the reconciliation process should be completed according to service level agreements.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:toleranceThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Tolerance Threshold Amount' ;
    rdfs:comment 'The maximum acceptable variance in monetary amounts for a match to be considered successful during reconciliation.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPaymentCount rdf:type rdf:Property ;
    rdfs:label 'Total Payment Count' ;
    rdfs:comment 'The total number of payment transactions included in the reconciliation scope.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalReconciledAmount rdf:type rdf:Property ;
    rdfs:label 'Total Reconciled Amount' ;
    rdfs:comment 'The aggregate monetary value of all payments included in the reconciliation scope.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unmatchedPaymentCount rdf:type rdf:Property ;
    rdfs:label 'Unmatched Payment Count' ;
    rdfs:comment 'The number of payment transactions that could not be matched between internal records and external confirmations, representing reconciliation breaks.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountHolderId rdf:type rdf:Property ;
    rdfs:label 'Account Holder Id' ;
    rdfs:comment 'Unique identifier for this account holder relationship record. Primary key for the association.' ;
    rdfs:domain ind:AccountHolder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:issuingBranchId rdf:type rdf:Property ;
    rdfs:label 'Issuing Branch Id' ;
    rdfs:comment 'Foreign key linking to channel.branch. Business justification: Cards are issued at specific branches. Issuing branch is tracked for branch performance reporting, card issuance audits, and customer service routing. card.issuing_branch_code is a denormalized text f' ;
    rdfs:domain ind:Card ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Branch .

ind:parentCardId rdf:type rdf:Property ;
    rdfs:label 'Parent Card Id' ;
    rdfs:comment 'Self-referencing FK on card (parent_card_id)' ;
    rdfs:domain ind:Card ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Card .

ind:primaryPreviousCardId rdf:type rdf:Property ;
    rdfs:label 'Primary Previous Card Id' ;
    rdfs:comment 'Reference to the card that this card replaced, establishing card lineage and history.' ;
    rdfs:domain ind:Card ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Card .

ind:atmWithdrawalEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Atm Withdrawal Enabled Flag' ;
    rdfs:comment 'Indicates whether the card is enabled for cash withdrawals at ATMs.' ;
    rdfs:domain ind:Card ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:binNumber rdf:type rdf:Property ;
    rdfs:label 'Bin Number' ;
    rdfs:comment 'The first six digits of the card number identifying the issuing institution and card type. Also known as Issuer Identification Number (IIN).' ;
    rdfs:domain ind:Card ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brand rdf:type rdf:Property ;
    rdfs:label 'Brand' ;
    rdfs:comment 'The payment network brand associated with the card, determining routing and acceptance.' ;
    rdfs:domain ind:Card ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardNumber rdf:type rdf:Property ;
    rdfs:label 'Card Number' ;
    rdfs:comment 'The 16-digit primary account number (PAN) embossed on the card. Uniquely identifies the card for payment processing.' ;
    rdfs:domain ind:Card ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardStatus rdf:type rdf:Property ;
    rdfs:label 'Card Status' ;
    rdfs:comment 'Current lifecycle status of the card indicating its operational state and usability for transactions.' ;
    rdfs:domain ind:Card ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardholderName rdf:type rdf:Property ;
    rdfs:label 'Cardholder Name' ;
    rdfs:comment 'The name of the individual or entity to whom the card is issued, as embossed on the card.' ;
    rdfs:domain ind:Card ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chipEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Chip Enabled Flag' ;
    rdfs:comment 'Indicates whether the card is equipped with an EMV chip for secure chip-and-PIN or chip-and-signature transactions.' ;
    rdfs:domain ind:Card ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contactlessEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Contactless Enabled Flag' ;
    rdfs:comment 'Indicates whether the card supports contactless (NFC) payment transactions.' ;
    rdfs:domain ind:Card ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cvvHash rdf:type rdf:Property ;
    rdfs:label 'Cvv Hash' ;
    rdfs:comment 'Hashed representation of the card verification value used for card-not-present transactions. Actual CVV is never stored per PCI DSS.' ;
    rdfs:domain ind:Card ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryAddress rdf:type rdf:Property ;
    rdfs:label 'Delivery Address' ;
    rdfs:comment 'The address to which the physical card was delivered or is registered for delivery.' ;
    rdfs:domain ind:Card ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Delivery Method' ;
    rdfs:comment 'The method by which the physical or digital card was delivered to the cardholder.' ;
    rdfs:domain ind:Card ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designCode rdf:type rdf:Property ;
    rdfs:label 'Design Code' ;
    rdfs:comment 'Code identifying the visual design or theme applied to the physical card (e.g., standard, premium, custom image).' ;
    rdfs:domain ind:Card ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:embossingName rdf:type rdf:Property ;
    rdfs:label 'Embossing Name' ;
    rdfs:comment 'The name physically embossed or printed on the card, which may differ slightly from the legal cardholder name for display purposes.' ;
    rdfs:domain ind:Card ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudAlertFlag rdf:type rdf:Property ;
    rdfs:label 'Fraud Alert Flag' ;
    rdfs:comment 'Indicates whether the card has been flagged for potential fraudulent activity and is under enhanced monitoring.' ;
    rdfs:domain ind:Card ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:internationalUsageEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'International Usage Enabled Flag' ;
    rdfs:comment 'Indicates whether the card is enabled for international transactions outside the issuing country.' ;
    rdfs:domain ind:Card ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:onlineTransactionEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Online Transaction Enabled Flag' ;
    rdfs:comment 'Indicates whether the card is enabled for online and e-commerce transactions.' ;
    rdfs:domain ind:Card ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pinSetFlag rdf:type rdf:Property ;
    rdfs:label 'Pin Set Flag' ;
    rdfs:comment 'Indicates whether a PIN has been set for this card, enabling ATM and point-of-sale transactions requiring PIN authentication.' ;
    rdfs:domain ind:Card ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:posTransactionEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Pos Transaction Enabled Flag' ;
    rdfs:comment 'Indicates whether the card is enabled for point-of-sale merchant transactions.' ;
    rdfs:domain ind:Card ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reissueReasonCode rdf:type rdf:Property ;
    rdfs:label 'Reissue Reason Code' ;
    rdfs:comment 'Code indicating the reason why the card was reissued or replaced.' ;
    rdfs:domain ind:Card ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tokenProvisionedFlag rdf:type rdf:Property ;
    rdfs:label 'Token Provisioned Flag' ;
    rdfs:comment 'Indicates whether a payment token has been provisioned for this card for use in digital wallets or tokenized payment systems.' ;
    rdfs:domain ind:Card ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentSanctionsListEntryId rdf:type rdf:Property ;
    rdfs:label 'Parent Sanctions List Entry Id' ;
    rdfs:comment 'Self-referencing FK on sanctions_list_entry (parent_sanctions_list_entry_id)' ;
    rdfs:domain ind:SanctionsListEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SanctionsListEntry .

ind:aircraftManufacturer rdf:type rdf:Property ;
    rdfs:label 'Aircraft Manufacturer' ;
    rdfs:comment 'Manufacturer name of sanctioned aircraft. Null for non-aircraft entries.' ;
    rdfs:domain ind:SanctionsListEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aircraftModel rdf:type rdf:Property ;
    rdfs:label 'Aircraft Model' ;
    rdfs:comment 'Model designation of sanctioned aircraft. Null for non-aircraft entries.' ;
    rdfs:domain ind:SanctionsListEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aircraftTailNumber rdf:type rdf:Property ;
    rdfs:label 'Aircraft Tail Number' ;
    rdfs:comment 'Registration or tail number of sanctioned aircraft. Null for non-aircraft entries.' ;
    rdfs:domain ind:SanctionsListEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aliasNames rdf:type rdf:Property ;
    rdfs:label 'Alias Names' ;
    rdfs:comment 'Known aliases, alternate spellings, or also-known-as (AKA) names associated with the sanctioned party. Multiple aliases may be concatenated or stored as delimited text.' ;
    rdfs:domain ind:SanctionsListEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSourceTimestamp rdf:type rdf:Property ;
    rdfs:label 'Data Source Timestamp' ;
    rdfs:comment 'Timestamp indicating when the sanctions list data was last published or updated by the source authority.' ;
    rdfs:domain ind:SanctionsListEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:entryStatus rdf:type rdf:Property ;
    rdfs:label 'Entry Status' ;
    rdfs:comment 'Current lifecycle status of the sanctions list entry indicating whether it is actively enforced, removed, or under review.' ;
    rdfs:domain ind:SanctionsListEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPepIndicator rdf:type rdf:Property ;
    rdfs:label 'Is Pep Indicator' ;
    rdfs:comment 'Boolean flag indicating whether the sanctioned individual is also identified as a Politically Exposed Person (PEP) by the sanctions authority.' ;
    rdfs:domain ind:SanctionsListEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:listSourceName rdf:type rdf:Property ;
    rdfs:label 'List Source Name' ;
    rdfs:comment 'Name of the sanctions list source authority or program (e.g., OFAC SDN, UN Consolidated List, EU Sanctions List, HMT UK Sanctions List).' ;
    rdfs:domain ind:SanctionsListEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:listType rdf:type rdf:Property ;
    rdfs:label 'List Type' ;
    rdfs:comment 'Type of sanctioned party: individual person, legal entity, vessel, or aircraft.' ;
    rdfs:domain ind:SanctionsListEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nationalIdentificationNumber rdf:type rdf:Property ;
    rdfs:label 'National Identification Number' ;
    rdfs:comment 'National ID number, tax ID, or other government-issued identification number for sanctioned individuals or entities.' ;
    rdfs:domain ind:SanctionsListEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nationality rdf:type rdf:Property ;
    rdfs:label 'Nationality' ;
    rdfs:comment 'Country of nationality or citizenship for individuals, or country of incorporation/registration for entities. May contain multiple values.' ;
    rdfs:domain ind:SanctionsListEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:placeOfBirth rdf:type rdf:Property ;
    rdfs:label 'Place Of Birth' ;
    rdfs:comment 'City and country of birth for sanctioned individuals. Null for entities, vessels, and aircraft.' ;
    rdfs:domain ind:SanctionsListEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryName rdf:type rdf:Property ;
    rdfs:label 'Primary Name' ;
    rdfs:comment 'Primary legal name or designation of the sanctioned individual, entity, vessel, or aircraft as published by the sanctions authority.' ;
    rdfs:domain ind:SanctionsListEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programCode rdf:type rdf:Property ;
    rdfs:label 'Program Code' ;
    rdfs:comment 'Code identifying the specific sanctions program under which this entry is listed (e.g., SDGT for Specially Designated Global Terrorist, IRAN for Iran Sanctions).' ;
    rdfs:domain ind:SanctionsListEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programDescription rdf:type rdf:Property ;
    rdfs:label 'Program Description' ;
    rdfs:comment 'Full description of the sanctions program or legal authority under which the entry is designated.' ;
    rdfs:domain ind:SanctionsListEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remarks rdf:type rdf:Property ;
    rdfs:label 'Remarks' ;
    rdfs:comment 'Additional remarks, notes, or contextual information provided by the sanctions authority regarding the entry.' ;
    rdfs:domain ind:SanctionsListEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningPriority rdf:type rdf:Property ;
    rdfs:label 'Screening Priority' ;
    rdfs:comment 'Priority level assigned for real-time transaction screening and customer due diligence checks based on risk and regulatory requirements.' ;
    rdfs:domain ind:SanctionsListEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceUrl rdf:type rdf:Property ;
    rdfs:label 'Source Url' ;
    rdfs:comment 'URL or web link to the official sanctions list publication or entry detail page from the issuing authority.' ;
    rdfs:domain ind:SanctionsListEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uniqueReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Unique Reference Number' ;
    rdfs:comment 'Official unique identifier assigned by the sanctions authority to this entry (e.g., OFAC SDN number, UN reference number).' ;
    rdfs:domain ind:SanctionsListEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vesselCallSign rdf:type rdf:Property ;
    rdfs:label 'Vessel Call Sign' ;
    rdfs:comment 'Radio call sign assigned to sanctioned vessels. Null for non-vessel entries.' ;
    rdfs:domain ind:SanctionsListEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vesselFlag rdf:type rdf:Property ;
    rdfs:label 'Vessel Flag' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the flag state under which a sanctioned vessel is registered. Null for non-vessel entries.' ;
    rdfs:domain ind:SanctionsListEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vesselImoNumber rdf:type rdf:Property ;
    rdfs:label 'Vessel Imo Number' ;
    rdfs:comment 'IMO ship identification number for sanctioned vessels. Null for non-vessel entries.' ;
    rdfs:domain ind:SanctionsListEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vesselTonnage rdf:type rdf:Property ;
    rdfs:label 'Vessel Tonnage' ;
    rdfs:comment 'Gross tonnage of sanctioned vessels in metric tons. Null for non-vessel entries.' ;
    rdfs:domain ind:SanctionsListEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:distributionChannelId rdf:type rdf:Property ;
    rdfs:label 'Distribution Channel Id' ;
    rdfs:comment 'Foreign key linking to channel.channel. Business justification: Multi-tranche deals distribute different tranches through different channels (retail tranche via digital platform, institutional tranche via direct sales desk). Tranche-level distribution channel trac' ;
    rdfs:domain ind:Tranche ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:parentTrancheId rdf:type rdf:Property ;
    rdfs:label 'Parent Tranche Id' ;
    rdfs:comment 'Self-referencing FK on tranche (parent_tranche_id)' ;
    rdfs:domain ind:Tranche ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Tranche .

ind:amortizationSchedule rdf:type rdf:Property ;
    rdfs:label 'Amortization Schedule' ;
    rdfs:comment 'Description or reference to the detailed amortization schedule for the tranche.' ;
    rdfs:domain ind:Tranche ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callProvisionFlag rdf:type rdf:Property ;
    rdfs:label 'Call Provision Flag' ;
    rdfs:comment 'Indicates whether the tranche includes a call provision allowing early redemption by the issuer.' ;
    rdfs:domain ind:Tranche ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commitmentFeeRate rdf:type rdf:Property ;
    rdfs:label 'Commitment Fee Rate' ;
    rdfs:comment 'The commitment fee rate charged on undrawn amounts, expressed as a decimal.' ;
    rdfs:domain ind:Tranche ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:covenantPackage rdf:type rdf:Property ;
    rdfs:label 'Covenant Package' ;
    rdfs:comment 'Classification of the covenant structure attached to the tranche (e.g., covenant-lite, traditional).' ;
    rdfs:domain ind:Tranche ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prepaymentPenaltyFlag rdf:type rdf:Property ;
    rdfs:label 'Prepayment Penalty Flag' ;
    rdfs:comment 'Indicates whether a penalty applies for early prepayment of the tranche.' ;
    rdfs:domain ind:Tranche ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:securityType rdf:type rdf:Property ;
    rdfs:label 'Security Type' ;
    rdfs:comment 'Indicates whether the tranche is secured by collateral or unsecured.' ;
    rdfs:domain ind:Tranche ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seniorityLevel rdf:type rdf:Property ;
    rdfs:label 'Seniority Level' ;
    rdfs:comment 'Indicates the priority of the tranche in the repayment waterfall relative to other tranches.' ;
    rdfs:domain ind:Tranche ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trancheCode rdf:type rdf:Property ;
    rdfs:label 'Tranche Code' ;
    rdfs:comment 'Externally-known unique code or identifier for the tranche, used in deal documentation and regulatory filings.' ;
    rdfs:domain ind:Tranche ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trancheName rdf:type rdf:Property ;
    rdfs:label 'Tranche Name' ;
    rdfs:comment 'Human-readable name or label for the tranche, often indicating seniority or class (e.g., Senior Secured, Mezzanine, Class A).' ;
    rdfs:domain ind:Tranche ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trancheStatus rdf:type rdf:Property ;
    rdfs:label 'Tranche Status' ;
    rdfs:comment 'Current lifecycle status of the tranche.' ;
    rdfs:domain ind:Tranche ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trancheType rdf:type rdf:Property ;
    rdfs:label 'Tranche Type' ;
    rdfs:comment 'Classification of the tranche based on its position in the capital structure and risk profile.' ;
    rdfs:domain ind:Tranche ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:underwritingFeeRate rdf:type rdf:Property ;
    rdfs:label 'Underwriting Fee Rate' ;
    rdfs:comment 'The underwriting or arrangement fee rate charged for the tranche, expressed as a decimal percentage of principal.' ;
    rdfs:domain ind:Tranche ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:utilizationFeeRate rdf:type rdf:Property ;
    rdfs:label 'Utilization Fee Rate' ;
    rdfs:comment 'The utilization fee rate applied when drawn amounts exceed a specified threshold, expressed as a decimal.' ;
    rdfs:domain ind:Tranche ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:businessCountryId rdf:type rdf:Property ;
    rdfs:label 'Business Country Id' ;
    rdfs:comment 'Foreign key linking to reference.country. Business justification: Merchant country determines applicable regulatory requirements, interchange rules, AML risk rating, and cross-border payment rules. merchant has business_country_code as a plain text denormalized fiel' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:amlScreeningDate rdf:type rdf:Property ;
    rdfs:label 'Aml Screening Date' ;
    rdfs:comment 'Date when the merchant\'s AML screening was last performed.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:annualTransactionVolume rdf:type rdf:Property ;
    rdfs:label 'Annual Transaction Volume' ;
    rdfs:comment 'Estimated or actual annual transaction volume processed by the merchant in settlement currency.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageTransactionAmount rdf:type rdf:Property ;
    rdfs:label 'Average Transaction Amount' ;
    rdfs:comment 'Average value of individual transactions processed by the merchant in settlement currency.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:businessAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Business Address Line1' ;
    rdfs:comment 'First line of the merchant\'s registered business address.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Business Address Line2' ;
    rdfs:comment 'Second line of the merchant\'s registered business address (suite, floor, building).' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessCity rdf:type rdf:Property ;
    rdfs:label 'Business City' ;
    rdfs:comment 'City or municipality of the merchant\'s registered business address.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessPostalCode rdf:type rdf:Property ;
    rdfs:label 'Business Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the merchant\'s registered business address.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessStateProvince rdf:type rdf:Property ;
    rdfs:label 'Business State Province' ;
    rdfs:comment 'State, province, or region of the merchant\'s registered business address.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryCode rdf:type rdf:Property ;
    rdfs:label 'Category Code' ;
    rdfs:comment 'Four-digit ISO 18245 code classifying the merchant\'s type of business or trade.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargebackThresholdPercentage rdf:type rdf:Property ;
    rdfs:label 'Chargeback Threshold Percentage' ;
    rdfs:comment 'Maximum allowable chargeback ratio (as percentage of total transactions) before merchant is flagged for review.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:doingBusinessAsName rdf:type rdf:Property ;
    rdfs:label 'Doing Business As Name' ;
    rdfs:comment 'The trade name or DBA name under which the merchant operates, if different from legal name.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isHighRisk rdf:type rdf:Property ;
    rdfs:label 'Is High Risk' ;
    rdfs:comment 'Boolean flag indicating whether the merchant is classified as high-risk based on industry, geography, or transaction patterns.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:merchantStatus rdf:type rdf:Property ;
    rdfs:label 'Merchant Status' ;
    rdfs:comment 'Current lifecycle status of the merchant in the payment processing system.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:merchantType rdf:type rdf:Property ;
    rdfs:label 'Merchant Type' ;
    rdfs:comment 'Classification of the merchant based on transaction channel and business model.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pciAttestationDate rdf:type rdf:Property ;
    rdfs:label 'Pci Attestation Date' ;
    rdfs:comment 'Date of the merchant\'s most recent PCI DSS compliance attestation or validation.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pciComplianceLevel rdf:type rdf:Property ;
    rdfs:label 'Pci Compliance Level' ;
    rdfs:comment 'PCI DSS compliance level assigned to the merchant based on annual transaction volume.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportsCrossBorderPayments rdf:type rdf:Property ;
    rdfs:label 'Supports Cross Border Payments' ;
    rdfs:comment 'Boolean flag indicating whether the merchant is enabled to accept payments from international customers.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsRecurringPayments rdf:type rdf:Property ;
    rdfs:label 'Supports Recurring Payments' ;
    rdfs:comment 'Boolean flag indicating whether the merchant is enabled to process recurring or subscription-based payments.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentClearingHouseId rdf:type rdf:Property ;
    rdfs:label 'Parent Clearing House Id' ;
    rdfs:comment 'Self-referencing FK on clearing_house (parent_clearing_house_id)' ;
    rdfs:domain ind:ClearingHouse ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClearingHouse .

ind:clearingHouseCode rdf:type rdf:Property ;
    rdfs:label 'Clearing House Code' ;
    rdfs:comment 'Unique external code or identifier assigned to the clearing house by regulatory or industry bodies.' ;
    rdfs:domain ind:ClearingHouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingHouseStatus rdf:type rdf:Property ;
    rdfs:label 'Clearing House Status' ;
    rdfs:comment 'Current operational status of the clearing house in the trading and settlement ecosystem.' ;
    rdfs:domain ind:ClearingHouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingHouseType rdf:type rdf:Property ;
    rdfs:label 'Clearing House Type' ;
    rdfs:comment 'Classification of the clearing house based on the asset classes and services it provides.' ;
    rdfs:domain ind:ClearingHouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingModel rdf:type rdf:Property ;
    rdfs:label 'Clearing Model' ;
    rdfs:comment 'The clearing and settlement model employed by the clearing house.' ;
    rdfs:domain ind:ClearingHouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:connectivityProtocol rdf:type rdf:Property ;
    rdfs:label 'Connectivity Protocol' ;
    rdfs:comment 'Primary technical connectivity protocol used for trade submission and clearing (e.g., FIX, SWIFT, proprietary API).' ;
    rdfs:domain ind:ClearingHouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultFundRequired rdf:type rdf:Property ;
    rdfs:label 'Default Fund Required' ;
    rdfs:comment 'Indicates whether clearing members are required to contribute to a default fund or guarantee fund.' ;
    rdfs:domain ind:ClearingHouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:headquartersCity rdf:type rdf:Property ;
    rdfs:label 'Headquarters City' ;
    rdfs:comment 'City where the clearing house headquarters is located.' ;
    rdfs:domain ind:ClearingHouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marginModel rdf:type rdf:Property ;
    rdfs:label 'Margin Model' ;
    rdfs:comment 'The margin calculation methodology used by the clearing house for risk management.' ;
    rdfs:domain ind:ClearingHouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:membershipRequired rdf:type rdf:Property ;
    rdfs:label 'Membership Required' ;
    rdfs:comment 'Indicates whether direct membership is required to clear trades through this clearing house.' ;
    rdfs:domain ind:ClearingHouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:micCode rdf:type rdf:Property ;
    rdfs:label 'Mic Code' ;
    rdfs:comment 'ISO 10383 four-character Market Identifier Code uniquely identifying the clearing house in global markets.' ;
    rdfs:domain ind:ClearingHouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumCapitalRequirement rdf:type rdf:Property ;
    rdfs:label 'Minimum Capital Requirement' ;
    rdfs:comment 'Minimum capital requirement for clearing members in the settlement currency.' ;
    rdfs:domain ind:ClearingHouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nettingEligible rdf:type rdf:Property ;
    rdfs:label 'Netting Eligible' ;
    rdfs:comment 'Indicates whether the clearing house supports multilateral netting of trades.' ;
    rdfs:domain ind:ClearingHouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operatingHours rdf:type rdf:Property ;
    rdfs:label 'Operating Hours' ;
    rdfs:comment 'Standard operating hours of the clearing house, including time zone.' ;
    rdfs:domain ind:ClearingHouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentOrganization rdf:type rdf:Property ;
    rdfs:label 'Parent Organization' ;
    rdfs:comment 'Name of the parent company or holding entity that owns or operates the clearing house.' ;
    rdfs:domain ind:ClearingHouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportedAssetClasses rdf:type rdf:Property ;
    rdfs:label 'Supported Asset Classes' ;
    rdfs:comment 'Comma-separated list of asset classes supported by the clearing house (e.g., equities, fixed income, derivatives, commodities, FX).' ;
    rdfs:domain ind:ClearingHouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeReportingRequired rdf:type rdf:Property ;
    rdfs:label 'Trade Reporting Required' ;
    rdfs:comment 'Indicates whether trades cleared through this clearing house must be reported to trade repositories.' ;
    rdfs:domain ind:ClearingHouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scenarioAppetiteResultId rdf:type rdf:Property ;
    rdfs:label 'Scenario Appetite Result Id' ;
    rdfs:comment 'Primary key for the scenario_appetite_result association' ;
    rdfs:domain ind:ScenarioAppetiteResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:breachIndicator rdf:type rdf:Property ;
    rdfs:label 'Breach Indicator' ;
    rdfs:comment 'Indicates whether the stressed metric value breaches the appetite threshold defined on the linked appetite statement. A true value triggers escalation per the appetite breach_escalation_level.' ;
    rdfs:domain ind:ScenarioAppetiteResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stressedMetricValue rdf:type rdf:Property ;
    rdfs:label 'Stressed Metric Value' ;
    rdfs:comment 'The computed value of the risk appetite metric under the conditions of the linked stress scenario. Belongs to the intersection — the same appetite metric will have a different stressed value under each scenario.' ;
    rdfs:domain ind:ScenarioAppetiteResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stressedThresholdDelta rdf:type rdf:Property ;
    rdfs:label 'Stressed Threshold Delta' ;
    rdfs:comment 'The arithmetic difference between the stressed_metric_value and the appetite threshold (limit_value, range_lower_bound, or range_upper_bound as applicable). Negative values indicate headroom; positive values indicate breach magnitude.' ;
    rdfs:domain ind:ScenarioAppetiteResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:testDate rdf:type rdf:Property ;
    rdfs:label 'Test Date' ;
    rdfs:comment 'The date on which this stress scenario was formally evaluated against this appetite statement. Supports point-in-time governance reporting and audit trail.' ;
    rdfs:domain ind:ScenarioAppetiteResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reconciliationItemId rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Item Id' ;
    rdfs:comment 'Primary key for the reconciliation_item association' ;
    rdfs:domain ind:ReconciliationItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reconciliationSequence rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Sequence' ;
    rdfs:comment 'Indicates which cycle of the reconciliation process this item belongs to — initial run, amended run (after additional statement data arrives), or final run (after all breaks are resolved). Enables tracking of a transaction across multiple reconciliation cycles.' ;
    rdfs:domain ind:ReconciliationItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .
