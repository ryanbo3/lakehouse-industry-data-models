    rdfs:comment 'Standard cost per participant for the training course, used for budgeting and resource allocation planning.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:courseType rdf:type rdf:Property ;
