    rdfs:comment 'Classification of the training course by subject matter category. Distinguishes Good Clinical Practice (GCP) training from Standard Operating Procedure (SOP), regulatory, therapeutic area, technical skills, and safety training.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditUnits rdf:type rdf:Property ;
